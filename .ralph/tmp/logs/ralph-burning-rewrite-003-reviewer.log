elf) -> String {\n    50\t        match self {\n    51\t            Self::Bool(value) => value.to_string(),\n    52\t            Self::FlowPreset(value) => format!(\"\\\"{}\\\"\", value.as_str()),\n    53\t            Self::String(Some(value)) => format!(\"\\\"{value}\\\"\"),\n    54\t            Self::String(None) => \"\\\"<unset>\\\"\".to_owned(),\n    55\t        }\n    56\t    }\n    57\t}\n    58\t\n    59\t#[derive(Debug, Clone, PartialEq, Eq)]\n    60\tpub struct ConfigEntry {\n    61\t    pub key: &'static str,\n    62\t    pub value: ConfigValue,\n    63\t    pub source: ConfigValueSource,\n    64\t}\n    65\t\n    66\t#[derive(Debug, Clone, PartialEq, Eq)]\n    67\tstruct ResolvedValue<T> {\n    68\t    value: T,\n    69\t    source: ConfigValueSource,\n    70\t}\n    71\t\n    72\t#[derive(Debug, Clone, PartialEq, Eq)]\n    73\tpub struct EffectiveConfig {\n    74\t    prompt_review_enabled: ResolvedValue<bool>,\n    75\t    default_flow: ResolvedValue<FlowPreset>,\n    76\t    default_backend: ResolvedValue<Option<String>>,\n    77\t    default_model: ResolvedValue<Option<String>>,\n    78\t}\n    79\t\n    80\timpl EffectiveConfig {\n    81\t    pub fn load(base_dir: &Path) -> AppResult<Self> {\n    82\t        let config = load_workspace_config(base_dir)?;\n    83\t        Ok(Self::from_workspace_config(&config))\n    84\t    }\n    85\t\n    86\t    pub fn get(&self, key: &str) -> AppResult<ConfigEntry> {\n    87\t        let key = ConfigKey::parse(key)?;\n    88\t        Ok(self.entry_for(key))\n    89\t    }\n    90\t\n    91\t    pub fn set(base_dir: &Path, key: &str, value: &str) -> AppResult<ConfigEntry> {\n    92\t        let key = ConfigKey::parse(key)?;\n    93\t        let _ = Self::load(base_dir)?;\n    94\t\n    95\t        let config_path = workspace_config_path(base_dir);\n    96\t        let raw = FileSystem::read_to_string(&config_path)?;\n    97\t        let mut document = raw.parse::<DocumentMut>()?;\n    98\t        key.apply_to_document(&mut document, value)?;\n    99\t        FileSystem::write_atomic(&config_path, &document.to_string())?;\n   100\t\n   101\t        Self::load(base_dir)?.get(key.as_str())\n   102\t    }\n   103\t\n   104\t    pub fn entries(&self) -> Vec<ConfigEntry> {\n   105\t        ConfigKey::ALL\n   106\t            .iter()\n   107\t            .copied()\n   108\t            .map(|key| self.entry_for(key))\n   109\t            .collect()\n   110\t    }\n   111\t\n   112\t    /// Default: `true`.\n   113\t    pub fn prompt_review_enabled(&self) -> bool {\n   114\t        self.prompt_review_enabled.value\n   115\t    }\n   116\t\n   117\t    /// Default: `standard`.\n   118\t    pub fn default_flow(&self) -> FlowPreset {\n   119\t        self.default_flow.value\n   120\t    }\n   121\t\n   122\t    /// Default: unset.\n   123\t    pub fn default_backend(&self) -> Option<&str> {\n   124\t        self.default_backend.value.as_deref()\n   125\t    }\n   126\t\n   127\t    /// Default: unset.\n   128\t    pub fn default_model(&self) -> Option<&str> {\n   129\t        self.default_model.value.as_deref()\n   130\t    }\n   131\t\n   132\t    fn from_workspace_config(config: &WorkspaceConfig) -> Self {\n   133\t        let settings = &config.settings;\n   134\t        Self {\n   135\t            prompt_review_enabled: resolve_value(\n   136\t                settings.prompt_review.enabled,\n   137\t                DEFAULT_PROMPT_REVIEW_ENABLED,\n   138\t            ),\n   139\t            default_flow: resolve_value(settings.default_flow, DEFAULT_FLOW_PRESET),\n   140\t            default_backend: resolve_optional_value(settings.default_backend.as_ref()),\n   141\t            default_model: resolve_optional_value(settings.default_model.as_ref()),\n   142\t        }\n   143\t    }\n   144\t\n   145\t    fn entry_for(&self, key: ConfigKey) -> ConfigEntry {\n   146\t        match key {\n   147\t            ConfigKey::PromptReviewEnabled => ConfigEntry {\n   148\t                key: key.as_str(),\n   149\t                value: ConfigValue::Bool(self.prompt_review_enabled()),\n   150\t                source: self.prompt_review_enabled.source,\n   151\t            },\n   152\t            ConfigKey::DefaultFlow => ConfigEntry {\n   153\t                key: key.as_str(),\n   154\t                value: ConfigValue::FlowPreset(self.default_flow()),\n   155\t                source: self.default_flow.source,\n   156\t            },\n   157\t            ConfigKey::DefaultBackend => ConfigEntry {\n   158\t                key: key.as_str(),\n   159\t                value: ConfigValue::String(self.default_backend.value.clone()),\n   160\t                source: self.default_backend.source,\n   161\t            },\n   162\t            ConfigKey::DefaultModel => ConfigEntry {\n   163\t                key: key.as_str(),\n   164\t                value: ConfigValue::String(self.default_model.value.clone()),\n   165\t                source: self.default_model.source,\n   166\t            },\n   167\t        }\n   168\t    }\n   169\t}\n   170\t\n   171\tfn resolve_value<T: Copy>(value: Option<T>, default: T) -> ResolvedValue<T> {\n   172\t    match value {\n   173\t        Some(value) => ResolvedValue {\n   174\t            value,\n   175\t            source: ConfigValueSource::WorkspaceToml,\n   176\t        },\n   177\t        None => ResolvedValue {\n   178\t            value: default,\n   179\t            source: ConfigValueSource::Default,\n   180\t        },\n   181\t    }\n   182\t}\n   183\t\n   184\tfn resolve_optional_value(value: Option<&String>) -> ResolvedValue<Option<String>> {\n   185\t    match value {\n   186\t        Some(value) => ResolvedValue {\n   187\t            value: Some(value.clone()),\n   188\t            source: ConfigValueSource::WorkspaceToml,\n   189\t        },\n   190\t        None => ResolvedValue {\n   191\t            value: None,\n   192\t            source: ConfigValueSource::Default,\n   193\t        },\n   194\t    }\n   195\t}\n   196\t\n   197\t#[derive(Debug, Clone, Copy, PartialEq, Eq)]\n   198\tenum ConfigKey {\n   199\t    PromptReviewEnabled,\n   200\t    DefaultFlow,\n   201\t    DefaultBackend,\n   202\t    DefaultModel,\n   203\t}\n   204\t\n   205\timpl ConfigKey {\n   206\t    const ALL: [Self; 4] = [\n   207\t        Self::PromptReviewEnabled,\n   208\t        Self::DefaultFlow,\n   209\t        Self::DefaultBackend,\n   210\t        Self::DefaultModel,\n   211\t    ];\n   212\t\n   213\t    fn parse(value: &str) -> AppResult<Self> {\n   214\t        match value {\n   215\t            \"prompt_review.enabled\" => Ok(Self::PromptReviewEnabled),\n   216\t            \"default_flow\" => Ok(Self::DefaultFlow),\n   217\t            \"default_backend\" => Ok(Self::DefaultBackend),\n   218\t            \"default_model\" => Ok(Self::DefaultModel),\n   219\t            _ => Err(AppError::UnknownConfigKey {\n   220\t                key: value.to_owned(),\n   221\t            }),\n   222\t        }\n   223\t    }\n   224\t\n   225\t    fn as_str(self) -> &'static str {\n   226\t        match self {\n   227\t            Self::PromptReviewEnabled => \"prompt_review.enabled\",\n   228\t            Self::DefaultFlow => \"default_flow\",\n   229\t            Self::DefaultBackend => \"default_backend\",\n   230\t            Self::DefaultModel => \"default_model\",\n   231\t        }\n   232\t    }\n   233\t\n   234\t    fn apply_to_document(self, document: &mut DocumentMut, raw_value: &str) -> AppResult<()> {\n   235\t        match self {\n   236\t            Self::PromptReviewEnabled => {\n   237\t                let parsed = parse_bool(self.as_str(), raw_value)?;\n   238\t                document[\"settings\"][\"prompt_review\"][\"enabled\"] = value(parsed);\n   239\t            }\n   240\t            Self::DefaultFlow => {\n   241\t                let parsed = parse_flow_preset(self.as_str(), raw_value)?;\n   242\t                document[\"settings\"][\"default_flow\"] = value(parsed.as_str());\n   243\t            }\n   244\t            Self::DefaultBackend => apply_optional_string(document, \"default_backend\", raw_value)?,\n   245\t            Self::DefaultModel => apply_optional_string(document, \"default_model\", raw_value)?,\n   246\t        }\n   247\t\n   248\t        Ok(())\n   249\t    }\n   250\t}\n   251\t\n   252\tfn parse_bool(key: &str, raw_value: &str) -> AppResult<bool> {\n   253\t    match raw_value.trim() {\n   254\t        \"true\" => Ok(true),\n   255\t        \"false\" => Ok(false),\n   256\t        _ => Err(AppError::InvalidConfigValue {\n   257\t            key: key.to_owned(),\n   258\t            value: raw_value.to_owned(),\n   259\t            reason: \"expected `true` or `false`\".to_owned(),\n   260\t        }),\n   261\t    }\n   262\t}\n   263\t\n   264\tfn parse_flow_preset(key: &str, raw_value: &str) -> AppResult<FlowPreset> {\n   265\t    raw_value\n   266\t        .trim()\n   267\t        .parse::<FlowPreset>()\n   268\t        .map_err(|_| AppError::InvalidConfigValue {\n   269\t            key: key.to_owned(),\n   270\t            value: raw_value.to_owned(),\n   271\t            reason: \"expected one of: standard, quick_dev, docs_change, ci_improvement\".to_owned(),\n   272\t        })\n   273\t}\n   274\t\n   275\tfn parse_optional_string(key: &str, raw_value: &str) -> AppResult<Option<String>> {\n   276\t    let trimmed = raw_value.trim();\n   277\t    if trimmed.is_empty() {\n   278\t        return Err(AppError::InvalidConfigValue {\n   279\t            key: key.to_owned(),\n   280\t            value: raw_value.to_owned(),\n   281\t            reason: \"expected a non-empty string or one of: unset, none, null\".to_owned(),\n   282\t        });\n   283\t    }\n   284\t\n   285\t    if matches!(trimmed, \"unset\" | \"none\" | \"null\") {\n   286\t        Ok(None)\n   287\t    } else {\n   288\t        Ok(Some(trimmed.to_owned()))\n   289\t    }\n   290\t}\n   291\t\n   292\tfn apply_optional_string(\n   293\t    document: &mut DocumentMut,\n   294\t    setting_name: &str,\n   295\t    raw_value: &str,\n   296\t) -> AppResult<()> {\n   297\t    match parse_optional_string(setting_name, raw_value)? {\n   298\t        Some(parsed) => {\n   299\t            document[\"settings\"][setting_name] = value(parsed);\n   300\t        }\n   301\t        None => {\n   302\t            if let Some(settings) = document\n   303\t                .as_table_mut()\n   304\t                .get_mut(\"settings\")\n   305\t                .and_then(|item| item.as_table_mut())\n   306\t            {\n   307\t                settings.remove(setting_name);\n   308\t            }\n   309\t        }\n   310\t    }\n   311\t\n   312\t    Ok(())\n   313\t}\n","exit_code":0,"status":"completed"}}
{"type":"item.completed","item":{"id":"item_12","type":"command_execution","command":"/run/current-system/sw/bin/bash -lc \"nl -ba ralph-burning-rewrite/src/adapters/fs.rs | sed -n '1,260p'\"","aggregated_output":"     1\tuse std::env;\n     2\tuse std::fs::{self, OpenOptions};\n     3\tuse std::io::Write;\n     4\tuse std::path::Path;\n     5\tuse std::process::Command;\n     6\tuse std::time::{SystemTime, UNIX_EPOCH};\n     7\t\n     8\tuse crate::shared::domain::WorkspaceConfig;\n     9\tuse crate::shared::error::{AppError, AppResult};\n    10\t\n    11\tconst ACTIVE_PROJECT_FILE: &str = \"active-project\";\n    12\t\n    13\tpub struct FileSystem;\n    14\t\n    15\timpl FileSystem {\n    16\t    pub fn create_workspace(\n    17\t        workspace_root: &Path,\n    18\t        workspace_config: &str,\n    19\t        required_directories: &[&str],\n    20\t    ) -> AppResult<()> {\n    21\t        fs::create_dir_all(workspace_root)?;\n    22\t\n    23\t        for directory in required_directories {\n    24\t            fs::create_dir_all(workspace_root.join(directory))?;\n    25\t        }\n    26\t\n    27\t        Self::write_atomic(&workspace_root.join(\"workspace.toml\"), workspace_config)?;\n    28\t        Ok(())\n    29\t    }\n    30\t\n    31\t    pub fn read_to_string(path: &Path) -> AppResult<String> {\n    32\t        Ok(fs::read_to_string(path)?)\n    33\t    }\n    34\t\n    35\t    pub fn write_atomic(path: &Path, contents: &str) -> AppResult<()> {\n    36\t        let parent = path.parent().ok_or_else(|| {\n    37\t            AppError::Io(std::io::Error::new(\n    38\t                std::io::ErrorKind::InvalidInput,\n    39\t                format!(\"path '{}' has no parent directory\", path.display()),\n    40\t            ))\n    41\t        })?;\n    42\t        fs::create_dir_all(parent)?;\n    43\t\n    44\t        let timestamp = SystemTime::now()\n    45\t            .duration_since(UNIX_EPOCH)\n    46\t            .map(|duration| duration.as_nanos())\n    47\t            .unwrap_or_default();\n    48\t        let temp_path = parent.join(format!(\n    49\t            \".{}.{}.{}.tmp\",\n    50\t            path.file_name()\n    51\t                .and_then(|value| value.to_str())\n    52\t                .unwrap_or(\"workspace\"),\n    53\t            std::process::id(),\n    54\t            timestamp\n    55\t        ));\n    56\t\n    57\t        let mut file = OpenOptions::new()\n    58\t            .create_new(true)\n    59\t            .write(true)\n    60\t            .open(&temp_path)?;\n    61\t        file.write_all(contents.as_bytes())?;\n    62\t        file.sync_all()?;\n    63\t        drop(file);\n    64\t\n    65\t        if let Err(error) = fs::rename(&temp_path, path) {\n    66\t            let _ = fs::remove_file(&temp_path);\n    67\t            return Err(error.into());\n    68\t        }\n    69\t\n    70\t        Ok(())\n    71\t    }\n    72\t\n    73\t    pub fn render_workspace_config(config: &WorkspaceConfig) -> AppResult<String> {\n    74\t        Ok(toml::to_string_pretty(config)?)\n    75\t    }\n    76\t\n    77\t    pub fn read_active_project(workspace_root: &Path) -> AppResult<Option<String>> {\n    78\t        let path = workspace_root.join(ACTIVE_PROJECT_FILE);\n    79\t        match fs::read_to_string(path) {\n    80\t            Ok(raw) => {\n    81\t                let trimmed = raw.trim();\n    82\t                if trimmed.is_empty() {\n    83\t                    Ok(None)\n    84\t                } else {\n    85\t                    Ok(Some(trimmed.to_owned()))\n    86\t                }\n    87\t            }\n    88\t            Err(error) if error.kind() == std::io::ErrorKind::NotFound => Ok(None),\n    89\t            Err(error) => Err(error.into()),\n    90\t        }\n    91\t    }\n    92\t\n    93\t    pub fn write_active_project(workspace_root: &Path, project_id: &str) -> AppResult<()> {\n    94\t        Self::write_atomic(&workspace_root.join(ACTIVE_PROJECT_FILE), project_id)\n    95\t    }\n    96\t\n    97\t    pub fn open_editor(path: &Path) -> AppResult<()> {\n    98\t        let editor = env::var(\"VISUAL\")\n    99\t            .ok()\n   100\t            .filter(|value| !value.trim().is_empty())\n   101\t            .or_else(|| {\n   102\t                env::var(\"EDITOR\")\n   103\t                    .ok()\n   104\t                    .filter(|value| !value.trim().is_empty())\n   105\t            })\n   106\t            .unwrap_or_else(|| \"vi\".to_owned());\n   107\t\n   108\t        let mut parts = editor.split_whitespace();\n   109\t        let program = parts.next().ok_or_else(|| AppError::EditorFailed {\n   110\t            editor: editor.clone(),\n   111\t            details: \": empty editor command\".to_owned(),\n   112\t        })?;\n   113\t        let status = Command::new(program).args(parts).arg(path).status()?;\n   114\t\n   115\t        if status.success() {\n   116\t            Ok(())\n   117\t        } else {\n   118\t            let details = match status.code() {\n   119\t                Some(code) => format!(\" with exit code {code}\"),\n   120\t                None => \" after being terminated by a signal\".to_owned(),\n   121\t            };\n   122\t            Err(AppError::EditorFailed { editor, details })\n   123\t        }\n   124\t    }\n   125\t}\n","exit_code":0,"status":"completed"}}
