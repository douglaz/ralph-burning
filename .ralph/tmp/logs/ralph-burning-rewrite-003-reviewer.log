r {\n    55\t        match self {\n    56\t            Self::Standard => {\n    57\t                \"Full delivery flow with planning, implementation, QA, review, and acceptance.\"\n    58\t            }\n    59\t            Self::QuickDev => \"Fast delivery flow for small code changes with lightweight review.\",\n    60\t            Self::DocsChange => {\n    61\t                \"Documentation-focused flow for planning, content updates, and validation.\"\n    62\t            }\n    63\t            Self::CiImprovement => {\n    64\t                \"CI improvement flow for automation planning, updates, and validation.\"\n    65\t            }\n    66\t        }\n    67\t    }\n    68\t}\n    69\t\n    70\timpl fmt::Display for FlowPreset {\n    71\t    fn fmt(&self, f: &mut fmt::Formatter<'_>) -> fmt::Result {\n    72\t        f.write_str(self.as_str())\n    73\t    }\n    74\t}\n    75\t\n    76\timpl FromStr for FlowPreset {\n    77\t    type Err = AppError;\n    78\t\n    79\t    fn from_str(value: &str) -> Result<Self, Self::Err> {\n    80\t        match value {\n    81\t            \"standard\" => Ok(Self::Standard),\n    82\t            \"quick_dev\" => Ok(Self::QuickDev),\n    83\t            \"docs_change\" => Ok(Self::DocsChange),\n    84\t            \"ci_improvement\" => Ok(Self::CiImprovement),\n    85\t            _ => Err(AppError::InvalidFlowPreset {\n    86\t                flow_id: value.to_owned(),\n    87\t            }),\n    88\t        }\n    89\t    }\n    90\t}\n    91\t\n    92\t#[derive(Debug, Clone, Copy, PartialEq, Eq, Hash, Serialize, Deserialize)]\n    93\t#[serde(rename_all = \"snake_case\")]\n    94\tpub enum StageId {\n    95\t    PromptReview,\n    96\t    Planning,\n    97\t    Implementation,\n    98\t    Qa,\n    99\t    Review,\n   100\t    CompletionPanel,\n   101\t    AcceptanceQa,\n   102\t    FinalReview,\n   103\t    PlanAndImplement,\n   104\t    ApplyFixes,\n   105\t    DocsPlan,\n   106\t    DocsUpdate,\n   107\t    Do