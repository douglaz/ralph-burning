Check {\n    pub fn success(target: &ResolvedBackendTarget, contract: &InvocationContract) -> Self {\n        Self {\n            backend: target.backend.clone(),\n            model: target.model.clone(),\n            contract_id: contract.label(),\n            supported: true,\n            details: None,\n        }\n","exit_code":0,"status":"completed"}}
