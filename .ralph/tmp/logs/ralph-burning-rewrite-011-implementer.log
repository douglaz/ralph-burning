attempt_count\n   169\t    );\n   170\t    Ok(())\n   171\t}\n   172\t\n   173\tasync fn handle_reconcile(ttl_seconds: Option<u64>) -> AppResult<()> {\n   174\t    let current_dir = std::env::current_dir()?;\n   175\t    let config = workspace_governance::load_workspace_config(&current_dir)?;\n   176\t    workspace_governance::ensure_supported_workspace_version(&config)?;\n   177\t\n   178\t    let store = FsDaemonStore;\n   179\t    let worktree = WorktreeAdapter;\n   180\t    let report = LeaseService::reconcile(\n   181\t        &store,\n   182\t        &worktree,\n   183\t        &current_dir,\n   184\t        &current_dir,\n   185\t        ttl_seconds,\n   186\t        chrono::Utc::now(),\n   187\t    )?;\n   188\t\n   189\t    println!(\n   190\t        \"reconciled stale_leases={} failed_tasks={} released_leases={}\",\n   191\t        report.stale_lease_ids.len(),\n   192\t        report.failed_task_ids.len(),\n   193\t        report.released_lease_ids.len()\n   194\t    );\n   195\t    Ok(())\n   196\t}\n   197\t\n   198\tasync fn cleanup_aborted_task(\n   199\t    store: &dyn DaemonStorePort,\n   200\t    worktree: &WorktreeAdapter,\n   201\t    base_dir: &std::path::Path,\n   202\t    task_id: &str,\n   203\t    original_status: TaskStatus,\n   204\t) -> AppResult<()> {\n   205\t    let grace_deadline = std::time::Instant::now() + std::time::Duration::from_secs(1);\n   206\t    let await_daemon_cleanup = original_status == TaskStatus::Active;\n   207\t\n   208\t    loop {\n   209\t        let lease = LeaseService::find_lease_for_task(store, base_dir, task_id)?;\n   210\t        let Some(lease) = lease else {\n   211\t            let task = store.read_task(base_dir, task_id)?;\n   212\t            if task.lease_id.is_some() {\n   213\t                DaemonTaskService::clear_lease_reference(store, base_dir, task_id)?;\n   214\t            }\n   215\t            return Ok(());\n   216\t        };\n   217\t\n   218\t        if await_daemon_cleanup && std::time::Instant::now() < grace_deadline {\n   219\t            tokio::time::sleep(std::time::Duration::from_millis(100)).await;\n   220\t            continue;\n   221\t        }\n   222\t\n   223\t        let release_result = LeaseService::release(store, worktree, base_dir, base_dir, &lease);\n   224\t        let clear_result =\n   225\t            DaemonTaskService::clear_lease_reference(store, base_dir, task_id).map(|_| ());\n   226\t        return match (release_result, clear_result) {\n   227\t            (Ok(()), Ok(())) => Ok(()),\n   228\t            (Err(error), Ok(())) => Err(error),\n   229\t            (Ok(()), Err(error)) => Err(error),\n   230\t            (Err(error), Err(_)) => Err(error),\n   231\t        };\n   232\t    }\n   233\t}\n","exit_code":0,"status":"completed"}}
