pshot_write,\n  2067→        base_dir,\n  2068→        project_id,\n  2069→        origin,\n  2070→    )\n  2071→    .await\n  2072→}\n  2073→\n  2074→fn failure_label(error: &AppError) -> String {\n  2075→    if let Some(failure_class) = error.failure_class() {\n  2076→        return failure_class.as_str().to_owned();\n  2077→    }\n  2078→\n  2079→    match error {\n  2080→        AppError::RemediationExhausted { .. } => \"remediation_exhausted\".to_owned(),\n  2081→        AppError::ResumeFailed { .. } => \"resume_failed\".to_owned(),\n  2082→        _ => \"unknown\".to_owned(),\n  2083→    }\n  2084→}\n  2085→\n  2086→fn prompt_review_requires_pause(payload: &StagePayload) -> bool {\n  2087→    matches!(\n  2088→        payload,\n  2089→        StagePayload::Planning(planning) if !planning.readiness.ready\n  2090→    )\n  2091→}\n  2092→\n  2093→fn validation_outcome(payload: &StagePayload) -> Option<ReviewOutcome> {\n  2094→    match payload {\n  2095→        StagePayload::Validation(validation) => Some(validation.outcome),\n  2096→        _ => None,\n  2097→    }\n  2098→}\n  2099→\n  2100→fn validation_follow_ups(payload: &StagePayload) -> &[String] {\n  2101→    match payload {\n  2102→        StagePayload::Validation(validation) => &validation.follow_up_or_amendments,\n  2103→        _ => &[],\n  2104→    }\n  2105→}\n  2106→\n  2107→/// Build typed QueuedAmendment records from follow-up strings.\n  2108→fn build_queued_amendments(\n  2109→    follow_ups: &[String],"}]},"parent_tool_use_id":"toolu_01WxWEKeVM8eN1eTgMgZkDxS","session_id":"3d9a0615-7442-4a66-ab27-f8160d110223","uuid":"9adc6df5-65b2-4059-ba76-7654f374af1a"}
