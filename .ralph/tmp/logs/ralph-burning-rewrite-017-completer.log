{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01NyLVFyfim4ERU9qK5AEaFw","type":"tool_result","content":"     1→use std::path::Path;\n     2→\n     3→use crate::contexts::automation_runtime::model::WatchedIssueMeta;\n     4→use crate::contexts::automation_runtime::watcher::IssueWatcherPort;\n     5→use crate::shared::error::AppResult;\n     6→\n     7→/// File-based issue watcher that reads candidate issues from\n     8→/// `.ralph-burning/daemon/watched/*.json`.\n     9→///\n    10→/// Each JSON file represents a watched issue candidate with fields matching\n    11→/// `WatchedIssueMeta`. The daemon polls this directory each cycle.\n    12→pub struct FileIssueWatcher;\n    13→\n    14→impl IssueWatcherPort for FileIssueWatcher {\n    15→    fn poll(&self, base_dir: &Path) -> AppResult<Vec<WatchedIssueMeta>> {\n    16→        let watched_dir = base_dir\n    17→            .join(\".ralph-burning\")\n    18→            .join(\"daemon\")\n    19→            .join(\"watched\");\n    20→\n    21→        if !watched_dir.is_dir() {\n    22→            return Ok(Vec::new());\n    23→        }\n    24→\n    25→        let mut candidates = Vec::new();\n    26→        for entry in std::fs::read_dir(&watched_dir)? {\n    27→            let entry = entry?;\n    28→            let path = entry.path();\n    29→            if !path.extension().is_some_and(|ext| ext == \"json\") {\n    30→                continue;\n    31→            }\n    32→            let contents = std::fs::read_to_string(&path)?;\n    33→            let meta: WatchedIssueMeta = serde_json::from_str(&contents)?;\n    34→            candidates.push(meta);\n    35→        }\n    36→\n    37→        Ok(candidates)\n    38→    }\n    39→}\n    40→\n    41→/// In-memory watcher for testing. Returns a fixed set of candidates.\n    42→pub struct InMemoryIssueWatcher {\n    43→    pub candidates: Vec<WatchedIssueMeta>,\n    44→}\n    45→\n    46→impl InMemoryIssueWatcher {\n    47→    pub fn new(candidates: Vec<WatchedIssueMeta>) -> Self {\n    48→        Self { candidates }\n    49→    }\n    50→\n    51→    pub fn empty() -> Self {\n    52→        Self {\n    53→            candidates: Vec::new(),\n    54→        }\n    55→    }\n    56→}\n    57→\n    58→impl IssueWatcherPort for InMemoryIssueWatcher {\n    59→    fn poll(&self, _base_dir: &Path) -> AppResult<Vec<WatchedIssueMeta>> {\n    60→        Ok(self.candidates.clone())\n    61→    }\n    62→}\n    63→"}]},"parent_tool_use_id":"toolu_01KfEVp49FXGUv77ZeSPdiaP","session_id":"3d9a0615-7442-4a66-ab27-f8160d110223","uuid":"fbf07c9a-41dd-4e2f-933a-47bcc009fff5"}
