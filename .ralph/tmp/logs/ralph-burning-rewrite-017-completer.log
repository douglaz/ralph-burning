58→            StageId::DocsValidation,\n    59→            StageId::Review,\n    60→        ],\n    61→        flow_definition(FlowPreset::DocsChange).stages\n    62→    );\n    63→}\n    64→\n    65→#[test]\n    66→fn ci_improvement_flow_stage_order_matches_spec() {\n    67→    assert_eq!(\n    68→        &[\n    69→            StageId::CiPlan,\n    70→            StageId::CiUpdate,\n    71→            StageId::CiValidation,\n    72→            StageId::Review,\n    73→        ],\n    74→        flow_definition(FlowPreset::CiImprovement).stages\n    75→    );\n    76→}\n    77→"}]},"parent_tool_use_id":"toolu_01MHSrvSzvPbhimpWpfubf5n","session_id":"3d9a0615-7442-4a66-ab27-f8160d110223","uuid":"34c4a4e4-17a5-4c3a-b4e8-0b354c2c438b"}
