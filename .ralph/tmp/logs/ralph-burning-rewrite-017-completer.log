aFail { iteration }\n   153→            | Self::ImplQaResponse { iteration }\n   154→            | Self::QuickDevApplyFixes { iteration }\n   155→            | Self::PreCommitCheckFailure { iteration }\n   156→            | Self::ImplPreCommitResponse { iteration } => Some(*iteration),\n   157→            _ => None,\n   158→        }\n   159→    }\n   160→\n   161→    pub fn iterations(&self) -> Option<u32> {\n   162→        match self {\n   163→            Self::ReviewApproved { iterations } => Some(*iterations),\n   164→            _ => None,\n   165→        }\n   166→    }\n   167→}\n   168→\n   169→#[derive(Debug, Clone)]\n   170→pub struct ArtifactWriteInput<'a> {\n   171→    pub project_id: &'a str,\n   172→    pub loop_number: u32,\n   173→    pub loop_slug: &'a str,\n   174→    pub backend: &'a str,\n   175→    pub role: &'a str,\n   176→    pub kind: ArtifactKind,\n   177→    pub body: &'a str,\n   178→}\n   179→\n   180→#[derive(Debug, Clone)]\n   181→pub struct ProjectScopedArtifactWriteInput<'a> {\n   182→    pub artifact: &'a str,\n   183→    pub file_name: &'a str,\n   184→    pub project_id: &'a str,\n   185→    pub backend: &'a str,\n   186→    pub role: &'a str,\n   187→    pub body: &'a str,\n   188→}\n   189→\n   190→pub fn write_artifact(project_dir: &Path, input: ArtifactWriteInput<'_>) -> Result<PathBuf> {\n   191→    let loop_dir_name = format!(\"{:03}-{}\", input.loop_number, input.loop_slug);\n   192→    let loop_dir = project_dir.join(\"loops\").join(loop_dir_name);\n   193→    fs::create_dir_all(&loop_dir)?;\n   194→\n   195→    let now = now_utc();\n   196→    let created_at = now.to_rfc3339_opts(chrono::SecondsFormat::Secs, true);\n   197→    let timestamp = format_timestamp_yyyymmddhhmmss(now);\n   198→    let artifact_path = loop_dir.join(input.kind.file_name_with_timestamp(&timestamp));\n   199→    let body = strip_backend_frontmatter(input.body);\n   200→\n   201→    let mut fm = String::from(\"---\\n\");\n   202→    fm.push_str(&format!(\"artifact: {}\\n\", input.kind.base_type()));\n   203→    fm.push_str(&format!(\"loop: {}\\n\", input.loop_number));\n   204→    if let Some(iteration) = input.kind.iteration() {\n   205→        fm.push_str(&format!(\"iteration: {iteration}\\n\"));\n   206→    }\n   207→    if let Some(iterations) = input.kind.iterations() {\n   208→        fm.push_str(&format!(\"iterations: {iterations}\\n\"));\n   209→    }\n   210→    fm.push_str(&format!(\"project: {}\\n\", input.project_id));\n   211→    fm.push_str(&format!(\"backend: {}\\n\", input.backend));\n   212→    fm.push_str(&format!(\"role: {}\\n\", input.role));\n   213→    fm.push_str(&format!(\"created_at: {created_at}\\n\"));\n   214→    fm.push_str(\"---\\n\\n\");\n   215→\n   216→    let content = format!(\"{}{body}\\n\", fm);\n   217→    fs::write(&artifact_path, content)?;\n   218→\n   219→    Ok(artifact_path)\n   220→}\n   221→\n   222→pub fn write_project_scoped_artifact(\n   223→    project_dir: &Path,\n   224→    input: ProjectScopedArtifactWriteInput<'_>,\n   225→) -> Result<PathBuf> {\n   226→    let now = now_utc();\n   227→    let created_at = now.to_rfc3339_opts(chrono::SecondsFormat::Secs, true);\n   228→    let artifact_path = project_dir.join(input.file_name);\n   229→    let body = strip_backend_frontmatter(input.body);\n   230→\n   231→    let mut fm = String::from(\"---\\n\");\n   232→    fm.push_str(&format!(\"artifact: {}\\n\", input.artifact));\n   233→    fm.push_str(&format!(\"project: {}\\n\", input.project_id));\n   234→    fm.push_str(&format!(\"backend: {}\\n\", input.backend));\n   235→    fm.push_str(&format!(\"role: {}\\n\", input.role));\n   236→    fm.push_str(&format!(\"created_at: {created_at}\\n\"));\n   237→    fm.push_str(\"---\\n\\n\");\n   238→\n   239→    let content = format!(\"{}{body}\\n\", fm);\n   240→    fs::write(&artifact_path, content)?;\n   241→\n   242→    Ok(artifact_path)\n   243→}\n   244→\n   245→pub fn artifact_relative_path(project_dir: &Path, artifact_path: &Path) -> String {\n   246→    artifact_path\n   247→        .strip_prefix(project_dir)\n   248→        .unwrap_or(artifact_path)\n   249→        .to_string_lossy()\n   250→        .replace('\\\\', \"/\")\n   251→}\n   252→\n   253→pub fn parse_artifact_filename_timestamp(file_name: &str) -> Option<String> {\n   254→    let (prefix, _) = file_name.split_once('-')?;\n   255→    if prefix.len() == ARTIFACT_TIMESTAMP_LEN && prefix.chars().all(|c| c.is_ascii_digit()) {\n   256→        Some(prefix.to_owned())\n   257→    } else {\n   258→        None\n   259→    }\n   260→}\n   261→\n   262→pub fn resolve_artifact_path_by_suffix(\n   263→    project_dir: &Path,\n   264→    loop_number: u32,\n   265→    loop_slug: &str,\n   266→    suffix: &str,\n   267→) -> Result<Option<String>> {\n   268→    let loop_dir_name = format!(\"{loop_number:03}-{loop_slug}\");\n   269→    let loop_dir = project_dir.join(\"loops\").join(loop_dir_name);\n   270→\n   271→    let read_dir = match fs::read_dir(&loop_dir) {\n   272→        Ok(entries) => entries,\n   273→        Err(err) if err.kind() == ErrorKind::NotFound => return Ok(None),\n   274→        Err(err) => return Err(err.into()),\n   275→    };\n   276→\n   277→    let mut best: Option<(Option<String>, String)> = None;\n   278→    for entry in read_dir {\n   279→        let entry = entry?;\n   280→        if !entry.file_type()?.is_file() {\n   281→            continue;\n   282→        }\n   283→\n   284→        let file_name = entry.file_name();\n   285→        let Some(file_name) = file_name.to_str() else {\n   286→            continue;\n   287→        };\n   288→\n   289→        let timestamp = if file_name == suffix {\n   290→            None\n   291→        } else if let Some(prefix) = parse_artifact_filename_timestamp(file_name) {\n   292→            let expected_suffix = format!(\"-{suffix}\");\n   293→            if file_name.ends_with(&expected_suffix) {\n   294→                Some(prefix)\n   295→            } else {\n   296→                continue;\n   297→            }\n   298→        } else {\n   299→            continue;\n   300→        };\n   301→\n   302→        let rel = artifact_relative_path(project_dir, &entry.path());\n   303→        match &best {\n   304→            None => best = Some((timestamp, rel)),\n   305→            Some((best_ts, best_rel)) => {\n   306→                if is_candidate_better(timestamp.as_deref(), best_ts.as_deref(), &rel, best_rel) {\n   307→                    best = Some((timestamp, rel));\n   308→                }\n   309→            }\n   310→        }\n   311→    }\n   312→\n   313→    Ok(best.map(|(_, rel)| rel))\n   314→}\n   315→\n   316→fn is_candidate_better(\n   317→    candidate_ts: Option<&str>,\n   318→    best_ts: Option<&str>,\n   319→    candidate_rel: &str,\n   320→    best_rel: &str,\n   321→) -> bool {\n   322→    match (candidate_ts, best_ts) {\n   323→        (Some(c), Some(b)) => c > b || (c == b && candidate_rel > best_rel),\n   324→        (Some(_), None) => true,\n   325→        (None, Some(_)) => false,\n   326→        (None, None) => candidate_rel > best_rel,\n   327→    }\n   328→}\n   329→\n   330→pub(crate) fn strip_backend_frontmatter(raw: &str) -> String {\n   331→    let trimmed = raw.trim();\n   332→    if !trimmed.starts_with(\"---\") {\n   333→        return trimmed.to_owned();\n   334→    }\n   335→\n   336→    let mut lines = trimmed.lines();\n   337→    let first = lines.next();\n   338→    if first != Some(\"---\") {\n   339→        return trimmed.to_owned();\n   340→    }\n   341→\n   342→    let mut in_frontmatter = true;\n   343→    let mut out = String::new();\n   344→\n   345→    for line in lines {\n   346→        if in_frontmatter && line.trim() == \"---\" {\n   347→            in_frontmatter = false;\n   348→            continue;\n   349→        }\n   350→        if !in_frontmatter {\n   351→            out.push_str(line);\n   352→            out.push('\\n');\n   353→        }\n   354→    }\n   355→\n   356→    if in_frontmatter {\n   357→        trimmed.to_owned()\n   358→    } else {\n   359→        out.trim().to_owned()\n   360→    }\n   361→}\n   362→\n   363→#[cfg(test)]\n   364→mod tests {\n   365→    use regex::Regex;\n   366→    use tempfile::TempDir;\n   367→\n   368→    use super::{\n   369→        resolve_artifact_path_by_suffix, write_artifact, write_project_scoped_artifact,\n   370→        ArtifactKind, ArtifactWriteInput, ProjectScopedArtifactWriteInput,\n   371→    };\n   372→\n   373→    #[test]\n   374→    fn write_artifact_prefixes_filename_with_timestamp() {\n   375→        let temp = TempDir::new().expect(\"temp dir\");\n   376→        let project_dir = temp.path();\n   377→\n   378→        let path = write_artifact(\n   379→            project_dir,\n   380→            ArtifactWriteInput {\n   381→                project_id: \"demo\",\n   382→                loop_number: 1,\n   383→                loop_slug: \"sample\",\n   384→                backend: \"claude\",\n   385→                role: \"planner\",\n   386→                kind: ArtifactKind::Spec,\n   387→                body: \"# Feature: Demo\\n\\n## Description\\nx\\n\\n## Acceptance Criteria\\n- [ ] x\\n\\n## Files to Modify/Create\\n- `a` - b\\n\\n## Dependencies\\n- Requires: none\\n- Blocks: none\",\n   388→            },\n   389→        )\n   390→        .expect(\"write artifact\");\n   391→\n   392→        let file_name = path\n   393→            .file_name()\n   394→            .and_then(|s| s.to_str())\n   395→            .expect(\"utf8 file name\");\n   396→        let re = Regex::new(r\"^\\d{14}-spec\\.md$\").expect(\"regex\");\n   397→        assert!(\n   398→            re.is_match(file_name),\n   399→            \"expected timestamp-prefixed filename, got {file_name}\"\n   400→        );\n   401→    }\n   402→\n   403→    #[test]\n   404→    fn resolve_artifact_path_by_suffix_prefers_latest_timestamped_file() {\n   405→        let temp = TempDir::new().expect(\"temp dir\");\n   406→        let loop_dir = temp.path().join(\"loops/001-demo\");\n   407→        std::fs::create_dir_all(&loop_dir).expect(\"create loop dir\");\n   408→\n   409→        std::fs::write(loop_dir.join(\"review-001-feedback.md\"), \"legacy\").expect(\"write legacy\");\n   410→        std::fs::write(\n   411→            loop_dir.join(\"20260203055910-review-001-feedback.md\"),\n   412→            \"old timestamp\",\n   413→        )\n   414→        .expect(\"write old\");\n   415→        std::fs::write(\n   416→            loop_dir.join(\"20260203060159-review-001-feedback.md\"),\n   417→            \"new timestamp\",\n   418→        )\n   419→        .expect(\"write new\");\n   420→\n   421→        let resolved =\n   422→            resolve_artifact_path_by_suffix(temp.path(), 1, \"demo\", \"review-001-feedback.md\")\n   423→                .expect(\"resolve\")\n   424→                .expect(\"path should exist\");\n   425→\n   426→        assert_eq!(\n   427→            resolved,\n   428→            \"loops/001-demo/20260203060159-review-001-feedback.md\"\n   429→        );\n   430→    }\n   431→\n   432→    #[test]\n   433→    fn qa_and_acceptance_artifact_kinds_render_expected_names_and_types() {\n   434→        assert_eq!(\n   435→            ArtifactKind::QaPass { iteration: 1 }.file_name(),\n   436→            \"qa-001-pass.md\"\n   437→        );\n   438→        assert_eq!(\n   439→            ArtifactKind::QaFail { iteration: 7 }.file_name(),\n   440→            \"qa-007-fail.md\"\n   441→        );\n   442→        assert_eq!(\n   443→            ArtifactKind::ImplQaResponse { iteration: 3 }.file_name(),\n   444→            \"impl-qa-response-003.md\"\n   445→        );\n   446→        assert_eq!(\n   447→            ArtifactKind::AcceptancePass.file_name(),\n   448→            \"acceptance-pass.md\"\n   449→        );\n   450→        assert_eq!(\n   451→            ArtifactKind::AcceptanceFail.file_name(),\n   452→            \"acceptance-fail.md\"\n   453→        );\n   454→\n   455→        assert_eq!(ArtifactKind::QaPass { iteration: 1 }.base_type(), \"qa-pass\");\n   456→        assert_eq!(ArtifactKind::QaFail { iteration: 1 }.base_type(), \"qa-fail\");\n   457→        assert_eq!(\n   458→            ArtifactKind::ImplQaResponse { iteration: 1 }.base_type(),\n   459→            \"impl-qa-response\"\n   460→        );\n   461→        assert_eq!(ArtifactKind::AcceptancePass.base_type(), \"acceptance-pass\");\n   462→        assert_eq!(ArtifactKind::AcceptanceFail.base_type(), \"acceptance-fail\");\n   463→    }\n   464→\n   465→    #[test]\n   466→    fn final_review_artifact_kinds_render_expected_names_and_types() {\n   467→        assert_eq!(\n   468→            ArtifactKind::FinalReviewProposals {\n   469→                backend: \"claude\".to_owned()\n   470→            }\n   471→            .file_name(),\n   472→            \"final-review-proposals-claude.md\"\n   473→        );\n   474→        assert_eq!(\n   475→            ArtifactKind::FinalReviewPlannerPositions.file_name(),\n   476→            \"final-review-planner-positions.md\"\n   477→        );\n   478→        assert_eq!(\n   479→            ArtifactKind::FinalReviewVotes {\n   480→                backend: \"codex(gpt-5)\".to_owned()\n   481→            }\n   482→            .file_name(),\n   483→            \"final-review-votes-codex-gpt-5.md\"\n   484→        );\n   485→        assert_eq!(\n   486→            ArtifactKind::FinalReviewArbiterRuling.file_name(),\n   487→            \"final-review-arbiter-ruling.md\"\n   488→        );\n   489→        assert_eq!(\n   490→            ArtifactKind::FinalReviewExit {\n   491→                outcome: \"approved\".to_owned()\n   492→            }\n   493→            .file_name(),\n   494→            \"final-review-exit-approved.md\"\n   495→        );\n   496→\n   497→        assert_eq!(\n   498→            ArtifactKind::FinalReviewProposals {\n   499→                backend: \"claude\".to_owned()\n   500→            }\n   501→            .base_type(),\n   502→            \"final-review-proposals\"\n   503→        );\n   504→        assert_eq!(\n   505→            ArtifactKind::FinalReviewPlannerPositions.base_type(),\n   506→            \"final-review-planner-positions\"\n   507→        );\n   508→        assert_eq!(\n   509→            ArtifactKind::FinalReviewVotes {\n   510→                backend: \"codex\".to_owned()\n   511→            }\n   512→            .base_type(),\n   513→            \"final-review-votes\"\n   514→        );\n   515→        assert_eq!(\n   516→            ArtifactKind::FinalReviewArbiterRuling.base_type(),\n   517→            \"final-review-arbiter-ruling\"\n   518→        );\n   519→        assert_eq!(\n   520→            ArtifactKind::FinalReviewExit {\n   521→                outcome: \"restart\".to_owned()\n   522→            }\n   523→            .base_type(),\n   524→            \"final-review-exit\"\n   525→        );\n   526→    }\n   527→\n   528→    #[test]\n   529→    fn write_project_scoped_artifact_writes_project_frontmatter_schema() {\n   530→        let temp = TempDir::new().expect(\"temp dir\");\n   531→        let project_dir = temp.path();\n   532→\n   533→        let path = write_project_scoped_artifact(\n   534→            project_dir,\n   535→            ProjectScopedArtifactWriteInput {\n   536→                artifact: \"prompt-review\",\n   537→                file_name: \"prompt-review.md\",\n   538→                project_id: \"demo\",\n   539→                backend: \"codex(gpt-5.3-codex-xhigh)\",\n   540→                role: \"prompt_reviewer\",\n   541→                body: \"# Prompt Review\\n\\n## Issues Found\\n- mock\\n\\n## Refined Prompt\\nThis is a sufficiently long refined prompt.\",\n   542→            },\n   543→        )\n   544→        .expect(\"write project artifact\");\n   545→\n   546→        assert_eq!(\n   547→            path,\n   548→            project_dir.join(\"prompt-review.md\"),\n   549→            \"project-scoped artifact should be written directly under project root\"\n   550→        );\n   551→\n   552→        let content = std::fs::read_to_string(path).expect(\"read artifact\");\n   553→        assert!(content.contains(\"artifact: prompt-review\"));\n   554→        assert!(content.contains(\"project: demo\"));\n   555→        assert!(content.contains(\"backend: codex(gpt-5.3-codex-xhigh)\"));\n   556→        assert!(content.contains(\"role: prompt_reviewer\"));\n   557→        assert!(content.contains(\"created_at: \"));\n   558→        assert!(\n   559→            !content.contains(\"\\nloop: \"),\n   560→            \"project-scoped artifact must not include loop field\"\n   561→        );\n   562→        assert!(\n   563→            !content.contains(\"\\niteration: \"),\n   564→            \"project-scoped artifact must not include iteration field\"\n   565→        );\n   566→        assert!(\n   567→            !content.contains(\"\\niterations: \"),\n   568→            \"project-scoped artifact must not include iterations field\"\n   569→        );\n   570→    }\n   571→}\n   572→"}]},"parent_tool_use_id":"toolu_01D1YGYYF5pXopdBJ1HtvaN6","session_id":"3d9a0615-7442-4a66-ab27-f8160d110223","uuid":"03816232-513a-4e90-bc06-287d99f1efb9"}
