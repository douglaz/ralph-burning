{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01WAZRaLPXs59obEVGs41ag9","type":"tool_result","content":"     1→use std::path::Path;\n     2→\n     3→use chrono::Utc;\n     4→use serde_json::json;\n     5→\n     6→use crate::contexts::automation_runtime::lease_service::LeaseService;\n     7→use crate::contexts::automation_runtime::model::{\n     8→    DaemonJournalEvent, DaemonJournalEventType, DaemonTask, DispatchMode, TaskStatus,\n     9→    WatchedIssueMeta, WorktreeLease,\n    10→};\n    11→use crate::contexts::automation_runtime::routing::RoutingEngine;\n    12→use crate::contexts::automation_runtime::{DaemonStorePort, WorktreePort};\n    13→use crate::shared::domain::{FlowPreset, ProjectId};\n    14→use crate::shared::error::{AppError, AppResult};\n    15→\n    16→#[derive(Debug, Clone, PartialEq, Eq)]\n    17→pub struct CreateTaskInput {\n    18→    pub task_id: String,\n    19→    pub issue_ref: String,\n    20→    pub project_id: String,\n    21→    pub project_name: Option<String>,\n    22→    pub prompt: Option<String>,\n    23→    pub routing_command: Option<String>,\n    24→    pub routing_labels: Vec<String>,\n    25→    pub dispatch_mode: DispatchMode,\n    26→    pub source_revision: Option<String>,\n    27→}\n    28→\n    29→pub struct DaemonTaskService;\n    30→\n    31→impl DaemonTaskService {\n    32→    pub fn list_tasks(store: &dyn DaemonStorePort, base_dir: &Path) -> AppResult<Vec<DaemonTask>> {\n    33→        store.list_tasks(base_dir)\n    34→    }\n    35→\n    36→    pub fn create_task(\n    37→        store: &dyn DaemonStorePort,\n    38→        base_dir: &Path,\n    39→        routing_engine: &RoutingEngine,\n    40→        default_flow: FlowPreset,\n    41→        input: CreateTaskInput,\n    42→    ) -> AppResult<DaemonTask> {\n    43→        validate_identifier(&input.task_id)?;\n    44→        let project_id = ProjectId::new(input.project_id.clone())?;\n    45→        let issue_ref = normalize_required(\"issue_ref\", &input.issue_ref)?;\n    46→\n    47→        let existing_tasks = store.list_tasks(base_dir)?;\n    48→        if existing_tasks\n    49→            .iter()\n    50→            .any(|task| task.issue_ref == issue_ref && !task.is_terminal())\n    51→        {\n    52→            return Err(AppError::DuplicateTaskForIssue { issue_ref });\n    53→        }\n    54→\n    55→        let resolution = routing_engine.resolve_flow(\n    56→            input.routing_command.as_deref(),\n    57→            &input.routing_labels,\n    58→            default_flow,\n    59→        )?;\n    60→\n    61→        let now = Utc::now();\n    62→        let task = DaemonTask {\n    63→            task_id: input.task_id,\n    64→            issue_ref: normalize_required(\"issue_ref\", &input.issue_ref)?,\n    65→            project_id: project_id.to_string(),\n    66→            project_name: input.project_name.filter(|value| !value.trim().is_empty()),\n    67→            prompt: input.prompt.filter(|value| !value.trim().is_empty()),\n    68→            routing_command: input\n    69→                .routing_command\n    70→                .filter(|value| !value.trim().is_empty()),\n    71→            routing_labels: input.routing_labels,\n    72→            resolved_flow: Some(resolution.flow),\n    73→            routing_source: Some(resolution.source),\n    74→            routing_warnings: resolution.warnings.clone(),\n    75→            status: TaskStatus::Pending,\n    76→            created_at: now,\n    77→            updated_at: now,\n    78→            attempt_count: 0,\n    79→            lease_id: None,\n    80→            failure_class: None,\n    81→            failure_message: None,\n    82→            dispatch_mode: input.dispatch_mode,\n    83→            source_revision: input.source_revision,\n    84→            requirements_run_id: None,\n    85→        };\n    86→\n    87→        store.create_task(base_dir, &task)?;\n    88→        Self::append_journal_event(\n    89→            store,\n    90→            base_dir,\n    91→            DaemonJournalEventType::TaskCreated,\n    92→            json!({\n    93→                \"task_id\": task.task_id,\n    94→                \"issue_ref\": task.issue_ref,\n    95→                \"project_id\": task.project_id,\n    96→                \"flow\": resolution.flow,\n    97→                \"routing_source\": resolution.source,\n    98→                \"warnings\": resolution.warnings,\n    99→            }),\n   100→        )?;\n   101→\n   102→        Ok(task)\n   103→    }\n   104→\n   105→    pub fn claim_task(\n   106→        store: &dyn DaemonStorePort,\n   107→        worktree: &dyn WorktreePort,\n   108→        routing_engine: &RoutingEngine,\n   109→        base_dir: &Path,\n   110→        repo_root: &Path,\n   111→        task_id: &str,\n   112→        default_flow: FlowPreset,\n   113→        lease_ttl_seconds: u64,\n   114→    ) -> AppResult<(DaemonTask, WorktreeLease)> {\n   115→        let mut task = store.read_task(base_dir, task_id)?;\n   116→        if task.status != TaskStatus::Pending {\n   117→            return Err(AppError::TaskStateTransitionInvalid {\n   118→                task_id: task.task_id.clone(),\n   119→                from: task.status.as_str().to_owned(),\n   120→                to: TaskStatus::Claimed.as_str().to_owned(),\n   121→            });\n   122→        }\n   123→\n   124→        if task.lease_id.is_some()\n   125→            || store\n   126→                .list_leases(base_dir)?\n   127→                .iter()\n   128→                .any(|lease| lease.task_id == task.task_id)\n   129→        {\n   130→            return Err(AppError::TaskStateTransitionInvalid {\n   131→                task_id: task.task_id.clone(),\n   132→                from: task.status.as_str().to_owned(),\n   133→                to: \"claimed_with_duplicate_lease\".to_owned(),\n   134→            });\n   135→        }\n   136→\n   137→        hydrate_routing(&mut task, routing_engine, default_flow)?;\n   138→        let project_id = ProjectId::new(task.project_id.clone())?;\n   139→        let lease = match LeaseService::acquire(\n   140→            store,\n   141→            worktree,\n   142→            base_dir,\n   143→            repo_root,\n   144→            &task.task_id,\n   145→            &project_id,\n   146→            lease_ttl_seconds,\n   147→        ) {\n   148→            Ok(lease) => lease,\n   149→            Err(AppError::ProjectWriterLockHeld { .. }) => {\n   150→                return Err(AppError::ProjectWriterLockHeld {\n   151→                    project_id: project_id.to_string(),\n   152→                })\n   153→            }\n   154→            Err(error) => {\n   155→                let _ = Self::mark_failed(\n   156→                    store,\n   157→                    base_dir,\n   158→                    &task.task_id,\n   159→                    \"worktree_creation_failed\",\n   160→                    &error.to_string(),\n   161→                );\n   162→                return Err(error);\n   163→            }\n   164→        };\n   165→\n   166→        let now = Utc::now();\n   167→        task.transition_to(TaskStatus::Claimed, now)?;\n   168→        task.attach_lease(lease.lease_id.clone());\n   169→        store.write_task(base_dir, &task).map_err(|error| {\n   170→            let _ = LeaseService::release(store, worktree, base_dir, repo_root, &lease);\n   171→            error\n   172→        })?;\n   173→\n   174→        Self::append_journal_event(\n   175→            store,\n   176→            base_dir,\n   177→            DaemonJournalEventType::LeaseAcquired,\n   178→            json!({\n   179→                \"task_id\": task.task_id,\n   180→                \"lease_id\": lease.lease_id,\n   181→                \"project_id\": project_id,\n   182→                \"worktree_path\": lease.worktree_path,\n   183→                \"branch_name\": lease.branch_name,\n   184→                \"ttl_seconds\": lease.ttl_seconds,\n   185→            }),\n   186→        )?;\n   187→        Self::append_journal_event(\n   188→            store,\n   189→            base_dir,\n   190→            DaemonJournalEventType::TaskClaimed,\n   191→            json!({\n   192→                \"task_id\": task.task_id,\n   193→                \"lease_id\": lease.lease_id,\n   194→                \"project_id\": project_id,\n   195→            }),\n   196→        )?;\n   197→\n   198→        Ok((task, lease))\n   199→    }\n   200→\n   201→    pub fn mark_active(\n   202→        store: &dyn DaemonStorePort,\n   203→        base_dir: &Path,\n   204→        task_id: &str,\n   205→    ) -> AppResult<DaemonTask> {\n   206→        let mut task = store.read_task(base_dir, task_id)?;\n   207→        task.transition_to(TaskStatus::Active, Utc::now())?;\n   208→        store.write_task(base_dir, &task)?;\n   209→        Ok(task)\n   210→    }\n   211→\n   212→    pub fn mark_completed(\n   213→        store: &dyn DaemonStorePort,\n   214→        base_dir: &Path,\n   215→        task_id: &str,\n   216→    ) -> AppResult<DaemonTask> {\n   217→        let mut task = store.read_task(base_dir, task_id)?;\n   218→        task.transition_to(TaskStatus::Completed, Utc::now())?;\n   219→        store.write_task(base_dir, &task)?;\n   220→        Self::append_journal_event(\n   221→            store,\n   222→            base_dir,\n   223→            DaemonJournalEventType::TaskCompleted,\n   224→            json!({ \"task_id\": task.task_id }),\n   225→        )?;\n   226→        Ok(task)\n   227→    }\n   228→\n   229→    pub fn mark_failed(\n   230→        store: &dyn DaemonStorePort,\n   231→        base_dir: &Path,\n   232→        task_id: &str,\n   233→        failure_class: &str,\n   234→        failure_message: &str,\n   235→    ) -> AppResult<DaemonTask> {\n   236→        let mut task = store.read_task(base_dir, task_id)?;\n   237→        task.transition_to(TaskStatus::Failed, Utc::now())?;\n   238→        task.set_failure(failure_class, failure_message);\n   239→        store.write_task(base_dir, &task)?;\n   240→        Self::append_journal_event(\n   241→            store,\n   242→            base_dir,\n   243→            DaemonJournalEventType::TaskFailed,\n   244→            json!({\n   245→                \"task_id\": task.task_id,\n   246→                \"failure_class\": failure_class,\n   247→                \"failure_message\": failure_message,\n   248→            }),\n   249→        )?;\n   250→        Ok(task)\n   251→    }\n   252→\n   253→    pub fn mark_aborted(\n   254→        store: &dyn DaemonStorePort,\n   255→        base_dir: &Path,\n   256→        task_id: &str,\n   257→    ) -> AppResult<DaemonTask> {\n   258→        let mut task = store.read_task(base_dir, task_id)?;\n   259→        if matches!(\n   260→            task.status,\n   261→            TaskStatus::Completed | TaskStatus::Failed | TaskStatus::Aborted\n   262→        ) {\n   263→            return Err(AppError::TaskStateTransitionInvalid {\n   264→                task_id: task.task_id.clone(),\n   265→                from: task.status.as_str().to_owned(),\n   266→                to: TaskStatus::Aborted.as_str().to_owned(),\n   267→            });\n   268→        }\n   269→        task.transition_to(TaskStatus::Aborted, Utc::now())?;\n   270→        store.write_task(base_dir, &task)?;\n   271→        Self::append_journal_event(\n   272→            store,\n   273→            base_dir,\n   274→            DaemonJournalEventType::TaskAborted,\n   275→            json!({ \"task_id\": task.task_id }),\n   276→        )?;\n   277→        Ok(task)\n   278→    }\n   279→\n   280→    pub fn retry_task(\n   281→        store: &dyn DaemonStorePort,\n   282→        base_dir: &Path,\n   283→        task_id: &str,\n   284→    ) -> AppResult<DaemonTask> {\n   285→        let mut task = store.read_task(base_dir, task_id)?;\n   286→        if task.status != TaskStatus::Failed {\n   287→            return Err(AppError::TaskStateTransitionInvalid {\n   288→                task_id: task.task_id.clone(),\n   289→                from: task.status.as_str().to_owned(),\n   290→                to: TaskStatus::Pending.as_str().to_owned(),\n   291→            });\n   292→        }\n   293→\n   294→        task.transition_to(TaskStatus::Pending, Utc::now())?;\n   295→        task.attempt_count += 1;\n   296→        task.clear_failure();\n   297→        task.clear_lease();\n   298→        store.write_task(base_dir, &task)?;\n   299→        Ok(task)\n   300→    }"}]},"parent_tool_use_id":"toolu_01WxWEKeVM8eN1eTgMgZkDxS","session_id":"3d9a0615-7442-4a66-ab27-f8160d110223","uuid":"c052de24-acac-48f0-9cc4-dee53074e6ff"}
