{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01A5GtRXGT7xNKEXfp3dYfsx","type":"tool_result","content":"     1→use std::path::Path;\n     2→use std::process::{Command, Output};\n     3→use std::sync::Arc;\n     4→\n     5→use crate::error::RalphError;\n     6→use crate::Result;\n     7→use tokio::sync::Semaphore;\n     8→\n     9→const BOOTSTRAP_COMMIT_MESSAGE: &str = \"ralph: bootstrap empty commit\";\n    10→const FALLBACK_GIT_NAME: &str = \"ralph-daemon\";\n    11→const FALLBACK_GIT_EMAIL: &str = \"ralph@localhost\";\n    12→\n    13→/// Ensure `repo_root` is ready for daemon dispatch/worktree operations.\n    14→///\n    15→/// Idempotent behavior:\n    16→/// - Initializes git for non-repo directories.\n    17→/// - Rejects bare repositories as unsupported.\n    18→/// - Creates one empty bootstrap commit for unborn HEAD.\n    19→/// - Initializes `.ralph/` workspace if missing.\n    20→pub async fn ensure_repo_ready(\n    21→    repo_root: &Path,\n    22→    repo_root_lock: Option<Arc<Semaphore>>,\n    23→) -> Result<()> {\n    24→    let _permit = if let Some(lock) = repo_root_lock {\n    25→        Some(lock.acquire_owned().await.map_err(|err| {\n    26→            RalphError::Orchestration(format!(\"git root semaphore closed: {err}\"))\n    27→        })?)\n    28→    } else {\n    29→        None\n    30→    };\n    31→\n    32→    let repo_root = repo_root.to_path_buf();\n    33→    let result = tokio::task::spawn_blocking(move || ensure_repo_ready_sync(&repo_root))\n    34→        .await\n    35→        .map_err(|err| RalphError::Orchestration(format!(\"bootstrap task join failure: {err}\")))?;\n    36→\n    37→    result\n    38→}\n    39→\n    40→pub fn ensure_repo_ready_sync(repo_root: &Path) -> Result<()> {\n    41→    if !repo_root.exists() {\n    42→        std::fs::create_dir_all(repo_root)?;\n    43→    }\n    44→\n    45→    if !is_git_repo(repo_root)? {\n    46→        run_git_checked(repo_root, &[\"init\"], \"failed to initialize git repository\")?;\n    47→    }\n    48→\n    49→    if is_bare_repo(repo_root)? {\n    50→        return Err(RalphError::Unsupported(format!(\n    51→            \"daemon bootstrap does not support bare repositories: {}\",\n    52→            repo_root.display()\n    53→        )));\n    54→    }\n    55→\n    56→    ensure_fallback_identity_if_missing(repo_root)?;\n    57→\n    58→    if is_head_unborn(repo_root)? {\n    59→        run_git_checked(\n    60→            repo_root,\n    61→            &[\n    62→                \"-c\",\n    63→                \"commit.gpgsign=false\",\n    64→                \"commit\",\n    65→                \"--allow-empty\",\n    66→                \"--no-verify\",\n    67→                \"-m\",\n    68→                BOOTSTRAP_COMMIT_MESSAGE,\n    69→            ],\n    70→            \"failed to create bootstrap commit\",\n    71→        )?;\n    72→    }\n    73→\n    74→    ensure_workspace_initialized(repo_root)?;\n    75→    Ok(())\n    76→}\n    77→\n    78→fn ensure_workspace_initialized(repo_root: &Path) -> Result<()> {\n    79→    let workspace_root = repo_root.join(\".ralph\");\n    80→    if workspace_root.exists() {\n    81→        return Ok(());\n    82→    }\n    83→\n    84→    let _ = crate::cli::init::create_workspace(&workspace_root)?;\n    85→    Ok(())\n    86→}\n    87→\n    88→fn ensure_fallback_identity_if_missing(repo_root: &Path) -> Result<()> {\n    89→    let has_name = has_git_config_value(repo_root, \"user.name\")?;\n    90→    let has_email = has_git_config_value(repo_root, \"user.email\")?;\n    91→\n    92→    if !has_name {\n    93→        run_git_checked(\n    94→            repo_root,\n    95→            &[\"config\", \"--local\", \"user.name\", FALLBACK_GIT_NAME],\n    96→            \"failed to set fallback git user.name\",\n    97→        )?;\n    98→    }\n    99→\n   100→    if !has_email {\n   101→        run_git_checked(\n   102→            repo_root,\n   103→            &[\"config\", \"--local\", \"user.email\", FALLBACK_GIT_EMAIL],\n   104→            \"failed to set fallback git user.email\",\n   105→        )?;\n   106→    }\n   107→\n   108→    Ok(())\n   109→}\n   110→\n   111→fn has_git_config_value(repo_root: &Path, key: &str) -> Result<bool> {\n   112→    let output = run_git_raw(\n   113→        repo_root,\n   114→        &[\"config\", \"--get\", key],\n   115→        \"failed to read git config\",\n   116→    )?;\n   117→    if !output.status.success() {\n   118→        return Ok(false);\n   119→    }\n   120→    Ok(!String::from_utf8_lossy(&output.stdout).trim().is_empty())\n   121→}\n   122→\n   123→fn is_git_repo(repo_root: &Path) -> Result<bool> {\n   124→    let output = run_git_raw(\n   125→        repo_root,\n   126→        &[\"rev-parse\", \"--git-dir\"],\n   127→        \"failed to check git repository state\",\n   128→    )?;\n   129→    Ok(output.status.success())\n   130→}\n   131→\n   132→fn is_bare_repo(repo_root: &Path) -> Result<bool> {\n   133→    let stdout = run_git_checked(\n   134→        repo_root,\n   135→        &[\"rev-parse\", \"--is-bare-repository\"],\n   136→        \"failed to check bare repository state\",\n   137→    )?;\n   138→    Ok(stdout.trim() == \"true\")\n   139→}\n   140→\n   141→fn is_head_unborn(repo_root: &Path) -> Result<bool> {\n   142→    let output = run_git_raw(\n   143→        repo_root,\n   144→        &[\"rev-parse\", \"--verify\", \"--quiet\", \"HEAD\"],\n   145→        \"failed to check HEAD state\",\n   146→    )?;\n   147→    Ok(!output.status.success())\n   148→}\n   149→\n   150→fn run_git_checked(repo_root: &Path, args: &[&str], context: &str) -> Result<String> {"}]},"parent_tool_use_id":"toolu_01D1YGYYF5pXopdBJ1HtvaN6","session_id":"3d9a0615-7442-4a66-ab27-f8160d110223","uuid":"190323d6-5ccc-4995-bb45-96e0ce4d4e56"}
