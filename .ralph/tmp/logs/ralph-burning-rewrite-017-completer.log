{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01QVySTDSUMeNMmhDA8AMaSf","type":"tool_result","content":"     1→/// Adapter contract tests for filesystem-backed stores.\n     2→/// Verifies round-trip persistence, corruption visibility, and edge cases\n     3→/// for FsProjectStore, FsJournalStore, FsArtifactStore, FsRuntimeLogStore,\n     4→/// FsRunSnapshotStore, and FsActiveProjectStore.\n     5→use std::fs;\n     6→\n     7→use chrono::{TimeZone, Utc};\n     8→use tempfile::tempdir;\n     9→\n    10→use ralph_burning::adapters::fs::{\n    11→    FileSystem, FsActiveProjectStore, FsAmendmentQueueStore, FsArtifactStore, FsJournalStore,\n    12→    FsProjectStore, FsRollbackPointStore, FsRunSnapshotStore, FsRuntimeLogStore,\n    13→};\n    14→use ralph_burning::contexts::project_run_record::journal;\n    15→use ralph_burning::contexts::project_run_record::model::*;\n    16→use ralph_burning::contexts::project_run_record::service::{\n    17→    ActiveProjectPort, ArtifactStorePort, JournalStorePort, ProjectStorePort,\n    18→    RollbackPointStorePort, RunSnapshotPort, RuntimeLogStorePort,\n    19→};\n    20→use ralph_burning::shared::domain::{FlowPreset, ProjectId, StageId};\n    21→use ralph_burning::shared::error::AppError;\n    22→\n    23→fn test_timestamp() -> chrono::DateTime<Utc> {\n    24→    Utc.with_ymd_and_hms(2026, 3, 11, 19, 0, 0)\n    25→        .single()\n    26→        .expect(\"valid timestamp\")\n    27→}\n    28→\n    29→fn make_project_record(id: &str) -> ProjectRecord {\n    30→    ProjectRecord {\n    31→        id: ProjectId::new(id).unwrap(),\n    32→        name: format!(\"Project {id}\"),\n    33→        flow: FlowPreset::Standard,\n    34→        prompt_reference: \"prompt.md\".to_owned(),\n    35→        prompt_hash: \"abc123\".to_owned(),\n    36→        created_at: test_timestamp(),\n    37→        status_summary: ProjectStatusSummary::Created,\n    38→    }\n    39→}\n    40→\n    41→fn setup_workspace(base_dir: &std::path::Path) {\n    42→    let ws = base_dir.join(\".ralph-burning\");\n    43→    fs::create_dir_all(ws.join(\"projects\")).expect(\"create projects dir\");\n    44→    let config = ralph_burning::shared::domain::WorkspaceConfig::new(test_timestamp());\n    45→    let rendered = FileSystem::render_workspace_config(&config).expect(\"render config\");\n    46→    FileSystem::write_atomic(&ws.join(\"workspace.toml\"), &rendered).expect(\"write config\");\n    47→}\n    48→\n    49→fn create_project_on_disk(base_dir: &std::path::Path, id: &str) {\n    50→    let store = FsProjectStore;\n    51→    let record = make_project_record(id);\n    52→    let snapshot = RunSnapshot::initial();\n    53→    let sessions = SessionStore::empty();\n    54→    let event = JournalEvent {\n    55→        sequence: 1,\n    56→        timestamp: test_timestamp(),\n    57→        event_type: JournalEventType::ProjectCreated,\n    58→        details: serde_json::json!({\"project_id\": id, \"flow\": \"standard\"}),\n    59→    };\n    60→    let journal_line = journal::serialize_event(&event).expect(\"serialize event\");\n    61→    store\n    62→        .create_project_atomic(\n    63→            base_dir,\n    64→            &record,\n    65→            \"# Prompt\\n\",\n    66→            &snapshot,\n    67→            &journal_line,\n    68→            &sessions,\n    69→        )\n    70→        .expect(\"create project\");\n    71→}\n    72→\n    73→// ── FsProjectStore ──\n    74→\n    75→#[test]\n    76→fn project_store_round_trip_create_and_read() {\n    77→    let tmp = tempdir().unwrap();\n    78→    setup_workspace(tmp.path());\n    79→    create_project_on_disk(tmp.path(), \"alpha\");\n    80→\n    81→    let store = FsProjectStore;\n    82→    let pid = ProjectId::new(\"alpha\").unwrap();\n    83→    let record = store.read_project_record(tmp.path(), &pid).unwrap();\n    84→\n    85→    assert_eq!(record.id.as_str(), \"alpha\");\n    86→    assert_eq!(record.flow, FlowPreset::Standard);\n    87→    assert_eq!(record.prompt_reference, \"prompt.md\");\n    88→    assert_eq!(record.prompt_hash, \"abc123\");\n    89→    assert_eq!(record.status_summary, ProjectStatusSummary::Created);\n    90→}\n    91→\n    92→#[test]\n    93→fn project_store_exists_returns_true_for_created_project() {\n    94→    let tmp = tempdir().unwrap();\n    95→    setup_workspace(tmp.path());\n    96→    create_project_on_disk(tmp.path(), \"alpha\");\n    97→\n    98→    let store = FsProjectStore;\n    99→    let pid = ProjectId::new(\"alpha\").unwrap();\n   100→    assert!(store.project_exists(tmp.path(), &pid).unwrap());\n   101→}\n   102→\n   103→#[test]\n   104→fn project_store_exists_returns_false_for_missing_project() {\n   105→    let tmp = tempdir().unwrap();\n   106→    setup_workspace(tmp.path());\n   107→\n   108→    let store = FsProjectStore;\n   109→    let pid = ProjectId::new(\"nonexistent\").unwrap();\n   110→    assert!(!store.project_exists(tmp.path(), &pid).unwrap());\n   111→}\n   112→\n   113→#[test]\n   114→fn project_store_list_returns_sorted_ids() {\n   115→    let tmp = tempdir().unwrap();\n   116→    setup_workspace(tmp.path());\n   117→    create_project_on_disk(tmp.path(), \"beta\");\n   118→    create_project_on_disk(tmp.path(), \"alpha\");\n   119→\n   120→    let store = FsProjectStore;\n   121→    let ids = store.list_project_ids(tmp.path()).unwrap();\n   122→    let id_strs: Vec<&str> = ids.iter().map(|p| p.as_str()).collect();\n   123→    assert_eq!(id_strs, vec![\"alpha\", \"beta\"]);\n   124→}\n   125→\n   126→#[test]\n   127→fn project_store_stage_and_commit_delete_removes_project() {\n   128→    let tmp = tempdir().unwrap();\n   129→    setup_workspace(tmp.path());\n   130→    create_project_on_disk(tmp.path(), \"alpha\");\n   131→\n   132→    let store = FsProjectStore;\n   133→    let pid = ProjectId::new(\"alpha\").unwrap();\n   134→\n   135→    // Stage: project becomes invisible\n   136→    store.stage_delete(tmp.path(), &pid).unwrap();\n   137→    assert!(!store.project_exists(tmp.path(), &pid).unwrap());\n   138→\n   139→    // Commit: permanently remove\n   140→    store.commit_delete(tmp.path(), &pid).unwrap();\n   141→\n   142→    // Verify pending-delete dir is also gone\n   143→    let pending = tmp\n   144→        .path()\n   145→        .join(\".ralph-burning/projects/.alpha.pending-delete\");\n   146→    assert!(!pending.exists());\n   147→}\n   148→\n   149→#[test]\n   150→fn project_store_stage_and_rollback_restores_project() {"}]},"parent_tool_use_id":"toolu_01HsEmyUbu9C7KXmVEUyYJ77","session_id":"3d9a0615-7442-4a66-ab27-f8160d110223","uuid":"ca4812a4-a021-47f5-b352-908c9fb42dd3"}
