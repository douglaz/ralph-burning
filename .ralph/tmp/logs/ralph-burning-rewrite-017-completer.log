{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013GgyU9XRRVb7UfnFwZXpcd","type":"tool_result","content":"     1→use std::collections::HashSet;\n     2→use std::path::{Path, PathBuf};\n     3→use std::process::Command;\n     4→\n     5→use clap::{Args, Subcommand};\n     6→\n     7→use crate::config::{resolve_daemon_config, validate_effective_daemon_config};\n     8→use crate::daemon::bootstrap;\n     9→use crate::daemon::github;\n    10→use crate::daemon::rebase_agent;\n    11→use crate::daemon::runtime::{retrigger_failed_task, DaemonRuntimeConfig};\n    12→use crate::project::load_project_config_if_exists;\n    13→use crate::util::lock::DaemonLock;\n    14→use crate::workspace::Workspace;\n    15→use crate::{error::RalphError, Result};\n    16→\n    17→#[derive(Debug, Args)]\n    18→pub struct DaemonArgs {\n    19→    #[command(subcommand)]\n    20→    pub command: DaemonCommand,\n    21→}\n    22→\n    23→#[derive(Debug, Subcommand)]\n    24→pub enum DaemonCommand {\n    25→    Start(DaemonStartArgs),\n    26→    Status(DaemonStatusArgs),\n    27→    Abort(DaemonAbortArgs),\n    28→    Retrigger(DaemonRetriggerArgs),\n    29→}\n    30→\n    31→#[derive(Debug, Args)]\n    32→pub struct DaemonStartArgs {\n    33→    #[arg(long)]\n    34→    pub data_dir: PathBuf,\n    35→    #[arg(long = \"repo\")]\n    36→    pub repo: Vec<String>,\n    37→    #[arg(long)]\n    38→    pub git_bin: Option<PathBuf>,\n    39→    #[arg(long)]\n    40→    pub gh_bin: Option<PathBuf>,\n    41→    #[arg(long, value_parser = super::parse_positive_u64)]\n    42→    pub poll_seconds: Option<u64>,\n    43→    #[arg(long, value_parser = super::parse_positive_u32)]\n    44→    pub max_concurrent: Option<u32>,\n    45→    #[arg(long = \"label\")]\n    46→    pub labels: Vec<String>,\n    47→    /// Run a single poll/claim/dispatch/collect iteration and exit.\n    48→    /// Used by conformance tests for deterministic behavior.\n    49→    #[arg(long)]\n    50→    pub single_iteration: bool,\n    51→    #[arg(long)]\n    52→    pub verbose: bool,\n    53→}\n    54→\n    55→#[derive(Debug, Args)]\n    56→pub struct DaemonStatusArgs {\n    57→    #[arg(long)]\n    58→    pub data_dir: PathBuf,\n    59→    /// Owner/repo to query status for. If omitted, scans all repos in data-dir.\n    60→    #[arg(long = \"repo\")]\n    61→    pub repo: Vec<String>,\n    62→}\n    63→\n    64→#[derive(Debug, Args)]\n    65→pub struct DaemonAbortArgs {\n    66→    #[arg(long)]\n    67→    pub data_dir: PathBuf,\n    68→    /// Issue number to abort (fetches current labels from GitHub).\n    69→    pub issue_number: String,\n    70→    /// Owner/repo of the issue to abort.\n    71→    #[arg(long)]\n    72→    pub repo: Option<String>,\n    73→}\n    74→\n    75→#[derive(Debug, Args)]\n    76→pub struct DaemonRetriggerArgs {\n    77→    /// Issue number to retrigger.\n    78→    pub issue_number: String,\n    79→    /// Owner/repo of the issue.\n    80→    #[arg(long)]\n    81→    pub repo: Option<String>,\n    82→}\n    83→\n    84→pub async fn execute(args: DaemonArgs) -> Result<()> {\n    85→    match args.command {\n    86→        DaemonCommand::Start(start_args) => execute_start(start_args).await,\n    87→        DaemonCommand::Status(status_args) => execute_status(status_args).await,\n    88→        DaemonCommand::Abort(abort_args) => execute_abort(abort_args).await,\n    89→        DaemonCommand::Retrigger(retrigger_args) => execute_retrigger(retrigger_args).await,\n    90→    }\n    91→}\n    92→\n    93→async fn execute_start(args: DaemonStartArgs) -> Result<()> {\n    94→    if args.repo.is_empty() {\n    95→        return Err(RalphError::Validation(\n    96→            \"at least one --repo owner/repo is required\".to_owned(),\n    97→        ));\n    98→    }\n    99→\n   100→    let mut normalized_repos = Vec::with_capacity(args.repo.len());\n   101→    let mut seen = HashSet::new();\n   102→    for repo in &args.repo {\n   103→        validate_repo_slug(repo)?;\n   104→        let normalized = repo.trim().to_ascii_lowercase();\n   105→        if !seen.insert(normalized.clone()) {\n   106→            return Err(RalphError::Validation(format!(\n   107→                \"duplicate --repo: {}\",\n   108→                normalized\n   109→            )));\n   110→        }\n   111→        normalized_repos.push(normalized);\n   112→    }\n   113→\n   114→    let cli_git_bin = args\n   115→        .git_bin\n   116→        .as_ref()\n   117→        .map(|path| path.to_string_lossy().into_owned());\n   118→    let cli_gh_bin = args\n   119→        .gh_bin\n   120→        .as_ref()\n   121→        .map(|path| path.to_string_lossy().into_owned());\n   122→    let startup_git_bin = cli_git_bin.clone().unwrap_or_else(|| \"git\".to_owned());\n   123→    let startup_gh_bin = cli_gh_bin.clone().unwrap_or_else(|| \"gh\".to_owned());\n   124→\n   125→    preflight_check_git(&startup_git_bin)?;\n   126→\n   127→    // Guard: --data-dir must not be inside a git working tree\n   128→    guard_not_git_repo(&args.data_dir, &startup_git_bin)?;\n   129→\n   130→    preflight_check_gh(&startup_gh_bin)?;\n   131→\n   132→    // Create data-dir after guard passes\n   133→    std::fs::create_dir_all(&args.data_dir).map_err(|err| {\n   134→        RalphError::Orchestration(format!(\n   135→            \"failed to create data-dir {}: {err}\",\n   136→            args.data_dir.display()\n   137→        ))\n   138→    })?;\n   139→\n   140→    let mut deprecation_warned = false;\n   141→\n   142→    let mut repo_configs: Vec<DaemonRuntimeConfig> = Vec::new();\n   143→    let mut daemon_locks: Vec<DaemonLock> = Vec::new();\n   144→\n   145→    for slug in &normalized_repos {\n   146→        let (owner, repo_name) = parse_repo_slug(slug)?;\n   147→        let repo_dir = args.data_dir.join(&owner).join(&repo_name);\n   148→\n   149→        // Clone or bootstrap the repo\n   150→        clone_or_bootstrap(\n   151→            &owner,\n   152→            &repo_name,\n   153→            &repo_dir,\n   154→            &startup_gh_bin,\n   155→            &startup_git_bin,\n   156→        )?;\n   157→\n   158→        // Load workspace from repo's .ralph/\n   159→        let workspace = Workspace::load(repo_dir.join(\".ralph\"))?;\n   160→        let git_bin = cli_git_bin\n   161→            .clone()\n   162→            .unwrap_or_else(|| workspace.config.workspace.git_bin.clone());\n   163→        let gh_bin = cli_gh_bin\n   164→            .clone()\n   165→            .unwrap_or_else(|| workspace.config.workspace.gh_bin.clone());\n   166→\n   167→        preflight_check_git(&git_bin)?;\n   168→        preflight_check_gh(&gh_bin)?;\n   169→\n   170→        // Ensure lifecycle labels exist (best-effort, non-blocking)\n   171→        github::ensure_labels_best_effort_with_gh_bin(&gh_bin, &owner, &repo_name).await;\n   172→\n   173→        // Ensure PRD lifecycle labels exist (best-effort, non-blocking)\n   174→        github::ensure_prd_labels_best_effort_with_gh_bin(&gh_bin, &owner, &repo_name).await;\n   175→\n   176→        // Load project config if an active project exists\n   177→        let project_config = match workspace.active_project_id() {\n   178→            Some(project_id) if workspace.project_exists(&project_id) => {\n   179→                load_project_config_if_exists(&workspace.project_dir(&project_id))?\n   180→            }\n   181→            _ => None,\n   182→        };\n   183→\n   184→        let daemon_cfg = resolve_daemon_config(&workspace.config, project_config.as_ref());\n   185→        crate::config::validate_daemon_workspace_config(&workspace.config).map_err(|err| {\n   186→            RalphError::Validation(format!(\"invalid daemon config for {slug}: {err}\"))\n   187→        })?;\n   188→        validate_effective_daemon_config(&workspace.config, &daemon_cfg).map_err(|err| {\n   189→            RalphError::Validation(format!(\"invalid daemon config for {slug}: {err}\"))\n   190→        })?;\n   191→        // Validate the backend string at startup so invalid config fails early.\n   192→        // The raw string is stored and parsed again at invocation time by\n   193→        // resolve_rebase_conflicts.\n   194→        let rebase_agent_backend_str = daemon_cfg.rebase_agent_backend.clone();\n   195→        rebase_agent::parse_rebase_agent_backend(&rebase_agent_backend_str).map_err(|err| {\n   196→            RalphError::Validation(format!(\n   197→                \"invalid daemon rebase agent backend for {slug}: {err}\"\n   198→            ))\n   199→        })?;\n   200→\n   201→        // Validate PRD backend config at startup so invalid specs fail fast.\n   202→        if daemon_cfg.prd_enabled {\n   203→            crate::config::validate_interactive_prd_workspace_config(&workspace.config).map_err(\n   204→                |err| RalphError::Validation(format!(\"invalid PRD config for {slug}: {err}\")),\n   205→            )?;\n   206→        }\n   207→\n   208→        if !deprecation_warned && daemon_cfg.repo.is_some() {\n   209→            eprintln!(\n   210→                \"warning: daemon.repo config key is ignored by `daemon start`; use --repo flag instead\"\n   211→            );\n   212→            deprecation_warned = true;\n   213→        }\n   214→\n   215→        let poll_seconds = args.poll_seconds.unwrap_or(daemon_cfg.poll_seconds);\n   216→        let max_concurrent = args.max_concurrent.unwrap_or(daemon_cfg.max_concurrent);\n   217→        let labels = if args.labels.is_empty() {\n   218→            daemon_cfg.labels\n   219→        } else {\n   220→            args.labels.clone()\n   221→        };\n   222→\n   223→        println!(\n   224→            \"daemon start validated for repo {}/{} (poll={}s, max_concurrent={}, labels={})\",\n   225→            owner,\n   226→            repo_name,\n   227→            poll_seconds,\n   228→            max_concurrent,\n   229→            labels.join(\",\")\n   230→        );\n   231→\n   232→        let runtime_config = DaemonRuntimeConfig {\n   233→            owner,\n   234→            repo: repo_name,\n   235→            base_branch: workspace.config.git.base_branch.clone(),\n   236→            poll_seconds,\n   237→            max_concurrent,\n   238→            labels,\n   239→            single_iteration: args.single_iteration,\n   240→            verbose: args.verbose,\n   241→            repo_root: repo_dir,\n   242→            refinement_enabled: daemon_cfg.refinement_enabled,\n   243→            refinement_backend: daemon_cfg.refinement_backend,\n   244→            global_config: workspace.config.clone(),\n   245→            auto_rebase_enabled: daemon_cfg.auto_rebase_enabled,\n   246→            rebase_interval_seconds: daemon_cfg.rebase_interval_seconds,\n   247→            max_rebases_per_cycle: daemon_cfg.max_rebases_per_cycle,\n   248→            rebase_timeout_seconds: daemon_cfg.rebase_timeout_seconds,\n   249→            rebase_agent_backend: rebase_agent_backend_str,\n   250→            workspace_root: workspace.root.clone(),\n   251→            prd_enabled: daemon_cfg.prd_enabled,\n   252→            prd_question_backends: daemon_cfg.prd_question_backends,\n   253→            prd_writer_backend: daemon_cfg.prd_writer_backend,\n   254→            prd_reviewer_backend: daemon_cfg.prd_reviewer_backend,\n   255→            prd_max_revisions: daemon_cfg.prd_max_revisions,\n   256→            prd_backend_timeout_secs: daemon_cfg.prd_backend_timeout_secs,\n   257→            prd_shutdown_timeout_secs: daemon_cfg.prd_shutdown_timeout_secs,\n   258→            git_bin,\n   259→            gh_bin,\n   260→            max_backend_retries: daemon_cfg.max_backend_retries,\n   261→            pr_review_whitelist: daemon_cfg.pr_review_whitelist.clone(),\n   262→        };\n   263→\n   264→        let daemon_lock = DaemonLock::acquire(&runtime_config.repo_root)?;\n   265→        daemon_locks.push(daemon_lock);\n   266→        repo_configs.push(runtime_config);\n   267→    }\n   268→\n   269→    // Run one runtime::run() per repo using JoinSet\n   270→    let mut join_set = tokio::task::JoinSet::new();\n   271→\n   272→    for config in repo_configs {\n   273→        join_set.spawn(async move { crate::daemon::runtime::run(&config).await });\n   274→    }\n   275→\n   276→    while let Some(result) = join_set.join_next().await {\n   277→        match result {\n   278→            Err(join_err) => {\n   279→                join_set.abort_all();\n   280→                return Err(RalphError::Orchestration(format!(\n   281→                    \"daemon runtime task panicked: {join_err}\"\n   282→                )));\n   283→            }\n   284→            Ok(Err(err)) => {\n   285→                join_set.abort_all();\n   286→                return Err(err);\n   287→            }\n   288→            Ok(Ok(())) => {}\n   289→        }\n   290→    }\n   291→\n   292→    drop(daemon_locks);\n   293→    Ok(())\n   294→}\n   295→\n   296→/// Status: query GitHub labels to show current issue lifecycle state.\n   297→async fn execute_status(args: DaemonStatusArgs) -> Result<()> {\n   298→    let repos = if args.repo.is_empty() {\n   299→        // Scan data-dir for owner/repo directories\n   300→        scan_repo_slugs(&args.data_dir)?\n   301→    } else {\n   302→        args.repo\n   303→            .iter()\n   304→            .map(|r| {\n   305→                validate_repo_slug(r)?;\n   306→                Ok(r.trim().to_ascii_lowercase())\n   307→            })\n   308→            .collect::<Result<Vec<_>>>()?\n   309→    };\n   310→\n   311→    if repos.is_empty() {\n   312→        println!(\"no daemon repos found\");\n   313→        return Ok(());\n   314→    }\n   315→\n   316→    let mut found_any = false;\n   317→\n   318→    for slug in &repos {\n   319→        let (owner, repo_name) = parse_repo_slug(slug)?;\n   320→\n   321→        // Query issues with lifecycle labels from GitHub.\n   322→        // Each label requires a separate query because `gh issue list --label`\n   323→        // uses AND semantics (repeated --label only returns issues matching ALL).\n   324→        let mut issues: Vec<github::GhIssue> = Vec::new();\n   325→        let mut seen: std::collections::HashSet<u32> = std::collections::HashSet::new();\n   326→        for label in &[\"ralph:ready\", \"ralph:in-progress\"] {\n   327→            let query_labels = vec![label.to_string()];\n   328→            match github::poll_issues(&owner, &repo_name, &query_labels).await {\n   329→                Ok((batch, _overflow)) => {\n   330→                    for issue in batch {\n   331→                        if seen.insert(issue.number) {\n   332→                            issues.push(issue);\n   333→                        }\n   334→                    }\n   335→                }\n   336→                Err(err) => {\n   337→                    eprintln!(\"warning: failed to query {label} issues for {slug}: {err}\");\n   338→                }\n   339→            }\n   340→        }\n   341→\n   342→        if issues.is_empty() {\n   343→            continue;\n   344→        }\n   345→\n   346→        if !found_any {\n   347→            println!(\"DAEMON ISSUES\");\n   348→            println!(\"{:<20} {:<8} {:<30}\", \"REPO\", \"ISSUE\", \"LIFECYCLE LABELS\");\n   349→            found_any = true;\n   350→        }\n   351→\n   352→        for issue in &issues {\n   353→            let lifecycle = github::classify_lifecycle_labels(&issue.labels);\n   354→            println!(\n   355→                \"{:<20} {:<8} {:<30}\",\n   356→                slug,\n   357→                issue.number,\n   358→                lifecycle.join(\", \")\n   359→            );\n   360→        }\n   361→    }\n   362→\n   363→    if !found_any {\n   364→        println!(\"no daemon tasks\");\n   365→    }\n   366→\n   367→    Ok(())\n   368→}\n   369→\n   370→/// Abort: kill child (if running locally) and swap label to `ralph:failed`.\n   371→async fn execute_abort(args: DaemonAbortArgs) -> Result<()> {\n   372→    let issue_number: u32 = args.issue_number.parse().map_err(|_| {\n   373→        RalphError::Validation(format!(\"invalid issue number: {}\", args.issue_number))\n   374→    })?;\n   375→\n   376→    let slug = args\n   377→        .repo\n   378→        .ok_or_else(|| RalphError::Validation(\"--repo is required for abort\".to_owned()))?;\n   379→    let (owner, repo_name) = parse_repo_slug(&slug)?;\n   380→\n   381→    // Verify the issue is currently in-progress\n   382→    let labels = github::fetch_issue_labels(&owner, &repo_name, issue_number).await?;\n   383→    let lifecycle = github::classify_lifecycle_labels(&labels);\n   384→\n   385→    if !lifecycle.iter().any(|l| l == \"ralph:in-progress\") {\n   386→        return Err(RalphError::Validation(format!(\n   387→            \"issue {slug}#{issue_number} is not in-progress (labels: {})\",\n   388→            lifecycle.join(\", \")\n   389→        )));\n   390→    }\n   391→\n   392→    // Swap label: in-progress -> failed (no PID info available from CLI)\n   393→    crate::daemon::abort_task_by_labels(&owner, &repo_name, issue_number, None).await?;\n   394→\n   395→    println!(\"aborted issue {slug}#{issue_number}\");\n   396→    Ok(())\n   397→}\n   398→\n   399→async fn execute_retrigger(args: DaemonRetriggerArgs) -> Result<()> {\n   400→    let issue_number: u32 = args.issue_number.parse().map_err(|_| {\n   401→        RalphError::Validation(format!(\"invalid issue number: {}\", args.issue_number))\n   402→    })?;\n   403→\n   404→    let slug = args\n   405→        .repo\n   406→        .ok_or_else(|| RalphError::Validation(\"--repo is required for retrigger\".to_owned()))?;\n   407→    let (owner, repo_name) = parse_repo_slug(&slug)?;\n   408→\n   409→    retrigger_failed_task(&owner, &repo_name, issue_number).await?;\n   410→    println!(\"retriggered issue {slug}#{issue_number}\");\n   411→    Ok(())\n   412→}\n   413→\n   414→/// Scan `<data-dir>/<owner>/<repo>` directories and return owner/repo slugs.\n   415→fn scan_repo_slugs(data_dir: &Path) -> Result<Vec<String>> {\n   416→    let mut slugs = Vec::new();\n   417→\n   418→    let owners = match std::fs::read_dir(data_dir) {\n   419→        Ok(entries) => entries,\n   420→        Err(err) if err.kind() == std::io::ErrorKind::NotFound => return Ok(slugs),\n   421→        Err(err) => return Err(err.into()),\n   422→    };\n   423→\n   424→    for owner_entry in owners {\n   425→        let owner_entry = owner_entry?;\n   426→        if !owner_entry.file_type()?.is_dir() {\n   427→            continue;\n   428→        }\n   429→\n   430→        let owner_name = owner_entry.file_name().to_string_lossy().into_owned();\n   431→        let repos = match std::fs::read_dir(owner_entry.path()) {\n   432→            Ok(entries) => entries,\n   433→            Err(_) => continue,\n   434→        };\n   435→\n   436→        for repo_entry in repos {\n   437→            let repo_entry = repo_entry?;\n   438→            if !repo_entry.file_type()?.is_dir() {\n   439→                continue;\n   440→            }\n   441→\n   442→            let repo_name = repo_entry.file_name().to_string_lossy().into_owned();\n   443→            // Check if it looks like a git repo\n   444→            if repo_entry.path().join(\".git\").exists() {\n   445→                slugs.push(format!(\"{owner_name}/{repo_name}\"));\n   446→            }\n   447→        }\n   448→    }\n   449→\n   450→    Ok(slugs)\n   451→}\n   452→\n   453→/// Reject `--data-dir` paths inside a git working tree.\n   454→fn guard_not_git_repo(data_dir: &Path, git_bin: &str) -> Result<()> {\n   455→    let check_dir = nearest_existing_ancestor(data_dir);\n   456→\n   457→    let output = Command::new(git_bin)\n   458→        .args([\"rev-parse\", \"--show-toplevel\"])\n   459→        .current_dir(&check_dir)\n   460→        .stdout(std::process::Stdio::piped())\n   461→        .stderr(std::process::Stdio::piped())\n   462→        .output();\n   463→\n   464→    match output {\n   465→        Ok(out) if out.status.success() => Err(RalphError::Validation(\n   466→            \"--data-dir must not be inside a git repository\".to_owned(),\n   467→        )),\n   468→        _ => Ok(()),\n   469→    }\n   470→}\n   471→\n   472→fn nearest_existing_ancestor(path: &Path) -> PathBuf {\n   473→    let mut current = path.to_path_buf();\n   474→    loop {\n   475→        if current.exists() {\n   476→            return current;\n   477→        }\n   478→        if !current.pop() {\n   479→            return PathBuf::from(\"/\");\n   480→        }\n   481→    }\n   482→}\n   483→\n   484→fn clone_or_bootstrap(\n   485→    owner: &str,\n   486→    repo: &str,\n   487→    repo_dir: &Path,\n   488→    gh_bin: &str,\n   489→    git_bin: &str,\n   490→) -> Result<()> {\n   491→    if repo_dir.join(\".git\").exists() {\n   492→        bootstrap::ensure_repo_ready_sync(repo_dir)?;\n   493→        return Ok(());\n   494→    }\n   495→\n   496→    if let Some(parent) = repo_dir.parent() {\n   497→        std::fs::create_dir_all(parent).map_err(|err| {\n   498→            RalphError::Orchestration(format!(\n   499→                \"failed to create parent directory for {}: {err}\",\n   500→                repo_dir.display()\n   501→            ))\n   502→        })?;\n   503→    }\n   504→\n   505→    let slug = format!(\"{owner}/{repo}\");\n   506→    let repo_dir_str = repo_dir.to_string_lossy();\n   507→    let output = Command::new(gh_bin)\n   508→        .args([\"repo\", \"clone\", &slug, &repo_dir_str])\n   509→        .output()\n   510→        .map_err(|err| {\n   511→            RalphError::Orchestration(format!(\"failed to run {gh_bin} repo clone {slug}: {err}\"))\n   512→        })?;\n   513→\n   514→    if !output.status.success() {\n   515→        let stderr = String::from_utf8_lossy(&output.stderr);\n   516→        return Err(RalphError::Orchestration(format!(\n   517→            \"{gh_bin} repo clone {slug} failed: {}\",\n   518→            stderr.trim()\n   519→        )));\n   520→    }\n   521→\n   522→    let ssh_url = format!(\"git@github.com:{owner}/{repo}.git\");\n   523→    let _ = Command::new(git_bin)\n   524→        .args([\"remote\", \"set-url\", \"origin\", &ssh_url])\n   525→        .current_dir(repo_dir)\n   526→        .output();\n   527→\n   528→    bootstrap::ensure_repo_ready_sync(repo_dir)?;\n   529→    Ok(())\n   530→}\n   531→\n   532→fn validate_repo_slug(repo: &str) -> Result<()> {\n   533→    let trimmed = repo.trim();\n   534→    let Some((owner, name)) = trimmed.split_once('/') else {\n   535→        return Err(RalphError::Validation(format!(\n   536→            \"invalid repo '{}': expected owner/repo\",\n   537→            repo\n   538→        )));\n   539→    };\n   540→\n   541→    let invalid = owner.is_empty()\n   542→        || name.is_empty()\n   543→        || name.contains('/')\n   544→        || owner == \".\"\n   545→        || owner == \"..\"\n   546→        || name == \".\"\n   547→        || name == \"..\"\n   548→        || !is_valid_repo_component(owner)\n   549→        || !is_valid_repo_component(name);\n   550→    if invalid {\n   551→        return Err(RalphError::Validation(format!(\n   552→            \"invalid repo '{}': expected owner/repo\",\n   553→            repo\n   554→        )));\n   555→    }\n   556→\n   557→    Ok(())\n   558→}\n   559→\n   560→fn parse_repo_slug(repo: &str) -> Result<(String, String)> {\n   561→    validate_repo_slug(repo)?;\n   562→    let trimmed = repo.trim();\n   563→    let (owner, name) = trimmed.split_once('/').unwrap_or_default();\n   564→    Ok((owner.to_owned(), name.to_owned()))\n   565→}\n   566→\n   567→fn is_valid_repo_component(component: &str) -> bool {\n   568→    component\n   569→        .chars()\n   570→        .all(|ch| ch.is_ascii_alphanumeric() || ch == '.' || ch == '_' || ch == '-')\n   571→}\n   572→\n   573→fn preflight_check_git(git_bin: &str) -> Result<()> {\n   574→    match Command::new(git_bin).arg(\"--version\").output() {\n   575→        Ok(_) => Ok(()),\n   576→        Err(err) if err.kind() == std::io::ErrorKind::NotFound => Err(RalphError::Validation(\n   577→            format!(\n   578→                \"git executable not found: {git_bin}. Set --git-bin or workspace.git_bin to a valid path.\"\n   579→            ),\n   580→        )),\n   581→        Err(err) => Err(RalphError::Validation(format!(\n   582→            \"git executable check failed ({git_bin}): {err}\"\n   583→        ))),\n   584→    }\n   585→}\n   586→\n   587→fn preflight_check_gh(gh_bin: &str) -> Result<()> {\n   588→    match Command::new(gh_bin).arg(\"--version\").output() {\n   589→        Ok(_) => Ok(()),\n   590→        Err(err) if err.kind() == std::io::ErrorKind::NotFound => {\n   591→            Err(RalphError::Validation(format!(\n   592→                \"gh executable not found: {gh_bin}. The daemon requires gh to poll issues, \\\n   593→                 post comments, and create PRs. Set --gh-bin or workspace.gh_bin to a valid path.\"\n   594→            )))\n   595→        }\n   596→        Err(err) => Err(RalphError::Validation(format!(\n   597→            \"gh executable check failed ({gh_bin}): {err}\"\n   598→        ))),\n   599→    }\n   600→}\n   601→"}]},"parent_tool_use_id":"toolu_015UBZ4JVrmK3iBgEnHWXFGU","session_id":"3d9a0615-7442-4a66-ab27-f8160d110223","uuid":"1c54efa6-e9b6-4ce0-95cd-d1c75ca7663b"}
