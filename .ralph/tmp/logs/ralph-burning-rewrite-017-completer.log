{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_011HSoRLXNY62QnLuNjivnws","type":"tool_result","content":"     1→use std::fmt;\n     2→use std::path::Path;\n     3→\n     4→use toml_edit::{value, DocumentMut};\n     5→\n     6→use crate::adapters::fs::FileSystem;\n     7→use crate::shared::domain::{FlowPreset, WorkspaceConfig};\n     8→use crate::shared::error::{AppError, AppResult};\n     9→\n    10→use super::{load_workspace_config, workspace_config_path};\n    11→\n    12→/// Default: enabled.\n    13→pub const DEFAULT_PROMPT_REVIEW_ENABLED: bool = true;\n    14→/// Default: standard.\n    15→pub const DEFAULT_FLOW_PRESET: FlowPreset = FlowPreset::Standard;\n    16→\n    17→#[derive(Debug, Clone, Copy, PartialEq, Eq)]\n    18→pub enum ConfigValueSource {\n    19→    Default,\n    20→    WorkspaceToml,\n    21→}\n    22→\n    23→impl fmt::Display for ConfigValueSource {\n    24→    fn fmt(&self, f: &mut fmt::Formatter<'_>) -> fmt::Result {\n    25→        match self {\n    26→            Self::Default => f.write_str(\"default\"),\n    27→            Self::WorkspaceToml => f.write_str(\"workspace.toml\"),\n    28→        }\n    29→    }\n    30→}\n    31→\n    32→#[derive(Debug, Clone, PartialEq, Eq)]\n    33→pub enum ConfigValue {\n    34→    Bool(bool),\n    35→    FlowPreset(FlowPreset),\n    36→    String(Option<String>),\n    37→}\n    38→\n    39→impl ConfigValue {\n    40→    pub fn display_value(&self) -> String {\n    41→        match self {\n    42→            Self::Bool(value) => value.to_string(),\n    43→            Self::FlowPreset(value) => value.as_str().to_owned(),\n    44→            Self::String(Some(value)) => value.clone(),\n    45→            Self::String(None) => \"<unset>\".to_owned(),\n    46→        }\n    47→    }\n    48→\n    49→    pub fn toml_like_value(&self) -> String {\n    50→        match self {\n    51→            Self::Bool(value) => value.to_string(),\n    52→            Self::FlowPreset(value) => format!(\"\\\"{}\\\"\", value.as_str()),\n    53→            Self::String(Some(value)) => format!(\"\\\"{value}\\\"\"),\n    54→            Self::String(None) => \"\\\"<unset>\\\"\".to_owned(),\n    55→        }\n    56→    }\n    57→}\n    58→\n    59→#[derive(Debug, Clone, PartialEq, Eq)]\n    60→pub struct ConfigEntry {\n    61→    pub key: &'static str,\n    62→    pub value: ConfigValue,\n    63→    pub source: ConfigValueSource,\n    64→}\n    65→\n    66→#[derive(Debug, Clone, PartialEq, Eq)]\n    67→struct ResolvedValue<T> {\n    68→    value: T,\n    69→    source: ConfigValueSource,\n    70→}\n    71→\n    72→#[derive(Debug, Clone, PartialEq, Eq)]\n    73→pub struct EffectiveConfig {\n    74→    prompt_review_enabled: ResolvedValue<bool>,\n    75→    default_flow: ResolvedValue<FlowPreset>,\n    76→    default_backend: ResolvedValue<Option<String>>,\n    77→    default_model: ResolvedValue<Option<String>>,\n    78→}\n    79→\n    80→impl EffectiveConfig {\n    81→    pub fn load(base_dir: &Path) -> AppResult<Self> {\n    82→        let config = load_workspace_config(base_dir)?;\n    83→        Ok(Self::from_workspace_config(&config))\n    84→    }\n    85→\n    86→    pub fn get(&self, key: &str) -> AppResult<ConfigEntry> {\n    87→        let key = ConfigKey::parse(key)?;\n    88→        Ok(self.entry_for(key))\n    89→    }\n    90→\n    91→    pub fn set(base_dir: &Path, key: &str, value: &str) -> AppResult<ConfigEntry> {\n    92→        let key = ConfigKey::parse(key)?;\n    93→        let _ = Self::load(base_dir)?;\n    94→\n    95→        let config_path = workspace_config_path(base_dir);\n    96→        let raw = FileSystem::read_to_string(&config_path)?;\n    97→        let mut document = raw.parse::<DocumentMut>()?;\n    98→        key.apply_to_document(&mut document, value)?;\n    99→        FileSystem::write_atomic(&config_path, &document.to_string())?;\n   100→"}]},"parent_tool_use_id":"toolu_01KfEVp49FXGUv77ZeSPdiaP","session_id":"3d9a0615-7442-4a66-ab27-f8160d110223","uuid":"eb6ba9d5-0d03-4cc9-97e2-780c9d6c6436"}
