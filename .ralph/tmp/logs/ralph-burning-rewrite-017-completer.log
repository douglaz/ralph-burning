     task_id: String,\n   151→        from: String,\n   152→        to: String,\n   153→    },\n   154→    #[error(\"rebase conflict for branch '{branch_name}': {details}\")]\n   155→    RebaseConflict {\n   156→        branch_name: String,\n   157→        details: String,\n   158→    },\n   159→    #[error(\"watcher ingestion failed for issue '{issue_ref}': {details}\")]\n   160→    WatcherIngestionFailed { issue_ref: String, details: String },\n   161→    #[error(\"requirements handoff failed for task '{task_id}': {details}\")]\n   162→    RequirementsHandoffFailed { task_id: String, details: String },\n   163→    #[error(\"duplicate watched issue '{issue_ref}' with source_revision '{source_revision}'\")]\n   164→    DuplicateWatchedIssue {\n   165→        issue_ref: String,\n   166→        source_revision: String,\n   167→    },\n   168→    #[error(\"conformance parse error in {file} line {line}: {details}\")]\n   169→    ConformanceParseFailed {\n   170→        file: String,\n   171→        line: usize,\n   172→        details: String,\n   173→    },\n   174→    #[error(\"conformance discovery failed: {details}\")]\n   175→    ConformanceDiscoveryFailed { details: String },\n   176→    #[error(\"conformance registry drift: {details}\")]\n   177→    ConformanceRegistryDrift { details: String },\n   178→    #[error(\"conformance filter failed: unknown scenario ID '{scenario_id}'\")]\n   179→    ConformanceFilterFailed { scenario_id: String },\n   180→    #[error(\"cutover guard violation in {file} line {line}: {pattern}\")]\n   181→    ConformanceCutoverViolation {\n   182→        file: String,\n   183→        line: usize,\n   184→        pattern: String,\n   185→    },\n   186→    #[error(\"conformance scenario '{scenario_id}' failed: {details}\")]\n   187→    ConformanceScenarioFailed {\n   188→        scenario_id: String,\n   189→        details: String,\n   190→    },\n   191→    #[error(\"conformance run failed (see above for details)\")]\n   192→    Conforma