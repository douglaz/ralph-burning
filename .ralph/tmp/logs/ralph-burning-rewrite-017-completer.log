{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01XfqrqXXiMqTEpdFpRXEb53","type":"tool_result","content":"     1→use std::fs;\n     2→use std::path::{Path, PathBuf};\n     3→use std::process::Command;\n     4→\n     5→use crate::contexts::automation_runtime::WorktreePort;\n     6→use crate::contexts::project_run_record::service::RepositoryResetPort;\n     7→use crate::shared::error::{AppError, AppResult};\n     8→\n     9→#[derive(Debug, Default, Clone, Copy)]\n    10→pub struct WorktreeAdapter;\n    11→\n    12→impl WorktreeAdapter {\n    13→    fn git(repo_root: &Path, args: &[&str]) -> AppResult<std::process::Output> {\n    14→        Command::new(\"git\")\n    15→            .args(args)\n    16→            .current_dir(repo_root)\n    17→            .output()\n    18→            .map_err(AppError::from)\n    19→    }\n    20→\n    21→    fn git_in(dir: &Path, args: &[&str]) -> AppResult<std::process::Output> {\n    22→        Command::new(\"git\")\n    23→            .args(args)\n    24→            .current_dir(dir)\n    25→            .output()\n    26→            .map_err(AppError::from)\n    27→    }\n    28→\n    29→    fn default_branch_ref(&self, repo_root: &Path) -> AppResult<String> {\n    30→        let origin_head = Self::git(\n    31→            repo_root,\n    32→            &[\n    33→                \"symbolic-ref\",\n    34→                \"--quiet\",\n    35→                \"--short\",\n    36→                \"refs/remotes/origin/HEAD\",\n    37→            ],\n    38→        )?;\n    39→        if origin_head.status.success() {\n    40→            let value = String::from_utf8_lossy(&origin_head.stdout)\n    41→                .trim()\n    42→                .to_owned();\n    43→            if !value.is_empty() {\n    44→                return Ok(value);\n    45→            }\n    46→        }\n    47→\n    48→        let current = Self::git(repo_root, &[\"branch\", \"--show-current\"])?;\n    49→        if current.status.success() {\n    50→            let branch = String::from_utf8_lossy(&current.stdout).trim().to_owned();"}]},"parent_tool_use_id":"toolu_01KfEVp49FXGUv77ZeSPdiaP","session_id":"3d9a0615-7442-4a66-ab27-f8160d110223","uuid":"24bb0e5f-b8df-48fe-85d4-18c72a46985f"}
