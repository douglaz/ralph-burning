48→pub struct SessionStore {\n   249→    pub sessions: Vec<serde_json::Value>,\n   250→}\n   251→\n   252→impl SessionStore {\n   253→    pub fn empty() -> Self {\n   254→        Self {\n   255→            sessions: Vec::new(),\n   256→        }\n   257→    }\n   258→}\n   259→\n   260→/// Summary of a failed stage for run snapshot persistence.\n   261→#[derive(Debug, Clone, PartialEq, Serialize, Deserialize)]\n   262→pub struct FailedStageSummary {\n   263→    pub stage_id: StageId,\n   264→    pub cycle: u32,\n   265→    pub attempt: u32,\n   266→    pub failure_class: String,\n   267→    pub message: String,\n   268→    pub failed_at: DateTime<Utc>,\n   269→}\n   270→\n   271→/// Summary used in `project list` output.\n   272→#[derive(Debug, Clone)]\n   273→pub struct ProjectListEntry {\n   274→    pub id: ProjectId,\n   275→    pub name: String,\n   276→    pub flow: FlowPreset,\n   277→    pub status_summary: ProjectStatusSummary,\n   278→    pub created_at: DateTime<Utc>,\n   279→    pub is_active: bool,\n   280→}\n   281→\n   282→/// Detailed project view used in `project show` output.\n   283→#[derive(Debug, Clone)]\n   284→pub struct ProjectDetail {\n   285→    pub record: ProjectRecord,\n   286→    pub run_snapshot: RunSnapshot,\n   287→    pub journal_event_count: u64,\n   288→    pub rollback_count: usize,\n   289→    pub is_active: bool,\n   290→}\n   291→"}]},"parent_tool_use_id":"toolu_01WxWEKeVM8eN1eTgMgZkDxS","session_id":"3d9a0615-7442-4a66-ab27-f8160d110223","uuid":"3aa8bd79-9b72-4eb7-b7c0-bd0871650877"}
