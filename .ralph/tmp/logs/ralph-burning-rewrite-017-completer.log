{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01AKeim2Zmzs5EsiyTkF6xzb","type":"tool_result","content":"     1→use std::fs;\n     2→use std::io::ErrorKind;\n     3→use std::path::{Path, PathBuf};\n     4→\n     5→use toml_edit::DocumentMut;\n     6→\n     7→use crate::cli::InitArgs;\n     8→use crate::config::GlobalConfig;\n     9→use crate::error::RalphError;\n    10→use crate::prompts::templates::{\n    11→    default_arbiter_template, default_completer_template, default_final_reviewer_template,\n    12→    default_implementer_template, default_planner_position_template, default_planner_template,\n    13→    default_prompt_review_validator_template, default_prompt_reviewer_template,\n    14→    default_qa_template, default_reviewer_template, default_vote_template,\n    15→};\n    16→use crate::workspace::Workspace;\n    17→use crate::Result;\n    18→\n    19→type TemplateContentFn = fn() -> &'static str;\n    20→\n    21→pub(crate) const MINIMAL_TOML: &str = r#\"\n    22→# ralph workspace configuration\n    23→# The defaults are loaded from built-in values in the application and shown here\n    24→# for convenience so this file remains intentionally minimal.\n    25→[workspace]\n    26→\"#;\n    27→\n    28→pub(crate) const TEMPLATE_FILES: &[(&str, TemplateContentFn)] = &[\n    29→    (\"spec.md\", default_planner_template),\n    30→    (\"implementation.md\", default_implementer_template),\n    31→    (\"review.md\", default_reviewer_template),\n    32→    (\"prompt_reviewer.md\", default_prompt_reviewer_template),\n    33→    (\n    34→        \"prompt_review_validator.md\",\n    35→        default_prompt_review_validator_template,\n    36→    ),\n    37→    (\"completion.md\", default_completer_template),\n    38→    (\"qa.md\", default_qa_template),\n    39→    (\"final_reviewer.md\", default_final_reviewer_template),\n    40→    (\"planner_position.md\", default_planner_position_template),\n    41→    (\"vote.md\", default_vote_template),\n    42→    (\"arbiter.md\", default_arbiter_template),\n    43→];\n    44→\n    45→#[derive(Debug, Clone, PartialEq, Eq)]\n    46→pub(crate) enum InitAction {\n    47→    CreateDir {\n    48→        path: PathBuf,\n    49→    },\n    50→    WriteMinimalConfig {\n    51→        path: PathBuf,\n    52→    },\n    53→    WriteConfig {\n    54→        path: PathBuf,\n    55→    },\n    56→    WriteTemplate {\n    57→        path: PathBuf,\n    58→        content: &'static str,\n    59→    },\n    60→    OverlayConfig {\n    61→        path: PathBuf,\n    62→    },\n    63→}\n    64→\n    65→impl InitAction {\n    66→    fn describe(&self) -> String {\n    67→        match self {\n    68→            Self::CreateDir { path } => format!(\"create-dir {}\", path.display()),\n    69→            Self::WriteMinimalConfig { path } => format!(\"write-config {}\", path.display()),\n    70→            Self::WriteConfig { path } => format!(\"write-config {}\", path.display()),\n    71→            Self::WriteTemplate { path, .. } => format!(\"write-template {}\", path.display()),\n    72→            Self::OverlayConfig { path } => format!(\"overlay-config {}\", path.display()),\n    73→        }\n    74→    }\n    75→}\n    76→\n    77→fn invalid_target(path: &Path, reason: impl Into<String>) -> RalphError {\n    78→    RalphError::InitTargetInvalid {\n    79→        path: path.to_path_buf(),\n    80→        reason: reason.into(),\n    81→    }\n    82→}\n    83→\n    84→fn validate_parent_chain(root: &Path) -> Result<()> {\n    85→    let mut current = root.parent();\n    86→    while let Some(parent) = current {\n    87→        match fs::metadata(parent) {\n    88→            Ok(metadata) => {\n    89→                if !metadata.is_dir() {\n    90→                    return Err(invalid_target(\n    91→                        root,\n    92→                        format!(\"parent '{}' is not a directory\", parent.display()),\n    93→                    ));\n    94→                }\n    95→                fs::read_dir(parent).map_err(|err| {\n    96→                    invalid_target(\n    97→                        root,\n    98→                        format!(\"cannot access parent '{}': {err}\", parent.display()),\n    99→                    )\n   100→                })?;\n   101→                return Ok(());\n   102→            }\n   103→            Err(err) if err.kind() == ErrorKind::NotFound => {\n   104→                current = parent.parent();\n   105→            }\n   106→            Err(err) => {\n   107→                return Err(invalid_target(\n   108→                    root,\n   109→                    format!(\"cannot access parent '{}': {err}\", parent.display()),\n   110→                ));\n   111→            }\n   112→        }\n   113→    }\n   114→\n   115→    Ok(())\n   116→}\n   117→\n   118→pub(crate) fn validate_target(root: &Path) -> Result<()> {\n   119→    match fs::metadata(root) {\n   120→        Ok(metadata) => {\n   121→            if !metadata.is_dir() {\n   122→                return Err(invalid_target(root, \"target exists but is not a directory\"));\n   123→            }\n   124→\n   125→            let mut entries = fs::read_dir(root).map_err(|err| {\n   126→                invalid_target(root, format!(\"cannot read target directory: {err}\"))\n   127→            })?;\n   128→            if entries.next().transpose()?.is_some() {\n   129→                return Err(RalphError::Validation(format!(\n   130→                    \"workspace directory '{}' already exists and is not empty\",\n   131→                    root.display()\n   132→                )));\n   133→            }\n   134→            Ok(())\n   135→        }\n   136→        Err(err) if err.kind() == ErrorKind::NotFound => validate_parent_chain(root),\n   137→        Err(err) => Err(invalid_target(root, format!(\"cannot access target: {err}\"))),\n   138→    }\n   139→}\n   140→\n   141→/// Result of validating a `--copy-files` target directory.\n   142→#[derive(Debug)]\n   143→enum CopyFilesTarget {\n   144→    /// Directory is new or empty — full scaffold needed.\n   145→    NewOrEmpty,\n   146→    /// Existing workspace with valid ralph.toml — overlay mode.\n   147→    ExistingWorkspace,\n   148→}\n   149→\n   150→/// Validate the target for `--copy-files` mode. Returns:\n   151→/// - `Ok(NewOrEmpty)` for non-existent or empty directories.\n   152→/// - `Ok(ExistingWorkspace)` when `ralph.toml` exists and parses.\n   153→/// - `Err` with exit code 2 for non-workspace non-empty dirs.\n   154→/// - `Err` with exit code 1 for malformed ralph.toml.\n   155→fn validate_copy_files_target(root: &Path) -> Result<CopyFilesTarget> {\n   156→    match fs::metadata(root) {\n   157→        Ok(metadata) => {\n   158→            if !metadata.is_dir() {\n   159→                return Err(invalid_target(root, \"target exists but is not a directory\"));\n   160→            }\n   161→\n   162→            let mut entries = fs::read_dir(root).map_err(|err| {\n   163→                invalid_target(root, format!(\"cannot read target directory: {err}\"))\n   164→            })?;\n   165→            let is_empty = entries.next().transpose()?.is_none();\n   166→            if is_empty {\n   167→                return Ok(CopyFilesTarget::NewOrEmpty);\n   168→            }\n   169→\n   170→            // Non-empty directory — check for ralph.toml\n   171→            let toml_path = root.join(\"ralph.toml\");\n   172→            match fs::metadata(&toml_path) {\n   173→                Ok(m) if m.is_file() => {}\n   174→                Ok(_) | Err(_) => {\n   175→                    return Err(RalphError::Validation(\n   176→                        \"directory exists but is not a ralph workspace (no ralph.toml found)\"\n   177→                            .to_owned(),\n   178→                    ));\n   179→                }\n   180→            }\n   181→\n   182→            // ralph.toml exists — try to parse it\n   183→            let raw = fs::read_to_string(&toml_path)?;\n   184→            let _config: GlobalConfig = toml::from_str(&raw).map_err(|e| {\n   185→                RalphError::Orchestration(format!(\"failed to parse ralph.toml: {e}\"))\n   186→            })?;\n   187→\n   188→            Ok(CopyFilesTarget::ExistingWorkspace)\n   189→        }\n   190→        Err(err) if err.kind() == ErrorKind::NotFound => {\n   191→            validate_parent_chain(root)?;\n   192→            Ok(CopyFilesTarget::NewOrEmpty)\n   193→        }\n   194→        Err(err) => Err(invalid_target(root, format!(\"cannot access target: {err}\"))),\n   195→    }\n   196→}\n   197→\n   198→pub(crate) fn plan_full_actions(root: &Path) -> Vec<InitAction> {\n   199→    let templates_dir = root.join(\"templates\");\n   200→"}]},"parent_tool_use_id":"toolu_01D1YGYYF5pXopdBJ1HtvaN6","session_id":"3d9a0615-7442-4a66-ab27-f8160d110223","uuid":"7105849b-44d4-48db-a225-1b389ebc74ce"}
