{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01CaPqkRaYmt85gf2TwK9pxv","type":"tool_result","content":"     1→use std::path::Path;\n     2→\n     3→use chrono::{DateTime, Utc};\n     4→\n     5→use crate::contexts::workflow_composition;\n     6→use crate::shared::domain::{FlowPreset, ProjectId, StageId};\n     7→use crate::shared::error::{AppError, AppResult};\n     8→\n     9→use super::journal;\n    10→use super::model::{\n    11→    ArtifactRecord, JournalEvent, JournalEventType, PayloadRecord, ProjectDetail, ProjectListEntry,\n    12→    ProjectRecord, ProjectStatusSummary, RollbackPoint, RunSnapshot, RunStatus, RuntimeLogEntry,\n    13→    SessionStore,\n    14→};\n    15→use super::queries::{self, RunHistoryView, RunStatusView, RunTailView};\n    16→\n    17→/// Port for reading and writing project records.\n    18→pub trait ProjectStorePort {\n    19→    fn project_exists(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<bool>;\n    20→    fn read_project_record(\n    21→        &self,\n    22→        base_dir: &Path,\n    23→        project_id: &ProjectId,\n    24→    ) -> AppResult<ProjectRecord>;\n    25→    fn list_project_ids(&self, base_dir: &Path) -> AppResult<Vec<ProjectId>>;\n    26→\n    27→    /// Stage a project for deletion: makes it invisible to list/show but\n    28→    /// keeps data on disk for potential rollback.\n    29→    fn stage_delete(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<()>;\n    30→\n    31→    /// Finalize a staged delete: permanently removes the project data.\n    32→    fn commit_delete(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<()>;\n    33→\n    34→    /// Roll back a staged delete: restores the project to its canonical path.\n    35→    fn rollback_delete(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<()>;\n    36→\n    37→    /// Atomically stage and commit a new project. If any step fails,\n    38→    /// the project must not be visible to list/show.\n    39→    fn create_project_atomic(\n    40→        &self,\n    41→        base_dir: &Path,\n    42→        record: &ProjectRecord,\n    43→        prompt_contents: &str,\n    44→        run_snapshot: &RunSnapshot,\n    45→        initial_journal_line: &str,\n    46→        sessions: &SessionStore,\n    47→    ) -> AppResult<()>;\n    48→}\n    49→\n    50→/// Port for reading and appending journal events.\n    51→pub trait JournalStorePort {\n    52→    fn read_journal(&self, base_dir: &Path, project_id: &ProjectId)\n    53→        -> AppResult<Vec<JournalEvent>>;\n    54→    fn append_event(&self, base_dir: &Path, project_id: &ProjectId, line: &str) -> AppResult<()>;\n    55→}\n    56→\n    57→/// Port for reading payload and artifact durable history.\n    58→pub trait ArtifactStorePort {\n    59→    fn list_payloads(\n    60→        &self,\n    61→        base_dir: &Path,\n    62→        project_id: &ProjectId,\n    63→    ) -> AppResult<Vec<PayloadRecord>>;\n    64→    fn list_artifacts(\n    65→        &self,\n    66→        base_dir: &Path,\n    67→        project_id: &ProjectId,\n    68→    ) -> AppResult<Vec<ArtifactRecord>>;\n    69→}\n    70→\n    71→/// Port for reading runtime logs (separate from durable history).\n    72→pub trait RuntimeLogStorePort {\n    73→    fn read_runtime_logs(\n    74→        &self,\n    75→        base_dir: &Path,\n    76→        project_id: &ProjectId,\n    77→    ) -> AppResult<Vec<RuntimeLogEntry>>;\n    78→}\n    79→\n    80→/// Port for reading/writing the run snapshot.\n    81→pub trait RunSnapshotPort {\n    82→    fn read_run_snapshot(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<RunSnapshot>;\n    83→}\n    84→\n    85→/// Port for writing the run snapshot atomically.\n    86→pub trait RunSnapshotWritePort {\n    87→    fn write_run_snapshot(\n    88→        &self,\n    89→        base_dir: &Path,\n    90→        project_id: &ProjectId,\n    91→        snapshot: &RunSnapshot,\n    92→    ) -> AppResult<()>;\n    93→}\n    94→\n    95→/// Port for durable rollback point persistence.\n    96→pub trait RollbackPointStorePort {\n    97→    fn write_rollback_point(\n    98→        &self,\n    99→        base_dir: &Path,\n   100→        project_id: &ProjectId,\n   101→        rollback_point: &RollbackPoint,\n   102→    ) -> AppResult<()>;\n   103→\n   104→    fn list_rollback_points(\n   105→        &self,\n   106→        base_dir: &Path,\n   107→        project_id: &ProjectId,\n   108→    ) -> AppResult<Vec<RollbackPoint>>;\n   109→\n   110→    fn read_rollback_point_by_stage(\n   111→        &self,\n   112→        base_dir: &Path,\n   113→        project_id: &ProjectId,\n   114→        stage_id: StageId,\n   115→    ) -> AppResult<Option<RollbackPoint>>;\n   116→}\n   117→\n   118→/// Port for repository reset operations during hard rollback.\n   119→pub trait RepositoryResetPort {\n   120→    fn reset_to_sha(&self, repo_root: &Path, sha: &str) -> AppResult<()>;\n   121→}\n   122→\n   123→/// Port for writing payload and artifact records atomically as a pair.\n   124→pub trait PayloadArtifactWritePort {\n   125→    fn write_payload_artifact_pair(\n   126→        &self,\n   127→        base_dir: &Path,\n   128→        project_id: &ProjectId,\n   129→        payload: &PayloadRecord,\n   130→        artifact: &ArtifactRecord,\n   131→    ) -> AppResult<()>;\n   132→\n   133→    /// Remove a previously written payload/artifact pair.\n   134→    /// Used to roll back a stage commit when journal or snapshot persistence\n   135→    /// fails after the pair was already written.\n   136→    fn remove_payload_artifact_pair(\n   137→        &self,\n   138→        base_dir: &Path,\n   139→        project_id: &ProjectId,\n   140→        payload_id: &str,\n   141→        artifact_id: &str,\n   142→    ) -> AppResult<()>;\n   143→}\n   144→\n   145→/// Port for appending runtime log entries (best-effort, not durable history).\n   146→pub trait RuntimeLogWritePort {\n   147→    fn append_runtime_log(\n   148→        &self,\n   149→        base_dir: &Path,\n   150→        project_id: &ProjectId,\n   151→        entry: &RuntimeLogEntry,\n   152→    ) -> AppResult<()>;\n   153→}\n   154→\n   155→/// Port for durable amendment queue persistence under `projects/<id>/amendments/`.\n   156→pub trait AmendmentQueuePort {\n   157→    /// Write a single amendment file atomically.\n   158→    fn write_amendment(\n   159→        &self,\n   160→        base_dir: &Path,\n   161→        project_id: &ProjectId,\n   162→        amendment: &super::model::QueuedAmendment,\n   163→    ) -> AppResult<()>;\n   164→\n   165→    /// List all pending amendment files from disk.\n   166→    fn list_pending_amendments(\n   167→        &self,\n   168→        base_dir: &Path,\n   169→        project_id: &ProjectId,\n   170→    ) -> AppResult<Vec<super::model::QueuedAmendment>>;\n   171→\n   172→    /// Remove a single amendment file by ID.\n   173→    fn remove_amendment(\n   174→        &self,\n   175→        base_dir: &Path,\n   176→        project_id: &ProjectId,\n   177→        amendment_id: &str,\n   178→    ) -> AppResult<()>;\n   179→\n   180→    /// Remove all pending amendment files. Returns count removed.\n   181→    fn drain_amendments(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<u32>;\n   182→\n   183→    /// Check if any amendment files exist on disk.\n   184→    fn has_pending_amendments(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<bool>;\n   185→}\n   186→\n   187→/// Port for reading/writing/clearing the active project pointer.\n   188→pub trait ActiveProjectPort {\n   189→    fn read_active_project_id(&self, base_dir: &Path) -> AppResult<Option<String>>;\n   190→    fn clear_active_project(&self, base_dir: &Path) -> AppResult<()>;\n   191→    fn write_active_project(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<()>;\n   192→}\n   193→\n   194→/// Input for the `project create` use case.\n   195→pub struct CreateProjectInput {\n   196→    pub id: ProjectId,\n   197→    pub name: String,\n   198→    pub flow: FlowPreset,\n   199→    pub prompt_path: String,\n   200→    pub prompt_contents: String,\n   201→    pub prompt_hash: String,\n   202→    pub created_at: DateTime<Utc>,\n   203→}\n   204→\n   205→/// Create a new project with all canonical files.\n   206→pub fn create_project(\n   207→    store: &dyn ProjectStorePort,\n   208→    journal_store: &dyn JournalStorePort,\n   209→    base_dir: &Path,\n   210→    input: CreateProjectInput,\n   211→) -> AppResult<ProjectRecord> {\n   212→    // Check for duplicate project ID\n   213→    if store.project_exists(base_dir, &input.id)? {\n   214→        return Err(AppError::DuplicateProject {\n   215→            project_id: input.id.to_string(),\n   216→        });\n   217→    }\n   218→\n   219→    let record = ProjectRecord {\n   220→        id: input.id.clone(),\n   221→        name: input.name,\n   222→        flow: input.flow,\n   223→        prompt_reference: \"prompt.md\".to_owned(),\n   224→        prompt_hash: input.prompt_hash,\n   225→        created_at: input.created_at,\n   226→        status_summary: ProjectStatusSummary::Created,\n   227→    };\n   228→\n   229→    let run_snapshot = RunSnapshot::initial();\n   230→    let sessions = SessionStore::empty();\n   231→\n   232→    // Create the initial journal event\n   233→    let initial_event = JournalEvent {\n   234→        sequence: 1,\n   235→        timestamp: input.created_at,\n   236→        event_type: JournalEventType::ProjectCreated,\n   237→        details: serde_json::json!({\n   238→            \"project_id\": record.id.as_str(),\n   239→            \"flow\": record.flow.as_str(),\n   240→        }),\n   241→    };\n   242→    let journal_line = journal::serialize_event(&initial_event)?;\n   243→\n   244→    // Atomic creation: all files or nothing\n   245→    store.create_project_atomic(\n   246→        base_dir,\n   247→        &record,\n   248→        &input.prompt_contents,\n   249→        &run_snapshot,\n   250→        &journal_line,\n   251→        &sessions,\n   252→    )?;\n   253→\n   254→    // create_project_atomic writes the journal as part of the atomic init,\n   255→    // but we don't call journal_store.append_event here because the atomic\n   256→    // creation already wrote the initial journal line. The journal_store\n   257→    // parameter is kept for interface consistency and future use.\n   258→    let _ = journal_store;\n   259→\n   260→    Ok(record)\n   261→}\n   262→\n   263→/// List all projects with summary data.\n   264→pub fn list_projects(\n   265→    store: &dyn ProjectStorePort,\n   266→    active_port: &dyn ActiveProjectPort,\n   267→    base_dir: &Path,\n   268→) -> AppResult<Vec<ProjectListEntry>> {\n   269→    let active_id = active_port.read_active_project_id(base_dir)?;\n   270→    let project_ids = store.list_project_ids(base_dir)?;\n   271→\n   272→    let mut entries = Vec::new();\n   273→    for pid in project_ids {\n   274→        let record = store.read_project_record(base_dir, &pid)?;\n   275→        let is_active = active_id.as_deref() == Some(pid.as_str());\n   276→        entries.push(ProjectListEntry {\n   277→            id: record.id,\n   278→            name: record.name,\n   279→            flow: record.flow,\n   280→            status_summary: record.status_summary,\n   281→            created_at: record.created_at,\n   282→            is_active,\n   283→        });\n   284→    }\n   285→\n   286→    Ok(entries)\n   287→}\n   288→\n   289→/// Show detailed project information.\n   290→pub fn show_project(\n   291→    store: &dyn ProjectStorePort,\n   292→    run_port: &dyn RunSnapshotPort,\n   293→    journal_port: &dyn JournalStorePort,\n   294→    active_port: &dyn ActiveProjectPort,\n   295→    base_dir: &Path,\n   296→    project_id: &ProjectId,\n   297→) -> AppResult<ProjectDetail> {\n   298→    if !store.project_exists(base_dir, project_id)? {\n   299→        return Err(AppError::ProjectNotFound {\n   300→            project_id: project_id.to_string(),\n   301→        });\n   302→    }\n   303→\n   304→    let record = store.read_project_record(base_dir, project_id)?;\n   305→    let run_snapshot = run_port.read_run_snapshot(base_dir, project_id)?;\n   306→    let events = journal_port.read_journal(base_dir, project_id)?;\n   307→    let journal_event_count = events.len() as u64;\n   308→    let active_id = active_port.read_active_project_id(base_dir)?;\n   309→    let is_active = active_id.as_deref() == Some(project_id.as_str());\n   310→\n   311→    // Count rollback points from journal events\n   312→    let rollback_count = events\n   313→        .iter()\n   314→        .filter(|e| e.event_type == JournalEventType::RollbackCreated)\n   315→        .count();\n   316→\n   317→    Ok(ProjectDetail {\n   318→        record,\n   319→        run_snapshot,\n   320→        journal_event_count,\n   321→        rollback_count,\n   322→        is_active,\n   323→    })\n   324→}\n   325→\n   326→/// Delete a project. Fails if project has an active run.\n   327→/// Clears active-project pointer if it pointed to the deleted project.\n   328→///\n   329→/// Transactional: if any post-validation step fails, the project remains\n   330→/// addressable at its canonical path and the active-project pointer is\n   331→/// unchanged.\n   332→pub fn delete_project(\n   333→    store: &dyn ProjectStorePort,\n   334→    run_port: &dyn RunSnapshotPort,\n   335→    active_port: &dyn ActiveProjectPort,\n   336→    base_dir: &Path,\n   337→    project_id: &ProjectId,\n   338→) -> AppResult<()> {\n   339→    if !store.project_exists(base_dir, project_id)? {\n   340→        return Err(AppError::ProjectNotFound {\n   341→            project_id: project_id.to_string(),\n   342→        });\n   343→    }\n   344→\n   345→    // Check for active run\n   346→    let run_snapshot = run_port.read_run_snapshot(base_dir, project_id)?;\n   347→    if run_snapshot.has_active_run() {\n   348→        return Err(AppError::ActiveRunDelete {\n   349→            project_id: project_id.to_string(),\n   350→        });\n   351→    }\n   352→\n   353→    // Check if this is the active project (before delete)\n   354→    let active_id = active_port.read_active_project_id(base_dir)?;\n   355→    let was_active = active_id.as_deref() == Some(project_id.as_str());\n   356→\n   357→    // Phase 1: Stage the delete — project becomes invisible to list/show\n   358→    // but data remains on disk for rollback.\n   359→    store.stage_delete(base_dir, project_id)?;\n   360→\n   361→    // Phase 2: Clear the active-project pointer if needed.\n   362→    // If this fails, roll back the staged delete so the project remains\n   363→    // addressable and the pointer is unchanged.\n   364→    if was_active {\n   365→        if let Err(clear_err) = active_port.clear_active_project(base_dir) {\n   366→            store\n   367→                .rollback_delete(base_dir, project_id)\n   368→                .map_err(|restore_err| AppError::CorruptRecord {\n   369→                    file: format!(\"projects/{}\", project_id),\n   370→                    details: format!(\n   371→                        \"delete partially failed: pointer clear error: {}, restore error: {}\",\n   372→                        clear_err, restore_err\n   373→                    ),\n   374→                })?;\n   375→            return Err(clear_err);\n   376→        }\n   377→    }\n   378→\n   379→    // Phase 3: Finalize — permanently remove the project data.\n   380→    // At this point the logical delete has succeeded (project is invisible,\n   381→    // pointer is cleared). Best-effort cleanup of the staged data.\n   382→    let _ = store.commit_delete(base_dir, project_id);\n   383→\n   384→    Ok(())\n   385→}\n   386→\n   387→/// Get run status for the active project.\n   388→pub fn run_status(\n   389→    run_port: &dyn RunSnapshotPort,\n   390→    base_dir: &Path,\n   391→    project_id: &ProjectId,\n   392→) -> AppResult<RunStatusView> {\n   393→    let snapshot = run_port.read_run_snapshot(base_dir, project_id)?;\n   394→    Ok(queries::build_status_view(project_id.as_str(), &snapshot))\n   395→}\n   396→\n   397→/// Get run history (durable only, no runtime logs).\n   398→pub fn run_history(\n   399→    journal_port: &dyn JournalStorePort,\n   400→    artifact_port: &dyn ArtifactStorePort,\n   401→    base_dir: &Path,\n   402→    project_id: &ProjectId,\n   403→) -> AppResult<RunHistoryView> {\n   404→    let events =\n   405→        queries::visible_journal_events(&journal_port.read_journal(base_dir, project_id)?)?;\n   406→    let (payloads, artifacts) = queries::filter_history_records(\n   407→        &events,\n   408→        artifact_port.list_payloads(base_dir, project_id)?,\n   409→        artifact_port.list_artifacts(base_dir, project_id)?,\n   410→    )?;\n   411→\n   412→    queries::validate_history_consistency(&payloads, &artifacts)?;\n   413→\n   414→    Ok(queries::build_history_view(\n   415→        project_id.as_str(),\n   416→        events,\n   417→        payloads,\n   418→        artifacts,\n   419→    ))\n   420→}\n   421→\n   422→/// Get run tail: durable history by default, with optional runtime logs.\n   423→pub fn run_tail(\n   424→    journal_port: &dyn JournalStorePort,\n   425→    artifact_port: &dyn ArtifactStorePort,\n   426→    log_port: &dyn RuntimeLogStorePort,\n   427→    base_dir: &Path,\n   428→    project_id: &ProjectId,\n   429→    include_logs: bool,\n   430→) -> AppResult<RunTailView> {\n   431→    let events =\n   432→        queries::visible_journal_events(&journal_port.read_journal(base_dir, project_id)?)?;\n   433→    let (payloads, artifacts) = queries::filter_history_records(\n   434→        &events,\n   435→        artifact_port.list_payloads(base_dir, project_id)?,\n   436→        artifact_port.list_artifacts(base_dir, project_id)?,\n   437→    )?;\n   438→\n   439→    queries::validate_history_consistency(&payloads, &artifacts)?;\n   440→\n   441→    let runtime_logs = if include_logs {\n   442→        log_port.read_runtime_logs(base_dir, project_id)?\n   443→    } else {\n   444→        Vec::new()\n   445→    };\n   446→\n   447→    Ok(queries::build_tail_view(\n   448→        project_id.as_str(),\n   449→        events,\n   450→        payloads,\n   451→        artifacts,\n   452→        include_logs,\n   453→        runtime_logs,\n   454→    ))\n   455→}\n   456→\n   457→/// List visible rollback points for the current logical history branch.\n   458→pub fn list_rollback_points(\n   459→    rollback_store: &dyn RollbackPointStorePort,\n   460→    journal_port: &dyn JournalStorePort,\n   461→    base_dir: &Path,\n   462→    project_id: &ProjectId,\n   463→) -> AppResult<Vec<RollbackPoint>> {\n   464→    let events =\n   465→        queries::visible_journal_events(&journal_port.read_journal(base_dir, project_id)?)?;\n   466→    let visible_ids = visible_rollback_ids(&events);\n   467→    let mut points = rollback_store\n   468→        .list_rollback_points(base_dir, project_id)?\n   469→        .into_iter()\n   470→        .filter(|point| visible_ids.contains(point.rollback_id.as_str()))\n   471→        .collect::<Vec<_>>();\n   472→    points.sort_by_key(|point| point.created_at);\n   473→    Ok(points)\n   474→}\n   475→\n   476→/// Look up the latest visible rollback point for a stage.\n   477→pub fn get_rollback_point_for_stage(\n   478→    rollback_store: &dyn RollbackPointStorePort,\n   479→    journal_port: &dyn JournalStorePort,\n   480→    base_dir: &Path,\n   481→    project_id: &ProjectId,\n   482→    stage_id: StageId,\n   483→) -> AppResult<Option<RollbackPoint>> {\n   484→    let visible_events =\n   485→        queries::visible_journal_events(&journal_port.read_journal(base_dir, project_id)?)?;\n   486→    let visible_ids = visible_rollback_ids(&visible_events);\n   487→\n   488→    Ok(rollback_store\n   489→        .list_rollback_points(base_dir, project_id)?\n   490→        .into_iter()\n   491→        .filter(|point| point.stage_id == stage_id)\n   492→        .filter(|point| visible_ids.contains(point.rollback_id.as_str()))\n   493→        .max_by_key(|point| point.created_at))\n   494→}\n   495→\n   496→/// Perform a logical or hard rollback to a visible checkpoint.\n   497→#[allow(clippy::too_many_arguments)]\n   498→pub fn perform_rollback(\n   499→    run_port: &dyn RunSnapshotPort,\n   500→    run_write_port: &dyn RunSnapshotWritePort,\n   501→    journal_port: &dyn JournalStorePort,\n   502→    rollback_store: &dyn RollbackPointStorePort,\n   503→    reset_port: Option<&dyn RepositoryResetPort>,\n   504→    base_dir: &Path,\n   505→    project_id: &ProjectId,\n   506→    flow: FlowPreset,\n   507→    target_stage: StageId,\n   508→    hard: bool,\n   509→) -> AppResult<RollbackPoint> {\n   510→    let current_snapshot = run_port.read_run_snapshot(base_dir, project_id)?;\n   511→    match current_snapshot.status {\n   512→        RunStatus::Failed | RunStatus::Paused => {}\n   513→        status => {\n   514→            return Err(AppError::RollbackInvalidStatus {\n   515→                project_id: project_id.to_string(),\n   516→                status: status.to_string(),\n   517→            });\n   518→        }\n   519→    }\n   520→\n   521→    if !flow_stage_membership(flow, target_stage) {\n   522→        return Err(AppError::RollbackStageNotInFlow {\n   523→            project_id: project_id.to_string(),\n   524→            stage_id: target_stage.to_string(),\n   525→            flow: flow.to_string(),\n   526→        });\n   527→    }\n   528→\n   529→    let rollback_point = get_rollback_point_for_stage(\n   530→        rollback_store,\n   531→        journal_port,\n   532→        base_dir,\n   533→        project_id,\n   534→        target_stage,\n   535→    )?\n   536→    .ok_or_else(|| AppError::RollbackPointNotFound {\n   537→        project_id: project_id.to_string(),\n   538→        stage_id: target_stage.to_string(),\n   539→    })?;\n   540→\n   541→    let events = journal_port.read_journal(base_dir, project_id)?;\n   542→    let visible_through_sequence =\n   543→        rollback_created_sequence_for(&events, rollback_point.rollback_id.as_str())?;\n   544→\n   545→    let mut restored_snapshot = rollback_point.run_snapshot.clone();\n   546→    restored_snapshot.status = RunStatus::Paused;\n   547→    restored_snapshot.active_run = None;\n   548→    restored_snapshot.rollback_point_meta.rollback_count =\n   549→        current_snapshot.rollback_point_meta.rollback_count + 1;\n   550→    restored_snapshot.rollback_point_meta.last_rollback_id =\n   551→        Some(rollback_point.rollback_id.clone());\n   552→    restored_snapshot.status_summary = format!(\n   553→        \"paused after rollback to {} (cycle {}); run `ralph-burning run resume` to continue\",\n   554→        rollback_point.stage_id.display_name(),\n   555→        rollback_point.cycle\n   556→    );\n   557→\n   558→    let sequence = journal::last_sequence(&events) + 1;\n   559→    let rollback_event = journal::rollback_performed_event(\n   560→        sequence,\n   561→        Utc::now(),\n   562→        rollback_point.rollback_id.as_str(),\n   563→        rollback_point.stage_id,\n   564→        rollback_point.cycle,\n   565→        visible_through_sequence,\n   566→        hard,\n   567→        rollback_point.git_sha.as_deref(),\n   568→        restored_snapshot.rollback_point_meta.rollback_count,\n   569→    );\n   570→    let rollback_line = journal::serialize_event(&rollback_event)?;\n   571→    run_write_port.write_run_snapshot(base_dir, project_id, &restored_snapshot)?;\n   572→    if let Err(append_error) = journal_port.append_event(base_dir, project_id, &rollback_line) {\n   573→        if let Err(restore_error) =\n   574→            run_write_port.write_run_snapshot(base_dir, project_id, &current_snapshot)\n   575→        {\n   576→            return Err(AppError::CorruptRecord {\n   577→                file: format!(\"projects/{}/run.json\", project_id.as_str()),\n   578→                details: format!(\n   579→                    \"rollback journal append failed after snapshot write: {append_error}; failed to restore the previous snapshot: {restore_error}\"\n   580→                ),\n   581→            });\n   582→        }\n   583→        return Err(append_error);\n   584→    }\n   585→\n   586→    if hard {\n   587→        let git_sha =\n   588→            rollback_point\n   589→                .git_sha\n   590→                .as_deref()\n   591→                .ok_or_else(|| AppError::RollbackGitResetFailed {\n   592→                    project_id: project_id.to_string(),\n   593→                    rollback_id: rollback_point.rollback_id.clone(),\n   594→                    details: \"rollback point does not record a git commit SHA\".to_owned(),\n   595→                })?;\n   596→\n   597→        let reset_port = reset_port.ok_or_else(|| AppError::RollbackGitResetFailed {\n   598→            project_id: project_id.to_string(),\n   599→            rollback_id: rollback_point.rollback_id.clone(),\n   600→            details: \"no repository reset adapter was provided\".to_owned(),\n   601→        })?;\n   602→\n   603→        if let Err(error) = reset_port.reset_to_sha(base_dir, git_sha) {\n   604→            return Err(AppError::RollbackGitResetFailed {\n   605→                project_id: project_id.to_string(),\n   606→                rollback_id: rollback_point.rollback_id.clone(),\n   607→                details: error.to_string(),\n   608→            });\n   609→        }\n   610→    }\n   611→\n   612→    Ok(rollback_point)\n   613→}\n   614→\n   615→fn flow_stage_membership(flow: FlowPreset, stage_id: StageId) -> bool {\n   616→    workflow_composition::flow_definition(flow)\n   617→        .stages\n   618→        .contains(&stage_id)\n   619→}\n   620→\n   621→fn visible_rollback_ids(events: &[JournalEvent]) -> std::collections::HashSet<&str> {\n   622→    events\n   623→        .iter()\n   624→        .filter(|event| event.event_type == JournalEventType::RollbackCreated)\n   625→        .filter_map(|event| {\n   626→            event\n   627→                .details\n   628→                .get(\"rollback_id\")\n   629→                .and_then(|value| value.as_str())\n   630→        })\n   631→        .collect()\n   632→}\n   633→\n   634→fn rollback_created_sequence_for(events: &[JournalEvent], rollback_id: &str) -> AppResult<u64> {\n   635→    events\n   636→        .iter()\n   637→        .find(|event| {\n   638→            event.event_type == JournalEventType::RollbackCreated\n   639→                && event\n   640→                    .details\n   641→                    .get(\"rollback_id\")\n   642→                    .and_then(|value| value.as_str())\n   643→                    == Some(rollback_id)\n   644→        })\n   645→        .map(|event| event.sequence)\n   646→        .ok_or_else(|| AppError::CorruptRecord {\n   647→            file: \"journal.ndjson\".to_owned(),\n   648→            details: format!(\n   649→                \"missing rollback_created event for rollback point '{}'\",\n   650→                rollback_id\n   651→            ),\n   652→        })\n   653→}\n   654→"}]},"parent_tool_use_id":"toolu_01WxWEKeVM8eN1eTgMgZkDxS","session_id":"3d9a0615-7442-4a66-ab27-f8160d110223","uuid":"39352a99-6b5f-4393-a52c-32ec18380bfb"}
