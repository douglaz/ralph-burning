 297→        agent_service.resolver(),\n   298→        Some(&workspace_defaults),\n   299→    )?;\n   300→    preflight_check(agent_service.adapter(), &stage_plan).await?;\n   301→\n   302→    let run_id = generate_run_id()?;\n   303→    let now = Utc::now();\n   304→    let events = journal_store.read_journal(base_dir, project_id)?;\n   305→    let mut seq = journal::last_sequence(&events);\n   306→    let first_stage = stage_plan[0].stage_id;\n   307→    let initial_cursor = StageCursor::initial(first_stage);\n   308→    let mut current_snapshot = RunSnapshot {\n   309→        active_run: Some(ActiveRun {\n   310→            run_id: run_id.as_str().to_owned(),\n   311→            stage_cursor: initial_cursor.clone(),\n   312→            started_at: now,\n   313→        }),\n   314→        status: RunStatus::Running,\n   315→        cycle_history: snapshot.cycle_history.clone(),\n   316→        completion_rounds: 1,\n   317→        rollback_point_meta: snapshot.rollback_point_meta.clone(),\n   318→        amendment_queue: snapshot.amendment_queue.clone(),\n   319→        status_summary: format!(\"running: {}\", first_stage.display_name()),\n   320→    };\n   321→    run_snapshot_write.write_run_snapshot(base_dir, project_id, &current_snapshot)?;\n   322→\n   323→    seq += 1;\n   324→    let run_started = journal::run_started_event(seq, now, &run_id, first_stage);\n   325→    let run_started_line = journal::serialize_event(&run_started)?;\n   326→    if let Err(error) = journal_store.append_event(base_dir, project_id, &run_started_line) {\n   327→        seq -= 1;\n   328→        return fail_run(\n   329→            &AppError::RunStartFailed {\n   330→                reason: format!(\"failed to persist run_started event: {}\", error),\n   331→            },\n   332→            first_stage,\n   333→            &run_id,\n   334→            &mut seq,\n   335→            &mut current_snapshot,\n   336→            journal_store,\n   337→            run_snapshot_write,\n   338→            base_dir,\n   339→            project_id,\n   340→            ExecutionOrigin::Start,\n   341→        )\n   342→        .await;\n   343→    }\n   344→\n   345→    execute_run_internal(\n   346→        agent_service,\n   347→        run_snapshot_write,\n   348→        journal_store,\n   349→        artifact_write,\n   350→        log_write,\n   351→        amendment_queue_port,\n   352→        rollback_store,\n   353→        base_dir,\n   354→        project_id,\n   355→        &run_id,\n   356→        &mut seq,\n   357→        &mut current_snapshot,\n   358→        semantics,\n   359→        &stage_plan,\n   360→        0,\n   361→        initial_cursor,\n   362→        retry_policy,\n   363→        cancellation_token,\n   364→        ExecutionOrigin::Start,\n   365→        None,\n   366→        effective_config,\n   367→    )\n   368→    .await?;\n   369→\n   370→    Ok(())\n   371→}\n   372→\n   373→#[allow(clippy::too_many_arguments)]\n   374→pub async fn execute_standard_run<A, R, S>(\n   375→    agent_service: &AgentExecutionService<A, R, S>,\n   376→    run_snapshot_read: &dyn RunSnapshotPort,\n   377→    run_snapshot_write: &dyn RunSnapshotWritePort,\n   378→    journal_store: &dyn JournalStorePort,\n   379→    artifact_write: &dyn PayloadArtifactWritePort,\n   380→    log_write: &dyn RuntimeLogWritePort,\n   381→    amendment_queue_port: &dyn AmendmentQueuePort,\n   382→    base_dir: &Path,\n   383→    project_id: &ProjectId,\n   384→    effective_config: &EffectiveConfig,\n   385→) -> AppResult<()>\n   386→where\n   387→    A: AgentExecutionPort,\n   388→    R: RawOutputPort,\n   389→    S: SessionStorePort,\n   390→{\n   391→    execute_run(\n   392→        agent_service,\n   393→        run_snapshot_read,\n   394→        run_snapshot_write,\n   395→        journal_store,\n   396→        artifact_write,\n   397→        log_write,\n   398→        amendment_queue_port,\n   399→        base_dir,\n   400→        project_id,\n   401→        F