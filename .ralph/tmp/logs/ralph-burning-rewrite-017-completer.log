lude_logs,\n   359→    )?;\n   360→\n   361→    println!(\"Project: {}\", tail.project_id);\n   362→    println!(\"--- Durable History ---\");\n   363→    for event in &tail.events {\n   364→        println!(\n   365→            \"  [{}] {} - {:?}\",\n   366→            event.sequence, event.timestamp, event.event_type\n   367→        );\n   368→    }\n   369→\n   370→    if !tail.payloads.is_empty() {\n   371→        println!(\"--- Payloads ---\");\n   372→        for payload in &tail.payloads {\n   373→            println!(\n   374→                \"  {} ({}, cycle {}, attempt {})\",\n   375→                payload.payload_id, payload.stage_id, payload.cycle, payload.attempt\n   376→            );\n   377→        }\n   378→    }\n   379→\n   380→    if !tail.artifacts.is_empty() {\n   381→        println!(\"--- Artifacts ---\");\n   382→        for artifact in &tail.artifacts {\n   383→            println!(\n   384→                \"  {} (payload: {}, stage: {})\",\n   385→                artifact.artifact_id, artifact.payload_id, artifact.stage_id\n   386→            );\n   387→        }\n   388→    }\n   389→\n   390→    if let Some(ref logs) = tail.runtime_logs {\n   391→        println!(\"--- Runtime Logs ---\");\n   392→        if logs.is_empty() {\n   393→            println!(\"  (no runtime logs)\");\n   394→        } else {\n   395→            for log in logs {\n   396→                println!(\n   397→                    \"  [{}] {:?} [{}] {}\",\n   398→                    log.timestamp, log.level, log.source, log.message\n   399→                );\n   400→            }\n   401→        }\n   402→    }\n   403→\n   404→    Ok(())\n   405→}\n   406→\n   407→async fn handle_rollback(target: String, hard: bool) -> AppResult<()> {\n   408→    let current_dir = std::env::current_dir()?;\n   409→\n   410→    let config = workspace_governance::load_workspace_config(&current_dir)?;\n   411→    workspace_governance::ensure_supported_workspace_version(&config)?;\n  