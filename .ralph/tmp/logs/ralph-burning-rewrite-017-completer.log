{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01KLH4R3htSweHCi9w7NM1UH","type":"tool_result","content":"     1→use clap::{Args, Subcommand};\n     2→\n     3→use crate::adapters::fs::{\n     4→    FsAmendmentQueueStore, FsArtifactStore, FsJournalStore, FsPayloadArtifactWriteStore,\n     5→    FsProjectStore, FsRawOutputStore, FsRollbackPointStore, FsRunSnapshotStore,\n     6→    FsRunSnapshotWriteStore, FsRuntimeLogStore, FsRuntimeLogWriteStore, FsSessionStore,\n     7→};\n     8→use crate::adapters::stub_backend::StubBackendAdapter;\n     9→use crate::adapters::worktree::WorktreeAdapter;\n    10→use crate::contexts::agent_execution::service::AgentExecutionService;\n    11→use crate::contexts::project_run_record::model::RunStatus;\n    12→use crate::contexts::project_run_record::service::{self, ProjectStorePort, RunSnapshotPort};\n    13→use crate::contexts::workflow_composition::engine;\n    14→use crate::contexts::workspace_governance;\n    15→use crate::contexts::workspace_governance::config::EffectiveConfig;\n    16→use crate::shared::domain::StageId;\n    17→use crate::shared::error::{AppError, AppResult};\n    18→\n    19→#[derive(Debug, Args)]\n    20→pub struct RunCommand {\n    21→    #[command(subcommand)]\n    22→    pub command: RunSubcommand,\n    23→}\n    24→\n    25→#[derive(Debug, Subcommand)]\n    26→pub enum RunSubcommand {\n    27→    Start,\n    28→    Resume,\n    29→    Status,\n    30→    History,\n    31→    Tail {\n    32→        #[arg(long)]\n    33→        logs: bool,\n    34→    },\n    35→    Rollback {\n    36→        #[arg(long)]\n    37→        to: String,\n    38→        #[arg(long)]\n    39→        hard: bool,\n    40→    },\n    41→}\n    42→\n    43→pub async fn handle(command: RunCommand) -> AppResult<()> {\n    44→    match command.command {\n    45→        RunSubcommand::Status => handle_status().await,\n    46→        RunSubcommand::History => handle_history().await,\n    47→        RunSubcommand::Tail { logs } => handle_tail(logs).await,\n    48→        RunSubcommand::Start => handle_start().await,\n    49→        RunSubcommand::Resume => handle_resume().await,\n    50→        RunSubcommand::Rollback { to, hard } => handle_rollback(to, hard).await,\n    51→    }\n    52→}\n    53→\n    54→pub fn build_agent_execution_service(\n    55→) -> AgentExecutionService<StubBackendAdapter, FsRawOutputStore, FsSessionStore> {\n    56→    let mut adapter = StubBackendAdapter::default();\n    57→\n    58→    // Test-only injection seam: environment variables configure the stub backend\n    59→    // to simulate failure modes that aren't reachable through normal CLI usage.\n    60→    if std::env::var(\"RALPH_BURNING_TEST_BACKEND_UNAVAILABLE\").is_ok() {\n    61→        adapter = adapter.unavailable();\n    62→    }\n    63→    if let Ok(stage_str) = std::env::var(\"RALPH_BURNING_TEST_FAIL_INVOKE_STAGE\") {\n    64→        if let Ok(stage_id) = stage_str.parse::<StageId>() {\n    65→            adapter = adapter.with_invoke_failure(stage_id);\n    66→        }\n    67→    }\n    68→    // Test-only seam: configure a stage to fail the first N invocations, then succeed.\n    69→    // Format: \"stage_id:count\" e.g. \"implementation:1\"\n    70→    if let Ok(spec) = std::env::var(\"RALPH_BURNING_TEST_TRANSIENT_FAILURE\") {\n    71→        if let Some((stage_str, count_str)) = spec.split_once(':') {\n    72→            if let (Ok(stage_id), Ok(count)) = (stage_str.parse::<StageId>(), count_str.parse::<u32>()) {\n    73→                adapter = adapter.with_transient_failure(stage_id, count);\n    74→            }\n    75→        }\n    76→    }\n    77→    // Test-only seam: JSON map from stage-id string to payload JSON.\n    78→    // Values may be a single object or an array of objects (payload sequence).\n    79→    // Example: {\"completion_panel\": {\"outcome\":\"conditionally_approved\",...}}\n    80→    // Example sequence: {\"qa\": [{\"outcome\":\"request_changes\",.