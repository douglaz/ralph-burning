{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Dud987MYqsKguuVsEQKvWT","type":"tool_result","content":"     1→use std::env;\n     2→use std::fs::{self, OpenOptions};\n     3→use std::io::Write;\n     4→use std::path::{Path, PathBuf};\n     5→use std::process::Command;\n     6→use std::time::{SystemTime, UNIX_EPOCH};\n     7→\n     8→use crate::contexts::agent_execution::model::RawOutputReference;\n     9→use crate::contexts::agent_execution::service::RawOutputPort;\n    10→use crate::contexts::agent_execution::session::{PersistedSessions, SessionStorePort};\n    11→use crate::contexts::automation_runtime::model::{DaemonJournalEvent, DaemonTask, WorktreeLease};\n    12→use crate::contexts::automation_runtime::DaemonStorePort;\n    13→use crate::contexts::project_run_record::journal;\n    14→use crate::contexts::project_run_record::model::{\n    15→    ArtifactRecord, JournalEvent, PayloadRecord, ProjectRecord, RollbackPoint, RunSnapshot,\n    16→    RuntimeLogEntry, SessionStore,\n    17→};\n    18→use crate::contexts::project_run_record::service::{\n    19→    ActiveProjectPort, ArtifactStorePort, JournalStorePort, PayloadArtifactWritePort,\n    20→    ProjectStorePort, RollbackPointStorePort, RunSnapshotPort, RunSnapshotWritePort,\n    21→    RuntimeLogStorePort, RuntimeLogWritePort,\n    22→};\n    23→use crate::shared::domain::{ProjectId, StageId, WorkspaceConfig};\n    24→use crate::shared::error::{AppError, AppResult};\n    25→\n    26→const ACTIVE_PROJECT_FILE: &str = \"active-project\";\n    27→const WORKSPACE_DIR: &str = \".ralph-burning\";\n    28→const PROJECTS_DIR: &str = \"projects\";\n    29→const PROJECT_CONFIG_FILE: &str = \"project.toml\";\n    30→const RUN_FILE: &str = \"run.json\";\n    31→const JOURNAL_FILE: &str = \"journal.ndjson\";\n    32→const SESSIONS_FILE: &str = \"sessions.json\";\n    33→const PROMPT_FILE: &str = \"prompt.md\";\n    34→\n    35→/// Required subdirectories inside a project.\n    36→const PROJECT_SUBDIRS: &[&str] = &[\n    37→    \"history/payloads\",\n    38→    \"history/artifacts\",\n    39→    \"runtime/logs\",\n    40→    \"runtime/backend\",\n    41→    \"runtime/temp\",\n    42→    \"amendments\",\n    43→    \"rollback\",\n    44→];\n    45→\n    46→pub struct FileSystem;\n    47→\n    48→impl FileSystem {\n    49→    pub fn create_workspace(\n    50→        workspace_root: &Path,\n    51→        workspace_config: &str,\n    52→        required_directories: &[&str],\n    53→    ) -> AppResult<()> {\n    54→        fs::create_dir_all(workspace_root)?;\n    55→\n    56→        for directory in required_directories {\n    57→            fs::create_dir_all(workspace_root.join(directory))?;\n    58→        }\n    59→\n    60→        Self::write_atomic(&workspace_root.join(\"workspace.toml\"), workspace_config)?;\n    61→        Ok(())\n    62→    }\n    63→\n    64→    pub fn read_to_string(path: &Path) -> AppResult<String> {\n    65→        Ok(fs::read_to_string(path)?)\n    66→    }\n    67→\n    68→    pub fn write_atomic(path: &Path, contents: &str) -> AppResult<()> {\n    69→        let parent = path.parent().ok_or_else(|| {\n    70→            AppError::Io(std::io::Error::new(\n    71→                std::io::ErrorKind::InvalidInput,\n    72→                format!(\"path '{}' has no parent directory\", path.display()),\n    73→            ))\n    74→        })?;\n    75→        fs::create_dir_all(parent)?;\n    76→\n    77→        let timestamp = SystemTime::now()\n    78→            .duration_since(UNIX_EPOCH)\n    79→            .map(|duration| duration.as_nanos())\n    80→            .unwrap_or_default();\n    81→        let temp_path = parent.join(format!(\n    82→            \".{}.{}.{}.tmp\",\n    83→            path.file_name()\n    84→                .and_then(|value| value.to_str())\n    85→                .unwrap_or(\"workspace\"),\n    86→            std::process::id(),\n    87→            timestamp\n    88→        ));\n    89→\n    90→        let mut file = OpenOptions::new()\n    91→            .create_new(true)\n    92→            .write(true)\n    93→            .open(&temp_path)?;\n    94→        file.write_all(contents.as_bytes())?;\n    95→        file.sync_all()?;\n    96→        drop(file);\n    97→\n    98→        if let Err(error) = fs::rename(&temp_path, path) {\n    99→            let _ = fs::remove_file(&temp_path);\n   100→            return Err(error.into());"}]},"parent_tool_use_id":"toolu_01KfEVp49FXGUv77ZeSPdiaP","session_id":"3d9a0615-7442-4a66-ab27-f8160d110223","uuid":"2c789baa-11ad-4ec7-9fe9-de53e9bc26a2"}
