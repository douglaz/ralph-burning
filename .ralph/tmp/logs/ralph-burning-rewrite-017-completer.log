{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0195mTasX8Vm8utHjTgt3C4f","type":"tool_result","content":"     1→#![forbid(unsafe_code)]\n     2→\n     3→use ralph_burning::contexts::workflow_composition::contracts::{\n     4→    all_contracts, contract_for_stage, ContractFamily,\n     5→};\n     6→use ralph_burning::contexts::workflow_composition::{built_in_flows, flow_definition};\n     7→use ralph_burning::shared::domain::{FailureClass, FlowPreset, StageId};\n     8→use ralph_burning::shared::error::ContractError;\n     9→use serde_json::json;\n    10→\n    11→// ── Helpers ─────────────────────────────────────────────────────────────────\n    12→\n    13→fn valid_planning_json() -> serde_json::Value {\n    14→    json!({\n    15→        \"problem_framing\": \"Implement stage contracts for the orchestrator.\",\n    16→        \"assumptions_or_open_questions\": [\"Schema coverage is exhaustive.\"],\n    17→        \"proposed_work\": [\n    18→            {\n    19→                \"order\": 1,\n    20→                \"summary\": \"Define payload types\",\n    21→                \"details\": \"Create typed structs for each contract family.\"\n    22→            }\n    23→        ],\n    24→        \"readiness\": {\n    25→            \"ready\": true,\n    26→            \"risks\": []\n    27→        }\n    28→    })\n    29→}\n    30→\n    31→fn valid_execution_json() -> serde_json::Value {\n    32→    json!({\n    33→        \"change_summary\": \"Added stage contract registry.\",\n    34→        \"steps\": [\n    35→            {\n    36→                \"order\": 1,\n    37→                \"description\": \"Created payloads module\",\n    38→                \"status\": \"completed\"\n    39→            }\n    40→        ],\n    41→        \"validation_evidence\": [\"cargo test passes\"],\n    42→        \"outstanding_risks\": []\n    43→    })\n    44→}\n    45→\n    46→fn valid_validation_approved_json() -> serde_json::Value {\n    47→    json!({\n    48→        \"outcome\": \"approved\",\n    49→        \"evidence\": [\"All tests pass.\"],\n    50→        \"findings_or_gaps\": [],\n    51→        \"follow_up_or_amendments\": []\n    52→    })\n    53→}\n    54→\n    55→fn valid_validation_rejected_json() -> serde_json::Value {\n    56→    json!({\n    57→        \"outcome\": \"rejected\",\n    58→        \"evidence\": [\"Tests fail on CI.\"],\n    59→        \"findings_or_gaps\": [\"Missing edge-case coverage.\"],\n    60→        \"follow_up_or_amendments\": [\"Add tests for empty inputs.\"]\n    61→    })\n    62→}\n    63→\n    64→// ── Registry completeness ───────────────────────────────────────────────────\n    65→\n    66→#[test]\n    67→fn every_stage_id_has_a_contract() {\n    68→    let contracts = all_contracts();\n    69→    assert_eq!(contracts.len(), StageId::ALL.len());\n    70→\n    71→    for &stage_id in &StageId::ALL {\n    72→        let contract = contract_for_stage(stage_id);\n    73→        assert_eq!(contract.stage_id, stage_id);\n    74→    }\n    75→}\n    76→\n    77→#[test]\n    78→fn every_stage_in_every_built_in_flow_has_contract_coverage() {\n    79→    for flow in built_in_flows() {\n    80→        for &stage_id in flow.stages {\n    81→            let contract = contract_for_stage(stage_id);\n    82→            assert_eq!(\n    83→                contract.stage_id, stage_id,\n    84→                \"stage {} in flow {} has no matching contract\",\n    85→                stage_id, flow.preset\n    86→            );\n    87→        }\n    88→    }\n    89→}\n    90→\n    91→#[test]\n    92→fn planning_stages_map_to_planning_family() {\n    93→    for stage_id in [\n    94→        StageId::PromptReview,\n    95→        StageId::Planning,\n    96→        StageId::DocsPlan,\n    97→        StageId::CiPlan,\n    98→    ] {\n    99→        assert_eq!(\n   100→            contract_for_stage(stage_id).family,\n   101→            ContractFamily::Planning,\n   102→            \"{stage_id} should be Planning family\"\n   103→        );\n   104→    }\n   105→}\n   106→\n   107→#[test]\n   108→fn execution_stages_map_to_execution_family() {\n   109→    for stage_id in [\n   110→        StageId::Implementation,\n   111→        StageId::PlanAndImplement,\n   112→        StageId::ApplyFixes,\n   113→        StageId::DocsUpdate,\n   114→        StageId::CiUpdate,\n   115→    ] {\n   116→        assert_eq!(\n   117→            contract_for_stage(stage_id).family,\n   118→            ContractFamily::Execution,\n   119→            \"{stage_id} should be Execution family\"\n   120→        );\n   121→    }\n   122→}\n   123→\n   124→#[test]\n   125→fn validation_stages_map_to_validation_family() {\n   126→    for stage_id in [\n   127→        StageId::Qa,\n   128→        StageId::DocsValidation,\n   129→        StageId::CiValidation,\n   130→        StageId::AcceptanceQa,\n   131→        StageId::Review,\n   132→        StageId::FinalReview,\n   133→        StageId::CompletionPanel,\n   134→    ] {\n   135→        assert_eq!(\n   136→            contract_for_stage(stage_id).family,\n   137→            ContractFamily::Validation,\n   138→            \"{stage_id} should be Validation family\"\n   139→        );\n   140→    }\n   141→}\n   142→\n   143→// ── Schema validation ───────────────────────────────────────────────────────\n   144→\n   145→#[test]\n   146→fn schema_failure_short_circuits_semantic_validation() {\n   147→    let contract = contract_for_stage(StageId::Planning);\n   148→    // Missing required fields → schema error, no domain error.\n   149→    let bad_json = json!({\"not_a_real_field\": true});\n   150→    let err = contract.evaluate(&bad_json).unwrap_err();\n   151→    assert!(\n   152→        matches!(err, ContractError::SchemaValidation { .. }),\n   153→        \"expected SchemaValidation, got: {err:?}\"\n   154→    );\n   155→    assert_eq!(err.failure_class(), FailureClass::SchemaValidationFailure);\n   156→}\n   157→\n   158→#[test]\n   159→fn schema_failure_short_circuits_rendering() {\n   160→    // An execution contract with invalid JSON should never reach the renderer.\n   161→    let contract = contract_for_stage(StageId::Implementation);\n   162→    let bad_json = json!(42);\n   163→    let err = contract.evaluate(&bad_json).unwrap_err();\n   164→    assert!(matches!(err, ContractError::SchemaValidation { .. }));\n   165→}\n   166→\n   167→// ── Semantic / domain validation ────────────────────────────────────────────\n   168→\n   169→#[test]\n   170→fn domain_failure_short_circuits_rendering() {\n   171→    let contract = contract_for_stage(StageId::Planning);\n   172→    // Schema-valid but domain-invalid: empty problem_framing.\n   173→    let json = json!({\n   174→        \"problem_framing\": \"   \",\n   175→        \"assumptions_or_open_questions\": [],\n   176→        \"proposed_work\": [],\n   177→        \"readiness\": { \"ready\": false, \"risks\": [] }\n   178→    });\n   179→    let err = contract.evaluate(&json).unwrap_err();\n   180→    assert!(\n   181→        matches!(err, ContractError::DomainValidation { .. }),\n   182→        \"expected DomainValidation, got: {err:?}\"\n   183→    );\n   184→    assert_eq!(err.failure_class(), FailureClass::DomainValidationFailure);\n   185→}\n   186→\n   187→#[test]\n   188→fn planning_rejects_zero_order_work_item() {\n   189→    let contract = contract_for_stage(StageId::Planning);\n   190→    let json = json!({\n   191→        \"problem_framing\": \"Valid framing.\",\n   192→        \"assumptions_or_open_questions\": [],\n   193→        \"proposed_work\": [\n   194→            { \"order\": 0, \"summary\": \"Bad order\", \"details\": \"\" }\n   195→        ],\n   196→        \"readiness\": { \"ready\": true, \"risks\": [] }\n   197→    });\n   198→    let err = contract.evaluate(&json).unwrap_err();\n   199→    assert!(matches!(err, ContractError::DomainValidation { .. }));\n   200→}\n   201→\n   202→#[test]\n   203→fn execution_rejects_empty_change_summary() {\n   204→    let contract = contract_for_stage(StageId::Implementation);\n   205→    let json = json!({\n   206→        \"change_summary\": \"\",\n   207→        \"steps\": [{ \"order\": 1, \"description\": \"step\", \"status\": \"completed\" }],\n   208→        \"validation_evidence\": [],\n   209→        \"outstanding_risks\": []\n   210→    });\n   211→    let err = contract.evaluate(&json).unwrap_err();\n   212→    assert!(matches!(err, ContractError::DomainValidation { .. }));\n   213→}\n   214→\n   215→#[test]\n   216→fn execution_rejects_empty_steps() {\n   217→    let contract = contract_for_stage(StageId::Implementation);\n   218→    let json = json!({\n   219→        \"change_summary\": \"Did things.\",\n   220→        \"steps\": [],\n   221→        \"validation_evidence\": [],\n   222→        \"outstanding_risks\": []\n   223→    });\n   224→    let err = contract.evaluate(&json).unwrap_err();\n   225→    assert!(matches!(err, ContractError::DomainValidation { .. }));\n   226→}\n   227→\n   228→#[test]\n   229→fn validation_rejects_non_passing_without_follow_up() {\n   230→    let contract = contract_for_stage(StageId::Review);\n   231→    let json = json!({\n   232→        \"outcome\": \"request_changes\",\n   233→        \"evidence\": [\"Some evidence.\"],\n   234→        \"findings_or_gaps\": [\"A gap.\"],\n   235→        \"follow_up_or_amendments\": []\n   236→    });\n   237→    let err = contract.evaluate(&json).unwrap_err();\n   238→    assert!(matches!(err, ContractError::DomainValidation { .. }));\n   239→}\n   240→\n   241→// ── Successful evaluation ───────────────────────────────────────────────────\n   242→\n   243→#[test]\n   244→fn planning_contract_evaluates_successfully() {\n   245→    let contract = contract_for_stage(StageId::Planning);\n   246→    let bundle = contract.evaluate(&valid_planning_json()).unwrap();\n   247→    assert!(!bundle.artifact.is_empty());\n   248→    assert!(bundle.artifact.contains(\"# Planning\"));\n   249→}\n   250→\n   251→#[test]\n   252→fn execution_contract_evaluates_successfully() {\n   253→    let contract = contract_for_stage(StageId::Implementation);\n   254→    let bundle = contract.evaluate(&valid_execution_json()).unwrap();\n   255→    assert!(bundle.artifact.contains(\"# Implementation\"));\n   256→}\n   257→\n   258→#[test]\n   259→fn validation_approved_evaluates_with_no_outcome_failure() {\n   260→    let contract = contract_for_stage(StageId::Review);\n   261→    let bundle = contract\n   262→        .evaluate(&valid_validation_approved_json())\n   263→        .unwrap();\n   264→    assert!(bundle.artifact.contains(\"**Approved**\"));\n   265→}\n   266→\n   267→// ── QA/Review outcome failure mapping ───────────────────────────────────────\n   268→\n   269→#[test]\n   270→fn non_passing_review_maps_to_qa_review_outcome_failure() {\n   271→    let contract = contract_for_stage(StageId::Review);\n   272→    let err = contract\n   273→        .evaluate(&valid_validation_rejected_json())\n   274→        .unwrap_err();\n   275→    assert!(\n   276→        matches!(err, ContractError::QaReviewOutcome { .. }),\n   277→        \"expected QaReviewOutcome, got: {err:?}\"\n   278→    );\n   279→    assert_eq!(err.failure_class(), FailureClass::QaReviewOutcomeFailure);\n   280→}\n   281→\n   282→#[test]\n   283→fn conditionally_approved_maps_to_qa_review_outcome_failure() {\n   284→    let contract = contract_for_stage(StageId::Qa);\n   285→    let json = json!({\n   286→        \"outcome\": \"conditionally_approved\",\n   287→        \"evidence\": [\"Mostly good.\"],\n   288→        \"findings_or_gaps\": [\"Minor issue.\"],\n   289→        \"follow_up_or_amendments\": [\"Fix minor issue.\"]\n   290→    });\n   291→    let err = contract.evaluate(&json).unwrap_err();\n   292→    assert!(matches!(err, ContractError::QaReviewOutcome { .. }));\n   293→    assert_eq!(err.failure_class(), FailureClass::QaReviewOutcomeFailure);\n   294→}\n   295→\n   296→#[test]\n   297→fn evaluate_permissive_accepts_non_passing_validation_payloads() {\n   298→    let contract = contract_for_stage(StageId::Review);\n   299→    let bundle = contract\n   300→        .evaluate_permissive(&valid_validation_rejected_json())\n   301→        .expect(\"permissive evaluation\");\n   302→\n   303→    assert!(bundle.artifact.contains(\"Rejected\"));\n   304→}\n   305→\n   306→// ── JSON Schema generation ──────────────────────────────────────────────────\n   307→\n   308→#[test]\n   309→fn json_schema_is_generated_for_each_family() {\n   310→    for &stage_id in &StageId::ALL {\n   311→        let contract = contract_for_stage(stage_id);\n   312→        let schema = contract.json_schema();\n   313→        // Schema must have a root schema object with definitions.\n   314→        assert!(\n   315→            schema.schema.metadata.is_some()\n   316→                || !schema.definitions.is_empty()\n   317→                || schema.schema.object.is_some()\n   318→                || schema.schema.subschemas.is_some(),\n   319→            \"schema for {stage_id} should have content\"\n   320→        );\n   321→    }\n   322→}\n   323→\n   324→// ── Conformance scenario IDs ────────────────────────────────────────────────\n   325→// These tests verify the scenario IDs referenced in\n   326→// tests/conformance/features/stage_contracts.feature\n   327→\n   328→#[test]\n   329→fn sc_eval_001_successful_planning_contract_evaluation() {\n   330→    let contract = contract_for_stage(StageId::Planning);\n   331→    let bundle = contract.evaluate(&valid_planning_json()).unwrap();\n   332→    assert!(!bundle.artifact.is_empty());\n   333→}\n   334→\n   335→#[test]\n   336→fn sc_eval_002_successful_execution_contract_evaluation() {\n   337→    let contract = contract_for_stage(StageId::Implementation);\n   338→    let bundle = contract.evaluate(&valid_execution_json()).unwrap();\n   339→    assert!(!bundle.artifact.is_empty());\n   340→}\n   341→\n   342→#[test]\n   343→fn sc_eval_003_successful_validation_contract_evaluation() {\n   344→    let contract = contract_for_stage(StageId::Review);\n   345→    let bundle = contract\n   346→        .evaluate(&valid_validation_approved_json())\n   347→        .unwrap();\n   348→    assert!(!bundle.artifact.is_empty());\n   349→}\n   350→\n   351→#[test]\n   352→fn sc_eval_004_schema_failure_prevents_semantic_validation() {\n   353→    let contract = contract_for_stage(StageId::Planning);\n   354→    let err = contract.evaluate(&json!({})).unwrap_err();\n   355→    assert!(matches!(err, ContractError::SchemaValidation { .. }));\n   356→}\n   357→\n   358→#[test]\n   359→fn sc_eval_005_domain_failure_prevents_rendering() {\n   360→    let contract = contract_for_stage(StageId::Implementation);\n   361→    let json = json!({\n   362→        \"change_summary\": \"   \",\n   363→        \"steps\": [],\n   364→        \"validation_evidence\": [],\n   365→        \"outstanding_risks\": []\n   366→    });\n   367→    let err = contract.evaluate(&json).unwrap_err();\n   368→    assert!(matches!(err, ContractError::DomainValidation { .. }));\n   369→}\n   370→\n   371→#[test]\n   372→fn sc_eval_006_qa_review_outcome_failure() {\n   373→    let contract = contract_for_stage(StageId::FinalReview);\n   374→    let json = json!({\n   375→        \"outcome\": \"rejected\",\n   376→        \"evidence\": [\"Fails acceptance.\"],\n   377→        \"findings_or_gaps\": [\"Critical gap.\"],\n   378→        \"follow_up_or_amendments\": [\"Rework needed.\"]\n   379→    });\n   380→    let err = contract.evaluate(&json).unwrap_err();\n   381→    assert!(matches!(err, ContractError::QaReviewOutcome { .. }));\n   382→    assert_eq!(err.failure_class(), FailureClass::QaReviewOutcomeFailure);\n   383→}\n   384→\n   385→// ── All flows have complete contract coverage ───────────────────────────────\n   386→\n   387→#[test]\n   388→fn sc_eval_007_all_presets_have_complete_contract_coverage() {\n   389→    for preset in FlowPreset::all() {\n   390→        let flow = flow_definition(*preset);\n   391→        for &stage_id in flow.stages {\n   392→            let _contract = contract_for_stage(stage_id);\n   393→            // No panic = contract exists.\n   394→        }\n   395→    }\n   396→}\n   397→\n   398→// ── SC-EVAL-009: Non-passing outcomes are distinct from schema/domain ────────\n   399→\n   400→#[test]\n   401→fn sc_eval_009_non_passing_review_not_schema_or_domain_failure() {\n   402→    let contract = contract_for_stage(StageId::Review);\n   403→    let json = json!({\n   404→        \"outcome\": \"request_changes\",\n   405→        \"evidence\": [\"Some evidence.\"],\n   406→        \"findings_or_gaps\": [\"A gap.\"],\n   407→        \"follow_up_or_amendments\": [\"Fix it.\"]\n   408→    });\n   409→    let err = contract.evaluate(&json).unwrap_err();\n   410→    assert!(matches!(err, ContractError::QaReviewOutcome { .. }));\n   411→    assert_eq!(err.failure_class(), FailureClass::QaReviewOutcomeFailure);\n   412→    assert_ne!(err.failure_class(), FailureClass::SchemaValidationFailure);\n   413→    assert_ne!(err.failure_class(), FailureClass::DomainValidationFailure);\n   414→}\n   415→\n   416→// ── Runtime validation alignment with generated schema ───────────────────────\n   417→\n   418→#[test]\n   419→fn schema_validation_rejects_what_generated_schema_marks_required() {\n   420→    // Proves that runtime deserialization (evaluate) rejects a payload missing\n   421→    // fields that the generated JSON Schema marks as required, ensuring the two\n   422→    // validation paths stay aligned.\n   423→    use jsonschema::JSONSchema;\n   424→\n   425→    let contract = contract_for_stage(StageId::Planning);\n   426→    let schema_value = serde_json::to_value(contract.json_schema()).expect(\"schema serializes\");\n   427→    let compiled = JSONSchema::compile(&schema_value).expect(\"schema compiles\");\n   428→\n   429→    let missing_fields = json!({\"not_a_real_field\": true});\n   430→\n   431→    // Generated schema rejects this payload.\n   432→    assert!(\n   433→        !compiled.is_valid(&missing_fields),\n   434→        \"generated schema should reject payload missing required fields\"\n   435→    );\n   436→    // Runtime evaluation also rejects it.\n   437→    let err = contract.evaluate(&missing_fields).unwrap_err();\n   438→    assert!(\n   439→        matches!(err, ContractError::SchemaValidation { .. }),\n   440→        \"runtime evaluation should also reject: {err:?}\"\n   441→    );\n   442→}\n   443→\n   444→#[test]\n   445→fn schema_validation_accepts_what_generated_schema_accepts() {\n   446→    use jsonschema::JSONSchema;\n   447→\n   448→    let contract = contract_for_stage(StageId::Planning);\n   449→    let schema_value = serde_json::to_value(contract.json_schema()).expect(\"schema serializes\");\n   450→    let compiled = JSONSchema::compile(&schema_value).expect(\"schema compiles\");\n   451→\n   452→    let valid = valid_planning_json();\n   453→\n   454→    // Generated schema accepts this payload.\n   455→    assert!(\n   456→        compiled.is_valid(&valid),\n   457→        \"generated schema should accept valid payload\"\n   458→    );\n   459→    // Runtime evaluation also accepts it.\n   460→    assert!(\n   461→        contract.evaluate(&valid).is_ok(),\n   462→        \"runtime evaluation should also accept valid payload\"\n   463→    );\n   464→}\n   465→"}]},"parent_tool_use_id":"toolu_01D1YGYYF5pXopdBJ1HtvaN6","session_id":"3d9a0615-7442-4a66-ab27-f8160d110223","uuid":"d7b1aa1a-a323-44b9-8936-1e0eee7bf3aa"}
