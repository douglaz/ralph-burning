id: String,\n    50→    pub issue_ref: String,\n    51→    pub project_id: String,\n    52→    #[serde(default, skip_serializing_if = \"Option::is_none\")]\n    53→    pub project_name: Option<String>,\n    54→    #[serde(default, skip_serializing_if = \"Option::is_none\")]\n    55→    pub prompt: Option<String>,\n    56→    #[serde(default, skip_serializing_if = \"Option::is_none\")]\n    57→    pub routing_command: Option<String>,\n    58→    #[serde(default, skip_serializing_if = \"Vec::is_empty\")]\n    59→    pub routing_labels: Vec<String>,\n    60→    #[serde(default, skip_serializing_if = \"Option::is_none\")]\n    61→    pub resolved_flow: Option<FlowPreset>,\n    62→    #[serde(default, skip_serializing_if = \"Option::is_none\")]\n    63→    pub routing_source: Option<RoutingSource>,\n    64→    #[serde(default, skip_serializing_if = \"Vec::is_empty\")]\n    65→    pub routing_warnings: Vec<String>,\n    66→    pub status: TaskStatus,\n    67→    pub created_at: DateTime<Utc>,\n    68→    pub updated_at: DateTime<Utc>,\n    69→    #[serde(default)]\n    70→    pub attempt_count: u32,\n    71→    #[serde(default, skip_serializing_if = \"Option::is_none\")]\n    72→    pub lease_id: Option<String>,\n    73→    #[serde(default, skip_serializing_if = \"Option::is_none\")]\n    74→    pub failure_class: Option<String>,\n    75→    #[serde(default, skip_serializing_if = \"Option::is_none\")]\n    76→    pub failure_message: Option<String>,\n    77→    /// Dispatch mode for this task (workflow vs requirements handoff).\n    78→    #[serde(default = \"default_dispatch_mode\")]\n    79→    pub dispatch_mode: DispatchMode,\n    80→    /// Stable source revision for idempotent re-polling.\n    81→    #[serde(default, skip_serializing_if = \"Option::is_none\")]\n    82→    pub source_revision: Option<String>,\n    83→    /// Linked requirements run ID (set during requirements_draft or requirements_quick dispatch).\n    84→    #[serde(default, skip_serializing_if = \"Option::is_none\")]\n    85→    pub requirements_run_id: Option<String>,\n    86→}\n    87→\n    88→fn default_dispatch_mode() -> DispatchMode {\n    89→    DispatchMode::Workflow\n    90→}\n    91→\n    92→impl DaemonTask {\n    93→    pub fn is_terminal(&self) -> bool {\n    94→        self.status.is_terminal()\n    95→    }\n    96→\n    97→    pub fn transition_to(&mut self, next: TaskStatus, now: DateTime<Utc>) -> AppResult<()> {\n    98→        if !self.status.can_transition_to(next) {\n    99→            return Err(AppError::TaskStateTransitionInvalid {\n   100→                task_id: self.task_id.clone(),\n   101→                from: self.status.as_str().to_owned(),\n   102→                to: next.as_str().to_owned(),\n   103→            });\n   104→        }\n   105→\n   106→        self.status = next;\n   107→        self.updated_at = now;\n   108→        Ok(())\n   109→    }\n   110→\n   111→    pub fn attach_lease(&mut self, lease_id: impl Into<String>) {\n   112→        self.lease_id = Some(lease_id.into());\n   113→    }\n   114→\n   115→    pub fn clear_lease(&mut self) {\n   116→        self.lease_id = None;\n   117→    }\n   118→\n   119→    pub fn clear_failure(&mut self) {\n   120→        self.failure_class = None;\n   121→        self.failure_message = None;\n   122→    }\n   123→\n   124→    pub fn set_failure(\n   125→        &mut self,\n   126→        failure_class: impl Into<String>,\n   127→        failure_message: impl Into<String>,\n   128→    ) {\n   129→        self.failure_class = Some(failure_class.into());\n   130→        self.failure_message = Some(failure_message.into());\n   131→    }\n   132→}\n   133→\n   134→#[derive(Debug, Clone, Copy, PartialEq, Eq, Serialize, Deserialize)]\n   135→#[serde(rename_all = \"snake_case\")]\n   136→pub enum TaskStatus {\n   137→    Pending,\n   138→    Claimed,\n   139→    Active,\n   140→    /// Waiting for external input (e.g. requirements answers). Holds no lease,\n   141→    /// no writer lock, no active workflow run.\n   142→    WaitingForRequirements,\n   143→    Completed,\n   144→    Failed,\n   145→    Aborted,\n   146→}\n   147→\n   148→impl TaskStatus {\n   149→    pub fn as_str(self) -> &'static str {\n   150→        match self {\n   151→            Self::Pending => \"pending\",\n   152→            Self::Claimed => \"claimed\",\n   153→            Self::Active => \"active\",\n   154→            Self::WaitingForRequirements => \"waiting_for_requirements\",\n   155→            Self::Completed => \"completed\",\n   156→            Self::Failed => \"failed\",\n   157→            Self::Aborted => \"aborted\",\n   158→        }\n   159→    }\n   160→\n   161→    pub fn is_terminal(self) -> bool {\n   162→        matches!(self, Self::Completed | Self::Failed | Self::Aborted)\n   163→    }\n   164→\n   165→    /// Whether this status is non-terminal and counts as an active task for\n   166→    /// duplicate-issue detection purposes.\n   167→    pub fn is_active_for_issue(self) -> bool {\n   168→        !self.is_terminal()\n   169→    }\n   170→\n   171→    pub fn can_transition_to(self, next: Self) -> bool {\n   172→        match (self, next) {\n   173→            (Self::Pending, Self::Claimed | Self::Failed) => true,\n   174→            (Self::Claimed, Self::Active | Self::Failed | Self::Aborted) => true,\n   175→            (Self::Active, Self::Pending | Self::Completed | Self::Failed | Self::Aborted | Self::WaitingForRequirements) => true,\n   176→            (Self::WaitingForRequirements, Self::Pending | Self::Failed | Self::Aborted) => true,\n   177→            (Self::Failed, Self::Pending) => true,\n   178→            _ if self == next => true,\n   179→            _ => false,\n   180→        }\n   181→    }\n   182→}\n   183→\n   184→impl std::fmt::Display for TaskStatus {\n   185→    fn fmt(&self, f: &mut std::fmt::Formatter<'_>) -> std::fmt::Result {\n   186→        f.write_str(self.as_str())\n   187→    }\n   188→}\n   189→\n   190→#[derive(Debug, Clone, PartialEq, Eq, Serialize, Deserialize)]\n   191→pub struct WorktreeLease {\n   192→    pub lease_id: String,\n   193→    pub task_id: String,\n   194→    pub project_id: String,\n   195→    pub worktree_path: PathBuf,\n   196→    pub branch_name: String,\n   197→    pub acquired_at: DateTime<Utc>,\n   198→    pub ttl_seconds: u64,\n   199→    pub last_heartbeat: DateTime<Utc>,\n   200→}\n   201→\n   202→impl WorktreeLease {\n   203→    pub fn heartbeat_deadline(&self) -> DateTime<Utc> {\n   204→        self.last_heartbeat + Duration::seconds(self.ttl_seconds.min(i64::MAX as u64) as i64)\n   205→    }\n   206→\n   207→    pub fn is_stale_at(&self, now: DateTime<Utc>) -> bool {\n   208→        now > self.heartbeat_deadline()\n   209→    }\n   210→}\n   211→\n   212→#[derive(Debug, Clone, Copy, PartialEq, Eq, Serialize, Deserialize)]\n   213→#[serde(rename_all = \"snake_case\")]\n   214→pub enum RoutingSource {\n   215→    Command,\n   216→    Label,\n   217→    DefaultFlow,\n   218→}\n   219→\n   220→#[derive(Debug, Clone, PartialEq, Eq, Serialize, Deserialize)]\n   221→pub struct RoutingResolution {\n   222→    pub flow: FlowPreset,\n   223→    pub source: RoutingSource,\n   224→    #[serde(default, skip_serializing_if = \"Vec::is_empty\")]\n   225→    pub warnings: Vec<String>,\n   226→}\n   227→\n   228→#[derive(Debug, Clone, PartialEq, Serialize, Deserialize)]\n   229→pub struct DaemonJournalEvent {\n   230→    pub sequence: u64,\n   231→    pub timestamp: DateTime<Utc>,\n   232→    pub event_type: DaemonJournalEventType,\n   233→    pub details: serde_json::Value,\n   234→}\n   235→\n   236→#[derive(Debug, Clone, Copy, PartialEq, Eq, Serialize, Deserialize)]\n   237→#[serde(rename_all = \"snake_case\")]\n   238→pub enum DaemonJournalEventType {\n   239→    TaskCreated,\n   240→    TaskClaimed,\n   241→    TaskCompleted,\n   242→    TaskFailed,\n   243→    TaskAborted,\n   244→    LeaseAcquired,\n   245→    LeaseReleased,\n   246→    ReconciliationRun,\