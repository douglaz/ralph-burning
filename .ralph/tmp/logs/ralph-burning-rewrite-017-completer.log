{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01GQ7rdH1Xki3J5qfoNk7P4Q","type":"tool_result","content":"     1→use std::collections::HashMap;\n     2→use std::path::{Path, PathBuf};\n     3→use std::process::Command;\n     4→\n     5→use super::runner::ScenarioExecutor;\n     6→\n     7→use crate::contexts::workflow_composition::contracts::{contract_for_stage, all_contracts, ContractFamily};\n     8→use crate::shared::domain::StageId;\n     9→use crate::shared::error::ContractError;\n    10→\n    11→// ---------------------------------------------------------------------------\n    12→// Temp workspace helper\n    13→// ---------------------------------------------------------------------------\n    14→\n    15→struct TempWorkspace {\n    16→    path: PathBuf,\n    17→}\n    18→\n    19→impl TempWorkspace {\n    20→    fn new() -> Result<Self, String> {\n    21→        let path = std::env::temp_dir().join(format!(\n    22→            \"ralph-conformance-{}\",\n    23→            uuid::Uuid::new_v4()\n    24→        ));\n    25→        std::fs::create_dir_all(&path).map_err(|e| format!(\"create temp workspace: {e}\"))?;\n    26→        Ok(Self { path })\n    27→    }\n    28→\n    29→    fn path(&self) -> &Path {\n    30→        &self.path\n    31→    }\n    32→}\n    33→\n    34→impl Drop for TempWorkspace {\n    35→    fn drop(&mut self) {\n    36→        let _ = std::fs::remove_dir_all(&self.path);\n    37→    }\n    38→}\n    39→\n    40→// ---------------------------------------------------------------------------\n    41→// CLI helpers\n    42→// ---------------------------------------------------------------------------\n    43→\n    44→fn binary_path() -> PathBuf {\n    45→    let exe = std::env::current_exe().expect(\"current executable path\");\n    46→    // Canonicalize to an absolute path so the binary can be found even when the\n    47→    // child process runs in a different working directory (e.g. a temp workspace).\n    48→    exe.canonicalize().unwrap_or(exe)\n    49→}\n    50→\n    51→struct CmdOutput {\n    52→    success: bool,\n    53→    stdout: String,\n    54→    stderr: String,\n    55→}\n    56→\n    57→fn run_cli(args: &[&str], cwd: &Path) -> Result<CmdOutput, String> {\n    58→    run_cli_with_env(args, cwd, &[])\n    59→}\n    60→\n    61→fn run_cli_with_env(\n    62→    args: &[&str],\n    63→    cwd: &Path,\n    64→    env: &[(&str, &str)],\n    65→) -> Result<CmdOutput, String> {\n    66→    let mut cmd = Command::new(binary_path());\n    67→    cmd.args(args).current_dir(cwd);\n    68→    for (k, v) in env {\n    69→        cmd.env(k, v);\n    70→    }\n    71→    let output = cmd.output().map_err(|e| format!(\"failed to run CLI: {e}\"))?;\n    72→\n    73→    Ok(CmdOutput {\n    74→        success: output.status.success(),\n    75→        stdout: String::from_utf8_lossy(&output.stdout).to_string(),\n    76→        stderr: String::from_utf8_lossy(&output.stderr).to_string(),\n    77→    })\n    78→}\n    79→\n    80→// ---------------------------------------------------------------------------\n    81→// Journal and durable-state assertion helpers\n    82→// ---------------------------------------------------------------------------\n    83→\n    84→fn read_journal(ws: &TempWorkspace, project_id: &str) -> Result<Vec<serde_json::Value>, String> {\n    85→    let path = ws\n    86→        .path()\n    87→        .join(format!(\".ralph-burning/projects/{project_id}/journal.ndjson\"));\n    88→    let content = std::fs::read_to_string(&path).map_err(|e| format!(\"read journal: {e}\"))?;\n    89→    content\n    90→        .lines()\n    91→        .filter(|l| !l.trim().is_empty())\n    92→        .map(|l| serde_json::from_str(l).map_err(|e| format!(\"parse journal line: {e}\")))\n    93→        .collect()\n    94→}\n    95→\n    96→fn read_run_snapshot(\n    97→    ws: &TempWorkspace,\n    98→    project_id: &str,\n    99→) -> Result<serde_json::Value, String> {\n   100→    let path = ws\n   101→        .path()\n   102→        .join(format!(\".ralph-burning/projects/{project_id}/run.json\"));\n   103→    let content = std::fs::read_to_string(&path).map_err(|e| format!(\"read run.json: {e}\"))?;\n   104→    serde_json::from_str(&content).map_err(|e| format!(\"parse run.json: {e}\"))\n   105→}\n   106→\n   107→fn count_payload_files(ws: &TempWorkspace, project_id: &str) -> Result<usize, String> {\n   108→    let dir = ws\n   109→        .path()\n   110→        .join(format!(\".ralph-burning/projects/{project_id}/history/payloads\"));\n   111→    let count = std::fs::read_dir(&dir)\n   112→        .map_err(|e| format!(\"read payloads dir: {e}\"))?\n   113→        .filter_map(|e| e.ok())\n   114→        .filter(|e| e.path().extension().map_or(false, |ext| ext == \"json\"))\n   115→        .count();\n   116→    Ok(count)\n   117→}\n   118→\n   119→fn count_artifact_files(ws: &TempWorkspace, project_id: &str) -> Result<usize, String> {\n   120→    let dir = ws\n   121→        .path()\n   122→        .join(format!(\".ralph-burning/projects/{project_id}/history/artifacts\"));\n   123→    let count = std::fs::read_dir(&dir)\n   124→        .map_err(|e| format!(\"read artifacts dir: {e}\"))?\n   125→        .filter_map(|e| e.ok())\n   126→        .filter(|e| e.path().extension().map_or(false, |ext| ext == \"json\"))\n   127→        .count();\n   128→    Ok(count)\n   129→}\n   130→\n   131→fn journal_event_types(events: &[serde_json::Value]) -> Vec<String> {\n   132→    events\n   133→        .iter()\n   134→        .filter_map(|e| e.get(\"event_type\").and_then(|v| v.as_str()).map(String::from))\n   135→        .collect()\n   136→}\n   137→\n   138→/// Check that `haystack` does not contain `needle`, returning a descriptive error if it does.\n   139→#[allow(dead_code)]\n   140→fn assert_not_contains(haystack: &str, needle: &str, context: &str) -> Result<(), String> {\n   141→    if haystack.contains(needle) {\n   142→        return Err(format