{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0175VkcuweBDkwbqt51Lreat","type":"tool_result","content":"     1→use std::fmt;\n     2→use std::path::{Path, PathBuf};\n     3→use std::sync::atomic::{AtomicBool, Ordering};\n     4→use std::sync::Arc;\n     5→use std::time::Duration;\n     6→\n     7→use chrono::{DateTime, Utc};\n     8→use serde_json::Value;\n     9→use tokio::sync::Notify;\n    10→\n    11→use crate::contexts::agent_execution::session::SessionMetadata;\n    12→use crate::contexts::workflow_composition::contracts::StageContract;\n    13→use crate::shared::domain::{\n    14→    BackendRole, BackendSpec, ModelSpec, ResolvedBackendTarget, SessionPolicy, StageId,\n    15→};\n    16→\n    17→#[derive(Clone)]\n    18→pub struct CancellationToken {\n    19→    cancelled: Arc<AtomicBool>,\n    20→    notify: Arc<Notify>,\n    21→}\n    22→\n    23→impl CancellationToken {\n    24→    pub fn new() -> Self {\n    25→        Self {\n    26→            cancelled: Arc::new(AtomicBool::new(false)),\n    27→            notify: Arc::new(Notify::new()),\n    28→        }\n    29→    }\n    30→\n    31→    pub fn cancel(&self) {\n    32→        self.cancelled.store(true, Ordering::SeqCst);\n    33→        self.notify.notify_waiters();\n    34→    }\n    35→\n    36→    pub fn is_cancelled(&self) -> bool {\n    37→        self.cancelled.load(Ordering::SeqCst)\n    38→    }\n    39→\n    40→    pub async fn cancelled(&self) {\n    41→        if self.is_cancelled() {\n    42→            return;\n    43→        }\n    44→\n    45→        self.notify.notified().await;\n    46→    }\n    47→}\n    48→\n    49→impl Default for CancellationToken {\n    50→    fn default() -> Self {\n    51→        Self::new()\n    52→    }\n    53→}\n    54→\n    55→impl fmt::Debug for CancellationToken {\n    56→    fn fmt(&self, f: &mut fmt::Formatter<'_>) -> fmt::Result {\n    57→        f.debug_struct(\"CancellationToken\")\n    58→            .field(\"cancelled\", &self.is_cancelled())\n    59→            .finish()\n    60→    }\n    61→}\n    62→\n    63→#[derive(Debug, Clone, PartialEq)]\n    64→pub struct InvocationPayload {\n    65→    pub prompt: String,\n    66→    pub context: Value,\n    67→}\n    68→\n    69→// ── Domain-neutral contract identifier ──────────────────────────────────────\n    70→\n    71→/// A domain-neutral invocation contract. Wraps either a workflow `StageContract`\n    72→/// or a requirements-specific contract label. This generalizes agent execution\n    73→/// away from workflow-only `StageContract` coupling.\n    74→#[derive(Debug, Clone)]\n    75→pub enum InvocationContract {\n    76→    /// Workflow stage contract — validated by agent execution.\n    77→    Stage(StageContract),\n    78→    /// Requirements or other domain contract — caller validates after invocation.\n    79→    Requirements { label: String },\n    80→}\n    81→\n    82→impl InvocationContract {\n    83→    /// Human-readable label for error messages and logging.\n    84→    pub fn label(&self) -> String {\n    85→        match self {\n    86→            Self::Stage(c) => c.stage_id.as_str().to_owned(),\n    87→            Self::Requirements { label } => label.clone(),\n    88→        }\n    89→    }\n    90→\n    91→    /// Returns the `StageId` if this is a workflow stage contract.\n    92→    pub fn stage_id(&self) -> Option<StageId> {\n    93→        match self {\n    94→            Self::Stage(c) => Some(c.stage_id),\n    95→            Self::Requirements { .. } => None,\n    96→        }\n    97→    }\n    98→\n    99→    /// Returns the `StageContract` if this is a workflow stage contract.\n   100→    pub fn stage_contract(&self) -> Option<&StageContract> {\n   101→        match self {\n   102→            Self::Stage(c) => Some(c),\n   103→            Self::Requirements { .. } => None,\n   104→        }\n   105→    }\n   106→}\n   107→\n   108→#[derive(Debug, Clone)]\n   109→pub struct InvocationRequest {\n   110→    pub invocation_id: String,\n   111→    pub project_root: PathBuf,\n   112→    pub contract: InvocationContract,\n   113→    pub role: BackendRole,\n   114→    pub resolved_target: ResolvedBackendTarget,\n   115→    pub payload: InvocationPayload,\n   116→    pub timeout: Duration,\n   117→    pub cancellation_token: CancellationToken,\n   118→    pub session_policy: SessionPolicy,\n   119→    pub prior_session: Option<SessionMetadata>,\n   120→    pub attempt_number: u32,\n   121→}\n   122→\n   123→#[derive(Debug, Clone, PartialEq, Eq)]\n   124→pub struct CapabilityCheck {\n   125→    pub backend: BackendSpec,\n   126→    pub model: ModelSpec,\n   127→    pub contract_id: String,\n   128→    pub supported: bool,\n   129→    pub details: Option<String>,\n   130→}\n   131→\n   132→impl CapabilityCheck {\n   133→    pub fn success(target: &ResolvedBackendTarget, contract: &InvocationContract) -> Self {\n   134→        Self {\n   135→            backend: target.backend.clone(),\n   136→            model: target.model.clone(),\n   137→            contract_id: contract.label(),\n   138→            supported: true,\n   139→            details: None,\n   140→        }\n   141→    }\n   142→\n   143→    pub fn failure(\n   144→        target: &ResolvedBackendTarget,\n   145→        contract: &InvocationContract,\n   146→        details: impl Into<String>,\n   147→    ) -> Self {\n   148→        Self {\n   149→            backend: target.backend.clone(),\n   150→            model: target.model.clone(),\n   151→            contract_id: contract.label(),\n   152→            supported: false,\n   153→            details: Some(details.into()),\n   154→        }\n   155→    }\n   156→}\n   157→\n   158→#[derive(Debug, Clone, PartialEq, Eq)]\n   159→pub enum RawOutputReference {\n   160→    Inline(String),\n   161→    Stored(PathBuf),\n   162→}\n   163→\n   164→impl RawOutputReference {\n   165→    pub fn inline_contents(&self) -> Option<&str> {\n   166→        match self {\n   167→            Self::Inline(contents) => Some(contents),\n   168→            Self::Stored(_) => None,\n   169→        }\n   170→    }\n   171→\n   172→    pub fn stored_path(&self) -> Option<&Path> {\n   173→        match self {\n   174→            Self::Inline(_) => None,\n   175→            Self::Stored(path) => Some(path.as_path()),\n   176→        }\n   177→    }\n   178→}\n   179→\n   180→#[derive(Debug, Clone, Default, PartialEq, Eq)]\n   181→pub struct TokenCounts {\n   182→    pub prompt_tokens: Option<u32>,\n   183→    pub completion_tokens: Option<u32>,\n   184→    pub total_tokens: Option<u32>,\n   185→}\n   186→\n   187→#[derive(Debug, Clone, PartialEq, Eq)]\n   188→pub struct InvocationMetadata {\n   189→    pub invocation_id: String,\n   190→    pub duration: Duration,\n   191→    pub token_counts: TokenCounts,\n   192→    pub backend_used: BackendSpec,\n   193→    pub model_used: ModelSpec,\n   194→    pub attempt_number: u32,\n   195→    pub session_id: Option<String>,\n   196→    pub session_reused: bool,\n   197→}\n   198→\n   199→#[derive(Debug, Clone, PartialEq)]\n   200→pub struct InvocationEnvelope {\n   201→    pub raw_output_reference: RawOutputReference,\n   202→    pub parsed_payload: Value,\n   203→    pub metadata: InvocationMetadata,\n   204→    pub timestamp: DateTime<Utc>,\n   205→}\n   206→"}]},"parent_tool_use_id":"toolu_01WxWEKeVM8eN1eTgMgZkDxS","session_id":"3d9a0615-7442-4a66-ab27-f8160d110223","uuid":"149e655d-d5be-44cb-bf10-c2dad8955b0a"}
