{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01JrTU1Mjy5fXyf7yUeUm188","type":"tool_result","content":"     1→use std::collections::HashMap;\n     2→\n     3→use crate::shared::domain::FailureClass;\n     4→\n     5→#[derive(Debug, Clone, Copy, PartialEq, Eq)]\n     6→pub struct RetryRule {\n     7→    pub max_attempts: u32,\n     8→    pub retryable: bool,\n     9→}\n    10→\n    11→impl RetryRule {\n    12→    pub const fn retryable(max_attempts: u32) -> Self {\n    13→        Self {\n    14→            max_attempts,\n    15→            retryable: true,\n    16→        }\n    17→    }\n    18→\n    19→    pub const fn terminal() -> Self {\n    20→        Self {\n    21→            max_attempts: 1,\n    22→            retryable: false,\n    23→        }\n    24→    }\n    25→}\n    26→\n    27→#[derive(Debug, Clone, PartialEq, Eq)]\n    28→pub struct RetryPolicy {\n    29→    rules: HashMap<FailureClass, RetryRule>,\n    30→    max_remediation_cycles: u32,\n    31→}\n    32→\n    33→impl RetryPolicy {\n    34→    pub fn default_policy() -> Self {\n    35→        let mut rules = HashMap::new();\n    36→        rules.insert(FailureClass::TransportFailure, RetryRule::retryable(3));\n    37→        rules.insert(\n    38→            FailureClass::SchemaValidationFailure,\n    39→            RetryRule::retryable(2),\n    40→        );\n    41→        rules.insert(\n    42→            FailureClass::DomainValidationFailure,\n    43→            RetryRule::retryable(2),\n    44→        );\n    45→        rules.insert(FailureClass::Timeout, RetryRule::retryable(2));\n    46→        rules.insert(FailureClass::Cancellation, RetryRule::terminal());\n    47→        rules.insert(FailureClass::QaReviewOutcomeFailure, RetryRule::terminal());\n    48→\n    49→        Self {\n    50→            rules,\n    51→            max_remediation_cycles: 3,\n    52→        }\n    53→    }\n    54→\n    55→    pub fn with_rule(mut self, failure_class: FailureClass, rule: RetryRule) -> Self {\n    56→        self.rules.insert(failure_class, rule);\n    57→        self\n    58→    }\n    59→\n    60→    pub fn with_max_remediation_cycles(mut self, max_remediation_cycles: u32) -> Self {\n    61→        self.max_remediation_cycles = max_remediation_cycles.max(1);\n    62→        self\n    63→    }\n    64→\n    65→    pub fn rule_for(&self, failure_class: FailureClass) -> RetryRule {\n    66→        self.rules\n    67→            .get(&failure_class)\n    68→            .copied()\n    69→            .unwrap_or_else(RetryRule::terminal)\n    70→    }\n    71→\n    72→    pub fn max_attempts(&self, failure_class: FailureClass) -> u32 {\n    73→        self.rule_for(failure_class).max_attempts\n    74→    }\n    75→\n    76→    pub fn is_retryable(&self, failure_class: FailureClass) -> bool {\n    77→        self.rule_for(failure_class).retryable\n    78→    }\n    79→\n    80→    pub fn max_remediation_cycles(&self) -> u32 {\n    81→        self.max_remediation_cycles\n    82→    }\n    83→}\n    84→"}]},"parent_tool_use_id":"toolu_01WxWEKeVM8eN1eTgMgZkDxS","session_id":"3d9a0615-7442-4a66-ab27-f8160d110223","uuid":"5c3cad84-1ec4-41c6-98e1-ce89d7c737ed"}
