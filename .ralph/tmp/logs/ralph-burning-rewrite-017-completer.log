ot_read.read_run_snapshot(&current_dir, &project_id)?;\n   174→    match final_snapshot.status {\n   175→        RunStatus::Completed => println!(\"Run completed successfully.\"),\n   176→        RunStatus::Paused => println!(\"{}\", final_snapshot.status_summary),\n   177→        status => println!(\"Run finished with status '{}'.\", status),\n   178→    }\n   179→    Ok(())\n   180→}\n   181→\n   182→async fn handle_resume() -> AppResult<()> {\n   183→    let current_dir = std::env::current_dir()?;\n   184→\n   185→    let config = workspace_governance::load_workspace_config(&current_dir)?;\n   186→    workspace_governance::ensure_supported_workspace_version(&config)?;\n   187→\n   188→    let project_id = workspace_governance::resolve_active_project(&current_dir)?;\n   189→\n   190→    let project_store = FsProjectStore;\n   191→    let project_record = project_store.read_project_record(&current_dir, &project_id)?;\n   192→    let run_snapshot_read = FsRunSnapshotStore;\n   193→    let run_snapshot = run_snapshot_read.read_run_snapshot(&current_dir, &project_id)?;\n   194→    match run_snapshot.status {\n   195→        RunStatus::Failed | RunStatus::Paused => {}\n   196→        RunStatus::NotStarted => {\n   197→            return Err(AppError::ResumeFailed {\n   198→                reason: \"project has not started a run yet; use `ralph-burning run start`\"\n   199→                    .to_owned(),\n   200→            });\n   201→        }\n   202→        RunStatus::Running => {\n   203→            return Err(AppError::ResumeFailed {\n   204→                reason: \"project already has a running run; `run resume` only works from failed or paused snapshots\".to_owned(),\n   205→            });\n   206→        }\n   207→        RunStatus::Completed => {\n   208→            return Err(AppError::ResumeFailed {\n   209→                reason: \"project is already completed; there is nothing to resume\".to_owned(),\n   210→            });\n   211→        }\n   212→   