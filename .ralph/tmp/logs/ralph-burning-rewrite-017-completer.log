ruct ConfigSetArgs {\n   252→    pub key: String,\n   253→    pub value: String,\n   254→    #[command(flatten)]\n   255→    pub scope: ConfigScopeArgs,\n   256→}\n   257→\n   258→#[derive(Debug, Args)]\n   259→pub struct ConfigShowArgs {\n   260→    #[command(flatten)]\n   261→    pub scope: ConfigScopeArgs,\n   262→}\n   263→\n   264→#[derive(Debug, Args)]\n   265→pub struct ConfigEditArgs {\n   266→    #[command(flatten)]\n   267→    pub scope: ConfigScopeArgs,\n   268→}\n   269→\n   270→#[derive(Debug, Args, Clone)]\n   271→pub struct ConfigScopeArgs {\n   272→    #[arg(long, conflicts_with = \"project\")]\n   273→    pub global: bool,\n   274→    #[arg(long)]\n   275→    pub project: Option<String>,\n   276→}\n   277→\n   278→fn parse_positive_usize(value: &str) -> std::result::Result<usize, String> {\n   279→    let parsed = value\n   280→        .parse::<usize>()\n   281→        .map_err(|_| format!(\"invalid value '{value}': expected positive integer\"))?;\n   282→    if parsed == 0 {\n   283→        return Err(\"must be greater than 0\".to_owned());\n   284→    }\n   285→    Ok(parsed)\n   286→}\n   287→\n   288→fn parse_positive_u64(value: &str) -> std::result::Result<u64, String> {\n   289→    let parsed = value\n   290→        .parse::<u64>()\n   291→        .map_err(|_| format!(\"invalid value '{value}': expected positive integer\"))?;\n   292→    if parsed == 0 {\n   293→        return Err(\"must be greater than 0\".to_owned());\n   294→    }\n   295→    Ok(parsed)\n   296→}\n   297→\n   298→fn parse_positive_u32(value: &str) -> std::result::Result<u32, String> {\n   299→    let parsed = value\n   300→        .parse::<u32>()\n   301→        .map_err(|_| format!(\"invalid value '{value}': expected positive integer\"))?;\n   302→    if parsed == 0 {\n   303→        return Err(\"must be greater than 0\".to_owned());\n   304→    }\n   305→    Ok(parsed)\n   306→}\n   307→\n   308→pub async fn run(cli: Cli) -> Result<()> {\n   309→    match cli.command {\n   310→        Commands::Init(args) => init::execute(args),\n   311→        Commands::Project(args) => project::execute(args),\n   312→        Commands::Run(args) => run::execute(args).await,\n   313→        Commands::Backend(args) => backend::execute(args).await,\n   314→        Commands::Prd(args) => prd::execute(args).await,\n   315→        Commands::QuickPrd(args) => quick_prd::execute(args).await,\n   316→        Commands::Auto(args) => auto::execute(args).await,\n   317→        Commands::QuickDevRun(args) => quick_dev_run::execute(args).await,\n   318→        Commands::QuickDevAuto(args) => quick_dev_auto::execute(args).await,\n   319→        Commands::Validate(args) => validate::execute(args),\n   320→        Commands::Status(args) => status::execute(args).await,\n   321→        Commands::History(args) => history::execute(args),\n   322→        Commands::Tail(args) => tail::execute(args).await,\n   323→        Commands::Rollback(args) => rollback::execute(args),\n   324→        Commands::Config(args) => config::execute(args),\n   325→        Commands::Daemon(args) => daemon::execute(args).await,\n   326→        Commands::Amend(args) => amend::execute(args),\n   327→    }\n   328→}\n   329→\n   330→#[cfg(test)]\n   331→mod tests {\n   332→    use clap::Parser;\n   333→\n   334→    use super::{Cli, Commands};\n   335→\n   336→    #[test]\n   337→    fn parses_run_with_tmux_flag() {\n   338→        let cli = Cli::parse_from([\"ralph\", \"run\", \"--tmux\"]);\n   339→        let Commands::Run(args) = cli.command else {\n   340→            panic!(\"expected run command\");\n   341→        };\n   342→\n   343→        assert_eq!(args.tmux, Some(true));\n   344→        assert_eq!(args.no_tmux, None);\n   345→    }\n   346→\n   347→    #[test]\n   348→    fn parses_run_with_no_tmux_flag() {\n   349→        let cli = Cli::parse_from([\"ralph\", \"run\", \"--no-tmux\"]);\n   350→        let Commands::Run(args) = cli.command else {\n   351→            panic!(\"expected run command\");\n   352→        };\n   353→\n   354→        assert_eq!(args.tmux, None);\n   355→        assert_eq!(args.no_tmux, Some(false));\n   356→    }\n   357→\n   358→    #[test]\n   359→    fn parses_run_without_tmux_flags() {\n   360→        let cli = Cli::parse_from([\"ralph\", \"run\"]);\n   361→        let Commands::Run(args) = cli.command else {\n   362→            panic!(\"expected run command\");\n   363→        };\n   364→\n   365→        assert_eq!(args.tmux, None);\n   366→        assert_eq!(args.no_tmux, None);\n   367→    }\n   368→\n   369→    #[test]\n   370→    fn rejects_run_with_conflicting_tmux_flags() {\n   371→        let result = Cli::try_parse_from([\"ralph\", \"run\", \"--tmux\", \"--no-tmux\"]);\n   372→        assert!(result.is_err());\n   373→    }\n   374→\n   375→    #[test]\n   376→    fn parses_init_with_dry_run_long_flag() {\n   377→        let cli = Cli::parse_from([\"ralph\", \"init\", \"--dry-run\"]);\n   378→        let Commands::Init(args) = cli.command else {\n   379→            panic!(\"expected init command\");\n   380→        };\n   381→\n   382→        assert_eq!(args.dir, std::path::PathBuf::from(\".ralph\"));\n   383→        assert!(args.dry_run);\n   384→    }\n   385→\n   386→    #[test]\n   387→    fn parses_init_with_dry_run_short_flag() {\n   388→        let cli = Cli::parse_from([\"ralph\", \"init\", \"-n\"]);\n   389→        let Commands::Init(args) = cli.command else {\n   390→            panic!(\"expected init command\");\n   391→        };\n   392→\n   393→        assert_eq!(args.dir, std::path::PathBuf::from(\".ralph\"));\n   394→        assert!(args.dry_run);\n   395→    }\n   396→\n   397→    #[test]\n   398→    fn parses_run_with_role_backend_overrides() {\n   399→        let cli = Cli::parse_from([\n   400→            \"ralph\",\n   401→            \"run\",\n   402→            \"--planner-backend\",\n   403→            \"claude(opus)\",\n   404→            \"--implementer-backend\",\n   405→           