  .collect();\n   789\t    assert_eq!(\n   790\t        vec![\"plan_and_implement\", \"review\", \"apply_fixes\", \"final_review\"],\n   791\t        entered\n   792\t    );\n   793\t\n   794\t    let payload_count =\n   795\t        fs::read_dir(base_dir.join(\".ralph-burning/projects/qd-happy/history/payloads\"))\n   796\t            .unwrap()\n   797\t            .count();\n   798\t    let artifact_count =\n   799\t        fs::read_dir(base_dir.join(\".ralph-burning/projects/qd-happy/history/artifacts\"))\n   800\t            .unwrap()\n   801\t            .count();\n   802\t    assert_eq!(payload_count, 4);\n   803\t    assert_eq!(artifact_count, 4);\n   804\t}\n   805\t\n   806\t#[tokio::test]\n   807\tasync fn quick_dev_review_request_changes_restarts_from_apply_fixes() {\n   808\t    let tmp = tempdir().unwrap();\n   809\t    let base_dir = tmp.path();\n   810\t\n   811\t    setup_workspace(base_dir);\n   812\t    let pid = create_project_with_flow(base_dir, \"qd-remediation\", FlowPreset::QuickDev);\n   813\t\n   814\t    let adapter = RecordingAdapter::new(StubBackendAdapter::default().with_stage_payload_sequence(\n   815\t        StageId::Review,\n   816\t        vec![\n   817\t            request_changes_payload(&[\"fix the identified issues\"]),\n   818\t            approved_validation_payload(),\n   819\t        ],\n   820\t    ));\n   821\t    let adapter_handle = adapter.clone();\n   822\t    let agent_service = build_agent_service_with_adapter(adapter);\n   823\t    let config = EffectiveConfig::load(base_dir).unwrap();\n   824\t\n   825\t    let result = engine::execute_run(\n   826\t        &agent_service,\n   827\t        &FsRunSnapshotStore,\n   828\t        &FsRunSnapshotWriteStore,\n   829\t        &FsJournalStore,\n   830\t        &FsPayloadArtifactWriteStore,\n   831\t        &FsRuntimeLogWriteStore,\n   832\t        &FsAmendmentQueueStore,\n   833\t        base_dir,\n   834\t        &pid,\n   835\t        FlowPreset::QuickDev,\n   836\t        &config,\n   837\t    )\n   838\t    .await;\n   839\t\n   840\t    assert!(result.is_ok(), \"{result:?}\");\n   841\t\n   842\t    let events = FsJournalStore.read_journal(base_dir, &pid).unwrap();\n   843\t\n   844\t    // In quick_dev, the execution stage (apply_fixes) comes AFTER the trigger\n   845\t    // stage (review), so apply_fixes is entered once: only after the cycle\n   846\t    // advance, not before the review that triggered remediation.\n   847\t    assert_eq!(\n   848\t        stage_events(&events, JournalEventType::StageEntered, \"apply_fixes\").len(),\n   849\t        1\n   850\t    );\n   851\t\n   852\t    let cycle_advanced: Vec<_> = events\n   853\t        .iter()\n   854\t        .filter(|event| event.event_type == JournalEventType::CycleAdvanced)\n   855\t        .collect();\n   856\t    assert_eq!(cycle_advanced.len(), 1);\n   857\t    assert_eq!(cycle_advanced[0].details[\"resume_stage\"], \"apply_fixes\");\n   858\t\n   859\t    // apply_fixes is invoked once (after cycle advance) with remediation context\n   860\t    let apply_fixes_contexts = adapter_handle.contexts_for(StageId::ApplyFixes);\n   861\t    assert_eq!(apply_fixes_contexts.len(), 1);\n   862\t    assert_eq!(\n   863\t        apply_fixes_contexts[0][\"remediation\"][\"follow_up_or_amendments\"][0],\n   864\t        \"fix the identified issues\"\n   865\t    );\n   866\t}\n   867\t\n   868\t#[tokio::test]\n   869\tasync fn quick_dev_review_rejected_fails_run() {\n   870\t    let tmp = tempdir().unwrap();\n   871\t    let base_dir = tmp.path();\n   872\t\n   873\t    setup_workspace(base_dir);\n   874\t    let pid = create_project_with_flow(base_dir, \"qd-rejected\", FlowPreset::QuickDev);\n   875\t\n   876\t    let agent_service = build_agent_service_with_adapter(\n   877\t        StubBackendAdapter::default()\n   878\t            .with_stage_payload(StageId::Review, rejected_validation_payload()),\n   879\t    );\n   880\t    let config = EffectiveConfig::load(base_dir).unwrap();\n   881\t\n   882\t    let result = engine::execute_run(\n   883\t        &agent_service,\n   884\t        &FsRunSnapshotStore,\n   885\t        &FsRunSnapshotWriteStore,\n   886\t        &FsJournalStore,\n   887\t        &FsPayloadArtifactWriteStore,\n   888\t        &FsRuntimeLogWriteStore,\n   889\t        &FsAmendmentQueueStore,\n   890\t        base_dir,\n   891\t        &pid,\n   892\t        FlowPreset::QuickDev,\n   893\t        &config,\n   894\t    )\n   895\t    .await;\n   896\t\n   897\t    assert!(result.is_err());\n   898\t\n   899\t    let snapshot = FsRunSnapshotStore\n   900\t        .read_run_snapshot(base_dir, &pid)\n   901\t        .unwrap();\n   902\t    assert_eq!(snapshot.status, RunStatus::Failed);\n   903\t\n   904\t    let events = FsJournalStore.read_journal(base_dir, &pid).unwrap();\n   905\t    let run_failed = events\n   906\t        .iter()\n   907\t        .rev()\n   908\t        .find(|event| event.event_type == JournalEventType::RunFailed)\n   909\t        .expect(\"run_failed\");\n   910\t    assert_eq!(\n   911\t        run_failed.details[\"failure_class\"],\n   912\t        \"qa_review_outcome_failure\"\n   913\t    );\n   914\t}\n   915\t\n   916\t#[tokio::test]\n   917\tasync fn quick_dev_final_review_conditionally_approved_triggers_completion_round() {\n   918\t    let tmp = tempdir().unwrap();\n   919\t    let base_dir = tmp.path();\n   920\t\n   921\t    setup_workspace(base_dir);\n   922\t    let pid = create_project_with_flow(base_dir, \"qd-cr\", FlowPreset::QuickDev);\n   923\t\n   924\t    let agent_service = build_agent_service_with_adapter(\n   925\t        StubBackendAdapter::default().with_stage_payload_sequence(\n   926\t            StageId::FinalReview,\n   927\t            vec![\n   928\t                conditionally_approved_payload(&[\"polish the edge cases\"]),\n   929\t                approved_validation_payload(),\n   930\t            ],\n   931\t        ),\n   932\t    );\n   933\t    let config = EffectiveConfig::load(base_dir).unwrap();\n   934\t\n   935\t    let result = engine::execute_run(\n   936\t        &agent_service,\n   937\t        &FsRunSnapshotStore,\n   938\t        &FsRunSnapshotWriteStore,\n   939\t        &FsJournalStore,\n   940\t        &FsPayloadArtifactWriteStore,\n   941\t        &FsRuntimeLogWriteStore,\n   942\t        &FsAmendmentQueueStore,\n   943\t        base_dir,\n   944\t        &pid,\n   945\t        FlowPreset::QuickDev,\n   946\t        &config,\n   947\t    )\n   948\t    .await;\n   949\t\n   950\t    assert!(result.is_ok(), \"run should complete: {result:?}\");\n   951\t\n   952\t    let snapshot = FsRunSnapshotStore\n   953\t        .read_run_snapshot(base_dir, &pid)\n   954\t        .unwrap();\n   955\t    assert_eq!(snapshot.status, RunStatus::Completed);\n   956\t    assert_eq!(snapshot.completion_rounds, 2);\n   957\t    assert!(snapshot.amendment_queue.pending.is_empty());\n   958\t\n   959\t    let events = FsJournalStore.read_journal(base_dir, &pid).unwrap();\n   960\t    let round_events: Vec<_> = events\n   961\t        .iter()\n   962\t        .filter(|e| e.event_type == JournalEventType::CompletionRoundAdvanced)\n   963\t        .collect();\n   964\t    assert_eq!(round_events.len(), 1);\n   965\t\n   966\t    // Verify the run restarted at plan_and_implement\n   967\t    let plan_entries = stage_events(&events, JournalEventType::StageEntered, \"plan_and_implement\");\n   968\t    assert_eq!(plan_entries.len(), 2, \"plan_and_implement should run twice across completion rounds\");\n   969\t}\n   970\t\n   971\t#[tokio::test]\n   972\tasync fn resume_from_failed_quick_dev_run_skips_completed_stages() {\n   973\t    let tmp = tempdir().unwrap();\n   974\t    let base_dir = tmp.path();\n   975\t\n   976\t    setup_workspace(base_dir);\n   977\t    let pid = create_project_with_flow(base_dir, \"qd-resume\", FlowPreset::QuickDev);\n   978\t    let config = EffectiveConfig::load(base_dir).unwrap();\n   979\t\n   980\t    let failing_agent_service = build_agent_service_with_adapter(\n   981\t        StubBackendAdapter::default().with_transient_failure(StageId::Review, 3),\n   982\t    );\n   983\t    let first_result = engine::execute_run(\n   984\t        &failing_agent_service,\n   985\t        &FsRunSnapshotStore,\n   986\t        &FsRunSnapshotWriteStore,\n   987\t        &FsJournalStore,\n   988\t        &FsPayloadArtifactWriteStore,\n   989\t        &FsRuntimeLogWriteStore,\n   990\t        &FsAmendmentQueueStore,\n   991\t        base_dir,\n   992\t        &pid,\n   993\t        FlowPreset::QuickDev,\n   994\t        &config,\n   995\t    )\n   996\t    .await;\n   997\t    assert!(first_result.is_err());\n   998\t\n   999\t    let resume_agent_service = build_agent_service();\n  1000\t    let resume_result = engine::resume_run(\n  1001\t        &resume_agent_service,\n  1002\t        &FsRunSnapshotStore,\n  1003\t        &FsRunSnapshotWriteStore,\n  1004\t        &FsJournalStore,\n  1005\t        &FsArtifactStore,\n  1006\t        &FsPayloadArtifactWriteStore,\n  1007\t        &FsRuntimeLogWriteStore,\n  1008\t        &FsAmendmentQueueStore,\n  1009\t        base_dir,\n  1010\t        &pid,\n  1011\t        FlowPreset::QuickDev,\n  1012\t        &config,\n  1013\t    )\n  1014\t    .await;\n  1015\t    assert!(resume_result.is_ok(), \"{resume_result:?}\");\n  1016\t\n  1017\t    let snapshot = FsRunSnapshotStore\n  1018\t        .read_run_snapshot(base_dir, &pid)\n  1019\t        .unwrap();\n  1020\t    assert_eq!(snapshot.status, RunStatus::Completed);\n  1021\t\n  1022\t    let events = FsJournalStore.read_journal(base_dir, &pid).unwrap();\n  1023\t    assert_eq!(\n  1024\t        stage_events(&events, JournalEventType::StageEntered, \"plan_and_implement\").len(),\n  1025\t        1\n  1026\t    );\n  1027\t    assert_eq!(\n  1028\t        stage_events(&events, JournalEventType::StageEntered, \"review\").len(),\n  1029\t        4\n  1030\t    );\n  1031\t\n  1032\t    let run_resumed = events\n  1033\t        .iter()\n  1034\t        .find(|event| event.event_type == JournalEventType::RunResumed)\n  1035\t        .expect(\"run_resumed\");\n  1036\t    assert_eq!(run_resumed.details[\"resume_stage\"], \"review\");\n  1037\t}\n  1038\t\n  1039\t#[tokio::test]\n  1040\tasync fn quick_dev_preflight_failure_leaves_state_unchanged() {\n  1041\t    let tmp = tempdir().unwrap();\n  1042\t    let base_dir = tmp.path();\n  1043\t\n  1044\t    setup_workspace(base_dir);\n  1045\t    let pid = create_project_with_flow(base_dir, \"qd-preflight\", FlowPreset::QuickDev);\n  1046\t\n  1047\t    let agent_service = build_agent_service_with_adapter(\n  1048\t        StubBackendAdapter::default().unavailable(),\n  1049\t    );\n  1050\t    let config = EffectiveConfig::load(base_dir).unwrap();\n  1051\t\n  1052\t    let pre_snapshot = FsRunSnapshotStore\n  1053\t        .read_run_snapshot(base_dir, &pid)\n  1054\t        .unwrap();\n  1055\t    assert_eq!(pre_snapshot.status, RunStatus::NotStarted);\n  1056\t\n  1057\t    let result = engine::execute_run(\n  1058\t        &agent_service,\n  1059\t        &FsRunSnapshotStore,\n  1060\t        &FsRunSnapshotWriteStore,\n  1061\t        &FsJournalStore,\n  1062\t        &FsPayloadArtifactWriteStore,\n  1063\t        &FsRuntimeLogWriteStore,\n  1064\t        &FsAmendmentQueueStore,\n  1065\t        base_dir,\n","exit_code":0,"status":"completed"}}
