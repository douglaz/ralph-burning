ror) =\n   794\t                            amendment_queue_port.write_amendment(base_dir, project_id, amendment)\n   795\t                        {\n   796\t                            // Roll back already-written amendment files from this batch.\n   797\t                            for id in &written_ids {\n   798\t                                let _ =\n   799\t                                    amendment_queue_port.remove_amendment(base_dir, project_id, id);\n   800\t                            }\n   801\t                            // Failure invariant: if amendment persistence fails, no queue\n   802\t                            // entry becomes visible in run.json.\n   803\t                            return fail_run_result(\n   804\t                                &AppError::AmendmentQueueError {\n   805\t                                    details: format!(\n   806\t                                        \"failed to persist amendment '{}': {}\",\n   807\t                                        amendment.amendment_id, error\n   808\t                                    ),\n   809\t                                },\n   810\t                                stage_id,\n   811\t                                run_id,\n   812\t                                seq,\n   813\t                                snapshot,\n   814\t                                journal_store,\n   815\t                                run_snapshot_write,\n   816\t                                base_dir,\n   817\t                                project_id,\n   818\t                                origin,\n   819\t                            )\n   820\t                            .await;\n   821\t                        }\n   822\t                        written_ids.push(amendment.amendment_id.clone());\n   823\t                    }\n   824\t\n   825\t                    // Emit amendment_queued journal events.\n   826\t                    for amendment in &amendments {\n   827\t        