t dispatch_future => break result,\n   310\t                _ = heartbeat.tick() => {\n   311\t                    let _ = LeaseService::heartbeat(self.store, base_dir, &lease.lease_id);\n   312\t                }\n   313\t                _ = abort_poll.tick() => {\n   314\t                    let current = self.store.read_task(base_dir, &task.task_id)?;\n   315\t                    if current.status == TaskStatus::Aborted {\n   316\t                        task_cancel.cancel();\n   317\t                    }\n   318\t                }\n   319\t                _ = shutdown.cancelled() => {\n   320\t                    let _ = DaemonTaskService::mark_aborted(self.store, base_dir, &task.task_id);\n   321\t                    task_cancel.cancel();\n   322\t                }\n   323\t            }\n   324\t        }\n   325\t    }\n   326\t\n   327\t    async fn dispatch_in_worktree(\n   328\t        &self,\n   329\t        base_dir: &Path,\n   330\t        project_id: &ProjectId,\n   331\t        flow: FlowPreset,\n   332\t        run_status: RunStatus,\n   333\t        effective_config: &EffectiveConfig,\n   334\t        worktree_path: &Path,\n   335\t        cancellation_token: CancellationToken,\n   336\t    ) -> AppResult<()> {\n   337\t        let original_dir = std::env::current_dir()?;\n   338\t        std::env::set_current_dir(worktree_path)?;\n   339\t\n   340\t        let result = match run_status {\n   341\t            RunStatus::NotStarted => {\n   342\t                engine::execute_run_with_retry(\n   343\t                    self.agent_service,\n   344\t                    self.run_snapshot_read,\n   345\t                    self.run_snapshot_write,\n   346\t                    self.journal_store,\n   347\t                    self.artifact_write,\n   348\t                    self.log_write,\n   349\t                    self.amendment_queue,\n   350\t                    base_dir,\n   351\t                    project_id,\n   352\t                    flow,\n   353\t                    effective_config,\n   354\t                    &RetryPolicy::default_policy(),\n   355\t                    cancellation_token,\n   356\t                )\n   357\t                .await\n   358\t            }\n   359\t            RunStatus::Failed | RunStatus::Paused => {\n   360\t                engine::resume_run_with_retry(\n   361\t                    self.agent_service,\n   362\t                    self.run_snapshot_read,\n   363\t                    self.run_snapshot_write,\n   364\t                    self.journal_store,\n   365\t                    self.artifact_store,\n   366\t                    self.artifact_write,\n   367\t                    self.log_write,\n   368\t                    self.amendment_queue,\n   369\t                    base_dir,\n   370\t                    project_id,\n   371\t                    flow,\n   372\t                    effective_config,\n   373\t                    &RetryPolicy::default_policy(),\n   374\t                    cancellation_token,\n   375\t                )\n   376\t                .await\n   377\t            }\n   378\t            RunStatus::Running => Err(AppError::TaskStateTransitionInvalid {\n   379\t                task_id: project_id.to_string(),\n   380\t                from: \"run_running\".to_owned(),\n   381\t                to: \"daemon_dispatch\".to_owned(),\n   382\t            }),\n   383\t            RunStatus::Completed => Err(AppError::TaskStateTransitionInvalid {\n   384\t                task_id: project_id.to_string(),\n   385\t                from: \"run_completed\".to_owned(),\n   386\t                to: \"daemon_dispatch\".to_owned(),\n   387\t            }),\n   388\t        };\n   389\t\n   390\t        let reset_result = std::env::set_current_dir(original_dir);\n","exit_code":0,"status":"completed"}}
