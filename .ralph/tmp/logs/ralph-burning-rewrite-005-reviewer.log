   51\t        self.cancelled_invocations\n    52\t            .lock()\n    53\t            .expect(\"cancelled invocation lock poisoned\")\n    54\t            .clone()\n    55\t    }\n    56\t}\n    57\t\n    58\timpl AgentExecutionPort for StubBackendAdapter {\n    59\t    async fn check_capability(\n    60\t        &self,\n    61\t        backend: &crate::shared::domain::ResolvedBackendTarget,\n    62\t        stage_contract: &crate::contexts::workflow_composition::contracts::StageContract,\n    63\t    ) -> AppResult<()> {\n    64\t        if self.unsupported_stages.contains(&stage_contract.stage_id)\n    65\t            || !backend.supports_stage(stage_contract.stage_id)\n    66\t        {\n    67\t            return Err(AppError::CapabilityMismatch {\n    68\t                backend: backend.backend.family.to_string(),\n    69\t                stage_id: stage_contract.stage_id,\n    70\t                details: \"stub adapter does not support the requested stage\".to_owned(),\n    71\t            });\n    72\t        }\n    73\t\n    74\t        Ok(())\n    75\t    }\n    76\t\n    77\t    async fn check_availability(\n    78\t        &self,\n    79\t        backend: &crate::shared::domain::ResolvedBackendTarget,\n    80\t    ) -> AppResult<()> {\n    81\t        if self.available {\n    82\t            Ok(())\n    83\t        } else {\n    84\t            Err(AppError::BackendUnavailable {\n    85\t                backend: backend.backend.family.to_string(),\n    86\t                details: \"stub adapter configured as unavailable\".to_owned(),\n    87\t            })\n    88\t        }\n    89\t    }\n    90\t\n    91\t    async fn invoke(&self, request: InvocationRequest) -> AppResult<InvocationEnvelope> {\n    92\t        if request.cancellation_token.is_cancelled() {\n    93\t            return Err(AppError::InvocationCancelled {\n    94\t                backend: request.resolved_target.backend.family.to_string(),\n    95\t                stage_id: request.stage_contract.stage_id,\n    96\t            });\n    97\t        }\n    98\t\n    99\t        if self.delay > Duration::from_millis(0) {\n   100\t            tokio::select! {\n   101\t                _ = request.cancellation_token.cancelled() => {\n   102\t                    return Err(AppError::InvocationCancelled {\n   103\t                        backend: request.resolved_target.backend.family.to_string(),\n   104\t                        stage_id: request.stage_contract.stage_id,\n   105\t                    });\n   106\t                }\n   107\t                _ = tokio::time::sleep(self.delay) => {}\n   108\t            }\n   109\t        }\n   110\t\n   111\t        let payload = canned_payload_for_stage(request.stage_contract.stage_id);\n   112\t        let raw_output = serde_json::to_string_pretty(&payload)?;\n   113\t        let prompt_token_count = count_tokens(&request.payload.prompt);\n   114\t        let completion_token_count = count_tokens(&raw_output);\n   115\t        let prompt_tokens = Some(prompt_token_count);\n   116\t        let completion_tokens = Some(completion_token_count);\n   117\t        let total_tokens = Some(prompt_token_count + completion_token_count);\n   118\t\n   119\t        let supports_reuse =\n   120\t            request.role.allows_session_reuse() && request.resolved_target.supports_session_reuse();\n   121\t        let session_reused = supports_reuse\n   122\t            && matches!(request.session_policy, SessionPolicy::ReuseIfAllowed)\n   123\t            && request.prior_session.is_some();\n   124\t        let session_id = if supports_reuse {\n   125\t            request\n   126\t                .prior_session\n   127\t                .as_ref()\n   128\t                .map(|session| session.session_id.clone())\n   129\t                .filter(|_| session_reused)\n   130\t                .or_else(|| {\n   131\t                    Some(format!(\n   132\t                        \"stub-{}-{}\",\n   133\t           