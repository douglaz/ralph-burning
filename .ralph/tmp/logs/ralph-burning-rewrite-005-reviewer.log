d.clone(),\n   111\t            model: target.model.clone(),\n   112\t            stage_id: stage_contract.stage_id,\n   113\t            supported: false,\n   114\t            details: Some(details.into()),\n   115\t        }\n   116\t    }\n   117\t}\n   118\t\n   119\t#[derive(Debug, Clone, PartialEq, Eq)]\n   120\tpub enum RawOutputReference {\n   121\t    Inline(String),\n   122\t    Stored(PathBuf),\n   123\t}\n   124\t\n   125\timpl RawOutputReference {\n   126\t    pub fn inline_contents(&self) -> Option<&str> {\n   127\t        match self {\n   128\t            Self::Inline(contents) => Some(contents),\n   129\t            Self::Stored(_) => None,\n   130\t        }\n   131\t    }\n   132\t\n   133\t    pub fn stored_path(&self) -> Option<&Path> {\n   134\t        match self {\n   135\t            Self::Inline(_) => None,\n   136\t            Self::Stored(path) => Some(path.as_path()),\n   137\t        }\n   138\t    }\n   139\t}\n   140\t\n   141\t#[derive(Debug, Clone, Default, PartialEq, Eq)]\n   142\tpub struct TokenCounts {\n   143\t    pub prompt_tokens: Option<u32>,\n   144\t    pub completion_tokens: Option<u32>,\n   145\t    pub total_tokens: Option<u32>,\n   146\t}\n   147\t\n   148\t#[derive(Debug, Clone, PartialEq, Eq)]\n   149\tpub struct InvocationMetadata {\n   150\t    pub invocation_id: String,\n   151\t    pub duration: Duration,\n   152\t    pub token_counts: TokenCounts,\n   153\t    pub backend_used: BackendSpec,\n   154\t    pub model_used: ModelSpec,\n   155\t    pub attempt_number: u32,\n   156\t    pub session_id: Option<String>,\n   157\t    pub session_reused: bool,\n   158\t}\n   159\t\n   160\t#[derive(Debug, Clone, PartialEq)]\n   161\tpub struct InvocationEnvelope {\n   162\t    pub raw_output_reference: RawOutputReference,\n   163\t    pub parsed_payload: Value,\n   164\t    pub metadata: InvocationMetadata,\n   165\t    pub timestamp: DateTime<Utc>,\n   166\t}\n","exit_code":0,"status":"completed"}}
