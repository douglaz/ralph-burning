t <id>`\")]\n    38\t    NoActiveProject,\n    39\t    #[error(\n    40\t        \"project '{project_id}' was not found under .ralph-burning/projects/ or is missing project.toml\"\n    41\t    )]\n    42\t    ProjectNotFound { project_id: String },\n    43\t    #[error(\"editor '{editor}' failed{details}\")]\n    44\t    EditorFailed { editor: String, details: String },\n    45\t    #[error(\"project '{project_id}' already exists\")]\n    46\t    DuplicateProject { project_id: String },\n    47\t    #[error(\"corrupt record in {file}: {details}\")]\n    48\t    CorruptRecord { file: String, details: String },\n    49\t    #[error(\"invalid prompt file '{path}': {reason}\")]\n    50\t    InvalidPrompt { path: String, reason: String },\n    51\t    #[error(\"cannot delete project '{project_id}': it has an active run\")]\n    52\t    ActiveRunDelete { project_id: String },\n    53\t    #[error(\"journal sequence error: {details}\")]\n    54\t    JournalSequence { details: String },\n    55\t    #[error(\"{command} is not yet implemented\")]\n    56\t    NotYetImplemented { command: String },\n    57\t    #[error(\"backend '{backend}' is unavailable: {details}\")]\n    58\t    BackendUnavailable { backend: String, details: String },\n    59\t    #[error(\"backend '{backend}' cannot satisfy stage '{stage_id}': {details}\")]\n    60\t    CapabilityMismatch {\n    61\t        backend: String,\n    62\t        stage_id: StageId,\n    63\t        details: String,\n    64\t    },\n    65\t    #[error(\"backend invocation failed for stage '{stage_id}' via '{backend}': {details}\")]\n    66\t    InvocationFailed {\n    67\t        backend: String,\n    68\t        stage_id: StageId,\n    69\t        failure_class: FailureClass,\n    70\t        details: String,\n    71\t    },\n    72\t    #[error(\n    73\t        \"backend invocation timed out for stage '{stage_id}' via '{backend}' after {timeout_ms} ms\"\n    74\t    )]\n    75\t    InvocationTimeout {\n    76\t        backend: String,\n    77\t        stage_id: StageId,\n    78\t        timeout_ms: u64,\n    79\t    },\n    80\t    #[error(\"backend invocation cancelled for stage '{stage_id}' via '{backend}'\")]\n    81\t    InvocationCancelled { backend: String, stage_id: StageId },\n    82\t    #[error(transparent)]\n    83\t    Io(#[from] std::io::Error),\n    84\t    #[error(transparent)]\n    85\t    TomlDeserialize(#[from] toml::de::Error),\n    86\t    #[error(transparent)]\n    87\t    TomlSerialize(#[from] toml::ser::Error),\n    88\t    #[error(transparent)]\n    89\t    TomlEdit(#[from] toml_edit::TomlError),\n    90\t    #[error(transparent)]\n    91\t    SerdeJson(#[from] serde_json::Error),\n    92\t}\n    93\t\n    94\t/// Errors specific to stage contract evaluation.\n    95\t///\n    96\t/// Each variant maps to a distinct [`FailureClass`] for retry/terminal policy.\n    97\t#[derive(Debug, Error)]\n    98\tpub enum ContractError {\n    99\t    #[error(\"schema validation failed for stage '{stage_id}': {details}\")]\n   100\t    SchemaValidation { stage_id: StageId, details: String },\n   101\t\n   102\t    #[error(\"domain validation failed for stage '{stage_id}': {details}\")]\n   103\t    DomainValidation { stage_id: StageId, details: String },\n   104\t\n   105\t    #[error(\"rendering failed for stage '{stage_id}': {details}\")]\n   106\t    RenderError { stage_id: StageId, details: String },\n   107\t\n   108\t    #[error(\"non-passing QA/review outcome for stage '{stage_id}': {outcome}\")]\n   109\t    QaReviewOutcome { stage_id: StageId, outcome: String },\n   110\t}\n   111\t\n   112\timpl ContractError {\n   113\t    pub fn failure_class(&self) -> FailureClass {\n   114\t        match self {\n   115\t            Self::SchemaValidation { .. } => FailureClass::SchemaValidationFailure,\n   116\t            Self::DomainValidation { .. } | Self::RenderError { .. } => {\n   117\t                FailureClass::DomainValidationFailure\n   118\t            }\n   119\t            Self::QaReviewOutcome { .. } => FailureClass::QaReviewOutcomeFailure,\n   120\t        }\n   121\t    }\n   122\t\n   123\t    pub fn stage_id(&self) -> StageId {\n   124\t        match self {\n   125\t            Self::SchemaValidation { stage_id, .. }\n   126\t            | Self::DomainValidation { stage_id, .. }\n   127\t            | Self::RenderError { stage_id, .. }\n   128\t            | Self::QaReviewOutcome { stage_id, .. } => *stage_id,\n   129\t        }\n   130\t    }\n   131\t}\n   132\t\n   133\timpl AppError {\n   134\t    pub fn failure_class(&self) -> Option<FailureClass> {\n   135\t        match self {\n   136\t            Self::BackendUnavailable { .. } => Some(FailureClass::TransportFailure),\n   137\t            Self::CapabilityMismatch { .. } => Some(FailureClass::DomainValidationFailure),\n   138\t            Self::InvocationFailed { failure_class, .. } => Some(*failure_class),\n   139\t            Self::InvocationTimeout { .. } => Some(FailureClass::Timeout),\n   140\t            Self::InvocationCancelled { .. } => Some(FailureClass::Cancellation),\n   141\t            _ => None,\n   142\t        }\n   143\t    }\n   144\t}\n","exit_code":0,"status":"completed"}}
