pub fn load_reusable_session(\n    57\t        &self,\n    58\t        project_root: &Path,\n    59\t        role: BackendRole,\n    60\t        target: &ResolvedBackendTarget,\n    61\t        session_policy: SessionPolicy,\n    62\t    ) -> AppResult<Option<SessionMetadata>> {\n    63\t        if !matches!(session_policy, SessionPolicy::ReuseIfAllowed)\n    64\t            || !role.allows_session_reuse()\n    65\t            || !target.supports_session_reuse()\n    66\t        {\n    67\t            return Ok(None);\n    68\t        }\n    69\t\n    70\t        let sessions = self.store.load_sessions(project_root)?;\n    71\t        Ok(sessions\n    72\t            .sessions\n    73\t            .into_iter()\n    74\t            .find(|session| session_matches(session, role, target)))\n    75\t    }\n    76\t\n    77\t    pub fn record_session(\n    78\t        &self,\n    79\t        project_root: &Path,\n    80\t        role: BackendRole,\n    81\t        target: &ResolvedBackendTarget,\n    82\t        session_id: Option<&str>,\n    83\t        timestamp: DateTime<Utc>,\n    84\t    ) -> AppResult<()> {\n    85\t        if !role.allows_session_reuse() || !target.supports_session_reuse() {\n    86\t            return Ok(());\n    87\t        }\n    88\t\n    89\t        let Some(session_id) = session_id else {\n    90\t            return Ok(());\n    91\t        };\n    92\t\n    93\t        let mut sessions = self.store.load_sessions(project_root)?;\n    94\t        if let Some(existing) = sessions\n    95\t            .sessions\n    96\t            .iter_mut()\n    97\t            .find(|session| session_matches(session, role, target))\n    98\t        {\n    99\t            existing.session_id = session_id.to_owned();\n   100\t            existing.last_used_at = timestamp;\n   101\t            existing.invocation_count += 1;\n   102\t        } else {\n   103\t            sessions.sessions.push(SessionMetadata {\n   104\t                role,\n   105\t                backend_family: target.backend.family,\n   106\t                model_id: target.model.model_id.clone(),\n   107\t                session_id: session_id.to_owned(),\n   108\t                created_at: timestamp,\n   109\t                last_used_at: timestamp,\n   110\t                invocation_count: 1,\n   111\t            });\n   112\t        }\n   113\t\n   114\t        self.store.save_sessions(project_root, &sessions)\n   115\t    }\n   116\t}\n   117\t\n   118\tfn session_matches(\n   119\t    session: &SessionMetadata,\n   120\t    role: BackendRole,\n   121\t    target: &ResolvedBackendTarget,\n   122\t) -> bool {\n   123\t    session.role == role\n   124\t        && session.backend_family == target.backend.family\n   125\t        && session.model_id == target.model.model_id\n   126\t}\n","exit_code":0,"status":"completed"}}
