{"type":"item.completed","item":{"id":"item_47","type":"command_execution","command":"/run/current-system/sw/bin/bash -lc \"nl -ba src/contexts/agent_execution/service.rs | sed -n '1,320p'\"","aggregated_output":"     1\tuse std::path::Path;\n     2\tuse std::time::Instant;\n     3\t\n     4\tuse chrono::Utc;\n     5\tuse serde_json::Value;\n     6\t\n     7\tuse crate::contexts::agent_execution::model::{\n     8\t    CapabilityCheck, InvocationEnvelope, InvocationRequest, RawOutputReference,\n     9\t};\n    10\tuse crate::contexts::agent_execution::session::{SessionManager, SessionStorePort};\n    11\tuse crate::contexts::workflow_composition::contracts::StageContract;\n    12\tuse crate::contexts::workspace_governance::EffectiveConfig;\n    13\tuse crate::shared::domain::{\n    14\t    BackendFamily, BackendRole, BackendSpec, FailureClass, ModelSpec, ResolvedBackendTarget,\n    15\t};\n    16\tuse crate::shared::error::{AppError, AppResult, ContractError};\n    17\t\n    18\t#[derive(Debug, Clone, Default, PartialEq, Eq)]\n    19\tpub struct BackendSelectionConfig {\n    20\t    pub backend_family: Option<BackendFamily>,\n    21\t    pub model_id: Option<String>,\n    22\t}\n    23\t\n    24\timpl BackendSelectionConfig {\n    25\t    pub fn from_effective_config(config: &EffectiveConfig) -> AppResult<Self> {\n    26\t        Ok(Self {\n    27\t            backend_family: config\n    28\t                .default_backend()\n    29\t                .map(|value| parse_backend_family(\"default_backend\", value))\n    30\t                .transpose()?,\n    31\t            model_id: config.default_model().map(|value| value.to_owned()),\n    32\t        })\n    33\t    }\n    34\t}\n    35\t\n    36\t#[derive(Debug, Clone, Default)]\n    37\tpub struct BackendResolver;\n    38\t\n    39\timpl BackendResolver {\n    40\t    pub fn new() -> Self {\n    41\t        Self\n    42\t    }\n    43\t\n    44\t    pub fn resolve(\n    45\t        &self,\n    46\t        role: BackendRole,\n    47\t        explicit_model_override: Option<ModelSpec>,\n    48\t        project_config: Option<&BackendSelectionConfig>,\n    49\t        workspace_defaults: Option<&BackendSelectionConfig>,\n    50\t    ) -> AppResult<ResolvedBackendTarget> {\n    51\t        let mut target = role.default_target();\n    52\t\n    53\t        if let Some(workspace_defaults) = workspace_defaults {\n    54\t            Self::apply_selection(&mut target, workspace_defaults);\n    55\t        }\n    56\t        if let Some(project_config) = project_config {\n    57\t            Self::apply_selection(&mut target, project_config);\n    58\t        }\n    59\t        if let Some(model_override) = explicit_model_override {\n    60\t            Self::apply_model_override(&mut target, model_override);\n    61\t        }\n    62\t\n    63\t        Ok(target)\n    64\t    }\n    65\t\n    66\t    pub fn resolve_from_effective_config(\n    67\t        &self,\n    68\t        role: BackendRole,\n    69\t        explicit_model_override: Option<ModelSpec>,\n    70\t        project_config: Option<&BackendSelectionConfig>,\n    71\t        effective_config: &EffectiveConfig,\n    72\t    ) -> AppResult<ResolvedBackendTarget> {\n    73\t        let workspace_defaults = BackendSelectionConfig::from_effective_config(effective_config)?;\n    74\t        self.resolve(\n    75\t            role,\n    76\t            explicit_model_override,\n    77\t            project_config,\n    78\t            Some(&workspace_defaults),\n    79\t        )\n    80\t    }\n    81\t\n    82\t    fn apply_selection(target: &mut ResolvedBackendTarget, selection: &BackendSelectionConfig) {\n    83\t        if let Some(backend_family) = selection.backend_family {\n    84\t            target.backend = BackendSpec::from_family(backend_family);\n    85\t            if target.model.backend_family != backend_family {\n    86\t                target.model = ModelSpec::default_for_backend(backend_family);\n    87\t            }\n    88\t        }\n    89\t\n    90\t        if let Some(model_id) = &selection.model_id {\n    91\t            target.model = ModelSpec::new(target.backend.family, model_id.clone());\n    92\t        }\n    93\t    }\n    94\t\n    95\t    fn apply_model_override(target: &mut ResolvedBackendTarget, model_override: ModelSpec) {\n    96\t        if target.backend.family != model_override.backend_family {\n    97\t            target.backend = BackendSpec::from_family(model_override.backend_family);\n    98\t        }\n    99\t        target.model = model_override;\n   100\t    }\n   101\t}\n   102\t\n   103\t#[allow(async_fn_in_trait)]\n   104\tpub trait AgentExecutionPort {\n   105\t    async fn check_capability(\n   106\t        &self,\n   107\t        backend: &ResolvedBackendTarget,\n   108\t        stage_contract: &StageContract,\n   109\t    ) -> AppResult<()>;\n   110\t\n   111\t    async fn check_availability(&self, backend: &ResolvedBackendTarget) -> AppResult<()>;\n   112\t\n   113\t    async fn invoke(&self, request: InvocationRequest) -> AppResult<InvocationEnvelope>;\n   114\t\n   115\t    async fn cancel(&self, invocation_id: &str) -> AppResult<()>;\n   116\t}\n   117\t\n   118\tpub trait RawOutputPort {\n   119\t    fn persist_raw_output(\n   120\t        &self,\n   121\t        project_root: &Path,\n   122\t        invocation_id: &str,\n   123\t        contents: &str,\n   124\t    ) -> AppResult<RawOutputReference>;\n   125\t}\n   126\t\n   127\tpub struct AgentExecutionService<A, R, S> {\n   128\t    adapter: A,\n   129\t    raw_output_store: R,\n   130\t    session_manager: SessionManager<S>,\n   131\t    resolver: BackendResolver,\n   132\t}\n   133\t\n   134\timpl<A, R, S> AgentExecutionService<A, R, S> {\n   135\t    pub fn new(adapter: A, raw_output_store: R, session_store: S) -> Self {\n   136\t        Self {\n   137\t            adapter,\n   138\t            raw_output_store,\n   139\t            session_manager: SessionManager::new(session_store),\n   140\t            resolver: BackendResolver::new(),\n   141\t        }\n   142\t    }\n   143\t\n   144\t    pub fn resolver(&self) -> &BackendResolver {\n   145\t        &self.resolver\n   146\t    }\n   147\t}\n   148\t\n   149\timpl<A, R, S> AgentExecutionService<A, R, S>\n   150\twhere\n   151\t    A: AgentExecutionPort,\n   152\t    R: RawOutputPort,\n   153\t    S: SessionStorePort,\n   154\t{\n   155\t    pub async fn invoke(&self, request: InvocationRequest) -> AppResult<InvocationEnvelope> {\n   156\t        let _ = CapabilityCheck::success(&request.resolved_target, request.stage_contract);\n   157\t\n   158\t        self.adapter\n   159\t            .check_capability(&request.resolved_target, &request.stage_contract)\n   160\t            .await\n   161\t            .map_err(|error| map_capability_error(error, &request))?;\n   162\t\n   163\t        self.adapter\n   164\t            .check_availability(&request.resolved_target)\n   165\t            .await\n   166\t            .map_err(|error| map_availability_error(error, &request))?;\n   167\t\n   168\t        let prior_session = self.session_manager.load_reusable_session(\n   169\t            &request.project_root,\n   170\t            request.role,\n   171\t            &request.resolved_target,\n   172\t            request.session_policy,\n   173\t        )?;\n   174\t\n   175\t        let mut request = request;\n   176\t        request.prior_session = prior_session;\n   177\t\n   178\t        if request.cancellation_token.is_cancelled() {\n   179\t            return Err(AppError::InvocationCancelled {\n   180\t                backend: request.resolved_target.backend.family.to_string(),\n   181\t                stage_id: request.stage_contract.stage_id,\n   182\t            });\n   183\t        }\n   184\t\n   185\t        let started_at = Utc::now();\n   186\t        let started = Instant::now();\n   187\t        let invocation_id = request.invocation_id.clone();\n   188\t        let timeout_ms = request.timeout.as_millis().min(u64::MAX as u128) as u64;\n   189\t\n   190\t        let invoke_future = self.adapter.invoke(request.clone());\n   191\t        tokio::pin!(invoke_future);\n   192\t\n   193\t        let mut envelope = tokio::select! {\n   194\t            _ = request.cancellation_token.cancelled() => {\n   195\t                let _ = self.adapter.cancel(&invocation_id).await;\n   196\t                return Err(AppError::InvocationCancelled {\n   197\t                    backend: request.resolved_target.backend.family.to_string(),\n   198\t                    stage_id: request.stage_contract.stage_id,\n   199\t                });\n   200\t            }\n   201\t            result = tokio::time::timeout(request.timeout, &mut invoke_future) => {\n   202\t                match result {\n   203\t                    Ok(result) => result.map_err(|error| map_invoke_error(error, &request))?,\n   204\t                    Err(_) => {\n   205\t                        let _ = self.adapter.cancel(&invocation_id).await;\n   206\t                        return Err(AppError::InvocationTimeout {\n   207\t                            backend: request.resolved_target.backend.family.to_string(),\n   208\t                            stage_id: request.stage_contract.stage_id,\n   209\t                            timeout_ms,\n   210\t                        });\n   211\t                    }\n   212\t                }\n   213\t            }\n   214\t        };\n   215\t\n   216\t        let duration = started.elapsed();\n   217\t        envelope.metadata.duration = duration;\n   218\t        envelope.metadata.attempt_number = request.attempt_number;\n   219\t        envelope.metadata.backend_used = request.resolved_target.backend.clone();\n   220\t        envelope.metadata.model_used = request.resolved_target.model.clone();\n   221\t        envelope.timestamp = Utc::now();\n   222\t\n   223\t        let raw_output = extract_raw_output(&envelope.raw_output_reference)?;\n   224\t        let stored_reference = self.raw_output_store.persist_raw_output(\n   225\t            &request.project_root,\n   226\t            &request.invocation_id,\n   227\t            &raw_output,\n   228\t        )?;\n   229\t\n   230\t        let parsed_payload =\n   231\t            extract_structured_payload(&request, envelope.parsed_payload, &raw_output)?;\n   232\t\n   233\t        request\n   234\t            .stage_contract\n   235\t            .evaluate(&parsed_payload)\n   236\t            .map_err(|error| map_contract_error(error, &request))?;\n   237\t\n   238\t        envelope.raw_output_reference = stored_reference;\n   239\t        envelope.parsed_payload = parsed_payload;\n   240\t        envelope.timestamp = started_at + duration;\n   241\t\n   242\t        self.session_manager.record_session(\n   243\t            &request.project_root,\n   244\t            request.role,\n   245\t            &request.resolved_target,\n   246\t            envelope.metadata.session_id.as_deref(),\n   247\t            envelope.timestamp,\n   248\t        )?;\n   249\t\n   250\t        Ok(envelope)\n   251\t    }\n   252\t}\n   253\t\n   254\tfn parse_backend_family(key: &str, value: &str) -> AppResult<BackendFamily> {\n   255\t    match value {\n   256\t        \"claude\" => Ok(BackendFamily::Claude),\n   257\t        \"codex\" => Ok(BackendFamily::Codex),\n   258\t        \"openrouter\" => Ok(BackendFamily::OpenRouter),\n   259\t        \"stub\" => Ok(BackendFamily::Stub),\n   260\t        _ => Err(AppError::InvalidConfigValue {\n   261\t            key: key.to_owned(),\n   262\t            value: value.to_owned(),\n   263\t            reason: \"expected one of claude, codex, openrouter, stub\".to_owned(),\n   264\t        }),\n   265\t    }\n   266\t}\n   267\t\n   268\tfn extract_raw_output(raw_output_reference: &RawOutputReference) -> AppResult<String> {\n   269\t    match raw_output_reference {\n   270\t        RawOutputReference::Inline(contents) => Ok(contents.clone()),\n   271\t        RawOutputReference::Stored(path) => std::fs::read_to_string(path).map_err(AppError::from),\n   272\t    }\n   273\t}\n   274\t\n   275\tfn extract_structured_payload(\n   276\t    request: &InvocationRequest,\n   277\t    parsed_payload: Value,\n   278\t    raw_output: &str,\n   279\t) -> AppResult<Value> {\n   280\t    if !parsed_payload.is_null() {\n   281\t        return Ok(parsed_payload);\n   282\t    }\n   283\t\n   284\t    serde_json::from_str(raw_output).map_err(|error| AppError::InvocationFailed {\n   285\t        backend: request.resolved_target.backend.family.to_string(),\n   286\t        stage_id: request.stage_contract.stage_id,\n   287\t        failure_class: FailureClass::SchemaValidationFailure,\n   288\t        details: error.to_string(),\n   289\t    })\n   290\t}\n   291\t\n   292\tfn map_capability_error(error: AppError, request: &InvocationRequest) -> AppError {\n   293\t    match error {\n   294\t        AppError::CapabilityMismatch { .. } => error,\n   295\t        other => AppError::CapabilityMismatch {\n   296\t            backend: request.resolved_target.backend.family.to_string(),\n   297\t            stage_id: request.stage_contract.stage_id,\n   298\t            details: other.to_string(),\n   299\t        },\n   300\t    }\n   301\t}\n   302\t\n   303\tfn map_availability_error(error: AppError, request: &InvocationRequest) -> AppError {\n   304\t    match error {\n   305\t        AppError::BackendUnavailable { .. } => error,\n   306\t        other => AppError::BackendUnavailable {\n   307\t            backend: request.resolved_target.backend.family.to_string(),\n   308\t            details: other.to_string(),\n   309\t        },\n   310\t    }\n   311\t}\n   312\t\n   313\tfn map_invoke_error(error: AppError, request: &InvocationRequest) -> AppError {\n   314\t    match error {\n   315\t        AppError::InvocationFailed { .. }\n   316\t        | AppError::InvocationTimeout { .. }\n   317\t        | AppError::InvocationCancelled { .. } => error,\n   318\t        other => AppError::InvocationFailed {\n   319\t            backend: request.resolved_target.backend.family.to_string(),\n   320\t            stage_id: request.stage_contract.stage_id,\n","exit_code":0,"status":"completed"}}
