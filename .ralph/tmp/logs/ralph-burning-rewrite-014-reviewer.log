{"type":"item.completed","item":{"id":"item_62","type":"command_execution","command":"/run/current-system/sw/bin/bash -lc \"nl -ba /root/new-ralph-burning/ralph-burning-rewrite/src/contexts/conformance_spec/cutover_guard.rs | sed -n '1,220p'\"","aggregated_output":"     1\tuse std::path::Path;\n     2\t\n     3\tuse crate::shared::error::{AppError, AppResult};\n     4\t\n     5\t/// Legacy runtime patterns that must not appear in production source code.\n     6\tconst LEGACY_PATTERNS: &[&str] = &[\n     7\t    \".ralph/\",\n     8\t    \"multibackend-orchestration\",\n     9\t    \"multibackend_orchestration\",\n    10\t];\n    11\t\n    12\t/// Scans production source code under `src/` for legacy runtime references.\n    13\t///\n    14\t/// Returns an error on the first violation found, including file path,\n    15\t/// line number, and the offending pattern.\n    16\tpub fn check_cutover_guard(src_dir: &Path) -> AppResult<()> {\n    17\t    if !src_dir.is_dir() {\n    18\t        return Err(AppError::ConformanceDiscoveryFailed {\n    19\t            details: format!(\"source directory not found: {}\", src_dir.display()),\n    20\t        });\n    21\t    }\n    22\t\n    23\t    scan_directory(src_dir)\n    24\t}\n    25\t\n    26\tfn scan_directory(dir: &Path) -> AppResult<()> {\n    27\t    let mut entries: Vec<_> = std::fs::read_dir(dir)\n    28\t        .map_err(|e| AppError::ConformanceDiscoveryFailed {\n    29\t            details: format!(\"cannot read directory {}: {e}\", dir.display()),\n    30\t        })?\n    31\t        .filter_map(|e| e.ok())\n    32\t        .collect();\n    33\t\n    34\t    entries.sort_by_key(|e| e.path());\n    35\t\n    36\t    for entry in entries {\n    37\t        let path = entry.path();\n    38\t        if path.is_dir() {\n    39\t            // Skip the conformance_spec context itself — it legitimately references\n    40\t            // legacy patterns for the purpose of the cutover guard.\n    41\t            let dir_name = path.file_name().unwrap_or_default().to_string_lossy();\n    42\t            if dir_name == \"conformance_spec\" {\n    43\t                continue;\n    44\t            }\n    45\t            scan_directory(&path)?;\n    46\t        } else if path.extension().map_or(false, |ext| ext == \"rs\") {\n    47\t            scan_file(&path)?;\n    48\t        }\n    49\t    }\n    50\t\n    51\t    Ok(())\n    52\t}\n    53\t\n    54\tfn scan_file(path: &Path) -> AppResult<()> {\n    55\t    let content = std::fs::read_to_string(path).map_err(|e| {\n    56\t        AppError::ConformanceDiscoveryFailed {\n    57\t            details: format!(\"cannot read {}: {e}\", path.display()),\n    58\t        }\n    59\t    })?;\n    60\t\n    61\t    let file_display = path.display().to_string();\n    62\t\n    63\t    for (line_idx, line) in content.lines().enumerate() {\n    64\t        let line_number = line_idx + 1;\n    65\t        let trimmed = line.trim();\n    66\t\n    67\t        // Skip comments — legacy references in comments are informational only\n    68\t        if trimmed.starts_with(\"//\") {\n    69\t            continue;\n    70\t        }\n    71\t\n    72\t        for pattern in LEGACY_PATTERNS {\n    73\t            if line.contains(pattern) {\n    74\t                return Err(AppError::ConformanceCutoverViolation {\n    75\t                    file: file_display,\n    76\t                    line: line_number,\n    77\t                    pattern: pattern.to_string(),\n    78\t                });\n    79\t            }\n    80\t        }\n    81\t    }\n    82\t\n    83\t    Ok(())\n    84\t}\n","exit_code":0,"status":"completed"}}
