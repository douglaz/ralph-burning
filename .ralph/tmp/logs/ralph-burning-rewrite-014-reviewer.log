{"type":"item.completed","item":{"id":"item_57","type":"command_execution","command":"/run/current-system/sw/bin/bash -lc \"nl -ba ralph-burning-rewrite/tests/cli.rs | sed -n '3870,4010p'\"","aggregated_output":"  3870\t// Conformance List / Run CLI surface tests\n  3871\t// ===========================================================================\n  3872\t\n  3873\t#[test]\n  3874\tfn conformance_list_discovers_all_scenarios() {\n  3875\t    let output = Command::new(binary())\n  3876\t        .args([\"conformance\", \"list\"])\n  3877\t        .output()\n  3878\t        .expect(\"run conformance list\");\n  3879\t\n  3880\t    assert!(\n  3881\t        output.status.success(),\n  3882\t        \"conformance list should succeed: {}\",\n  3883\t        String::from_utf8_lossy(&output.stderr)\n  3884\t    );\n  3885\t\n  3886\t    let stdout = String::from_utf8_lossy(&output.stdout);\n  3887\t    // Should print a table header\n  3888\t    assert!(stdout.contains(\"SCENARIO ID\"));\n  3889\t    assert!(stdout.contains(\"FEATURE\"));\n  3890\t    // Should discover scenarios from checked-in feature files\n  3891\t    assert!(stdout.contains(\"Total:\"));\n  3892\t    // Should include known scenario IDs\n  3893\t    assert!(stdout.contains(\"workspace-init-fresh\"));\n  3894\t    assert!(stdout.contains(\"SC-START-001\"));\n  3895\t}\n  3896\t\n  3897\t#[test]\n  3898\tfn conformance_run_with_valid_filter_executes_one_scenario() {\n  3899\t    let output = Command::new(binary())\n  3900\t        .args([\"conformance\", \"run\", \"--filter\", \"flow-list-all-presets\"])\n  3901\t        .output()\n  3902\t        .expect(\"run conformance run --filter\");\n  3903\t\n  3904\t    assert!(\n  3905\t        output.status.success(),\n  3906\t        \"conformance run --filter should succeed: {}\",\n  3907\t        String::from_utf8_lossy(&output.stderr)\n  3908\t    );\n  3909\t\n  3910\t    let stderr = String::from_utf8_lossy(&output.stderr);\n  3911\t    assert!(stderr.contains(\"flow-list-all-presets\"));\n  3912\t    assert!(stderr.contains(\"PASS\"));\n  3913\t    assert!(stderr.contains(\"Selected:  1\"));\n  3914\t    assert!(stderr.contains(\"Passed:    1\"));\n  3915\t}\n  3916\t\n  3917\t#[test]\n  3918\tfn conformance_run_with_unknown_filter_exits_non_zero() {\n  3919\t    let output = Command::new(binary())\n  3920\t        .args([\"conformance\", \"run\", \"--filter\", \"nonexistent-scenario-id\"])\n  3921\t        .output()\n  3922\t        .expect(\"run conformance run --filter unknown\");\n  3923\t\n  3924\t    assert!(\n  3925\t        !output.status.success(),\n  3926\t        \"conformance run with unknown filter should fail\"\n  3927\t    );\n  3928\t\n  3929\t    let stderr = String::from_utf8_lossy(&output.stderr);\n  3930\t    assert!(stderr.contains(\"nonexistent-scenario-id\"));\n  3931\t}\n  3932\t\n  3933\t#[test]\n  3934\tfn conformance_list_validates_no_duplicate_ids() {\n  3935\t    // The checked-in corpus has no duplicates, so conformance list should succeed.\n  3936\t    // The duplicate-ID detection logic is exercised by unit tests with synthetic data.\n  3937\t    let output = Command::new(binary())\n  3938\t        .args([\"conformance\", \"list\"])\n  3939\t        .output()\n  3940\t        .expect(\"run conformance list\");\n  3941\t\n  3942\t    assert!(\n  3943\t        output.status.success(),\n  3944\t        \"conformance list should succeed when no duplicates: {}\",\n  3945\t        String::from_utf8_lossy(&output.stderr)\n  3946\t    );\n  3947\t\n  3948\t    let stdout = String::from_utf8_lossy(&output.stdout);\n  3949\t    // Verify it discovered a meaningful number of scenarios\n  3950\t    assert!(\n  3951\t        stdout.contains(\"Total:\"),\n  3952\t        \"output should include a total count\"\n  3953\t    );\n  3954\t}\n  3955\t\n  3956\t#[test]\n  3957\tfn conformance_run_fail_fast_reports_summary_once() {\n  3958\t    // Run a single scenario that passes - verify the summary output format.\n  3959\t    // Fail-fast with actual failures is tested at the unit level.\n  3960\t    let output = Command::new(binary())\n  3961\t        .args([\"conformance\", \"run\", \"--filter\", \"workspace-init-fresh\"])\n  3962\t        .output()\n  3963\t        .expect(\"run conformance with filter\");\n  3964\t\n  3965\t    assert!(\n  3966\t        output.status.success(),\n  3967\t        \"filtered conformance run should pass: {}\",\n  3968\t        String::from_utf8_lossy(&output.stderr)\n  3969\t    );\n  3970\t\n  3971\t    let stderr = String::from_utf8_lossy(&output.stderr);\n  3972\t    assert!(stderr.contains(\"Selected:  1\"));\n  3973\t    assert!(stderr.contains(\"Passed:    1\"));\n  3974\t    assert!(stderr.contains(\"Failed:    0\"));\n  3975\t    assert!(stderr.contains(\"Not run:   0\"));\n  3976\t    // Verify no double-reporting: the summary appears exactly once\n  3977\t    assert_eq!(\n  3978\t        stderr.matches(\"Conformance Summary\").count(),\n  3979\t        1,\n  3980\t        \"summary should be printed exactly once\"\n  3981\t    );\n  3982\t}\n  3983\t\n  3984\t#[test]\n  3985\tfn conformance_run_failure_exits_non_zero_with_single_report() {\n  3986\t    // Run a scenario that will fail (inject invoke failure via env var).\n  3987\t    // This tests the fail-fast exit and verifies the scenario failure is reported once.\n  3988\t    let output = Command::new(binary())\n  3989\t        .args([\"conformance\", \"run\", \"--filter\", \"SC-START-012\"])\n  3990\t        .output()\n  3991\t        .expect(\"run conformance with failing scenario\");\n  3992\t\n  3993\t    // SC-START-012 internally injects a failure, so when run via conformance runner\n  3994\t    // it should succeed (the scenario tests that failure is handled correctly).\n  3995\t    // However, we can test that a filtered unknown scenario correctly exits non-zero\n  3996\t    // and verify the fail-fast output structure.\n  3997\t    // The actual fail-fast behavior with real failures is tested in the unit suite.\n  3998\t    let stderr = String::from_utf8_lossy(&output.stderr);\n  3999\t    assert!(\n  4000\t        stderr.contains(\"Conformance Summary\"),\n  4001\t        \"output should include summary\"\n  4002\t    );\n  4003\t}\n","exit_code":0,"status":"completed"}}
