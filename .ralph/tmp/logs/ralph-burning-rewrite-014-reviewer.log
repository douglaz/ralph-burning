\");\n    38\t    let sc_start = scenarios.iter().find(|s| s.id == \"SC-START-001\");\n    39\t    assert!(sc_start.is_some(), \"SC-START-001 should be discovered\");\n    40\t    let meta = sc_start.unwrap();\n    41\t    assert_eq!(meta.id_source, IdSource::Comment);\n    42\t    assert_eq!(meta.kind, ScenarioKind::Scenario);\n    43\t}\n    44\t\n    45\t#[test]\n    46\tfn discover_scenarios_extracts_tag_ids() {\n    47\t    let scenarios = catalog::discover_scenarios().expect(\"discover\");\n    48\t    let ws_init = scenarios.iter().find(|s| s.id == \"workspace-init-fresh\");\n    49\t    assert!(ws_init.is_some(), \"workspace-init-fresh should be discovered\");\n    50\t    let meta = ws_init.unwrap();\n    51\t    assert_eq!(meta.id_source, IdSource::Tag);\n    52\t    assert_eq!(meta.kind, ScenarioKind::Scenario);\n    53\t}\n    54\t\n    55\t#[test]\n    56\tfn discover_scenarios_handles_scenario_outlines() {\n    57\t    let scenarios = catalog::discover_scenarios().expect(\"discover\");\n    58\t    let outline = scenarios.iter().find(|s| s.id == \"flow-show-each-preset\");\n    59\t    assert!(\n    60\t        outline.is_some(),\n    61\t        \"flow-show-each-preset should be discovered\"\n    62\t    );\n    63\t    let meta = outline.unwrap();\n    64\t    assert_eq!(meta.kind, ScenarioKind::ScenarioOutline);\n    65\t}\n    66\t\n    67\t// ===========================================================================\n    68\t// ID validation\n    69\t// ===========================================================================\n    70\t\n    71\t#[test]\n    72\tfn validate_ids_accepts_unique_ids() {\n    73\t    let scenarios = catalog::discover_scenarios().expect(\"discover\");\n    74\t    assert!(catalog::validate_ids(&scenarios).is_ok());\n    75\t}\n    76\t\n    77\t#[test]\n    78\tfn validate_ids_rejects_duplicates() {\n    79\t    let scenarios = vec![\n    80\t        ScenarioMeta {\n    81\t            id: \"DUP-001\".to_owned(),\n  