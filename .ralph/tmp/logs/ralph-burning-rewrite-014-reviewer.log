t            s.source_file,\n    49\t            s.source_line,\n    50\t        );\n    51\t    }\n    52\t\n    53\t    println!();\n    54\t    println!(\"Total: {} scenarios\", scenarios.len());\n    55\t\n    56\t    Ok(())\n    57\t}\n    58\t\n    59\tfn handle_run(filter: Option<String>) -> AppResult<()> {\n    60\t    // Phase 1: Discovery and validation\n    61\t    let scenarios = catalog::discover_scenarios()?;\n    62\t    catalog::validate_ids(&scenarios)?;\n    63\t\n    64\t    // Phase 2: Build and validate registry\n    65\t    let registry = scenarios::build_registry();\n    66\t    runner::validate_registry(&scenarios, &registry)?;\n    67\t\n    68\t    // Phase 3: Cutover guard\n    69\t    let src_dir = std::path::Path::new(concat!(env!(\"CARGO_MANIFEST_DIR\"), \"/src\"));\n    70\t    cutover_guard::check_cutover_guard(src_dir)?;\n    71\t\n    72\t    // Phase 4: Filter resolution\n    73\t    let selected: Vec<&_> = if let Some(ref filter_id) = filter {\n    74\t        runner::resolve_filter(&scenarios, filter_id)?\n    75\t    } else {\n    76\t        scenarios.iter().collect()\n    77\t    };\n    78\t\n    79\t    if selected.is_empty() {\n    80\t        return Err(AppError::ConformanceDiscoveryFailed {\n    81\t            details: \"no scenarios selected for execution\".to_owned(),\n    82\t        });\n    83\t    }\n    84\t\n    85\t    eprintln!(\"Running {} conformance scenarios...\", selected.len());\n    86\t    eprintln!();\n    87\t\n    88\t    // Phase 5: Execution\n    89\t    let report = runner::run_scenarios(&selected, &registry);\n    90\t\n    91\t    // Phase 6: Summary\n    92\t    eprint!(\"{report}\");\n    93\t\n    94\t    // Phase 7: Exit code\n    95\t    if report.failed > 0 {\n    96\t        let failed_id = report\n    97\t            .results\n    98\t            .iter()\n    99\t            .find_map(|r| match &r.outcome {\n   100\t                ScenarioOutcome::Failed(reason) => Some((r.id.clone(), reason.clone())),\n   101\t                _ => None,\n   102\t            })\n   103\t            .unwrap_or_default();\n   104\t        Err(AppError::ConformanceScenarioFailed {\n   105\t            scenario_id: failed_id.0,\n   106\t            details: failed_id.1,\n   107\t        })\n   108\t    } else {\n   109\t        Ok(())\n   110\t    }\n   111\t}\n   112\t\n   113\tfn truncate(s: &str, max_len: usize) -> String {\n   114\t    if s.len() <= max_len {\n   115\t        s.to_owned()\n   116\t    } else {\n   117\t        format!(\"{}...\", &s[..max_len - 3])\n   118\t    }\n   119\t}\n","exit_code":0,"status":"completed"}}
