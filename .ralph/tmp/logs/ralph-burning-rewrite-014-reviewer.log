{"type":"item.completed","item":{"id":"item_69","type":"command_execution","command":"/run/current-system/sw/bin/bash -lc \"nl -ba /root/new-ralph-burning/ralph-burning-rewrite/src/contexts/conformance_spec/runner.rs | sed -n '1,220p'\"","aggregated_output":"     1\tuse std::collections::HashMap;\n     2\tuse std::time::{Duration, Instant};\n     3\t\n     4\tuse crate::shared::error::{AppError, AppResult};\n     5\t\n     6\tuse super::model::{ConformanceReport, ScenarioMeta, ScenarioOutcome, ScenarioResult};\n     7\t\n     8\t/// Type alias for a scenario executor function.\n     9\tpub type ScenarioExecutor = Box<dyn Fn() -> Result<(), String> + Send + Sync>;\n    10\t\n    11\t/// Validate that the registry and discovered scenarios are in one-to-one correspondence.\n    12\tpub fn validate_registry(\n    13\t    scenarios: &[ScenarioMeta],\n    14\t    registry: &HashMap<String, ScenarioExecutor>,\n    15\t) -> AppResult<()> {\n    16\t    let mut errors = Vec::new();\n    17\t\n    18\t    // Check every discovered scenario has a registered executor\n    19\t    for scenario in scenarios {\n    20\t        if !registry.contains_key(&scenario.id) {\n    21\t            errors.push(format!(\n    22\t                \"discovered scenario '{}' ({}) has no registered executor\",\n    23\t                scenario.id, scenario.source_file\n    24\t            ));\n    25\t        }\n    26\t    }\n    27\t\n    28\t    // Check every registered executor maps to a discovered scenario\n    29\t    let discovered_ids: std::collections::HashSet<&str> =\n    30\t        scenarios.iter().map(|s| s.id.as_str()).collect();\n    31\t\n    32\t    let mut orphan_ids: Vec<&str> = registry\n    33\t        .keys()\n    34\t        .filter(|id| !discovered_ids.contains(id.as_str()))\n    35\t        .map(|s| s.as_str())\n    36\t        .collect();\n    37\t    orphan_ids.sort();\n    38\t\n    39\t    for id in orphan_ids {\n    40\t        errors.push(format!(\n    41\t            \"registered executor '{id}' has no corresponding discovered scenario\"\n    42\t        ));\n    43\t    }\n    44\t\n    45\t    if !errors.is_empty() {\n    46\t        return Err(AppError::ConformanceRegistryDrift {\n    47\t            details: errors.join(\"; \"),\n    48\t        });\n    49\t    }\n    50\t\n    51\t    Ok(())\n    52\t}\n    53\t\n    54\t/// Resolve the filter against discovered scenarios.\n    55\t///\n    56\t/// Returns the filtered subset in discovery order, or an error for unknown IDs.\n    57\tpub fn resolve_filter<'a>(\n    58\t    scenarios: &'a [ScenarioMeta],\n    59\t    filter: &str,\n    60\t) -> AppResult<Vec<&'a ScenarioMeta>> {\n    61\t    let matched: Vec<&ScenarioMeta> = scenarios.iter().filter(|s| s.id == filter).collect();\n    62\t\n    63\t    if matched.is_empty() {\n    64\t        return Err(AppError::ConformanceFilterFailed {\n    65\t            scenario_id: filter.to_owned(),\n    66\t        });\n    67\t    }\n    68\t\n    69\t    Ok(matched)\n    70\t}\n    71\t\n    72\t/// Execute selected scenarios with fail-fast semantics.\n    73\t///\n    74\t/// Runs scenarios in the order given. On the first failure, stops immediately,\n    75\t/// marks remaining scenarios as not-run, and returns the full report.\n    76\tpub fn run_scenarios(\n    77\t    selected: &[&ScenarioMeta],\n    78\t    registry: &HashMap<String, ScenarioExecutor>,\n    79\t) -> ConformanceReport {\n    80\t    let wall_start = Instant::now();\n    81\t    let total = selected.len();\n    82\t    let mut results = Vec::with_capacity(total);\n    83\t    let mut passed = 0usize;\n    84\t    let mut failed = 0usize;\n    85\t    let mut hit_failure = false;\n    86\t\n    87\t    for (idx, scenario) in selected.iter().enumerate() {\n    88\t        if hit_failure {\n    89\t            // Mark remaining as not-run\n    90\t            results.push(ScenarioResult {\n    91\t                id: scenario.id.clone(),\n    92\t                outcome: ScenarioOutcome::NotRun,\n    93\t                duration: Duration::ZERO,\n    94\t            });\n    95\t            continue;\n    96\t        }\n    97\t\n    98\t        let executor = registry.get(&scenario.id).expect(\"validated registry\");\n    99\t\n   100\t        let scenario_start = Instant::now();\n   101\t\n   102\t        // Execute with panic catching for isolation\n   103\t        let exec_result = std::panic::catch_unwind(std::panic::AssertUnwindSafe(|| executor()));\n   104\t        let scenario_duration = scenario_start.elapsed();\n   105\t\n   106\t        match exec_result {\n   107\t            Ok(Ok(())) => {\n   108\t                eprintln!(\n   109\t                    \"  [{}/{}] {} ... PASS ({:.2}s)\",\n   110\t                    idx + 1,\n   111\t                    total,\n   112\t                    scenario.id,\n   113\t                    scenario_duration.as_secs_f64()\n   114\t                );\n   115\t                results.push(ScenarioResult {\n   116\t                    id: scenario.id.clone(),\n   117\t                    outcome: ScenarioOutcome::Passed,\n   118\t                    duration: scenario_duration,\n   119\t                });\n   120\t                passed += 1;\n   121\t            }\n   122\t            Ok(Err(reason)) => {\n   123\t                eprintln!(\n   124\t                    \"  [{}/{}] {} ... FAIL ({:.2}s)\",\n   125\t                    idx + 1,\n   126\t                    total,\n   127\t                    scenario.id,\n   128\t                    scenario_duration.as_secs_f64()\n   129\t                );\n   130\t                eprintln!(\"    Reason: {reason}\");\n   131\t                results.push(ScenarioResult {\n   132\t                    id: scenario.id.clone(),\n   133\t                    outcome: ScenarioOutcome::Failed(reason),\n   134\t                    duration: scenario_duration,\n   135\t                });\n   136\t                failed += 1;\n   137\t                hit_failure = true;\n   138\t            }\n   139\t            Err(panic_info) => {\n   140\t                let reason = if let Some(msg) = panic_info.downcast_ref::<String>() {\n   141\t                    msg.clone()\n   142\t                } else if let Some(msg) = panic_info.downcast_ref::<&str>() {\n   143\t                    msg.to_string()\n   144\t                } else {\n   145\t                    \"panic (no message)\".to_owned()\n   146\t                };\n   147\t                eprintln!(\n   148\t                    \"  [{}/{}] {} ... PANIC ({:.2}s)\",\n   149\t                    idx + 1,\n   150\t                    total,\n   151\t                    scenario.id,\n   152\t                    scenario_duration.as_secs_f64()\n   153\t                );\n   154\t                eprintln!(\"    Reason: {reason}\");\n   155\t                results.push(ScenarioResult {\n   156\t                    id: scenario.id.clone(),\n   157\t                    outcome: ScenarioOutcome::Failed(format!(\"panic: {reason}\")),\n   158\t                    duration: scenario_duration,\n   159\t                });\n   160\t                failed += 1;\n   161\t                hit_failure = true;\n   162\t            }\n   163\t        }\n   164\t    }\n   165\t\n   166\t    let not_run = total - passed - failed;\n   167\t\n   168\t    ConformanceReport {\n   169\t        selected: total,\n   170\t        passed,\n   171\t        failed,\n   172\t        not_run,\n   173\t        wall_clock: wall_start.elapsed(),\n   174\t        results,\n   175\t    }\n   176\t}\n","exit_code":0,"status":"completed"}}
