3911\t    assert!(stderr.contains(\"flow-list-all-presets\"));\n  3912\t    assert!(stderr.contains(\"PASS\"));\n  3913\t    assert!(stderr.contains(\"Selected:  1\"));\n  3914\t    assert!(stderr.contains(\"Passed:    1\"));\n  3915\t}\n  3916\t\n  3917\t#[test]\n  3918\tfn conformance_run_with_unknown_filter_exits_non_zero() {\n  3919\t    let output = Command::new(binary())\n  3920\t        .args([\"conformance\", \"run\", \"--filter\", \"nonexistent-scenario-id\"])\n  3921\t        .output()\n  3922\t        .expect(\"run conformance run --filter unknown\");\n  3923\t\n  3924\t    assert!(\n  3925\t        !output.status.success(),\n  3926\t        \"conformance run with unknown filter should fail\"\n  3927\t    );\n  3928\t\n  3929\t    let stderr = String::from_utf8_lossy(&output.stderr);\n  3930\t    assert!(stderr.contains(\"nonexistent-scenario-id\"));\n  3931\t}\n  3932\t\n  3933\t#[test]\n  3934\tfn conformance_list_detects_duplicate_ids() {\n  3935\t    // This test validates that the catalog rejects duplicate scenario IDs.\n  3936\t    // Since the checked-in corpus has no duplicates, conformance list should succeed.\n  3937\t    let output = Command::new(binary())\n  3938\t        .args([\"conformance\", \"list\"])\n  3939\t        .output()\n  3940\t        .expect(\"run conformance list\");\n  3941\t\n  3942\t    assert!(\n  3943\t        output.status.success(),\n  3944\t        \"conformance list should succeed when no duplicates: {}\",\n  3945\t        String::from_utf8_lossy(&output.stderr)\n  3946\t    );\n  3947\t}\n  3948\t\n  3949\t#[test]\n  3950\tfn conformance_run_fail_fast_stops_on_failure() {\n  3951\t    // We test the fail-fast behavior by running a known-passing filter\n  3952\t    // (which should not trigger fail-fast). The full suite test is more\n  3953\t    // appropriate for CI, where fail-fast would stop at the first failure.\n  3954\t    let output = Command::new(binary())\n  3955\t        .args([\"conformance\", \"run\", \"--