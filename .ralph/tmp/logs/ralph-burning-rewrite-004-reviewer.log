{"type":"item.completed","item":{"id":"item_16","type":"command_execution","command":"/run/current-system/sw/bin/bash -lc \"nl -ba /root/new-ralph-burning/ralph-burning-rewrite/src/contexts/project_run_record/model.rs | sed -n '1,360p'\"","aggregated_output":"     1\tuse chrono::{DateTime, Utc};\n     2\tuse serde::{Deserialize, Serialize};\n     3\t\n     4\tuse crate::shared::domain::{FlowPreset, ProjectId, StageCursor, StageId};\n     5\t\n     6\t/// Immutable project metadata persisted in `project.toml`.\n     7\t#[derive(Debug, Clone, PartialEq, Serialize, Deserialize)]\n     8\tpub struct ProjectRecord {\n     9\t    pub id: ProjectId,\n    10\t    pub name: String,\n    11\t    pub flow: FlowPreset,\n    12\t    pub prompt_reference: String,\n    13\t    pub prompt_hash: String,\n    14\t    pub created_at: DateTime<Utc>,\n    15\t    pub status_summary: ProjectStatusSummary,\n    16\t}\n    17\t\n    18\t#[derive(Debug, Clone, Copy, PartialEq, Eq, Serialize, Deserialize)]\n    19\t#[serde(rename_all = \"snake_case\")]\n    20\tpub enum ProjectStatusSummary {\n    21\t    Created,\n    22\t    Active,\n    23\t    Completed,\n    24\t    Failed,\n    25\t}\n    26\t\n    27\t/// Canonical run state persisted in `run.json`.\n    28\t/// This is the single source of truth for run progression - never inferred from artifacts.\n    29\t#[derive(Debug, Clone, PartialEq, Serialize, Deserialize)]\n    30\tpub struct RunSnapshot {\n    31\t    pub active_run: Option<ActiveRun>,\n    32\t    pub status: RunStatus,\n    33\t    pub cycle_history: Vec<CycleHistoryEntry>,\n    34\t    pub completion_rounds: u32,\n    35\t    pub rollback_point_meta: RollbackPointMeta,\n    36\t    pub amendment_queue: AmendmentQueueState,\n    37\t    pub status_summary: String,\n    38\t}\n    39\t\n    40\timpl RunSnapshot {\n    41\t    pub fn initial() -> Self {\n    42\t        Self {\n    43\t            active_run: None,\n    44\t            status: RunStatus::NotStarted,\n    45\t            cycle_history: Vec::new(),\n    46\t            completion_rounds: 0,\n    47\t            rollback_point_meta: RollbackPointMeta::default(),\n    48\t            amendment_queue: AmendmentQueueState::default(),\n    49\t            status_summary: \"not started\".to_owned(),\n    50\t        }\n    51\t    }\n    52\t\n    53\t    pub fn has_active_run(&self) -> bool {\n    54\t        self.active_run.is_some()\n    55\t    }\n    56\t\n    57\t    /// Semantic validation of run snapshot consistency.\n    58\t    /// Returns `Err` with a description if status and active_run are inconsistent.\n    59\t    pub fn validate_semantics(&self) -> Result<(), String> {\n    60\t        match (&self.status, &self.active_run) {\n    61\t            // Running or Paused requires an active run cursor\n    62\t            (RunStatus::Running, None) => Err(\n    63\t                \"status is 'running' but active_run is null — inconsistent canonical state\"\n    64\t                    .to_owned(),\n    65\t            ),\n    66\t            (RunStatus::Paused, None) => Err(\n    67\t                \"status is 'paused' but active_run is null — inconsistent canonical state\"\n    68\t                    .to_owned(),\n    69\t            ),\n    70\t            // NotStarted must not have an active run cursor\n    71\t            (RunStatus::NotStarted, Some(_)) => Err(\n    72\t                \"status is 'not_started' but active_run is present — inconsistent canonical state\"\n    73\t                    .to_owned(),\n    74\t            ),\n    75\t            // All other combinations are valid:\n    76\t            // NotStarted + None, Running/Paused + Some, Completed/Failed + None/Some\n    77\t            _ => Ok(()),\n    78\t        }\n    79\t    }\n    80\t}\n    81\t\n    82\t#[derive(Debug, Clone, PartialEq, Serialize, Deserialize)]\n    83\tpub struct ActiveRun {\n    84\t    pub run_id: String,\n    85\t    pub stage_cursor: StageCursor,\n    86\t    pub started_at: DateTime<Utc>,\n    87\t}\n    88\t\n    89\t#[derive(Debug, Clone, Copy, PartialEq, Eq, Serialize, Deserialize)]\n    90\t#[serde(rename_all = \"snake_case\")]\n    91\tpub enum RunStatus {\n    92\t    NotStarted,\n    93\t    Running,\n    94\t    Paused,\n    95\t    Completed,\n    96\t    Failed,\n    97\t}\n    98\t\n    99\timpl RunStatus {\n   100\t    /// Human-readable status string for CLI output.\n   101\t    pub fn display_str(self) -> &'static str {\n   102\t        match self {\n   103\t            Self::NotStarted => \"not started\",\n   104\t            Self::Running => \"running\",\n   105\t            Self::Paused => \"paused\",\n   106\t            Self::Completed => \"completed\",\n   107\t            Self::Failed => \"failed\",\n   108\t        }\n   109\t    }\n   110\t}\n   111\t\n   112\t/// A single entry in the cycle history tracking progression through work cycles.\n   113\t#[derive(Debug, Clone, PartialEq, Serialize, Deserialize)]\n   114\tpub struct CycleHistoryEntry {\n   115\t    pub cycle: u32,\n   116\t    pub stage_id: StageId,\n   117\t    pub started_at: DateTime<Utc>,\n   118\t    pub completed_at: Option<DateTime<Utc>>,\n   119\t}\n   120\t\n   121\t/// Rollback-point metadata tracked in the canonical run snapshot.\n   122\t#[derive(Debug, Clone, Default, PartialEq, Serialize, Deserialize)]\n   123\tpub struct RollbackPointMeta {\n   124\t    pub last_rollback_id: Option<String>,\n   125\t    pub rollback_count: u32,\n   126\t}\n   127\t\n   128\t/// Amendment queue state tracked in the canonical run snapshot.\n   129\t#[derive(Debug, Clone, Default, PartialEq, Serialize, Deserialize)]\n   130\tpub struct AmendmentQueueState {\n   131\t    pub pending: Vec<serde_json::Value>,\n   132\t    pub processed_count: u32,\n   133\t}\n   134\t\n   135\t/// A single journal event stored in `journal.ndjson`.\n   136\t#[derive(Debug, Clone, PartialEq, Serialize, Deserialize)]\n   137\tpub struct JournalEvent {\n   138\t    pub sequence: u64,\n   139\t    pub timestamp: DateTime<Utc>,\n   140\t    pub event_type: JournalEventType,\n   141\t    pub details: serde_json::Value,\n   142\t}\n   143\t\n   144\t#[derive(Debug, Clone, PartialEq, Eq, Serialize, Deserialize)]\n   145\t#[serde(rename_all = \"snake_case\")]\n   146\tpub enum JournalEventType {\n   147\t    ProjectCreated,\n   148\t    RunStarted,\n   149\t    StageEntered,\n   150\t    StageCompleted,\n   151\t    CycleAdvanced,\n   152\t    CompletionRoundAdvanced,\n   153\t    RunCompleted,\n   154\t    RunFailed,\n   155\t    RollbackCreated,\n   156\t    AmendmentQueued,\n   157\t}\n   158\t\n   159\t/// A durable history payload record stored in `history/payloads/`.\n   160\t#[derive(Debug, Clone, PartialEq, Serialize, Deserialize)]\n   161\tpub struct PayloadRecord {\n   162\t    pub payload_id: String,\n   163\t    pub stage_id: StageId,\n   164\t    pub cycle: u32,\n   165\t    pub attempt: u32,\n   166\t    pub created_at: DateTime<Utc>,\n   167\t    pub payload: serde_json::Value,\n   168\t}\n   169\t\n   170\t/// A durable history artifact record stored in `history/artifacts/`.\n   171\t#[derive(Debug, Clone, PartialEq, Serialize, Deserialize)]\n   172\tpub struct ArtifactRecord {\n   173\t    pub artifact_id: String,\n   174\t    pub payload_id: String,\n   175\t    pub stage_id: StageId,\n   176\t    pub created_at: DateTime<Utc>,\n   177\t    pub content: String,\n   178\t}\n   179\t\n   180\t/// A runtime log entry stored in `runtime/logs/`.\n   181\t#[derive(Debug, Clone, PartialEq, Serialize, Deserialize)]\n   182\tpub struct RuntimeLogEntry {\n   183\t    pub timestamp: DateTime<Utc>,\n   184\t    pub level: LogLevel,\n   185\t    pub source: String,\n   186\t    pub message: String,\n   187\t}\n   188\t\n   189\t#[derive(Debug, Clone, Copy, PartialEq, Eq, Serialize, Deserialize)]\n   190\t#[serde(rename_all = \"snake_case\")]\n   191\tpub enum LogLevel {\n   192\t    Debug,\n   193\t    Info,\n   194\t    Warn,\n   195\t    Error,\n   196\t}\n   197\t\n   198\t/// Rollback metadata stored in `rollback/`.\n   199\t#[derive(Debug, Clone, PartialEq, Serialize, Deserialize)]\n   200\tpub struct RollbackPoint {\n   201\t    pub rollback_id: String,\n   202\t    pub created_at: DateTime<Utc>,\n   203\t    pub stage_id: StageId,\n   204\t    pub cycle: u32,\n   205\t    pub run_snapshot: RunSnapshot,\n   206\t}\n   207\t\n   208\t/// Empty session store for `sessions.json`.\n   209\t#[derive(Debug, Clone, PartialEq, Serialize, Deserialize)]\n   210\tpub struct SessionStore {\n   211\t    pub sessions: Vec<serde_json::Value>,\n   212\t}\n   213\t\n   214\timpl SessionStore {\n   215\t    pub fn empty() -> Self {\n   216\t        Self {\n   217\t            sessions: Vec::new(),\n   218\t        }\n   219\t    }\n   220\t}\n   221\t\n   222\t/// Summary used in `project list` output.\n   223\t#[derive(Debug, Clone)]\n   224\tpub struct ProjectListEntry {\n   225\t    pub id: ProjectId,\n   226\t    pub name: String,\n   227\t    pub flow: FlowPreset,\n   228\t    pub status_summary: ProjectStatusSummary,\n   229\t    pub created_at: DateTime<Utc>,\n   230\t    pub is_active: bool,\n   231\t}\n   232\t\n   233\t/// Detailed project view used in `project show` output.\n   234\t#[derive(Debug, Clone)]\n   235\tpub struct ProjectDetail {\n   236\t    pub record: ProjectRecord,\n   237\t    pub run_snapshot: RunSnapshot,\n   238\t    pub journal_event_count: u64,\n   239\t    pub rollback_count: usize,\n   240\t    pub is_active: bool,\n   241\t}\n","exit_code":0,"status":"completed"}}
