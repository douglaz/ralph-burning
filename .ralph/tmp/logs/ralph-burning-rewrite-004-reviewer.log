;\n    38\t}\n    39\t\n    40\t#[test]\n    41\tfn resolve_active_project_trims_newlines() {\n    42\t    let temp_dir = tempdir().expect(\"create temp dir\");\n    43\t    initialize_workspace_fixture(temp_dir.path());\n    44\t    create_project_fixture(temp_dir.path(), \"alpha\");\n    45\t    fs::write(\n    46\t        temp_dir.path().join(\".ralph-burning/active-project\"),\n    47\t        \"alpha\\n\",\n    48\t    )\n    49\t    .expect(\"write active project\");\n    50\t\n    51\t    let resolved = resolve_active_project(temp_dir.path()).expect(\"resolve active project\");\n    52\t\n    53\t    assert_eq!(\"alpha\", resolved.as_str());\n    54\t}\n    55\t\n    56\t#[test]\n    57\tfn set_active_project_rejects_missing_projects() {\n    58\t    let temp_dir = tempdir().expect(\"create temp dir\");\n    59\t    initialize_workspace_fixture(temp_dir.path());\n    60\t    let project_id = ProjectId::new(\"missing\").expect(\"project id\");\n    61\t\n    62\t    let error = set_active_project(temp_dir.path(), &project_id).expect_err(\"missing project\");\n    63\t\n    64\t    assert!(matches!(error, AppError::ProjectNotFound { .. }));\n    65\t}\n    66\t\n    67\t#[test]\n    68\tfn resolve_active_project_rejects_path_like_pointer_values() {\n    69\t    let temp_dir = tempdir().expect(\"create temp dir\");\n    70\t    initialize_workspace_fixture(temp_dir.path());\n    71\t    fs::write(\n    72\t        temp_dir.path().join(\".ralph-burning/active-project\"),\n    73\t        \"../escape\\n\",\n    74\t    )\n    75\t    .expect(\"write active project\");\n    76\t\n    77\t    let error =\n    78\t        resolve_active_project(temp_dir.path()).expect_err(\"path-like active project should fail\");\n    79\t\n    80\t    assert!(matches!(error, AppError::InvalidIdentifier { .. }));\n    81\t}\n    82\t\n    83\tfn create_project_fixture(base_dir: &std::path::Path, project_id: &str) {\n    84\t    let project_root = base_dir.join(\".ralph-burning/proje