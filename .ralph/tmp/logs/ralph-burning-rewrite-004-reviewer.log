{"type":"item.completed","item":{"id":"item_46","type":"command_execution","command":"/run/current-system/sw/bin/bash -lc \"nl -ba ralph-burning-rewrite/src/contexts/project_run_record/service.rs | sed -n '1,260p'\"","aggregated_output":"     1\tuse std::path::Path;\n     2\t\n     3\tuse chrono::{DateTime, Utc};\n     4\t\n     5\tuse crate::shared::domain::{FlowPreset, ProjectId};\n     6\tuse crate::shared::error::{AppError, AppResult};\n     7\t\n     8\tuse super::model::{\n     9\t    ArtifactRecord, JournalEvent, JournalEventType, PayloadRecord,\n    10\t    ProjectDetail, ProjectListEntry, ProjectRecord, ProjectStatusSummary,\n    11\t    RunSnapshot, RuntimeLogEntry, SessionStore,\n    12\t};\n    13\tuse super::journal;\n    14\tuse super::queries::{\n    15\t    self, RunHistoryView, RunStatusView, RunTailView,\n    16\t};\n    17\t\n    18\t/// Port for reading and writing project records.\n    19\tpub trait ProjectStorePort {\n    20\t    fn project_exists(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<bool>;\n    21\t    fn read_project_record(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<ProjectRecord>;\n    22\t    fn list_project_ids(&self, base_dir: &Path) -> AppResult<Vec<ProjectId>>;\n    23\t    fn delete_project(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<()>;\n    24\t\n    25\t    /// Atomically stage and commit a new project. If any step fails,\n    26\t    /// the project must not be visible to list/show.\n    27\t    fn create_project_atomic(\n    28\t        &self,\n    29\t        base_dir: &Path,\n    30\t        record: &ProjectRecord,\n    31\t        prompt_contents: &str,\n    32\t        run_snapshot: &RunSnapshot,\n    33\t        initial_journal_line: &str,\n    34\t        sessions: &SessionStore,\n    35\t    ) -> AppResult<()>;\n    36\t}\n    37\t\n    38\t/// Port for reading and appending journal events.\n    39\tpub trait JournalStorePort {\n    40\t    fn read_journal(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<Vec<JournalEvent>>;\n    41\t    fn append_event(&self, base_dir: &Path, project_id: &ProjectId, line: &str) -> AppResult<()>;\n    42\t}\n    43\t\n    44\t/// Port for reading payload and artifact durable history.\n    45\tpub trait ArtifactStorePort {\n    46\t    fn list_payloads(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<Vec<PayloadRecord>>;\n    47\t    fn list_artifacts(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<Vec<ArtifactRecord>>;\n    48\t}\n    49\t\n    50\t/// Port for reading runtime logs (separate from durable history).\n    51\tpub trait RuntimeLogStorePort {\n    52\t    fn read_runtime_logs(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<Vec<RuntimeLogEntry>>;\n    53\t}\n    54\t\n    55\t/// Port for reading/writing the run snapshot.\n    56\tpub trait RunSnapshotPort {\n    57\t    fn read_run_snapshot(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<RunSnapshot>;\n    58\t}\n    59\t\n    60\t/// Port for reading/clearing the active project pointer.\n    61\tpub trait ActiveProjectPort {\n    62\t    fn read_active_project_id(&self, base_dir: &Path) -> AppResult<Option<String>>;\n    63\t    fn clear_active_project(&self, base_dir: &Path) -> AppResult<()>;\n    64\t}\n    65\t\n    66\t/// Input for the `project create` use case.\n    67\tpub struct CreateProjectInput {\n    68\t    pub id: ProjectId,\n    69\t    pub name: String,\n    70\t    pub flow: FlowPreset,\n    71\t    pub prompt_path: String,\n    72\t    pub prompt_contents: String,\n    73\t    pub prompt_hash: String,\n    74\t    pub created_at: DateTime<Utc>,\n    75\t}\n    76\t\n    77\t/// Create a new project with all canonical files.\n    78\tpub fn create_project(\n    79\t    store: &dyn ProjectStorePort,\n    80\t    journal_store: &dyn JournalStorePort,\n    81\t    base_dir: &Path,\n    82\t    input: CreateProjectInput,\n    83\t) -> AppResult<ProjectRecord> {\n    84\t    // Check for duplicate project ID\n    85\t    if store.project_exists(base_dir, &input.id)? {\n    86\t        return Err(AppError::DuplicateProject {\n    87\t            project_id: input.id.to_string(),\n    88\t        });\n    89\t    }\n    90\t\n    91\t    let record = ProjectRecord {\n    92\t        id: input.id.clone(),\n    93\t        name: input.name,\n    94\t        flow: input.flow,\n    95\t        prompt_reference: input.prompt_path,\n    96\t        prompt_hash: input.prompt_hash,\n    97\t        created_at: input.created_at,\n    98\t        status_summary: ProjectStatusSummary::Created,\n    99\t    };\n   100\t\n   101\t    let run_snapshot = RunSnapshot::initial();\n   102\t    let sessions = SessionStore::empty();\n   103\t\n   104\t    // Create the initial journal event\n   105\t    let initial_event = JournalEvent {\n   106\t        sequence: 1,\n   107\t        timestamp: input.created_at,\n   108\t        event_type: JournalEventType::ProjectCreated,\n   109\t        details: serde_json::json!({\n   110\t            \"project_id\": record.id.as_str(),\n   111\t            \"flow\": record.flow.as_str(),\n   112\t        }),\n   113\t    };\n   114\t    let journal_line = journal::serialize_event(&initial_event)?;\n   115\t\n   116\t    // Atomic creation: all files or nothing\n   117\t    store.create_project_atomic(\n   118\t        base_dir,\n   119\t        &record,\n   120\t        &input.prompt_contents,\n   121\t        &run_snapshot,\n   122\t        &journal_line,\n   123\t        &sessions,\n   124\t    )?;\n   125\t\n   126\t    // create_project_atomic writes the journal as part of the atomic init,\n   127\t    // but we don't call journal_store.append_event here because the atomic\n   128\t    // creation already wrote the initial journal line. The journal_store\n   129\t    // parameter is kept for interface consistency and future use.\n   130\t    let _ = journal_store;\n   131\t\n   132\t    Ok(record)\n   133\t}\n   134\t\n   135\t/// List all projects with summary data.\n   136\tpub fn list_projects(\n   137\t    store: &dyn ProjectStorePort,\n   138\t    active_port: &dyn ActiveProjectPort,\n   139\t    base_dir: &Path,\n   140\t) -> AppResult<Vec<ProjectListEntry>> {\n   141\t    let active_id = active_port.read_active_project_id(base_dir)?;\n   142\t    let project_ids = store.list_project_ids(base_dir)?;\n   143\t\n   144\t    let mut entries = Vec::new();\n   145\t    for pid in project_ids {\n   146\t        let record = store.read_project_record(base_dir, &pid)?;\n   147\t        let is_active = active_id.as_deref() == Some(pid.as_str());\n   148\t        entries.push(ProjectListEntry {\n   149\t            id: record.id,\n   150\t            name: record.name,\n   151\t            flow: record.flow,\n   152\t            status_summary: record.status_summary,\n   153\t            created_at: record.created_at,\n   154\t            is_active,\n   155\t        });\n   156\t    }\n   157\t\n   158\t    Ok(entries)\n   159\t}\n   160\t\n   161\t/// Show detailed project information.\n   162\tpub fn show_project(\n   163\t    store: &dyn ProjectStorePort,\n   164\t    run_port: &dyn RunSnapshotPort,\n   165\t    journal_port: &dyn JournalStorePort,\n   166\t    active_port: &dyn ActiveProjectPort,\n   167\t    base_dir: &Path,\n   168\t    project_id: &ProjectId,\n   169\t) -> AppResult<ProjectDetail> {\n   170\t    if !store.project_exists(base_dir, project_id)? {\n   171\t        return Err(AppError::ProjectNotFound {\n   172\t            project_id: project_id.to_string(),\n   173\t        });\n   174\t    }\n   175\t\n   176\t    let record = store.read_project_record(base_dir, project_id)?;\n   177\t    let run_snapshot = run_port.read_run_snapshot(base_dir, project_id)?;\n   178\t    let events = journal_port.read_journal(base_dir, project_id)?;\n   179\t    let journal_event_count = events.len() as u64;\n   180\t    let active_id = active_port.read_active_project_id(base_dir)?;\n   181\t    let is_active = active_id.as_deref() == Some(project_id.as_str());\n   182\t\n   183\t    // Count rollback points from journal events\n   184\t    let rollback_count = events\n   185\t        .iter()\n   186\t        .filter(|e| e.event_type == JournalEventType::RollbackCreated)\n   187\t        .count();\n   188\t\n   189\t    Ok(ProjectDetail {\n   190\t        record,\n   191\t        run_snapshot,\n   192\t        journal_event_count,\n   193\t        rollback_count,\n   194\t        is_active,\n   195\t    })\n   196\t}\n   197\t\n   198\t/// Delete a project. Fails if project has an active run.\n   199\t/// Clears active-project pointer if it pointed to the deleted project.\n   200\tpub fn delete_project(\n   201\t    store: &dyn ProjectStorePort,\n   202\t    run_port: &dyn RunSnapshotPort,\n   203\t    active_port: &dyn ActiveProjectPort,\n   204\t    base_dir: &Path,\n   205\t    project_id: &ProjectId,\n   206\t) -> AppResult<()> {\n   207\t    if !store.project_exists(base_dir, project_id)? {\n   208\t        return Err(AppError::ProjectNotFound {\n   209\t            project_id: project_id.to_string(),\n   210\t        });\n   211\t    }\n   212\t\n   213\t    // Check for active run\n   214\t    let run_snapshot = run_port.read_run_snapshot(base_dir, project_id)?;\n   215\t    if run_snapshot.has_active_run() {\n   216\t        return Err(AppError::ActiveRunDelete {\n   217\t            project_id: project_id.to_string(),\n   218\t        });\n   219\t    }\n   220\t\n   221\t    // Check if this is the active project (before delete)\n   222\t    let active_id = active_port.read_active_project_id(base_dir)?;\n   223\t    let was_active = active_id.as_deref() == Some(project_id.as_str());\n   224\t\n   225\t    // Perform the actual delete\n   226\t    store.delete_project(base_dir, project_id)?;\n   227\t\n   228\t    // Clear active-project pointer only after successful delete\n   229\t    if was_active {\n   230\t        active_port.clear_active_project(base_dir)?;\n   231\t    }\n   232\t\n   233\t    Ok(())\n   234\t}\n   235\t\n   236\t/// Get run status for the active project.\n   237\tpub fn run_status(\n   238\t    run_port: &dyn RunSnapshotPort,\n   239\t    base_dir: &Path,\n   240\t    project_id: &ProjectId,\n   241\t) -> AppResult<RunStatusView> {\n   242\t    let snapshot = run_port.read_run_snapshot(base_dir, project_id)?;\n   243\t    Ok(queries::build_status_view(project_id.as_str(), &snapshot))\n   244\t}\n   245\t\n   246\t/// Get run history (durable only, no runtime logs).\n   247\tpub fn run_history(\n   248\t    journal_port: &dyn JournalStorePort,\n   249\t    artifact_port: &dyn ArtifactStorePort,\n   250\t    base_dir: &Path,\n   251\t    project_id: &ProjectId,\n   252\t) -> AppResult<RunHistoryView> {\n   253\t    let events = journal_port.read_journal(base_dir, project_id)?;\n   254\t    let payloads = artifact_port.list_payloads(base_dir, project_id)?;\n   255\t    let artifacts = artifact_port.list_artifacts(base_dir, project_id)?;\n   256\t\n   257\t    queries::validate_history_consistency(&payloads, &artifacts)?;\n   258\t\n   259\t    Ok(queries::build_history_view(\n   260\t        project_id.as_str(),\n","exit_code":0,"status":"completed"}}
