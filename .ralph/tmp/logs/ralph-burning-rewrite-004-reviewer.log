{"type":"item.completed","item":{"id":"item_13","type":"command_execution","command":"/run/current-system/sw/bin/bash -lc \"nl -ba /root/new-ralph-burning/ralph-burning-rewrite/src/adapters/fs.rs | sed -n '1,760p'\"","aggregated_output":"     1\tuse std::env;\n     2\tuse std::fs::{self, OpenOptions};\n     3\tuse std::io::Write;\n     4\tuse std::path::{Path, PathBuf};\n     5\tuse std::process::Command;\n     6\tuse std::time::{SystemTime, UNIX_EPOCH};\n     7\t\n     8\tuse crate::contexts::project_run_record::journal;\n     9\tuse crate::contexts::project_run_record::model::{\n    10\t    ArtifactRecord, JournalEvent, PayloadRecord, ProjectRecord, RunSnapshot,\n    11\t    RuntimeLogEntry, SessionStore,\n    12\t};\n    13\tuse crate::contexts::project_run_record::service::{\n    14\t    ActiveProjectPort, ArtifactStorePort, JournalStorePort, ProjectStorePort,\n    15\t    RuntimeLogStorePort, RunSnapshotPort,\n    16\t};\n    17\tuse crate::shared::domain::{ProjectId, WorkspaceConfig};\n    18\tuse crate::shared::error::{AppError, AppResult};\n    19\t\n    20\tconst ACTIVE_PROJECT_FILE: &str = \"active-project\";\n    21\tconst WORKSPACE_DIR: &str = \".ralph-burning\";\n    22\tconst PROJECTS_DIR: &str = \"projects\";\n    23\tconst PROJECT_CONFIG_FILE: &str = \"project.toml\";\n    24\tconst RUN_FILE: &str = \"run.json\";\n    25\tconst JOURNAL_FILE: &str = \"journal.ndjson\";\n    26\tconst SESSIONS_FILE: &str = \"sessions.json\";\n    27\tconst PROMPT_FILE: &str = \"prompt.md\";\n    28\t\n    29\t/// Required subdirectories inside a project.\n    30\tconst PROJECT_SUBDIRS: &[&str] = &[\n    31\t    \"history/payloads\",\n    32\t    \"history/artifacts\",\n    33\t    \"runtime/logs\",\n    34\t    \"runtime/backend\",\n    35\t    \"runtime/temp\",\n    36\t    \"amendments\",\n    37\t    \"rollback\",\n    38\t];\n    39\t\n    40\tpub struct FileSystem;\n    41\t\n    42\timpl FileSystem {\n    43\t    pub fn create_workspace(\n    44\t        workspace_root: &Path,\n    45\t        workspace_config: &str,\n    46\t        required_directories: &[&str],\n    47\t    ) -> AppResult<()> {\n    48\t        fs::create_dir_all(workspace_root)?;\n    49\t\n    50\t        for directory in required_directories {\n    51\t            fs::create_dir_all(workspace_root.join(directory))?;\n    52\t        }\n    53\t\n    54\t        Self::write_atomic(&workspace_root.join(\"workspace.toml\"), workspace_config)?;\n    55\t        Ok(())\n    56\t    }\n    57\t\n    58\t    pub fn read_to_string(path: &Path) -> AppResult<String> {\n    59\t        Ok(fs::read_to_string(path)?)\n    60\t    }\n    61\t\n    62\t    pub fn write_atomic(path: &Path, contents: &str) -> AppResult<()> {\n    63\t        let parent = path.parent().ok_or_else(|| {\n    64\t            AppError::Io(std::io::Error::new(\n    65\t                std::io::ErrorKind::InvalidInput,\n    66\t                format!(\"path '{}' has no parent directory\", path.display()),\n    67\t            ))\n    68\t        })?;\n    69\t        fs::create_dir_all(parent)?;\n    70\t\n    71\t        let timestamp = SystemTime::now()\n    72\t            .duration_since(UNIX_EPOCH)\n    73\t            .map(|duration| duration.as_nanos())\n    74\t            .unwrap_or_default();\n    75\t        let temp_path = parent.join(format!(\n    76\t            \".{}.{}.{}.tmp\",\n    77\t            path.file_name()\n    78\t                .and_then(|value| value.to_str())\n    79\t                .unwrap_or(\"workspace\"),\n    80\t            std::process::id(),\n    81\t            timestamp\n    82\t        ));\n    83\t\n    84\t        let mut file = OpenOptions::new()\n    85\t            .create_new(true)\n    86\t            .write(true)\n    87\t            .open(&temp_path)?;\n    88\t        file.write_all(contents.as_bytes())?;\n    89\t        file.sync_all()?;\n    90\t        drop(file);\n    91\t\n    92\t        if let Err(error) = fs::rename(&temp_path, path) {\n    93\t            let _ = fs::remove_file(&temp_path);\n    94\t            return Err(error.into());\n    95\t        }\n    96\t\n    97\t        Ok(())\n    98\t    }\n    99\t\n   100\t    pub fn render_workspace_config(config: &WorkspaceConfig) -> AppResult<String> {\n   101\t        Ok(toml::to_string_pretty(config)?)\n   102\t    }\n   103\t\n   104\t    pub fn read_active_project(workspace_root: &Path) -> AppResult<Option<String>> {\n   105\t        let path = workspace_root.join(ACTIVE_PROJECT_FILE);\n   106\t        match fs::read_to_string(path) {\n   107\t            Ok(raw) => {\n   108\t                let trimmed = raw.trim();\n   109\t                if trimmed.is_empty() {\n   110\t                    Ok(None)\n   111\t                } else {\n   112\t                    Ok(Some(trimmed.to_owned()))\n   113\t                }\n   114\t            }\n   115\t            Err(error) if error.kind() == std::io::ErrorKind::NotFound => Ok(None),\n   116\t            Err(error) => Err(error.into()),\n   117\t        }\n   118\t    }\n   119\t\n   120\t    pub fn write_active_project(workspace_root: &Path, project_id: &str) -> AppResult<()> {\n   121\t        Self::write_atomic(&workspace_root.join(ACTIVE_PROJECT_FILE), project_id)\n   122\t    }\n   123\t\n   124\t    pub fn open_editor(path: &Path) -> AppResult<()> {\n   125\t        let editor = env::var(\"EDITOR\")\n   126\t            .ok()\n   127\t            .filter(|value| !value.trim().is_empty())\n   128\t            .or_else(|| {\n   129\t                env::var(\"VISUAL\")\n   130\t                    .ok()\n   131\t                    .filter(|value| !value.trim().is_empty())\n   132\t            })\n   133\t            .unwrap_or_else(|| \"vi\".to_owned());\n   134\t\n   135\t        let mut parts = editor.split_whitespace();\n   136\t        let program = parts.next().ok_or_else(|| AppError::EditorFailed {\n   137\t            editor: editor.clone(),\n   138\t            details: \": empty editor command\".to_owned(),\n   139\t        })?;\n   140\t        let status = Command::new(program).args(parts).arg(path).status()?;\n   141\t\n   142\t        if status.success() {\n   143\t            Ok(())\n   144\t        } else {\n   145\t            let details = match status.code() {\n   146\t                Some(code) => format!(\" with exit code {code}\"),\n   147\t                None => \" after being terminated by a signal\".to_owned(),\n   148\t            };\n   149\t            Err(AppError::EditorFailed { editor, details })\n   150\t        }\n   151\t    }\n   152\t\n   153\t    /// Compute a simple hash of content for prompt integrity tracking.\n   154\t    pub fn prompt_hash(contents: &str) -> String {\n   155\t        use std::collections::hash_map::DefaultHasher;\n   156\t        use std::hash::{Hash, Hasher};\n   157\t        let mut hasher = DefaultHasher::new();\n   158\t        contents.hash(&mut hasher);\n   159\t        format!(\"{:016x}\", hasher.finish())\n   160\t    }\n   161\t\n   162\t    // ── Helpers for project filesystem layout ──\n   163\t\n   164\t    fn workspace_root_path(base_dir: &Path) -> PathBuf {\n   165\t        base_dir.join(WORKSPACE_DIR)\n   166\t    }\n   167\t\n   168\t    fn project_root(base_dir: &Path, project_id: &ProjectId) -> PathBuf {\n   169\t        Self::workspace_root_path(base_dir)\n   170\t            .join(PROJECTS_DIR)\n   171\t            .join(project_id.as_str())\n   172\t    }\n   173\t\n   174\t    fn append_line(path: &Path, line: &str) -> AppResult<()> {\n   175\t        let parent = path.parent().ok_or_else(|| {\n   176\t            AppError::Io(std::io::Error::new(\n   177\t                std::io::ErrorKind::InvalidInput,\n   178\t                format!(\"path '{}' has no parent directory\", path.display()),\n   179\t            ))\n   180\t        })?;\n   181\t        fs::create_dir_all(parent)?;\n   182\t\n   183\t        let mut file = OpenOptions::new()\n   184\t            .create(true)\n   185\t            .append(true)\n   186\t            .open(path)?;\n   187\t        writeln!(file, \"{}\", line)?;\n   188\t        file.sync_all()?;\n   189\t        Ok(())\n   190\t    }\n   191\t}\n   192\t\n   193\t/// Filesystem-backed implementation of `ProjectStorePort`.\n   194\tpub struct FsProjectStore;\n   195\t\n   196\timpl ProjectStorePort for FsProjectStore {\n   197\t    fn project_exists(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<bool> {\n   198\t        let project_root = FileSystem::project_root(base_dir, project_id);\n   199\t        if !project_root.is_dir() {\n   200\t            return Ok(false);\n   201\t        }\n   202\t        if !project_root.join(PROJECT_CONFIG_FILE).is_file() {\n   203\t            return Err(AppError::CorruptRecord {\n   204\t                file: format!(\"projects/{}/project.toml\", project_id),\n   205\t                details: \"project directory exists but canonical project.toml is missing\"\n   206\t                    .to_owned(),\n   207\t            });\n   208\t        }\n   209\t        Ok(true)\n   210\t    }\n   211\t\n   212\t    fn read_project_record(\n   213\t        &self,\n   214\t        base_dir: &Path,\n   215\t        project_id: &ProjectId,\n   216\t    ) -> AppResult<ProjectRecord> {\n   217\t        let project_root = FileSystem::project_root(base_dir, project_id);\n   218\t        let path = project_root.join(PROJECT_CONFIG_FILE);\n   219\t        let raw = fs::read_to_string(&path).map_err(|e| {\n   220\t            if e.kind() == std::io::ErrorKind::NotFound {\n   221\t                if project_root.is_dir() {\n   222\t                    // Directory exists but project.toml is missing — corruption\n   223\t                    AppError::CorruptRecord {\n   224\t                        file: format!(\"projects/{}/project.toml\", project_id),\n   225\t                        details: \"project directory exists but canonical project.toml is missing\"\n   226\t                            .to_owned(),\n   227\t                    }\n   228\t                } else {\n   229\t                    AppError::ProjectNotFound {\n   230\t                        project_id: project_id.to_string(),\n   231\t                    }\n   232\t                }\n   233\t            } else {\n   234\t                e.into()\n   235\t            }\n   236\t        })?;\n   237\t        toml::from_str(&raw).map_err(|e| AppError::CorruptRecord {\n   238\t            file: format!(\"projects/{}/project.toml\", project_id),\n   239\t            details: e.to_string(),\n   240\t        })\n   241\t    }\n   242\t\n   243\t    fn list_project_ids(&self, base_dir: &Path) -> AppResult<Vec<ProjectId>> {\n   244\t        let projects_dir = FileSystem::workspace_root_path(base_dir).join(PROJECTS_DIR);\n   245\t        if !projects_dir.is_dir() {\n   246\t            return Ok(Vec::new());\n   247\t        }\n   248\t\n   249\t        let mut ids = Vec::new();\n   250\t        for entry in fs::read_dir(&projects_dir)? {\n   251\t            let entry = entry?;\n   252\t            if !entry.file_type()?.is_dir() {\n   253\t                continue;\n   254\t            }\n   255\t            let name = entry.file_name();\n   256\t            let name_str = name.to_string_lossy();\n   257\t            // Skip hidden directories (staging/trash from transactional operations)\n   258\t            if name_str.starts_with('.') {\n   259\t                continue;\n   260\t            }\n   261\t            if let Ok(pid) = ProjectId::new(name_str.as_ref()) {\n   262\t                if !entry.path().join(PROJECT_CONFIG_FILE).is_file() {\n   263\t                    return Err(AppError::CorruptRecord {\n   264\t                        file: format!(\"projects/{}/project.toml\", name_str),\n   265\t                        details:\n   266\t                            \"project directory exists but canonical project.toml is missing\"\n   267\t                                .to_owned(),\n   268\t                    });\n   269\t                }\n   270\t                ids.push(pid);\n   271\t            }\n   272\t        }\n   273\t\n   274\t        ids.sort_by(|a, b| a.as_str().cmp(b.as_str()));\n   275\t        Ok(ids)\n   276\t    }\n   277\t\n   278\t    fn delete_project(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<()> {\n   279\t        let project_root = FileSystem::project_root(base_dir, project_id);\n   280\t        if !project_root.is_dir() {\n   281\t            return Err(AppError::ProjectNotFound {\n   282\t                project_id: project_id.to_string(),\n   283\t            });\n   284\t        }\n   285\t\n   286\t        // Transactional delete: rename to a trash path first, then remove.\n   287\t        // If removal fails, rename back so the project remains addressable.\n   288\t        let trash_name = format!(\".{}.deleting.{}\", project_id, std::process::id());\n   289\t        let trash_path = project_root\n   290\t            .parent()\n   291\t            .expect(\"project root has parent\")\n   292\t            .join(&trash_name);\n   293\t\n   294\t        // Phase 1: atomic rename to trash location\n   295\t        fs::rename(&project_root, &trash_path)?;\n   296\t\n   297\t        // Phase 2: remove the trash directory\n   298\t        if let Err(remove_err) = fs::remove_dir_all(&trash_path) {\n   299\t            // Removal failed — restore the project to its original path.\n   300\t            // The spec requires that a failed delete leaves the project addressable,\n   301\t            // so we must guarantee the restore succeeds. If rename-back fails, fall\n   302\t            // back to copying the entire tree back before returning the error.\n   303\t            if fs::rename(&trash_path, &project_root).is_err() {\n   304\t                // Rename-back failed (e.g., partial removal left an inconsistent\n   305\t                // state). Use a recursive copy as a last resort to restore\n   306\t                // addressability, then clean up the trash path.\n   307\t                if let Err(copy_err) = copy_dir_recursive(&trash_path, &project_root) {\n   308\t                    // Even the copy fallback failed. Return a compound error that\n   309\t                    // makes the situation clear to the operator.\n   310\t                    return Err(AppError::CorruptRecord {\n   311\t                        file: format!(\"projects/{}\", project_id),\n   312\t                        details: format!(\n   313\t                            \"delete failed and project could not be restored: remove error: {}, restore error: {}\",\n   314\t                            remove_err, copy_err\n   315\t                        ),\n   316\t                    });\n   317\t                }\n   318\t                // Copy succeeded — clean up the trash remnants (best effort).\n   319\t                let _ = fs::remove_dir_all(&trash_path);\n   320\t            }\n   321\t            return Err(remove_err.into());\n   322\t        }\n   323\t\n   324\t        Ok(())\n   325\t    }\n   326\t\n   327\t    fn create_project_atomic(\n   328\t        &self,\n   329\t        base_dir: &Path,\n   330\t        record: &ProjectRecord,\n   331\t        prompt_contents: &str,\n   332\t        run_snapshot: &RunSnapshot,\n   333\t        initial_journal_line: &str,\n   334\t        sessions: &SessionStore,\n   335\t    ) -> AppResult<()> {\n   336\t        let project_root = FileSystem::project_root(base_dir, &record.id);\n   337\t\n   338\t        // Stage into a temporary directory alongside the final location\n   339\t        let staging_name = format!(\".{}.staging.{}\", record.id, std::process::id());\n   340\t        let staging_root = project_root\n   341\t            .parent()\n   342\t            .expect(\"project root has parent\")\n   343\t            .join(&staging_name);\n   344\t\n   345\t        // Clean up any leftover staging dir\n   346\t        if staging_root.exists() {\n   347\t            fs::remove_dir_all(&staging_root)?;\n   348\t        }\n   349\t\n   350\t        // Create staging directory and all subdirs\n   351\t        fs::create_dir_all(&staging_root)?;\n   352\t        for subdir in PROJECT_SUBDIRS {\n   353\t            fs::create_dir_all(staging_root.join(subdir))?;\n   354\t        }\n   355\t\n   356\t        // Write all canonical files into staging\n   357\t        let write_result = (|| -> AppResult<()> {\n   358\t            // project.toml\n   359\t            let project_toml = toml::to_string_pretty(record).map_err(|e| {\n   360\t                AppError::Io(std::io::Error::other(e.to_string()))\n   361\t            })?;\n   362\t            fs::write(staging_root.join(PROJECT_CONFIG_FILE), project_toml)?;\n   363\t\n   364\t            // prompt.md\n   365\t            fs::write(staging_root.join(PROMPT_FILE), prompt_contents)?;\n   366\t\n   367\t            // run.json\n   368\t            let run_json = serde_json::to_string_pretty(run_snapshot)?;\n   369\t            fs::write(staging_root.join(RUN_FILE), run_json)?;\n   370\t\n   371\t            // journal.ndjson (with initial event)\n   372\t            let mut journal_content = initial_journal_line.to_owned();\n   373\t            journal_content.push('\\n');\n   374\t            fs::write(staging_root.join(JOURNAL_FILE), journal_content)?;\n   375\t\n   376\t            // sessions.json\n   377\t            let sessions_json = serde_json::to_string_pretty(sessions)?;\n   378\t            fs::write(staging_root.join(SESSIONS_FILE), sessions_json)?;\n   379\t\n   380\t            Ok(())\n   381\t        })();\n   382\t\n   383\t        if let Err(e) = write_result {\n   384\t            // Clean up staging on failure\n   385\t            let _ = fs::remove_dir_all(&staging_root);\n   386\t            return Err(e);\n   387\t        }\n   388\t\n   389\t        // Atomic rename from staging to final location\n   390\t        if let Err(e) = fs::rename(&staging_root, &project_root) {\n   391\t            let _ = fs::remove_dir_all(&staging_root);\n   392\t            return Err(e.into());\n   393\t        }\n   394\t\n   395\t        Ok(())\n   396\t    }\n   397\t}\n   398\t\n   399\t/// Filesystem-backed implementation of `JournalStorePort`.\n   400\tpub struct FsJournalStore;\n   401\t\n   402\timpl JournalStorePort for FsJournalStore {\n   403\t    fn read_journal(\n   404\t        &self,\n   405\t        base_dir: &Path,\n   406\t        project_id: &ProjectId,\n   407\t    ) -> AppResult<Vec<JournalEvent>> {\n   408\t        let path = FileSystem::project_root(base_dir, project_id).join(JOURNAL_FILE);\n   409\t        match fs::read_to_string(&path) {\n   410\t            Ok(contents) => journal::parse_journal(&contents),\n   411\t            Err(e) if e.kind() == std::io::ErrorKind::NotFound => {\n   412\t                Err(AppError::CorruptRecord {\n   413\t                    file: format!(\"projects/{}/journal.ndjson\", project_id),\n   414\t                    details: \"canonical file is missing\".to_owned(),\n   415\t                })\n   416\t            }\n   417\t            Err(e) => Err(e.into()),\n   418\t        }\n   419\t    }\n   420\t\n   421\t    fn append_event(\n   422\t        &self,\n   423\t        base_dir: &Path,\n   424\t        project_id: &ProjectId,\n   425\t        line: &str,\n   426\t    ) -> AppResult<()> {\n   427\t        let path = FileSystem::project_root(base_dir, project_id).join(JOURNAL_FILE);\n   428\t        FileSystem::append_line(&path, line)\n   429\t    }\n   430\t}\n   431\t\n   432\t/// Filesystem-backed implementation of `ArtifactStorePort`.\n   433\tpub struct FsArtifactStore;\n   434\t\n   435\timpl ArtifactStorePort for FsArtifactStore {\n   436\t    fn list_payloads(\n   437\t        &self,\n   438\t        base_dir: &Path,\n   439\t        project_id: &ProjectId,\n   440\t    ) -> AppResult<Vec<PayloadRecord>> {\n   441\t        let dir = FileSystem::project_root(base_dir, project_id).join(\"history/payloads\");\n   442\t        if !dir.is_dir() {\n   443\t            return Ok(Vec::new());\n   444\t        }\n   445\t\n   446\t        let mut records = Vec::new();\n   447\t        for entry in fs::read_dir(&dir)? {\n   448\t            let entry = entry?;\n   449\t            let path = entry.path();\n   450\t            if path.extension().is_some_and(|ext| ext == \"json\") {\n   451\t                let raw = fs::read_to_string(&path)?;\n   452\t                let record: PayloadRecord = serde_json::from_str(&raw).map_err(|e| {\n   453\t                    AppError::CorruptRecord {\n   454\t                        file: format!(\n   455\t                            \"history/payloads/{}\",\n   456\t                            path.file_name()\n   457\t                                .unwrap_or_default()\n   458\t                                .to_string_lossy()\n   459\t                        ),\n   460\t                        details: e.to_string(),\n   461\t                    }\n   462\t                })?;\n   463\t                records.push(record);\n   464\t            }\n   465\t        }\n   466\t\n   467\t        records.sort_by_key(|r| r.created_at);\n   468\t        Ok(records)\n   469\t    }\n   470\t\n   471\t    fn list_artifacts(\n   472\t        &self,\n   473\t        base_dir: &Path,\n   474\t        project_id: &ProjectId,\n   475\t    ) -> AppResult<Vec<ArtifactRecord>> {\n   476\t        let dir = FileSystem::project_root(base_dir, project_id).join(\"history/artifacts\");\n   477\t        if !dir.is_dir() {\n   478\t            return Ok(Vec::new());\n   479\t        }\n   480\t\n   481\t        let mut records = Vec::new();\n   482\t        for entry in fs::read_dir(&dir)? {\n   483\t            let entry = entry?;\n   484\t            let path = entry.path();\n   485\t            if path.extension().is_some_and(|ext| ext == \"json\") {\n   486\t                let raw = fs::read_to_string(&path)?;\n   487\t                let record: ArtifactRecord =\n   488\t                    serde_json::from_str(&raw).map_err(|e| AppError::CorruptRecord {\n   489\t                        file: format!(\n   490\t                            \"history/artifacts/{}\",\n   491\t                            path.file_name()\n   492\t                                .unwrap_or_default()\n   493\t                                .to_string_lossy()\n   494\t                        ),\n   495\t                        details: e.to_string(),\n   496\t                    })?;\n   497\t                records.push(record);\n   498\t            }\n   499\t        }\n   500\t\n   501\t        records.sort_by_key(|r| r.created_at);\n   502\t        Ok(records)\n   503\t    }\n   504\t}\n   505\t\n   506\t/// Filesystem-backed implementation of `RuntimeLogStorePort`.\n   507\tpub struct FsRuntimeLogStore;\n   508\t\n   509\timpl RuntimeLogStorePort for FsRuntimeLogStore {\n   510\t    fn read_runtime_logs(\n   511\t        &self,\n   512\t        base_dir: &Path,\n   513\t        project_id: &ProjectId,\n   514\t    ) -> AppResult<Vec<RuntimeLogEntry>> {\n   515\t        let dir = FileSystem::project_root(base_dir, project_id).join(\"runtime/logs\");\n   516\t        if !dir.is_dir() {\n   517\t            return Ok(Vec::new());\n   518\t        }\n   519\t\n   520\t        let mut entries = Vec::new();\n   521\t        let mut paths: Vec<_> = fs::read_dir(&dir)?\n   522\t            .filter_map(|e| e.ok())\n   523\t            .map(|e| e.path())\n   524\t            .filter(|p| p.extension().is_some_and(|ext| ext == \"ndjson\"))\n   525\t            .collect();\n   526\t        paths.sort();\n   527\t\n   528\t        for path in paths {\n   529\t            let contents = fs::read_to_string(&path)?;\n   530\t            for line in contents.lines() {\n   531\t                let trimmed = line.trim();\n   532\t                if trimmed.is_empty() {\n   533\t                    continue;\n   534\t                }\n   535\t                if let Ok(entry) = serde_json::from_str::<RuntimeLogEntry>(trimmed) {\n   536\t                    entries.push(entry);\n   537\t                }\n   538\t            }\n   539\t        }\n   540\t\n   541\t        Ok(entries)\n   542\t    }\n   543\t}\n   544\t\n   545\t/// Filesystem-backed implementation of `RunSnapshotPort`.\n   546\tpub struct FsRunSnapshotStore;\n   547\t\n   548\timpl RunSnapshotPort for FsRunSnapshotStore {\n   549\t    fn read_run_snapshot(\n   550\t        &self,\n   551\t        base_dir: &Path,\n   552\t        project_id: &ProjectId,\n   553\t    ) -> AppResult<RunSnapshot> {\n   554\t        let path = FileSystem::project_root(base_dir, project_id).join(RUN_FILE);\n   555\t        match fs::read_to_string(&path) {\n   556\t            Ok(raw) => {\n   557\t                let snapshot: RunSnapshot =\n   558\t                    serde_json::from_str(&raw).map_err(|e| AppError::CorruptRecord {\n   559\t                        file: format!(\"projects/{}/run.json\", project_id),\n   560\t                        details: e.to_string(),\n   561\t                    })?;\n   562\t                // Semantic validation: reject inconsistent status/active_run combinations\n   563\t                snapshot\n   564\t                    .validate_semantics()\n   565\t                    .map_err(|details| AppError::CorruptRecord {\n   566\t                        file: format!(\"projects/{}/run.json\", project_id),\n   567\t                        details,\n   568\t                    })?;\n   569\t                Ok(snapshot)\n   570\t            }\n   571\t            Err(e) if e.kind() == std::io::ErrorKind::NotFound => {\n   572\t                Err(AppError::CorruptRecord {\n   573\t                    file: format!(\"projects/{}/run.json\", project_id),\n   574\t                    details: \"canonical file is missing\".to_owned(),\n   575\t                })\n   576\t            }\n   577\t            Err(e) => Err(e.into()),\n   578\t        }\n   579\t    }\n   580\t}\n   581\t\n   582\t/// Filesystem-backed implementation of `ActiveProjectPort`.\n   583\tpub struct FsActiveProjectStore;\n   584\t\n   585\timpl ActiveProjectPort for FsActiveProjectStore {\n   586\t    fn read_active_project_id(&self, base_dir: &Path) -> AppResult<Option<String>> {\n   587\t        FileSystem::read_active_project(&FileSystem::workspace_root_path(base_dir))\n   588\t    }\n   589\t\n   590\t    fn clear_active_project(&self, base_dir: &Path) -> AppResult<()> {\n   591\t        let path = FileSystem::workspace_root_path(base_dir).join(ACTIVE_PROJECT_FILE);\n   592\t        match fs::remove_file(&path) {\n   593\t            Ok(()) => Ok(()),\n   594\t            Err(e) if e.kind() == std::io::ErrorKind::NotFound => Ok(()),\n   595\t            Err(e) => Err(e.into()),\n   596\t        }\n   597\t    }\n   598\t\n   599\t    fn write_active_project(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<()> {\n   600\t        FileSystem::write_active_project(\n   601\t            &FileSystem::workspace_root_path(base_dir),\n   602\t            project_id.as_str(),\n   603\t        )\n   604\t    }\n   605\t}\n   606\t\n   607\t/// Recursively copy a directory tree from `src` to `dst`.\n   608\t/// Used as a fallback when rename-based restore fails during transactional delete.\n   609\tfn copy_dir_recursive(src: &Path, dst: &Path) -> std::io::Result<()> {\n   610\t    fs::create_dir_all(dst)?;\n   611\t    for entry in fs::read_dir(src)? {\n   612\t        let entry = entry?;\n   613\t        let src_path = entry.path();\n   614\t        let dst_path = dst.join(entry.file_name());\n   615\t        if entry.file_type()?.is_dir() {\n   616\t            copy_dir_recursive(&src_path, &dst_path)?;\n   617\t        } else {\n   618\t            fs::copy(&src_path, &dst_path)?;\n   619\t        }\n   620\t    }\n   621\t    Ok(())\n   622\t}\n","exit_code":0,"status":"completed"}}
