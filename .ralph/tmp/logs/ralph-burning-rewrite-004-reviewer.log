{"type":"item.completed","item":{"id":"item_22","type":"command_execution","command":"/run/current-system/sw/bin/bash -lc \"nl -ba /root/new-ralph-burning/ralph-burning-rewrite/tests/unit/project_run_record_test.rs | sed -n '1,420p'\"","aggregated_output":"     1\tuse std::path::Path;\n     2\t\n     3\tuse chrono::{TimeZone, Utc};\n     4\t\n     5\tuse ralph_burning::contexts::project_run_record::model::*;\n     6\tuse ralph_burning::contexts::project_run_record::service::*;\n     7\tuse ralph_burning::shared::domain::{FlowPreset, ProjectId};\n     8\tuse ralph_burning::shared::error::{AppError, AppResult};\n     9\t\n    10\t// ── Fake implementations of ports for service-level testing ──\n    11\t\n    12\tstruct FakeProjectStore {\n    13\t    existing_ids: Vec<String>,\n    14\t}\n    15\t\n    16\timpl FakeProjectStore {\n    17\t    fn empty() -> Self {\n    18\t        Self {\n    19\t            existing_ids: Vec::new(),\n    20\t        }\n    21\t    }\n    22\t\n    23\t    fn with_existing(ids: &[&str]) -> Self {\n    24\t        Self {\n    25\t            existing_ids: ids.iter().map(|s| s.to_string()).collect(),\n    26\t        }\n    27\t    }\n    28\t}\n    29\t\n    30\timpl ProjectStorePort for FakeProjectStore {\n    31\t    fn project_exists(&self, _base_dir: &Path, project_id: &ProjectId) -> AppResult<bool> {\n    32\t        Ok(self.existing_ids.contains(&project_id.to_string()))\n    33\t    }\n    34\t\n    35\t    fn read_project_record(\n    36\t        &self,\n    37\t        _base_dir: &Path,\n    38\t        project_id: &ProjectId,\n    39\t    ) -> AppResult<ProjectRecord> {\n    40\t        if !self.existing_ids.contains(&project_id.to_string()) {\n    41\t            return Err(AppError::ProjectNotFound {\n    42\t                project_id: project_id.to_string(),\n    43\t            });\n    44\t        }\n    45\t        Ok(make_project_record(project_id.as_str()))\n    46\t    }\n    47\t\n    48\t    fn list_project_ids(&self, _base_dir: &Path) -> AppResult<Vec<ProjectId>> {\n    49\t        self.existing_ids\n    50\t            .iter()\n    51\t            .map(|id| ProjectId::new(id.as_str()))\n    52\t            .collect()\n    53\t    }\n    54\t\n    55\t    fn delete_project(&self, _base_dir: &Path, project_id: &ProjectId) -> AppResult<()> {\n    56\t        if !self.existing_ids.contains(&project_id.to_string()) {\n    57\t            return Err(AppError::ProjectNotFound {\n    58\t                project_id: project_id.to_string(),\n    59\t            });\n    60\t        }\n    61\t        Ok(())\n    62\t    }\n    63\t\n    64\t    fn create_project_atomic(\n    65\t        &self,\n    66\t        _base_dir: &Path,\n    67\t        _record: &ProjectRecord,\n    68\t        _prompt_contents: &str,\n    69\t        _run_snapshot: &RunSnapshot,\n    70\t        _initial_journal_line: &str,\n    71\t        _sessions: &SessionStore,\n    72\t    ) -> AppResult<()> {\n    73\t        Ok(())\n    74\t    }\n    75\t}\n    76\t\n    77\tstruct FakeJournalStore;\n    78\t\n    79\timpl JournalStorePort for FakeJournalStore {\n    80\t    fn read_journal(\n    81\t        &self,\n    82\t        _base_dir: &Path,\n    83\t        _project_id: &ProjectId,\n    84\t    ) -> AppResult<Vec<JournalEvent>> {\n    85\t        Ok(vec![make_project_created_event()])\n    86\t    }\n    87\t\n    88\t    fn append_event(\n    89\t        &self,\n    90\t        _base_dir: &Path,\n    91\t        _project_id: &ProjectId,\n    92\t        _line: &str,\n    93\t    ) -> AppResult<()> {\n    94\t        Ok(())\n    95\t    }\n    96\t}\n    97\t\n    98\tstruct FakeRunSnapshotStore {\n    99\t    has_active_run: bool,\n   100\t}\n   101\t\n   102\timpl FakeRunSnapshotStore {\n   103\t    fn no_run() -> Self {\n   104\t        Self {\n   105\t            has_active_run: false,\n   106\t        }\n   107\t    }\n   108\t\n   109\t    fn active_run() -> Self {\n   110\t        Self {\n   111\t            has_active_run: true,\n   112\t        }\n   113\t    }\n   114\t}\n   115\t\n   116\timpl RunSnapshotPort for FakeRunSnapshotStore {\n   117\t    fn read_run_snapshot(\n   118\t        &self,\n   119\t        _base_dir: &Path,\n   120\t        _project_id: &ProjectId,\n   121\t    ) -> AppResult<RunSnapshot> {\n   122\t        if self.has_active_run {\n   123\t            Ok(RunSnapshot {\n   124\t                active_run: Some(ActiveRun {\n   125\t                    run_id: \"run-1\".to_owned(),\n   126\t                    stage_cursor: ralph_burning::shared::domain::StageCursor::initial(\n   127\t                        ralph_burning::shared::domain::StageId::Planning,\n   128\t                    ),\n   129\t                    started_at: test_timestamp(),\n   130\t                }),\n   131\t                status: RunStatus::Running,\n   132\t                cycle_history: Vec::new(),\n   133\t                completion_rounds: 0,\n   134\t                rollback_point_meta: RollbackPointMeta::default(),\n   135\t                amendment_queue: AmendmentQueueState::default(),\n   136\t                status_summary: \"running\".to_owned(),\n   137\t            })\n   138\t        } else {\n   139\t            Ok(RunSnapshot::initial())\n   140\t        }\n   141\t    }\n   142\t}\n   143\t\n   144\tstruct FakeActiveProjectStore {\n   145\t    active_id: Option<String>,\n   146\t}\n   147\t\n   148\timpl FakeActiveProjectStore {\n   149\t    fn none() -> Self {\n   150\t        Self { active_id: None }\n   151\t    }\n   152\t\n   153\t    fn with_active(id: &str) -> Self {\n   154\t        Self {\n   155\t            active_id: Some(id.to_owned()),\n   156\t        }\n   157\t    }\n   158\t}\n   159\t\n   160\timpl ActiveProjectPort for FakeActiveProjectStore {\n   161\t    fn read_active_project_id(&self, _base_dir: &Path) -> AppResult<Option<String>> {\n   162\t        Ok(self.active_id.clone())\n   163\t    }\n   164\t\n   165\t    fn clear_active_project(&self, _base_dir: &Path) -> AppResult<()> {\n   166\t        Ok(())\n   167\t    }\n   168\t\n   169\t    fn write_active_project(\n   170\t        &self,\n   171\t        _base_dir: &Path,\n   172\t        _project_id: &ProjectId,\n   173\t    ) -> AppResult<()> {\n   174\t        Ok(())\n   175\t    }\n   176\t}\n   177\t\n   178\t// ── Helpers ──\n   179\t\n   180\tfn test_timestamp() -> chrono::DateTime<Utc> {\n   181\t    Utc.with_ymd_and_hms(2026, 3, 11, 19, 0, 0)\n   182\t        .single()\n   183\t        .expect(\"valid timestamp\")\n   184\t}\n   185\t\n   186\tfn make_project_record(id: &str) -> ProjectRecord {\n   187\t    ProjectRecord {\n   188\t        id: ProjectId::new(id).unwrap(),\n   189\t        name: format!(\"Project {id}\"),\n   190\t        flow: FlowPreset::Standard,\n   191\t        prompt_reference: \"prompt.md\".to_owned(),\n   192\t        prompt_hash: \"abc123\".to_owned(),\n   193\t        created_at: test_timestamp(),\n   194\t        status_summary: ProjectStatusSummary::Created,\n   195\t    }\n   196\t}\n   197\t\n   198\tfn make_project_created_event() -> JournalEvent {\n   199\t    JournalEvent {\n   200\t        sequence: 1,\n   201\t        timestamp: test_timestamp(),\n   202\t        event_type: JournalEventType::ProjectCreated,\n   203\t        details: serde_json::json!({\"project_id\": \"alpha\", \"flow\": \"standard\"}),\n   204\t    }\n   205\t}\n   206\t\n   207\tfn dummy_base_dir() -> std::path::PathBuf {\n   208\t    std::path::PathBuf::from(\"/tmp/test\")\n   209\t}\n   210\t\n   211\t// ── Domain Tests ──\n   212\t\n   213\t#[test]\n   214\tfn run_snapshot_initial_has_no_active_run() {\n   215\t    let snapshot = RunSnapshot::initial();\n   216\t    assert!(!snapshot.has_active_run());\n   217\t    assert_eq!(snapshot.status, RunStatus::NotStarted);\n   218\t}\n   219\t\n   220\t#[test]\n   221\tfn session_store_empty_has_no_sessions() {\n   222\t    let store = SessionStore::empty();\n   223\t    assert!(store.sessions.is_empty());\n   224\t}\n   225\t\n   226\t#[test]\n   227\tfn project_record_flow_is_immutable_after_creation() {\n   228\t    let record = make_project_record(\"alpha\");\n   229\t    assert_eq!(record.flow, FlowPreset::Standard);\n   230\t    // Flow is a plain field with no setter — immutability enforced by\n   231\t    // not providing mutation methods on ProjectRecord.\n   232\t}\n   233\t\n   234\t#[test]\n   235\tfn journal_event_types_serialize_to_snake_case() {\n   236\t    let event = make_project_created_event();\n   237\t    let json = serde_json::to_string(&event).expect(\"serialize\");\n   238\t    assert!(json.contains(\"\\\"project_created\\\"\"));\n   239\t}\n   240\t\n   241\t// ── Service Tests with Fake Ports ──\n   242\t\n   243\t#[test]\n   244\tfn create_project_succeeds_with_valid_input() {\n   245\t    let store = FakeProjectStore::empty();\n   246\t    let journal_store = FakeJournalStore;\n   247\t    let base_dir = dummy_base_dir();\n   248\t\n   249\t    let input = CreateProjectInput {\n   250\t        id: ProjectId::new(\"alpha\").unwrap(),\n   251\t        name: \"Alpha Project\".to_owned(),\n   252\t        flow: FlowPreset::Standard,\n   253\t        prompt_path: \"prompt.md\".to_owned(),\n   254\t        prompt_contents: \"# My prompt\\nDo something.\".to_owned(),\n   255\t        prompt_hash: \"hash123\".to_owned(),\n   256\t        created_at: test_timestamp(),\n   257\t    };\n   258\t\n   259\t    let result = create_project(&store, &journal_store, &base_dir, input);\n   260\t    assert!(result.is_ok());\n   261\t\n   262\t    let record = result.unwrap();\n   263\t    assert_eq!(record.id.as_str(), \"alpha\");\n   264\t    assert_eq!(record.flow, FlowPreset::Standard);\n   265\t    assert_eq!(record.status_summary, ProjectStatusSummary::Created);\n   266\t}\n   267\t\n   268\t#[test]\n   269\tfn create_project_fails_on_duplicate_id() {\n   270\t    let store = FakeProjectStore::with_existing(&[\"alpha\"]);\n   271\t    let journal_store = FakeJournalStore;\n   272\t    let base_dir = dummy_base_dir();\n   273\t\n   274\t    let input = CreateProjectInput {\n   275\t        id: ProjectId::new(\"alpha\").unwrap(),\n   276\t        name: \"Alpha Again\".to_owned(),\n   277\t        flow: FlowPreset::Standard,\n   278\t        prompt_path: \"prompt.md\".to_owned(),\n   279\t        prompt_contents: \"content\".to_owned(),\n   280\t        prompt_hash: \"hash\".to_owned(),\n   281\t        created_at: test_timestamp(),\n   282\t    };\n   283\t\n   284\t    let result = create_project(&store, &journal_store, &base_dir, input);\n   285\t    assert!(result.is_err());\n   286\t    assert!(matches!(\n   287\t        result.unwrap_err(),\n   288\t        AppError::DuplicateProject { .. }\n   289\t    ));\n   290\t}\n   291\t\n   292\t#[test]\n   293\tfn list_projects_returns_entries_with_active_flag() {\n   294\t    let store = FakeProjectStore::with_existing(&[\"alpha\", \"beta\"]);\n   295\t    let active_store = FakeActiveProjectStore::with_active(\"alpha\");\n   296\t    let base_dir = dummy_base_dir();\n   297\t\n   298\t    let entries = list_projects(&store, &active_store, &base_dir).unwrap();\n   299\t    assert_eq!(entries.len(), 2);\n   300\t\n   301\t    let alpha = entries.iter().find(|e| e.id.as_str() == \"alpha\").unwrap();\n   302\t    assert!(alpha.is_active);\n   303\t\n   304\t    let beta = entries.iter().find(|e| e.id.as_str() == \"beta\").unwrap();\n   305\t    assert!(!beta.is_active);\n   306\t}\n   307\t\n   308\t#[test]\n   309\tfn list_projects_with_no_active_project() {\n   310\t    let store = FakeProjectStore::with_existing(&[\"alpha\"]);\n   311\t    let active_store = FakeActiveProjectStore::none();\n   312\t    let base_dir = dummy_base_dir();\n   313\t\n   314\t    let entries = list_projects(&store, &active_store, &base_dir).unwrap();\n   315\t    assert_eq!(entries.len(), 1);\n   316\t    assert!(!entries[0].is_active);\n   317\t}\n   318\t\n   319\t#[test]\n   320\tfn show_project_returns_detail() {\n   321\t    let store = FakeProjectStore::with_existing(&[\"alpha\"]);\n   322\t    let run_store = FakeRunSnapshotStore::no_run();\n   323\t    let journal_store = FakeJournalStore;\n   324\t    let active_store = FakeActiveProjectStore::with_active(\"alpha\");\n   325\t    let base_dir = dummy_base_dir();\n   326\t    let pid = ProjectId::new(\"alpha\").unwrap();\n   327\t\n   328\t    let detail =\n   329\t        show_project(&store, &run_store, &journal_store, &active_store, &base_dir, &pid).unwrap();\n   330\t\n   331\t    assert_eq!(detail.record.id.as_str(), \"alpha\");\n   332\t    assert!(detail.is_active);\n   333\t    assert_eq!(detail.journal_event_count, 1);\n   334\t    assert!(!detail.run_snapshot.has_active_run());\n   335\t}\n   336\t\n   337\t#[test]\n   338\tfn show_project_fails_for_missing_project() {\n   339\t    let store = FakeProjectStore::empty();\n   340\t    let run_store = FakeRunSnapshotStore::no_run();\n   341\t    let journal_store = FakeJournalStore;\n   342\t    let active_store = FakeActiveProjectStore::none();\n   343\t    let base_dir = dummy_base_dir();\n   344\t    let pid = ProjectId::new(\"missing\").unwrap();\n   345\t\n   346\t    let result =\n   347\t        show_project(&store, &run_store, &journal_store, &active_store, &base_dir, &pid);\n   348\t    assert!(matches!(\n   349\t        result.unwrap_err(),\n   350\t        AppError::ProjectNotFound { .. }\n   351\t    ));\n   352\t}\n   353\t\n   354\t#[test]\n   355\tfn delete_project_succeeds_when_no_active_run() {\n   356\t    let store = FakeProjectStore::with_existing(&[\"alpha\"]);\n   357\t    let run_store = FakeRunSnapshotStore::no_run();\n   358\t    let active_store = FakeActiveProjectStore::none();\n   359\t    let base_dir = dummy_base_dir();\n   360\t    let pid = ProjectId::new(\"alpha\").unwrap();\n   361\t\n   362\t    let result = delete_project(&store, &run_store, &active_store, &base_dir, &pid);\n   363\t    assert!(result.is_ok());\n   364\t}\n   365\t\n   366\t#[test]\n   367\tfn delete_project_fails_with_active_run() {\n   368\t    let store = FakeProjectStore::with_existing(&[\"alpha\"]);\n   369\t    let run_store = FakeRunSnapshotStore::active_run();\n   370\t    let active_store = FakeActiveProjectStore::none();\n   371\t    let base_dir = dummy_base_dir();\n   372\t    let pid = ProjectId::new(\"alpha\").unwrap();\n   373\t\n   374\t    let result = delete_project(&store, &run_store, &active_store, &base_dir, &pid);\n   375\t    assert!(matches!(\n   376\t        result.unwrap_err(),\n   377\t        AppError::ActiveRunDelete { .. }\n   378\t    ));\n   379\t}\n   380\t\n   381\t#[test]\n   382\tfn delete_project_fails_for_missing_project() {\n   383\t    let store = FakeProjectStore::empty();\n   384\t    let run_store = FakeRunSnapshotStore::no_run();\n   385\t    let active_store = FakeActiveProjectStore::none();\n   386\t    let base_dir = dummy_base_dir();\n   387\t    let pid = ProjectId::new(\"missing\").unwrap();\n   388\t\n   389\t    let result = delete_project(&store, &run_store, &active_store, &base_dir, &pid);\n   390\t    assert!(matches!(\n   391\t        result.unwrap_err(),\n   392\t        AppError::ProjectNotFound { .. }\n   393\t    ));\n   394\t}\n   395\t\n   396\t#[test]\n   397\tfn run_status_reports_not_started_when_no_active_run() {\n   398\t    let run_store = FakeRunSnapshotStore::no_run();\n   399\t    let base_dir = dummy_base_dir();\n   400\t    let pid = ProjectId::new(\"alpha\").unwrap();\n   401\t\n   402\t    let status = run_status(&run_store, &base_dir, &pid).unwrap();\n   403\t    assert_eq!(status.status, \"not started\");\n   404\t    assert!(status.stage.is_none());\n   405\t    assert!(status.cycle.is_none());\n   406\t}\n   407\t\n   408\t#[test]\n   409\tfn run_status_reports_running_with_stage_cursor() {\n   410\t    let run_store = FakeRunSnapshotStore::active_run();\n   411\t    let base_dir = dummy_base_dir();\n   412\t    let pid = ProjectId::new(\"alpha\").unwrap();\n   413\t\n   414\t    let status = run_status(&run_store, &base_dir, &pid).unwrap();\n   415\t    assert_eq!(status.status, \"running\");\n   416\t    assert_eq!(status.stage, Some(\"planning\".to_owned()));\n   417\t    assert_eq!(status.cycle, Some(1));\n   418\t}\n   419\t\n   420\t// ── Semantic Validation ──\n","exit_code":0,"status":"completed"}}
{"type":"item.completed","item":{"id":"item_23","type":"command_execution","command":"/run/current-system/sw/bin/bash -lc \"nl -ba /root/new-ralph-burning/ralph-burning-rewrite/tests/unit/adapter_contract_test.rs | sed -n '1,420p'\"","aggregated_output":"     1\t/// Adapter contract tests for filesystem-backed stores.\n     2\t/// Verifies round-trip persistence, corruption visibility, and edge cases\n     3\t/// for FsProjectStore, FsJournalStore, FsArtifactStore, FsRuntimeLogStore,\n     4\t/// FsRunSnapshotStore, and FsActiveProjectStore.\n     5\tuse std::fs;\n     6\t\n     7\tuse chrono::{TimeZone, Utc};\n     8\tuse tempfile::tempdir;\n     9\t\n    10\tuse ralph_burning::adapters::fs::{\n    11\t    FsActiveProjectStore, FsArtifactStore, FsJournalStore, FsProjectStore,\n    12\t    FsRuntimeLogStore, FsRunSnapshotStore, FileSystem,\n    13\t};\n    14\tuse ralph_burning::contexts::project_run_record::journal;\n    15\tuse ralph_burning::contexts::project_run_record::model::*;\n    16\tuse ralph_burning::contexts::project_run_record::service::{\n    17\t    ActiveProjectPort, ArtifactStorePort, JournalStorePort, ProjectStorePort,\n    18\t    RuntimeLogStorePort, RunSnapshotPort,\n    19\t};\n    20\tuse ralph_burning::shared::domain::{FlowPreset, ProjectId};\n    21\tuse ralph_burning::shared::error::AppError;\n    22\t\n    23\tfn test_timestamp() -> chrono::DateTime<Utc> {\n    24\t    Utc.with_ymd_and_hms(2026, 3, 11, 19, 0, 0)\n    25\t        .single()\n    26\t        .expect(\"valid timestamp\")\n    27\t}\n    28\t\n    29\tfn make_project_record(id: &str) -> ProjectRecord {\n    30\t    ProjectRecord {\n    31\t        id: ProjectId::new(id).unwrap(),\n    32\t        name: format!(\"Project {id}\"),\n    33\t        flow: FlowPreset::Standard,\n    34\t        prompt_reference: \"prompt.md\".to_owned(),\n    35\t        prompt_hash: \"abc123\".to_owned(),\n    36\t        created_at: test_timestamp(),\n    37\t        status_summary: ProjectStatusSummary::Created,\n    38\t    }\n    39\t}\n    40\t\n    41\tfn setup_workspace(base_dir: &std::path::Path) {\n    42\t    let ws = base_dir.join(\".ralph-burning\");\n    43\t    fs::create_dir_all(ws.join(\"projects\")).expect(\"create projects dir\");\n    44\t    let config = ralph_burning::shared::domain::WorkspaceConfig::new(test_timestamp());\n    45\t    let rendered = FileSystem::render_workspace_config(&config).expect(\"render config\");\n    46\t    FileSystem::write_atomic(&ws.join(\"workspace.toml\"), &rendered).expect(\"write config\");\n    47\t}\n    48\t\n    49\tfn create_project_on_disk(base_dir: &std::path::Path, id: &str) {\n    50\t    let store = FsProjectStore;\n    51\t    let record = make_project_record(id);\n    52\t    let snapshot = RunSnapshot::initial();\n    53\t    let sessions = SessionStore::empty();\n    54\t    let event = JournalEvent {\n    55\t        sequence: 1,\n    56\t        timestamp: test_timestamp(),\n    57\t        event_type: JournalEventType::ProjectCreated,\n    58\t        details: serde_json::json!({\"project_id\": id, \"flow\": \"standard\"}),\n    59\t    };\n    60\t    let journal_line = journal::serialize_event(&event).expect(\"serialize event\");\n    61\t    store\n    62\t        .create_project_atomic(base_dir, &record, \"# Prompt\\n\", &snapshot, &journal_line, &sessions)\n    63\t        .expect(\"create project\");\n    64\t}\n    65\t\n    66\t// ── FsProjectStore ──\n    67\t\n    68\t#[test]\n    69\tfn project_store_round_trip_create_and_read() {\n    70\t    let tmp = tempdir().unwrap();\n    71\t    setup_workspace(tmp.path());\n    72\t    create_project_on_disk(tmp.path(), \"alpha\");\n    73\t\n    74\t    let store = FsProjectStore;\n    75\t    let pid = ProjectId::new(\"alpha\").unwrap();\n    76\t    let record = store.read_project_record(tmp.path(), &pid).unwrap();\n    77\t\n    78\t    assert_eq!(record.id.as_str(), \"alpha\");\n    79\t    assert_eq!(record.flow, FlowPreset::Standard);\n    80\t    assert_eq!(record.prompt_reference, \"prompt.md\");\n    81\t    assert_eq!(record.prompt_hash, \"abc123\");\n    82\t    assert_eq!(record.status_summary, ProjectStatusSummary::Created);\n    83\t}\n    84\t\n    85\t#[test]\n    86\tfn project_store_exists_returns_true_for_created_project() {\n    87\t    let tmp = tempdir().unwrap();\n    88\t    setup_workspace(tmp.path());\n    89\t    create_project_on_disk(tmp.path(), \"alpha\");\n    90\t\n    91\t    let store = FsProjectStore;\n    92\t    let pid = ProjectId::new(\"alpha\").unwrap();\n    93\t    assert!(store.project_exists(tmp.path(), &pid).unwrap());\n    94\t}\n    95\t\n    96\t#[test]\n    97\tfn project_store_exists_returns_false_for_missing_project() {\n    98\t    let tmp = tempdir().unwrap();\n    99\t    setup_workspace(tmp.path());\n   100\t\n   101\t    let store = FsProjectStore;\n   102\t    let pid = ProjectId::new(\"nonexistent\").unwrap();\n   103\t    assert!(!store.project_exists(tmp.path(), &pid).unwrap());\n   104\t}\n   105\t\n   106\t#[test]\n   107\tfn project_store_list_returns_sorted_ids() {\n   108\t    let tmp = tempdir().unwrap();\n   109\t    setup_workspace(tmp.path());\n   110\t    create_project_on_disk(tmp.path(), \"beta\");\n   111\t    create_project_on_disk(tmp.path(), \"alpha\");\n   112\t\n   113\t    let store = FsProjectStore;\n   114\t    let ids = store.list_project_ids(tmp.path()).unwrap();\n   115\t    let id_strs: Vec<&str> = ids.iter().map(|p| p.as_str()).collect();\n   116\t    assert_eq!(id_strs, vec![\"alpha\", \"beta\"]);\n   117\t}\n   118\t\n   119\t#[test]\n   120\tfn project_store_delete_removes_project() {\n   121\t    let tmp = tempdir().unwrap();\n   122\t    setup_workspace(tmp.path());\n   123\t    create_project_on_disk(tmp.path(), \"alpha\");\n   124\t\n   125\t    let store = FsProjectStore;\n   126\t    let pid = ProjectId::new(\"alpha\").unwrap();\n   127\t    store.delete_project(tmp.path(), &pid).unwrap();\n   128\t    assert!(!store.project_exists(tmp.path(), &pid).unwrap());\n   129\t}\n   130\t\n   131\t#[test]\n   132\tfn project_store_read_missing_project_toml_returns_corrupt() {\n   133\t    let tmp = tempdir().unwrap();\n   134\t    setup_workspace(tmp.path());\n   135\t    create_project_on_disk(tmp.path(), \"alpha\");\n   136\t\n   137\t    // Remove project.toml but keep directory\n   138\t    let project_root = tmp.path().join(\".ralph-burning/projects/alpha\");\n   139\t    fs::remove_file(project_root.join(\"project.toml\")).unwrap();\n   140\t\n   141\t    let store = FsProjectStore;\n   142\t    let pid = ProjectId::new(\"alpha\").unwrap();\n   143\t    let err = store.read_project_record(tmp.path(), &pid).unwrap_err();\n   144\t    assert!(matches!(err, AppError::CorruptRecord { .. }));\n   145\t}\n   146\t\n   147\t#[test]\n   148\tfn project_store_exists_with_missing_project_toml_returns_corrupt() {\n   149\t    let tmp = tempdir().unwrap();\n   150\t    setup_workspace(tmp.path());\n   151\t    create_project_on_disk(tmp.path(), \"alpha\");\n   152\t\n   153\t    fs::remove_file(\n   154\t        tmp.path()\n   155\t            .join(\".ralph-burning/projects/alpha/project.toml\"),\n   156\t    )\n   157\t    .unwrap();\n   158\t\n   159\t    let store = FsProjectStore;\n   160\t    let pid = ProjectId::new(\"alpha\").unwrap();\n   161\t    let err = store.project_exists(tmp.path(), &pid).unwrap_err();\n   162\t    assert!(matches!(err, AppError::CorruptRecord { .. }));\n   163\t}\n   164\t\n   165\t#[test]\n   166\tfn project_store_list_with_corrupt_project_toml_returns_error() {\n   167\t    let tmp = tempdir().unwrap();\n   168\t    setup_workspace(tmp.path());\n   169\t    create_project_on_disk(tmp.path(), \"alpha\");\n   170\t\n   171\t    // Remove project.toml to simulate corruption\n   172\t    fs::remove_file(\n   173\t        tmp.path()\n   174\t            .join(\".ralph-burning/projects/alpha/project.toml\"),\n   175\t    )\n   176\t    .unwrap();\n   177\t\n   178\t    let store = FsProjectStore;\n   179\t    let err = store.list_project_ids(tmp.path()).unwrap_err();\n   180\t    assert!(matches!(err, AppError::CorruptRecord { .. }));\n   181\t}\n   182\t\n   183\t#[test]\n   184\tfn project_store_read_malformed_toml_returns_corrupt() {\n   185\t    let tmp = tempdir().unwrap();\n   186\t    setup_workspace(tmp.path());\n   187\t    create_project_on_disk(tmp.path(), \"alpha\");\n   188\t\n   189\t    // Write malformed TOML\n   190\t    fs::write(\n   191\t        tmp.path()\n   192\t            .join(\".ralph-burning/projects/alpha/project.toml\"),\n   193\t        \"this is not valid toml ][}{\",\n   194\t    )\n   195\t    .unwrap();\n   196\t\n   197\t    let store = FsProjectStore;\n   198\t    let pid = ProjectId::new(\"alpha\").unwrap();\n   199\t    let err = store.read_project_record(tmp.path(), &pid).unwrap_err();\n   200\t    assert!(matches!(err, AppError::CorruptRecord { .. }));\n   201\t}\n   202\t\n   203\t#[test]\n   204\tfn project_store_atomic_create_does_not_leave_staging_dirs() {\n   205\t    let tmp = tempdir().unwrap();\n   206\t    setup_workspace(tmp.path());\n   207\t    create_project_on_disk(tmp.path(), \"alpha\");\n   208\t\n   209\t    let projects_dir = tmp.path().join(\".ralph-burning/projects\");\n   210\t    for entry in fs::read_dir(&projects_dir).unwrap() {\n   211\t        let name = entry.unwrap().file_name();\n   212\t        let name_str = name.to_string_lossy();\n   213\t        assert!(\n   214\t            !name_str.starts_with('.'),\n   215\t            \"staging directory should not remain: {name_str}\"\n   216\t        );\n   217\t    }\n   218\t}\n   219\t\n   220\t// ── FsJournalStore ──\n   221\t\n   222\t#[test]\n   223\tfn journal_store_round_trip_read() {\n   224\t    let tmp = tempdir().unwrap();\n   225\t    setup_workspace(tmp.path());\n   226\t    create_project_on_disk(tmp.path(), \"alpha\");\n   227\t\n   228\t    let store = FsJournalStore;\n   229\t    let pid = ProjectId::new(\"alpha\").unwrap();\n   230\t    let events = store.read_journal(tmp.path(), &pid).unwrap();\n   231\t    assert_eq!(events.len(), 1);\n   232\t    assert_eq!(events[0].sequence, 1);\n   233\t    assert_eq!(events[0].event_type, JournalEventType::ProjectCreated);\n   234\t}\n   235\t\n   236\t#[test]\n   237\tfn journal_store_append_and_read() {\n   238\t    let tmp = tempdir().unwrap();\n   239\t    setup_workspace(tmp.path());\n   240\t    create_project_on_disk(tmp.path(), \"alpha\");\n   241\t\n   242\t    let store = FsJournalStore;\n   243\t    let pid = ProjectId::new(\"alpha\").unwrap();\n   244\t\n   245\t    let event = JournalEvent {\n   246\t        sequence: 2,\n   247\t        timestamp: test_timestamp(),\n   248\t        event_type: JournalEventType::RunStarted,\n   249\t        details: serde_json::json!({\"run_id\": \"run-1\"}),\n   250\t    };\n   251\t    let line = journal::serialize_event(&event).unwrap();\n   252\t    store.append_event(tmp.path(), &pid, &line).unwrap();\n   253\t\n   254\t    let events = store.read_journal(tmp.path(), &pid).unwrap();\n   255\t    assert_eq!(events.len(), 2);\n   256\t    assert_eq!(events[1].sequence, 2);\n   257\t    assert_eq!(events[1].event_type, JournalEventType::RunStarted);\n   258\t}\n   259\t\n   260\t#[test]\n   261\tfn journal_store_missing_file_returns_corrupt() {\n   262\t    let tmp = tempdir().unwrap();\n   263\t    setup_workspace(tmp.path());\n   264\t    create_project_on_disk(tmp.path(), \"alpha\");\n   265\t\n   266\t    fs::remove_file(\n   267\t        tmp.path()\n   268\t            .join(\".ralph-burning/projects/alpha/journal.ndjson\"),\n   269\t    )\n   270\t    .unwrap();\n   271\t\n   272\t    let store = FsJournalStore;\n   273\t    let pid = ProjectId::new(\"alpha\").unwrap();\n   274\t    let err = store.read_journal(tmp.path(), &pid).unwrap_err();\n   275\t    assert!(matches!(err, AppError::CorruptRecord { .. }));\n   276\t}\n   277\t\n   278\t#[test]\n   279\tfn journal_store_corrupt_json_returns_error() {\n   280\t    let tmp = tempdir().unwrap();\n   281\t    setup_workspace(tmp.path());\n   282\t    create_project_on_disk(tmp.path(), \"alpha\");\n   283\t\n   284\t    fs::write(\n   285\t        tmp.path()\n   286\t            .join(\".ralph-burning/projects/alpha/journal.ndjson\"),\n   287\t        \"{not valid json}\\n\",\n   288\t    )\n   289\t    .unwrap();\n   290\t\n   291\t    let store = FsJournalStore;\n   292\t    let pid = ProjectId::new(\"alpha\").unwrap();\n   293\t    let err = store.read_journal(tmp.path(), &pid).unwrap_err();\n   294\t    assert!(matches!(err, AppError::CorruptRecord { .. }));\n   295\t}\n   296\t\n   297\t// ── FsRunSnapshotStore ──\n   298\t\n   299\t#[test]\n   300\tfn run_snapshot_store_round_trip() {\n   301\t    let tmp = tempdir().unwrap();\n   302\t    setup_workspace(tmp.path());\n   303\t    create_project_on_disk(tmp.path(), \"alpha\");\n   304\t\n   305\t    let store = FsRunSnapshotStore;\n   306\t    let pid = ProjectId::new(\"alpha\").unwrap();\n   307\t    let snapshot = store.read_run_snapshot(tmp.path(), &pid).unwrap();\n   308\t\n   309\t    assert_eq!(snapshot.status, RunStatus::NotStarted);\n   310\t    assert!(snapshot.active_run.is_none());\n   311\t    assert!(snapshot.cycle_history.is_empty());\n   312\t    assert_eq!(snapshot.completion_rounds, 0);\n   313\t}\n   314\t\n   315\t#[test]\n   316\tfn run_snapshot_store_missing_file_returns_corrupt() {\n   317\t    let tmp = tempdir().unwrap();\n   318\t    setup_workspace(tmp.path());\n   319\t    create_project_on_disk(tmp.path(), \"alpha\");\n   320\t\n   321\t    fs::remove_file(tmp.path().join(\".ralph-burning/projects/alpha/run.json\")).unwrap();\n   322\t\n   323\t    let store = FsRunSnapshotStore;\n   324\t    let pid = ProjectId::new(\"alpha\").unwrap();\n   325\t    let err = store.read_run_snapshot(tmp.path(), &pid).unwrap_err();\n   326\t    assert!(matches!(err, AppError::CorruptRecord { .. }));\n   327\t}\n   328\t\n   329\t#[test]\n   330\tfn run_snapshot_store_corrupt_json_returns_error() {\n   331\t    let tmp = tempdir().unwrap();\n   332\t    setup_workspace(tmp.path());\n   333\t    create_project_on_disk(tmp.path(), \"alpha\");\n   334\t\n   335\t    fs::write(\n   336\t        tmp.path().join(\".ralph-burning/projects/alpha/run.json\"),\n   337\t        \"not json at all\",\n   338\t    )\n   339\t    .unwrap();\n   340\t\n   341\t    let store = FsRunSnapshotStore;\n   342\t    let pid = ProjectId::new(\"alpha\").unwrap();\n   343\t    let err = store.read_run_snapshot(tmp.path(), &pid).unwrap_err();\n   344\t    assert!(matches!(err, AppError::CorruptRecord { .. }));\n   345\t}\n   346\t\n   347\t#[test]\n   348\tfn run_snapshot_store_semantically_inconsistent_returns_corrupt() {\n   349\t    let tmp = tempdir().unwrap();\n   350\t    setup_workspace(tmp.path());\n   351\t    create_project_on_disk(tmp.path(), \"alpha\");\n   352\t\n   353\t    // Write a syntactically valid but semantically inconsistent run.json\n   354\t    let bad_snapshot = serde_json::json!({\n   355\t        \"active_run\": null,\n   356\t        \"status\": \"running\",\n   357\t        \"cycle_history\": [],\n   358\t        \"completion_rounds\": 0,\n   359\t        \"rollback_point_meta\": {\"last_rollback_id\": null, \"rollback_count\": 0},\n   360\t        \"amendment_queue\": {\"pending\": [], \"processed_count\": 0},\n   361\t        \"status_summary\": \"running\"\n   362\t    });\n   363\t    fs::write(\n   364\t        tmp.path().join(\".ralph-burning/projects/alpha/run.json\"),\n   365\t        serde_json::to_string_pretty(&bad_snapshot).unwrap(),\n   366\t    )\n   367\t    .unwrap();\n   368\t\n   369\t    let store = FsRunSnapshotStore;\n   370\t    let pid = ProjectId::new(\"alpha\").unwrap();\n   371\t    let err = store.read_run_snapshot(tmp.path(), &pid).unwrap_err();\n   372\t    assert!(matches!(err, AppError::CorruptRecord { .. }));\n   373\t}\n   374\t\n   375\t// ── FsArtifactStore ──\n   376\t\n   377\t#[test]\n   378\tfn artifact_store_empty_dirs_return_empty_vecs() {\n   379\t    let tmp = tempdir().unwrap();\n   380\t    setup_workspace(tmp.path());\n   381\t    create_project_on_disk(tmp.path(), \"alpha\");\n   382\t\n   383\t    let store = FsArtifactStore;\n   384\t    let pid = ProjectId::new(\"alpha\").unwrap();\n   385\t    assert!(store.list_payloads(tmp.path(), &pid).unwrap().is_empty());\n   386\t    assert!(store.list_artifacts(tmp.path(), &pid).unwrap().is_empty());\n   387\t}\n   388\t\n   389\t#[test]\n   390\tfn artifact_store_round_trip_payload() {\n   391\t    let tmp = tempdir().unwrap();\n   392\t    setup_workspace(tmp.path());\n   393\t    create_project_on_disk(tmp.path(), \"alpha\");\n   394\t\n   395\t    let payload = PayloadRecord {\n   396\t        payload_id: \"p1\".to_owned(),\n   397\t        stage_id: ralph_burning::shared::domain::StageId::Planning,\n   398\t        cycle: 1,\n   399\t        attempt: 1,\n   400\t        created_at: test_timestamp(),\n   401\t        payload: serde_json::json!({\"plan\": \"build it\"}),\n   402\t    };\n   403\t    let payload_json = serde_json::to_string_pretty(&payload).unwrap();\n   404\t    fs::write(\n   405\t        tmp.path()\n   406\t            .join(\".ralph-burning/projects/alpha/history/payloads/p1.json\"),\n   407\t        payload_json,\n   408\t    )\n   409\t    .unwrap();\n   410\t\n   411\t    let store = FsArtifactStore;\n   412\t    let pid = ProjectId::new(\"alpha\").unwrap();\n   413\t    let payloads = store.list_payloads(tmp.path(), &pid).unwrap();\n   414\t    assert_eq!(payloads.len(), 1);\n   415\t    assert_eq!(payloads[0].payload_id, \"p1\");\n   416\t}\n   417\t\n   418\t#[test]\n   419\tfn artifact_store_round_trip_artifact() {\n   420\t    let tmp = tempdir().unwrap();\n","exit_code":0,"status":"completed"}}
