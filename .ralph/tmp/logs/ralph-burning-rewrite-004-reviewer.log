{"type":"item.completed","item":{"id":"item_21","type":"command_execution","command":"/run/current-system/sw/bin/bash -lc \"nl -ba /root/new-ralph-burning/ralph-burning-rewrite/tests/unit/adapter_contract_test.rs | sed -n '1,340p'\"","aggregated_output":"     1\t/// Adapter contract tests for filesystem-backed stores.\n     2\t/// Verifies round-trip persistence, corruption visibility, and edge cases\n     3\t/// for FsProjectStore, FsJournalStore, FsArtifactStore, FsRuntimeLogStore,\n     4\t/// FsRunSnapshotStore, and FsActiveProjectStore.\n     5\tuse std::fs;\n     6\t\n     7\tuse chrono::{TimeZone, Utc};\n     8\tuse tempfile::tempdir;\n     9\t\n    10\tuse ralph_burning::adapters::fs::{\n    11\t    FsActiveProjectStore, FsArtifactStore, FsJournalStore, FsProjectStore,\n    12\t    FsRuntimeLogStore, FsRunSnapshotStore, FileSystem,\n    13\t};\n    14\tuse ralph_burning::contexts::project_run_record::journal;\n    15\tuse ralph_burning::contexts::project_run_record::model::*;\n    16\tuse ralph_burning::contexts::project_run_record::service::{\n    17\t    ActiveProjectPort, ArtifactStorePort, JournalStorePort, ProjectStorePort,\n    18\t    RuntimeLogStorePort, RunSnapshotPort,\n    19\t};\n    20\tuse ralph_burning::shared::domain::{FlowPreset, ProjectId};\n    21\tuse ralph_burning::shared::error::AppError;\n    22\t\n    23\tfn test_timestamp() -> chrono::DateTime<Utc> {\n    24\t    Utc.with_ymd_and_hms(2026, 3, 11, 19, 0, 0)\n    25\t        .single()\n    26\t        .expect(\"valid timestamp\")\n    27\t}\n    28\t\n    29\tfn make_project_record(id: &str) -> ProjectRecord {\n    30\t    ProjectRecord {\n    31\t        id: ProjectId::new(id).unwrap(),\n    32\t        name: format!(\"Project {id}\"),\n    33\t        flow: FlowPreset::Standard,\n    34\t        prompt_reference: \"prompt.md\".to_owned(),\n    35\t        prompt_hash: \"abc123\".to_owned(),\n    36\t        created_at: test_timestamp(),\n    37\t        status_summary: ProjectStatusSummary::Created,\n    38\t    }\n    39\t}\n    40\t\n    41\tfn setup_workspace(base_dir: &std::path::Path) {\n    42\t    let ws = base_dir.join(\".ralph-burning\");\n    43\t    fs::create_dir_all(ws.join(\"projects\")).expect(\"create projects dir\");\n    44\t    let config = ralph_burning::shared::domain::WorkspaceConfig::new(test_timestamp());\n    45\t    let rendered = FileSystem::render_workspace_config(&config).expect(\"render config\");\n    46\t    FileSystem::write_atomic(&ws.join(\"workspace.toml\"), &rendered).expect(\"write config\");\n    47\t}\n    48\t\n    49\tfn create_project_on_disk(base_dir: &std::path::Path, id: &str) {\n    50\t    let store = FsProjectStore;\n    51\t    let record = make_project_record(id);\n    52\t    let snapshot = RunSnapshot::initial();\n    53\t    let sessions = SessionStore::empty();\n    54\t    let event = JournalEvent {\n    55\t        sequence: 1,\n    56\t        timestamp: test_timestamp(),\n    57\t        event_type: JournalEventType::ProjectCreated,\n    58\t        details: serde_json::json!({\"project_id\": id, \"flow\": \"standard\"}),\n    59\t    };\n    60\t    let journal_line = journal::serialize_event(&event).expect(\"serialize event\");\n    61\t    store\n    62\t        .create_project_atomic(base_dir, &record, \"# Prompt\\n\", &snapshot, &journal_line, &sessions)\n    63\t        .expect(\"create project\");\n    64\t}\n    65\t\n    66\t// ── FsProjectStore ──\n    67\t\n    68\t#[test]\n    69\tfn project_store_round_trip_create_and_read() {\n    70\t    let tmp = tempdir().unwrap();\n    71\t    setup_workspace(tmp.path());\n    72\t    create_project_on_disk(tmp.path(), \"alpha\");\n    73\t\n    74\t    let store = FsProjectStore;\n    75\t    let pid = ProjectId::new(\"alpha\").unwrap();\n    76\t    let record = store.read_project_record(tmp.path(), &pid).unwrap();\n    77\t\n    78\t    assert_eq!(record.id.as_str(), \"alpha\");\n    79\t    assert_eq!(record.flow, FlowPreset::Standard);\n    80\t    assert_eq!(record.prompt_reference, \"prompt.md\");\n    81\t    assert_eq!(record.prompt_hash, \"abc123\");\n    82\t    assert_eq!(record.status_summary, ProjectStatusSummary::Created);\n    83\t}\n    84\t\n    85\t#[test]\n    86\tfn project_store_exists_returns_true_for_created_project() {\n    87\t    let tmp = tempdir().unwrap();\n    88\t    setup_workspace(tmp.path());\n    89\t    create_project_on_disk(tmp.path(), \"alpha\");\n    90\t\n    91\t    let store = FsProjectStore;\n    92\t    let pid = ProjectId::new(\"alpha\").unwrap();\n    93\t    assert!(store.project_exists(tmp.path(), &pid).unwrap());\n    94\t}\n    95\t\n    96\t#[test]\n    97\tfn project_store_exists_returns_false_for_missing_project() {\n    98\t    let tmp = tempdir().unwrap();\n    99\t    setup_workspace(tmp.path());\n   100\t\n   101\t    let store = FsProjectStore;\n   102\t    let pid = ProjectId::new(\"nonexistent\").unwrap();\n   103\t    assert!(!store.project_exists(tmp.path(), &pid).unwrap());\n   104\t}\n   105\t\n   106\t#[test]\n   107\tfn project_store_list_returns_sorted_ids() {\n   108\t    let tmp = tempdir().unwrap();\n   109\t    setup_workspace(tmp.path());\n   110\t    create_project_on_disk(tmp.path(), \"beta\");\n   111\t    create_project_on_disk(tmp.path(), \"alpha\");\n   112\t\n   113\t    let store = FsProjectStore;\n   114\t    let ids = store.list_project_ids(tmp.path()).unwrap();\n   115\t    let id_strs: Vec<&str> = ids.iter().map(|p| p.as_str()).collect();\n   116\t    assert_eq!(id_strs, vec![\"alpha\", \"beta\"]);\n   117\t}\n   118\t\n   119\t#[test]\n   120\tfn project_store_delete_removes_project() {\n   121\t    let tmp = tempdir().unwrap();\n   122\t    setup_workspace(tmp.path());\n   123\t    create_project_on_disk(tmp.path(), \"alpha\");\n   124\t\n   125\t    let store = FsProjectStore;\n   126\t    let pid = ProjectId::new(\"alpha\").unwrap();\n   127\t    store.delete_project(tmp.path(), &pid).unwrap();\n   128\t    assert!(!store.project_exists(tmp.path(), &pid).unwrap());\n   129\t}\n   130\t\n   131\t#[test]\n   132\tfn project_store_read_missing_project_toml_returns_corrupt() {\n   133\t    let tmp = tempdir().unwrap();\n   134\t    setup_workspace(tmp.path());\n   135\t    create_project_on_disk(tmp.path(), \"alpha\");\n   136\t\n   137\t    // Remove project.toml but keep directory\n   138\t    let project_root = tmp.path().join(\".ralph-burning/projects/alpha\");\n   139\t    fs::remove_file(project_root.join(\"project.toml\")).unwrap();\n   140\t\n   141\t    let store = FsProjectStore;\n   142\t    let pid = ProjectId::new(\"alpha\").unwrap();\n   143\t    let err = store.read_project_record(tmp.path(), &pid).unwrap_err();\n   144\t    assert!(matches!(err, AppError::CorruptRecord { .. }));\n   145\t}\n   146\t\n   147\t#[test]\n   148\tfn project_store_exists_with_missing_project_toml_returns_corrupt() {\n   149\t    let tmp = tempdir().unwrap();\n   150\t    setup_workspace(tmp.path());\n   151\t    create_project_on_disk(tmp.path(), \"alpha\");\n   152\t\n   153\t    fs::remove_file(\n   154\t        tmp.path()\n   155\t            .join(\".ralph-burning/projects/alpha/project.toml\"),\n   156\t    )\n   157\t    .unwrap();\n   158\t\n   159\t    let store = FsProjectStore;\n   160\t    let pid = ProjectId::new(\"alpha\").unwrap();\n   161\t    let err = store.project_exists(tmp.path(), &pid).unwrap_err();\n   162\t    assert!(matches!(err, AppError::CorruptRecord { .. }));\n   163\t}\n   164\t\n   165\t#[test]\n   166\tfn project_store_list_with_corrupt_project_toml_returns_error() {\n   167\t    let tmp = tempdir().unwrap();\n   168\t    setup_workspace(tmp.path());\n   169\t    create_project_on_disk(tmp.path(), \"alpha\");\n   170\t\n   171\t    // Remove project.toml to simulate corruption\n   172\t    fs::remove_file(\n   173\t        tmp.path()\n   174\t            .join(\".ralph-burning/projects/alpha/project.toml\"),\n   175\t    )\n   176\t    .unwrap();\n   177\t\n   178\t    let store = FsProjectStore;\n   179\t    let err = store.list_project_ids(tmp.path()).unwrap_err();\n   180\t    assert!(matches!(err, AppError::CorruptRecord { .. }));\n   181\t}\n   182\t\n   183\t#[test]\n   184\tfn project_store_read_malformed_toml_returns_corrupt() {\n   185\t    let tmp = tempdir().unwrap();\n   186\t    setup_workspace(tmp.path());\n   187\t    create_project_on_disk(tmp.path(), \"alpha\");\n   188\t\n   189\t    // Write malformed TOML\n   190\t    fs::write(\n   191\t        tmp.path()\n   192\t            .join(\".ralph-burning/projects/alpha/project.toml\"),\n   193\t        \"this is not valid toml ][}{\",\n   194\t    )\n   195\t    .unwrap();\n   196\t\n   197\t    let store = FsProjectStore;\n   198\t    let pid = ProjectId::new(\"alpha\").unwrap();\n   199\t    let err = store.read_project_record(tmp.path(), &pid).unwrap_err();\n   200\t    assert!(matches!(err, AppError::CorruptRecord { .. }));\n   201\t}\n   202\t\n   203\t#[test]\n   204\tfn project_store_atomic_create_does_not_leave_staging_dirs() {\n   205\t    let tmp = tempdir().unwrap();\n   206\t    setup_workspace(tmp.path());\n   207\t    create_project_on_disk(tmp.path(), \"alpha\");\n   208\t\n   209\t    let projects_dir = tmp.path().join(\".ralph-burning/projects\");\n   210\t    for entry in fs::read_dir(&projects_dir).unwrap() {\n   211\t        let name = entry.unwrap().file_name();\n   212\t        let name_str = name.to_string_lossy();\n   213\t        assert!(\n   214\t            !name_str.starts_with('.'),\n   215\t            \"staging directory should not remain: {name_str}\"\n   216\t        );\n   217\t    }\n   218\t}\n   219\t\n   220\t// ── FsJournalStore ──\n   221\t\n   222\t#[test]\n   223\tfn journal_store_round_trip_read() {\n   224\t    let tmp = tempdir().unwrap();\n   225\t    setup_workspace(tmp.path());\n   226\t    create_project_on_disk(tmp.path(), \"alpha\");\n   227\t\n   228\t    let store = FsJournalStore;\n   229\t    let pid = ProjectId::new(\"alpha\").unwrap();\n   230\t    let events = store.read_journal(tmp.path(), &pid).unwrap();\n   231\t    assert_eq!(events.len(), 1);\n   232\t    assert_eq!(events[0].sequence, 1);\n   233\t    assert_eq!(events[0].event_type, JournalEventType::ProjectCreated);\n   234\t}\n   235\t\n   236\t#[test]\n   237\tfn journal_store_append_and_read() {\n   238\t    let tmp = tempdir().unwrap();\n   239\t    setup_workspace(tmp.path());\n   240\t    create_project_on_disk(tmp.path(), \"alpha\");\n   241\t\n   242\t    let store = FsJournalStore;\n   243\t    let pid = ProjectId::new(\"alpha\").unwrap();\n   244\t\n   245\t    let event = JournalEvent {\n   246\t        sequence: 2,\n   247\t        timestamp: test_timestamp(),\n   248\t        event_type: JournalEventType::RunStarted,\n   249\t        details: serde_json::json!({\"run_id\": \"run-1\"}),\n   250\t    };\n   251\t    let line = journal::serialize_event(&event).unwrap();\n   252\t    store.append_event(tmp.path(), &pid, &line).unwrap();\n   253\t\n   254\t    let events = store.read_journal(tmp.path(), &pid).unwrap();\n   255\t    assert_eq!(events.len(), 2);\n   256\t    assert_eq!(events[1].sequence, 2);\n   257\t    assert_eq!(events[1].event_type, JournalEventType::RunStarted);\n   258\t}\n   259\t\n   260\t#[test]\n   261\tfn journal_store_missing_file_returns_corrupt() {\n   262\t    let tmp = tempdir().unwrap();\n   263\t    setup_workspace(tmp.path());\n   264\t    create_project_on_disk(tmp.path(), \"alpha\");\n   265\t\n   266\t    fs::remove_file(\n   267\t        tmp.path()\n   268\t            .join(\".ralph-burning/projects/alpha/journal.ndjson\"),\n   269\t    )\n   270\t    .unwrap();\n   271\t\n   272\t    let store = FsJournalStore;\n   273\t    let pid = ProjectId::new(\"alpha\").unwrap();\n   274\t    let err = store.read_journal(tmp.path(), &pid).unwrap_err();\n   275\t    assert!(matches!(err, AppError::CorruptRecord { .. }));\n   276\t}\n   277\t\n   278\t#[test]\n   279\tfn journal_store_corrupt_json_returns_error() {\n   280\t    let tmp = tempdir().unwrap();\n   281\t    setup_workspace(tmp.path());\n   282\t    create_project_on_disk(tmp.path(), \"alpha\");\n   283\t\n   284\t    fs::write(\n   285\t        tmp.path()\n   286\t            .join(\".ralph-burning/projects/alpha/journal.ndjson\"),\n   287\t        \"{not valid json}\\n\",\n   288\t    )\n   289\t    .unwrap();\n   290\t\n   291\t    let store = FsJournalStore;\n   292\t    let pid = ProjectId::new(\"alpha\").unwrap();\n   293\t    let err = store.read_journal(tmp.path(), &pid).unwrap_err();\n   294\t    assert!(matches!(err, AppError::CorruptRecord { .. }));\n   295\t}\n   296\t\n   297\t// ── FsRunSnapshotStore ──\n   298\t\n   299\t#[test]\n   300\tfn run_snapshot_store_round_trip() {\n   301\t    let tmp = tempdir().unwrap();\n   302\t    setup_workspace(tmp.path());\n   303\t    create_project_on_disk(tmp.path(), \"alpha\");\n   304\t\n   305\t    let store = FsRunSnapshotStore;\n   306\t    let pid = ProjectId::new(\"alpha\").unwrap();\n   307\t    let snapshot = store.read_run_snapshot(tmp.path(), &pid).unwrap();\n   308\t\n   309\t    assert_eq!(snapshot.status, RunStatus::NotStarted);\n   310\t    assert!(snapshot.active_run.is_none());\n   311\t    assert!(snapshot.cycle_history.is_empty());\n   312\t    assert_eq!(snapshot.completion_rounds, 0);\n   313\t}\n   314\t\n   315\t#[test]\n   316\tfn run_snapshot_store_missing_file_returns_corrupt() {\n   317\t    let tmp = tempdir().unwrap();\n   318\t    setup_workspace(tmp.path());\n   319\t    create_project_on_disk(tmp.path(), \"alpha\");\n   320\t\n   321\t    fs::remove_file(tmp.path().join(\".ralph-burning/projects/alpha/run.json\")).unwrap();\n   322\t\n   323\t    let store = FsRunSnapshotStore;\n   324\t    let pid = ProjectId::new(\"alpha\").unwrap();\n   325\t    let err = store.read_run_snapshot(tmp.path(), &pid).unwrap_err();\n   326\t    assert!(matches!(err, AppError::CorruptRecord { .. }));\n   327\t}\n   328\t\n   329\t#[test]\n   330\tfn run_snapshot_store_corrupt_json_returns_error() {\n   331\t    let tmp = tempdir().unwrap();\n   332\t    setup_workspace(tmp.path());\n   333\t    create_project_on_disk(tmp.path(), \"alpha\");\n   334\t\n   335\t    fs::write(\n   336\t        tmp.path().join(\".ralph-burning/projects/alpha/run.json\"),\n   337\t        \"not json at all\",\n   338\t    )\n   339\t    .unwrap();\n   340\t\n","exit_code":0,"status":"completed"}}
