 r#\"{\"active_run\":null,\"status\":\"not_started\",\"cycle_history\":[],\"completion_rounds\":0,\"rollback_point_meta\":{\"last_rollback_id\":null,\"rollback_count\":0},\"amendment_queue\":{\"pending\":[],\"processed_count\":0},\"status_summary\":\"not started\"}\"#,\n    42\t    ).expect(\"write run.json\");\n    43\t    fs::write(\n    44\t        project_root.join(\"journal.ndjson\"),\n    45\t        format!(\n    46\t            r#\"{{\"sequence\":1,\"timestamp\":\"2026-03-11T19:00:00Z\",\"event_type\":\"project_created\",\"details\":{{\"project_id\":\"{}\",\"flow\":\"standard\"}}}}\"#,\n    47\t            project_id\n    48\t        ),\n    49\t    ).expect(\"write journal\");\n    50\t    fs::write(project_root.join(\"sessions.json\"), r#\"{\"sessions\":[]}\"#).expect(\"write sessions\");\n    51\t    for subdir in &[\n    52\t        \"history/payloads\", \"history/artifacts\", \"runtime/logs\",\n    53\t        \"runtime/backend\", \"runtime/temp\", \"amendments\", \"rollback\",\n    54\t    ] {\n    55\t        fs::create_dir_all(project_root.join(subdir)).expect(\"create project subdirectory\");\n    56\t    }\n    57\t}\n    58\t\n    59\tfn write_editor_script(\n    60\t    base_dir: &std::path::Path,\n    61\t    name: &str,\n    62\t    contents: &str,\n    63\t) -> std::path::PathBuf {\n    64\t    let script_path = base_dir.join(name);\n    65\t    fs::write(&script_path, contents).expect(\"write editor script\");\n    66\t    let mut permissions = fs::metadata(&script_path)\n    67\t        .expect(\"script metadata\")\n    68\t        .permissions();\n    69\t    permissions.set_mode(0o755);\n    70\t    fs::set_permissions(&script_path, permissions).expect(\"set script permissions\");\n    71\t    script_path\n    72\t}\n    73\t\n    74\t#[test]\n    75\tfn flow_list_prints_all_presets() {\n    76\t    let output = Command::new(binary())\n    77\t        .args([\"flow\", \"list\"])\n    78\t        .output()\n    79\t        .expect(\"run flow list\");\n    80\t\n    81\t    assert!(output.status.success());\n    82\t\n    83\t    let stdout = String::from_utf8_lossy(&output.stdout);\n    84\t    assert!(stdout.contains(\"standard\"));\n    85\t    assert!(stdout.contains(\"quick_dev\"));\n    86\t    assert!(stdout.contains(\"docs_change\"));\n    87\t    assert!(stdout.contains(\"ci_improvement\"));\n    88\t}\n    89\t\n    90\t#[test]\n    91\tfn flow_show_standard_prints_stage_sequence() {\n    92\t    let output = Command::new(binary())\n    93\t        .args([\"flow\", \"show\", \"standard\"])\n    94\t        .output()\n    95\t        .expect(\"run flow show\");\n    96\t\n    97\t    assert!(output.status.success());\n    98\t\n    99\t    let stdout = String::from_utf8_lossy(&output.stdout);\n   100\t    assert!(stdout.contains(\"Stage count: 8\"));\n   101\t    assert!(stdout.contains(\"1. prompt_review\"));\n   102\t    assert!(stdout.contains(\"8. final_review\"));\n   103\t    assert!(stdout.contains(\"Final review enabled: yes\"));\n   104\t}\n   105\t\n   106\t#[test]\n   107\tfn flow_show_invalid_preset_exits_non_zero_with_clear_error() {\n   108\t    let output = Command::new(binary())\n   109\t        .args([\"flow\", \"show\", \"unknown_flow\"])\n   110\t        .output()\n   111\t        .expect(\"run flow show invalid\");\n   112\t\n   113\t    assert!(!output.status.success());\n   114\t\n   115\t    let stderr = String::from_utf8_lossy(&output.stderr);\n   116\t    assert!(stderr.contains(\"unknown flow preset 'unknown_flow'\"));\n   117\t}\n   118\t\n   119\t#[test]\n   120\tfn init_creates_workspace_layout() {\n   121\t    let temp_dir = tempdir().expect(\"create temp dir\");\n   122\t    let output = Command::new(binary())\n   123\t        .arg(\"init\")\n   124\t        .current_dir(temp_dir.path())\n   125\t        .output()\n   126\t        .expect(\"run init\");\n   127\t\n   128\t    assert!(output.status.success());\n   129\t    assert!(temp_dir\n   130\t        .path()\n   131\t        .join(\".ralph-burning/workspace.toml\")\n   132\t        .is_file());\n   133\t    assert!(temp_dir.path().join(\".ralph-burning/projects\").is_dir());\n   134\t    assert!(temp_dir.path().join(\".ralph-burning/requirements\").is_dir());\n   135\t    assert!(temp_dir.path().join(\".ralph-burning/daemon/tasks\").is_dir());\n   136\t    assert!(temp_dir\n   137\t        .path()\n   138\t        .join(\".ralph-burning/daemon/leases\")\n   139\t        .is_dir());\n   140\t}\n   141\t\n   142\t#[test]\n   143\tfn init_fails_when_workspace_already_exists() {\n   144\t    let temp_dir = tempdir().expect(\"create temp dir\");\n   145\t\n   146\t    let first = Command::new(binary())\n   147\t        .arg(\"init\")\n   148\t        .current_dir(temp_dir.path())\n   149\t        .output()\n   150\t        .expect(\"run first init\");\n   151\t    assert!(first.status.success());\n   152\t\n   153\t    let second = Command::new(binary())\n   154\t        .arg(\"init\")\n   155\t        .current_dir(temp_dir.path())\n   156\t        .output()\n   157\t        .expect(\"run second init\");\n   158\t\n   159\t    assert!(!second.status.success());\n   160\t\n   161\t    let stderr = String::from_utf8_lossy(&second.stderr);\n   162\t    assert!(stderr.contains(\"workspace already initialized\"));\n   163\t}\n   164\t\n   165\t#[test]\n   166\tfn config_show_prints_effective_values_and_sources() {\n   167\t    let temp_dir = initialize_workspace_fixture();\n   168\t\n   169\t    let output = Command::new(binary())\n   170\t        .args([\"config\", \"show\"])\n   171\t        .current_dir(temp_dir.path())\n   172\t        .output()\n   173\t        .expect(\"run config show\");\n   174\t\n   175\t    assert!(output.status.success());\n   176\t\n   177\t    let stdout = String::from_utf8_lossy(&output.stdout);\n   178\t    assert!(stdout.contains(\"[settings]\"));\n   179\t    assert!(stdout.contains(\"prompt_review.enabled = true # source: default\"));\n   180\t    assert!(stdout.contains(\"default_flow = \\\"standard\\\" # source: default\"));\n   181\t    assert!(stdout.contains(\"default_backend = \\\"<unset>\\\" # source: default\"));\n   182\t}\n   183\t\n   184\t#[test]\n   185\tfn config_get_prints_known_values_and_rejects_unknown_keys() {\n   186\t    let temp_dir = initialize_workspace_fixture();\n   187\t\n   188\t    let known = Command::new(binary())\n   189\t        .args([\"config\", \"get\", \"default_flow\"])\n   190\t        .current_dir(temp_dir.path())\n   191\t        .output()\n   192\t        .expect(\"run config get\");\n   193\t    assert!(known.status.success());\n   194\t    assert_eq!(\"standard\\n\", String::from_utf8_lossy(&known.stdout));\n   195\t\n   196\t    let unknown = Command::new(binary())\n   197\t        .args([\"config\", \"get\", \"unknown.key\"])\n   198\t        .current_dir(temp_dir.path())\n   199\t        .output()\n   200\t        .expect(\"run config get invalid\");\n   201\t    assert!(!unknown.status.success());\n   202\t    assert!(String::from_utf8_lossy(&unknown.stderr).contains(\"unknown config key\"));\n   203\t}\n   204\t\n   205\t#[test]\n   206\tfn config_set_updates_valid_keys_and_rejects_invalid_values() {\n   207\t    let temp_dir = initialize_workspace_fixture();\n   208\t\n   209\t    let valid = Command::new(binary())\n   210\t        .args([\"config\", \"set\", \"default_flow\", \"quick_dev\"])\n   211\t        .current_dir(temp_dir.path())\n   212\t        .output()\n   213\t        .expect(\"run config set\");\n   214\t    assert!(valid.status.success());\n   215\t    assert!(String::from_utf8_lossy(&valid.stdout).contains(\"Updated default_flow = quick_dev\"));\n   216\t\n   217\t    let workspace_config =\n   218\t        fs::read_to_string(temp_dir.path().join(\".ralph-burning/workspace.toml\"))\n   219\t            .expect(\"read workspace config\");\n   220\t    assert!(workspace_config.contains(\"default_flow = \\\"quick_dev\\\"\"));\n   221\t\n   222\t    let invalid_value = Command::new(binary())\n   223\t        .args([\"config\", \"set\", \"default_flow\", \"unknown_flow\"])\n   224\t        .current_dir(temp_dir.path())\n   225\t        .output()\n   226\t        .expect(\"run invalid config set\");\n   227\t    assert!(!invalid_value.status.success());\n   228\t    assert!(String::from_utf8_lossy(&invalid_value.stderr).contains(\"invalid value\"));\n   229\t\n   230\t    let invalid_key = Command::new(binary())\n   231\t        .args([\"config\", \"set\", \"unknown.key\", \"value\"])\n   232\t        .current_dir(temp_dir.path())\n   233\t        .output()\n   234\t        .expect(\"run invalid key config set\");\n   235\t    assert!(!invalid_key.status.success());\n   236\t    assert!(String::from_utf8_lossy(&invalid_key.stderr).contains(\"unknown config key\"));\n   237\t}\n   238\t\n   239\t#[test]\n   240\tfn config_edit_revalidates_workspace_file() {\n   241\t    let temp_dir = initialize_workspace_fixture();\n   242\t    let editor = write_editor_script(\n   243\t        temp_dir.path(),\n   244\t        \"editor-valid.sh\",\n   245\t        \"#!/bin/sh\\ncat <<'EOF' > \\\"$1\\\"\\nversion = 1\\ncreated_at = \\\"2026-03-11T17:50:55Z\\\"\\n\\n[settings]\\ndefault_backend = \\\"claude\\\"\\nEOF\\n\",\n   246\t    );\n   247\t\n   248\t    let output = Command::new(binary())\n   249\t        .args([\"config\", \"edit\"])\n   250\t        .env(\"EDITOR\", &editor)\n   251\t        .env_remove(\"VISUAL\")\n   252\t        .current_dir(temp_dir.path())\n   253\t        .output()\n   254\t        .expect(\"run config edit\");\n   255\t\n   256\t    assert!(output.status.success());\n   257\t    assert!(String::from_utf8_lossy(&output.stdout).contains(\"Validated workspace.toml\"));\n   258\t}\n   259\t\n   260\t#[test]\n   261\tfn config_edit_prefers_editor_over_visual() {\n   262\t    let temp_dir = initialize_workspace_fixture();\n   263\t    let editor = write_editor_script(\n   264\t        temp_dir.path(),\n   265\t        \"editor-wins.sh\",\n   266\t        \"#!/bin/sh\\ncat <<'EOF' > \\\"$1\\\"\\nversion = 1\\ncreated_at = \\\"2026-03-11T17:50:55Z\\\"\\n\\n[settings]\\ndefault_backend = \\\"editor\\\"\\nEOF\\n\",\n   267\t    );\n   268\t    let visual = write_editor_script(\n   269\t        temp_dir.path(),\n   270\t        \"visual-loses.sh\",\n   271\t        \"#!/bin/sh\\ncat <<'EOF' > \\\"$1\\\"\\nversion = 1\\ncreated_at = \\\"2026-03-11T17:50:55Z\\\"\\n\\n[settings]\\ndefault_backend = \\\"visual\\\"\\nEOF\\n\",\n   272\t    );\n   273\t\n   274\t    let output = Command::new(binary())\n   275\t        .args([\"config\", \"edit\"])\n   276\t        .env(\"EDITOR\", &editor)\n   277\t        .env(\"VISUAL\", &visual)\n   278\t        .current_dir(temp_dir.path())\n   279\t        .output()\n   280\t        .expect(\"run config edit\");\n   281\t\n   282\t    assert!(output.status.success());\n   283\t\n   284\t    let workspace_config =\n   285\t        fs::read_to_string(temp_dir.path().join(\".ralph-burning/workspace.toml\"))\n   286\t            .expect(\"read workspace config\");\n   287\t    assert!(workspace_config.contains(\"default_backend = \\\"editor\\\"\"));\n   288\t    assert!(!workspace_config.contains(\"default_backend = \\\"visual\\\"\"));\n   289\t}\n   290\t\n   291\t#[test]\n   292\tfn config_edit_fails_when_editor_leaves_invalid_file() {\n   293\t    let temp_dir = initialize_workspace_fixture();\n   294\t    let editor = write_editor_script(\n   295\t        temp_dir.path(),\n   296\t        \"editor-invalid.sh\",\n   297\t        \"#!/bin/sh\\nprintf '%s\\n' 'version = 999' 'created_at = \\\"2026-03-11T17:50:55Z\\\"' > \\\"$1\\\"\\n\",\n   298\t    );\n   299\t\n   300\t    let output = Command::new(binary())\n   301\t        .args([\"config\", \"edit\"])\n   302\t        .env(\"EDITOR\", &editor)\n   303\t        .env_remove(\"VISUAL\")\n   304\t        .current_dir(temp_dir.path())\n   305\t        .output()\n   306\t        .expect(\"run invalid config edit\");\n   307\t\n   308\t    assert!(!output.status.success());\n   309\t    let stderr = String::from_utf8_lossy(&output.stderr);\n   310\t    assert!(stderr.contains(\"workspace.toml is invalid after editing\"));\n   311\t    assert!(stderr.contains(\"unsupported workspace version 999\"));\n   312\t}\n   313\t\n   314\t#[test]\n   315\tfn project_select_sets_active_project_and_rejects_missing_projects() {\n   316\t    let temp_dir = initialize_workspace_fixture();\n   317\t    create_project_fixture(temp_dir.path(), \"alpha\");\n   318\t\n   319\t    let existing = Command::new(binary())\n   320\t        .args([\"project\", \"select\", \"alpha\"])\n   321\t        .current_dir(temp_dir.path())\n   322\t        .output()\n   323\t        .expect(\"run project select\");\n   324\t    assert!(existing.status.success());\n   325\t    assert!(String::from_utf8_lossy(&existing.stdout).contains(\"Selected project alpha\"));\n   326\t    assert_eq!(\n   327\t        \"alpha\",\n   328\t        fs::read_to_string(temp_dir.path().join(\".ralph-burning/active-project\"))\n   329\t            .expect(\"read active project\")\n   330\t    );\n   331\t\n   332\t    let missing = Command::new(binary())\n   333\t        .args([\"project\", \"select\", \"missing\"])\n   334\t        .current_dir(temp_dir.path())\n   335\t        .output()\n   336\t        .expect(\"run missing project select\");\n   337\t    assert!(!missing.status.success());\n   338\t    assert!(String::from_utf8_lossy(&missing.stderr).contains(\"project 'missing' was not found\"));\n   339\t}\n   340\t\n   341\t#[test]\n   342\tfn project_select_rejects_path_like_ids_before_writing_active_project() {\n   343\t    let temp_dir = initialize_workspace_fixture();\n   344\t\n   345\t    let output = Command::new(binary())\n   346\t        .args([\"project\", \"select\", \"../escape\"])\n   347\t        .current_dir(temp_dir.path())\n   348\t        .output()\n   349\t        .expect(\"run path-like project select\");\n   350\t\n   351\t    assert!(!output.status.success());\n   352\t    assert!(String::from_utf8_lossy(&output.stderr).contains(\"invalid identifier\"));\n   353\t    assert!(!temp_dir\n   354\t        .path()\n   355\t        .join(\".ralph-burning/active-project\")\n   356\t        .exists());\n   357\t}\n   358\t\n   359\t// ── Project Create ──\n   360\t\n   361\tfn write_prompt_fixture(base_dir: &std::path::Path) -> std::path::PathBuf {\n   362\t    let prompt_path = base_dir.join(\"test-prompt.md\");\n   363\t    fs::write(&prompt_path, \"# Test Prompt\\nImplement the feature.\\n\").expect(\"write prompt\");\n   364\t    prompt_path\n   365\t}\n   366\t\n   367\t#[test]\n   368\tfn project_create_succeeds_and_writes_all_canonical_files() {\n   369\t    let temp_dir = initialize_workspace_fixture();\n   370\t    let prompt = write_prompt_fixture(temp_dir.path());\n   371\t\n   372\t    let output = Command::new(binary())\n   373\t        .args([\n   374\t            \"project\", \"create\",\n   375\t            \"--id\", \"alpha\",\n   376\t            \"--name\", \"Alpha Project\",\n   377\t            \"--prompt\", prompt.to_str().unwrap(),\n   378\t            \"--flow\", \"standard\",\n   379\t        ])\n   380\t        .current_dir(temp_dir.path())\n   381\t        .output()\n   382\t        .expect(\"run project create\");\n   383\t\n   384\t    assert!(output.status.success(), \"stderr: {}\", String::from_utf8_lossy(&output.stderr));\n   385\t\n   386\t    let stdout = String::from_utf8_lossy(&output.stdout);\n   387\t    assert!(stdout.contains(\"Created project 'alpha'\"));\n   388\t    assert!(stdout.contains(\"standard\"));\n   389\t\n   390\t    let project_root = temp_dir.path().join(\".ralph-burning/projects/alpha\");\n   391\t    assert!(project_root.join(\"project.toml\").is_file());\n   392\t    assert!(project_root.join(\"prompt.md\").is_file());\n   393\t    assert!(project_root.join(\"run.json\").is_file());\n   394\t    assert!(project_root.join(\"journal.ndjson\").is_file());\n   395\t    assert!(project_root.join(\"sessions.json\").is_file());\n   396\t    assert!(project_root.join(\"history/payloads\").is_dir());\n   397\t    assert!(project_root.join(\"history/artifacts\").is_dir());\n   398\t    assert!(project_root.join(\"runtime/logs\").is_dir());\n   399\t    assert!(project_root.join(\"runtime/backend\").is_dir());\n   400\t    assert!(project_root.join(\"runtime/temp\").is_dir());\n   401\t    assert!(project_root.join(\"amendments\").is_dir());\n   402\t    assert!(project_root.join(\"rollback\").is_dir());\n   403\t}\n   404\t\n   405\t#[test]\n   406\tfn project_create_initializes_journal_with_project_created_event() {\n   407\t    let temp_dir = initialize_workspace_fixture();\n   408\t    let prompt = write_prompt_fixture(temp_dir.path());\n   409\t\n   410\t    let output = Command::new(binary())\n   411\t        .args([\n   412\t            \"project\", \"create\",\n   413\t            \"--id\", \"beta\",\n   414\t            \"--name\", \"Beta\",\n   415\t            \"--prompt\", prompt.to_str().unwrap(),\n   416\t            \"--flow\", \"quick_dev\",\n   417\t        ])\n   418\t        .current_dir(temp_dir.path())\n   419\t        .output()\n   420\t        .expect(\"run project create\");\n   421\t    assert!(output.status.success());\n   422\t\n   423\t    let journal = fs::read_to_string(\n   424\t        temp_dir.path().join(\".ralph-burning/projects/beta/journal.ndjson\"),\n   425\t    )\n   426\t    .expect(\"read journal\");\n   427\t\n   428\t    assert!(journal.contains(\"\\\"project_created\\\"\"));\n   429\t    assert!(journal.contains(\"\\\"sequence\\\":1\"));\n   430\t}\n   431\t\n   432\t#[test]\n   433\tfn project_create_run_json_shows_not_started() {\n   434\t    let temp_dir = initialize_workspace_fixture();\n   435\t    let prompt = write_prompt_fixture(temp_dir.path());\n   436\t\n   437\t    Command::new(binary())\n   438\t        .args([\n   439\t            \"project\", \"create\",\n   440\t            \"--id\", \"gamma\",\n   441\t            \"--name\", \"Gamma\",\n   442\t            \"--prompt\", prompt.to_str().unwrap(),\n   443\t            \"--flow\", \"standard\",\n   444\t        ])\n   445\t        .current_dir(temp_dir.path())\n   446\t        .output()\n   447\t        .expect(\"run project create\");\n   448\t\n   449\t    let run_json = fs::read_to_string(\n   450\t        temp_dir.path().join(\".ralph-burning/projects/gamma/run.json\"),\n   451\t    )\n   452\t    .expect(\"read run.json\");\n   453\t\n   454\t    assert!(run_json.contains(\"\\\"not_started\\\"\"));\n   455\t    assert!(run_json.contains(\"\\\"active_run\\\": null\"));\n   456\t}\n   457\t\n   458\t#[test]\n   459\tfn project_create_records_canonical_prompt_reference_not_source_path() {\n   460\t    let temp_dir = initialize_workspace_fixture();\n","exit_code":0,"status":"completed"}}
