d: Cell<bool>,\n   603\t        write_called: Cell<bool>,\n   604\t    }\n   605\t\n   606\t    impl ActiveProjectPort for TrackingActiveStore {\n   607\t        fn read_active_project_id(&self, _base_dir: &Path) -> AppResult<Option<String>> {\n   608\t            Ok(self.active_id.clone())\n   609\t        }\n   610\t\n   611\t        fn clear_active_project(&self, _base_dir: &Path) -> AppResult<()> {\n   612\t            self.clear_called.set(true);\n   613\t            Ok(())\n   614\t        }\n   615\t\n   616\t        fn write_active_project(\n   617\t            &self,\n   618\t            _base_dir: &Path,\n   619\t            _project_id: &ProjectId,\n   620\t        ) -> AppResult<()> {\n   621\t            self.write_called.set(true);\n   622\t            Ok(())\n   623\t        }\n   624\t    }\n   625\t\n   626\t    let store = FailingDeleteStore {\n   627\t        existing_ids: vec![\"alpha\".to_owned()],\n   628\t    };\n   629\t    let run_store = FakeRunSnapshotStore::no_run();\n   630\t    let active_store = TrackingActiveStore {\n   631\t        active_id: Some(\"alpha\".to_owned()),\n   632\t        clear_called: Cell::new(false),\n   633\t        write_called: Cell::new(false),\n   634\t    };\n   635\t    let base_dir = dummy_base_dir();\n   636\t    let pid = ProjectId::new(\"alpha\").unwrap();\n   637\t\n   638\t    let result = delete_project(&store, &run_store, &active_store, &base_dir, &pid);\n   639\t    assert!(result.is_err(), \"delete should fail\");\n   640\t    // The pointer must never be cleared or written when delete fails —\n   641\t    // the project remains fully addressable with the original pointer.\n   642\t    assert!(\n   643\t        !active_store.clear_called.get(),\n   644\t        \"clear_active_project must not be called when delete fails\"\n   645\t    );\n   646\t    assert!(\n   647\t        !active_store.write_called.get(),\n   648\t        \"write_active_project must not be called when delete fails\"\n   649\t    );\n   650\t}\n   651\t\n   652\t#[test]\n   653\tfn delete_project_propagates_clear_pointer_failure_after_successful_delete() {\n   654\t    use std::cell::Cell;\n   655\t\n   656\t    struct SucceedingDeleteStore {\n   657\t        existing_ids: Vec<String>,\n   658\t    }\n   659\t\n   660\t    impl ProjectStorePort for SucceedingDeleteStore {\n   661\t        fn project_exists(&self, _base_dir: &Path, project_id: &ProjectId) -> AppResult<bool> {\n   662\t            Ok(self.existing_ids.contains(&project_id.to_string()))\n   663\t        }\n   664\t\n   665\t        fn read_project_record(\n   666\t            &self,\n   667\t            _base_dir: &Path,\n   668\t            project_id: &ProjectId,\n   669\t        ) -> AppResult<ProjectRecord> {\n   670\t            Ok(make_project_record(project_id.as_str()))\n   671\t        }\n   672\t\n   673\t        fn list_project_ids(&self, _base_dir: &Path) -> AppResult<Vec<ProjectId>> {\n   674\t            self.existing_ids.iter().map(ProjectId::new).collect()\n   675\t        }\n   676\t\n   677\t        fn delete_project(&self, _base_dir: &Path, _project_id: &ProjectId) -> AppResult<()> {\n   678\t            Ok(())\n   679\t        }\n   680\t\n   681\t        fn create_project_atomic(\n   682\t            &self,\n   683\t            _base_dir: &Path,\n   684\t            _record: &ProjectRecord,\n   685\t            _prompt_contents: &str,\n   686\t            _run_snapshot: &RunSnapshot,\n   687\t            _initial_journal_line: &str,\n   688\t            _sessions: &SessionStore,\n   689\t        ) -> AppResult<()> {\n   690\t            Ok(())\n   691\t        }\n   692\t    }\n   693\t\n   694\t    struct FailingClearActiveStore {\n   695\t        active_id: Option<String>,\n   696\t        clear_called: Cell<bool>,\n   697\t    }\n   698\t\n   699\t    impl ActiveProjectPort for FailingClearActiveStore {\n   700\t        fn read_active_project_id(&self, _base_dir: &Path) -> AppResult<Option<String>> {\n   701\t            Ok(self.active_id.clone())\n   702\t        }\n   703\t\n   704\t        fn clear_active_project(&self, _base_dir: &Path) -> AppResult<()> {\n   705\t            self.clear_called.set(true);\n   706\t            Err(AppError::Io(std::io::Error::new(\n   707\t                std::io::ErrorKind::PermissionDenied,\n   708\t                \"simulated clear failure\",\n   709\t            )))\n   710\t        }\n   711\t\n   712\t        fn write_active_project(\n   713\t            &self,\n   714\t            _base_dir: &Path,\n   715\t            _project_id: &ProjectId,\n   716\t        ) -> AppResult<()> {\n   717\t            Ok(())\n   718\t        }\n   719\t    }\n   720\t\n   721\t    let store = SucceedingDeleteStore {\n   722\t        existing_ids: vec![\"alpha\".to_owned()],\n   723\t    };\n   724\t    let run_store = FakeRunSnapshotStore::no_run();\n   725\t    let active_store = FailingClearActiveStore {\n   726\t        active_id: Some(\"alpha\".to_owned()),\n   727\t        clear_called: Cell::new(false),\n   728\t    };\n   729\t    let base_dir = dummy_base_dir();\n   730\t    let pid = ProjectId::new(\"alpha\").unwrap();\n   731\t\n   732\t    let result = delete_project(&store, &run_store, &active_store, &base_dir, &pid);\n   733\t    // Delete succeeded, but clearing the pointer failed — the error\n   734\t    // must propagate so the caller knows the pointer is stale.\n   735\t    assert!(result.is_err(), \"should propagate clear-pointer failure\");\n   736\t    assert!(\n   737\t        active_store.clear_called.get(),\n   738\t        \"clear_active_project should be attempted after successful delete\"\n   739\t    );\n   740\t}\n   741\t\n   742\t#[test]\n   743\tfn delete_project_succeeds_for_completed_terminal_state() {\n   744\t    let store = FakeProjectStore::with_existing(&[\"alpha\"]);\n   745\t    let run_store = FakeTerminalRunSnapshotStore {\n   746\t        status: RunStatus::Completed,\n   747\t        summary: \"done\".to_owned(),\n   748\t    };\n   749\t    let active_store = FakeActiveProjectStore::none();\n   750\t    let base_dir = dummy_base_dir();\n   751\t    let pid = ProjectId::new(\"alpha\").unwrap();\n   752\t\n   753\t    let result = delete_project(&store, &run_store, &active_store, &base_dir, &pid);\n   754\t    assert!(result.is_ok());\n   755\t}\n","exit_code":0,"status":"completed"}}
{"type":"item.completed","item":{"id":"item_30","type":"command_execution","command":"/run/current-system/sw/bin/bash -lc \"nl -ba /root/new-ralph-burning/ralph-burning-rewrite/tests/unit/query_test.rs | sed -n '1,280p'\"","aggregated_output":"     1\tuse chrono::{TimeZone, Utc};\n     2\t\n     3\tuse ralph_burning::contexts::project_run_record::model::*;\n     4\tuse ralph_burning::contexts::project_run_record::queries;\n     5\tuse ralph_burning::shared::domain::{StageCursor, StageId};\n     6\tuse ralph_burning::shared::error::AppError;\n     7\t\n     8\tfn test_timestamp() -> chrono::DateTime<Utc> {\n     9\t    Utc.with_ymd_and_hms(2026, 3, 11, 19, 0, 0)\n    10\t        .single()\n    11\t        .expect(\"valid timestamp\")\n    12\t}\n    13\t\n    14\t// ── RunStatusView ──\n    15\t\n    16\t#[test]\n    17\tfn status_view_not_started_when_no_active_run() {\n    18\t    let snapshot = RunSnapshot::initial();\n    19\t    let view = queries::build_status_view(\"alpha\", &snapshot);\n    20\t\n    21\t    assert_eq!(view.project_id, \"alpha\");\n    22\t    assert_eq!(view.status, \"not started\");\n    23\t    assert!(view.stage.is_none());\n    24\t    assert!(view.cycle.is_none());\n    25\t    assert!(view.completion_round.is_none());\n    26\t}\n    27\t\n    28\t#[test]\n    29\tfn status_view_reports_completed_terminal_state_without_active_run() {\n    30\t    let snapshot = RunSnapshot {\n    31\t        active_run: None,\n    32\t        status: RunStatus::Completed,\n    33\t        cycle_history: Vec::new(),\n    34\t        completion_rounds: 3,\n    35\t        rollback_point_meta: RollbackPointMeta::default(),\n    36\t        amendment_queue: AmendmentQueueState::default(),\n    37\t        status_summary: \"completed after 3 rounds\".to_owned(),\n    38\t    };\n    39\t    let view = queries::build_status_view(\"alpha\", &snapshot);\n    40\t\n    41\t    assert_eq!(view.status, \"completed\");\n    42\t    assert!(view.stage.is_none());\n    43\t    assert_eq!(view.summary, \"completed after 3 rounds\");\n    44\t}\n    45\t\n    46\t#[test]\n    47\tfn status_view_reports_failed_terminal_state_without_active_run() {\n    48\t    let snapshot = RunSnapshot {\n    49\t        active_run: None,\n    50\t        status: RunStatus::Failed,\n    51\t        cycle_history: Vec::new(),\n    52\t        completion_rounds: 0,\n    53\t        rollback_point_meta: RollbackPointMeta::default(),\n    54\t        amendment_queue: AmendmentQueueState::default(),\n    55\t        status_summary: \"failed at implementation\".to_owned(),\n    56\t    };\n    57\t    let view = queries::build_status_view(\"alpha\", &snapshot);\n    58\t\n    59\t    assert_eq!(view.status, \"failed\");\n    60\t    assert_eq!(view.summary, \"failed at implementation\");\n    61\t}\n    62\t\n    63\t#[test]\n    64\tfn status_view_reports_running_with_cursor() {\n    65\t    let snapshot = RunSnapshot {\n    66\t        active_run: Some(ActiveRun {\n    67\t            run_id: \"run-1\".to_owned(),\n    68\t            stage_cursor: StageCursor::initial(StageId::Planning),\n    69\t            started_at: test_timestamp(),\n    70\t        }),\n    71\t        status: RunStatus::Running,\n    72\t        cycle_history: Vec::new(),\n    73\t        completion_rounds: 0,\n    74\t        rollback_point_meta: RollbackPointMeta::default(),\n    75\t        amendment_queue: AmendmentQueueState::default(),\n    76\t        status_summary: \"running at planning\".to_owned(),\n    77\t    };\n    78\t    let view = queries::build_status_view(\"alpha\", &snapshot);\n    79\t\n    80\t    assert_eq!(view.status, \"running\");\n    81\t    assert_eq!(view.stage, Some(\"planning\".to_owned()));\n    82\t    assert_eq!(view.cycle, Some(1));\n    83\t    assert_eq!(view.completion_round, Some(1));\n    84\t}\n    85\t\n    86\t// ── RunHistoryView ──\n    87\t\n    88\t#[test]\n    89\tfn history_view_contains_only_durable_records() {\n    90\t    let events = vec![JournalEvent {\n    91\t        sequence: 1,\n    92\t        timestamp: test_timestamp(),\n    93\t        event_type: JournalEventType::ProjectCreated,\n    94\t        details: serde_json::json!({}),\n    95\t    }];\n    96\t\n    97\t    let view = queries::build_history_view(\"alpha\", events.clone(), vec![], vec![]);\n    98\t\n    99\t    assert_eq!(view.project_id, \"alpha\");\n   100\t    assert_eq!(view.events.len(), 1);\n   101\t    assert!(view.payloads.is_empty());\n   102\t    assert!(view.artifacts.is_empty());\n   103\t}\n   104\t\n   105\t// ── RunTailView ──\n   106\t\n   107\t#[test]\n   108\tfn tail_view_omits_logs_when_not_requested() {\n   109\t    let view = queries::build_tail_view(\"alpha\", vec![], vec![], vec![], false, vec![]);\n   110\t    assert!(view.runtime_logs.is_none());\n   111\t}\n   112\t\n   113\t#[test]\n   114\tfn tail_view_includes_logs_when_requested() {\n   115\t    let logs = vec![RuntimeLogEntry {\n   116\t        timestamp: test_timestamp(),\n   117\t        level: LogLevel::Info,\n   118\t        source: \"agent\".to_owned(),\n   119\t        message: \"started\".to_owned(),\n   120\t    }];\n   121\t\n   122\t    let view = queries::build_tail_view(\"alpha\", vec![], vec![], vec![], true, logs);\n   123\t    assert!(view.runtime_logs.is_some());\n   124\t    assert_eq!(view.runtime_logs.as_ref().unwrap().len(), 1);\n   125\t}\n   126\t\n   127\t#[test]\n   128\tfn tail_view_includes_empty_logs_when_requested_but_none_exist() {\n   129\t    let view = queries::build_tail_view(\"alpha\", vec![], vec![], vec![], true, vec![]);\n   130\t    assert!(view.runtime_logs.is_some());\n   131\t    assert!(view.runtime_logs.as_ref().unwrap().is_empty());\n   132\t}\n   133\t\n   134\t// ── History Consistency Validation ──\n   135\t\n   136\t#[test]\n   137\tfn validate_history_consistency_passes_with_matching_records() {\n   138\t    let payloads = vec![PayloadRecord {\n   139\t        payload_id: \"p1\".to_owned(),\n   140\t        stage_id: StageId::Planning,\n   141\t        cycle: 1,\n   142\t        attempt: 1,\n   143\t        created_at: test_timestamp(),\n   144\t        payload: serde_json::json!({}),\n   145\t    }];\n   146\t    let artifacts = vec![ArtifactRecord {\n   147\t        artifact_id: \"a1\".to_owned(),\n   148\t        payload_id: \"p1\".to_owned(),\n   149\t        stage_id: StageId::Planning,\n   150\t        created_at: test_timestamp(),\n   151\t        content: \"# Planning\".to_owned(),\n   152\t    }];\n   153\t\n   154\t    assert!(queries::validate_history_consistency(&payloads, &artifacts).is_ok());\n   155\t}\n   156\t\n   157\t#[test]\n   158\tfn validate_history_consistency_fails_with_orphaned_artifact() {\n   159\t    let payloads = vec![];\n   160\t    let artifacts = vec![ArtifactRecord {\n   161\t        artifact_id: \"a1\".to_owned(),\n   162\t        payload_id: \"p-missing\".to_owned(),\n   163\t        stage_id: StageId::Planning,\n   164\t        created_at: test_timestamp(),\n   165\t        content: \"# Planning\".to_owned(),\n   166\t    }];\n   167\t\n   168\t    let result = queries::validate_history_consistency(&payloads, &artifacts);\n   169\t    assert!(matches!(\n   170\t        result.unwrap_err(),\n   171\t        AppError::CorruptRecord { .. }\n   172\t    ));\n   173\t}\n   174\t\n   175\t#[test]\n   176\tfn validate_history_consistency_passes_with_no_records() {\n   177\t    assert!(queries::validate_history_consistency(&[], &[]).is_ok());\n   178\t}\n   179\t\n   180\t// ── Orphaned Payload Detection ──\n   181\t\n   182\t#[test]\n   183\tfn validate_history_consistency_fails_with_orphaned_payload() {\n   184\t    let payloads = vec![PayloadRecord {\n   185\t        payload_id: \"p-orphan\".to_owned(),\n   186\t        stage_id: StageId::Planning,\n   187\t        cycle: 1,\n   188\t        attempt: 1,\n   189\t        created_at: test_timestamp(),\n   190\t        payload: serde_json::json!({}),\n   191\t    }];\n   192\t    let artifacts = vec![];\n   193\t\n   194\t    let result = queries::validate_history_consistency(&payloads, &artifacts);\n   195\t    assert!(result.is_err());\n   196\t    let err = result.unwrap_err();\n   197\t    assert!(matches!(err, AppError::CorruptRecord { .. }));\n   198\t    match err {\n   199\t        AppError::CorruptRecord { details, .. } => {\n   200\t            assert!(details.contains(\"no matching artifact\"));\n   201\t        }\n   202\t        _ => panic!(\"expected CorruptRecord\"),\n   203\t    }\n   204\t}\n   205\t\n   206\t// ── RunSnapshot Schema Completeness ──\n   207\t\n   208\t#[test]\n   209\tfn run_snapshot_initial_includes_all_canonical_fields() {\n   210\t    let snapshot = RunSnapshot::initial();\n   211\t    let json = serde_json::to_string_pretty(&snapshot).expect(\"serialize\");\n   212\t\n   213\t    // Verify all canonical fields are present in the serialized form\n   214\t    assert!(json.contains(\"\\\"active_run\\\"\"));\n   215\t    assert!(json.contains(\"\\\"status\\\"\"));\n   216\t    assert!(json.contains(\"\\\"cycle_history\\\"\"));\n   217\t    assert!(json.contains(\"\\\"completion_rounds\\\"\"));\n   218\t    assert!(json.contains(\"\\\"rollback_point_meta\\\"\"));\n   219\t    assert!(json.contains(\"\\\"amendment_queue\\\"\"));\n   220\t    assert!(json.contains(\"\\\"status_summary\\\"\"));\n   221\t}\n   222\t\n   223\t#[test]\n   224\tfn run_snapshot_round_trips_through_json() {\n   225\t    let snapshot = RunSnapshot::initial();\n   226\t    let json = serde_json::to_string(&snapshot).expect(\"serialize\");\n   227\t    let parsed: RunSnapshot = serde_json::from_str(&json).expect(\"deserialize\");\n   228\t    assert_eq!(snapshot, parsed);\n   229\t}\n   230\t\n   231\t// ── Runtime Log Separation ──\n   232\t\n   233\t#[test]\n   234\tfn runtime_logs_never_appear_in_history_view() {\n   235\t    // History view has no field for runtime logs - enforced by type system.\n   236\t    let view = queries::build_history_view(\"alpha\", vec![], vec![], vec![]);\n   237\t    // RunHistoryView has no runtime_logs field, so logs can never leak.\n   238\t    assert_eq!(view.project_id, \"alpha\");\n   239\t}\n","exit_code":0,"status":"completed"}}
