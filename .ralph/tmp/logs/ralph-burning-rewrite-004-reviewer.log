{"type":"item.completed","item":{"id":"item_18","type":"command_execution","command":"/run/current-system/sw/bin/bash -lc \"nl -ba /root/new-ralph-burning/ralph-burning-rewrite/src/contexts/project_run_record/service.rs | sed -n '1,320p'\"","aggregated_output":"     1\tuse std::path::Path;\n     2\t\n     3\tuse chrono::{DateTime, Utc};\n     4\t\n     5\tuse crate::shared::domain::{FlowPreset, ProjectId};\n     6\tuse crate::shared::error::{AppError, AppResult};\n     7\t\n     8\tuse super::model::{\n     9\t    ArtifactRecord, JournalEvent, JournalEventType, PayloadRecord,\n    10\t    ProjectDetail, ProjectListEntry, ProjectRecord, ProjectStatusSummary,\n    11\t    RunSnapshot, RuntimeLogEntry, SessionStore,\n    12\t};\n    13\tuse super::journal;\n    14\tuse super::queries::{\n    15\t    self, RunHistoryView, RunStatusView, RunTailView,\n    16\t};\n    17\t\n    18\t/// Port for reading and writing project records.\n    19\tpub trait ProjectStorePort {\n    20\t    fn project_exists(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<bool>;\n    21\t    fn read_project_record(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<ProjectRecord>;\n    22\t    fn list_project_ids(&self, base_dir: &Path) -> AppResult<Vec<ProjectId>>;\n    23\t\n    24\t    /// Stage a project for deletion: makes it invisible to list/show but\n    25\t    /// keeps data on disk for potential rollback.\n    26\t    fn stage_delete(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<()>;\n    27\t\n    28\t    /// Finalize a staged delete: permanently removes the project data.\n    29\t    fn commit_delete(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<()>;\n    30\t\n    31\t    /// Roll back a staged delete: restores the project to its canonical path.\n    32\t    fn rollback_delete(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<()>;\n    33\t\n    34\t    /// Atomically stage and commit a new project. If any step fails,\n    35\t    /// the project must not be visible to list/show.\n    36\t    fn create_project_atomic(\n    37\t        &self,\n    38\t        base_dir: &Path,\n    39\t        record: &ProjectRecord,\n    40\t        prompt_contents: &str,\n    41\t        run_snapshot: &RunSnapshot,\n    42\t        initial_journal_line: &str,\n    43\t        sessions: &SessionStore,\n    44\t    ) -> AppResult<()>;\n    45\t}\n    46\t\n    47\t/// Port for reading and appending journal events.\n    48\tpub trait JournalStorePort {\n    49\t    fn read_journal(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<Vec<JournalEvent>>;\n    50\t    fn append_event(&self, base_dir: &Path, project_id: &ProjectId, line: &str) -> AppResult<()>;\n    51\t}\n    52\t\n    53\t/// Port for reading payload and artifact durable history.\n    54\tpub trait ArtifactStorePort {\n    55\t    fn list_payloads(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<Vec<PayloadRecord>>;\n    56\t    fn list_artifacts(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<Vec<ArtifactRecord>>;\n    57\t}\n    58\t\n    59\t/// Port for reading runtime logs (separate from durable history).\n    60\tpub trait RuntimeLogStorePort {\n    61\t    fn read_runtime_logs(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<Vec<RuntimeLogEntry>>;\n    62\t}\n    63\t\n    64\t/// Port for reading/writing the run snapshot.\n    65\tpub trait RunSnapshotPort {\n    66\t    fn read_run_snapshot(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<RunSnapshot>;\n    67\t}\n    68\t\n    69\t/// Port for reading/writing/clearing the active project pointer.\n    70\tpub trait ActiveProjectPort {\n    71\t    fn read_active_project_id(&self, base_dir: &Path) -> AppResult<Option<String>>;\n    72\t    fn clear_active_project(&self, base_dir: &Path) -> AppResult<()>;\n    73\t    fn write_active_project(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<()>;\n    74\t}\n    75\t\n    76\t/// Input for the `project create` use case.\n    77\tpub struct CreateProjectInput {\n    78\t    pub id: ProjectId,\n    79\t    pub name: String,\n    80\t    pub flow: FlowPreset,\n    81\t    pub prompt_path: String,\n    82\t    pub prompt_contents: String,\n    83\t    pub prompt_hash: String,\n    84\t    pub created_at: DateTime<Utc>,\n    85\t}\n    86\t\n    87\t/// Create a new project with all canonical files.\n    88\tpub fn create_project(\n    89\t    store: &dyn ProjectStorePort,\n    90\t    journal_store: &dyn JournalStorePort,\n    91\t    base_dir: &Path,\n    92\t    input: CreateProjectInput,\n    93\t) -> AppResult<ProjectRecord> {\n    94\t    // Check for duplicate project ID\n    95\t    if store.project_exists(base_dir, &input.id)? {\n    96\t        return Err(AppError::DuplicateProject {\n    97\t            project_id: input.id.to_string(),\n    98\t        });\n    99\t    }\n   100\t\n   101\t    let record = ProjectRecord {\n   102\t        id: input.id.clone(),\n   103\t        name: input.name,\n   104\t        flow: input.flow,\n   105\t        prompt_reference: \"prompt.md\".to_owned(),\n   106\t        prompt_hash: input.prompt_hash,\n   107\t        created_at: input.created_at,\n   108\t        status_summary: ProjectStatusSummary::Created,\n   109\t    };\n   110\t\n   111\t    let run_snapshot = RunSnapshot::initial();\n   112\t    let sessions = SessionStore::empty();\n   113\t\n   114\t    // Create the initial journal event\n   115\t    let initial_event = JournalEvent {\n   116\t        sequence: 1,\n   117\t        timestamp: input.created_at,\n   118\t        event_type: JournalEventType::ProjectCreated,\n   119\t        details: serde_json::json!({\n   120\t            \"project_id\": record.id.as_str(),\n   121\t            \"flow\": record.flow.as_str(),\n   122\t        }),\n   123\t    };\n   124\t    let journal_line = journal::serialize_event(&initial_event)?;\n   125\t\n   126\t    // Atomic creation: all files or nothing\n   127\t    store.create_project_atomic(\n   128\t        base_dir,\n   129\t        &record,\n   130\t        &input.prompt_contents,\n   131\t        &run_snapshot,\n   132\t        &journal_line,\n   133\t        &sessions,\n   134\t    )?;\n   135\t\n   136\t    // create_project_atomic writes the journal as part of the atomic init,\n   137\t    // but we don't call journal_store.append_event here because the atomic\n   138\t    // creation already wrote the initial journal line. The journal_store\n   139\t    // parameter is kept for interface consistency and future use.\n   140\t    let _ = journal_store;\n   141\t\n   142\t    Ok(record)\n   143\t}\n   144\t\n   145\t/// List all projects with summary data.\n   146\tpub fn list_projects(\n   147\t    store: &dyn ProjectStorePort,\n   148\t    active_port: &dyn ActiveProjectPort,\n   149\t    base_dir: &Path,\n   150\t) -> AppResult<Vec<ProjectListEntry>> {\n   151\t    let active_id = active_port.read_active_project_id(base_dir)?;\n   152\t    let project_ids = store.list_project_ids(base_dir)?;\n   153\t\n   154\t    let mut entries = Vec::new();\n   155\t    for pid in project_ids {\n   156\t        let record = store.read_project_record(base_dir, &pid)?;\n   157\t        let is_active = active_id.as_deref() == Some(pid.as_str());\n   158\t        entries.push(ProjectListEntry {\n   159\t            id: record.id,\n   160\t            name: record.name,\n   161\t            flow: record.flow,\n   162\t            status_summary: record.status_summary,\n   163\t            created_at: record.created_at,\n   164\t            is_active,\n   165\t        });\n   166\t    }\n   167\t\n   168\t    Ok(entries)\n   169\t}\n   170\t\n   171\t/// Show detailed project information.\n   172\tpub fn show_project(\n   173\t    store: &dyn ProjectStorePort,\n   174\t    run_port: &dyn RunSnapshotPort,\n   175\t    journal_port: &dyn JournalStorePort,\n   176\t    active_port: &dyn ActiveProjectPort,\n   177\t    base_dir: &Path,\n   178\t    project_id: &ProjectId,\n   179\t) -> AppResult<ProjectDetail> {\n   180\t    if !store.project_exists(base_dir, project_id)? {\n   181\t        return Err(AppError::ProjectNotFound {\n   182\t            project_id: project_id.to_string(),\n   183\t        });\n   184\t    }\n   185\t\n   186\t    let record = store.read_project_record(base_dir, project_id)?;\n   187\t    let run_snapshot = run_port.read_run_snapshot(base_dir, project_id)?;\n   188\t    let events = journal_port.read_journal(base_dir, project_id)?;\n   189\t    let journal_event_count = events.len() as u64;\n   190\t    let active_id = active_port.read_active_project_id(base_dir)?;\n   191\t    let is_active = active_id.as_deref() == Some(project_id.as_str());\n   192\t\n   193\t    // Count rollback points from journal events\n   194\t    let rollback_count = events\n   195\t        .iter()\n   196\t        .filter(|e| e.event_type == JournalEventType::RollbackCreated)\n   197\t        .count();\n   198\t\n   199\t    Ok(ProjectDetail {\n   200\t        record,\n   201\t        run_snapshot,\n   202\t        journal_event_count,\n   203\t        rollback_count,\n   204\t        is_active,\n   205\t    })\n   206\t}\n   207\t\n   208\t/// Delete a project. Fails if project has an active run.\n   209\t/// Clears active-project pointer if it pointed to the deleted project.\n   210\t///\n   211\t/// Transactional: if any post-validation step fails, the project remains\n   212\t/// addressable at its canonical path and the active-project pointer is\n   213\t/// unchanged.\n   214\tpub fn delete_project(\n   215\t    store: &dyn ProjectStorePort,\n   216\t    run_port: &dyn RunSnapshotPort,\n   217\t    active_port: &dyn ActiveProjectPort,\n   218\t    base_dir: &Path,\n   219\t    project_id: &ProjectId,\n   220\t) -> AppResult<()> {\n   221\t    if !store.project_exists(base_dir, project_id)? {\n   222\t        return Err(AppError::ProjectNotFound {\n   223\t            project_id: project_id.to_string(),\n   224\t        });\n   225\t    }\n   226\t\n   227\t    // Check for active run\n   228\t    let run_snapshot = run_port.read_run_snapshot(base_dir, project_id)?;\n   229\t    if run_snapshot.has_active_run() {\n   230\t        return Err(AppError::ActiveRunDelete {\n   231\t            project_id: project_id.to_string(),\n   232\t        });\n   233\t    }\n   234\t\n   235\t    // Check if this is the active project (before delete)\n   236\t    let active_id = active_port.read_active_project_id(base_dir)?;\n   237\t    let was_active = active_id.as_deref() == Some(project_id.as_str());\n   238\t\n   239\t    // Phase 1: Stage the delete — project becomes invisible to list/show\n   240\t    // but data remains on disk for rollback.\n   241\t    store.stage_delete(base_dir, project_id)?;\n   242\t\n   243\t    // Phase 2: Clear the active-project pointer if needed.\n   244\t    // If this fails, roll back the staged delete so the project remains\n   245\t    // addressable and the pointer is unchanged.\n   246\t    if was_active {\n   247\t        if let Err(clear_err) = active_port.clear_active_project(base_dir) {\n   248\t            store.rollback_delete(base_dir, project_id).map_err(|restore_err| {\n   249\t                AppError::CorruptRecord {\n   250\t                    file: format!(\"projects/{}\", project_id),\n   251\t                    details: format!(\n   252\t                        \"delete partially failed: pointer clear error: {}, restore error: {}\",\n   253\t                        clear_err, restore_err\n   254\t                    ),\n   255\t                }\n   256\t            })?;\n   257\t            return Err(clear_err);\n   258\t        }\n   259\t    }\n   260\t\n   261\t    // Phase 3: Finalize — permanently remove the project data.\n   262\t    // At this point the logical delete has succeeded (project is invisible,\n   263\t    // pointer is cleared). Best-effort cleanup of the staged data.\n   264\t    let _ = store.commit_delete(base_dir, project_id);\n   265\t\n   266\t    Ok(())\n   267\t}\n   268\t\n   269\t/// Get run status for the active project.\n   270\tpub fn run_status(\n   271\t    run_port: &dyn RunSnapshotPort,\n   272\t    base_dir: &Path,\n   273\t    project_id: &ProjectId,\n   274\t) -> AppResult<RunStatusView> {\n   275\t    let snapshot = run_port.read_run_snapshot(base_dir, project_id)?;\n   276\t    Ok(queries::build_status_view(project_id.as_str(), &snapshot))\n   277\t}\n   278\t\n   279\t/// Get run history (durable only, no runtime logs).\n   280\tpub fn run_history(\n   281\t    journal_port: &dyn JournalStorePort,\n   282\t    artifact_port: &dyn ArtifactStorePort,\n   283\t    base_dir: &Path,\n   284\t    project_id: &ProjectId,\n   285\t) -> AppResult<RunHistoryView> {\n   286\t    let events = journal_port.read_journal(base_dir, project_id)?;\n   287\t    let payloads = artifact_port.list_payloads(base_dir, project_id)?;\n   288\t    let artifacts = artifact_port.list_artifacts(base_dir, project_id)?;\n   289\t\n   290\t    queries::validate_history_consistency(&payloads, &artifacts)?;\n   291\t\n   292\t    Ok(queries::build_history_view(\n   293\t        project_id.as_str(),\n   294\t        events,\n   295\t        payloads,\n   296\t        artifacts,\n   297\t    ))\n   298\t}\n   299\t\n   300\t/// Get run tail: durable history by default, with optional runtime logs.\n   301\tpub fn run_tail(\n   302\t    journal_port: &dyn JournalStorePort,\n   303\t    artifact_port: &dyn ArtifactStorePort,\n   304\t    log_port: &dyn RuntimeLogStorePort,\n   305\t    base_dir: &Path,\n   306\t    project_id: &ProjectId,\n   307\t    include_logs: bool,\n   308\t) -> AppResult<RunTailView> {\n   309\t    let events = journal_port.read_journal(base_dir, project_id)?;\n   310\t    let payloads = artifact_port.list_payloads(base_dir, project_id)?;\n   311\t    let artifacts = artifact_port.list_artifacts(base_dir, project_id)?;\n   312\t\n   313\t    queries::validate_history_consistency(&payloads, &artifacts)?;\n   314\t\n   315\t    let runtime_logs = if include_logs {\n   316\t        log_port.read_runtime_logs(base_dir, project_id)?\n   317\t    } else {\n   318\t        Vec::new()\n   319\t    };\n   320\t\n","exit_code":0,"status":"completed"}}
