{"type":"item.completed","item":{"id":"item_25","type":"command_execution","command":"/run/current-system/sw/bin/bash -lc \"nl -ba /root/new-ralph-burning/ralph-burning-rewrite/tests/cli.rs | sed -n '460,920p'\"","aggregated_output":"   460\t    let temp_dir = initialize_workspace_fixture();\n   461\t    // Use a non-standard filename to verify the recorded reference is canonical\n   462\t    let external_prompt = temp_dir.path().join(\"my-external-prompt.md\");\n   463\t    fs::write(&external_prompt, \"# External Prompt\\nContent.\").expect(\"write prompt\");\n   464\t\n   465\t    let output = Command::new(binary())\n   466\t        .args([\n   467\t            \"project\", \"create\",\n   468\t            \"--id\", \"reftest\",\n   469\t            \"--name\", \"Ref Test\",\n   470\t            \"--prompt\", external_prompt.to_str().unwrap(),\n   471\t            \"--flow\", \"standard\",\n   472\t        ])\n   473\t        .current_dir(temp_dir.path())\n   474\t        .output()\n   475\t        .expect(\"run project create\");\n   476\t    assert!(output.status.success());\n   477\t\n   478\t    let project_toml = fs::read_to_string(\n   479\t        temp_dir.path().join(\".ralph-burning/projects/reftest/project.toml\"),\n   480\t    )\n   481\t    .expect(\"read project.toml\");\n   482\t\n   483\t    // prompt_reference should be the canonical copied path, not the source path\n   484\t    assert!(\n   485\t        project_toml.contains(\"prompt_reference = \\\"prompt.md\\\"\"),\n   486\t        \"project.toml should record canonical prompt.md, got:\\n{project_toml}\"\n   487\t    );\n   488\t    assert!(\n   489\t        !project_toml.contains(\"my-external-prompt\"),\n   490\t        \"project.toml should not contain the source path\"\n   491\t    );\n   492\t}\n   493\t\n   494\t#[test]\n   495\tfn project_create_fails_on_duplicate_id() {\n   496\t    let temp_dir = initialize_workspace_fixture();\n   497\t    let prompt = write_prompt_fixture(temp_dir.path());\n   498\t\n   499\t    let first = Command::new(binary())\n   500\t        .args([\n   501\t            \"project\", \"create\",\n   502\t            \"--id\", \"dup\",\n   503\t            \"--name\", \"First\",\n   504\t            \"--prompt\", prompt.to_str().unwrap(),\n   505\t            \"--flow\", \"standard\",\n   506\t        ])\n   507\t        .current_dir(temp_dir.path())\n   508\t        .output()\n   509\t        .expect(\"first create\");\n   510\t    assert!(first.status.success());\n   511\t\n   512\t    let second = Command::new(binary())\n   513\t        .args([\n   514\t            \"project\", \"create\",\n   515\t            \"--id\", \"dup\",\n   516\t            \"--name\", \"Second\",\n   517\t            \"--prompt\", prompt.to_str().unwrap(),\n   518\t            \"--flow\", \"standard\",\n   519\t        ])\n   520\t        .current_dir(temp_dir.path())\n   521\t        .output()\n   522\t        .expect(\"second create\");\n   523\t\n   524\t    assert!(!second.status.success());\n   525\t    let stderr = String::from_utf8_lossy(&second.stderr);\n   526\t    assert!(stderr.contains(\"already exists\"));\n   527\t}\n   528\t\n   529\t#[test]\n   530\tfn project_create_fails_on_invalid_flow() {\n   531\t    let temp_dir = initialize_workspace_fixture();\n   532\t    let prompt = write_prompt_fixture(temp_dir.path());\n   533\t\n   534\t    let output = Command::new(binary())\n   535\t        .args([\n   536\t            \"project\", \"create\",\n   537\t            \"--id\", \"bad-flow\",\n   538\t            \"--name\", \"Bad Flow\",\n   539\t            \"--prompt\", prompt.to_str().unwrap(),\n   540\t            \"--flow\", \"nonexistent\",\n   541\t        ])\n   542\t        .current_dir(temp_dir.path())\n   543\t        .output()\n   544\t        .expect(\"run project create\");\n   545\t\n   546\t    assert!(!output.status.success());\n   547\t    let stderr = String::from_utf8_lossy(&output.stderr);\n   548\t    assert!(stderr.contains(\"unknown flow preset\"));\n   549\t}\n   550\t\n   551\t#[test]\n   552\tfn project_create_fails_on_missing_prompt() {\n   553\t    let temp_dir = initialize_workspace_fixture();\n   554\t\n   555\t    let output = Command::new(binary())\n   556\t        .args([\n   557\t            \"project\", \"create\",\n   558\t            \"--id\", \"no-prompt\",\n   559\t            \"--name\", \"No Prompt\",\n   560\t            \"--prompt\", \"/nonexistent/prompt.md\",\n   561\t            \"--flow\", \"standard\",\n   562\t        ])\n   563\t        .current_dir(temp_dir.path())\n   564\t        .output()\n   565\t        .expect(\"run project create\");\n   566\t\n   567\t    assert!(!output.status.success());\n   568\t    let stderr = String::from_utf8_lossy(&output.stderr);\n   569\t    assert!(stderr.contains(\"invalid prompt file\"));\n   570\t}\n   571\t\n   572\t#[test]\n   573\tfn project_create_does_not_set_active_project() {\n   574\t    let temp_dir = initialize_workspace_fixture();\n   575\t    let prompt = write_prompt_fixture(temp_dir.path());\n   576\t\n   577\t    Command::new(binary())\n   578\t        .args([\n   579\t            \"project\", \"create\",\n   580\t            \"--id\", \"noactive\",\n   581\t            \"--name\", \"No Active\",\n   582\t            \"--prompt\", prompt.to_str().unwrap(),\n   583\t            \"--flow\", \"standard\",\n   584\t        ])\n   585\t        .current_dir(temp_dir.path())\n   586\t        .output()\n   587\t        .expect(\"run project create\");\n   588\t\n   589\t    // active-project should not exist (create does not set it)\n   590\t    assert!(!temp_dir\n   591\t        .path()\n   592\t        .join(\".ralph-burning/active-project\")\n   593\t        .exists());\n   594\t}\n   595\t\n   596\t// ── Project List ──\n   597\t\n   598\t#[test]\n   599\tfn project_list_shows_no_projects_when_empty() {\n   600\t    let temp_dir = initialize_workspace_fixture();\n   601\t\n   602\t    let output = Command::new(binary())\n   603\t        .args([\"project\", \"list\"])\n   604\t        .current_dir(temp_dir.path())\n   605\t        .output()\n   606\t        .expect(\"run project list\");\n   607\t\n   608\t    assert!(output.status.success());\n   609\t    let stdout = String::from_utf8_lossy(&output.stdout);\n   610\t    assert!(stdout.contains(\"No projects found\"));\n   611\t}\n   612\t\n   613\t#[test]\n   614\tfn project_list_shows_created_projects_with_active_marker() {\n   615\t    let temp_dir = initialize_workspace_fixture();\n   616\t    let prompt = write_prompt_fixture(temp_dir.path());\n   617\t\n   618\t    // Create two projects\n   619\t    Command::new(binary())\n   620\t        .args([\n   621\t            \"project\", \"create\",\n   622\t            \"--id\", \"alpha\",\n   623\t            \"--name\", \"Alpha\",\n   624\t            \"--prompt\", prompt.to_str().unwrap(),\n   625\t            \"--flow\", \"standard\",\n   626\t        ])\n   627\t        .current_dir(temp_dir.path())\n   628\t        .output()\n   629\t        .expect(\"create alpha\");\n   630\t\n   631\t    Command::new(binary())\n   632\t        .args([\n   633\t            \"project\", \"create\",\n   634\t            \"--id\", \"beta\",\n   635\t            \"--name\", \"Beta\",\n   636\t            \"--prompt\", prompt.to_str().unwrap(),\n   637\t            \"--flow\", \"quick_dev\",\n   638\t        ])\n   639\t        .current_dir(temp_dir.path())\n   640\t        .output()\n   641\t        .expect(\"create beta\");\n   642\t\n   643\t    // Select alpha as active\n   644\t    Command::new(binary())\n   645\t        .args([\"project\", \"select\", \"alpha\"])\n   646\t        .current_dir(temp_dir.path())\n   647\t        .output()\n   648\t        .expect(\"select alpha\");\n   649\t\n   650\t    let output = Command::new(binary())\n   651\t        .args([\"project\", \"list\"])\n   652\t        .current_dir(temp_dir.path())\n   653\t        .output()\n   654\t        .expect(\"run project list\");\n   655\t\n   656\t    assert!(output.status.success());\n   657\t    let stdout = String::from_utf8_lossy(&output.stdout);\n   658\t    assert!(stdout.contains(\"alpha *\"));\n   659\t    assert!(stdout.contains(\"beta\"));\n   660\t    assert!(stdout.contains(\"standard\"));\n   661\t    assert!(stdout.contains(\"quick_dev\"));\n   662\t}\n   663\t\n   664\t// ── Project Show ──\n   665\t\n   666\t#[test]\n   667\tfn project_show_displays_project_details() {\n   668\t    let temp_dir = initialize_workspace_fixture();\n   669\t    let prompt = write_prompt_fixture(temp_dir.path());\n   670\t\n   671\t    Command::new(binary())\n   672\t        .args([\n   673\t            \"project\", \"create\",\n   674\t            \"--id\", \"showme\",\n   675\t            \"--name\", \"Show Me\",\n   676\t            \"--prompt\", prompt.to_str().unwrap(),\n   677\t            \"--flow\", \"docs_change\",\n   678\t        ])\n   679\t        .current_dir(temp_dir.path())\n   680\t        .output()\n   681\t        .expect(\"create project\");\n   682\t\n   683\t    let output = Command::new(binary())\n   684\t        .args([\"project\", \"show\", \"showme\"])\n   685\t        .current_dir(temp_dir.path())\n   686\t        .output()\n   687\t        .expect(\"run project show\");\n   688\t\n   689\t    assert!(output.status.success());\n   690\t    let stdout = String::from_utf8_lossy(&output.stdout);\n   691\t    assert!(stdout.contains(\"Project: showme\"));\n   692\t    assert!(stdout.contains(\"Name: Show Me\"));\n   693\t    assert!(stdout.contains(\"Flow: docs_change\"));\n   694\t    assert!(stdout.contains(\"Prompt hash:\"));\n   695\t    assert!(stdout.contains(\"Run status: not started\"));\n   696\t    assert!(stdout.contains(\"Journal events: 1\"));\n   697\t}\n   698\t\n   699\t#[test]\n   700\tfn project_show_resolves_active_project_when_no_id_given() {\n   701\t    let temp_dir = initialize_workspace_fixture();\n   702\t    let prompt = write_prompt_fixture(temp_dir.path());\n   703\t\n   704\t    Command::new(binary())\n   705\t        .args([\n   706\t            \"project\", \"create\",\n   707\t            \"--id\", \"active-show\",\n   708\t            \"--name\", \"Active Show\",\n   709\t            \"--prompt\", prompt.to_str().unwrap(),\n   710\t            \"--flow\", \"standard\",\n   711\t        ])\n   712\t        .current_dir(temp_dir.path())\n   713\t        .output()\n   714\t        .expect(\"create project\");\n   715\t\n   716\t    Command::new(binary())\n   717\t        .args([\"project\", \"select\", \"active-show\"])\n   718\t        .current_dir(temp_dir.path())\n   719\t        .output()\n   720\t        .expect(\"select project\");\n   721\t\n   722\t    let output = Command::new(binary())\n   723\t        .args([\"project\", \"show\"])\n   724\t        .current_dir(temp_dir.path())\n   725\t        .output()\n   726\t        .expect(\"run project show without id\");\n   727\t\n   728\t    assert!(output.status.success());\n   729\t    let stdout = String::from_utf8_lossy(&output.stdout);\n   730\t    assert!(stdout.contains(\"Project: active-show (active)\"));\n   731\t}\n   732\t\n   733\t// ── Project Delete ──\n   734\t\n   735\t#[test]\n   736\tfn project_delete_removes_project_directory() {\n   737\t    let temp_dir = initialize_workspace_fixture();\n   738\t    let prompt = write_prompt_fixture(temp_dir.path());\n   739\t\n   740\t    Command::new(binary())\n   741\t        .args([\n   742\t            \"project\", \"create\",\n   743\t            \"--id\", \"deleteme\",\n   744\t            \"--name\", \"Delete Me\",\n   745\t            \"--prompt\", prompt.to_str().unwrap(),\n   746\t            \"--flow\", \"standard\",\n   747\t        ])\n   748\t        .current_dir(temp_dir.path())\n   749\t        .output()\n   750\t        .expect(\"create project\");\n   751\t\n   752\t    let output = Command::new(binary())\n   753\t        .args([\"project\", \"delete\", \"deleteme\"])\n   754\t        .current_dir(temp_dir.path())\n   755\t        .output()\n   756\t        .expect(\"run project delete\");\n   757\t\n   758\t    assert!(output.status.success());\n   759\t    let stdout = String::from_utf8_lossy(&output.stdout);\n   760\t    assert!(stdout.contains(\"Deleted project 'deleteme'\"));\n   761\t    assert!(!temp_dir\n   762\t        .path()\n   763\t        .join(\".ralph-burning/projects/deleteme\")\n   764\t        .exists());\n   765\t}\n   766\t\n   767\t#[test]\n   768\tfn project_delete_clears_active_project_if_selected() {\n   769\t    let temp_dir = initialize_workspace_fixture();\n   770\t    let prompt = write_prompt_fixture(temp_dir.path());\n   771\t\n   772\t    Command::new(binary())\n   773\t        .args([\n   774\t            \"project\", \"create\",\n   775\t            \"--id\", \"active-del\",\n   776\t            \"--name\", \"Active Del\",\n   777\t            \"--prompt\", prompt.to_str().unwrap(),\n   778\t            \"--flow\", \"standard\",\n   779\t        ])\n   780\t        .current_dir(temp_dir.path())\n   781\t        .output()\n   782\t        .expect(\"create project\");\n   783\t\n   784\t    Command::new(binary())\n   785\t        .args([\"project\", \"select\", \"active-del\"])\n   786\t        .current_dir(temp_dir.path())\n   787\t        .output()\n   788\t        .expect(\"select project\");\n   789\t\n   790\t    assert!(temp_dir\n   791\t        .path()\n   792\t        .join(\".ralph-burning/active-project\")\n   793\t        .exists());\n   794\t\n   795\t    let output = Command::new(binary())\n   796\t        .args([\"project\", \"delete\", \"active-del\"])\n   797\t        .current_dir(temp_dir.path())\n   798\t        .output()\n   799\t        .expect(\"run project delete\");\n   800\t\n   801\t    assert!(output.status.success());\n   802\t    assert!(!temp_dir\n   803\t        .path()\n   804\t        .join(\".ralph-burning/active-project\")\n   805\t        .exists());\n   806\t}\n   807\t\n   808\t#[test]\n   809\tfn project_delete_fails_for_missing_project() {\n   810\t    let temp_dir = initialize_workspace_fixture();\n   811\t\n   812\t    let output = Command::new(binary())\n   813\t        .args([\"project\", \"delete\", \"nonexistent\"])\n   814\t        .current_dir(temp_dir.path())\n   815\t        .output()\n   816\t        .expect(\"run project delete\");\n   817\t\n   818\t    assert!(!output.status.success());\n   819\t    let stderr = String::from_utf8_lossy(&output.stderr);\n   820\t    assert!(stderr.contains(\"not found\"));\n   821\t}\n   822\t\n   823\t// ── Run Status ──\n   824\t\n   825\t#[test]\n   826\tfn run_status_shows_not_started_for_new_project() {\n   827\t    let temp_dir = initialize_workspace_fixture();\n   828\t    let prompt = write_prompt_fixture(temp_dir.path());\n   829\t\n   830\t    Command::new(binary())\n   831\t        .args([\n   832\t            \"project\", \"create\",\n   833\t            \"--id\", \"status-test\",\n   834\t            \"--name\", \"Status Test\",\n   835\t            \"--prompt\", prompt.to_str().unwrap(),\n   836\t            \"--flow\", \"standard\",\n   837\t        ])\n   838\t        .current_dir(temp_dir.path())\n   839\t        .output()\n   840\t        .expect(\"create project\");\n   841\t\n   842\t    Command::new(binary())\n   843\t        .args([\"project\", \"select\", \"status-test\"])\n   844\t        .current_dir(temp_dir.path())\n   845\t        .output()\n   846\t        .expect(\"select project\");\n   847\t\n   848\t    let output = Command::new(binary())\n   849\t        .args([\"run\", \"status\"])\n   850\t        .current_dir(temp_dir.path())\n   851\t        .output()\n   852\t        .expect(\"run status\");\n   853\t\n   854\t    assert!(output.status.success());\n   855\t    let stdout = String::from_utf8_lossy(&output.stdout);\n   856\t    assert!(stdout.contains(\"Status: not started\"));\n   857\t}\n   858\t\n   859\t// ── Run History ──\n   860\t\n   861\t#[test]\n   862\tfn run_history_shows_journal_events_for_new_project() {\n   863\t    let temp_dir = initialize_workspace_fixture();\n   864\t    let prompt = write_prompt_fixture(temp_dir.path());\n   865\t\n   866\t    Command::new(binary())\n   867\t        .args([\n   868\t            \"project\", \"create\",\n   869\t            \"--id\", \"hist-test\",\n   870\t            \"--name\", \"History Test\",\n   871\t            \"--prompt\", prompt.to_str().unwrap(),\n   872\t            \"--flow\", \"standard\",\n   873\t        ])\n   874\t        .current_dir(temp_dir.path())\n   875\t        .output()\n   876\t        .expect(\"create project\");\n   877\t\n   878\t    Command::new(binary())\n   879\t        .args([\"project\", \"select\", \"hist-test\"])\n   880\t        .current_dir(temp_dir.path())\n   881\t        .output()\n   882\t        .expect(\"select project\");\n   883\t\n   884\t    let output = Command::new(binary())\n   885\t        .args([\"run\", \"history\"])\n   886\t        .current_dir(temp_dir.path())\n   887\t        .output()\n   888\t        .expect(\"run history\");\n   889\t\n   890\t    assert!(output.status.success());\n   891\t    let stdout = String::from_utf8_lossy(&output.stdout);\n   892\t    assert!(stdout.contains(\"Journal Events\"));\n   893\t    assert!(stdout.contains(\"ProjectCreated\"));\n   894\t}\n   895\t\n   896\t// ── Run Tail ──\n   897\t\n   898\t#[test]\n   899\tfn run_tail_shows_durable_history_only_by_default() {\n   900\t    let temp_dir = initialize_workspace_fixture();\n   901\t    let prompt = write_prompt_fixture(temp_dir.path());\n   902\t\n   903\t    Command::new(binary())\n   904\t        .args([\n   905\t            \"project\", \"create\",\n   906\t            \"--id\", \"tail-test\",\n   907\t            \"--name\", \"Tail Test\",\n   908\t            \"--prompt\", prompt.to_str().unwrap(),\n   909\t            \"--flow\", \"standard\",\n   910\t        ])\n   911\t        .current_dir(temp_dir.path())\n   912\t        .output()\n   913\t        .expect(\"create project\");\n   914\t\n   915\t    Command::new(binary())\n   916\t        .args([\"project\", \"select\", \"tail-test\"])\n   917\t        .current_dir(temp_dir.path())\n   918\t        .output()\n   919\t        .expect(\"select project\");\n   920\t\n","exit_code":0,"status":"completed"}}
