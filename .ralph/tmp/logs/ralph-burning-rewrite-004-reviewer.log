{"type":"item.completed","item":{"id":"item_28","type":"command_execution","command":"/run/current-system/sw/bin/bash -lc \"nl -ba /root/new-ralph-burning/ralph-burning-rewrite/src/contexts/project_run_record/journal.rs | sed -n '1,240p'\"","aggregated_output":"     1\tuse crate::shared::error::{AppError, AppResult};\n     2\t\n     3\tuse super::model::JournalEvent;\n     4\t\n     5\t/// Validates that a new event's sequence follows the last known sequence.\n     6\t/// The first event must have sequence 1.\n     7\tpub fn validate_sequence(last_sequence: u64, event: &JournalEvent) -> AppResult<()> {\n     8\t    let expected = last_sequence + 1;\n     9\t    if event.sequence != expected {\n    10\t        return Err(AppError::JournalSequence {\n    11\t            details: format!(\n    12\t                \"expected sequence {expected}, got {}\",\n    13\t                event.sequence\n    14\t            ),\n    15\t        });\n    16\t    }\n    17\t    Ok(())\n    18\t}\n    19\t\n    20\t/// Serializes a journal event to a single NDJSON line (no trailing newline).\n    21\tpub fn serialize_event(event: &JournalEvent) -> AppResult<String> {\n    22\t    Ok(serde_json::to_string(event)?)\n    23\t}\n    24\t\n    25\t/// Deserializes a single NDJSON line into a journal event.\n    26\tpub fn deserialize_event(line: &str) -> AppResult<JournalEvent> {\n    27\t    let trimmed = line.trim();\n    28\t    if trimmed.is_empty() {\n    29\t        return Err(AppError::CorruptRecord {\n    30\t            file: \"journal.ndjson\".to_owned(),\n    31\t            details: \"empty line in journal\".to_owned(),\n    32\t        });\n    33\t    }\n    34\t    serde_json::from_str(trimmed).map_err(|e| AppError::CorruptRecord {\n    35\t        file: \"journal.ndjson\".to_owned(),\n    36\t        details: format!(\"invalid journal event: {e}\"),\n    37\t    })\n    38\t}\n    39\t\n    40\t/// Parses the full contents of a journal.ndjson file into ordered events.\n    41\t/// Validates monotonic sequence ordering.\n    42\tpub fn parse_journal(contents: &str) -> AppResult<Vec<JournalEvent>> {\n    43\t    let mut events = Vec::new();\n    44\t    let mut last_sequence = 0u64;\n    45\t\n    46\t    for line in contents.lines() {\n    47\t        if line.trim().is_empty() {\n    48\t            continue;\n    49\t        }\n    50\t        let event = deserialize_event(line)?;\n    51\t        validate_sequence(last_sequence, &event)?;\n    52\t        last_sequence = event.sequence;\n    53\t        events.push(event);\n    54\t    }\n    55\t\n    56\t    Ok(events)\n    57\t}\n    58\t\n    59\t/// Returns the last sequence number from a set of events, or 0 if empty.\n    60\tpub fn last_sequence(events: &[JournalEvent]) -> u64 {\n    61\t    events.last().map_or(0, |e| e.sequence)\n    62\t}\n","exit_code":0,"status":"completed"}}
