{"type":"item.completed","item":{"id":"item_19","type":"command_execution","command":"/run/current-system/sw/bin/bash -lc \"nl -ba /root/new-ralph-burning/ralph-burning-rewrite/src/adapters/fs.rs | sed -n '420,760p'\"","aggregated_output":"   420\t\n   421\t    fn append_event(\n   422\t        &self,\n   423\t        base_dir: &Path,\n   424\t        project_id: &ProjectId,\n   425\t        line: &str,\n   426\t    ) -> AppResult<()> {\n   427\t        let path = FileSystem::project_root(base_dir, project_id).join(JOURNAL_FILE);\n   428\t        FileSystem::append_line(&path, line)\n   429\t    }\n   430\t}\n   431\t\n   432\t/// Filesystem-backed implementation of `ArtifactStorePort`.\n   433\tpub struct FsArtifactStore;\n   434\t\n   435\timpl ArtifactStorePort for FsArtifactStore {\n   436\t    fn list_payloads(\n   437\t        &self,\n   438\t        base_dir: &Path,\n   439\t        project_id: &ProjectId,\n   440\t    ) -> AppResult<Vec<PayloadRecord>> {\n   441\t        let dir = FileSystem::project_root(base_dir, project_id).join(\"history/payloads\");\n   442\t        if !dir.is_dir() {\n   443\t            return Ok(Vec::new());\n   444\t        }\n   445\t\n   446\t        let mut records = Vec::new();\n   447\t        for entry in fs::read_dir(&dir)? {\n   448\t            let entry = entry?;\n   449\t            let path = entry.path();\n   450\t            if path.extension().is_some_and(|ext| ext == \"json\") {\n   451\t                let raw = fs::read_to_string(&path)?;\n   452\t                let record: PayloadRecord = serde_json::from_str(&raw).map_err(|e| {\n   453\t                    AppError::CorruptRecord {\n   454\t                        file: format!(\n   455\t                            \"history/payloads/{}\",\n   456\t                            path.file_name()\n   457\t                                .unwrap_or_default()\n   458\t                                .to_string_lossy()\n   459\t                        ),\n   460\t                        details: e.to_string(),\n   461\t                    }\n   462\t                })?;\n   463\t                records.push(record);\n   464\t            }\n   465\t        }\n   466\t\n   467\t        records.sort_by_key(|r| r.created_at);\n   468\t        Ok(records)\n   469\t    }\n   470\t\n   471\t    fn list_artifacts(\n   472\t        &self,\n   473\t        base_dir: &Path,\n   474\t        project_id: &ProjectId,\n   475\t    ) -> AppResult<Vec<ArtifactRecord>> {\n   476\t        let dir = FileSystem::project_root(base_dir, project_id).join(\"history/artifacts\");\n   477\t        if !dir.is_dir() {\n   478\t            return Ok(Vec::new());\n   479\t        }\n   480\t\n   481\t        let mut records = Vec::new();\n   482\t        for entry in fs::read_dir(&dir)? {\n   483\t            let entry = entry?;\n   484\t            let path = entry.path();\n   485\t            if path.extension().is_some_and(|ext| ext == \"json\") {\n   486\t                let raw = fs::read_to_string(&path)?;\n   487\t                let record: ArtifactRecord =\n   488\t                    serde_json::from_str(&raw).map_err(|e| AppError::CorruptRecord {\n   489\t                        file: format!(\n   490\t                            \"history/artifacts/{}\",\n   491\t                            path.file_name()\n   492\t                                .unwrap_or_default()\n   493\t                                .to_string_lossy()\n   494\t                        ),\n   495\t                        details: e.to_string(),\n   496\t                    })?;\n   497\t                records.push(record);\n   498\t            }\n   499\t        }\n   500\t\n   501\t        records.sort_by_key(|r| r.created_at);\n   502\t        Ok(records)\n   503\t    }\n   504\t}\n   505\t\n   506\t/// Filesystem-backed implementation of `RuntimeLogStorePort`.\n   507\tpub struct FsRuntimeLogStore;\n   508\t\n   509\timpl RuntimeLogStorePort for FsRuntimeLogStore {\n   510\t    fn read_runtime_logs(\n   511\t        &self,\n   512\t        base_dir: &Path,\n   513\t        project_id: &ProjectId,\n   514\t    ) -> AppResult<Vec<RuntimeLogEntry>> {\n   515\t        let dir = FileSystem::project_root(base_dir, project_id).join(\"runtime/logs\");\n   516\t        if !dir.is_dir() {\n   517\t            return Ok(Vec::new());\n   518\t        }\n   519\t\n   520\t        let mut entries = Vec::new();\n   521\t        let mut paths: Vec<_> = fs::read_dir(&dir)?\n   522\t            .filter_map(|e| e.ok())\n   523\t            .map(|e| e.path())\n   524\t            .filter(|p| p.extension().is_some_and(|ext| ext == \"ndjson\"))\n   525\t            .collect();\n   526\t        paths.sort();\n   527\t\n   528\t        for path in paths {\n   529\t            let contents = fs::read_to_string(&path)?;\n   530\t            for line in contents.lines() {\n   531\t                let trimmed = line.trim();\n   532\t                if trimmed.is_empty() {\n   533\t                    continue;\n   534\t                }\n   535\t                if let Ok(entry) = serde_json::from_str::<RuntimeLogEntry>(trimmed) {\n   536\t                    entries.push(entry);\n   537\t                }\n   538\t            }\n   539\t        }\n   540\t\n   541\t        Ok(entries)\n   542\t    }\n   543\t}\n   544\t\n   545\t/// Filesystem-backed implementation of `RunSnapshotPort`.\n   546\tpub struct FsRunSnapshotStore;\n   547\t\n   548\timpl RunSnapshotPort for FsRunSnapshotStore {\n   549\t    fn read_run_snapshot(\n   550\t        &self,\n   551\t        base_dir: &Path,\n   552\t        project_id: &ProjectId,\n   553\t    ) -> AppResult<RunSnapshot> {\n   554\t        let path = FileSystem::project_root(base_dir, project_id).join(RUN_FILE);\n   555\t        match fs::read_to_string(&path) {\n   556\t            Ok(raw) => {\n   557\t                let snapshot: RunSnapshot =\n   558\t                    serde_json::from_str(&raw).map_err(|e| AppError::CorruptRecord {\n   559\t                        file: format!(\"projects/{}/run.json\", project_id),\n   560\t                        details: e.to_string(),\n   561\t                    })?;\n   562\t                // Semantic validation: reject inconsistent status/active_run combinations\n   563\t                snapshot\n   564\t                    .validate_semantics()\n   565\t                    .map_err(|details| AppError::CorruptRecord {\n   566\t                        file: format!(\"projects/{}/run.json\", project_id),\n   567\t                        details,\n   568\t                    })?;\n   569\t                Ok(snapshot)\n   570\t            }\n   571\t            Err(e) if e.kind() == std::io::ErrorKind::NotFound => {\n   572\t                Err(AppError::CorruptRecord {\n   573\t                    file: format!(\"projects/{}/run.json\", project_id),\n   574\t                    details: \"canonical file is missing\".to_owned(),\n   575\t                })\n   576\t            }\n   577\t            Err(e) => Err(e.into()),\n   578\t        }\n   579\t    }\n   580\t}\n   581\t\n   582\t/// Filesystem-backed implementation of `ActiveProjectPort`.\n   583\tpub struct FsActiveProjectStore;\n   584\t\n   585\timpl ActiveProjectPort for FsActiveProjectStore {\n   586\t    fn read_active_project_id(&self, base_dir: &Path) -> AppResult<Option<String>> {\n   587\t        FileSystem::read_active_project(&FileSystem::workspace_root_path(base_dir))\n   588\t    }\n   589\t\n   590\t    fn clear_active_project(&self, base_dir: &Path) -> AppResult<()> {\n   591\t        let path = FileSystem::workspace_root_path(base_dir).join(ACTIVE_PROJECT_FILE);\n   592\t        match fs::remove_file(&path) {\n   593\t            Ok(()) => Ok(()),\n   594\t            Err(e) if e.kind() == std::io::ErrorKind::NotFound => Ok(()),\n   595\t            Err(e) => Err(e.into()),\n   596\t        }\n   597\t    }\n   598\t}\n   599\t\n   600\t/// Recursively copy a directory tree from `src` to `dst`.\n   601\t/// Used as a fallback when rename-based restore fails during transactional delete.\n   602\tfn copy_dir_recursive(src: &Path, dst: &Path) -> std::io::Result<()> {\n   603\t    fs::create_dir_all(dst)?;\n   604\t    for entry in fs::read_dir(src)? {\n   605\t        let entry = entry?;\n   606\t        let src_path = entry.path();\n   607\t        let dst_path = dst.join(entry.file_name());\n   608\t        if entry.file_type()?.is_dir() {\n   609\t            copy_dir_recursive(&src_path, &dst_path)?;\n   610\t        } else {\n   611\t            fs::copy(&src_path, &dst_path)?;\n   612\t        }\n   613\t    }\n   614\t    Ok(())\n   615\t}\n","exit_code":0,"status":"completed"}}
