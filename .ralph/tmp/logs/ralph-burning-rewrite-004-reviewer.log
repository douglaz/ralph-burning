{"type":"item.completed","item":{"id":"item_20","type":"command_execution","command":"/run/current-system/sw/bin/bash -lc \"nl -ba /root/new-ralph-burning/ralph-burning-rewrite/src/shared/error.rs | sed -n '1,260p'\"","aggregated_output":"     1\tuse std::path::PathBuf;\n     2\t\n     3\tuse thiserror::Error;\n     4\t\n     5\tuse crate::shared::domain::{FailureClass, StageId};\n     6\t\n     7\tpub type AppResult<T> = Result<T, AppError>;\n     8\t\n     9\t#[derive(Debug, Error)]\n    10\tpub enum AppError {\n    11\t    #[error(\"workspace already initialized at {path}\")]\n    12\t    AlreadyInitialized { path: PathBuf },\n    13\t    #[error(\n    14\t        \"cannot initialize workspace because {path} already exists without a workspace configuration\"\n    15\t    )]\n    16\t    WorkspaceConflict { path: PathBuf },\n    17\t    #[error(\"invalid {field}: must be greater than zero\")]\n    18\t    InvalidStageCursorField { field: &'static str },\n    19\t    #[error(\"invalid identifier '{value}': identifiers must be non-empty single path segments\")]\n    20\t    InvalidIdentifier { value: String },\n    21\t    #[error(\n    22\t        \"unknown flow preset '{flow_id}'. supported presets: standard, quick_dev, docs_change, ci_improvement\"\n    23\t    )]\n    24\t    InvalidFlowPreset { flow_id: String },\n    25\t    #[error(\"unsupported workspace version {version}; supported version is {supported}\")]\n    26\t    UnsupportedWorkspaceVersion { version: u32, supported: u32 },\n    27\t    #[error(\n    28\t        \"unknown config key '{key}'. supported keys: prompt_review.enabled, default_flow, default_backend, default_model\"\n    29\t    )]\n    30\t    UnknownConfigKey { key: String },\n    31\t    #[error(\"invalid value '{value}' for config key '{key}': {reason}\")]\n    32\t    InvalidConfigValue {\n    33\t        key: String,\n    34\t        value: String,\n    35\t        reason: String,\n    36\t    },\n    37\t    #[error(\"no active project selected; run `ralph-burning project select <id>`\")]\n    38\t    NoActiveProject,\n    39\t    #[error(\n    40\t        \"project '{project_id}' was not found under .ralph-burning/projects/ or is missing project.toml\"\n    41\t    )]\n    42\t    ProjectNotFound { project_id: String },\n    43\t    #[error(\"editor '{editor}' failed{details}\")]\n    44\t    EditorFailed { editor: String, details: String },\n    45\t    #[error(\"project '{project_id}' already exists\")]\n    46\t    DuplicateProject { project_id: String },\n    47\t    #[error(\"corrupt record in {file}: {details}\")]\n    48\t    CorruptRecord { file: String, details: String },\n    49\t    #[error(\"invalid prompt file '{path}': {reason}\")]\n    50\t    InvalidPrompt { path: String, reason: String },\n    51\t    #[error(\"cannot delete project '{project_id}': it has an active run\")]\n    52\t    ActiveRunDelete { project_id: String },\n    53\t    #[error(\"journal sequence error: {details}\")]\n    54\t    JournalSequence { details: String },\n    55\t    #[error(\"{command} is not yet implemented\")]\n    56\t    NotYetImplemented { command: String },\n    57\t    #[error(transparent)]\n    58\t    Io(#[from] std::io::Error),\n    59\t    #[error(transparent)]\n    60\t    TomlDeserialize(#[from] toml::de::Error),\n    61\t    #[error(transparent)]\n    62\t    TomlSerialize(#[from] toml::ser::Error),\n    63\t    #[error(transparent)]\n    64\t    TomlEdit(#[from] toml_edit::TomlError),\n    65\t    #[error(transparent)]\n    66\t    SerdeJson(#[from] serde_json::Error),\n    67\t}\n    68\t\n    69\t/// Errors specific to stage contract evaluation.\n    70\t///\n    71\t/// Each variant maps to a distinct [`FailureClass`] for retry/terminal policy.\n    72\t#[derive(Debug, Error)]\n    73\tpub enum ContractError {\n    74\t    #[error(\"schema validation failed for stage '{stage_id}': {details}\")]\n    75\t    SchemaValidation { stage_id: StageId, details: String },\n    76\t\n    77\t    #[error(\"domain validation failed for stage '{stage_id}': {details}\")]\n    78\t    DomainValidation { stage_id: StageId, details: String },\n    79\t\n    80\t    #[error(\"rendering failed for stage '{stage_id}': {details}\")]\n    81\t    RenderError { stage_id: StageId, details: String },\n    82\t\n    83\t    #[error(\"non-passing QA/review outcome for stage '{stage_id}': {outcome}\")]\n    84\t    QaReviewOutcome { stage_id: StageId, outcome: String },\n    85\t}\n    86\t\n    87\timpl ContractError {\n    88\t    pub fn failure_class(&self) -> FailureClass {\n    89\t        match self {\n    90\t            Self::SchemaValidation { .. } => FailureClass::SchemaValidationFailure,\n    91\t            Self::DomainValidation { .. } | Self::RenderError { .. } => {\n    92\t                FailureClass::DomainValidationFailure\n    93\t            }\n    94\t            Self::QaReviewOutcome { .. } => FailureClass::QaReviewOutcomeFailure,\n    95\t        }\n    96\t    }\n    97\t\n    98\t    pub fn stage_id(&self) -> StageId {\n    99\t        match self {\n   100\t            Self::SchemaValidation { stage_id, .. }\n   101\t            | Self::DomainValidation { stage_id, .. }\n   102\t            | Self::RenderError { stage_id, .. }\n   103\t            | Self::QaReviewOutcome { stage_id, .. } => *stage_id,\n   104\t        }\n   105\t    }\n   106\t}\n","exit_code":0,"status":"completed"}}
