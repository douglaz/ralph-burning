{"type":"item.completed","item":{"id":"item_14","type":"command_execution","command":"/run/current-system/sw/bin/bash -lc \"nl -ba /root/new-ralph-burning/ralph-burning-rewrite/src/contexts/workspace_governance/mod.rs | sed -n '1,260p'\"","aggregated_output":"     1\tpub mod config;\n     2\t\n     3\tuse std::path::{Path, PathBuf};\n     4\t\n     5\tuse chrono::{DateTime, Utc};\n     6\t\n     7\tuse crate::adapters::fs::FileSystem;\n     8\tuse crate::shared::domain::{ProjectId, WorkspaceConfig, CURRENT_WORKSPACE_VERSION};\n     9\tuse crate::shared::error::{AppError, AppResult};\n    10\t\n    11\tpub use config::{\n    12\t    ConfigEntry, ConfigValue, ConfigValueSource, EffectiveConfig, DEFAULT_FLOW_PRESET,\n    13\t    DEFAULT_PROMPT_REVIEW_ENABLED,\n    14\t};\n    15\t\n    16\tpub const WORKSPACE_DIR: &str = \".ralph-burning\";\n    17\tpub const WORKSPACE_CONFIG_FILE: &str = \"workspace.toml\";\n    18\tpub const ACTIVE_PROJECT_FILE: &str = \"active-project\";\n    19\tpub const PROJECTS_DIR: &str = \"projects\";\n    20\tpub const PROJECT_CONFIG_FILE: &str = \"project.toml\";\n    21\tpub const REQUIRED_WORKSPACE_DIRECTORIES: &[&str] =\n    22\t    &[\"projects\", \"requirements\", \"daemon/tasks\", \"daemon/leases\"];\n    23\t\n    24\t#[derive(Debug, Clone, PartialEq)]\n    25\tpub struct WorkspaceInitialization {\n    26\t    pub workspace_root: PathBuf,\n    27\t    pub config: WorkspaceConfig,\n    28\t}\n    29\t\n    30\tpub fn initialize_workspace(\n    31\t    base_dir: &Path,\n    32\t    created_at: DateTime<Utc>,\n    33\t) -> AppResult<WorkspaceInitialization> {\n    34\t    let workspace_root = workspace_root(base_dir);\n    35\t    let config_path = workspace_root.join(WORKSPACE_CONFIG_FILE);\n    36\t\n    37\t    if config_path.exists() {\n    38\t        return Err(AppError::AlreadyInitialized {\n    39\t            path: workspace_root,\n    40\t        });\n    41\t    }\n    42\t\n    43\t    if workspace_root.exists() {\n    44\t        return Err(AppError::WorkspaceConflict {\n    45\t            path: workspace_root,\n    46\t        });\n    47\t    }\n    48\t\n    49\t    let config = WorkspaceConfig::new(created_at);\n    50\t    let rendered = FileSystem::render_workspace_config(&config)?;\n    51\t    FileSystem::create_workspace(&workspace_root, &rendered, REQUIRED_WORKSPACE_DIRECTORIES)?;\n    52\t\n    53\t    Ok(WorkspaceInitialization {\n    54\t        workspace_root,\n    55\t        config,\n    56\t    })\n    57\t}\n    58\t\n    59\tpub fn load_workspace_config(base_dir: &Path) -> AppResult<WorkspaceConfig> {\n    60\t    let raw = FileSystem::read_to_string(&workspace_config_path(base_dir))?;\n    61\t    parse_workspace_config(&raw)\n    62\t}\n    63\t\n    64\tpub fn ensure_supported_workspace_version(config: &WorkspaceConfig) -> AppResult<()> {\n    65\t    if config.version != CURRENT_WORKSPACE_VERSION {\n    66\t        return Err(AppError::UnsupportedWorkspaceVersion {\n    67\t            version: config.version,\n    68\t            supported: CURRENT_WORKSPACE_VERSION,\n    69\t        });\n    70\t    }\n    71\t\n    72\t    Ok(())\n    73\t}\n    74\t\n    75\tpub fn resolve_active_project(base_dir: &Path) -> AppResult<ProjectId> {\n    76\t    let _ = EffectiveConfig::load(base_dir)?;\n    77\t    let active_project = FileSystem::read_active_project(&workspace_root(base_dir))?\n    78\t        .ok_or(AppError::NoActiveProject)?;\n    79\t    let project_id = ProjectId::new(active_project)?;\n    80\t    validate_project_exists(base_dir, &project_id)?;\n    81\t    Ok(project_id)\n    82\t}\n    83\t\n    84\tpub fn set_active_project(base_dir: &Path, project_id: &ProjectId) -> AppResult<()> {\n    85\t    let _ = EffectiveConfig::load(base_dir)?;\n    86\t    validate_project_exists(base_dir, project_id)?;\n    87\t    FileSystem::write_active_project(&workspace_root(base_dir), project_id.as_str())\n    88\t}\n    89\t\n    90\tpub(crate) fn parse_workspace_config(raw: &str) -> AppResult<WorkspaceConfig> {\n    91\t    let config: WorkspaceConfig = toml::from_str(raw)?;\n    92\t    ensure_supported_workspace_version(&config)?;\n    93\t    Ok(config)\n    94\t}\n    95\t\n    96\tpub(crate) fn workspace_root(base_dir: &Path) -> PathBuf {\n    97\t    base_dir.join(WORKSPACE_DIR)\n    98\t}\n    99\t\n   100\tpub(crate) fn workspace_config_path(base_dir: &Path) -> PathBuf {\n   101\t    workspace_root(base_dir).join(WORKSPACE_CONFIG_FILE)\n   102\t}\n   103\t\n   104\tfn validate_project_exists(base_dir: &Path, project_id: &ProjectId) -> AppResult<()> {\n   105\t    let project_root = workspace_root(base_dir)\n   106\t        .join(PROJECTS_DIR)\n   107\t        .join(project_id.as_str());\n   108\t    if !project_root.is_dir() {\n   109\t        return Err(AppError::ProjectNotFound {\n   110\t            project_id: project_id.to_string(),\n   111\t        });\n   112\t    }\n   113\t    let config_path = project_root.join(PROJECT_CONFIG_FILE);\n   114\t    if !config_path.is_file() {\n   115\t        return Err(AppError::CorruptRecord {\n   116\t            file: format!(\"projects/{}/project.toml\", project_id),\n   117\t            details: \"project directory exists but canonical project.toml is missing\".to_owned(),\n   118\t        });\n   119\t    }\n   120\t    // Deserialize as the canonical ProjectRecord to validate both TOML syntax\n   121\t    // and structural completeness. This catches corruption early so that\n   122\t    // commands resolving the active project fail fast instead of silently\n   123\t    // operating on corrupt canonical state (e.g. missing required fields).\n   124\t    let raw = std::fs::read_to_string(&config_path).map_err(|e| AppError::CorruptRecord {\n   125\t        file: format!(\"projects/{}/project.toml\", project_id),\n   126\t        details: format!(\"cannot read project.toml: {}\", e),\n   127\t    })?;\n   128\t    let _: crate::contexts::project_run_record::model::ProjectRecord =\n   129\t        toml::from_str(&raw).map_err(|e| AppError::CorruptRecord {\n   130\t            file: format!(\"projects/{}/project.toml\", project_id),\n   131\t            details: format!(\"project.toml has invalid canonical structure: {}\", e),\n   132\t        })?;\n   133\t    Ok(())\n   134\t}\n","exit_code":0,"status":"completed"}}
