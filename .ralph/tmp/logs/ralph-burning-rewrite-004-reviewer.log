{"type":"item.completed","item":{"id":"item_43","type":"command_execution","command":"/run/current-system/sw/bin/bash -lc \"nl -ba /root/new-ralph-burning/ralph-burning-rewrite/src/cli/run.rs | sed -n '1,240p'\"","aggregated_output":"     1\tuse clap::{Args, Subcommand};\n     2\t\n     3\tuse crate::adapters::fs::{\n     4\t    FsArtifactStore, FsJournalStore, FsRunSnapshotStore, FsRuntimeLogStore,\n     5\t};\n     6\tuse crate::contexts::project_run_record::service;\n     7\tuse crate::contexts::workspace_governance;\n     8\tuse crate::shared::error::{AppError, AppResult};\n     9\t\n    10\t#[derive(Debug, Args)]\n    11\tpub struct RunCommand {\n    12\t    #[command(subcommand)]\n    13\t    pub command: RunSubcommand,\n    14\t}\n    15\t\n    16\t#[derive(Debug, Subcommand)]\n    17\tpub enum RunSubcommand {\n    18\t    Start,\n    19\t    Resume,\n    20\t    Status,\n    21\t    History,\n    22\t    Tail {\n    23\t        #[arg(long)]\n    24\t        logs: bool,\n    25\t    },\n    26\t    Rollback {\n    27\t        #[arg(long)]\n    28\t        to: String,\n    29\t        #[arg(long)]\n    30\t        hard: bool,\n    31\t    },\n    32\t}\n    33\t\n    34\tpub async fn handle(command: RunCommand) -> AppResult<()> {\n    35\t    match command.command {\n    36\t        RunSubcommand::Status => handle_status().await,\n    37\t        RunSubcommand::History => handle_history().await,\n    38\t        RunSubcommand::Tail { logs } => handle_tail(logs).await,\n    39\t        RunSubcommand::Start => Err(AppError::NotYetImplemented {\n    40\t            command: \"run start\".to_owned(),\n    41\t        }),\n    42\t        RunSubcommand::Resume => Err(AppError::NotYetImplemented {\n    43\t            command: \"run resume\".to_owned(),\n    44\t        }),\n    45\t        RunSubcommand::Rollback { .. } => Err(AppError::NotYetImplemented {\n    46\t            command: \"run rollback\".to_owned(),\n    47\t        }),\n    48\t    }\n    49\t}\n    50\t\n    51\tasync fn handle_status() -> AppResult<()> {\n    52\t    let current_dir = std::env::current_dir()?;\n    53\t\n    54\t    let config = workspace_governance::load_workspace_config(&current_dir)?;\n    55\t    workspace_governance::ensure_supported_workspace_version(&config)?;\n    56\t\n    57\t    let project_id = workspace_governance::resolve_active_project(&current_dir)?;\n    58\t\n    59\t    let run_store = FsRunSnapshotStore;\n    60\t    let status = service::run_status(&run_store, &current_dir, &project_id)?;\n    61\t\n    62\t    println!(\"Project: {}\", status.project_id);\n    63\t    println!(\"Status: {}\", status.status);\n    64\t    if let Some(ref stage) = status.stage {\n    65\t        println!(\"Stage: {}\", stage);\n    66\t    }\n    67\t    if let Some(cycle) = status.cycle {\n    68\t        println!(\"Cycle: {}\", cycle);\n    69\t    }\n    70\t    if let Some(round) = status.completion_round {\n    71\t        println!(\"Completion round: {}\", round);\n    72\t    }\n    73\t    println!(\"Summary: {}\", status.summary);\n    74\t\n    75\t    Ok(())\n    76\t}\n    77\t\n    78\tasync fn handle_history() -> AppResult<()> {\n    79\t    let current_dir = std::env::current_dir()?;\n    80\t\n    81\t    let config = workspace_governance::load_workspace_config(&current_dir)?;\n    82\t    workspace_governance::ensure_supported_workspace_version(&config)?;\n    83\t\n    84\t    let project_id = workspace_governance::resolve_active_project(&current_dir)?;\n    85\t\n    86\t    let journal_store = FsJournalStore;\n    87\t    let artifact_store = FsArtifactStore;\n    88\t\n    89\t    let history = service::run_history(\n    90\t        &journal_store,\n    91\t        &artifact_store,\n    92\t        &current_dir,\n    93\t        &project_id,\n    94\t    )?;\n    95\t\n    96\t    println!(\"Project: {}\", history.project_id);\n    97\t    println!(\"--- Journal Events ---\");\n    98\t    for event in &history.events {\n    99\t        println!(\n   100\t            \"  [{}] {} - {:?}\",\n   101\t            event.sequence, event.timestamp, event.event_type\n   102\t        );\n   103\t    }\n   104\t\n   105\t    if !history.payloads.is_empty() {\n   106\t        println!(\"--- Payloads ---\");\n   107\t        for payload in &history.payloads {\n   108\t            println!(\n   109\t                \"  {} ({}, cycle {}, attempt {})\",\n   110\t                payload.payload_id, payload.stage_id, payload.cycle, payload.attempt\n   111\t            );\n   112\t        }\n   113\t    }\n   114\t\n   115\t    if !history.artifacts.is_empty() {\n   116\t        println!(\"--- Artifacts ---\");\n   117\t        for artifact in &history.artifacts {\n   118\t            println!(\n   119\t                \"  {} (payload: {}, stage: {})\",\n   120\t                artifact.artifact_id, artifact.payload_id, artifact.stage_id\n   121\t            );\n   122\t        }\n   123\t    }\n   124\t\n   125\t    Ok(())\n   126\t}\n   127\t\n   128\tasync fn handle_tail(include_logs: bool) -> AppResult<()> {\n   129\t    let current_dir = std::env::current_dir()?;\n   130\t\n   131\t    let config = workspace_governance::load_workspace_config(&current_dir)?;\n   132\t    workspace_governance::ensure_supported_workspace_version(&config)?;\n   133\t\n   134\t    let project_id = workspace_governance::resolve_active_project(&current_dir)?;\n   135\t\n   136\t    let journal_store = FsJournalStore;\n   137\t    let artifact_store = FsArtifactStore;\n   138\t    let log_store = FsRuntimeLogStore;\n   139\t\n   140\t    let tail = service::run_tail(\n   141\t        &journal_store,\n   142\t        &artifact_store,\n   143\t        &log_store,\n   144\t        &current_dir,\n   145\t        &project_id,\n   146\t        include_logs,\n   147\t    )?;\n   148\t\n   149\t    println!(\"Project: {}\", tail.project_id);\n   150\t    println!(\"--- Durable History ---\");\n   151\t    for event in &tail.events {\n   152\t        println!(\n   153\t            \"  [{}] {} - {:?}\",\n   154\t            event.sequence, event.timestamp, event.event_type\n   155\t        );\n   156\t    }\n   157\t\n   158\t    if !tail.payloads.is_empty() {\n   159\t        println!(\"--- Payloads ---\");\n   160\t        for payload in &tail.payloads {\n   161\t            println!(\n   162\t                \"  {} ({}, cycle {}, attempt {})\",\n   163\t                payload.payload_id, payload.stage_id, payload.cycle, payload.attempt\n   164\t            );\n   165\t        }\n   166\t    }\n   167\t\n   168\t    if !tail.artifacts.is_empty() {\n   169\t        println!(\"--- Artifacts ---\");\n   170\t        for artifact in &tail.artifacts {\n   171\t            println!(\n   172\t                \"  {} (payload: {}, stage: {})\",\n   173\t                artifact.artifact_id, artifact.payload_id, artifact.stage_id\n   174\t            );\n   175\t        }\n   176\t    }\n   177\t\n   178\t    if let Some(ref logs) = tail.runtime_logs {\n   179\t        println!(\"--- Runtime Logs ---\");\n   180\t        if logs.is_empty() {\n   181\t            println!(\"  (no runtime logs)\");\n   182\t        } else {\n   183\t            for log in logs {\n   184\t                println!(\n   185\t                    \"  [{}] {:?} [{}] {}\",\n   186\t                    log.timestamp, log.level, log.source, log.message\n   187\t                );\n   188\t            }\n   189\t        }\n   190\t    }\n   191\t\n   192\t    Ok(())\n   193\t}\n","exit_code":0,"status":"completed"}}
{"type":"item.completed","item":{"id":"item_42","type":"command_execution","command":"/run/current-system/sw/bin/bash -lc \"nl -ba /root/new-ralph-burning/ralph-burning-rewrite/src/cli/project.rs | sed -n '1,240p'\"","aggregated_output":"     1\tuse std::path::PathBuf;\n     2\t\n     3\tuse chrono::Utc;\n     4\tuse clap::{Args, Subcommand};\n     5\t\n     6\tuse crate::adapters::fs::{\n     7\t    FsActiveProjectStore, FsJournalStore, FsProjectStore, FsRunSnapshotStore, FileSystem,\n     8\t};\n     9\tuse crate::contexts::project_run_record::model::ProjectStatusSummary;\n    10\tuse crate::contexts::project_run_record::service::{self, CreateProjectInput};\n    11\tuse crate::contexts::workspace_governance;\n    12\tuse crate::shared::domain::{FlowPreset, ProjectId};\n    13\tuse crate::shared::error::{AppError, AppResult};\n    14\t\n    15\t#[derive(Debug, Args)]\n    16\tpub struct ProjectCommand {\n    17\t    #[command(subcommand)]\n    18\t    pub command: ProjectSubcommand,\n    19\t}\n    20\t\n    21\t#[derive(Debug, Subcommand)]\n    22\tpub enum ProjectSubcommand {\n    23\t    Create(ProjectCreateArgs),\n    24\t    Select { id: String },\n    25\t    List,\n    26\t    Show { id: Option<String> },\n    27\t    Delete { id: String },\n    28\t}\n    29\t\n    30\t#[derive(Debug, Args)]\n    31\tpub struct ProjectCreateArgs {\n    32\t    #[arg(long)]\n    33\t    pub id: String,\n    34\t    #[arg(long)]\n    35\t    pub name: String,\n    36\t    #[arg(long)]\n    37\t    pub prompt: PathBuf,\n    38\t    #[arg(long)]\n    39\t    pub flow: String,\n    40\t}\n    41\t\n    42\tpub async fn handle(command: ProjectCommand) -> AppResult<()> {\n    43\t    match command.command {\n    44\t        ProjectSubcommand::Select { id } => {\n    45\t            let current_dir = std::env::current_dir()?;\n    46\t            let project_id = ProjectId::new(id)?;\n    47\t            workspace_governance::set_active_project(&current_dir, &project_id)?;\n    48\t            println!(\"Selected project {}\", project_id);\n    49\t            Ok(())\n    50\t        }\n    51\t        ProjectSubcommand::Create(args) => handle_create(args).await,\n    52\t        ProjectSubcommand::List => handle_list().await,\n    53\t        ProjectSubcommand::Show { id } => handle_show(id).await,\n    54\t        ProjectSubcommand::Delete { id } => handle_delete(id).await,\n    55\t    }\n    56\t}\n    57\t\n    58\tasync fn handle_create(args: ProjectCreateArgs) -> AppResult<()> {\n    59\t    let current_dir = std::env::current_dir()?;\n    60\t\n    61\t    // Validate workspace version\n    62\t    let config = workspace_governance::load_workspace_config(&current_dir)?;\n    63\t    workspace_governance::ensure_supported_workspace_version(&config)?;\n    64\t\n    65\t    // Validate project ID\n    66\t    let project_id = ProjectId::new(args.id)?;\n    67\t\n    68\t    // Validate flow preset\n    69\t    let flow: FlowPreset = args.flow.parse()?;\n    70\t\n    71\t    // Validate prompt file is readable\n    72\t    let prompt_path = if args.prompt.is_absolute() {\n    73\t        args.prompt.clone()\n    74\t    } else {\n    75\t        current_dir.join(&args.prompt)\n    76\t    };\n    77\t\n    78\t    let prompt_contents = std::fs::read_to_string(&prompt_path).map_err(|e| {\n    79\t        AppError::InvalidPrompt {\n    80\t            path: args.prompt.display().to_string(),\n    81\t            reason: e.to_string(),\n    82\t        }\n    83\t    })?;\n    84\t\n    85\t    if prompt_contents.trim().is_empty() {\n    86\t        return Err(AppError::InvalidPrompt {\n    87\t            path: args.prompt.display().to_string(),\n    88\t            reason: \"prompt file is empty\".to_owned(),\n    89\t        });\n    90\t    }\n    91\t\n    92\t    let prompt_hash = FileSystem::prompt_hash(&prompt_contents);\n    93\t\n    94\t    let store = FsProjectStore;\n    95\t    let journal_store = FsJournalStore;\n    96\t\n    97\t    let input = CreateProjectInput {\n    98\t        id: project_id,\n    99\t        name: args.name,\n   100\t        flow,\n   101\t        prompt_path: args.prompt.display().to_string(),\n   102\t        prompt_contents,\n   103\t        prompt_hash,\n   104\t        created_at: Utc::now(),\n   105\t    };\n   106\t\n   107\t    let record = service::create_project(&store, &journal_store, &current_dir, input)?;\n   108\t\n   109\t    println!(\n   110\t        \"Created project '{}' with flow '{}'\",\n   111\t        record.id, record.flow\n   112\t    );\n   113\t    Ok(())\n   114\t}\n   115\t\n   116\tasync fn handle_list() -> AppResult<()> {\n   117\t    let current_dir = std::env::current_dir()?;\n   118\t\n   119\t    // Validate workspace\n   120\t    let config = workspace_governance::load_workspace_config(&current_dir)?;\n   121\t    workspace_governance::ensure_supported_workspace_version(&config)?;\n   122\t\n   123\t    let store = FsProjectStore;\n   124\t    let active_store = FsActiveProjectStore;\n   125\t\n   126\t    let entries = service::list_projects(&store, &active_store, &current_dir)?;\n   127\t\n   128\t    if entries.is_empty() {\n   129\t        println!(\"No projects found.\");\n   130\t        return Ok(());\n   131\t    }\n   132\t\n   133\t    for entry in &entries {\n   134\t        let active_marker = if entry.is_active { \" *\" } else { \"\" };\n   135\t        let status = match entry.status_summary {\n   136\t            ProjectStatusSummary::Created => \"created\",\n   137\t            ProjectStatusSummary::Active => \"active\",\n   138\t            ProjectStatusSummary::Completed => \"completed\",\n   139\t            ProjectStatusSummary::Failed => \"failed\",\n   140\t        };\n   141\t        println!(\n   142\t            \"  {}{} ({}) [{}] - {}\",\n   143\t            entry.id, active_marker, entry.flow, status, entry.name\n   144\t        );\n   145\t    }\n   146\t\n   147\t    Ok(())\n   148\t}\n   149\t\n   150\tasync fn handle_show(id: Option<String>) -> AppResult<()> {\n   151\t    let current_dir = std::env::current_dir()?;\n   152\t\n   153\t    // Validate workspace\n   154\t    let config = workspace_governance::load_workspace_config(&current_dir)?;\n   155\t    workspace_governance::ensure_supported_workspace_version(&config)?;\n   156\t\n   157\t    // Resolve project ID: explicit or active project\n   158\t    let project_id = match id {\n   159\t        Some(raw) => ProjectId::new(raw)?,\n   160\t        None => workspace_governance::resolve_active_project(&current_dir)?,\n   161\t    };\n   162\t\n   163\t    let store = FsProjectStore;\n   164\t    let run_store = FsRunSnapshotStore;\n   165\t    let journal_store = FsJournalStore;\n   166\t    let active_store = FsActiveProjectStore;\n   167\t\n   168\t    let detail = service::show_project(\n   169\t        &store,\n   170\t        &run_store,\n   171\t        &journal_store,\n   172\t        &active_store,\n   173\t        &current_dir,\n   174\t        &project_id,\n   175\t    )?;\n   176\t\n   177\t    let active_label = if detail.is_active { \" (active)\" } else { \"\" };\n   178\t    println!(\"Project: {}{}\", detail.record.id, active_label);\n   179\t    println!(\"Name: {}\", detail.record.name);\n   180\t    println!(\"Flow: {}\", detail.record.flow);\n   181\t    println!(\"Prompt reference: {}\", detail.record.prompt_reference);\n   182\t    println!(\"Prompt hash: {}\", detail.record.prompt_hash);\n   183\t    println!(\"Created: {}\", detail.record.created_at);\n   184\t    println!(\"Run status: {}\", detail.run_snapshot.status_summary);\n   185\t    println!(\"Journal events: {}\", detail.journal_event_count);\n   186\t    println!(\"Rollback points: {}\", detail.rollback_count);\n   187\t\n   188\t    Ok(())\n   189\t}\n   190\t\n   191\tasync fn handle_delete(id: String) -> AppResult<()> {\n   192\t    let current_dir = std::env::current_dir()?;\n   193\t\n   194\t    // Validate workspace\n   195\t    let config = workspace_governance::load_workspace_config(&current_dir)?;\n   196\t    workspace_governance::ensure_supported_workspace_version(&config)?;\n   197\t\n   198\t    let project_id = ProjectId::new(id)?;\n   199\t\n   200\t    let store = FsProjectStore;\n   201\t    let run_store = FsRunSnapshotStore;\n   202\t    let active_store = FsActiveProjectStore;\n   203\t\n   204\t    service::delete_project(\n   205\t        &store,\n   206\t        &run_store,\n   207\t        &active_store,\n   208\t        &current_dir,\n   209\t        &project_id,\n   210\t    )?;\n   211\t\n   212\t    println!(\"Deleted project '{}'\", project_id);\n   213\t    Ok(())\n   214\t}\n","exit_code":0,"status":"completed"}}
{"type":"item.completed","item":{"id":"item_41","type":"command_execution","command":"/run/current-system/sw/bin/bash -lc \"nl -ba /root/new-ralph-burning/ralph-burning-rewrite/src/adapters/fs.rs | sed -n '1,620p'\"","aggregated_output":"     1\tuse std::env;\n     2\tuse std::fs::{self, OpenOptions};\n     3\tuse std::io::Write;\n     4\tuse std::path::{Path, PathBuf};\n     5\tuse std::process::Command;\n     6\tuse std::time::{SystemTime, UNIX_EPOCH};\n     7\t\n     8\tuse crate::contexts::project_run_record::journal;\n     9\tuse crate::contexts::project_run_record::model::{\n    10\t    ArtifactRecord, JournalEvent, PayloadRecord, ProjectRecord, RunSnapshot,\n    11\t    RuntimeLogEntry, SessionStore,\n    12\t};\n    13\tuse crate::contexts::project_run_record::service::{\n    14\t    ActiveProjectPort, ArtifactStorePort, JournalStorePort, ProjectStorePort,\n    15\t    RuntimeLogStorePort, RunSnapshotPort,\n    16\t};\n    17\tuse crate::shared::domain::{ProjectId, WorkspaceConfig};\n    18\tuse crate::shared::error::{AppError, AppResult};\n    19\t\n    20\tconst ACTIVE_PROJECT_FILE: &str = \"active-project\";\n    21\tconst WORKSPACE_DIR: &str = \".ralph-burning\";\n    22\tconst PROJECTS_DIR: &str = \"projects\";\n    23\tconst PROJECT_CONFIG_FILE: &str = \"project.toml\";\n    24\tconst RUN_FILE: &str = \"run.json\";\n    25\tconst JOURNAL_FILE: &str = \"journal.ndjson\";\n    26\tconst SESSIONS_FILE: &str = \"sessions.json\";\n    27\tconst PROMPT_FILE: &str = \"prompt.md\";\n    28\t\n    29\t/// Required subdirectories inside a project.\n    30\tconst PROJECT_SUBDIRS: &[&str] = &[\n    31\t    \"history/payloads\",\n    32\t    \"history/artifacts\",\n    33\t    \"runtime/logs\",\n    34\t    \"runtime/backend\",\n    35\t    \"runtime/temp\",\n    36\t    \"amendments\",\n    37\t    \"rollback\",\n    38\t];\n    39\t\n    40\tpub struct FileSystem;\n    41\t\n    42\timpl FileSystem {\n    43\t    pub fn create_workspace(\n    44\t        workspace_root: &Path,\n    45\t        workspace_config: &str,\n    46\t        required_directories: &[&str],\n    47\t    ) -> AppResult<()> {\n    48\t        fs::create_dir_all(workspace_root)?;\n    49\t\n    50\t        for directory in required_directories {\n    51\t            fs::create_dir_all(workspace_root.join(directory))?;\n    52\t        }\n    53\t\n    54\t        Self::write_atomic(&workspace_root.join(\"workspace.toml\"), workspace_config)?;\n    55\t        Ok(())\n    56\t    }\n    57\t\n    58\t    pub fn read_to_string(path: &Path) -> AppResult<String> {\n    59\t        Ok(fs::read_to_string(path)?)\n    60\t    }\n    61\t\n    62\t    pub fn write_atomic(path: &Path, contents: &str) -> AppResult<()> {\n    63\t        let parent = path.parent().ok_or_else(|| {\n    64\t            AppError::Io(std::io::Error::new(\n    65\t                std::io::ErrorKind::InvalidInput,\n    66\t                format!(\"path '{}' has no parent directory\", path.display()),\n    67\t            ))\n    68\t        })?;\n    69\t        fs::create_dir_all(parent)?;\n    70\t\n    71\t        let timestamp = SystemTime::now()\n    72\t            .duration_since(UNIX_EPOCH)\n    73\t            .map(|duration| duration.as_nanos())\n    74\t            .unwrap_or_default();\n    75\t        let temp_path = parent.join(format!(\n    76\t            \".{}.{}.{}.tmp\",\n    77\t            path.file_name()\n    78\t                .and_then(|value| value.to_str())\n    79\t                .unwrap_or(\"workspace\"),\n    80\t            std::process::id(),\n    81\t            timestamp\n    82\t        ));\n    83\t\n    84\t        let mut file = OpenOptions::new()\n    85\t            .create_new(true)\n    86\t            .write(true)\n    87\t            .open(&temp_path)?;\n    88\t        file.write_all(contents.as_bytes())?;\n    89\t        file.sync_all()?;\n    90\t        drop(file);\n    91\t\n    92\t        if let Err(error) = fs::rename(&temp_path, path) {\n    93\t            let _ = fs::remove_file(&temp_path);\n    94\t            return Err(error.into());\n    95\t        }\n    96\t\n    97\t        Ok(())\n    98\t    }\n    99\t\n   100\t    pub fn render_workspace_config(config: &WorkspaceConfig) -> AppResult<String> {\n   101\t        Ok(toml::to_string_pretty(config)?)\n   102\t    }\n   103\t\n   104\t    pub fn read_active_project(workspace_root: &Path) -> AppResult<Option<String>> {\n   105\t        let path = workspace_root.join(ACTIVE_PROJECT_FILE);\n   106\t        match fs::read_to_string(path) {\n   107\t            Ok(raw) => {\n   108\t                let trimmed = raw.trim();\n   109\t                if trimmed.is_empty() {\n   110\t                    Ok(None)\n   111\t                } else {\n   112\t                    Ok(Some(trimmed.to_owned()))\n   113\t                }\n   114\t            }\n   115\t            Err(error) if error.kind() == std::io::ErrorKind::NotFound => Ok(None),\n   116\t            Err(error) => Err(error.into()),\n   117\t        }\n   118\t    }\n   119\t\n   120\t    pub fn write_active_project(workspace_root: &Path, project_id: &str) -> AppResult<()> {\n   121\t        Self::write_atomic(&workspace_root.join(ACTIVE_PROJECT_FILE), project_id)\n   122\t    }\n   123\t\n   124\t    pub fn open_editor(path: &Path) -> AppResult<()> {\n   125\t        let editor = env::var(\"EDITOR\")\n   126\t            .ok()\n   127\t            .filter(|value| !value.trim().is_empty())\n   128\t            .or_else(|| {\n   129\t                env::var(\"VISUAL\")\n   130\t                    .ok()\n   131\t                    .filter(|value| !value.trim().is_empty())\n   132\t            })\n   133\t            .unwrap_or_else(|| \"vi\".to_owned());\n   134\t\n   135\t        let mut parts = editor.split_whitespace();\n   136\t        let program = parts.next().ok_or_else(|| AppError::EditorFailed {\n   137\t            editor: editor.clone(),\n   138\t            details: \": empty editor command\".to_owned(),\n   139\t        })?;\n   140\t        let status = Command::new(program).args(parts).arg(path).status()?;\n   141\t\n   142\t        if status.success() {\n   143\t            Ok(())\n   144\t        } else {\n   145\t            let details = match status.code() {\n   146\t                Some(code) => format!(\" with exit code {code}\"),\n   147\t                None => \" after being terminated by a signal\".to_owned(),\n   148\t            };\n   149\t            Err(AppError::EditorFailed { editor, details })\n   150\t        }\n   151\t    }\n   152\t\n   153\t    /// Compute a simple hash of content for prompt integrity tracking.\n   154\t    pub fn prompt_hash(contents: &str) -> String {\n   155\t        use std::collections::hash_map::DefaultHasher;\n   156\t        use std::hash::{Hash, Hasher};\n   157\t        let mut hasher = DefaultHasher::new();\n   158\t        contents.hash(&mut hasher);\n   159\t        format!(\"{:016x}\", hasher.finish())\n   160\t    }\n   161\t\n   162\t    // ── Helpers for project filesystem layout ──\n   163\t\n   164\t    fn workspace_root_path(base_dir: &Path) -> PathBuf {\n   165\t        base_dir.join(WORKSPACE_DIR)\n   166\t    }\n   167\t\n   168\t    fn project_root(base_dir: &Path, project_id: &ProjectId) -> PathBuf {\n   169\t        Self::workspace_root_path(base_dir)\n   170\t            .join(PROJECTS_DIR)\n   171\t            .join(project_id.as_str())\n   172\t    }\n   173\t\n   174\t    fn append_line(path: &Path, line: &str) -> AppResult<()> {\n   175\t        let parent = path.parent().ok_or_else(|| {\n   176\t            AppError::Io(std::io::Error::new(\n   177\t                std::io::ErrorKind::InvalidInput,\n   178\t                format!(\"path '{}' has no parent directory\", path.display()),\n   179\t            ))\n   180\t        })?;\n   181\t        fs::create_dir_all(parent)?;\n   182\t\n   183\t        let mut file = OpenOptions::new()\n   184\t            .create(true)\n   185\t            .append(true)\n   186\t            .open(path)?;\n   187\t        writeln!(file, \"{}\", line)?;\n   188\t        file.sync_all()?;\n   189\t        Ok(())\n   190\t    }\n   191\t}\n   192\t\n   193\t/// Filesystem-backed implementation of `ProjectStorePort`.\n   194\tpub struct FsProjectStore;\n   195\t\n   196\timpl ProjectStorePort for FsProjectStore {\n   197\t    fn project_exists(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<bool> {\n   198\t        let project_root = FileSystem::project_root(base_dir, project_id);\n   199\t        if !project_root.is_dir() {\n   200\t            return Ok(false);\n   201\t        }\n   202\t        if !project_root.join(PROJECT_CONFIG_FILE).is_file() {\n   203\t            return Err(AppError::CorruptRecord {\n   204\t                file: format!(\"projects/{}/project.toml\", project_id),\n   205\t                details: \"project directory exists but canonical project.toml is missing\"\n   206\t                    .to_owned(),\n   207\t            });\n   208\t        }\n   209\t        Ok(true)\n   210\t    }\n   211\t\n   212\t    fn read_project_record(\n   213\t        &self,\n   214\t        base_dir: &Path,\n   215\t        project_id: &ProjectId,\n   216\t    ) -> AppResult<ProjectRecord> {\n   217\t        let project_root = FileSystem::project_root(base_dir, project_id);\n   218\t        let path = project_root.join(PROJECT_CONFIG_FILE);\n   219\t        let raw = fs::read_to_string(&path).map_err(|e| {\n   220\t            if e.kind() == std::io::ErrorKind::NotFound {\n   221\t                if project_root.is_dir() {\n   222\t                    // Directory exists but project.toml is missing — corruption\n   223\t                    AppError::CorruptRecord {\n   224\t                        file: format!(\"projects/{}/project.toml\", project_id),\n   225\t                        details: \"project directory exists but canonical project.toml is missing\"\n   226\t                            .to_owned(),\n   227\t                    }\n   228\t                } else {\n   229\t                    AppError::ProjectNotFound {\n   230\t                        project_id: project_id.to_string(),\n   231\t                    }\n   232\t                }\n   233\t            } else {\n   234\t                e.into()\n   235\t            }\n   236\t        })?;\n   237\t        toml::from_str(&raw).map_err(|e| AppError::CorruptRecord {\n   238\t            file: format!(\"projects/{}/project.toml\", project_id),\n   239\t            details: e.to_string(),\n   240\t        })\n   241\t    }\n   242\t\n   243\t    fn list_project_ids(&self, base_dir: &Path) -> AppResult<Vec<ProjectId>> {\n   244\t        let projects_dir = FileSystem::workspace_root_path(base_dir).join(PROJECTS_DIR);\n   245\t        if !projects_dir.is_dir() {\n   246\t            return Ok(Vec::new());\n   247\t        }\n   248\t\n   249\t        let mut ids = Vec::new();\n   250\t        for entry in fs::read_dir(&projects_dir)? {\n   251\t            let entry = entry?;\n   252\t            if !entry.file_type()?.is_dir() {\n   253\t                continue;\n   254\t            }\n   255\t            let name = entry.file_name();\n   256\t            let name_str = name.to_string_lossy();\n   257\t            // Skip hidden directories (staging/trash from transactional operations)\n   258\t            if name_str.starts_with('.') {\n   259\t                continue;\n   260\t            }\n   261\t            if let Ok(pid) = ProjectId::new(name_str.as_ref()) {\n   262\t                if !entry.path().join(PROJECT_CONFIG_FILE).is_file() {\n   263\t                    return Err(AppError::CorruptRecord {\n   264\t                        file: format!(\"projects/{}/project.toml\", name_str),\n   265\t                        details:\n   266\t                            \"project directory exists but canonical project.toml is missing\"\n   267\t                                .to_owned(),\n   268\t                    });\n   269\t                }\n   270\t                ids.push(pid);\n   271\t            }\n   272\t        }\n   273\t\n   274\t        ids.sort_by(|a, b| a.as_str().cmp(b.as_str()));\n   275\t        Ok(ids)\n   276\t    }\n   277\t\n   278\t    fn delete_project(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<()> {\n   279\t        let project_root = FileSystem::project_root(base_dir, project_id);\n   280\t        if !project_root.is_dir() {\n   281\t            return Err(AppError::ProjectNotFound {\n   282\t                project_id: project_id.to_string(),\n   283\t            });\n   284\t        }\n   285\t\n   286\t        // Transactional delete: rename to a trash path first, then remove.\n   287\t        // If removal fails, rename back so the project remains addressable.\n   288\t        let trash_name = format!(\".{}.deleting.{}\", project_id, std::process::id());\n   289\t        let trash_path = project_root\n   290\t            .parent()\n   291\t            .expect(\"project root has parent\")\n   292\t            .join(&trash_name);\n   293\t\n   294\t        // Phase 1: atomic rename to trash location\n   295\t        fs::rename(&project_root, &trash_path)?;\n   296\t\n   297\t        // Phase 2: remove the trash directory\n   298\t        if let Err(remove_err) = fs::remove_dir_all(&trash_path) {\n   299\t            // Removal failed — try to restore the project to its original path\n   300\t            if let Err(_restore_err) = fs::rename(&trash_path, &project_root) {\n   301\t                // Restore also failed; return the original removal error.\n   302\t                // The project is stranded at the trash path but not partially deleted.\n   303\t            }\n   304\t            return Err(remove_err.into());\n   305\t        }\n   306\t\n   307\t        Ok(())\n   308\t    }\n   309\t\n   310\t    fn create_project_atomic(\n   311\t        &self,\n   312\t        base_dir: &Path,\n   313\t        record: &ProjectRecord,\n   314\t        prompt_contents: &str,\n   315\t        run_snapshot: &RunSnapshot,\n   316\t        initial_journal_line: &str,\n   317\t        sessions: &SessionStore,\n   318\t    ) -> AppResult<()> {\n   319\t        let project_root = FileSystem::project_root(base_dir, &record.id);\n   320\t\n   321\t        // Stage into a temporary directory alongside the final location\n   322\t        let staging_name = format!(\".{}.staging.{}\", record.id, std::process::id());\n   323\t        let staging_root = project_root\n   324\t            .parent()\n   325\t            .expect(\"project root has parent\")\n   326\t            .join(&staging_name);\n   327\t\n   328\t        // Clean up any leftover staging dir\n   329\t        if staging_root.exists() {\n   330\t            fs::remove_dir_all(&staging_root)?;\n   331\t        }\n   332\t\n   333\t        // Create staging directory and all subdirs\n   334\t        fs::create_dir_all(&staging_root)?;\n   335\t        for subdir in PROJECT_SUBDIRS {\n   336\t            fs::create_dir_all(staging_root.join(subdir))?;\n   337\t        }\n   338\t\n   339\t        // Write all canonical files into staging\n   340\t        let write_result = (|| -> AppResult<()> {\n   341\t            // project.toml\n   342\t            let project_toml = toml::to_string_pretty(record).map_err(|e| {\n   343\t                AppError::Io(std::io::Error::other(e.to_string()))\n   344\t            })?;\n   345\t            fs::write(staging_root.join(PROJECT_CONFIG_FILE), project_toml)?;\n   346\t\n   347\t            // prompt.md\n   348\t            fs::write(staging_root.join(PROMPT_FILE), prompt_contents)?;\n   349\t\n   350\t            // run.json\n   351\t            let run_json = serde_json::to_string_pretty(run_snapshot)?;\n   352\t            fs::write(staging_root.join(RUN_FILE), run_json)?;\n   353\t\n   354\t            // journal.ndjson (with initial event)\n   355\t            let mut journal_content = initial_journal_line.to_owned();\n   356\t            journal_content.push('\\n');\n   357\t            fs::write(staging_root.join(JOURNAL_FILE), journal_content)?;\n   358\t\n   359\t            // sessions.json\n   360\t            let sessions_json = serde_json::to_string_pretty(sessions)?;\n   361\t            fs::write(staging_root.join(SESSIONS_FILE), sessions_json)?;\n   362\t\n   363\t            Ok(())\n   364\t        })();\n   365\t\n   366\t        if let Err(e) = write_result {\n   367\t            // Clean up staging on failure\n   368\t            let _ = fs::remove_dir_all(&staging_root);\n   369\t            return Err(e);\n   370\t        }\n   371\t\n   372\t        // Atomic rename from staging to final location\n   373\t        if let Err(e) = fs::rename(&staging_root, &project_root) {\n   374\t            let _ = fs::remove_dir_all(&staging_root);\n   375\t            return Err(e.into());\n   376\t        }\n   377\t\n   378\t        Ok(())\n   379\t    }\n   380\t}\n   381\t\n   382\t/// Filesystem-backed implementation of `JournalStorePort`.\n   383\tpub struct FsJournalStore;\n   384\t\n   385\timpl JournalStorePort for FsJournalStore {\n   386\t    fn read_journal(\n   387\t        &self,\n   388\t        base_dir: &Path,\n   389\t        project_id: &ProjectId,\n   390\t    ) -> AppResult<Vec<JournalEvent>> {\n   391\t        let path = FileSystem::project_root(base_dir, project_id).join(JOURNAL_FILE);\n   392\t        match fs::read_to_string(&path) {\n   393\t            Ok(contents) => journal::parse_journal(&contents),\n   394\t            Err(e) if e.kind() == std::io::ErrorKind::NotFound => {\n   395\t                Err(AppError::CorruptRecord {\n   396\t                    file: format!(\"projects/{}/journal.ndjson\", project_id),\n   397\t                    details: \"canonical file is missing\".to_owned(),\n   398\t                })\n   399\t            }\n   400\t            Err(e) => Err(e.into()),\n   401\t        }\n   402\t    }\n   403\t\n   404\t    fn append_event(\n   405\t        &self,\n   406\t        base_dir: &Path,\n   407\t        project_id: &ProjectId,\n   408\t        line: &str,\n   409\t    ) -> AppResult<()> {\n   410\t        let path = FileSystem::project_root(base_dir, project_id).join(JOURNAL_FILE);\n   411\t        FileSystem::append_line(&path, line)\n   412\t    }\n   413\t}\n   414\t\n   415\t/// Filesystem-backed implementation of `ArtifactStorePort`.\n   416\tpub struct FsArtifactStore;\n   417\t\n   418\timpl ArtifactStorePort for FsArtifactStore {\n   419\t    fn list_payloads(\n   420\t        &self,\n   421\t        base_dir: &Path,\n   422\t        project_id: &ProjectId,\n   423\t    ) -> AppResult<Vec<PayloadRecord>> {\n   424\t        let dir = FileSystem::project_root(base_dir, project_id).join(\"history/payloads\");\n   425\t        if !dir.is_dir() {\n   426\t            return Ok(Vec::new());\n   427\t        }\n   428\t\n   429\t        let mut records = Vec::new();\n   430\t        for entry in fs::read_dir(&dir)? {\n   431\t            let entry = entry?;\n   432\t            let path = entry.path();\n   433\t            if path.extension().is_some_and(|ext| ext == \"json\") {\n   434\t                let raw = fs::read_to_string(&path)?;\n   435\t                let record: PayloadRecord = serde_json::from_str(&raw).map_err(|e| {\n   436\t                    AppError::CorruptRecord {\n   437\t                        file: format!(\n   438\t                            \"history/payloads/{}\",\n   439\t                            path.file_name()\n   440\t                                .unwrap_or_default()\n   441\t                                .to_string_lossy()\n   442\t                        ),\n   443\t                        details: e.to_string(),\n   444\t                    }\n   445\t                })?;\n   446\t                records.push(record);\n   447\t            }\n   448\t        }\n   449\t\n   450\t        records.sort_by_key(|r| r.created_at);\n   451\t        Ok(records)\n   452\t    }\n   453\t\n   454\t    fn list_artifacts(\n   455\t        &self,\n   456\t        base_dir: &Path,\n   457\t        project_id: &ProjectId,\n   458\t    ) -> AppResult<Vec<ArtifactRecord>> {\n   459\t        let dir = FileSystem::project_root(base_dir, project_id).join(\"history/artifacts\");\n   460\t        if !dir.is_dir() {\n   461\t            return Ok(Vec::new());\n   462\t        }\n   463\t\n   464\t        let mut records = Vec::new();\n   465\t        for entry in fs::read_dir(&dir)? {\n   466\t            let entry = entry?;\n   467\t            let path = entry.path();\n   468\t            if path.extension().is_some_and(|ext| ext == \"json\") {\n   469\t                let raw = fs::read_to_string(&path)?;\n   470\t                let record: ArtifactRecord =\n   471\t                    serde_json::from_str(&raw).map_err(|e| AppError::CorruptRecord {\n   472\t                        file: format!(\n   473\t                            \"history/artifacts/{}\",\n   474\t                            path.file_name()\n   475\t                                .unwrap_or_default()\n   476\t                                .to_string_lossy()\n   477\t                        ),\n   478\t                        details: e.to_string(),\n   479\t                    })?;\n   480\t                records.push(record);\n   481\t            }\n   482\t        }\n   483\t\n   484\t        records.sort_by_key(|r| r.created_at);\n   485\t        Ok(records)\n   486\t    }\n   487\t}\n   488\t\n   489\t/// Filesystem-backed implementation of `RuntimeLogStorePort`.\n   490\tpub struct FsRuntimeLogStore;\n   491\t\n   492\timpl RuntimeLogStorePort for FsRuntimeLogStore {\n   493\t    fn read_runtime_logs(\n   494\t        &self,\n   495\t        base_dir: &Path,\n   496\t        project_id: &ProjectId,\n   497\t    ) -> AppResult<Vec<RuntimeLogEntry>> {\n   498\t        let dir = FileSystem::project_root(base_dir, project_id).join(\"runtime/logs\");\n   499\t        if !dir.is_dir() {\n   500\t            return Ok(Vec::new());\n   501\t        }\n   502\t\n   503\t        let mut entries = Vec::new();\n   504\t        let mut paths: Vec<_> = fs::read_dir(&dir)?\n   505\t            .filter_map(|e| e.ok())\n   506\t            .map(|e| e.path())\n   507\t            .filter(|p| p.extension().is_some_and(|ext| ext == \"ndjson\"))\n   508\t            .collect();\n   509\t        paths.sort();\n   510\t\n   511\t        for path in paths {\n   512\t            let contents = fs::read_to_string(&path)?;\n   513\t            for line in contents.lines() {\n   514\t                let trimmed = line.trim();\n   515\t                if trimmed.is_empty() {\n   516\t                    continue;\n   517\t                }\n   518\t                if let Ok(entry) = serde_json::from_str::<RuntimeLogEntry>(trimmed) {\n   519\t                    entries.push(entry);\n   520\t                }\n   521\t            }\n   522\t        }\n   523\t\n   524\t        Ok(entries)\n   525\t    }\n   526\t}\n   527\t\n   528\t/// Filesystem-backed implementation of `RunSnapshotPort`.\n   529\tpub struct FsRunSnapshotStore;\n   530\t\n   531\timpl RunSnapshotPort for FsRunSnapshotStore {\n   532\t    fn read_run_snapshot(\n   533\t        &self,\n   534\t        base_dir: &Path,\n   535\t        project_id: &ProjectId,\n   536\t    ) -> AppResult<RunSnapshot> {\n   537\t        let path = FileSystem::project_root(base_dir, project_id).join(RUN_FILE);\n   538\t        match fs::read_to_string(&path) {\n   539\t            Ok(raw) => {\n   540\t                let snapshot: RunSnapshot =\n   541\t                    serde_json::from_str(&raw).map_err(|e| AppError::CorruptRecord {\n   542\t                        file: format!(\"projects/{}/run.json\", project_id),\n   543\t                        details: e.to_string(),\n   544\t                    })?;\n   545\t                // Semantic validation: reject inconsistent status/active_run combinations\n   546\t                snapshot\n   547\t                    .validate_semantics()\n   548\t                    .map_err(|details| AppError::CorruptRecord {\n   549\t                        file: format!(\"projects/{}/run.json\", project_id),\n   550\t                        details,\n   551\t                    })?;\n   552\t                Ok(snapshot)\n   553\t            }\n   554\t            Err(e) if e.kind() == std::io::ErrorKind::NotFound => {\n   555\t                Err(AppError::CorruptRecord {\n   556\t                    file: format!(\"projects/{}/run.json\", project_id),\n   557\t                    details: \"canonical file is missing\".to_owned(),\n   558\t                })\n   559\t            }\n   560\t            Err(e) => Err(e.into()),\n   561\t        }\n   562\t    }\n   563\t}\n   564\t\n   565\t/// Filesystem-backed implementation of `ActiveProjectPort`.\n   566\tpub struct FsActiveProjectStore;\n   567\t\n   568\timpl ActiveProjectPort for FsActiveProjectStore {\n   569\t    fn read_active_project_id(&self, base_dir: &Path) -> AppResult<Option<String>> {\n   570\t        FileSystem::read_active_project(&FileSystem::workspace_root_path(base_dir))\n   571\t    }\n   572\t\n   573\t    fn clear_active_project(&self, base_dir: &Path) -> AppResult<()> {\n   574\t        let path = FileSystem::workspace_root_path(base_dir).join(ACTIVE_PROJECT_FILE);\n   575\t        match fs::remove_file(&path) {\n   576\t            Ok(()) => Ok(()),\n   577\t            Err(e) if e.kind() == std::io::ErrorKind::NotFound => Ok(()),\n   578\t            Err(e) => Err(e.into()),\n   579\t        }\n   580\t    }\n   581\t}\n","exit_code":0,"status":"completed"}}
