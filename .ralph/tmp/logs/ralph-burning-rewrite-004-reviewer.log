{"type":"item.completed","item":{"id":"item_38","type":"command_execution","command":"/run/current-system/sw/bin/bash -lc \"nl -ba /root/new-ralph-burning/ralph-burning-rewrite/src/contexts/project_run_record/queries.rs | sed -n '1,220p'\"","aggregated_output":"     1\tuse crate::shared::error::AppResult;\n     2\t\n     3\tuse super::model::{\n     4\t    JournalEvent, PayloadRecord, ArtifactRecord, RuntimeLogEntry, RunSnapshot,\n     5\t};\n     6\t\n     7\t/// Read model for `run status`: canonical state only, no inference from artifacts.\n     8\t#[derive(Debug, Clone)]\n     9\tpub struct RunStatusView {\n    10\t    pub project_id: String,\n    11\t    pub status: String,\n    12\t    pub stage: Option<String>,\n    13\t    pub cycle: Option<u32>,\n    14\t    pub completion_round: Option<u32>,\n    15\t    pub summary: String,\n    16\t}\n    17\t\n    18\timpl RunStatusView {\n    19\t    pub fn from_snapshot(project_id: &str, snapshot: &RunSnapshot) -> Self {\n    20\t        match &snapshot.active_run {\n    21\t            Some(active) => Self {\n    22\t                project_id: project_id.to_owned(),\n    23\t                status: snapshot.status.display_str().to_owned(),\n    24\t                stage: Some(active.stage_cursor.stage.as_str().to_owned()),\n    25\t                cycle: Some(active.stage_cursor.cycle),\n    26\t                completion_round: Some(active.stage_cursor.completion_round),\n    27\t                summary: snapshot.status_summary.clone(),\n    28\t            },\n    29\t            None => Self {\n    30\t                project_id: project_id.to_owned(),\n    31\t                status: snapshot.status.display_str().to_owned(),\n    32\t                stage: None,\n    33\t                cycle: None,\n    34\t                completion_round: None,\n    35\t                summary: snapshot.status_summary.clone(),\n    36\t            },\n    37\t        }\n    38\t    }\n    39\t}\n    40\t\n    41\t/// Read model for `run history`: durable history only (journal + payloads + artifacts).\n    42\t/// Runtime logs never appear here.\n    43\t#[derive(Debug, Clone)]\n    44\tpub struct RunHistoryView {\n    45\t    pub project_id: String,\n    46\t    pub events: Vec<JournalEvent>,\n    47\t    pub payloads: Vec<PayloadRecord>,\n    48\t    pub artifacts: Vec<ArtifactRecord>,\n    49\t}\n    50\t\n    51\t/// Read model for `run tail`: durable history by default, with optional runtime logs.\n    52\t#[derive(Debug, Clone)]\n    53\tpub struct RunTailView {\n    54\t    pub project_id: String,\n    55\t    pub events: Vec<JournalEvent>,\n    56\t    pub payloads: Vec<PayloadRecord>,\n    57\t    pub artifacts: Vec<ArtifactRecord>,\n    58\t    pub runtime_logs: Option<Vec<RuntimeLogEntry>>,\n    59\t}\n    60\t\n    61\t/// Build a status view from canonical run state.\n    62\tpub fn build_status_view(project_id: &str, snapshot: &RunSnapshot) -> RunStatusView {\n    63\t    RunStatusView::from_snapshot(project_id, snapshot)\n    64\t}\n    65\t\n    66\t/// Build a history view from durable records only. No runtime logs.\n    67\tpub fn build_history_view(\n    68\t    project_id: &str,\n    69\t    events: Vec<JournalEvent>,\n    70\t    payloads: Vec<PayloadRecord>,\n    71\t    artifacts: Vec<ArtifactRecord>,\n    72\t) -> RunHistoryView {\n    73\t    RunHistoryView {\n    74\t        project_id: project_id.to_owned(),\n    75\t        events,\n    76\t        payloads,\n    77\t        artifacts,\n    78\t    }\n    79\t}\n    80\t\n    81\t/// Build a tail view: durable history always, runtime logs only when requested.\n    82\tpub fn build_tail_view(\n    83\t    project_id: &str,\n    84\t    events: Vec<JournalEvent>,\n    85\t    payloads: Vec<PayloadRecord>,\n    86\t    artifacts: Vec<ArtifactRecord>,\n    87\t    include_logs: bool,\n    88\t    runtime_logs: Vec<RuntimeLogEntry>,\n    89\t) -> RunTailView {\n    90\t    RunTailView {\n    91\t        project_id: project_id.to_owned(),\n    92\t        events,\n    93\t        payloads,\n    94\t        artifacts,\n    95\t        runtime_logs: if include_logs {\n    96\t            Some(runtime_logs)\n    97\t        } else {\n    98\t            None\n    99\t        },\n   100\t    }\n   101\t}\n   102\t\n   103\t/// Validate that durable history records are consistent:\n   104\t/// every artifact has a matching payload and every payload has a matching artifact.\n   105\t/// Payload + artifact are treated as a paired durable-history unit.\n   106\tpub fn validate_history_consistency(\n   107\t    payloads: &[PayloadRecord],\n   108\t    artifacts: &[ArtifactRecord],\n   109\t) -> AppResult<()> {\n   110\t    // Check orphaned artifacts (artifact without matching payload)\n   111\t    for artifact in artifacts {\n   112\t        if !payloads.iter().any(|p| p.payload_id == artifact.payload_id) {\n   113\t            return Err(crate::shared::error::AppError::CorruptRecord {\n   114\t                file: format!(\"history/artifacts/{}\", artifact.artifact_id),\n   115\t                details: format!(\n   116\t                    \"artifact references payload '{}' which does not exist\",\n   117\t                    artifact.payload_id\n   118\t                ),\n   119\t            });\n   120\t        }\n   121\t    }\n   122\t    // Check orphaned payloads (payload without matching artifact)\n   123\t    for payload in payloads {\n   124\t        if !artifacts.iter().any(|a| a.payload_id == payload.payload_id) {\n   125\t            return Err(crate::shared::error::AppError::CorruptRecord {\n   126\t                file: format!(\"history/payloads/{}\", payload.payload_id),\n   127\t                details: \"payload has no matching artifact\".to_owned(),\n   128\t            });\n   129\t        }\n   130\t    }\n   131\t    Ok(())\n   132\t}\n","exit_code":0,"status":"completed"}}
{"type":"item.completed","item":{"id":"item_39","type":"command_execution","command":"/run/current-system/sw/bin/bash -lc \"nl -ba /root/new-ralph-burning/ralph-burning-rewrite/src/contexts/project_run_record/model.rs | sed -n '1,240p'\"","aggregated_output":"     1\tuse chrono::{DateTime, Utc};\n     2\tuse serde::{Deserialize, Serialize};\n     3\t\n     4\tuse crate::shared::domain::{FlowPreset, ProjectId, StageCursor, StageId};\n     5\t\n     6\t/// Immutable project metadata persisted in `project.toml`.\n     7\t#[derive(Debug, Clone, PartialEq, Serialize, Deserialize)]\n     8\tpub struct ProjectRecord {\n     9\t    pub id: ProjectId,\n    10\t    pub name: String,\n    11\t    pub flow: FlowPreset,\n    12\t    pub prompt_reference: String,\n    13\t    pub prompt_hash: String,\n    14\t    pub created_at: DateTime<Utc>,\n    15\t    pub status_summary: ProjectStatusSummary,\n    16\t}\n    17\t\n    18\t#[derive(Debug, Clone, Copy, PartialEq, Eq, Serialize, Deserialize)]\n    19\t#[serde(rename_all = \"snake_case\")]\n    20\tpub enum ProjectStatusSummary {\n    21\t    Created,\n    22\t    Active,\n    23\t    Completed,\n    24\t    Failed,\n    25\t}\n    26\t\n    27\t/// Canonical run state persisted in `run.json`.\n    28\t/// This is the single source of truth for run progression - never inferred from artifacts.\n    29\t#[derive(Debug, Clone, PartialEq, Serialize, Deserialize)]\n    30\tpub struct RunSnapshot {\n    31\t    pub active_run: Option<ActiveRun>,\n    32\t    pub status: RunStatus,\n    33\t    pub cycle_history: Vec<CycleHistoryEntry>,\n    34\t    pub completion_rounds: u32,\n    35\t    pub rollback_point_meta: RollbackPointMeta,\n    36\t    pub amendment_queue: AmendmentQueueState,\n    37\t    pub status_summary: String,\n    38\t}\n    39\t\n    40\timpl RunSnapshot {\n    41\t    pub fn initial() -> Self {\n    42\t        Self {\n    43\t            active_run: None,\n    44\t            status: RunStatus::NotStarted,\n    45\t            cycle_history: Vec::new(),\n    46\t            completion_rounds: 0,\n    47\t            rollback_point_meta: RollbackPointMeta::default(),\n    48\t            amendment_queue: AmendmentQueueState::default(),\n    49\t            status_summary: \"not started\".to_owned(),\n    50\t        }\n    51\t    }\n    52\t\n    53\t    pub fn has_active_run(&self) -> bool {\n    54\t        self.active_run.is_some()\n    55\t    }\n    56\t\n    57\t    /// Semantic validation of run snapshot consistency.\n    58\t    /// Returns `Err` with a description if status and active_run are inconsistent.\n    59\t    pub fn validate_semantics(&self) -> Result<(), String> {\n    60\t        match (&self.status, &self.active_run) {\n    61\t            // Running or Paused requires an active run cursor\n    62\t            (RunStatus::Running, None) => Err(\n    63\t                \"status is 'running' but active_run is null — inconsistent canonical state\"\n    64\t                    .to_owned(),\n    65\t            ),\n    66\t            (RunStatus::Paused, None) => Err(\n    67\t                \"status is 'paused' but active_run is null — inconsistent canonical state\"\n    68\t                    .to_owned(),\n    69\t            ),\n    70\t            // NotStarted must not have an active run cursor\n    71\t            (RunStatus::NotStarted, Some(_)) => Err(\n    72\t                \"status is 'not_started' but active_run is present — inconsistent canonical state\"\n    73\t                    .to_owned(),\n    74\t            ),\n    75\t            // All other combinations are valid:\n    76\t            // NotStarted + None, Running/Paused + Some, Completed/Failed + None/Some\n    77\t            _ => Ok(()),\n    78\t        }\n    79\t    }\n    80\t}\n    81\t\n    82\t#[derive(Debug, Clone, PartialEq, Serialize, Deserialize)]\n    83\tpub struct ActiveRun {\n    84\t    pub run_id: String,\n    85\t    pub stage_cursor: StageCursor,\n    86\t    pub started_at: DateTime<Utc>,\n    87\t}\n    88\t\n    89\t#[derive(Debug, Clone, Copy, PartialEq, Eq, Serialize, Deserialize)]\n    90\t#[serde(rename_all = \"snake_case\")]\n    91\tpub enum RunStatus {\n    92\t    NotStarted,\n    93\t    Running,\n    94\t    Paused,\n    95\t    Completed,\n    96\t    Failed,\n    97\t}\n    98\t\n    99\timpl RunStatus {\n   100\t    /// Human-readable status string for CLI output.\n   101\t    pub fn display_str(self) -> &'static str {\n   102\t        match self {\n   103\t            Self::NotStarted => \"not started\",\n   104\t            Self::Running => \"running\",\n   105\t            Self::Paused => \"paused\",\n   106\t            Self::Completed => \"completed\",\n   107\t            Self::Failed => \"failed\",\n   108\t        }\n   109\t    }\n   110\t}\n   111\t\n   112\t/// A single entry in the cycle history tracking progression through work cycles.\n   113\t#[derive(Debug, Clone, PartialEq, Serialize, Deserialize)]\n   114\tpub struct CycleHistoryEntry {\n   115\t    pub cycle: u32,\n   116\t    pub stage_id: StageId,\n   117\t    pub started_at: DateTime<Utc>,\n   118\t    pub completed_at: Option<DateTime<Utc>>,\n   119\t}\n   120\t\n   121\t/// Rollback-point metadata tracked in the canonical run snapshot.\n   122\t#[derive(Debug, Clone, Default, PartialEq, Serialize, Deserialize)]\n   123\tpub struct RollbackPointMeta {\n   124\t    pub last_rollback_id: Option<String>,\n   125\t    pub rollback_count: u32,\n   126\t}\n   127\t\n   128\t/// Amendment queue state tracked in the canonical run snapshot.\n   129\t#[derive(Debug, Clone, Default, PartialEq, Serialize, Deserialize)]\n   130\tpub struct AmendmentQueueState {\n   131\t    pub pending: Vec<serde_json::Value>,\n   132\t    pub processed_count: u32,\n   133\t}\n   134\t\n   135\t/// A single journal event stored in `journal.ndjson`.\n   136\t#[derive(Debug, Clone, PartialEq, Serialize, Deserialize)]\n   137\tpub struct JournalEvent {\n   138\t    pub sequence: u64,\n   139\t    pub timestamp: DateTime<Utc>,\n   140\t    pub event_type: JournalEventType,\n   141\t    pub details: serde_json::Value,\n   142\t}\n   143\t\n   144\t#[derive(Debug, Clone, PartialEq, Eq, Serialize, Deserialize)]\n   145\t#[serde(rename_all = \"snake_case\")]\n   146\tpub enum JournalEventType {\n   147\t    ProjectCreated,\n   148\t    RunStarted,\n   149\t    StageEntered,\n   150\t    StageCompleted,\n   151\t    CycleAdvanced,\n   152\t    CompletionRoundAdvanced,\n   153\t    RunCompleted,\n   154\t    RunFailed,\n   155\t    RollbackCreated,\n   156\t    AmendmentQueued,\n   157\t}\n   158\t\n   159\t/// A durable history payload record stored in `history/payloads/`.\n   160\t#[derive(Debug, Clone, PartialEq, Serialize, Deserialize)]\n   161\tpub struct PayloadRecord {\n   162\t    pub payload_id: String,\n   163\t    pub stage_id: StageId,\n   164\t    pub cycle: u32,\n   165\t    pub attempt: u32,\n   166\t    pub created_at: DateTime<Utc>,\n   167\t    pub payload: serde_json::Value,\n   168\t}\n   169\t\n   170\t/// A durable history artifact record stored in `history/artifacts/`.\n   171\t#[derive(Debug, Clone, PartialEq, Serialize, Deserialize)]\n   172\tpub struct ArtifactRecord {\n   173\t    pub artifact_id: String,\n   174\t    pub payload_id: String,\n   175\t    pub stage_id: StageId,\n   176\t    pub created_at: DateTime<Utc>,\n   177\t    pub content: String,\n   178\t}\n   179\t\n   180\t/// A runtime log entry stored in `runtime/logs/`.\n   181\t#[derive(Debug, Clone, PartialEq, Serialize, Deserialize)]\n   182\tpub struct RuntimeLogEntry {\n   183\t    pub timestamp: DateTime<Utc>,\n   184\t    pub level: LogLevel,\n   185\t    pub source: String,\n   186\t    pub message: String,\n   187\t}\n   188\t\n   189\t#[derive(Debug, Clone, Copy, PartialEq, Eq, Serialize, Deserialize)]\n   190\t#[serde(rename_all = \"snake_case\")]\n   191\tpub enum LogLevel {\n   192\t    Debug,\n   193\t    Info,\n   194\t    Warn,\n   195\t    Error,\n   196\t}\n   197\t\n   198\t/// Rollback metadata stored in `rollback/`.\n   199\t#[derive(Debug, Clone, PartialEq, Serialize, Deserialize)]\n   200\tpub struct RollbackPoint {\n   201\t    pub rollback_id: String,\n   202\t    pub created_at: DateTime<Utc>,\n   203\t    pub stage_id: StageId,\n   204\t    pub cycle: u32,\n   205\t    pub run_snapshot: RunSnapshot,\n   206\t}\n   207\t\n   208\t/// Empty session store for `sessions.json`.\n   209\t#[derive(Debug, Clone, PartialEq, Serialize, Deserialize)]\n   210\tpub struct SessionStore {\n   211\t    pub sessions: Vec<serde_json::Value>,\n   212\t}\n   213\t\n   214\timpl SessionStore {\n   215\t    pub fn empty() -> Self {\n   216\t        Self {\n   217\t            sessions: Vec::new(),\n   218\t        }\n   219\t    }\n   220\t}\n   221\t\n   222\t/// Summary used in `project list` output.\n   223\t#[derive(Debug, Clone)]\n   224\tpub struct ProjectListEntry {\n   225\t    pub id: ProjectId,\n   226\t    pub name: String,\n   227\t    pub flow: FlowPreset,\n   228\t    pub status_summary: ProjectStatusSummary,\n   229\t    pub created_at: DateTime<Utc>,\n   230\t    pub is_active: bool,\n   231\t}\n   232\t\n   233\t/// Detailed project view used in `project show` output.\n   234\t#[derive(Debug, Clone)]\n   235\tpub struct ProjectDetail {\n   236\t    pub record: ProjectRecord,\n   237\t    pub run_snapshot: RunSnapshot,\n   238\t    pub journal_event_count: u64,\n   239\t    pub rollback_count: usize,\n   240\t    pub is_active: bool,\n","exit_code":0,"status":"completed"}}
{"type":"item.started","item":{"id":"item_40","type":"command_execution","command":"/run/current-system/sw/bin/bash -lc \"nl -ba /root/new-ralph-burning/ralph-burning-rewrite/src/contexts/project_run_record/service.rs | sed -n '1,280p'\"","aggregated_output":"","exit_code":null,"status":"in_progress"}}
{"type":"item.completed","item":{"id":"item_40","type":"command_execution","command":"/run/current-system/sw/bin/bash -lc \"nl -ba /root/new-ralph-burning/ralph-burning-rewrite/src/contexts/project_run_record/service.rs | sed -n '1,280p'\"","aggregated_output":"     1\tuse std::path::Path;\n     2\t\n     3\tuse chrono::{DateTime, Utc};\n     4\t\n     5\tuse crate::shared::domain::{FlowPreset, ProjectId};\n     6\tuse crate::shared::error::{AppError, AppResult};\n     7\t\n     8\tuse super::model::{\n     9\t    ArtifactRecord, JournalEvent, JournalEventType, PayloadRecord,\n    10\t    ProjectDetail, ProjectListEntry, ProjectRecord, ProjectStatusSummary,\n    11\t    RunSnapshot, RuntimeLogEntry, SessionStore,\n    12\t};\n    13\tuse super::journal;\n    14\tuse super::queries::{\n    15\t    self, RunHistoryView, RunStatusView, RunTailView,\n    16\t};\n    17\t\n    18\t/// Port for reading and writing project records.\n    19\tpub trait ProjectStorePort {\n    20\t    fn project_exists(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<bool>;\n    21\t    fn read_project_record(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<ProjectRecord>;\n    22\t    fn list_project_ids(&self, base_dir: &Path) -> AppResult<Vec<ProjectId>>;\n    23\t    fn delete_project(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<()>;\n    24\t\n    25\t    /// Atomically stage and commit a new project. If any step fails,\n    26\t    /// the project must not be visible to list/show.\n    27\t    fn create_project_atomic(\n    28\t        &self,\n    29\t        base_dir: &Path,\n    30\t        record: &ProjectRecord,\n    31\t        prompt_contents: &str,\n    32\t        run_snapshot: &RunSnapshot,\n    33\t        initial_journal_line: &str,\n    34\t        sessions: &SessionStore,\n    35\t    ) -> AppResult<()>;\n    36\t}\n    37\t\n    38\t/// Port for reading and appending journal events.\n    39\tpub trait JournalStorePort {\n    40\t    fn read_journal(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<Vec<JournalEvent>>;\n    41\t    fn append_event(&self, base_dir: &Path, project_id: &ProjectId, line: &str) -> AppResult<()>;\n    42\t}\n    43\t\n    44\t/// Port for reading payload and artifact durable history.\n    45\tpub trait ArtifactStorePort {\n    46\t    fn list_payloads(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<Vec<PayloadRecord>>;\n    47\t    fn list_artifacts(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<Vec<ArtifactRecord>>;\n    48\t}\n    49\t\n    50\t/// Port for reading runtime logs (separate from durable history).\n    51\tpub trait RuntimeLogStorePort {\n    52\t    fn read_runtime_logs(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<Vec<RuntimeLogEntry>>;\n    53\t}\n    54\t\n    55\t/// Port for reading/writing the run snapshot.\n    56\tpub trait RunSnapshotPort {\n    57\t    fn read_run_snapshot(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<RunSnapshot>;\n    58\t}\n    59\t\n    60\t/// Port for reading/clearing the active project pointer.\n    61\tpub trait ActiveProjectPort {\n    62\t    fn read_active_project_id(&self, base_dir: &Path) -> AppResult<Option<String>>;\n    63\t    fn clear_active_project(&self, base_dir: &Path) -> AppResult<()>;\n    64\t}\n    65\t\n    66\t/// Input for the `project create` use case.\n    67\tpub struct CreateProjectInput {\n    68\t    pub id: ProjectId,\n    69\t    pub name: String,\n    70\t    pub flow: FlowPreset,\n    71\t    pub prompt_path: String,\n    72\t    pub prompt_contents: String,\n    73\t    pub prompt_hash: String,\n    74\t    pub created_at: DateTime<Utc>,\n    75\t}\n    76\t\n    77\t/// Create a new project with all canonical files.\n    78\tpub fn create_project(\n    79\t    store: &dyn ProjectStorePort,\n    80\t    journal_store: &dyn JournalStorePort,\n    81\t    base_dir: &Path,\n    82\t    input: CreateProjectInput,\n    83\t) -> AppResult<ProjectRecord> {\n    84\t    // Check for duplicate project ID\n    85\t    if store.project_exists(base_dir, &input.id)? {\n    86\t        return Err(AppError::DuplicateProject {\n    87\t            project_id: input.id.to_string(),\n    88\t        });\n    89\t    }\n    90\t\n    91\t    let record = ProjectRecord {\n    92\t        id: input.id.clone(),\n    93\t        name: input.name,\n    94\t        flow: input.flow,\n    95\t        prompt_reference: input.prompt_path,\n    96\t        prompt_hash: input.prompt_hash,\n    97\t        created_at: input.created_at,\n    98\t        status_summary: ProjectStatusSummary::Created,\n    99\t    };\n   100\t\n   101\t    let run_snapshot = RunSnapshot::initial();\n   102\t    let sessions = SessionStore::empty();\n   103\t\n   104\t    // Create the initial journal event\n   105\t    let initial_event = JournalEvent {\n   106\t        sequence: 1,\n   107\t        timestamp: input.created_at,\n   108\t        event_type: JournalEventType::ProjectCreated,\n   109\t        details: serde_json::json!({\n   110\t            \"project_id\": record.id.as_str(),\n   111\t            \"flow\": record.flow.as_str(),\n   112\t        }),\n   113\t    };\n   114\t    let journal_line = journal::serialize_event(&initial_event)?;\n   115\t\n   116\t    // Atomic creation: all files or nothing\n   117\t    store.create_project_atomic(\n   118\t        base_dir,\n   119\t        &record,\n   120\t        &input.prompt_contents,\n   121\t        &run_snapshot,\n   122\t        &journal_line,\n   123\t        &sessions,\n   124\t    )?;\n   125\t\n   126\t    // create_project_atomic writes the journal as part of the atomic init,\n   127\t    // but we don't call journal_store.append_event here because the atomic\n   128\t    // creation already wrote the initial journal line. The journal_store\n   129\t    // parameter is kept for interface consistency and future use.\n   130\t    let _ = journal_store;\n   131\t\n   132\t    Ok(record)\n   133\t}\n   134\t\n   135\t/// List all projects with summary data.\n   136\tpub fn list_projects(\n   137\t    store: &dyn ProjectStorePort,\n   138\t    active_port: &dyn ActiveProjectPort,\n   139\t    base_dir: &Path,\n   140\t) -> AppResult<Vec<ProjectListEntry>> {\n   141\t    let active_id = active_port.read_active_project_id(base_dir)?;\n   142\t    let project_ids = store.list_project_ids(base_dir)?;\n   143\t\n   144\t    let mut entries = Vec::new();\n   145\t    for pid in project_ids {\n   146\t        let record = store.read_project_record(base_dir, &pid)?;\n   147\t        let is_active = active_id.as_deref() == Some(pid.as_str());\n   148\t        entries.push(ProjectListEntry {\n   149\t            id: record.id,\n   150\t            name: record.name,\n   151\t            flow: record.flow,\n   152\t            status_summary: record.status_summary,\n   153\t            created_at: record.created_at,\n   154\t            is_active,\n   155\t        });\n   156\t    }\n   157\t\n   158\t    Ok(entries)\n   159\t}\n   160\t\n   161\t/// Show detailed project information.\n   162\tpub fn show_project(\n   163\t    store: &dyn ProjectStorePort,\n   164\t    run_port: &dyn RunSnapshotPort,\n   165\t    journal_port: &dyn JournalStorePort,\n   166\t    active_port: &dyn ActiveProjectPort,\n   167\t    base_dir: &Path,\n   168\t    project_id: &ProjectId,\n   169\t) -> AppResult<ProjectDetail> {\n   170\t    if !store.project_exists(base_dir, project_id)? {\n   171\t        return Err(AppError::ProjectNotFound {\n   172\t            project_id: project_id.to_string(),\n   173\t        });\n   174\t    }\n   175\t\n   176\t    let record = store.read_project_record(base_dir, project_id)?;\n   177\t    let run_snapshot = run_port.read_run_snapshot(base_dir, project_id)?;\n   178\t    let events = journal_port.read_journal(base_dir, project_id)?;\n   179\t    let journal_event_count = events.len() as u64;\n   180\t    let active_id = active_port.read_active_project_id(base_dir)?;\n   181\t    let is_active = active_id.as_deref() == Some(project_id.as_str());\n   182\t\n   183\t    // Count rollback points from journal events\n   184\t    let rollback_count = events\n   185\t        .iter()\n   186\t        .filter(|e| e.event_type == JournalEventType::RollbackCreated)\n   187\t        .count();\n   188\t\n   189\t    Ok(ProjectDetail {\n   190\t        record,\n   191\t        run_snapshot,\n   192\t        journal_event_count,\n   193\t        rollback_count,\n   194\t        is_active,\n   195\t    })\n   196\t}\n   197\t\n   198\t/// Delete a project. Fails if project has an active run.\n   199\t/// Clears active-project pointer if it pointed to the deleted project.\n   200\tpub fn delete_project(\n   201\t    store: &dyn ProjectStorePort,\n   202\t    run_port: &dyn RunSnapshotPort,\n   203\t    active_port: &dyn ActiveProjectPort,\n   204\t    base_dir: &Path,\n   205\t    project_id: &ProjectId,\n   206\t) -> AppResult<()> {\n   207\t    if !store.project_exists(base_dir, project_id)? {\n   208\t        return Err(AppError::ProjectNotFound {\n   209\t            project_id: project_id.to_string(),\n   210\t        });\n   211\t    }\n   212\t\n   213\t    // Check for active run\n   214\t    let run_snapshot = run_port.read_run_snapshot(base_dir, project_id)?;\n   215\t    if run_snapshot.has_active_run() {\n   216\t        return Err(AppError::ActiveRunDelete {\n   217\t            project_id: project_id.to_string(),\n   218\t        });\n   219\t    }\n   220\t\n   221\t    // Check if this is the active project (before delete)\n   222\t    let active_id = active_port.read_active_project_id(base_dir)?;\n   223\t    let was_active = active_id.as_deref() == Some(project_id.as_str());\n   224\t\n   225\t    // Perform the actual delete\n   226\t    store.delete_project(base_dir, project_id)?;\n   227\t\n   228\t    // Clear active-project pointer only after successful delete\n   229\t    if was_active {\n   230\t        active_port.clear_active_project(base_dir)?;\n   231\t    }\n   232\t\n   233\t    Ok(())\n   234\t}\n   235\t\n   236\t/// Get run status for the active project.\n   237\tpub fn run_status(\n   238\t    run_port: &dyn RunSnapshotPort,\n   239\t    base_dir: &Path,\n   240\t    project_id: &ProjectId,\n   241\t) -> AppResult<RunStatusView> {\n   242\t    let snapshot = run_port.read_run_snapshot(base_dir, project_id)?;\n   243\t    Ok(queries::build_status_view(project_id.as_str(), &snapshot))\n   244\t}\n   245\t\n   246\t/// Get run history (durable only, no runtime logs).\n   247\tpub fn run_history(\n   248\t    journal_port: &dyn JournalStorePort,\n   249\t    artifact_port: &dyn ArtifactStorePort,\n   250\t    base_dir: &Path,\n   251\t    project_id: &ProjectId,\n   252\t) -> AppResult<RunHistoryView> {\n   253\t    let events = journal_port.read_journal(base_dir, project_id)?;\n   254\t    let payloads = artifact_port.list_payloads(base_dir, project_id)?;\n   255\t    let artifacts = artifact_port.list_artifacts(base_dir, project_id)?;\n   256\t\n   257\t    queries::validate_history_consistency(&payloads, &artifacts)?;\n   258\t\n   259\t    Ok(queries::build_history_view(\n   260\t        project_id.as_str(),\n   261\t        events,\n   262\t        payloads,\n   263\t        artifacts,\n   264\t    ))\n   265\t}\n   266\t\n   267\t/// Get run tail: durable history by default, with optional runtime logs.\n   268\tpub fn run_tail(\n   269\t    journal_port: &dyn JournalStorePort,\n   270\t    artifact_port: &dyn ArtifactStorePort,\n   271\t    log_port: &dyn RuntimeLogStorePort,\n   272\t    base_dir: &Path,\n   273\t    project_id: &ProjectId,\n   274\t    include_logs: bool,\n   275\t) -> AppResult<RunTailView> {\n   276\t    let events = journal_port.read_journal(base_dir, project_id)?;\n   277\t    let payloads = artifact_port.list_payloads(base_dir, project_id)?;\n   278\t    let artifacts = artifact_port.list_artifacts(base_dir, project_id)?;\n   279\t\n   280\t    queries::validate_history_consistency(&payloads, &artifacts)?;\n","exit_code":0,"status":"completed"}}
