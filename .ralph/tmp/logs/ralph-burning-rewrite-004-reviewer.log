{"type":"item.completed","item":{"id":"item_12","type":"command_execution","command":"/run/current-system/sw/bin/bash -lc \"nl -ba /root/new-ralph-burning/ralph-burning-rewrite/src/contexts/project_run_record/service.rs | sed -n '1,340p'\"","aggregated_output":"     1\tuse std::path::Path;\n     2\t\n     3\tuse chrono::{DateTime, Utc};\n     4\t\n     5\tuse crate::shared::domain::{FlowPreset, ProjectId};\n     6\tuse crate::shared::error::{AppError, AppResult};\n     7\t\n     8\tuse super::model::{\n     9\t    ArtifactRecord, JournalEvent, JournalEventType, PayloadRecord,\n    10\t    ProjectDetail, ProjectListEntry, ProjectRecord, ProjectStatusSummary,\n    11\t    RunSnapshot, RuntimeLogEntry, SessionStore,\n    12\t};\n    13\tuse super::journal;\n    14\tuse super::queries::{\n    15\t    self, RunHistoryView, RunStatusView, RunTailView,\n    16\t};\n    17\t\n    18\t/// Port for reading and writing project records.\n    19\tpub trait ProjectStorePort {\n    20\t    fn project_exists(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<bool>;\n    21\t    fn read_project_record(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<ProjectRecord>;\n    22\t    fn list_project_ids(&self, base_dir: &Path) -> AppResult<Vec<ProjectId>>;\n    23\t    fn delete_project(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<()>;\n    24\t\n    25\t    /// Atomically stage and commit a new project. If any step fails,\n    26\t    /// the project must not be visible to list/show.\n    27\t    fn create_project_atomic(\n    28\t        &self,\n    29\t        base_dir: &Path,\n    30\t        record: &ProjectRecord,\n    31\t        prompt_contents: &str,\n    32\t        run_snapshot: &RunSnapshot,\n    33\t        initial_journal_line: &str,\n    34\t        sessions: &SessionStore,\n    35\t    ) -> AppResult<()>;\n    36\t}\n    37\t\n    38\t/// Port for reading and appending journal events.\n    39\tpub trait JournalStorePort {\n    40\t    fn read_journal(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<Vec<JournalEvent>>;\n    41\t    fn append_event(&self, base_dir: &Path, project_id: &ProjectId, line: &str) -> AppResult<()>;\n    42\t}\n    43\t\n    44\t/// Port for reading payload and artifact durable history.\n    45\tpub trait ArtifactStorePort {\n    46\t    fn list_payloads(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<Vec<PayloadRecord>>;\n    47\t    fn list_artifacts(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<Vec<ArtifactRecord>>;\n    48\t}\n    49\t\n    50\t/// Port for reading runtime logs (separate from durable history).\n    51\tpub trait RuntimeLogStorePort {\n    52\t    fn read_runtime_logs(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<Vec<RuntimeLogEntry>>;\n    53\t}\n    54\t\n    55\t/// Port for reading/writing the run snapshot.\n    56\tpub trait RunSnapshotPort {\n    57\t    fn read_run_snapshot(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<RunSnapshot>;\n    58\t}\n    59\t\n    60\t/// Port for reading/writing/clearing the active project pointer.\n    61\tpub trait ActiveProjectPort {\n    62\t    fn read_active_project_id(&self, base_dir: &Path) -> AppResult<Option<String>>;\n    63\t    fn clear_active_project(&self, base_dir: &Path) -> AppResult<()>;\n    64\t    fn write_active_project(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<()>;\n    65\t}\n    66\t\n    67\t/// Input for the `project create` use case.\n    68\tpub struct CreateProjectInput {\n    69\t    pub id: ProjectId,\n    70\t    pub name: String,\n    71\t    pub flow: FlowPreset,\n    72\t    pub prompt_path: String,\n    73\t    pub prompt_contents: String,\n    74\t    pub prompt_hash: String,\n    75\t    pub created_at: DateTime<Utc>,\n    76\t}\n    77\t\n    78\t/// Create a new project with all canonical files.\n    79\tpub fn create_project(\n    80\t    store: &dyn ProjectStorePort,\n    81\t    journal_store: &dyn JournalStorePort,\n    82\t    base_dir: &Path,\n    83\t    input: CreateProjectInput,\n    84\t) -> AppResult<ProjectRecord> {\n    85\t    // Check for duplicate project ID\n    86\t    if store.project_exists(base_dir, &input.id)? {\n    87\t        return Err(AppError::DuplicateProject {\n    88\t            project_id: input.id.to_string(),\n    89\t        });\n    90\t    }\n    91\t\n    92\t    let record = ProjectRecord {\n    93\t        id: input.id.clone(),\n    94\t        name: input.name,\n    95\t        flow: input.flow,\n    96\t        prompt_reference: \"prompt.md\".to_owned(),\n    97\t        prompt_hash: input.prompt_hash,\n    98\t        created_at: input.created_at,\n    99\t        status_summary: ProjectStatusSummary::Created,\n   100\t    };\n   101\t\n   102\t    let run_snapshot = RunSnapshot::initial();\n   103\t    let sessions = SessionStore::empty();\n   104\t\n   105\t    // Create the initial journal event\n   106\t    let initial_event = JournalEvent {\n   107\t        sequence: 1,\n   108\t        timestamp: input.created_at,\n   109\t        event_type: JournalEventType::ProjectCreated,\n   110\t        details: serde_json::json!({\n   111\t            \"project_id\": record.id.as_str(),\n   112\t            \"flow\": record.flow.as_str(),\n   113\t        }),\n   114\t    };\n   115\t    let journal_line = journal::serialize_event(&initial_event)?;\n   116\t\n   117\t    // Atomic creation: all files or nothing\n   118\t    store.create_project_atomic(\n   119\t        base_dir,\n   120\t        &record,\n   121\t        &input.prompt_contents,\n   122\t        &run_snapshot,\n   123\t        &journal_line,\n   124\t        &sessions,\n   125\t    )?;\n   126\t\n   127\t    // create_project_atomic writes the journal as part of the atomic init,\n   128\t    // but we don't call journal_store.append_event here because the atomic\n   129\t    // creation already wrote the initial journal line. The journal_store\n   130\t    // parameter is kept for interface consistency and future use.\n   131\t    let _ = journal_store;\n   132\t\n   133\t    Ok(record)\n   134\t}\n   135\t\n   136\t/// List all projects with summary data.\n   137\tpub fn list_projects(\n   138\t    store: &dyn ProjectStorePort,\n   139\t    active_port: &dyn ActiveProjectPort,\n   140\t    base_dir: &Path,\n   141\t) -> AppResult<Vec<ProjectListEntry>> {\n   142\t    let active_id = active_port.read_active_project_id(base_dir)?;\n   143\t    let project_ids = store.list_project_ids(base_dir)?;\n   144\t\n   145\t    let mut entries = Vec::new();\n   146\t    for pid in project_ids {\n   147\t        let record = store.read_project_record(base_dir, &pid)?;\n   148\t        let is_active = active_id.as_deref() == Some(pid.as_str());\n   149\t        entries.push(ProjectListEntry {\n   150\t            id: record.id,\n   151\t            name: record.name,\n   152\t            flow: record.flow,\n   153\t            status_summary: record.status_summary,\n   154\t            created_at: record.created_at,\n   155\t            is_active,\n   156\t        });\n   157\t    }\n   158\t\n   159\t    Ok(entries)\n   160\t}\n   161\t\n   162\t/// Show detailed project information.\n   163\tpub fn show_project(\n   164\t    store: &dyn ProjectStorePort,\n   165\t    run_port: &dyn RunSnapshotPort,\n   166\t    journal_port: &dyn JournalStorePort,\n   167\t    active_port: &dyn ActiveProjectPort,\n   168\t    base_dir: &Path,\n   169\t    project_id: &ProjectId,\n   170\t) -> AppResult<ProjectDetail> {\n   171\t    if !store.project_exists(base_dir, project_id)? {\n   172\t        return Err(AppError::ProjectNotFound {\n   173\t            project_id: project_id.to_string(),\n   174\t        });\n   175\t    }\n   176\t\n   177\t    let record = store.read_project_record(base_dir, project_id)?;\n   178\t    let run_snapshot = run_port.read_run_snapshot(base_dir, project_id)?;\n   179\t    let events = journal_port.read_journal(base_dir, project_id)?;\n   180\t    let journal_event_count = events.len() as u64;\n   181\t    let active_id = active_port.read_active_project_id(base_dir)?;\n   182\t    let is_active = active_id.as_deref() == Some(project_id.as_str());\n   183\t\n   184\t    // Count rollback points from journal events\n   185\t    let rollback_count = events\n   186\t        .iter()\n   187\t        .filter(|e| e.event_type == JournalEventType::RollbackCreated)\n   188\t        .count();\n   189\t\n   190\t    Ok(ProjectDetail {\n   191\t        record,\n   192\t        run_snapshot,\n   193\t        journal_event_count,\n   194\t        rollback_count,\n   195\t        is_active,\n   196\t    })\n   197\t}\n   198\t\n   199\t/// Delete a project. Fails if project has an active run.\n   200\t/// Clears active-project pointer if it pointed to the deleted project.\n   201\tpub fn delete_project(\n   202\t    store: &dyn ProjectStorePort,\n   203\t    run_port: &dyn RunSnapshotPort,\n   204\t    active_port: &dyn ActiveProjectPort,\n   205\t    base_dir: &Path,\n   206\t    project_id: &ProjectId,\n   207\t) -> AppResult<()> {\n   208\t    if !store.project_exists(base_dir, project_id)? {\n   209\t        return Err(AppError::ProjectNotFound {\n   210\t            project_id: project_id.to_string(),\n   211\t        });\n   212\t    }\n   213\t\n   214\t    // Check for active run\n   215\t    let run_snapshot = run_port.read_run_snapshot(base_dir, project_id)?;\n   216\t    if run_snapshot.has_active_run() {\n   217\t        return Err(AppError::ActiveRunDelete {\n   218\t            project_id: project_id.to_string(),\n   219\t        });\n   220\t    }\n   221\t\n   222\t    // Check if this is the active project (before delete)\n   223\t    let active_id = active_port.read_active_project_id(base_dir)?;\n   224\t    let was_active = active_id.as_deref() == Some(project_id.as_str());\n   225\t\n   226\t    // Delete the project first — the active-project pointer must remain\n   227\t    // intact until the delete has committed so that a failed delete leaves\n   228\t    // both the project and the pointer unchanged.\n   229\t    store.delete_project(base_dir, project_id)?;\n   230\t\n   231\t    // Delete succeeded — now clear the active-project pointer if it\n   232\t    // pointed to the deleted project.\n   233\t    if was_active {\n   234\t        active_port.clear_active_project(base_dir)?;\n   235\t    }\n   236\t\n   237\t    Ok(())\n   238\t}\n   239\t\n   240\t/// Get run status for the active project.\n   241\tpub fn run_status(\n   242\t    run_port: &dyn RunSnapshotPort,\n   243\t    base_dir: &Path,\n   244\t    project_id: &ProjectId,\n   245\t) -> AppResult<RunStatusView> {\n   246\t    let snapshot = run_port.read_run_snapshot(base_dir, project_id)?;\n   247\t    Ok(queries::build_status_view(project_id.as_str(), &snapshot))\n   248\t}\n   249\t\n   250\t/// Get run history (durable only, no runtime logs).\n   251\tpub fn run_history(\n   252\t    journal_port: &dyn JournalStorePort,\n   253\t    artifact_port: &dyn ArtifactStorePort,\n   254\t    base_dir: &Path,\n   255\t    project_id: &ProjectId,\n   256\t) -> AppResult<RunHistoryView> {\n   257\t    let events = journal_port.read_journal(base_dir, project_id)?;\n   258\t    let payloads = artifact_port.list_payloads(base_dir, project_id)?;\n   259\t    let artifacts = artifact_port.list_artifacts(base_dir, project_id)?;\n   260\t\n   261\t    queries::validate_history_consistency(&payloads, &artifacts)?;\n   262\t\n   263\t    Ok(queries::build_history_view(\n   264\t        project_id.as_str(),\n   265\t        events,\n   266\t        payloads,\n   267\t        artifacts,\n   268\t    ))\n   269\t}\n   270\t\n   271\t/// Get run tail: durable history by default, with optional runtime logs.\n   272\tpub fn run_tail(\n   273\t    journal_port: &dyn JournalStorePort,\n   274\t    artifact_port: &dyn ArtifactStorePort,\n   275\t    log_port: &dyn RuntimeLogStorePort,\n   276\t    base_dir: &Path,\n   277\t    project_id: &ProjectId,\n   278\t    include_logs: bool,\n   279\t) -> AppResult<RunTailView> {\n   280\t    let events = journal_port.read_journal(base_dir, project_id)?;\n   281\t    let payloads = artifact_port.list_payloads(base_dir, project_id)?;\n   282\t    let artifacts = artifact_port.list_artifacts(base_dir, project_id)?;\n   283\t\n   284\t    queries::validate_history_consistency(&payloads, &artifacts)?;\n   285\t\n   286\t    let runtime_logs = if include_logs {\n   287\t        log_port.read_runtime_logs(base_dir, project_id)?\n   288\t    } else {\n   289\t        Vec::new()\n   290\t    };\n   291\t\n   292\t    Ok(queries::build_tail_view(\n   293\t        project_id.as_str(),\n   294\t        events,\n   295\t        payloads,\n   296\t        artifacts,\n   297\t        include_logs,\n   298\t        runtime_logs,\n   299\t    ))\n   300\t}\n","exit_code":0,"status":"completed"}}
