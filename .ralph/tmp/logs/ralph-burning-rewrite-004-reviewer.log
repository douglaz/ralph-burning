handle_status() -> AppResult<()> {\n    52\t    let current_dir = std::env::current_dir()?;\n    53\t\n    54\t    let config = workspace_governance::load_workspace_config(&current_dir)?;\n    55\t    workspace_governance::ensure_supported_workspace_version(&config)?;\n    56\t\n    57\t    let project_id = workspace_governance::resolve_active_project(&current_dir)?;\n    58\t\n    59\t    let run_store = FsRunSnapshotStore;\n    60\t    let status = service::run_status(&run_store, &current_dir, &project_id)?;\n    61\t\n    62\t    println!(\"Project: {}\", status.project_id);\n    63\t    println!(\"Status: {}\", status.status);\n    64\t    if let Some(ref stage) = status.stage {\n    65\t        println!(\"Stage: {}\", stage);\n    66\t    }\n    67\t    if let Some(cycle) = status.cycle {\n    68\t        println!(\"Cycle: {}\", cycle);\n    69\t    }\n    70\t    if let Some(round) = status.completion_round {\n    71\t        println!(\"Completion round: {}\", round);\n    72\t    }\n    73\t    println!(\"Summary: {}\", status.summary);\n    74\t\n    75\t    Ok(())\n    76\t}\n    77\t\n    78\tasync fn handle_history() -> AppResult<()> {\n    79\t    let current_dir = std::env::current_dir()?;\n    80\t\n    81\t    let config = workspace_governance::load_workspace_config(&current_dir)?;\n    82\t    workspace_governance::ensure_supported_workspace_version(&config)?;\n    83\t\n    84\t    let project_id = workspace_governance::resolve_active_project(&current_dir)?;\n    85\t\n    86\t    let journal_store = FsJournalStore;\n    87\t    let artifact_store = FsArtifactStore;\n    88\t\n    89\t    let history = service::run_history(\n    90\t        &journal_store,\n    91\t        &artifact_store,\n    92\t        &current_dir,\n    93\t        &project_id,\n    94\t    )?;\n    95\t\n    96\t    println!(\"Project: {}\", history.project_id);\n    97\t    println!(\"--- Journal Events ---\");\n    98\t    for event in &history.events {\n    99\t        println!(\n   100\t            \"  [{}] {} - {:?}\",\n   101\t            event.sequence, event.timestamp, event.event_type\n   102\t        );\n   103\t    }\n   104\t\n   105\t    if !history.payloads.is_empty() {\n   106\t        println!(\"--- Payloads ---\");\n   107\t        for payload in &history.payloads {\n   108\t            println!(\n   109\t                \"  {} ({}, cycle {}, attempt {})\",\n   110\t                payload.payload_id, payload.stage_id, payload.cycle, payload.attempt\n   111\t            );\n   112\t        }\n   113\t    }\n   114\t\n   115\t    if !history.artifacts.is_empty() {\n   116\t        println!(\"--- Artifacts ---\");\n   117\t        for artifact in &history.artifacts {\n   118\t            println!(\n   119\t                \"  {} (payload: {}, stage: {})\",\n   120\t                artifact.artifact_id, artifact.payload_id, artifact.stage_id\n   121\t            );\n   122\t        }\n   123\t    }\n   124\t\n   125\t    Ok(())\n   126\t}\n   127\t\n   128\tasync fn handle_tail(include_logs: bool) -> AppResult<()> {\n   129\t    let current_dir = std::env::current_dir()?;\n   130\t\n   131\t    let config = workspace_governance::load_workspace_config(&current_dir)?;\n   132\t    workspace_governance::ensure_supported_workspace_version(&config)?;\n   133\t\n   134\t    let project_id = workspace_governance::resolve_active_project(&current_dir)?;\n   135\t\n   136\t    let journal_store = FsJournalStore;\n   137\t    let artifact_store = FsArtifactStore;\n   138\t    let log_store = FsRuntimeLogStore;\n   139\t\n   140\t    let tail = service::run_tail(\n   141\t        &journal_store,\n   142\t        &artifact_store,\n   143\t        &log_store,\n   144\t        &current_dir,\n   145\t        &project_id,\n   146\t        include_logs,\n   147\t    )?;\n   148\t\n   149\t    println!(\"Project: {}\", tail.project_id);\n   150\t    println!(\"--- Durable History ---\");\n   151\t    for event in &tail.events {\n   152\t        println!(\n   153\t            \"  [{}] {} - {:?}\",\n   154\t            event.sequence, event.timestamp, event.event_type\n   155\t        );\n   156\t    }\n   157\t\n   158\t    if let Some(ref logs) = tail.runtime_logs {\n   159\t        println!(\"--- Runtime Logs ---\");\n   160\t        if logs.is_empty() {\n   161\t            println!(\"  (no runtime logs)\");\n   162\t        } else {\n   163\t            for log in logs {\n   164\t                println!(\n   165\t                    \"  [{}] {:?} [{}] {}\",\n   166\t                    log.timestamp, log.level, log.source, log.message\n   167\t                );\n   168\t            }\n   169\t        }\n   170\t    }\n   171\t\n   172\t    Ok(())\n   173\t}\n","exit_code":0,"status":"completed"}}
