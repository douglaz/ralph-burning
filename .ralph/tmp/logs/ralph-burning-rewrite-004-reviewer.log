mat!(\"projects/{}/run.json\", project_id),\n   486\t                details: e.to_string(),\n   487\t            }),\n   488\t            Err(e) if e.kind() == std::io::ErrorKind::NotFound => Ok(RunSnapshot::initial()),\n   489\t            Err(e) => Err(e.into()),\n   490\t        }\n   491\t    }\n   492\t}\n   493\t\n   494\t/// Filesystem-backed implementation of `ActiveProjectPort`.\n   495\tpub struct FsActiveProjectStore;\n   496\t\n   497\timpl ActiveProjectPort for FsActiveProjectStore {\n   498\t    fn read_active_project_id(&self, base_dir: &Path) -> AppResult<Option<String>> {\n   499\t        FileSystem::read_active_project(&FileSystem::workspace_root_path(base_dir))\n   500\t    }\n   501\t\n   502\t    fn clear_active_project(&self, base_dir: &Path) -> AppResult<()> {\n   503\t        let path = FileSystem::workspace_root_path(base_dir).join(ACTIVE_PROJECT_FILE);\n   504\t        match fs::remove_file(&path) {\n   505\t            Ok(()) => Ok(()),\n   506\t            Err(e) if e.kind() == std::io::ErrorKind::NotFound => Ok(()),\n   507\t            Err(e) => Err(e.into()),\n   508\t        }\n   509\t    }\n   510\t}\n","exit_code":0,"status":"completed"}}
