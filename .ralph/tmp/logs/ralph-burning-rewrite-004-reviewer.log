{"type":"item.completed","item":{"id":"item_11","type":"command_execution","command":"/run/current-system/sw/bin/bash -lc \"sed -n '1,240p' ralph-burning-rewrite/src/contexts/project_run_record/model.rs\"","aggregated_output":"use chrono::{DateTime, Utc};\nuse serde::{Deserialize, Serialize};\n\nuse crate::shared::domain::{FlowPreset, ProjectId, StageCursor, StageId};\n\n/// Immutable project metadata persisted in `project.toml`.\n#[derive(Debug, Clone, PartialEq, Serialize, Deserialize)]\npub struct ProjectRecord {\n    pub id: ProjectId,\n    pub name: String,\n    pub flow: FlowPreset,\n    pub prompt_reference: String,\n    pub prompt_hash: String,\n    pub created_at: DateTime<Utc>,\n    pub status_summary: ProjectStatusSummary,\n}\n\n#[derive(Debug, Clone, Copy, PartialEq, Eq, Serialize, Deserialize)]\n#[serde(rename_all = \"snake_case\")]\npub enum ProjectStatusSummary {\n    Created,\n    Active,\n    Completed,\n    Failed,\n}\n\n/// Canonical run state persisted in `run.json`.\n/// This is the single source of truth for run progression - never inferred from artifacts.\n#[derive(Debug, Clone, PartialEq, Serialize, Deserialize)]\npub struct RunSnapshot {\n    pub active_run: Option<ActiveRun>,\n    pub status: RunStatus,\n    pub status_summary: String,\n}\n\nimpl RunSnapshot {\n    pub fn initial() -> Self {\n        Self {\n            active_run: None,\n            status: RunStatus::NotStarted,\n            status_summary: \"not started\".to_owned(),\n        }\n    }\n\n    pub fn has_active_run(&self) -> bool {\n        self.active_run.is_some()\n    }\n}\n\n#[derive(Debug, Clone, PartialEq, Serialize, Deserialize)]\npub struct ActiveRun {\n    pub run_id: String,\n    pub stage_cursor: StageCursor,\n    pub started_at: DateTime<Utc>,\n}\n\n#[derive(Debug, Clone, Copy, PartialEq, Eq, Serialize, Deserialize)]\n#[serde(rename_all = \"snake_case\")]\npub enum RunStatus {\n    NotStarted,\n    Running,\n    Paused,\n    Completed,\n    Failed,\n}\n\n/// A single journal event stored in `journal.ndjson`.\n#[derive(Debug, Clone, PartialEq, Serialize, Deserialize)]\npub struct JournalEvent {\n    pub sequence: u64,\n    pub timestamp: DateTime<Utc>,\n    pub event_type: JournalEventType,\n    pub details: serde_json::Value,\n}\n\n#[derive(Debug, Clone, PartialEq, Eq, Serialize, Deserialize)]\n#[serde(rename_all = \"snake_case\")]\npub enum JournalEventType {\n    ProjectCreated,\n    RunStarted,\n    StageEntered,\n    StageCompleted,\n    CycleAdvanced,\n    CompletionRoundAdvanced,\n    RunCompleted,\n    RunFailed,\n    RollbackCreated,\n    AmendmentQueued,\n}\n\n/// A durable history payload record stored in `history/payloads/`.\n#[derive(Debug, Clone, PartialEq, Serialize, Deserialize)]\npub struct PayloadRecord {\n    pub payload_id: String,\n    pub stage_id: StageId,\n    pub cycle: u32,\n    pub attempt: u32,\n    pub created_at: DateTime<Utc>,\n    pub payload: serde_json::Value,\n}\n\n/// A durable history artifact record stored in `history/artifacts/`.\n#[derive(Debug, Clone, PartialEq, Serialize, Deserialize)]\npub struct ArtifactRecord {\n    pub artifact_id: String,\n    pub payload_id: String,\n    pub stage_id: StageId,\n    pub created_at: DateTime<Utc>,\n    pub content: String,\n}\n\n/// A runtime log entry stored in `runtime/logs/`.\n#[derive(Debug, Clone, PartialEq, Serialize, Deserialize)]\npub struct RuntimeLogEntry {\n    pub timestamp: DateTime<Utc>,\n    pub level: LogLevel,\n    pub source: String,\n    pub message: String,\n}\n\n#[derive(Debug, Clone, Copy, PartialEq, Eq, Serialize, Deserialize)]\n#[serde(rename_all = \"snake_case\")]\npub enum LogLevel {\n    Debug,\n    Info,\n    Warn,\n    Error,\n}\n\n/// Rollback metadata stored in `rollback/`.\n#[derive(Debug, Clone, PartialEq, Serialize, Deserialize)]\npub struct RollbackPoint {\n    pub rollback_id: String,\n    pub created_at: DateTime<Utc>,\n    pub stage_id: StageId,\n    pub cycle: u32,\n    pub run_snapshot: RunSnapshot,\n}\n\n/// Empty session store for `sessions.json`.\n#[derive(Debug, Clone, PartialEq, Serialize, Deserialize)]\npub struct SessionStore {\n    pub sessions: Vec<serde_json::Value>,\n}\n\nimpl SessionStore {\n    pub fn empty() -> Self {\n        Self {\n            sessions: Vec::new(),\n        }\n    }\n}\n\n/// Summary used in `project list` output.\n#[derive(Debug, Clone)]\npub struct ProjectListEntry {\n    pub id: ProjectId,\n    pub name: String,\n    pub flow: FlowPreset,\n    pub status_summary: ProjectStatusSummary,\n    pub created_at: DateTime<Utc>,\n    pub is_active: bool,\n}\n\n/// Detailed project view used in `project show` output.\n#[derive(Debug, Clone)]\npub struct ProjectDetail {\n    pub record: ProjectRecord,\n    pub run_snapshot: RunSnapshot,\n    pub journal_event_count: u64,\n    pub rollback_count: usize,\n    pub is_active: bool,\n}\n","exit_code":0,"status":"completed"}}
