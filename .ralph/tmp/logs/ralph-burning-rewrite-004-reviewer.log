),\n   459\t                    }\n   460\t                })?;\n   461\t                records.push(record);\n   462\t            }\n   463\t        }\n   464\t\n   465\t        records.sort_by_key(|r| r.created_at);\n   466\t        Ok(records)\n   467\t    }\n   468\t\n   469\t    fn list_artifacts(\n   470\t        &self,\n   471\t        base_dir: &Path,\n   472\t        project_id: &ProjectId,\n   473\t    ) -> AppResult<Vec<ArtifactRecord>> {\n   474\t        let dir = FileSystem::project_root(base_dir, project_id).join(\"history/artifacts\");\n   475\t        if !dir.is_dir() {\n   476\t            return Ok(Vec::new());\n   477\t        }\n   478\t\n   479\t        let mut records = Vec::new();\n   480\t        for entry in fs::read_dir(&dir)? {\n   481\t            let entry = entry?;\n   482\t            let path = entry.path();\n   483\t            if path.extension().is_some_and(|ext| ext == \"json\") {\n   484\t                let raw = fs::read_to_string(&path)?;\n   485\t                let record: ArtifactRecord =\n   486\t                    serde_json::from_str(&raw).map_err(|e| AppError::CorruptRecord {\n   487\t                        file: format!(\n   488\t                            \"history/artifacts/{}\",\n   489\t                            path.file_name()\n   490\t                                .unwrap_or_default()\n   491\t                                .to_string_lossy()\n   492\t                        ),\n   493\t                        details: e.to_string(),\n   494\t                    })?;\n   495\t                records.push(record);\n   496\t            }\n   497\t        }\n   498\t\n   499\t        records.sort_by_key(|r| r.created_at);\n   500\t        Ok(records)\n   501\t    }\n   502\t}\n   503\t\n   504\t/// Filesystem-backed implementation of `RuntimeLogStorePort`.\n   505\tpub struct FsRuntimeLogStore;\n   506\t\n   507\timpl RuntimeLogStorePort for FsRuntimeLogStore {\n   508\t    fn read_runtime_logs(\n   509\t        &self,\n   510\t        base_dir: &Path,\n   511\t        project_id: &ProjectId,\n   512\t    ) -> AppResult<Vec<RuntimeLogEntry>> {\n   513\t        let dir = FileSystem::project_root(base_dir, project_id).join(\"runtime/logs\");\n   514\t        if !dir.is_dir() {\n   515\t            return Ok(Vec::new());\n   516\t        }\n   517\t\n   518\t        let mut entries = Vec::new();\n   519\t        let mut paths: Vec<_> = fs::read_dir(&dir)?\n   520\t            .filter_map(|e| e.ok())\n   521\t            .map(|e| e.path())\n   522\t            .filter(|p| p.extension().is_some_and(|ext| ext == \"ndjson\"))\n   523\t            .collect();\n   524\t        paths.sort();\n   525\t\n   526\t        for path in paths {\n   527\t            let contents = fs::read_to_string(&path)?;\n   528\t            for line in contents.lines() {\n   529\t                let trimmed = line.trim();\n   530\t                if trimmed.is_empty() {\n   531\t                    continue;\n   532\t                }\n   533\t                if let Ok(entry) = serde_json::from_str::<RuntimeLogEntry>(trimmed) {\n   534\t                    entries.push(entry);\n   535\t                }\n   536\t            }\n   537\t        }\n   538\t\n   539\t        Ok(entries)\n   540\t    }\n   541\t}\n   542\t\n   543\t/// Filesystem-backed implementation of `RunSnapshotPort`.\n   544\tpub struct FsRunSnapshotStore;\n   545\t\n   546\timpl RunSnapshotPort for FsRunSnapshotStore {\n   547\t    fn read_run_snapshot(\n   548\t        &self,\n   549\t        base_dir: &Path,\n   550\t        project_id: &ProjectId,\n   551\t    ) -> AppResult<RunSnapshot> {\n   552\t        let path = FileSystem::project_root(base_dir, project_id).join(RUN_FILE);\n   553\t        match fs::read_to_string(&path) {\n   554\t            Ok(raw) => {\n   555\t                let snapshot: RunSnapshot =\n   556\t                    serde_json::from_str(&raw).map_err(|e| AppError::CorruptRecord {\n   557\t                        file: format!(\"projects/{}/run.json\", project_id),\n   558\t                        details: e.to_string(),\n   559\t                    })?;\n   560\t                // Semantic validation: reject inconsistent status/active_run combinations\n   561\t                snapshot\n   562\t                    .validate_semantics()\n   563\t                    .map_err(|details| AppError::CorruptRecord {\n   564\t                        file: format!(\"projects/{}/run.json\", project_id),\n   565\t                        details,\n   566\t                    })?;\n   567\t                Ok(snapshot)\n   568\t            }\n   569\t            Err(e) if e.kind() == std::io::ErrorKind::NotFound => {\n   570\t                Err(AppError::CorruptRecord {\n   571\t                    file: format!(\"projects/{}/run.json\", project_id),\n   572\t                    details: \"canonical file is missing\".to_owned(),\n   573\t                })\n   574\t            }\n   575\t            Err(e) => Err(e.into()),\n   576\t        }\n   577\t    }\n   578\t}\n   579\t\n   580\t/// Filesystem-backed implementation of `ActiveProjectPort`.\n   581\tpub struct FsActiveProjectStore;\n   582\t\n   583\timpl ActiveProjectPort for FsActiveProjectStore {\n   584\t    fn read_active_project_id(&self, base_dir: &Path) -> AppResult<Option<String>> {\n   585\t        FileSystem::read_active_project(&FileSystem::workspace_root_path(base_dir))\n   586\t    }\n   587\t\n   588\t    fn clear_active_project(&self, base_dir: &Path) -> AppResult<()> {\n   589\t        let path = FileSystem::workspace_root_path(base_dir).join(ACTIVE_PROJECT_FILE);\n   590\t        match fs::remove_file(&path) {\n   591\t            Ok(()) => Ok(()),\n   592\t            Err(e) if e.kind() == std::io::ErrorKind::NotFound => Ok(()),\n   593\t            Err(e) => Err(e.into()),\n   594\t        }\n   595\t    }\n   596\t\n   597\t    fn write_active_project(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<()> {\n   598\t        FileSystem::write_active_project(\n   599\t            &FileSystem::workspace_root_path(base_dir),\n   600\t            project_id.as_str(),\n   601\t        )\n   602\t    }\n   603\t}\n   604\t\n","exit_code":0,"status":"completed"}}
