{"type":"item.completed","item":{"id":"item_44","type":"command_execution","command":"/run/current-system/sw/bin/bash -lc \"nl -ba ralph-burning-rewrite/src/contexts/project_run_record/queries.rs | sed -n '1,220p'\"","aggregated_output":"     1\tuse crate::shared::error::AppResult;\n     2\t\n     3\tuse super::model::{\n     4\t    JournalEvent, PayloadRecord, ArtifactRecord, RuntimeLogEntry, RunSnapshot,\n     5\t};\n     6\t\n     7\t/// Read model for `run status`: canonical state only, no inference from artifacts.\n     8\t#[derive(Debug, Clone)]\n     9\tpub struct RunStatusView {\n    10\t    pub project_id: String,\n    11\t    pub status: String,\n    12\t    pub stage: Option<String>,\n    13\t    pub cycle: Option<u32>,\n    14\t    pub completion_round: Option<u32>,\n    15\t    pub summary: String,\n    16\t}\n    17\t\n    18\timpl RunStatusView {\n    19\t    pub fn from_snapshot(project_id: &str, snapshot: &RunSnapshot) -> Self {\n    20\t        match &snapshot.active_run {\n    21\t            Some(active) => Self {\n    22\t                project_id: project_id.to_owned(),\n    23\t                status: format!(\"{:?}\", snapshot.status).to_lowercase(),\n    24\t                stage: Some(active.stage_cursor.stage.as_str().to_owned()),\n    25\t                cycle: Some(active.stage_cursor.cycle),\n    26\t                completion_round: Some(active.stage_cursor.completion_round),\n    27\t                summary: snapshot.status_summary.clone(),\n    28\t            },\n    29\t            None => Self {\n    30\t                project_id: project_id.to_owned(),\n    31\t                status: \"not started\".to_owned(),\n    32\t                stage: None,\n    33\t                cycle: None,\n    34\t                completion_round: None,\n    35\t                summary: snapshot.status_summary.clone(),\n    36\t            },\n    37\t        }\n    38\t    }\n    39\t}\n    40\t\n    41\t/// Read model for `run history`: durable history only (journal + payloads + artifacts).\n    42\t/// Runtime logs never appear here.\n    43\t#[derive(Debug, Clone)]\n    44\tpub struct RunHistoryView {\n    45\t    pub project_id: String,\n    46\t    pub events: Vec<JournalEvent>,\n    47\t    pub payloads: Vec<PayloadRecord>,\n    48\t    pub artifacts: Vec<ArtifactRecord>,\n    49\t}\n    50\t\n    51\t/// Read model for `run tail`: durable history by default, with optional runtime logs.\n    52\t#[derive(Debug, Clone)]\n    53\tpub struct RunTailView {\n    54\t    pub project_id: String,\n    55\t    pub events: Vec<JournalEvent>,\n    56\t    pub payloads: Vec<PayloadRecord>,\n    57\t    pub artifacts: Vec<ArtifactRecord>,\n    58\t    pub runtime_logs: Option<Vec<RuntimeLogEntry>>,\n    59\t}\n    60\t\n    61\t/// Build a status view from canonical run state.\n    62\tpub fn build_status_view(project_id: &str, snapshot: &RunSnapshot) -> RunStatusView {\n    63\t    RunStatusView::from_snapshot(project_id, snapshot)\n    64\t}\n    65\t\n    66\t/// Build a history view from durable records only. No runtime logs.\n    67\tpub fn build_history_view(\n    68\t    project_id: &str,\n    69\t    events: Vec<JournalEvent>,\n    70\t    payloads: Vec<PayloadRecord>,\n    71\t    artifacts: Vec<ArtifactRecord>,\n    72\t) -> RunHistoryView {\n    73\t    RunHistoryView {\n    74\t        project_id: project_id.to_owned(),\n    75\t        events,\n    76\t        payloads,\n    77\t        artifacts,\n    78\t    }\n    79\t}\n    80\t\n    81\t/// Build a tail view: durable history always, runtime logs only when requested.\n    82\tpub fn build_tail_view(\n    83\t    project_id: &str,\n    84\t    events: Vec<JournalEvent>,\n    85\t    payloads: Vec<PayloadRecord>,\n    86\t    artifacts: Vec<ArtifactRecord>,\n    87\t    include_logs: bool,\n    88\t    runtime_logs: Vec<RuntimeLogEntry>,\n    89\t) -> RunTailView {\n    90\t    RunTailView {\n    91\t        project_id: project_id.to_owned(),\n    92\t        events,\n    93\t        payloads,\n    94\t        artifacts,\n    95\t        runtime_logs: if include_logs {\n    96\t            Some(runtime_logs)\n    97\t        } else {\n    98\t            None\n    99\t        },\n   100\t    }\n   101\t}\n   102\t\n   103\t/// Validate that durable history records are consistent: every artifact has a matching payload.\n   104\tpub fn validate_history_consistency(\n   105\t    payloads: &[PayloadRecord],\n   106\t    artifacts: &[ArtifactRecord],\n   107\t) -> AppResult<()> {\n   108\t    for artifact in artifacts {\n   109\t        if !payloads.iter().any(|p| p.payload_id == artifact.payload_id) {\n   110\t            return Err(crate::shared::error::AppError::CorruptRecord {\n   111\t                file: format!(\"history/artifacts/{}\", artifact.artifact_id),\n   112\t                details: format!(\n   113\t                    \"artifact references payload '{}' which does not exist\",\n   114\t                    artifact.payload_id\n   115\t                ),\n   116\t            });\n   117\t        }\n   118\t    }\n   119\t    Ok(())\n   120\t}\n","exit_code":0,"status":"completed"}}
