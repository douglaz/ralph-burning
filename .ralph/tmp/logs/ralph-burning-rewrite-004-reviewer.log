wned(),\n   140\t        stage_id: StageId::Planning,\n   141\t        cycle: 1,\n   142\t        attempt: 1,\n   143\t        created_at: test_timestamp(),\n   144\t        payload: serde_json::json!({}),\n   145\t    }];\n   146\t    let artifacts = vec![ArtifactRecord {\n   147\t        artifact_id: \"a1\".to_owned(),\n   148\t        payload_id: \"p1\".to_owned(),\n   149\t        stage_id: StageId::Planning,\n   150\t        created_at: test_timestamp(),\n   151\t        content: \"# Planning\".to_owned(),\n   152\t    }];\n   153\t\n   154\t    assert!(queries::validate_history_consistency(&payloads, &artifacts).is_ok());\n   155\t}\n   156\t\n   157\t#[test]\n   158\tfn validate_history_consistency_fails_with_orphaned_artifact() {\n   159\t    let payloads = vec![];\n   160\t    let artifacts = vec![ArtifactRecord {\n   161\t        artifact_id: \"a1\".to_owned(),\n   162\t        payload_id: \"p-missing\".to_owned(),\n   163\t        stage_id: StageId::Planning,\n   164\t        created_at: test_timestamp(),\n   165\t        content: \"# Planning\".to_owned(),\n   166\t    }];\n   167\t\n   168\t    let result = queries::validate_history_consistency(&payloads, &artifacts);\n   169\t    assert!(matches!(\n   170\t        result.unwrap_err(),\n   171\t        AppError::CorruptRecord { .. }\n   172\t    ));\n   173\t}\n   174\t\n   175\t#[test]\n   176\tfn validate_history_consistency_passes_with_no_records() {\n   177\t    assert!(queries::validate_history_consistency(&[], &[]).is_ok());\n   178\t}\n   179\t\n   180\t// ── Orphaned Payload Detection ──\n   181\t\n   182\t#[test]\n   183\tfn validate_history_consistency_fails_with_orphaned_payload() {\n   184\t    let payloads = vec![PayloadRecord {\n   185\t        payload_id: \"p-orphan\".to_owned(),\n   186\t        stage_id: StageId::Planning,\n   187\t        cycle: 1,\n   188\t        attempt: 1,\n   189\t        created_at: test_timestamp(),\n   190\t        payload: serde_json::json!({}),\n   191\t    }];\n   192\t    let artifacts = vec![];\n   193\t\n   194\t    let result = queries::validate_history_consistency(&payloads, &artifacts);\n   195\t    assert!(result.is_err());\n   196\t    let err = result.unwrap_err();\n   197\t    assert!(matches!(err, AppError::CorruptRecord { .. }));\n   198\t    match err {\n   199\t        AppError::CorruptRecord { details, .. } => {\n   200\t            assert!(details.contains(\"no matching artifact\"));\n   201\t        }\n   202\t        _ => panic!(\"expected CorruptRecord\"),\n   203\t    }\n   204\t}\n   205\t\n   206\t// ── RunSnapshot Schema Completeness ──\n   207\t\n   208\t#[test]\n   209\tfn run_snapshot_initial_includes_all_canonical_fields() {\n   210\t    let snapshot = RunSnapshot::initial();\n   211\t    let json = serde_json::to_string_pretty(&snapshot).expect(\"serialize\");\n   212\t\n   213\t    // Verify all canonical fields are present in the serialized form\n   214\t    assert!(json.contains(\"\\\"active_run\\\"\"));\n   215\t    assert!(json.contains(\"\\\"status\\\"\"));\n   216\t    assert!(json.contains(\"\\\"cycle_history\\\"\"));\n   217\t    assert!(json.contains(\"\\\"completion_rounds\\\"\"));\n   218\t    assert!(json.contains(\"\\\"rollback_point_meta\\\"\"));\n   219\t    assert!(json.contains(\"\\\"amendment_queue\\\"\"));\n   220\t    assert!(json.contains(\"\\\"status_summary\\\"\"));\n   221\t}\n   222\t\n   223\t#[test]\n   224\tfn run_snapshot_round_trips_through_json() {\n   225\t    let snapshot = RunSnapshot::initial();\n   226\t    let json = serde_json::to_string(&snapshot).expect(\"serialize\");\n   227\t    let parsed: RunSnapshot = serde_json::from_str(&json).expect(\"deserialize\");\n   228\t    assert_eq!(snapshot, parsed);\n   229\t}\n   230\t\n   231\t// ── Runtime Log Separation ──\n   232\t\n   233\t#[test]\n   234\tfn runtime_logs_never_appear_in_history_view() {\n   235\t    // History view has no field for runtime logs - enforced by type system.\n   236\t    let view