    43\t    assert_eq!(view.summary, \"completed after 3 rounds\");\n    44\t}\n    45\t\n    46\t#[test]\n    47\tfn status_view_reports_failed_terminal_state_without_active_run() {\n    48\t    let snapshot = RunSnapshot {\n    49\t        active_run: None,\n    50\t        status: RunStatus::Failed,\n    51\t        cycle_history: Vec::new(),\n    52\t        completion_rounds: 0,\n    53\t        rollback_point_meta: RollbackPointMeta::default(),\n    54\t        amendment_queue: AmendmentQueueState::default(),\n    55\t        status_summary: \"failed at implementation\".to_owned(),\n    56\t    };\n    57\t    let view = queries::build_status_view(\"alpha\", &snapshot);\n    58\t\n    59\t    assert_eq!(view.status, \"failed\");\n    60\t    assert_eq!(view.summary, \"failed at implementation\");\n    61\t}\n    62\t\n    63\t#[test]\n    64\tfn status_view_reports_running_with_cursor() {\n    65\t    let snapshot = RunSnapshot {\n    66\t        active_run: Some(ActiveRun {\n    67\t            run_id: \"run-1\".to_owned(),\n    68\t            stage_cursor: StageCursor::initial(StageId::Planning),\n    69\t            started_at: test_timestamp(),\n    70\t        }),\n    71\t        status: RunStatus::Running,\n    72\t        cycle_history: Vec::new(),\n    73\t        completion_rounds: 0,\n    74\t        rollback_point_meta: RollbackPointMeta::default(),\n    75\t        amendment_queue: AmendmentQueueState::default(),\n    76\t        status_summary: \"running at planning\".to_owned(),\n    77\t    };\n    78\t    let view = queries::build_status_view(\"alpha\", &snapshot);\n    79\t\n    80\t    assert_eq!(view.status, \"running\");\n    81\t    assert_eq!(view.stage, Some(\"planning\".to_owned()));\n    82\t    assert_eq!(view.cycle, Some(1));\n    83\t    assert_eq!(view.completion_round, Some(1));\n    84\t}\n    85\t\n    86\t// ── RunHistoryView ──\n    87\t\n    88\t#[test]\n    89\tfn history_view_contains_only_durable_records() {\n    90\t   