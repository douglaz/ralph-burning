{"type":"item.completed","item":{"id":"item_49","type":"command_execution","command":"/run/current-system/sw/bin/bash -lc \"nl -ba ralph-burning-rewrite/src/adapters/fs.rs | sed -n '180,280p'\"","aggregated_output":"   180\t        })?;\n   181\t        fs::create_dir_all(parent)?;\n   182\t\n   183\t        let mut file = OpenOptions::new()\n   184\t            .create(true)\n   185\t            .append(true)\n   186\t            .open(path)?;\n   187\t        writeln!(file, \"{}\", line)?;\n   188\t        file.sync_all()?;\n   189\t        Ok(())\n   190\t    }\n   191\t}\n   192\t\n   193\t/// Filesystem-backed implementation of `ProjectStorePort`.\n   194\tpub struct FsProjectStore;\n   195\t\n   196\timpl ProjectStorePort for FsProjectStore {\n   197\t    fn project_exists(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<bool> {\n   198\t        let project_root = FileSystem::project_root(base_dir, project_id);\n   199\t        Ok(project_root.is_dir() && project_root.join(PROJECT_CONFIG_FILE).is_file())\n   200\t    }\n   201\t\n   202\t    fn read_project_record(\n   203\t        &self,\n   204\t        base_dir: &Path,\n   205\t        project_id: &ProjectId,\n   206\t    ) -> AppResult<ProjectRecord> {\n   207\t        let path = FileSystem::project_root(base_dir, project_id).join(PROJECT_CONFIG_FILE);\n   208\t        let raw = fs::read_to_string(&path).map_err(|e| {\n   209\t            if e.kind() == std::io::ErrorKind::NotFound {\n   210\t                AppError::ProjectNotFound {\n   211\t                    project_id: project_id.to_string(),\n   212\t                }\n   213\t            } else {\n   214\t                e.into()\n   215\t            }\n   216\t        })?;\n   217\t        toml::from_str(&raw).map_err(|e| AppError::CorruptRecord {\n   218\t            file: format!(\"projects/{}/project.toml\", project_id),\n   219\t            details: e.to_string(),\n   220\t        })\n   221\t    }\n   222\t\n   223\t    fn list_project_ids(&self, base_dir: &Path) -> AppResult<Vec<ProjectId>> {\n   224\t        let projects_dir = FileSystem::workspace_root_path(base_dir).join(PROJECTS_DIR);\n   225\t        if !projects_dir.is_dir() {\n   226\t            return Ok(Vec::new());\n   227\t        }\n   228\t\n   229\t        let mut ids = Vec::new();\n   230\t        for entry in fs::read_dir(&projects_dir)? {\n   231\t            let entry = entry?;\n   232\t            if !entry.file_type()?.is_dir() {\n   233\t                continue;\n   234\t            }\n   235\t            let name = entry.file_name();\n   236\t            let name_str = name.to_string_lossy();\n   237\t            // Only include projects that have a valid project.toml\n   238\t            if entry.path().join(PROJECT_CONFIG_FILE).is_file() {\n   239\t                if let Ok(pid) = ProjectId::new(name_str.as_ref()) {\n   240\t                    ids.push(pid);\n   241\t                }\n   242\t            }\n   243\t        }\n   244\t\n   245\t        ids.sort_by(|a, b| a.as_str().cmp(b.as_str()));\n   246\t        Ok(ids)\n   247\t    }\n   248\t\n   249\t    fn delete_project(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<()> {\n   250\t        let project_root = FileSystem::project_root(base_dir, project_id);\n   251\t        if !project_root.is_dir() {\n   252\t            return Err(AppError::ProjectNotFound {\n   253\t                project_id: project_id.to_string(),\n   254\t            });\n   255\t        }\n   256\t        fs::remove_dir_all(&project_root)?;\n   257\t        Ok(())\n   258\t    }\n   259\t\n   260\t    fn create_project_atomic(\n   261\t        &self,\n   262\t        base_dir: &Path,\n   263\t        record: &ProjectRecord,\n   264\t        prompt_contents: &str,\n   265\t        run_snapshot: &RunSnapshot,\n   266\t        initial_journal_line: &str,\n   267\t        sessions: &SessionStore,\n   268\t    ) -> AppResult<()> {\n   269\t        let project_root = FileSystem::project_root(base_dir, &record.id);\n   270\t\n   271\t        // Stage into a temporary directory alongside the final location\n   272\t        let staging_name = format!(\".{}.staging.{}\", record.id, std::process::id());\n   273\t        let staging_root = project_root\n   274\t            .parent()\n   275\t            .expect(\"project root has parent\")\n   276\t            .join(&staging_name);\n   277\t\n   278\t        // Clean up any leftover staging dir\n   279\t        if staging_root.exists() {\n   280\t            fs::remove_dir_all(&staging_root)?;\n","exit_code":0,"status":"completed"}}
