{"type":"item.completed","item":{"id":"item_25","type":"command_execution","command":"/run/current-system/sw/bin/bash -lc \"nl -ba /root/new-ralph-burning/ralph-burning-rewrite/tests/unit/project_run_record_test.rs | sed -n '1,420p'\"","aggregated_output":"     1\tuse std::path::Path;\n     2\t\n     3\tuse chrono::{TimeZone, Utc};\n     4\t\n     5\tuse ralph_burning::contexts::project_run_record::model::*;\n     6\tuse ralph_burning::contexts::project_run_record::service::*;\n     7\tuse ralph_burning::shared::domain::{FlowPreset, ProjectId};\n     8\tuse ralph_burning::shared::error::{AppError, AppResult};\n     9\t\n    10\t// ── Fake implementations of ports for service-level testing ──\n    11\t\n    12\tstruct FakeProjectStore {\n    13\t    existing_ids: Vec<String>,\n    14\t}\n    15\t\n    16\timpl FakeProjectStore {\n    17\t    fn empty() -> Self {\n    18\t        Self {\n    19\t            existing_ids: Vec::new(),\n    20\t        }\n    21\t    }\n    22\t\n    23\t    fn with_existing(ids: &[&str]) -> Self {\n    24\t        Self {\n    25\t            existing_ids: ids.iter().map(|s| s.to_string()).collect(),\n    26\t        }\n    27\t    }\n    28\t}\n    29\t\n    30\timpl ProjectStorePort for FakeProjectStore {\n    31\t    fn project_exists(&self, _base_dir: &Path, project_id: &ProjectId) -> AppResult<bool> {\n    32\t        Ok(self.existing_ids.contains(&project_id.to_string()))\n    33\t    }\n    34\t\n    35\t    fn read_project_record(\n    36\t        &self,\n    37\t        _base_dir: &Path,\n    38\t        project_id: &ProjectId,\n    39\t    ) -> AppResult<ProjectRecord> {\n    40\t        if !self.existing_ids.contains(&project_id.to_string()) {\n    41\t            return Err(AppError::ProjectNotFound {\n    42\t                project_id: project_id.to_string(),\n    43\t            });\n    44\t        }\n    45\t        Ok(make_project_record(project_id.as_str()))\n    46\t    }\n    47\t\n    48\t    fn list_project_ids(&self, _base_dir: &Path) -> AppResult<Vec<ProjectId>> {\n    49\t        self.existing_ids\n    50\t            .iter()\n    51\t            .map(|id| ProjectId::new(id.as_str()))\n    52\t            .collect()\n    53\t    }\n    54\t\n    55\t    fn delete_project(&self, _base_dir: &Path, project_id: &ProjectId) -> AppResult<()> {\n    56\t        if !self.existing_ids.contains(&project_id.to_string()) {\n    57\t            return Err(AppError::ProjectNotFound {\n    58\t                project_id: project_id.to_string(),\n    59\t            });\n    60\t        }\n    61\t        Ok(())\n    62\t    }\n    63\t\n    64\t    fn create_project_atomic(\n    65\t        &self,\n    66\t        _base_dir: &Path,\n    67\t        _record: &ProjectRecord,\n    68\t        _prompt_contents: &str,\n    69\t        _run_snapshot: &RunSnapshot,\n    70\t        _initial_journal_line: &str,\n    71\t        _sessions: &SessionStore,\n    72\t    ) -> AppResult<()> {\n    73\t        Ok(())\n    74\t    }\n    75\t}\n    76\t\n    77\tstruct FakeJournalStore;\n    78\t\n    79\timpl JournalStorePort for FakeJournalStore {\n    80\t    fn read_journal(\n    81\t        &self,\n    82\t        _base_dir: &Path,\n    83\t        _project_id: &ProjectId,\n    84\t    ) -> AppResult<Vec<JournalEvent>> {\n    85\t        Ok(vec![make_project_created_event()])\n    86\t    }\n    87\t\n    88\t    fn append_event(\n    89\t        &self,\n    90\t        _base_dir: &Path,\n    91\t        _project_id: &ProjectId,\n    92\t        _line: &str,\n    93\t    ) -> AppResult<()> {\n    94\t        Ok(())\n    95\t    }\n    96\t}\n    97\t\n    98\tstruct FakeRunSnapshotStore {\n    99\t    has_active_run: bool,\n   100\t}\n   101\t\n   102\timpl FakeRunSnapshotStore {\n   103\t    fn no_run() -> Self {\n   104\t        Self {\n   105\t            has_active_run: false,\n   106\t        }\n   107\t    }\n   108\t\n   109\t    fn active_run() -> Self {\n   110\t        Self {\n   111\t            has_active_run: true,\n   112\t        }\n   113\t    }\n   114\t}\n   115\t\n   116\timpl RunSnapshotPort for FakeRunSnapshotStore {\n   117\t    fn read_run_snapshot(\n   118\t        &self,\n   119\t        _base_dir: &Path,\n   120\t        _project_id: &ProjectId,\n   121\t    ) -> AppResult<RunSnapshot> {\n   122\t        if self.has_active_run {\n   123\t            Ok(RunSnapshot {\n   124\t                active_run: Some(ActiveRun {\n   125\t                    run_id: \"run-1\".to_owned(),\n   126\t                    stage_cursor: ralph_burning::shared::domain::StageCursor::initial(\n   127\t                        ralph_burning::shared::domain::StageId::Planning,\n   128\t                    ),\n   129\t                    started_at: test_timestamp(),\n   130\t                }),\n   131\t                status: RunStatus::Running,\n   132\t                cycle_history: Vec::new(),\n   133\t                completion_rounds: 0,\n   134\t                rollback_point_meta: RollbackPointMeta::default(),\n   135\t                amendment_queue: AmendmentQueueState::default(),\n   136\t                status_summary: \"running\".to_owned(),\n   137\t            })\n   138\t        } else {\n   139\t            Ok(RunSnapshot::initial())\n   140\t        }\n   141\t    }\n   142\t}\n   143\t\n   144\tstruct FakeActiveProjectStore {\n   145\t    active_id: Option<String>,\n   146\t}\n   147\t\n   148\timpl FakeActiveProjectStore {\n   149\t    fn none() -> Self {\n   150\t        Self { active_id: None }\n   151\t    }\n   152\t\n   153\t    fn with_active(id: &str) -> Self {\n   154\t        Self {\n   155\t            active_id: Some(id.to_owned()),\n   156\t        }\n   157\t    }\n   158\t}\n   159\t\n   160\timpl ActiveProjectPort for FakeActiveProjectStore {\n   161\t    fn read_active_project_id(&self, _base_dir: &Path) -> AppResult<Option<String>> {\n   162\t        Ok(self.active_id.clone())\n   163\t    }\n   164\t\n   165\t    fn clear_active_project(&self, _base_dir: &Path) -> AppResult<()> {\n   166\t        Ok(())\n   167\t    }\n   168\t}\n   169\t\n   170\t// ── Helpers ──\n   171\t\n   172\tfn test_timestamp() -> chrono::DateTime<Utc> {\n   173\t    Utc.with_ymd_and_hms(2026, 3, 11, 19, 0, 0)\n   174\t        .single()\n   175\t        .expect(\"valid timestamp\")\n   176\t}\n   177\t\n   178\tfn make_project_record(id: &str) -> ProjectRecord {\n   179\t    ProjectRecord {\n   180\t        id: ProjectId::new(id).unwrap(),\n   181\t        name: format!(\"Project {id}\"),\n   182\t        flow: FlowPreset::Standard,\n   183\t        prompt_reference: \"prompt.md\".to_owned(),\n   184\t        prompt_hash: \"abc123\".to_owned(),\n   185\t        created_at: test_timestamp(),\n   186\t        status_summary: ProjectStatusSummary::Created,\n   187\t    }\n   188\t}\n   189\t\n   190\tfn make_project_created_event() -> JournalEvent {\n   191\t    JournalEvent {\n   192\t        sequence: 1,\n   193\t        timestamp: test_timestamp(),\n   194\t        event_type: JournalEventType::ProjectCreated,\n   195\t        details: serde_json::json!({\"project_id\": \"alpha\", \"flow\": \"standard\"}),\n   196\t    }\n   197\t}\n   198\t\n   199\tfn dummy_base_dir() -> std::path::PathBuf {\n   200\t    std::path::PathBuf::from(\"/tmp/test\")\n   201\t}\n   202\t\n   203\t// ── Domain Tests ──\n   204\t\n   205\t#[test]\n   206\tfn run_snapshot_initial_has_no_active_run() {\n   207\t    let snapshot = RunSnapshot::initial();\n   208\t    assert!(!snapshot.has_active_run());\n   209\t    assert_eq!(snapshot.status, RunStatus::NotStarted);\n   210\t}\n   211\t\n   212\t#[test]\n   213\tfn session_store_empty_has_no_sessions() {\n   214\t    let store = SessionStore::empty();\n   215\t    assert!(store.sessions.is_empty());\n   216\t}\n   217\t\n   218\t#[test]\n   219\tfn project_record_flow_is_immutable_after_creation() {\n   220\t    let record = make_project_record(\"alpha\");\n   221\t    assert_eq!(record.flow, FlowPreset::Standard);\n   222\t    // Flow is a plain field with no setter — immutability enforced by\n   223\t    // not providing mutation methods on ProjectRecord.\n   224\t}\n   225\t\n   226\t#[test]\n   227\tfn journal_event_types_serialize_to_snake_case() {\n   228\t    let event = make_project_created_event();\n   229\t    let json = serde_json::to_string(&event).expect(\"serialize\");\n   230\t    assert!(json.contains(\"\\\"project_created\\\"\"));\n   231\t}\n   232\t\n   233\t// ── Service Tests with Fake Ports ──\n   234\t\n   235\t#[test]\n   236\tfn create_project_succeeds_with_valid_input() {\n   237\t    let store = FakeProjectStore::empty();\n   238\t    let journal_store = FakeJournalStore;\n   239\t    let base_dir = dummy_base_dir();\n   240\t\n   241\t    let input = CreateProjectInput {\n   242\t        id: ProjectId::new(\"alpha\").unwrap(),\n   243\t        name: \"Alpha Project\".to_owned(),\n   244\t        flow: FlowPreset::Standard,\n   245\t        prompt_path: \"prompt.md\".to_owned(),\n   246\t        prompt_contents: \"# My prompt\\nDo something.\".to_owned(),\n   247\t        prompt_hash: \"hash123\".to_owned(),\n   248\t        created_at: test_timestamp(),\n   249\t    };\n   250\t\n   251\t    let result = create_project(&store, &journal_store, &base_dir, input);\n   252\t    assert!(result.is_ok());\n   253\t\n   254\t    let record = result.unwrap();\n   255\t    assert_eq!(record.id.as_str(), \"alpha\");\n   256\t    assert_eq!(record.flow, FlowPreset::Standard);\n   257\t    assert_eq!(record.status_summary, ProjectStatusSummary::Created);\n   258\t}\n   259\t\n   260\t#[test]\n   261\tfn create_project_fails_on_duplicate_id() {\n   262\t    let store = FakeProjectStore::with_existing(&[\"alpha\"]);\n   263\t    let journal_store = FakeJournalStore;\n   264\t    let base_dir = dummy_base_dir();\n   265\t\n   266\t    let input = CreateProjectInput {\n   267\t        id: ProjectId::new(\"alpha\").unwrap(),\n   268\t        name: \"Alpha Again\".to_owned(),\n   269\t        flow: FlowPreset::Standard,\n   270\t        prompt_path: \"prompt.md\".to_owned(),\n   271\t        prompt_contents: \"content\".to_owned(),\n   272\t        prompt_hash: \"hash\".to_owned(),\n   273\t        created_at: test_timestamp(),\n   274\t    };\n   275\t\n   276\t    let result = create_project(&store, &journal_store, &base_dir, input);\n   277\t    assert!(result.is_err());\n   278\t    assert!(matches!(\n   279\t        result.unwrap_err(),\n   280\t        AppError::DuplicateProject { .. }\n   281\t    ));\n   282\t}\n   283\t\n   284\t#[test]\n   285\tfn list_projects_returns_entries_with_active_flag() {\n   286\t    let store = FakeProjectStore::with_existing(&[\"alpha\", \"beta\"]);\n   287\t    let active_store = FakeActiveProjectStore::with_active(\"alpha\");\n   288\t    let base_dir = dummy_base_dir();\n   289\t\n   290\t    let entries = list_projects(&store, &active_store, &base_dir).unwrap();\n   291\t    assert_eq!(entries.len(), 2);\n   292\t\n   293\t    let alpha = entries.iter().find(|e| e.id.as_str() == \"alpha\").unwrap();\n   294\t    assert!(alpha.is_active);\n   295\t\n   296\t    let beta = entries.iter().find(|e| e.id.as_str() == \"beta\").unwrap();\n   297\t    assert!(!beta.is_active);\n   298\t}\n   299\t\n   300\t#[test]\n   301\tfn list_projects_with_no_active_project() {\n   302\t    let store = FakeProjectStore::with_existing(&[\"alpha\"]);\n   303\t    let active_store = FakeActiveProjectStore::none();\n   304\t    let base_dir = dummy_base_dir();\n   305\t\n   306\t    let entries = list_projects(&store, &active_store, &base_dir).unwrap();\n   307\t    assert_eq!(entries.len(), 1);\n   308\t    assert!(!entries[0].is_active);\n   309\t}\n   310\t\n   311\t#[test]\n   312\tfn show_project_returns_detail() {\n   313\t    let store = FakeProjectStore::with_existing(&[\"alpha\"]);\n   314\t    let run_store = FakeRunSnapshotStore::no_run();\n   315\t    let journal_store = FakeJournalStore;\n   316\t    let active_store = FakeActiveProjectStore::with_active(\"alpha\");\n   317\t    let base_dir = dummy_base_dir();\n   318\t    let pid = ProjectId::new(\"alpha\").unwrap();\n   319\t\n   320\t    let detail =\n   321\t        show_project(&store, &run_store, &journal_store, &active_store, &base_dir, &pid).unwrap();\n   322\t\n   323\t    assert_eq!(detail.record.id.as_str(), \"alpha\");\n   324\t    assert!(detail.is_active);\n   325\t    assert_eq!(detail.journal_event_count, 1);\n   326\t    assert!(!detail.run_snapshot.has_active_run());\n   327\t}\n   328\t\n   329\t#[test]\n   330\tfn show_project_fails_for_missing_project() {\n   331\t    let store = FakeProjectStore::empty();\n   332\t    let run_store = FakeRunSnapshotStore::no_run();\n   333\t    let journal_store = FakeJournalStore;\n   334\t    let active_store = FakeActiveProjectStore::none();\n   335\t    let base_dir = dummy_base_dir();\n   336\t    let pid = ProjectId::new(\"missing\").unwrap();\n   337\t\n   338\t    let result =\n   339\t        show_project(&store, &run_store, &journal_store, &active_store, &base_dir, &pid);\n   340\t    assert!(matches!(\n   341\t        result.unwrap_err(),\n   342\t        AppError::ProjectNotFound { .. }\n   343\t    ));\n   344\t}\n   345\t\n   346\t#[test]\n   347\tfn delete_project_succeeds_when_no_active_run() {\n   348\t    let store = FakeProjectStore::with_existing(&[\"alpha\"]);\n   349\t    let run_store = FakeRunSnapshotStore::no_run();\n   350\t    let active_store = FakeActiveProjectStore::none();\n   351\t    let base_dir = dummy_base_dir();\n   352\t    let pid = ProjectId::new(\"alpha\").unwrap();\n   353\t\n   354\t    let result = delete_project(&store, &run_store, &active_store, &base_dir, &pid);\n   355\t    assert!(result.is_ok());\n   356\t}\n   357\t\n   358\t#[test]\n   359\tfn delete_project_fails_with_active_run() {\n   360\t    let store = FakeProjectStore::with_existing(&[\"alpha\"]);\n   361\t    let run_store = FakeRunSnapshotStore::active_run();\n   362\t    let active_store = FakeActiveProjectStore::none();\n   363\t    let base_dir = dummy_base_dir();\n   364\t    let pid = ProjectId::new(\"alpha\").unwrap();\n   365\t\n   366\t    let result = delete_project(&store, &run_store, &active_store, &base_dir, &pid);\n   367\t    assert!(matches!(\n   368\t        result.unwrap_err(),\n   369\t        AppError::ActiveRunDelete { .. }\n   370\t    ));\n   371\t}\n   372\t\n   373\t#[test]\n   374\tfn delete_project_fails_for_missing_project() {\n   375\t    let store = FakeProjectStore::empty();\n   376\t    let run_store = FakeRunSnapshotStore::no_run();\n   377\t    let active_store = FakeActiveProjectStore::none();\n   378\t    let base_dir = dummy_base_dir();\n   379\t    let pid = ProjectId::new(\"missing\").unwrap();\n   380\t\n   381\t    let result = delete_project(&store, &run_store, &active_store, &base_dir, &pid);\n   382\t    assert!(matches!(\n   383\t        result.unwrap_err(),\n   384\t        AppError::ProjectNotFound { .. }\n   385\t    ));\n   386\t}\n   387\t\n   388\t#[test]\n   389\tfn run_status_reports_not_started_when_no_active_run() {\n   390\t    let run_store = FakeRunSnapshotStore::no_run();\n   391\t    let base_dir = dummy_base_dir();\n   392\t    let pid = ProjectId::new(\"alpha\").unwrap();\n   393\t\n   394\t    let status = run_status(&run_store, &base_dir, &pid).unwrap();\n   395\t    assert_eq!(status.status, \"not started\");\n   396\t    assert!(status.stage.is_none());\n   397\t    assert!(status.cycle.is_none());\n   398\t}\n   399\t\n   400\t#[test]\n   401\tfn run_status_reports_running_with_stage_cursor() {\n   402\t    let run_store = FakeRunSnapshotStore::active_run();\n   403\t    let base_dir = dummy_base_dir();\n   404\t    let pid = ProjectId::new(\"alpha\").unwrap();\n   405\t\n   406\t    let status = run_status(&run_store, &base_dir, &pid).unwrap();\n   407\t    assert_eq!(status.status, \"running\");\n   408\t    assert_eq!(status.stage, Some(\"planning\".to_owned()));\n   409\t    assert_eq!(status.cycle, Some(1));\n   410\t}\n   411\t\n   412\t// ── Semantic Validation ──\n   413\t\n   414\t#[test]\n   415\tfn run_snapshot_validates_running_without_active_run_as_corrupt() {\n   416\t    let snapshot = RunSnapshot {\n   417\t        active_run: None,\n   418\t        status: RunStatus::Running,\n   419\t        cycle_history: Vec::new(),\n   420\t        completion_rounds: 0,\n","exit_code":0,"status":"completed"}}
