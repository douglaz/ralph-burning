\n  1145\t    let completed_snapshot = r#\"{\n  1146\t  \"active_run\": null,\n  1147\t  \"status\": \"completed\",\n  1148\t  \"cycle_history\": [],\n  1149\t  \"completion_rounds\": 3,\n  1150\t  \"rollback_point_meta\": { \"last_rollback_id\": null, \"rollback_count\": 0 },\n  1151\t  \"amendment_queue\": { \"pending\": [], \"processed_count\": 0 },\n  1152\t  \"status_summary\": \"completed after 3 rounds\"\n  1153\t}\"#;\n  1154\t    fs::write(\n  1155\t        temp_dir.path().join(\".ralph-burning/projects/terminal/run.json\"),\n  1156\t        completed_snapshot,\n  1157\t    )\n  1158\t    .expect(\"write completed snapshot\");\n  1159\t\n  1160\t    let output = Command::new(binary())\n  1161\t        .args([\"run\", \"status\"])\n  1162\t        .current_dir(temp_dir.path())\n  1163\t        .output()\n  1164\t        .expect(\"run status\");\n  1165\t\n  1166\t    assert!(output.status.success());\n  1167\t    let stdout = String::from_utf8_lossy(&output.stdout);\n  1168\t    assert!(stdout.contains(\"Status: completed\"));\n  1169\t    assert!(stdout.contains(\"completed after 3 rounds\"));\n  1170\t}\n  1171\t\n  1172\t#[test]\n  1173\tfn run_status_fails_for_semantically_inconsistent_snapshot() {\n  1174\t    let temp_dir = initialize_workspace_fixture();\n  1175\t    let prompt = write_prompt_fixture(temp_dir.path());\n  1176\t\n  1177\t    Command::new(binary())\n  1178\t        .args([\n  1179\t            \"project\", \"create\",\n  1180\t            \"--id\", \"inconsist\",\n  1181\t            \"--name\", \"Inconsistent\",\n  1182\t            \"--prompt\", prompt.to_str().unwrap(),\n  1183\t            \"--flow\", \"standard\",\n  1184\t        ])\n  1185\t        .current_dir(temp_dir.path())\n  1186\t        .output()\n  1187\t        .expect(\"create project\");\n  1188\t\n  1189\t    Command::new(binary())\n  1190\t        .args([\"project\", \"select\", \"inconsist\"])\n  1191\t        .current_dir(temp_dir.path())\n  1192\t        .output()\n  1193\t        .expect(\"select project\");\n  1194\t\n  1195\t    // Write a semantically inconsistent snapshot: running with no active_run\n  1196\t    let bad_snapshot = r#\"{\n  1197\t  \"active_run\": null,\n  1198\t  \"status\": \"running\",\n  1199\t  \"cycle_history\": [],\n  1200\t  \"completion_rounds\": 0,\n  1201\t  \"rollback_point_meta\": { \"last_rollback_id\": null, \"rollback_count\": 0 },\n  1202\t  \"amendment_queue\": { \"pending\": [], \"processed_count\": 0 },\n  1203\t  \"status_summary\": \"running\"\n  1204\t}\"#;\n  1205\t    fs::write(\n  1206\t        temp_dir.path().join(\".ralph-burning/projects/inconsist/run.json\"),\n  1207\t        bad_snapshot,\n  1208\t    )\n  1209\t    .expect(\"write inconsistent snapshot\");\n  1210\t\n  1211\t    let output = Command::new(binary())\n  1212\t        .args([\"run\", \"status\"])\n  1213\t        .current_dir(temp_dir.path())\n  1214\t        .output()\n  1215\t        .expect(\"run status\");\n  1216\t\n  1217\t    assert!(!output.status.success());\n  1218\t    let stderr = String::from_utf8_lossy(&output.stderr);\n  1219\t    assert!(stderr.contains(\"run.json\"));\n  1220\t    assert!(stderr.contains(\"inconsistent\"));\n  1221\t}\n  1222\t\n  1223\t#[test]\n  1224\tfn project_delete_fails_for_semantically_inconsistent_active_run() {\n  1225\t    let temp_dir = initialize_workspace_fixture();\n  1226\t    let prompt = write_prompt_fixture(temp_dir.path());\n  1227\t\n  1228\t    Command::new(binary())\n  1229\t        .args([\n  1230\t            \"project\", \"create\",\n  1231\t            \"--id\", \"bad-state\",\n  1232\t            \"--name\", \"Bad State\",\n  1233\t            \"--prompt\", prompt.to_str().unwrap(),\n  1234\t            \"--flow\", \"standard\",\n  1235\t        ])\n  1236\t        .current_dir(temp_dir.path())\n  1237\t        .output()\n  1238\t        .expect(\"create project\");\n  1239\t\n  1240\t    // Write a semantically inconsistent snapshot: paused with no active_run\n  1241\t    let bad_snapshot = r#\"{\n  1242\t  \"active_run\": null,\n  1243\t  \"status\": \"paused\",\n  1244\t  \"cycle_history\": [],\n  1245\t  \"completion_rounds\": 0,\n  1246\t  \"rollback_point_meta\": { \"last_rollback_id\": null, \"rollback_count\": 0 },\n  1247\t  \"amendment_queue\": { \"pending\": [], \"processed_count\": 0 },\n  1248\t  \"status_summary\": \"paused\"\n  1249\t}\"#;\n  1250\t    fs::write(\n  1251\t        temp_dir.path().join(\".ralph-burning/projects/bad-state/run.json\"),\n  1252\t        bad_snapshot,\n  1253\t    )\n  1254\t    .expect(\"write inconsistent snapshot\");\n  1255\t\n  1256\t    let output = Command::new(binary())\n  1257\t        .args([\"project\", \"delete\", \"bad-state\"])\n  1258\t        .current_dir(temp_dir.path())\n  1259\t        .output()\n  1260\t        .expect(\"run project delete\");\n  1261\t\n  1262\t    assert!(!output.status.success());\n  1263\t    let stderr = String::from_utf8_lossy(&output.stderr);\n  1264\t    assert!(stderr.contains(\"run.json\"));\n  1265\t    assert!(stderr.contains(\"inconsistent\"));\n  1266\t}\n  1267\t\n  1268\t// ── Run.json schema completeness ──\n  1269\t\n  1270\t#[test]\n  1271\tfn project_create_run_json_contains_all_canonical_fields() {\n  1272\t    let temp_dir = initialize_workspace_fixture();\n  1273\t    let prompt = write_prompt_fixture(temp_dir.path());\n  1274\t\n  1275\t    Command::new(binary())\n  1276\t        .args([\n  1277\t            \"project\", \"create\",\n  1278\t            \"--id\", \"schema\",\n  1279\t            \"--name\", \"Schema Check\",\n  1280\t            \"--prompt\", prompt.to_str().unwrap(),\n  1281\t            \"--flow\", \"standard\",\n  1282\t        ])\n  1283\t        .current_dir(temp_dir.path())\n  1284\t        .output()\n  1285\t        .expect(\"create project\");\n  1286\t\n  1287\t    let run_json = fs::read_to_string(\n  1288\t        temp_dir.path().join(\".ralph-burning/projects/schema/run.json\"),\n  1289\t    )\n  1290\t    .expect(\"read run.json\");\n  1291\t\n  1292\t    assert!(run_json.contains(\"\\\"cycle_history\\\"\"));\n  1293\t    assert!(run_json.contains(\"\\\"completion_rounds\\\"\"));\n  1294\t    assert!(run_json.contains(\"\\\"rollback_point_meta\\\"\"));\n  1295\t    assert!(run_json.contains(\"\\\"amendment_queue\\\"\"));\n  1296\t    assert!(run_json.contains(\"\\\"active_run\\\"\"));\n  1297\t    assert!(run_json.contains(\"\\\"status\\\"\"));\n  1298\t    assert!(run_json.contains(\"\\\"status_summary\\\"\"));\n  1299\t}\n","exit_code":0,"status":"completed"}}
