nce_rejects_duplicate() {\n    49\t    let event = make_event(2, JournalEventType::CycleAdvanced);\n    50\t    let result = journal::validate_sequence(2, &event);\n    51\t    assert!(result.is_err());\n    52\t}\n    53\t\n    54\t#[test]\n    55\tfn validate_sequence_rejects_backwards() {\n    56\t    let event = make_event(1, JournalEventType::RunStarted);\n    57\t    let result = journal::validate_sequence(3, &event);\n    58\t    assert!(result.is_err());\n    59\t}\n    60\t\n    61\t// ── Serialization ──\n    62\t\n    63\t#[test]\n    64\tfn serialize_event_produces_single_line_json() {\n    65\t    let event = make_event(1, JournalEventType::ProjectCreated);\n    66\t    let line = journal::serialize_event(&event).expect(\"serialize\");\n    67\t    assert!(!line.contains('\\n'));\n    68\t    assert!(line.contains(\"\\\"project_created\\\"\"));\n    69\t    assert!(line.contains(\"\\\"sequence\\\":1\"));\n    70\t}\n    71\t\n    72\t#[test]\n    73\tfn deserialize_event_round_trips() {\n    74\t    let event = make_event(1, JournalEventType::ProjectCreated);\n    75\t    let line = journal::serialize_event(&event).expect(\"serialize\");\n    76\t    let parsed = journal::deserialize_event(&line).expect(\"deserialize\");\n    77\t    assert_eq!(event, parsed);\n    78\t}\n    79\t\n    80\t#[test]\n    81\tfn deserialize_event_rejects_empty_line() {\n    82\t    let result = journal::deserialize_event(\"\");\n    83\t    assert!(matches!(\n    84\t        result.unwrap_err(),\n    85\t        AppError::CorruptRecord { .. }\n    86\t    ));\n    87\t}\n    88\t\n    89\t#[test]\n    90\tfn deserialize_event_rejects_malformed_json() {\n    91\t    let result = journal::deserialize_event(\"{not valid json}\");\n    92\t    assert!(matches!(\n    93\t        result.unwrap_err(),\n    94\t        AppError::CorruptRecord { .. }\n    95\t    ));\n    96\t}\n    97\t\n    98\t// ── Full Journal Parsing ──\n    99\t\n   100\t#[test]\n   101\tfn parse_journal_handles_empty_content() {\n   102\t    let events = journal::parse_journal(\"\").expect(\"parse empty\");\n   103\t    assert!(events.is_empty());\n   104\t}\n   105\t\n   106\t#[test]\n   107\tfn parse_journal_parses_ordered_events() {\n   108\t    let e1 = make_event(1, JournalEventType::ProjectCreated);\n   109\t    let e2 = make_event(2, JournalEventType::RunStarted);\n   110\t    let content = format!(\n   111\t        \"{}\\n{}\\n\",\n   112\t        journal::serialize_event(&e1).unwrap(),\n   113\t        journal::serialize_event(&e2).unwrap()\n   114\t    );\n   115\t\n   116\t    let events = journal::parse_journal(&content).expect(\"parse\");\n   117\t    assert_eq!(events.len(), 2);\n   118\t    assert_eq!(events[0].sequence, 1);\n   119\t    assert_eq!(events[1].sequence, 2);\n   120\t}\n   121\t\n   122\t#[test]\n   123\tfn parse_journal_rejects_out_of_order_sequence() {\n   124\t    let e1 = make_event(1, JournalEventType::ProjectCreated);\n   125\t    let e2 = make_event(3, JournalEventType::RunStarted); // gap\n   126\t    let content = format!(\n   127\t        \"{}\\n{}\\n\",\n   128\t        journal::serialize_event(&e1).unwrap(),\n   129\t        journal::serialize_event(&e2).unwrap()\n   130\t    );\n   131\t\n   132\t    let result = journal::parse_journal(&content);\n   133\t    assert!(matches!(\n   134\t        result.unwrap_err(),\n   135\t        AppError::JournalSequence { .. }\n   136\t    ));\n   137\t}\n   138\t\n   139\t#[test]\n   140\tfn parse_journal_skips_blank_lines() {\n   141\t    let e1 = make_event(1, JournalEventType::ProjectCreated);\n   142\t    let content = format!(\"\\n{}\\n\\n\", journal::serialize_event(&e1).unwrap());\n   143\t\n   144\t    let events = journal::parse_journal(&content).expect(\"parse\");\n   145\t    assert_eq!(events.len(), 1);\n   146\t}\n   147\t\n   148\t// ── last_sequence ──\n   149\t\n   150\t#[test]\n   151\tfn last_sequence_returns_0_for_empty() {\n   152\t    assert_eq!(journal::last_sequence(&[]), 0);\n   153\t}\n   154\t\n   155\t#[test]\n   156\tfn last_sequence_returns_last_event_sequence() {\n   157\t    let events = vec![\n   158\t        make_event(1, JournalEventType::ProjectCreated),\n   159\t        make_event(2, JournalEventType::RunStarted),\n   160\t    ];\n   161\t    assert_eq!(journal::last_sequence(&events), 2);\n   162\t}\n","exit_code":0,"status":"completed"}}
