{"type":"item.completed","item":{"id":"item_44","type":"command_execution","command":"/run/current-system/sw/bin/bash -lc \"nl -ba /root/new-ralph-burning/ralph-burning-rewrite/tests/cli.rs | sed -n '300,1320p'\"","aggregated_output":"   300\t\n   301\t    let missing = Command::new(binary())\n   302\t        .args([\"project\", \"select\", \"missing\"])\n   303\t        .current_dir(temp_dir.path())\n   304\t        .output()\n   305\t        .expect(\"run missing project select\");\n   306\t    assert!(!missing.status.success());\n   307\t    assert!(String::from_utf8_lossy(&missing.stderr).contains(\"project 'missing' was not found\"));\n   308\t}\n   309\t\n   310\t#[test]\n   311\tfn project_select_rejects_path_like_ids_before_writing_active_project() {\n   312\t    let temp_dir = initialize_workspace_fixture();\n   313\t\n   314\t    let output = Command::new(binary())\n   315\t        .args([\"project\", \"select\", \"../escape\"])\n   316\t        .current_dir(temp_dir.path())\n   317\t        .output()\n   318\t        .expect(\"run path-like project select\");\n   319\t\n   320\t    assert!(!output.status.success());\n   321\t    assert!(String::from_utf8_lossy(&output.stderr).contains(\"invalid identifier\"));\n   322\t    assert!(!temp_dir\n   323\t        .path()\n   324\t        .join(\".ralph-burning/active-project\")\n   325\t        .exists());\n   326\t}\n   327\t\n   328\t// ── Project Create ──\n   329\t\n   330\tfn write_prompt_fixture(base_dir: &std::path::Path) -> std::path::PathBuf {\n   331\t    let prompt_path = base_dir.join(\"test-prompt.md\");\n   332\t    fs::write(&prompt_path, \"# Test Prompt\\nImplement the feature.\\n\").expect(\"write prompt\");\n   333\t    prompt_path\n   334\t}\n   335\t\n   336\t#[test]\n   337\tfn project_create_succeeds_and_writes_all_canonical_files() {\n   338\t    let temp_dir = initialize_workspace_fixture();\n   339\t    let prompt = write_prompt_fixture(temp_dir.path());\n   340\t\n   341\t    let output = Command::new(binary())\n   342\t        .args([\n   343\t            \"project\", \"create\",\n   344\t            \"--id\", \"alpha\",\n   345\t            \"--name\", \"Alpha Project\",\n   346\t            \"--prompt\", prompt.to_str().unwrap(),\n   347\t            \"--flow\", \"standard\",\n   348\t        ])\n   349\t        .current_dir(temp_dir.path())\n   350\t        .output()\n   351\t        .expect(\"run project create\");\n   352\t\n   353\t    assert!(output.status.success(), \"stderr: {}\", String::from_utf8_lossy(&output.stderr));\n   354\t\n   355\t    let stdout = String::from_utf8_lossy(&output.stdout);\n   356\t    assert!(stdout.contains(\"Created project 'alpha'\"));\n   357\t    assert!(stdout.contains(\"standard\"));\n   358\t\n   359\t    let project_root = temp_dir.path().join(\".ralph-burning/projects/alpha\");\n   360\t    assert!(project_root.join(\"project.toml\").is_file());\n   361\t    assert!(project_root.join(\"prompt.md\").is_file());\n   362\t    assert!(project_root.join(\"run.json\").is_file());\n   363\t    assert!(project_root.join(\"journal.ndjson\").is_file());\n   364\t    assert!(project_root.join(\"sessions.json\").is_file());\n   365\t    assert!(project_root.join(\"history/payloads\").is_dir());\n   366\t    assert!(project_root.join(\"history/artifacts\").is_dir());\n   367\t    assert!(project_root.join(\"runtime/logs\").is_dir());\n   368\t    assert!(project_root.join(\"runtime/backend\").is_dir());\n   369\t    assert!(project_root.join(\"runtime/temp\").is_dir());\n   370\t    assert!(project_root.join(\"amendments\").is_dir());\n   371\t    assert!(project_root.join(\"rollback\").is_dir());\n   372\t}\n   373\t\n   374\t#[test]\n   375\tfn project_create_initializes_journal_with_project_created_event() {\n   376\t    let temp_dir = initialize_workspace_fixture();\n   377\t    let prompt = write_prompt_fixture(temp_dir.path());\n   378\t\n   379\t    let output = Command::new(binary())\n   380\t        .args([\n   381\t            \"project\", \"create\",\n   382\t            \"--id\", \"beta\",\n   383\t            \"--name\", \"Beta\",\n   384\t            \"--prompt\", prompt.to_str().unwrap(),\n   385\t            \"--flow\", \"quick_dev\",\n   386\t        ])\n   387\t        .current_dir(temp_dir.path())\n   388\t        .output()\n   389\t        .expect(\"run project create\");\n   390\t    assert!(output.status.success());\n   391\t\n   392\t    let journal = fs::read_to_string(\n   393\t        temp_dir.path().join(\".ralph-burning/projects/beta/journal.ndjson\"),\n   394\t    )\n   395\t    .expect(\"read journal\");\n   396\t\n   397\t    assert!(journal.contains(\"\\\"project_created\\\"\"));\n   398\t    assert!(journal.contains(\"\\\"sequence\\\":1\"));\n   399\t}\n   400\t\n   401\t#[test]\n   402\tfn project_create_run_json_shows_not_started() {\n   403\t    let temp_dir = initialize_workspace_fixture();\n   404\t    let prompt = write_prompt_fixture(temp_dir.path());\n   405\t\n   406\t    Command::new(binary())\n   407\t        .args([\n   408\t            \"project\", \"create\",\n   409\t            \"--id\", \"gamma\",\n   410\t            \"--name\", \"Gamma\",\n   411\t            \"--prompt\", prompt.to_str().unwrap(),\n   412\t            \"--flow\", \"standard\",\n   413\t        ])\n   414\t        .current_dir(temp_dir.path())\n   415\t        .output()\n   416\t        .expect(\"run project create\");\n   417\t\n   418\t    let run_json = fs::read_to_string(\n   419\t        temp_dir.path().join(\".ralph-burning/projects/gamma/run.json\"),\n   420\t    )\n   421\t    .expect(\"read run.json\");\n   422\t\n   423\t    assert!(run_json.contains(\"\\\"not_started\\\"\"));\n   424\t    assert!(run_json.contains(\"\\\"active_run\\\": null\"));\n   425\t}\n   426\t\n   427\t#[test]\n   428\tfn project_create_fails_on_duplicate_id() {\n   429\t    let temp_dir = initialize_workspace_fixture();\n   430\t    let prompt = write_prompt_fixture(temp_dir.path());\n   431\t\n   432\t    let first = Command::new(binary())\n   433\t        .args([\n   434\t            \"project\", \"create\",\n   435\t            \"--id\", \"dup\",\n   436\t            \"--name\", \"First\",\n   437\t            \"--prompt\", prompt.to_str().unwrap(),\n   438\t            \"--flow\", \"standard\",\n   439\t        ])\n   440\t        .current_dir(temp_dir.path())\n   441\t        .output()\n   442\t        .expect(\"first create\");\n   443\t    assert!(first.status.success());\n   444\t\n   445\t    let second = Command::new(binary())\n   446\t        .args([\n   447\t            \"project\", \"create\",\n   448\t            \"--id\", \"dup\",\n   449\t            \"--name\", \"Second\",\n   450\t            \"--prompt\", prompt.to_str().unwrap(),\n   451\t            \"--flow\", \"standard\",\n   452\t        ])\n   453\t        .current_dir(temp_dir.path())\n   454\t        .output()\n   455\t        .expect(\"second create\");\n   456\t\n   457\t    assert!(!second.status.success());\n   458\t    let stderr = String::from_utf8_lossy(&second.stderr);\n   459\t    assert!(stderr.contains(\"already exists\"));\n   460\t}\n   461\t\n   462\t#[test]\n   463\tfn project_create_fails_on_invalid_flow() {\n   464\t    let temp_dir = initialize_workspace_fixture();\n   465\t    let prompt = write_prompt_fixture(temp_dir.path());\n   466\t\n   467\t    let output = Command::new(binary())\n   468\t        .args([\n   469\t            \"project\", \"create\",\n   470\t            \"--id\", \"bad-flow\",\n   471\t            \"--name\", \"Bad Flow\",\n   472\t            \"--prompt\", prompt.to_str().unwrap(),\n   473\t            \"--flow\", \"nonexistent\",\n   474\t        ])\n   475\t        .current_dir(temp_dir.path())\n   476\t        .output()\n   477\t        .expect(\"run project create\");\n   478\t\n   479\t    assert!(!output.status.success());\n   480\t    let stderr = String::from_utf8_lossy(&output.stderr);\n   481\t    assert!(stderr.contains(\"unknown flow preset\"));\n   482\t}\n   483\t\n   484\t#[test]\n   485\tfn project_create_fails_on_missing_prompt() {\n   486\t    let temp_dir = initialize_workspace_fixture();\n   487\t\n   488\t    let output = Command::new(binary())\n   489\t        .args([\n   490\t            \"project\", \"create\",\n   491\t            \"--id\", \"no-prompt\",\n   492\t            \"--name\", \"No Prompt\",\n   493\t            \"--prompt\", \"/nonexistent/prompt.md\",\n   494\t            \"--flow\", \"standard\",\n   495\t        ])\n   496\t        .current_dir(temp_dir.path())\n   497\t        .output()\n   498\t        .expect(\"run project create\");\n   499\t\n   500\t    assert!(!output.status.success());\n   501\t    let stderr = String::from_utf8_lossy(&output.stderr);\n   502\t    assert!(stderr.contains(\"invalid prompt file\"));\n   503\t}\n   504\t\n   505\t#[test]\n   506\tfn project_create_does_not_set_active_project() {\n   507\t    let temp_dir = initialize_workspace_fixture();\n   508\t    let prompt = write_prompt_fixture(temp_dir.path());\n   509\t\n   510\t    Command::new(binary())\n   511\t        .args([\n   512\t            \"project\", \"create\",\n   513\t            \"--id\", \"noactive\",\n   514\t            \"--name\", \"No Active\",\n   515\t            \"--prompt\", prompt.to_str().unwrap(),\n   516\t            \"--flow\", \"standard\",\n   517\t        ])\n   518\t        .current_dir(temp_dir.path())\n   519\t        .output()\n   520\t        .expect(\"run project create\");\n   521\t\n   522\t    // active-project should not exist (create does not set it)\n   523\t    assert!(!temp_dir\n   524\t        .path()\n   525\t        .join(\".ralph-burning/active-project\")\n   526\t        .exists());\n   527\t}\n   528\t\n   529\t// ── Project List ──\n   530\t\n   531\t#[test]\n   532\tfn project_list_shows_no_projects_when_empty() {\n   533\t    let temp_dir = initialize_workspace_fixture();\n   534\t\n   535\t    let output = Command::new(binary())\n   536\t        .args([\"project\", \"list\"])\n   537\t        .current_dir(temp_dir.path())\n   538\t        .output()\n   539\t        .expect(\"run project list\");\n   540\t\n   541\t    assert!(output.status.success());\n   542\t    let stdout = String::from_utf8_lossy(&output.stdout);\n   543\t    assert!(stdout.contains(\"No projects found\"));\n   544\t}\n   545\t\n   546\t#[test]\n   547\tfn project_list_shows_created_projects_with_active_marker() {\n   548\t    let temp_dir = initialize_workspace_fixture();\n   549\t    let prompt = write_prompt_fixture(temp_dir.path());\n   550\t\n   551\t    // Create two projects\n   552\t    Command::new(binary())\n   553\t        .args([\n   554\t            \"project\", \"create\",\n   555\t            \"--id\", \"alpha\",\n   556\t            \"--name\", \"Alpha\",\n   557\t            \"--prompt\", prompt.to_str().unwrap(),\n   558\t            \"--flow\", \"standard\",\n   559\t        ])\n   560\t        .current_dir(temp_dir.path())\n   561\t        .output()\n   562\t        .expect(\"create alpha\");\n   563\t\n   564\t    Command::new(binary())\n   565\t        .args([\n   566\t            \"project\", \"create\",\n   567\t            \"--id\", \"beta\",\n   568\t            \"--name\", \"Beta\",\n   569\t            \"--prompt\", prompt.to_str().unwrap(),\n   570\t            \"--flow\", \"quick_dev\",\n   571\t        ])\n   572\t        .current_dir(temp_dir.path())\n   573\t        .output()\n   574\t        .expect(\"create beta\");\n   575\t\n   576\t    // Select alpha as active\n   577\t    Command::new(binary())\n   578\t        .args([\"project\", \"select\", \"alpha\"])\n   579\t        .current_dir(temp_dir.path())\n   580\t        .output()\n   581\t        .expect(\"select alpha\");\n   582\t\n   583\t    let output = Command::new(binary())\n   584\t        .args([\"project\", \"list\"])\n   585\t        .current_dir(temp_dir.path())\n   586\t        .output()\n   587\t        .expect(\"run project list\");\n   588\t\n   589\t    assert!(output.status.success());\n   590\t    let stdout = String::from_utf8_lossy(&output.stdout);\n   591\t    assert!(stdout.contains(\"alpha *\"));\n   592\t    assert!(stdout.contains(\"beta\"));\n   593\t    assert!(stdout.contains(\"standard\"));\n   594\t    assert!(stdout.contains(\"quick_dev\"));\n   595\t}\n   596\t\n   597\t// ── Project Show ──\n   598\t\n   599\t#[test]\n   600\tfn project_show_displays_project_details() {\n   601\t    let temp_dir = initialize_workspace_fixture();\n   602\t    let prompt = write_prompt_fixture(temp_dir.path());\n   603\t\n   604\t    Command::new(binary())\n   605\t        .args([\n   606\t            \"project\", \"create\",\n   607\t            \"--id\", \"showme\",\n   608\t            \"--name\", \"Show Me\",\n   609\t            \"--prompt\", prompt.to_str().unwrap(),\n   610\t            \"--flow\", \"docs_change\",\n   611\t        ])\n   612\t        .current_dir(temp_dir.path())\n   613\t        .output()\n   614\t        .expect(\"create project\");\n   615\t\n   616\t    let output = Command::new(binary())\n   617\t        .args([\"project\", \"show\", \"showme\"])\n   618\t        .current_dir(temp_dir.path())\n   619\t        .output()\n   620\t        .expect(\"run project show\");\n   621\t\n   622\t    assert!(output.status.success());\n   623\t    let stdout = String::from_utf8_lossy(&output.stdout);\n   624\t    assert!(stdout.contains(\"Project: showme\"));\n   625\t    assert!(stdout.contains(\"Name: Show Me\"));\n   626\t    assert!(stdout.contains(\"Flow: docs_change\"));\n   627\t    assert!(stdout.contains(\"Prompt hash:\"));\n   628\t    assert!(stdout.contains(\"Run status: not started\"));\n   629\t    assert!(stdout.contains(\"Journal events: 1\"));\n   630\t}\n   631\t\n   632\t#[test]\n   633\tfn project_show_resolves_active_project_when_no_id_given() {\n   634\t    let temp_dir = initialize_workspace_fixture();\n   635\t    let prompt = write_prompt_fixture(temp_dir.path());\n   636\t\n   637\t    Command::new(binary())\n   638\t        .args([\n   639\t            \"project\", \"create\",\n   640\t            \"--id\", \"active-show\",\n   641\t            \"--name\", \"Active Show\",\n   642\t            \"--prompt\", prompt.to_str().unwrap(),\n   643\t            \"--flow\", \"standard\",\n   644\t        ])\n   645\t        .current_dir(temp_dir.path())\n   646\t        .output()\n   647\t        .expect(\"create project\");\n   648\t\n   649\t    Command::new(binary())\n   650\t        .args([\"project\", \"select\", \"active-show\"])\n   651\t        .current_dir(temp_dir.path())\n   652\t        .output()\n   653\t        .expect(\"select project\");\n   654\t\n   655\t    let output = Command::new(binary())\n   656\t        .args([\"project\", \"show\"])\n   657\t        .current_dir(temp_dir.path())\n   658\t        .output()\n   659\t        .expect(\"run project show without id\");\n   660\t\n   661\t    assert!(output.status.success());\n   662\t    let stdout = String::from_utf8_lossy(&output.stdout);\n   663\t    assert!(stdout.contains(\"Project: active-show (active)\"));\n   664\t}\n   665\t\n   666\t// ── Project Delete ──\n   667\t\n   668\t#[test]\n   669\tfn project_delete_removes_project_directory() {\n   670\t    let temp_dir = initialize_workspace_fixture();\n   671\t    let prompt = write_prompt_fixture(temp_dir.path());\n   672\t\n   673\t    Command::new(binary())\n   674\t        .args([\n   675\t            \"project\", \"create\",\n   676\t            \"--id\", \"deleteme\",\n   677\t            \"--name\", \"Delete Me\",\n   678\t            \"--prompt\", prompt.to_str().unwrap(),\n   679\t            \"--flow\", \"standard\",\n   680\t        ])\n   681\t        .current_dir(temp_dir.path())\n   682\t        .output()\n   683\t        .expect(\"create project\");\n   684\t\n   685\t    let output = Command::new(binary())\n   686\t        .args([\"project\", \"delete\", \"deleteme\"])\n   687\t        .current_dir(temp_dir.path())\n   688\t        .output()\n   689\t        .expect(\"run project delete\");\n   690\t\n   691\t    assert!(output.status.success());\n   692\t    let stdout = String::from_utf8_lossy(&output.stdout);\n   693\t    assert!(stdout.contains(\"Deleted project 'deleteme'\"));\n   694\t    assert!(!temp_dir\n   695\t        .path()\n   696\t        .join(\".ralph-burning/projects/deleteme\")\n   697\t        .exists());\n   698\t}\n   699\t\n   700\t#[test]\n   701\tfn project_delete_clears_active_project_if_selected() {\n   702\t    let temp_dir = initialize_workspace_fixture();\n   703\t    let prompt = write_prompt_fixture(temp_dir.path());\n   704\t\n   705\t    Command::new(binary())\n   706\t        .args([\n   707\t            \"project\", \"create\",\n   708\t            \"--id\", \"active-del\",\n   709\t            \"--name\", \"Active Del\",\n   710\t            \"--prompt\", prompt.to_str().unwrap(),\n   711\t            \"--flow\", \"standard\",\n   712\t        ])\n   713\t        .current_dir(temp_dir.path())\n   714\t        .output()\n   715\t        .expect(\"create project\");\n   716\t\n   717\t    Command::new(binary())\n   718\t        .args([\"project\", \"select\", \"active-del\"])\n   719\t        .current_dir(temp_dir.path())\n   720\t        .output()\n   721\t        .expect(\"select project\");\n   722\t\n   723\t    assert!(temp_dir\n   724\t        .path()\n   725\t        .join(\".ralph-burning/active-project\")\n   726\t        .exists());\n   727\t\n   728\t    let output = Command::new(binary())\n   729\t        .args([\"project\", \"delete\", \"active-del\"])\n   730\t        .current_dir(temp_dir.path())\n   731\t        .output()\n   732\t        .expect(\"run project delete\");\n   733\t\n   734\t    assert!(output.status.success());\n   735\t    assert!(!temp_dir\n   736\t        .path()\n   737\t        .join(\".ralph-burning/active-project\")\n   738\t        .exists());\n   739\t}\n   740\t\n   741\t#[test]\n   742\tfn project_delete_fails_for_missing_project() {\n   743\t    let temp_dir = initialize_workspace_fixture();\n   744\t\n   745\t    let output = Command::new(binary())\n   746\t        .args([\"project\", \"delete\", \"nonexistent\"])\n   747\t        .current_dir(temp_dir.path())\n   748\t        .output()\n   749\t        .expect(\"run project delete\");\n   750\t\n   751\t    assert!(!output.status.success());\n   752\t    let stderr = String::from_utf8_lossy(&output.stderr);\n   753\t    assert!(stderr.contains(\"not found\"));\n   754\t}\n   755\t\n   756\t// ── Run Status ──\n   757\t\n   758\t#[test]\n   759\tfn run_status_shows_not_started_for_new_project() {\n   760\t    let temp_dir = initialize_workspace_fixture();\n   761\t    let prompt = write_prompt_fixture(temp_dir.path());\n   762\t\n   763\t    Command::new(binary())\n   764\t        .args([\n   765\t            \"project\", \"create\",\n   766\t            \"--id\", \"status-test\",\n   767\t            \"--name\", \"Status Test\",\n   768\t            \"--prompt\", prompt.to_str().unwrap(),\n   769\t            \"--flow\", \"standard\",\n   770\t        ])\n   771\t        .current_dir(temp_dir.path())\n   772\t        .output()\n   773\t        .expect(\"create project\");\n   774\t\n   775\t    Command::new(binary())\n   776\t        .args([\"project\", \"select\", \"status-test\"])\n   777\t        .current_dir(temp_dir.path())\n   778\t        .output()\n   779\t        .expect(\"select project\");\n   780\t\n   781\t    let output = Command::new(binary())\n   782\t        .args([\"run\", \"status\"])\n   783\t        .current_dir(temp_dir.path())\n   784\t        .output()\n   785\t        .expect(\"run status\");\n   786\t\n   787\t    assert!(output.status.success());\n   788\t    let stdout = String::from_utf8_lossy(&output.stdout);\n   789\t    assert!(stdout.contains(\"Status: not started\"));\n   790\t}\n   791\t\n   792\t// ── Run History ──\n   793\t\n   794\t#[test]\n   795\tfn run_history_shows_journal_events_for_new_project() {\n   796\t    let temp_dir = initialize_workspace_fixture();\n   797\t    let prompt = write_prompt_fixture(temp_dir.path());\n   798\t\n   799\t    Command::new(binary())\n   800\t        .args([\n   801\t            \"project\", \"create\",\n   802\t            \"--id\", \"hist-test\",\n   803\t            \"--name\", \"History Test\",\n   804\t            \"--prompt\", prompt.to_str().unwrap(),\n   805\t            \"--flow\", \"standard\",\n   806\t        ])\n   807\t        .current_dir(temp_dir.path())\n   808\t        .output()\n   809\t        .expect(\"create project\");\n   810\t\n   811\t    Command::new(binary())\n   812\t        .args([\"project\", \"select\", \"hist-test\"])\n   813\t        .current_dir(temp_dir.path())\n   814\t        .output()\n   815\t        .expect(\"select project\");\n   816\t\n   817\t    let output = Command::new(binary())\n   818\t        .args([\"run\", \"history\"])\n   819\t        .current_dir(temp_dir.path())\n   820\t        .output()\n   821\t        .expect(\"run history\");\n   822\t\n   823\t    assert!(output.status.success());\n   824\t    let stdout = String::from_utf8_lossy(&output.stdout);\n   825\t    assert!(stdout.contains(\"Journal Events\"));\n   826\t    assert!(stdout.contains(\"ProjectCreated\"));\n   827\t}\n   828\t\n   829\t// ── Run Tail ──\n   830\t\n   831\t#[test]\n   832\tfn run_tail_shows_durable_history_only_by_default() {\n   833\t    let temp_dir = initialize_workspace_fixture();\n   834\t    let prompt = write_prompt_fixture(temp_dir.path());\n   835\t\n   836\t    Command::new(binary())\n   837\t        .args([\n   838\t            \"project\", \"create\",\n   839\t            \"--id\", \"tail-test\",\n   840\t            \"--name\", \"Tail Test\",\n   841\t            \"--prompt\", prompt.to_str().unwrap(),\n   842\t            \"--flow\", \"standard\",\n   843\t        ])\n   844\t        .current_dir(temp_dir.path())\n   845\t        .output()\n   846\t        .expect(\"create project\");\n   847\t\n   848\t    Command::new(binary())\n   849\t        .args([\"project\", \"select\", \"tail-test\"])\n   850\t        .current_dir(temp_dir.path())\n   851\t        .output()\n   852\t        .expect(\"select project\");\n   853\t\n   854\t    let output = Command::new(binary())\n   855\t        .args([\"run\", \"tail\"])\n   856\t        .current_dir(temp_dir.path())\n   857\t        .output()\n   858\t        .expect(\"run tail\");\n   859\t\n   860\t    assert!(output.status.success());\n   861\t    let stdout = String::from_utf8_lossy(&output.stdout);\n   862\t    assert!(stdout.contains(\"Durable History\"));\n   863\t    // No runtime logs section when --logs not passed\n   864\t    assert!(!stdout.contains(\"Runtime Logs\"));\n   865\t}\n   866\t\n   867\t#[test]\n   868\tfn run_tail_with_logs_includes_runtime_logs_section() {\n   869\t    let temp_dir = initialize_workspace_fixture();\n   870\t    let prompt = write_prompt_fixture(temp_dir.path());\n   871\t\n   872\t    Command::new(binary())\n   873\t        .args([\n   874\t            \"project\", \"create\",\n   875\t            \"--id\", \"tail-logs\",\n   876\t            \"--name\", \"Tail Logs\",\n   877\t            \"--prompt\", prompt.to_str().unwrap(),\n   878\t            \"--flow\", \"standard\",\n   879\t        ])\n   880\t        .current_dir(temp_dir.path())\n   881\t        .output()\n   882\t        .expect(\"create project\");\n   883\t\n   884\t    Command::new(binary())\n   885\t        .args([\"project\", \"select\", \"tail-logs\"])\n   886\t        .current_dir(temp_dir.path())\n   887\t        .output()\n   888\t        .expect(\"select project\");\n   889\t\n   890\t    let output = Command::new(binary())\n   891\t        .args([\"run\", \"tail\", \"--logs\"])\n   892\t        .current_dir(temp_dir.path())\n   893\t        .output()\n   894\t        .expect(\"run tail --logs\");\n   895\t\n   896\t    assert!(output.status.success());\n   897\t    let stdout = String::from_utf8_lossy(&output.stdout);\n   898\t    assert!(stdout.contains(\"Durable History\"));\n   899\t    assert!(stdout.contains(\"Runtime Logs\"));\n   900\t}\n   901\t\n   902\t// ── Fail-fast on missing canonical files ──\n   903\t\n   904\t#[test]\n   905\tfn run_status_fails_fast_when_run_json_is_missing() {\n   906\t    let temp_dir = initialize_workspace_fixture();\n   907\t    let prompt = write_prompt_fixture(temp_dir.path());\n   908\t\n   909\t    Command::new(binary())\n   910\t        .args([\n   911\t            \"project\", \"create\",\n   912\t            \"--id\", \"broken\",\n   913\t            \"--name\", \"Broken\",\n   914\t            \"--prompt\", prompt.to_str().unwrap(),\n   915\t            \"--flow\", \"standard\",\n   916\t        ])\n   917\t        .current_dir(temp_dir.path())\n   918\t        .output()\n   919\t        .expect(\"create project\");\n   920\t\n   921\t    Command::new(binary())\n   922\t        .args([\"project\", \"select\", \"broken\"])\n   923\t        .current_dir(temp_dir.path())\n   924\t        .output()\n   925\t        .expect(\"select project\");\n   926\t\n   927\t    // Delete run.json to simulate corruption\n   928\t    fs::remove_file(\n   929\t        temp_dir.path().join(\".ralph-burning/projects/broken/run.json\"),\n   930\t    )\n   931\t    .expect(\"remove run.json\");\n   932\t\n   933\t    let output = Command::new(binary())\n   934\t        .args([\"run\", \"status\"])\n   935\t        .current_dir(temp_dir.path())\n   936\t        .output()\n   937\t        .expect(\"run status\");\n   938\t\n   939\t    assert!(!output.status.success());\n   940\t    let stderr = String::from_utf8_lossy(&output.stderr);\n   941\t    assert!(stderr.contains(\"run.json\"));\n   942\t    assert!(stderr.contains(\"missing\"));\n   943\t}\n   944\t\n   945\t#[test]\n   946\tfn run_history_fails_fast_when_journal_is_missing() {\n   947\t    let temp_dir = initialize_workspace_fixture();\n   948\t    let prompt = write_prompt_fixture(temp_dir.path());\n   949\t\n   950\t    Command::new(binary())\n   951\t        .args([\n   952\t            \"project\", \"create\",\n   953\t            \"--id\", \"nojrnl\",\n   954\t            \"--name\", \"No Journal\",\n   955\t            \"--prompt\", prompt.to_str().unwrap(),\n   956\t            \"--flow\", \"standard\",\n   957\t        ])\n   958\t        .current_dir(temp_dir.path())\n   959\t        .output()\n   960\t        .expect(\"create project\");\n   961\t\n   962\t    Command::new(binary())\n   963\t        .args([\"project\", \"select\", \"nojrnl\"])\n   964\t        .current_dir(temp_dir.path())\n   965\t        .output()\n   966\t        .expect(\"select project\");\n   967\t\n   968\t    // Delete journal.ndjson to simulate corruption\n   969\t    fs::remove_file(\n   970\t        temp_dir.path().join(\".ralph-burning/projects/nojrnl/journal.ndjson\"),\n   971\t    )\n   972\t    .expect(\"remove journal\");\n   973\t\n   974\t    let output = Command::new(binary())\n   975\t        .args([\"run\", \"history\"])\n   976\t        .current_dir(temp_dir.path())\n   977\t        .output()\n   978\t        .expect(\"run history\");\n   979\t\n   980\t    assert!(!output.status.success());\n   981\t    let stderr = String::from_utf8_lossy(&output.stderr);\n   982\t    assert!(stderr.contains(\"journal.ndjson\"));\n   983\t    assert!(stderr.contains(\"missing\"));\n   984\t}\n   985\t\n   986\t#[test]\n   987\tfn run_status_fails_fast_when_run_json_is_corrupt() {\n   988\t    let temp_dir = initialize_workspace_fixture();\n   989\t    let prompt = write_prompt_fixture(temp_dir.path());\n   990\t\n   991\t    Command::new(binary())\n   992\t        .args([\n   993\t            \"project\", \"create\",\n   994\t            \"--id\", \"corrupt\",\n   995\t            \"--name\", \"Corrupt\",\n   996\t            \"--prompt\", prompt.to_str().unwrap(),\n   997\t            \"--flow\", \"standard\",\n   998\t        ])\n   999\t        .current_dir(temp_dir.path())\n  1000\t        .output()\n  1001\t        .expect(\"create project\");\n  1002\t\n  1003\t    Command::new(binary())\n  1004\t        .args([\"project\", \"select\", \"corrupt\"])\n  1005\t        .current_dir(temp_dir.path())\n  1006\t        .output()\n  1007\t        .expect(\"select project\");\n  1008\t\n  1009\t    // Write corrupt JSON to run.json\n  1010\t    fs::write(\n  1011\t        temp_dir.path().join(\".ralph-burning/projects/corrupt/run.json\"),\n  1012\t        \"{invalid json}\",\n  1013\t    )\n  1014\t    .expect(\"corrupt run.json\");\n  1015\t\n  1016\t    let output = Command::new(binary())\n  1017\t        .args([\"run\", \"status\"])\n  1018\t        .current_dir(temp_dir.path())\n  1019\t        .output()\n  1020\t        .expect(\"run status\");\n  1021\t\n  1022\t    assert!(!output.status.success());\n  1023\t    let stderr = String::from_utf8_lossy(&output.stderr);\n  1024\t    assert!(stderr.contains(\"run.json\"));\n  1025\t}\n  1026\t\n  1027\t// ── Missing project.toml corruption detection ──\n  1028\t\n  1029\t#[test]\n  1030\tfn project_show_fails_fast_when_project_toml_is_missing() {\n  1031\t    let temp_dir = initialize_workspace_fixture();\n  1032\t    let prompt = write_prompt_fixture(temp_dir.path());\n  1033\t\n  1034\t    Command::new(binary())\n  1035\t        .args([\n  1036\t            \"project\", \"create\",\n  1037\t            \"--id\", \"corrupt-proj\",\n  1038\t            \"--name\", \"Corrupt\",\n  1039\t            \"--prompt\", prompt.to_str().unwrap(),\n  1040\t            \"--flow\", \"standard\",\n  1041\t        ])\n  1042\t        .current_dir(temp_dir.path())\n  1043\t        .output()\n  1044\t        .expect(\"create project\");\n  1045\t\n  1046\t    // Delete project.toml to simulate corruption\n  1047\t    fs::remove_file(\n  1048\t        temp_dir.path().join(\".ralph-burning/projects/corrupt-proj/project.toml\"),\n  1049\t    )\n  1050\t    .expect(\"remove project.toml\");\n  1051\t\n  1052\t    let output = Command::new(binary())\n  1053\t        .args([\"project\", \"show\", \"corrupt-proj\"])\n  1054\t        .current_dir(temp_dir.path())\n  1055\t        .output()\n  1056\t        .expect(\"run project show\");\n  1057\t\n  1058\t    assert!(!output.status.success());\n  1059\t    let stderr = String::from_utf8_lossy(&output.stderr);\n  1060\t    assert!(stderr.contains(\"project.toml\"));\n  1061\t    assert!(stderr.contains(\"missing\"));\n  1062\t}\n  1063\t\n  1064\t#[test]\n  1065\tfn project_list_fails_fast_when_project_toml_is_missing() {\n  1066\t    let temp_dir = initialize_workspace_fixture();\n  1067\t    let prompt = write_prompt_fixture(temp_dir.path());\n  1068\t\n  1069\t    Command::new(binary())\n  1070\t        .args([\n  1071\t            \"project\", \"create\",\n  1072\t            \"--id\", \"good-proj\",\n  1073\t            \"--name\", \"Good\",\n  1074\t            \"--prompt\", prompt.to_str().unwrap(),\n  1075\t            \"--flow\", \"standard\",\n  1076\t        ])\n  1077\t        .current_dir(temp_dir.path())\n  1078\t        .output()\n  1079\t        .expect(\"create project\");\n  1080\t\n  1081\t    // Delete project.toml to simulate corruption\n  1082\t    fs::remove_file(\n  1083\t        temp_dir.path().join(\".ralph-burning/projects/good-proj/project.toml\"),\n  1084\t    )\n  1085\t    .expect(\"remove project.toml\");\n  1086\t\n  1087\t    let output = Command::new(binary())\n  1088\t        .args([\"project\", \"list\"])\n  1089\t        .current_dir(temp_dir.path())\n  1090\t        .output()\n  1091\t        .expect(\"run project list\");\n  1092\t\n  1093\t    assert!(!output.status.success());\n  1094\t    let stderr = String::from_utf8_lossy(&output.stderr);\n  1095\t    assert!(stderr.contains(\"project.toml\"));\n  1096\t    assert!(stderr.conta