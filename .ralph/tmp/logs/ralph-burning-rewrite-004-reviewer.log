   147\t    assert!(stdout.contains(\"[settings]\"));\n   148\t    assert!(stdout.contains(\"prompt_review.enabled = true # source: default\"));\n   149\t    assert!(stdout.contains(\"default_flow = \\\"standard\\\" # source: default\"));\n   150\t    assert!(stdout.contains(\"default_backend = \\\"<unset>\\\" # source: default\"));\n   151\t}\n   152\t\n   153\t#[test]\n   154\tfn config_get_prints_known_values_and_rejects_unknown_keys() {\n   155\t    let temp_dir = initialize_workspace_fixture();\n   156\t\n   157\t    let known = Command::new(binary())\n   158\t        .args([\"config\", \"get\", \"default_flow\"])\n   159\t        .current_dir(temp_dir.path())\n   160\t        .output()\n   161\t        .expect(\"run config get\");\n   162\t    assert!(known.status.success());\n   163\t    assert_eq!(\"standard\\n\", String::from_utf8_lossy(&known.stdout));\n   164\t\n   165\t    let unknown = Command::new(binary())\n   166\t        .args([\"config\", \"get\", \"unknown.key\"])\n   167\t        .current_dir(temp_dir.path())\n   168\t        .output()\n   169\t        .expect(\"run config get invalid\");\n   170\t    assert!(!unknown.status.success());\n   171\t    assert!(String::from_utf8_lossy(&unknown.stderr).contains(\"unknown config key\"));\n   172\t}\n   173\t\n   174\t#[test]\n   175\tfn config_set_updates_valid_keys_and_rejects_invalid_values() {\n   176\t    let temp_dir = initialize_workspace_fixture();\n   177\t\n   178\t    let valid = Command::new(binary())\n   179\t        .args([\"config\", \"set\", \"default_flow\", \"quick_dev\"])\n   180\t        .current_dir(temp_dir.path())\n   181\t        .output()\n   182\t        .expect(\"run config set\");\n   183\t    assert!(valid.status.success());\n   184\t    assert!(String::from_utf8_lossy(&valid.stdout).contains(\"Updated default_flow = quick_dev\"));\n   185\t\n   186\t    let workspace_config =\n   187\t        fs::read_to_string(temp_dir.path().join(\".ralph-burning/workspace.toml\"))\n   188\t            .expect(\"read workspace config\");\n   189\t    assert!(workspace_config.contains(\"default_flow = \\\"quick_dev\\\"\"));\n   190\t\n   191\t    let invalid_value = Command::new(binary())\n   192\t        .args([\"config\", \"set\", \"default_flow\", \"unknown_flow\"])\n   193\t        .current_dir(temp_dir.path())\n   194\t        .output()\n   195\t        .expect(\"run invalid config set\");\n   196\t    assert!(!invalid_value.status.success());\n   197\t    assert!(String::from_utf8_lossy(&invalid_value.stderr).contains(\"invalid value\"));\n   198\t\n   199\t    let invalid_key = Command::new(binary())\n   200\t        .args([\"config\", \"set\", \"unknown.key\", \"value\"])\n   201\t        .current_dir(temp_dir.path())\n   202\t        .output()\n   203\t        .expect(\"run invalid key config set\");\n   204\t    assert!(!invalid_key.status.success());\n   205\t    assert!(String::from_utf8_lossy(&invalid_key.stderr).contains(\"unknown config key\"));\n   206\t}\n   207\t\n   208\t#[test]\n   209\tfn config_edit_revalidates_workspace_file() {\n   210\t    let temp_dir = initialize_workspace_fixture();\n   211\t    let editor = write_editor_script(\n   212\t        temp_dir.path(),\n   213\t        \"editor-valid.sh\",\n   214\t        \"#!/bin/sh\\ncat <<'EOF' > \\\"$1\\\"\\nversion = 1\\ncreated_at = \\\"2026-03-11T17:50:55Z\\\"\\n\\n[settings]\\ndefault_backend = \\\"claude\\\"\\nEOF\\n\",\n   215\t    );\n   216\t\n   217\t    let output = Command::new(binary())\n   218\t        .args([\"config\", \"edit\"])\n   219\t        .env(\"EDITOR\", &editor)\n   220\t        .env_remove(\"VISUAL\")\n   221\t        .current_dir(temp_dir.path())\n   222\t        .output()\n   223\t        .expect(\"run config edit\");\n   224\t\n   225\t    assert!(output.status.success());\n   226\t    assert!(String::from_utf8_lossy(&output.stdout).contains(\"Validated workspace.toml\"));\n   227\t}\n   228\t\n   229\t#[test]\n   230\tfn config_edit_prefers_editor_over_visual() {\n   231\t    let temp_dir = initialize_workspace_fixture();\n   232\t    let editor = write_editor_script(\n   233\t        temp_dir.path(),\n   234\t        \"editor-wins.sh\",\n   235\t        \"#!/bin/sh\\ncat <<'EOF' > \\\"$1\\\"\\nversion = 1\\ncreated_at = \\\"2026-03-11T17:50:55Z\\\"\\n\\n[settings]\\ndefault_backend = \\\"editor\\\"\\nEOF\\n\",\n   236\t    );\n   237\t    let visual = write_editor_script(\n   238\t        temp_dir.path(),\n   239\t        \"visual-loses.sh\",\n   240\t        \"#!/bin/sh\\ncat <<'EOF' > \\\"$1\\\"\\nversion = 1\\ncreated_at = \\\"2026-03-11T17:50:55Z\\\"\\n\\n[settings]\\ndefault_backend = \\\"visual\\\"\\nEOF\\n\",\n   241\t    );\n   242\t\n   243\t    let output = Command::new(binary())\n   244\t        .args([\"config\", \"edit\"])\n   245\t        .env(\"EDITOR\", &editor)\n   246\t        .env(\"VISUAL\", &visual)\n   247\t        .current_dir(temp_dir.path())\n   248\t        .output()\n   249\t        .expect(\"run config edit\");\n   250\t\n   251\t    assert!(output.status.success());\n   252\t\n   253\t    let workspace_config =\n   254\t        fs::read_to_string(temp_dir.path().join(\".ralph-burning/workspace.toml\"))\n   255\t            .expect(\"read workspace config\");\n   256\t    assert!(workspace_config.contains(\"default_backend = \\\"editor\\\"\"));\n   257\t    assert!(!workspace_config.contains(\"default_backend = \\\"visual\\\"\"));\n   258\t}\n   259\t\n   260\t#[test]\n   261\tfn config_edit_fails_when_editor_leaves_invalid_file() {\n   262\t    let temp_dir = initialize_workspace_fixture();\n   263\t    let editor = write_editor_script(\n   264\t        temp_dir.path(),\n   265\t        \"editor-invalid.sh\",\n   266\t        \"#!/bin/sh\\nprintf '%s\\n' 'version = 999' 'created_at = \\\"2026-03-11T17:50:55Z\\\"' > \\\"$1\\\"\\n\",\n   267\t    );\n   268\t\n   269\t    let output = Command::new(binary())\n   270\t        .args([\"config\", \"edit\"])\n   271\t        .env(\"EDITOR\", &editor)\n   272\t        .env_remove(\"VISUAL\")\n   273\t        .current_dir(temp_dir.path())\n   274\t        .output()\n   275\t        .expect(\"run invalid config edit\");\n   276\t\n   277\t    assert!(!output.status.success());\n   278\t    let stderr = String::from_utf8_lossy(&output.stderr);\n   279\t    assert!(stderr.contains(\"workspace.toml is invalid after editing\"));\n   280\t    assert!(stderr.contains(\"unsupported workspace version 999\"));\n   281\t}\n   282\t\n   283\t#[test]\n   284\tfn project_select_sets_active_project_and_rejects_missing_projects() {\n   285\t    let temp_dir = initialize_workspace_fixture();\n   286\t    create_project_fixture(temp_dir.path(), \"alpha\");\n   287\t\n   288\t    let existing = Command::new(binary())\n   289\t        .args([\"project\", \"select\", \"alpha\"])\n   290\t        .current_dir(temp_dir.path())\n   291\t        .output()\n   292\t        .expect(\"run project select\");\n   293\t    assert!(existing.status.success());\n   294\t    assert!(String::from_utf8_lossy(&existing.stdout).contains(\"Selected project alpha\"));\n   295\t    assert_eq!(\n   296\t        \"alpha\",\n   297\t        fs::read_to_string(temp_dir.path().join(\".ralph-burning/active-project\"))\n   298\t            .expect(\"read active project\")\n   299\t    );\n   300\t\n   301\t    let missing = Command::new(binary())\n   302\t        .args([\"project\", \"select\", \"missing\"])\n   303\t        .current_dir(temp_dir.path())\n   304\t        .output()\n   305\t        .expect(\"run missing project select\");\n   306\t    assert!(!missing.status.success());\n   307\t    assert!(String::from_utf8_lossy(&missing.stderr).contains(\"project 'missing' was not found\"));\n   308\t}\n   309\t\n   310\t#[test]\n   311\tfn project_select_rejects_path_like_ids_before_writing_active_project() {\n   312\t    let temp_dir = initialize_workspace_fixture();\n   313\t\n   314\t    let output = Command::new(binary())\n   315\t        .args([\"project\", \"select\", \"../escape\"])\n   316\t        .current_dir(temp_dir.path())\n   317\t        .output()\n   318\t        .expect(\"run path-like project select\");\n   319\t\n   320\t    assert!(!output.status.success());\n   321\t    assert!(String::from_utf8_lossy(&output.stderr).contains(\"invalid identifier\"));\n   322\t    assert!(!temp_dir\n   323\t        .path()\n   324\t        .join(\".ralph-burning/active-project\")\n   325\t        .exists());\n   326\t}\n   327\t\n   328\t// ── Project Create ──\n   329\t\n   330\tfn write_prompt_fixture(base_dir: &std::path::Path) -> std::path::PathBuf {\n   331\t    let prompt_path = base_dir.join(\"test-prompt.md\");\n   332\t    fs::write(&prompt_path, \"# Test Prompt\\nImplement the feature.\\n\").expect(\"write prompt\");\n   333\t    prompt_path\n   334\t}\n   335\t\n   336\t#[test]\n   337\tfn project_create_succeeds_and_writes_all_canonical_files() {\n   338\t    let temp_dir = initialize_workspace_fixture();\n   339\t    let prompt = write_prompt_fixture(temp_dir.path());\n   340\t\n   341\t    let output = Command::new(binary())\n   342\t        .args([\n   343\t            \"project\", \"create\",\n   344\t            \"--id\", \"alpha\",\n   345\t            \"--name\", \"Alpha Project\",\n   346\t            \"--prompt\", prompt.to_str().unwrap(),\n   347\t            \"--flow\", \"standard\",\n   348\t        ])\n   349\t        .current_dir(temp_dir.path())\n   350\t        .output()\n   351\t        .expect(\"run project create\");\n   352\t\n   353\t    assert!(output.status.success(), \"stderr: {}\", String::from_utf8_lossy(&output.stderr));\n   354\t\n   355\t    let stdout = String::from_utf8_lossy(&output.stdout);\n   356\t    assert!(stdout.contains(\"Created project 'alpha'\"));\n   357\t    assert!(stdout.contains(\"standard\"));\n   358\t\n   359\t    let project_root = temp_dir.path().join(\".ralph-burning/projects/alpha\");\n   360\t    assert!(project_root.join(\"project.toml\").is_file());\n","exit_code":0,"status":"completed"}}
