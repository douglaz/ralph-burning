{"type":"item.completed","item":{"id":"item_19","type":"command_execution","command":"/run/current-system/sw/bin/bash -lc \"nl -ba /root/new-ralph-burning/ralph-burning-rewrite/src/contexts/project_run_record/journal.rs | sed -n '1,260p'\"","aggregated_output":"     1\tuse crate::shared::error::{AppError, AppResult};\n     2\t\n     3\tuse super::model::{JournalEvent, JournalEventType};\n     4\t\n     5\t/// Validates that a new event's sequence follows the last known sequence.\n     6\t/// The first event must have sequence 1.\n     7\tpub fn validate_sequence(last_sequence: u64, event: &JournalEvent) -> AppResult<()> {\n     8\t    let expected = last_sequence + 1;\n     9\t    if event.sequence != expected {\n    10\t        return Err(AppError::JournalSequence {\n    11\t            details: format!(\n    12\t                \"expected sequence {expected}, got {}\",\n    13\t                event.sequence\n    14\t            ),\n    15\t        });\n    16\t    }\n    17\t    Ok(())\n    18\t}\n    19\t\n    20\t/// Serializes a journal event to a single NDJSON line (no trailing newline).\n    21\tpub fn serialize_event(event: &JournalEvent) -> AppResult<String> {\n    22\t    Ok(serde_json::to_string(event)?)\n    23\t}\n    24\t\n    25\t/// Deserializes a single NDJSON line into a journal event.\n    26\tpub fn deserialize_event(line: &str) -> AppResult<JournalEvent> {\n    27\t    let trimmed = line.trim();\n    28\t    if trimmed.is_empty() {\n    29\t        return Err(AppError::CorruptRecord {\n    30\t            file: \"journal.ndjson\".to_owned(),\n    31\t            details: \"empty line in journal\".to_owned(),\n    32\t        });\n    33\t    }\n    34\t    serde_json::from_str(trimmed).map_err(|e| AppError::CorruptRecord {\n    35\t        file: \"journal.ndjson\".to_owned(),\n    36\t        details: format!(\"invalid journal event: {e}\"),\n    37\t    })\n    38\t}\n    39\t\n    40\t/// Parses the full contents of a journal.ndjson file into ordered events.\n    41\t/// Validates monotonic sequence ordering and journal integrity (first event\n    42\t/// must be `project_created` with sequence 1).\n    43\tpub fn parse_journal(contents: &str) -> AppResult<Vec<JournalEvent>> {\n    44\t    let mut events = Vec::new();\n    45\t    let mut last_sequence = 0u64;\n    46\t\n    47\t    for line in contents.lines() {\n    48\t        if line.trim().is_empty() {\n    49\t            continue;\n    50\t        }\n    51\t        let event = deserialize_event(line)?;\n    52\t        validate_sequence(last_sequence, &event)?;\n    53\t        last_sequence = event.sequence;\n    54\t        events.push(event);\n    55\t    }\n    56\t\n    57\t    validate_journal_integrity(&events)?;\n    58\t\n    59\t    Ok(events)\n    60\t}\n    61\t\n    62\t/// Validates that a journal has the required structure:\n    63\t/// - Must not be empty (must contain at least the initial `project_created` event)\n    64\t/// - First event must be `project_created` with sequence 1\n    65\tpub fn validate_journal_integrity(events: &[JournalEvent]) -> AppResult<()> {\n    66\t    if events.is_empty() {\n    67\t        return Err(AppError::CorruptRecord {\n    68\t            file: \"journal.ndjson\".to_owned(),\n    69\t            details: \"journal is empty — must contain at least the initial project_created event\"\n    70\t                .to_owned(),\n    71\t        });\n    72\t    }\n    73\t\n    74\t    let first = &events[0];\n    75\t    if first.event_type != JournalEventType::ProjectCreated {\n    76\t        return Err(AppError::CorruptRecord {\n    77\t            file: \"journal.ndjson\".to_owned(),\n    78\t            details: format!(\n    79\t                \"first journal event type is '{:?}', expected 'project_created'\",\n    80\t                first.event_type\n    81\t            ),\n    82\t        });\n    83\t    }\n    84\t\n    85\t    Ok(())\n    86\t}\n    87\t\n    88\t/// Returns the last sequence number from a set of events, or 0 if empty.\n    89\tpub fn last_sequence(events: &[JournalEvent]) -> u64 {\n    90\t    events.last().map_or(0, |e| e.sequence)\n    91\t}\n","exit_code":0,"status":"completed"}}
{"type":"item.completed","item":{"id":"item_20","type":"command_execution","command":"/run/current-system/sw/bin/bash -lc \"nl -ba /root/new-ralph-burning/ralph-burning-rewrite/src/contexts/project_run_record/model.rs | sed -n '1,340p'\"","aggregated_output":"     1\tuse chrono::{DateTime, Utc};\n     2\tuse serde::{Deserialize, Serialize};\n     3\t\n     4\tuse crate::shared::domain::{FlowPreset, ProjectId, StageCursor, StageId};\n     5\t\n     6\t/// Immutable project metadata persisted in `project.toml`.\n     7\t#[derive(Debug, Clone, PartialEq, Serialize, Deserialize)]\n     8\tpub struct ProjectRecord {\n     9\t    pub id: ProjectId,\n    10\t    pub name: String,\n    11\t    pub flow: FlowPreset,\n    12\t    pub prompt_reference: String,\n    13\t    pub prompt_hash: String,\n    14\t    pub created_at: DateTime<Utc>,\n    15\t    pub status_summary: ProjectStatusSummary,\n    16\t}\n    17\t\n    18\t#[derive(Debug, Clone, Copy, PartialEq, Eq, Serialize, Deserialize)]\n    19\t#[serde(rename_all = \"snake_case\")]\n    20\tpub enum ProjectStatusSummary {\n    21\t    Created,\n    22\t    Active,\n    23\t    Completed,\n    24\t    Failed,\n    25\t}\n    26\t\n    27\t/// Canonical run state persisted in `run.json`.\n    28\t/// This is the single source of truth for run progression - never inferred from artifacts.\n    29\t#[derive(Debug, Clone, PartialEq, Serialize, Deserialize)]\n    30\tpub struct RunSnapshot {\n    31\t    pub active_run: Option<ActiveRun>,\n    32\t    pub status: RunStatus,\n    33\t    pub cycle_history: Vec<CycleHistoryEntry>,\n    34\t    pub completion_rounds: u32,\n    35\t    pub rollback_point_meta: RollbackPointMeta,\n    36\t    pub amendment_queue: AmendmentQueueState,\n    37\t    pub status_summary: String,\n    38\t}\n    39\t\n    40\timpl RunSnapshot {\n    41\t    pub fn initial() -> Self {\n    42\t        Self {\n    43\t            active_run: None,\n    44\t            status: RunStatus::NotStarted,\n    45\t            cycle_history: Vec::new(),\n    46\t            completion_rounds: 0,\n    47\t            rollback_point_meta: RollbackPointMeta::default(),\n    48\t            amendment_queue: AmendmentQueueState::default(),\n    49\t            status_summary: \"not started\".to_owned(),\n    50\t        }\n    51\t    }\n    52\t\n    53\t    pub fn has_active_run(&self) -> bool {\n    54\t        self.active_run.is_some()\n    55\t    }\n    56\t\n    57\t    /// Semantic validation of run snapshot consistency.\n    58\t    /// Returns `Err` with a description if status and active_run are inconsistent.\n    59\t    pub fn validate_semantics(&self) -> Result<(), String> {\n    60\t        match (&self.status, &self.active_run) {\n    61\t            // Running or Paused requires an active run cursor\n    62\t            (RunStatus::Running, None) => Err(\n    63\t                \"status is 'running' but active_run is null — inconsistent canonical state\"\n    64\t                    .to_owned(),\n    65\t            ),\n    66\t            (RunStatus::Paused, None) => Err(\n    67\t                \"status is 'paused' but active_run is null — inconsistent canonical state\"\n    68\t                    .to_owned(),\n    69\t            ),\n    70\t            // NotStarted must not have an active run cursor\n    71\t            (RunStatus::NotStarted, Some(_)) => Err(\n    72\t                \"status is 'not_started' but active_run is present — inconsistent canonical state\"\n    73\t                    .to_owned(),\n    74\t            ),\n    75\t            // All other combinations are valid:\n    76\t            // NotStarted + None, Running/Paused + Some, Completed/Failed + None/Some\n    77\t            _ => Ok(()),\n    78\t        }\n    79\t    }\n    80\t}\n    81\t\n    82\t#[derive(Debug, Clone, PartialEq, Serialize, Deserialize)]\n    83\tpub struct ActiveRun {\n    84\t    pub run_id: String,\n    85\t    pub stage_cursor: StageCursor,\n    86\t    pub started_at: DateTime<Utc>,\n    87\t}\n    88\t\n    89\t#[derive(Debug, Clone, Copy, PartialEq, Eq, Serialize, Deserialize)]\n    90\t#[serde(rename_all = \"snake_case\")]\n    91\tpub enum RunStatus {\n    92\t    NotStarted,\n    93\t    Running,\n    94\t    Paused,\n    95\t    Completed,\n    96\t    Failed,\n    97\t}\n    98\t\n    99\timpl RunStatus {\n   100\t    /// Human-readable status string for CLI output.\n   101\t    pub fn display_str(self) -> &'static str {\n   102\t        match self {\n   103\t            Self::NotStarted => \"not started\",\n   104\t            Self::Running => \"running\",\n   105\t            Self::Paused => \"paused\",\n   106\t            Self::Completed => \"completed\",\n   107\t            Self::Failed => \"failed\",\n   108\t        }\n   109\t    }\n   110\t}\n   111\t\n   112\t/// A single entry in the cycle history tracking progression through work cycles.\n   113\t#[derive(Debug, Clone, PartialEq, Serialize, Deserialize)]\n   114\tpub struct CycleHistoryEntry {\n   115\t    pub cycle: u32,\n   116\t    pub stage_id: StageId,\n   117\t    pub started_at: DateTime<Utc>,\n   118\t    pub completed_at: Option<DateTime<Utc>>,\n   119\t}\n   120\t\n   121\t/// Rollback-point metadata tracked in the canonical run snapshot.\n   122\t#[derive(Debug, Clone, Default, PartialEq, Serialize, Deserialize)]\n   123\tpub struct RollbackPointMeta {\n   124\t    pub last_rollback_id: Option<String>,\n   125\t    pub rollback_count: u32,\n   126\t}\n   127\t\n   128\t/// Amendment queue state tracked in the canonical run snapshot.\n   129\t#[derive(Debug, Clone, Default, PartialEq, Serialize, Deserialize)]\n   130\tpub struct AmendmentQueueState {\n   131\t    pub pending: Vec<serde_json::Value>,\n   132\t    pub processed_count: u32,\n   133\t}\n   134\t\n   135\t/// A single journal event stored in `journal.ndjson`.\n   136\t#[derive(Debug, Clone, PartialEq, Serialize, Deserialize)]\n   137\tpub struct JournalEvent {\n   138\t    pub sequence: u64,\n   139\t    pub timestamp: DateTime<Utc>,\n   140\t    pub event_type: JournalEventType,\n   141\t    pub details: serde_json::Value,\n   142\t}\n   143\t\n   144\t#[derive(Debug, Clone, PartialEq, Eq, Serialize, Deserialize)]\n   145\t#[serde(rename_all = \"snake_case\")]\n   146\tpub enum JournalEventType {\n   147\t    ProjectCreated,\n   148\t    RunStarted,\n   149\t    StageEntered,\n   150\t    StageCompleted,\n   151\t    CycleAdvanced,\n   152\t    CompletionRoundAdvanced,\n   153\t    RunCompleted,\n   154\t    RunFailed,\n   155\t    RollbackCreated,\n   156\t    AmendmentQueued,\n   157\t}\n   158\t\n   159\t/// A durable history payload record stored in `history/payloads/`.\n   160\t#[derive(Debug, Clone, PartialEq, Serialize, Deserialize)]\n   161\tpub struct PayloadRecord {\n   162\t    pub payload_id: String,\n   163\t    pub stage_id: StageId,\n   164\t    pub cycle: u32,\n   165\t    pub attempt: u32,\n   166\t    pub created_at: DateTime<Utc>,\n   167\t    pub payload: serde_json::Value,\n   168\t}\n   169\t\n   170\t/// A durable history artifact record stored in `history/artifacts/`.\n   171\t#[derive(Debug, Clone, PartialEq, Serialize, Deserialize)]\n   172\tpub struct ArtifactRecord {\n   173\t    pub artifact_id: String,\n   174\t    pub payload_id: String,\n   175\t    pub stage_id: StageId,\n   176\t    pub created_at: DateTime<Utc>,\n   177\t    pub content: String,\n   178\t}\n   179\t\n   180\t/// A runtime log entry stored in `runtime/logs/`.\n   181\t#[derive(Debug, Clone, PartialEq, Serialize, Deserialize)]\n   182\tpub struct RuntimeLogEntry {\n   183\t    pub timestamp: DateTime<Utc>,\n   184\t    pub level: LogLevel,\n   185\t    pub source: String,\n   186\t    pub message: String,\n   187\t}\n   188\t\n   189\t#[derive(Debug, Clone, Copy, PartialEq, Eq, Serialize, Deserialize)]\n   190\t#[serde(rename_all = \"snake_case\")]\n   191\tpub enum LogLevel {\n   192\t    Debug,\n   193\t    Info,\n   194\t    Warn,\n   195\t    Error,\n   196\t}\n   197\t\n   198\t/// Rollback metadata stored in `rollback/`.\n   199\t#[derive(Debug, Clone, PartialEq, Serialize, Deserialize)]\n   200\tpub struct RollbackPoint {\n   201\t    pub rollback_id: String,\n   202\t    pub created_at: DateTime<Utc>,\n   203\t    pub stage_id: StageId,\n   204\t    pub cycle: u32,\n   205\t    pub run_snapshot: RunSnapshot,\n   206\t}\n   207\t\n   208\t/// Empty session store for `sessions.json`.\n   209\t#[derive(Debug, Clone, PartialEq, Serialize, Deserialize)]\n   210\tpub struct SessionStore {\n   211\t    pub sessions: Vec<serde_json::Value>,\n   212\t}\n   213\t\n   214\timpl SessionStore {\n   215\t    pub fn empty() -> Self {\n   216\t        Self {\n   217\t            sessions: Vec::new(),\n   218\t        }\n   219\t    }\n   220\t}\n   221\t\n   222\t/// Summary used in `project list` output.\n   223\t#[derive(Debug, Clone)]\n   224\tpub struct ProjectListEntry {\n   225\t    pub id: ProjectId,\n   226\t    pub name: String,\n   227\t    pub flow: FlowPreset,\n   228\t    pub status_summary: ProjectStatusSummary,\n   229\t    pub created_at: DateTime<Utc>,\n   230\t    pub is_active: bool,\n   231\t}\n   232\t\n   233\t/// Detailed project view used in `project show` output.\n   234\t#[derive(Debug, Clone)]\n   235\tpub struct ProjectDetail {\n   236\t    pub record: ProjectRecord,\n   237\t    pub run_snapshot: RunSnapshot,\n   238\t    pub journal_event_count: u64,\n   239\t    pub rollback_count: usize,\n   240\t    pub is_active: bool,\n   241\t}\n","exit_code":0,"status":"completed"}}
{"type":"item.completed","item":{"id":"item_21","type":"command_execution","command":"/run/current-system/sw/bin/bash -lc \"nl -ba /root/new-ralph-burning/ralph-burning-rewrite/src/adapters/fs.rs | sed -n '1,420p'\"","aggregated_output":"     1\tuse std::env;\n     2\tuse std::fs::{self, OpenOptions};\n     3\tuse std::io::Write;\n     4\tuse std::path::{Path, PathBuf};\n     5\tuse std::process::Command;\n     6\tuse std::time::{SystemTime, UNIX_EPOCH};\n     7\t\n     8\tuse crate::contexts::project_run_record::journal;\n     9\tuse crate::contexts::project_run_record::model::{\n    10\t    ArtifactRecord, JournalEvent, PayloadRecord, ProjectRecord, RunSnapshot,\n    11\t    RuntimeLogEntry, SessionStore,\n    12\t};\n    13\tuse crate::contexts::project_run_record::service::{\n    14\t    ActiveProjectPort, ArtifactStorePort, JournalStorePort, ProjectStorePort,\n    15\t    RuntimeLogStorePort, RunSnapshotPort,\n    16\t};\n    17\tuse crate::shared::domain::{ProjectId, WorkspaceConfig};\n    18\tuse crate::shared::error::{AppError, AppResult};\n    19\t\n    20\tconst ACTIVE_PROJECT_FILE: &str = \"active-project\";\n    21\tconst WORKSPACE_DIR: &str = \".ralph-burning\";\n    22\tconst PROJECTS_DIR: &str = \"projects\";\n    23\tconst PROJECT_CONFIG_FILE: &str = \"project.toml\";\n    24\tconst RUN_FILE: &str = \"run.json\";\n    25\tconst JOURNAL_FILE: &str = \"journal.ndjson\";\n    26\tconst SESSIONS_FILE: &str = \"sessions.json\";\n    27\tconst PROMPT_FILE: &str = \"prompt.md\";\n    28\t\n    29\t/// Required subdirectories inside a project.\n    30\tconst PROJECT_SUBDIRS: &[&str] = &[\n    31\t    \"history/payloads\",\n    32\t    \"history/artifacts\",\n    33\t    \"runtime/logs\",\n    34\t    \"runtime/backend\",\n    35\t    \"runtime/temp\",\n    36\t    \"amendments\",\n    37\t    \"rollback\",\n    38\t];\n    39\t\n    40\tpub struct FileSystem;\n    41\t\n    42\timpl FileSystem {\n    43\t    pub fn create_workspace(\n    44\t        workspace_root: &Path,\n    45\t        workspace_config: &str,\n    46\t        required_directories: &[&str],\n    47\t    ) -> AppResult<()> {\n    48\t        fs::create_dir_all(workspace_root)?;\n    49\t\n    50\t        for directory in required_directories {\n    51\t            fs::create_dir_all(workspace_root.join(directory))?;\n    52\t        }\n    53\t\n    54\t        Self::write_atomic(&workspace_root.join(\"workspace.toml\"), workspace_config)?;\n    55\t        Ok(())\n    56\t    }\n    57\t\n    58\t    pub fn read_to_string(path: &Path) -> AppResult<String> {\n    59\t        Ok(fs::read_to_string(path)?)\n    60\t    }\n    61\t\n    62\t    pub fn write_atomic(path: &Path, contents: &str) -> AppResult<()> {\n    63\t        let parent = path.parent().ok_or_else(|| {\n    64\t            AppError::Io(std::io::Error::new(\n    65\t                std::io::ErrorKind::InvalidInput,\n    66\t                format!(\"path '{}' has no parent directory\", path.display()),\n    67\t            ))\n    68\t        })?;\n    69\t        fs::create_dir_all(parent)?;\n    70\t\n    71\t        let timestamp = SystemTime::now()\n    72\t            .duration_since(UNIX_EPOCH)\n    73\t            .map(|duration| duration.as_nanos())\n    74\t            .unwrap_or_default();\n    75\t        let temp_path = parent.join(format!(\n    76\t            \".{}.{}.{}.tmp\",\n    77\t            path.file_name()\n    78\t                .and_then(|value| value.to_str())\n    79\t                .unwrap_or(\"workspace\"),\n    80\t            std::process::id(),\n    81\t            timestamp\n    82\t        ));\n    83\t\n    84\t        let mut file = OpenOptions::new()\n    85\t            .create_new(true)\n    86\t            .write(true)\n    87\t            .open(&temp_path)?;\n    88\t        file.write_all(contents.as_bytes())?;\n    89\t        file.sync_all()?;\n    90\t        drop(file);\n    91\t\n    92\t        if let Err(error) = fs::rename(&temp_path, path) {\n    93\t            let _ = fs::remove_file(&temp_path);\n    94\t            return Err(error.into());\n    95\t        }\n    96\t\n    97\t        Ok(())\n    98\t    }\n    99\t\n   100\t    pub fn render_workspace_config(config: &WorkspaceConfig) -> AppResult<String> {\n   101\t        Ok(toml::to_string_pretty(config)?)\n   102\t    }\n   103\t\n   104\t    pub fn read_active_project(workspace_root: &Path) -> AppResult<Option<String>> {\n   105\t        let path = workspace_root.join(ACTIVE_PROJECT_FILE);\n   106\t        match fs::read_to_string(path) {\n   107\t            Ok(raw) => {\n   108\t                let trimmed = raw.trim();\n   109\t                if trimmed.is_empty() {\n   110\t                    Ok(None)\n   111\t                } else {\n   112\t                    Ok(Some(trimmed.to_owned()))\n   113\t                }\n   114\t            }\n   115\t            Err(error) if error.kind() == std::io::ErrorKind::NotFound => Ok(None),\n   116\t            Err(error) => Err(error.into()),\n   117\t        }\n   118\t    }\n   119\t\n   120\t    pub fn write_active_project(workspace_root: &Path, project_id: &str) -> AppResult<()> {\n   121\t        Self::write_atomic(&workspace_root.join(ACTIVE_PROJECT_FILE), project_id)\n   122\t    }\n   123\t\n   124\t    pub fn open_editor(path: &Path) -> AppResult<()> {\n   125\t        let editor = env::var(\"EDITOR\")\n   126\t            .ok()\n   127\t            .filter(|value| !value.trim().is_empty())\n   128\t            .or_else(|| {\n   129\t                env::var(\"VISUAL\")\n   130\t                    .ok()\n   131\t                    .filter(|value| !value.trim().is_empty())\n   132\t            })\n   133\t            .unwrap_or_else(|| \"vi\".to_owned());\n   134\t\n   135\t        let mut parts = editor.split_whitespace();\n   136\t        let program = parts.next().ok_or_else(|| AppError::EditorFailed {\n   137\t            editor: editor.clone(),\n   138\t            details: \": empty editor command\".to_owned(),\n   139\t        })?;\n   140\t        let status = Command::new(program).args(parts).arg(path).status()?;\n   141\t\n   142\t        if status.success() {\n   143\t            Ok(())\n   144\t        } else {\n   145\t            let details = match status.code() {\n   146\t                Some(code) => format!(\" with exit code {code}\"),\n   147\t                None => \" after being terminated by a signal\".to_owned(),\n   148\t            };\n   149\t            Err(AppError::EditorFailed { editor, details })\n   150\t        }\n   151\t    }\n   152\t\n   153\t    /// Compute a simple hash of content for prompt integrity tracking.\n   154\t    pub fn prompt_hash(contents: &str) -> String {\n   155\t        use std::collections::hash_map::DefaultHasher;\n   156\t        use std::hash::{Hash, Hasher};\n   157\t        let mut hasher = DefaultHasher::new();\n   158\t        contents.hash(&mut hasher);\n   159\t        format!(\"{:016x}\", hasher.finish())\n   160\t    }\n   161\t\n   162\t    // ── Helpers for project filesystem layout ──\n   163\t\n   164\t    fn workspace_root_path(base_dir: &Path) -> PathBuf {\n   165\t        base_dir.join(WORKSPACE_DIR)\n   166\t    }\n   167\t\n   168\t    fn project_root(base_dir: &Path, project_id: &ProjectId) -> PathBuf {\n   169\t        Self::workspace_root_path(base_dir)\n   170\t            .join(PROJECTS_DIR)\n   171\t            .join(project_id.as_str())\n   172\t    }\n   173\t\n   174\t    fn pending_delete_path(base_dir: &Path, project_id: &ProjectId) -> PathBuf {\n   175\t        Self::workspace_root_path(base_dir)\n   176\t            .join(PROJECTS_DIR)\n   177\t            .join(format!(\".{}.pending-delete\", project_id))\n   178\t    }\n   179\t\n   180\t    fn append_line(path: &Path, line: &str) -> AppResult<()> {\n   181\t        let parent = path.parent().ok_or_else(|| {\n   182\t            AppError::Io(std::io::Error::new(\n   183\t                std::io::ErrorKind::InvalidInput,\n   184\t                format!(\"path '{}' has no parent directory\", path.display()),\n   185\t            ))\n   186\t        })?;\n   187\t        fs::create_dir_all(parent)?;\n   188\t\n   189\t        let mut file = OpenOptions::new()\n   190\t            .create(true)\n   191\t            .append(true)\n   192\t            .open(path)?;\n   193\t        writeln!(file, \"{}\", line)?;\n   194\t        file.sync_all()?;\n   195\t        Ok(())\n   196\t    }\n   197\t}\n   198\t\n   199\t/// Filesystem-backed implementation of `ProjectStorePort`.\n   200\tpub struct FsProjectStore;\n   201\t\n   202\timpl ProjectStorePort for FsProjectStore {\n   203\t    fn project_exists(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<bool> {\n   204\t        let project_root = FileSystem::project_root(base_dir, project_id);\n   205\t        if !project_root.is_dir() {\n   206\t            return Ok(false);\n   207\t        }\n   208\t        if !project_root.join(PROJECT_CONFIG_FILE).is_file() {\n   209\t            return Err(AppError::CorruptRecord {\n   210\t                file: format!(\"projects/{}/project.toml\", project_id),\n   211\t                details: \"project directory exists but canonical project.toml is missing\"\n   212\t                    .to_owned(),\n   213\t            });\n   214\t        }\n   215\t        Ok(true)\n   216\t    }\n   217\t\n   218\t    fn read_project_record(\n   219\t        &self,\n   220\t        base_dir: &Path,\n   221\t        project_id: &ProjectId,\n   222\t    ) -> AppResult<ProjectRecord> {\n   223\t        let project_root = FileSystem::project_root(base_dir, project_id);\n   224\t        let path = project_root.join(PROJECT_CONFIG_FILE);\n   225\t        let raw = fs::read_to_string(&path).map_err(|e| {\n   226\t            if e.kind() == std::io::ErrorKind::NotFound {\n   227\t                if project_root.is_dir() {\n   228\t                    // Directory exists but project.toml is missing — corruption\n   229\t                    AppError::CorruptRecord {\n   230\t                        file: format!(\"projects/{}/project.toml\", project_id),\n   231\t                        details: \"project directory exists but canonical project.toml is missing\"\n   232\t                            .to_owned(),\n   233\t                    }\n   234\t                } else {\n   235\t                    AppError::ProjectNotFound {\n   236\t                        project_id: project_id.to_string(),\n   237\t                    }\n   238\t                }\n   239\t            } else {\n   240\t                e.into()\n   241\t            }\n   242\t        })?;\n   243\t        toml::from_str(&raw).map_err(|e| AppError::CorruptRecord {\n   244\t            file: format!(\"projects/{}/project.toml\", project_id),\n   245\t            details: e.to_string(),\n   246\t        })\n   247\t    }\n   248\t\n   249\t    fn list_project_ids(&self, base_dir: &Path) -> AppResult<Vec<ProjectId>> {\n   250\t        let projects_dir = FileSystem::workspace_root_path(base_dir).join(PROJECTS_DIR);\n   251\t        if !projects_dir.is_dir() {\n   252\t            return Ok(Vec::new());\n   253\t        }\n   254\t\n   255\t        let mut ids = Vec::new();\n   256\t        for entry in fs::read_dir(&projects_dir)? {\n   257\t            let entry = entry?;\n   258\t            if !entry.file_type()?.is_dir() {\n   259\t                continue;\n   260\t            }\n   261\t            let name = entry.file_name();\n   262\t            let name_str = name.to_string_lossy();\n   263\t            // Skip hidden directories (staging/trash from transactional operations)\n   264\t            if name_str.starts_with('.') {\n   265\t                continue;\n   266\t            }\n   267\t            if let Ok(pid) = ProjectId::new(name_str.as_ref()) {\n   268\t                if !entry.path().join(PROJECT_CONFIG_FILE).is_file() {\n   269\t                    return Err(AppError::CorruptRecord {\n   270\t                        file: format!(\"projects/{}/project.toml\", name_str),\n   271\t                        details:\n   272\t                            \"project directory exists but canonical project.toml is missing\"\n   273\t                                .to_owned(),\n   274\t                    });\n   275\t                }\n   276\t                ids.push(pid);\n   277\t            }\n   278\t        }\n   279\t\n   280\t        ids.sort_by(|a, b| a.as_str().cmp(b.as_str()));\n   281\t        Ok(ids)\n   282\t    }\n   283\t\n   284\t    fn stage_delete(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<()> {\n   285\t        let project_root = FileSystem::project_root(base_dir, project_id);\n   286\t        if !project_root.is_dir() {\n   287\t            return Err(AppError::ProjectNotFound {\n   288\t                project_id: project_id.to_string(),\n   289\t            });\n   290\t        }\n   291\t\n   292\t        let pending_path = FileSystem::pending_delete_path(base_dir, project_id);\n   293\t\n   294\t        // Clean up any leftover pending-delete from a previous crash\n   295\t        if pending_path.exists() {\n   296\t            fs::remove_dir_all(&pending_path)?;\n   297\t        }\n   298\t\n   299\t        // Atomic rename to pending-delete location — project becomes\n   300\t        // invisible to list/show but data stays on disk.\n   301\t        fs::rename(&project_root, &pending_path)?;\n   302\t        Ok(())\n   303\t    }\n   304\t\n   305\t    fn commit_delete(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<()> {\n   306\t        let pending_path = FileSystem::pending_delete_path(base_dir, project_id);\n   307\t        if pending_path.is_dir() {\n   308\t            fs::remove_dir_all(&pending_path)?;\n   309\t        }\n   310\t        Ok(())\n   311\t    }\n   312\t\n   313\t    fn rollback_delete(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<()> {\n   314\t        let project_root = FileSystem::project_root(base_dir, project_id);\n   315\t        let pending_path = FileSystem::pending_delete_path(base_dir, project_id);\n   316\t\n   317\t        if !pending_path.is_dir() {\n   318\t            return Ok(());\n   319\t        }\n   320\t\n   321\t        fs::rename(&pending_path, &project_root)?;\n   322\t        Ok(())\n   323\t    }\n   324\t\n   325\t    fn create_project_atomic(\n   326\t        &self,\n   327\t        base_dir: &Path,\n   328\t        record: &ProjectRecord,\n   329\t        prompt_contents: &str,\n   330\t        run_snapshot: &RunSnapshot,\n   331\t        initial_journal_line: &str,\n   332\t        sessions: &SessionStore,\n   333\t    ) -> AppResult<()> {\n   334\t        let project_root = FileSystem::project_root(base_dir, &record.id);\n   335\t\n   336\t        // Stage into a temporary directory alongside the final location\n   337\t        let staging_name = format!(\".{}.staging.{}\", record.id, std::process::id());\n   338\t        let staging_root = project_root\n   339\t            .parent()\n   340\t            .expect(\"project root has parent\")\n   341\t            .join(&staging_name);\n   342\t\n   343\t        // Clean up any leftover staging dir\n   344\t        if staging_root.exists() {\n   345\t            fs::remove_dir_all(&staging_root)?;\n   346\t        }\n   347\t\n   348\t        // Create staging directory and all subdirs\n   349\t        fs::create_dir_all(&staging_root)?;\n   350\t        for subdir in PROJECT_SUBDIRS {\n   351\t            fs::create_dir_all(staging_root.join(subdir))?;\n   352\t        }\n   353\t\n   354\t        // Write all canonical files into staging\n   355\t        let write_result = (|| -> AppResult<()> {\n   356\t            // project.toml\n   357\t            let project_toml = toml::to_string_pretty(record).map_err(|e| {\n   358\t                AppError::Io(std::io::Error::other(e.to_string()))\n   359\t            })?;\n   360\t            fs::write(staging_root.join(PROJECT_CONFIG_FILE), project_toml)?;\n   361\t\n   362\t            // prompt.md\n   363\t            fs::write(staging_root.join(PROMPT_FILE), prompt_contents)?;\n   364\t\n   365\t            // run.json\n   366\t            let run_json = serde_json::to_string_pretty(run_snapshot)?;\n   367\t            fs::write(staging_root.join(RUN_FILE), run_json)?;\n   368\t\n   369\t            // journal.ndjson (with initial event)\n   370\t            let mut journal_content = initial_journal_line.to_owned();\n   371\t            journal_content.push('\\n');\n   372\t            fs::write(staging_root.join(JOURNAL_FILE), journal_content)?;\n   373\t\n   374\t            // sessions.json\n   375\t            let sessions_json = serde_json::to_string_pretty(sessions)?;\n   376\t            fs::write(staging_root.join(SESSIONS_FILE), sessions_json)?;\n   377\t\n   378\t            Ok(())\n   379\t        })();\n   380\t\n   381\t        if let Err(e) = write_result {\n   382\t            // Clean up staging on failure\n   383\t            let _ = fs::remove_dir_all(&staging_root);\n   384\t            return Err(e);\n   385\t        }\n   386\t\n   387\t        // Atomic rename from staging to final location\n   388\t        if let Err(e) = fs::rename(&staging_root, &project_root) {\n   389\t            let _ = fs::remove_dir_all(&staging_root);\n   390\t            return Err(e.into());\n   391\t        }\n   392\t\n   393\t        Ok(())\n   394\t    }\n   395\t}\n   396\t\n   397\t/// Filesystem-backed implementation of `JournalStorePort`.\n   398\tpub struct FsJournalStore;\n   399\t\n   400\timpl JournalStorePort for FsJournalStore {\n   401\t    fn read_journal(\n   402\t        &self,\n   403\t        base_dir: &Path,\n   404\t        project_id: &ProjectId,\n   405\t    ) -> AppResult<Vec<JournalEvent>> {\n   406\t        let path = FileSystem::project_root(base_dir, project_id).join(JOURNAL_FILE);\n   407\t        match fs::read_to_string(&path) {\n   408\t            Ok(contents) => journal::parse_journal(&contents),\n   409\t            Err(e) if e.kind() == std::io::ErrorKind::NotFound => {\n   410\t                Err(AppError::CorruptRecord {\n   411\t                    file: format!(\"projects/{}/journal.ndjson\", project_id),\n   412\t                    details: \"canonical file is missing\".to_owned(),\n   413\t                })\n   414\t            }\n   415\t            Err(e) => Err(e.into()),\n   416\t        }\n   417\t    }\n   418\t\n   419\t    fn append_event(\n   420\t        &self,\n","exit_code":0,"status":"completed"}}
