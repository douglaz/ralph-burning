n   267\t}\n   268\t\n   269\tasync fn handle_history() -> AppResult<()> {\n   270\t    let current_dir = std::env::current_dir()?;\n   271\t\n   272\t    let config = workspace_governance::load_workspace_config(&current_dir)?;\n   273\t    workspace_governance::ensure_supported_workspace_version(&config)?;\n   274\t\n   275\t    let project_id = workspace_governance::resolve_active_project(&current_dir)?;\n   276\t\n   277\t    // Validate canonical project record before proceeding with run queries\n   278\t    let project_store = FsProjectStore;\n   279\t    let _ = project_store.read_project_record(&current_dir, &project_id)?;\n   280\t\n   281\t    let journal_store = FsJournalStore;\n   282\t    let artifact_store = FsArtifactStore;\n   283\t\n   284\t    let history = service::run_history(&journal_store, &artifact_store, &current_dir, &project_id)?;\n   285\t\n   286\t    println!(\"Project: {}\", history.project_id);\n   287\t    println!(\"--- Journal Events ---\");\n   288\t    for event in &history.events {\n   289\t        println!(\n   290\t            \"  [{}] {} - {:?}\",\n   291\t            event.sequence, event.timestamp, event.event_type\n   292\t        );\n   293\t    }\n   294\t\n   295\t    if !history.payloads.is_empty() {\n   296\t        println!(\"--- Payloads ---\");\n   297\t        for payload in &history.payloads {\n   298\t            println!(\n   299\t                \"  {} ({}, cycle {}, attempt {})\",\n   300\t                payload.payload_id, payload.stage_id, payload.cycle, payload.attempt\n   301\t            );\n   302\t        }\n   303\t    }\n   304\t\n   305\t    if !history.artifacts.is_empty() {\n   306\t        println!(\"--- Artifacts ---\");\n   307\t        for artifact in &history.artifacts {\n   308\t            println!(\n   309\t                \"  {} (payload: {}, stage: {})\",\n   310\t                artifact.artifact_id, artifact.payload_id, artifact.stage_id\n   311\t            );\n   312\t        }\n   31