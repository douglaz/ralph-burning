  57\tconst FLOW_DEFINITIONS: [FlowDefinition; 4] = [\n    58\t    FlowDefinition {\n    59\t        preset: FlowPreset::Standard,\n    60\t        description:\n    61\t            \"Full delivery flow with planning, implementation, QA, review, and acceptance.\",\n    62\t        stages: &STANDARD_STAGES,\n    63\t        validation_profile: ValidationProfile {\n    64\t            name: \"standard-default\",\n    65\t            summary: \"Full validation suite with completion and acceptance checks.\",\n    66\t            final_review_enabled: true,\n    67\t        },\n    68\t    },\n    69\t    FlowDefinition {\n    70\t        preset: FlowPreset::QuickDev,\n    71\t        description: \"Fast delivery flow for small code changes with lightweight review.\",\n    72\t        stages: &QUICK_DEV_STAGES,\n    73\t        validation_profile: ValidationProfile {\n    74\t            name: \"quick-dev-default\",\n    75\t            summary: \"Lightweight panel with final review enabled by default.\",\n    76\t            final_review_enabled: true,\n    77\t        },\n    78\t    },\n    79\t    FlowDefinition {\n    80\t        preset: FlowPreset::DocsChange,\n    81\t        description: \"Documentation-focused flow for planning, content updates, and validation.\",\n    82\t        stages: &DOCS_CHANGE_STAGES,\n    83\t        validation_profile: ValidationProfile {\n    84\t            name: \"docs-default\",\n    85\t            summary: \"Documentation validation with final review disabled by default.\",\n    86\t            final_review_enabled: false,\n    87\t        },\n    88\t    },\n    89\t    FlowDefinition {\n    90\t        preset: FlowPreset::CiImprovement,\n    91\t        description: \"CI improvement flow for automation planning, updates, and validation.\",\n    92\t        stages: &CI_IMPROVEMENT_STAGES,\n    93\t        validation_profile: ValidationProfile {\n    94\t            name: \"ci-default\",\n    95\t            summary: \"Automation