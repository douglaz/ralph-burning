ery stage target.\n    87\tpub async fn preflight_check<A: AgentExecutionPort>(\n    88\t    adapter: &A,\n    89\t    plan: &[StagePlan],\n    90\t) -> AppResult<()> {\n    91\t    for entry in plan {\n    92\t        adapter\n    93\t            .check_capability(&entry.target, &entry.contract)\n    94\t            .await\n    95\t            .map_err(|e| AppError::PreflightFailed {\n    96\t                stage_id: entry.stage_id,\n    97\t                details: e.to_string(),\n    98\t            })?;\n    99\t        adapter\n   100\t            .check_availability(&entry.target)\n   101\t            .await\n   102\t            .map_err(|e| AppError::PreflightFailed {\n   103\t                stage_id: entry.stage_id,\n   104\t                details: e.to_string(),\n   105\t            })?;\n   106\t    }\n   107\t    Ok(())\n   108\t}\n   109\t\n   110\t/// Generate a new run ID from a timestamp.\n   111\tfn generate_run_id() -> AppResult<RunId> {\n   112\t    let now = Utc::now();\n   113\t    RunId::new(format!(\"run-{}\", now.format(\"%Y%m%d%H%M%S\")))\n   114\t}\n   115\t\n   116\t#[derive(Debug, Clone, Copy)]\n   117\tenum ExecutionOrigin {\n   118\t    Start,\n   119\t    Resume,\n   120\t}\n   121\t\n   122\timpl ExecutionOrigin {\n   123\t    fn error(self, reason: String) -> AppError {\n   124\t        match self {\n   125\t            Self::Start => AppError::RunStartFailed { reason },\n   126\t            Self::Resume => AppError::ResumeFailed { reason },\n   127\t        }\n   128\t    }\n   129\t}\n   130\t\n   131\t#[derive(Debug, Clone, Copy, PartialEq, Eq)]\n   132\tenum RunOutcome {\n   133\t    Completed,\n   134\t    Paused,\n   135\t}\n   136\t\n   137\t#[derive(Debug)]\n   138\tstruct ResumeState {\n   139\t    run_id: RunId,\n   140\t    started_at: DateTime<Utc>,\n   141\t    stage_index: usize,\n   142\t    cursor: StageCursor,\n   143\t}\n   144\t\n   145\t/// The standard-flow orchestration engine.\n   146\t#[allow(clippy::too_man