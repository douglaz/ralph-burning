{"type":"item.completed","item":{"id":"item_25","type":"command_execution","command":"/run/current-system/sw/bin/bash -lc \"nl -ba ralph-burning-rewrite/tests/unit/adapter_contract_test.rs | sed -n '960,1165p'\"","aggregated_output":"   960\t    let loaded = store.read_project_record(tmp.path(), &pid).unwrap();\n   961\t    assert_eq!(loaded.prompt_reference, \"prompt.md\");\n   962\t}\n   963\t\n   964\t// ── FsAmendmentQueueStore ──\n   965\t\n   966\tuse ralph_burning::contexts::project_run_record::service::AmendmentQueuePort;\n   967\t\n   968\tfn make_amendment(id: &str, stage: ralph_burning::shared::domain::StageId) -> QueuedAmendment {\n   969\t    QueuedAmendment {\n   970\t        amendment_id: id.to_owned(),\n   971\t        source_stage: stage,\n   972\t        source_cycle: 1,\n   973\t        source_completion_round: 1,\n   974\t        body: format!(\"Fix issue from {id}\"),\n   975\t        created_at: test_timestamp(),\n   976\t        batch_sequence: 1,\n   977\t    }\n   978\t}\n   979\t\n   980\tfn make_amendment_with_seq(\n   981\t    id: &str,\n   982\t    stage: ralph_burning::shared::domain::StageId,\n   983\t    seq: u32,\n   984\t) -> QueuedAmendment {\n   985\t    QueuedAmendment {\n   986\t        amendment_id: id.to_owned(),\n   987\t        source_stage: stage,\n   988\t        source_cycle: 1,\n   989\t        source_completion_round: 1,\n   990\t        body: format!(\"Fix issue from {id}\"),\n   991\t        created_at: test_timestamp(),\n   992\t        batch_sequence: seq,\n   993\t    }\n   994\t}\n   995\t\n   996\t#[test]\n   997\tfn amendment_queue_write_and_list_round_trip() {\n   998\t    let tmp = tempdir().unwrap();\n   999\t    setup_workspace(tmp.path());\n  1000\t    create_project_on_disk(tmp.path(), \"alpha\");\n  1001\t\n  1002\t    let store = FsAmendmentQueueStore;\n  1003\t    let pid = ProjectId::new(\"alpha\").unwrap();\n  1004\t    let amendment = make_amendment(\"amend-001\", ralph_burning::shared::domain::Stage