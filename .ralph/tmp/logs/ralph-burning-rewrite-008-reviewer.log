ment(\"amend-001\", ralph_burning::shared::domain::StageId::CompletionPanel);\n  1051\t    let mut a2 = make_amendment(\"amend-002\", ralph_burning::shared::domain::StageId::CompletionPanel);\n  1052\t    // Offset timestamp so sort is deterministic\n  1053\t    a2.created_at = test_timestamp() + chrono::Duration::seconds(1);\n  1054\t\n  1055\t    store.write_amendment(tmp.path(), &pid, &a1).unwrap();\n  1056\t    store.write_amendment(tmp.path(), &pid, &a2).unwrap();\n  1057\t\n  1058\t    store.remove_amendment(tmp.path(), &pid, \"amend-001\").unwrap();\n  1059\t\n  1060\t    let pending = store.list_pending_amendments(tmp.path(), &pid).unwrap();\n  1061\t    assert_eq!(pending.len(), 1);\n  1062\t    assert_eq!(pending[0].amendment_id, \"amend-002\");\n  1063\t}\n  1064\t\n  1065\t#[test]\n  1066\tfn amendment_queue_remove_nonexistent_is_ok() {\n  1067\t    let tmp = tempdir().unwrap();\n  1068\t    setup_workspace(tmp.path());\n  1069\t    create_project_on_disk(tmp.path(), \"alpha\");\n  1070\t\n  1071\t    let store = FsAmendmentQueueStore;\n  1072\t    let pid = ProjectId::new(\"alpha\").unwrap();\n  1073\t\n  1074\t    // Removing non-existent amendment should succeed\n  1075\t    store.remove_amendment(tmp.path(), &pid, \"nonexistent\").unwrap();\n  1076\t}\n  1077\t\n  1078\t#[test]\n  1079\tfn amendment_queue_drain_removes_all_and_returns_count() {\n  1080\t    let tmp = tempdir().unwrap();\n  1081\t    setup_workspace(tmp.path());\n  1082\t    create_project_on_disk(tmp.path(), \"alpha\");\n  1083\t\n  1084\t    let store = FsAmendmentQueueStore;\n  1085\t    let pid = ProjectId::new(\"alpha\").unwrap();\n  1086\t\n  1087\t    let a1 = make_amendment(\"amend-001\", ralph_burning::shared::domain::StageId::CompletionPanel);\n  1088\t    let a2 = make_amendment(\"amend-002\", ralph_burning::shared::domain::StageId::AcceptanceQa);\n  1089\t    store.write_amendment(tmp.path(), &pid, &a1).unwrap();\n  1090\t    store.write_amendment(tmp.path(), &pid, &a2).un