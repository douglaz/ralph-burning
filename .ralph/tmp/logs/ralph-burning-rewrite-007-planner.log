{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016g7LyyviydGSawkEcorAse","type":"tool_result","content":"   300→            invocation_id,\n   301→            project_root: project_root.clone(),\n   302→            stage_contract: stage_entry.contract,\n   303→            role: stage_entry.role,\n   304→            resolved_target: stage_entry.target.clone(),\n   305→            payload: InvocationPayload {\n   306→                prompt: format!(\"Execute stage: {}\", stage_id.display_name()),\n   307→                context: serde_json::json!({}),\n   308→            },\n   309→            timeout: Duration::from_secs(300),\n   310→            cancellation_token: CancellationToken::new(),\n   311→            session_policy: SessionPolicy::ReuseIfAllowed,\n   312→            prior_session: None,\n   313→            attempt_number: cursor.attempt,\n   314→        };\n   315→\n   316→        let envelope = match agent_service.invoke(request).await {\n   317→            Ok(env) => env,\n   318→            Err(e) => {\n   319→                return fail_run(\n   320→                    &e,\n   321→                    stage_id,\n   322→                    &run_id,\n   323→                    &mut seq,\n   324→                    &mut current_snapshot,\n   325→                    journal_store,\n   326→                    run_snapshot_write,\n   327→                    base_dir,\n   328→                    project_id,\n   329→                )\n   330→                .await;\n   331→            }\n   332→        };\n   333→\n   334→        // Evaluate the contract (schema + domain + outcome + render)\n   335→        let bundle = match stage_entry.contract.evaluate(&envelope.parsed_payload) {\n   336→            Ok(bundle) => bundle,\n   337→            Err(contract_err) => {\n   338→                let app_err = AppError::InvocationFailed {\n   339→                    backend: stage_entry.target.backend.family.to_string(),\n   340→                    stage_id,\n   341→                    failure_class: contract_err.failure_class(),\n   342→                    details: contract_err.to_string(),\n   343→                };\n   344→                return fail_run(\n   345→                    &app_err,\n   346→                    stage_id,\n   347→                    &run_id,\n   348→                    &mut seq,\n   349→                    &mut current_snapshot,\n   350→                    journal_store,\n   351→                    run_snapshot_write,\n   352→                    base_dir,\n   353→                    project_id,\n   354→                )\n   355→                .await;\n   356→            }\n   357→        };\n   358→\n   359→        // Persist payload + artifact pair atomically\n   360→        let stage_now = Utc::now();\n   361→        let payload_id = format!(\n   362→            \"{}-{}-c{}-a{}\",\n   363→            run_id.as_str(),\n   364→            stage_id.as_str(),\n   365→            cursor.cycle,\n   366→            cursor.attempt\n   367→        );\n   368→        let artifact_id = format!(\"{}-artifact\", payload_id);\n   369→\n   370→        let payload_record = PayloadRecord {\n   371→            payload_id: payload_id.clone(),\n   372→            stage_id,\n   373→            cycle: cursor.cycle,\n   374→            attempt: cursor.attempt,\n   375→            created_at: stage_now,\n   376→            payload: serde_json::to_value(&bundle.payload)?,\n   377→        };\n   378→        let artifact_record = ArtifactRecord {\n   379→            artifact_id: artifact_id.clone(),\n   380→            payload_id: payload_id.clone(),\n   381→            stage_id,\n   382→            created_at: stage_now,\n   383→            content: bundle.artifact.clone(),\n   384→        };\n   385→\n   386→        // Atomic stage commit: payload + artifact + snapshot + journal.\n   387→        // All four must succeed for the stage to become durably visible.\n   388→        // Order: payload/artifact → snapshot cursor → stage_completed journal.\n   389→        // This ensures that if any step fails, no stage_completed event leaks\n   390→        // into the journal without a matching snapshot and durable files.\n   391→\n   392→        // Step 1: Write payload + artifact pair.\n   393→        // If this fails after stage_entered, the run must persist failed state.\n   394→        // The fs adapter uses staging + rename so canonical files only appear on\n   395→        // full success, but as defense-in-depth we also call remove_payload_artifact_pair\n   396→        // to clean up any orphaned canonical files before failing the run.\n   397→        if let Err(e) =\n   398→            artifact_write.write_payload_artifact_pair(base_dir, project_id, &payload_record, &artifact_record)\n   399→        {\n   400→            // Defense-in-depth: remove any leaked canonical files.\n   401→            let _ = artifact_write.remove_payload_artifact_pair(\n   402→                base_dir,\n   403→                project_id,\n   404→                &payload_id,\n   405→                &artifact_id,\n   406→            );\n   407→            let commit_err = AppError::StageCommitFailed {\n   408→                stage_id,\n   409→                details: format!(\"payload/artifact persistence failed: {}\", e),\n   410→            };\n   411→            return fail_run(\n   412→                &commit_err,\n   413→                stage_id,\n   414→                &run_id,\n   415→                &mut seq,\n   416→                &mut current_snapshot,\n   417→                journal_store,\n   418→                run_snapshot_write,\n   419→                base_dir,\n   420→                project_id,\n   421→            )\n   422→            .await;\n   423→        }\n   424→\n   425→        // Step 2: Update snapshot cursor to reflect completed stage.\n   426→        // Written BEFORE stage_completed journal so that snapshot failure\n   427→        // never leaves a stage_completed event without a matching cursor.\n   428→        let pre_commit_snapshot = current_snapshot.clone();\n   429→        if idx + 1 < stage_plan.len() {\n   430→            let next_stage = stage_plan[idx + 1].stage_id;\n   431→            current_snapshot.active_run.as_mut().unwrap().stage_cursor =\n   432→                StageCursor::initial(next_stage);\n   433→            current_snapshot.status_summary = format!(\n   434→                \"running: completed {}, next {}\",\n   435→                stage_id.display_name(),\n   436→                next_stage.display_name()\n   437→            );\n   438→        }\n   439→        if let Err(e) = run_snapshot_write.write_run_snapshot(base_dir, project_id, &current_snapshot) {\n   440→            // Roll back payload/artifact; no stage_completed was written yet.\n   441→            // Propagate rollback failure so leaked durable history is surfaced.\n   442→            let rollback_detail = match artifact_write.remove_payload_artifact_pair(base_dir, project_id, &payload_id, &artifact_id) {\n   443→                Ok(()) => String::new(),\n   444→                Err(cleanup_err) => format!(\"; payload/artifact rollback failed: {} — leaked durable history may exist\", cleanup_err),\n   445→            };\n   446→            current_snapshot = pre_commit_snapshot;\n   447→            let commit_err = AppError::StageCommitFailed {\n   448→                stage_id,\n   449→                details: format!(\"snapshot write failed during stage commit: {}{}\", e, rollback_detail),\n   450→            };\n   451→            return fail_run(\n   452→                &commit_err,\n   453→                stage_id,\n   454→                &run_id,\n   455→                &mut seq,\n   456→                &mut current_snapshot,\n   457→                journal_store,\n   458→                run_snapshot_write,\n   459→                base_dir,\n   460→                project_id,\n   461→            )\n   462→            .await;\n   463→        }\n   464→\n   465→        // Step 3: Append stage_completed journal event.\n   466→        // If this fails, roll back payload/artifact and overwrite snapshot\n   467→        // via fail_run so the stage remains uncommitted.\n   468→        seq += 1;\n   469→        let stage_completed = journal::stage_completed_event(\n   470→            seq,\n   471→            Utc::now(),\n   472→            &run_id,\n   473→            stage_id,\n   474→            cursor.cycle,\n   475→            cursor.attempt,\n   476→            &payload_id,\n   477→            &artifact_id,\n   478→        );\n   479→        let stage_completed_line = journal::serialize_event(&stage_completed)?;\n   480→        if let Err(e) = journal_store.append_event(base_dir, project_id, &stage_completed_line) {\n   481→            // Roll back payload/artifact so no partial durable history is visible.\n   482→            // Propagate rollback failure so leaked durable history is surfaced.\n   483→            let rollback_detail = match artifact_write.remove_payload_artifact_pair(base_dir, project_id, &payload_id, &artifact_id) {\n   484→                Ok(()) => String::new(),\n   485→                Err(cleanup_err) => format!(\"; payload/artifact rollback failed: {} — leaked durable history may exist\", cleanup_err),\n   486→            };\n   487→            seq -= 1; // undo the seq increment since the event was not persisted\n   488→            let commit_err = AppError::StageCommitFailed {\n   489→                stage_id,\n   490→                details: format!(\"journal append failed during stage commit: {}{}\", e, rollback_detail),\n   491→            };\n   492→            return fail_run(\n   493→                &commit_err,\n   494→                stage_id,\n   495→                &run_id,\n   496→                &mut seq,\n   497→                &mut current_snapshot,\n   498→                journal_store,\n   499→                run_snapshot_write,"}]},"parent_tool_