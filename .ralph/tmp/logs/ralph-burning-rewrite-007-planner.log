{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Ujm6WapSNxNhPLuKgg2s66","type":"tool_result","content":"     1→use std::path::Path;\n     2→\n     3→use chrono::{DateTime, Utc};\n     4→\n     5→use crate::shared::domain::{FlowPreset, ProjectId};\n     6→use crate::shared::error::{AppError, AppResult};\n     7→\n     8→use super::journal;\n     9→use super::model::{\n    10→    ArtifactRecord, JournalEvent, JournalEventType, PayloadRecord, ProjectDetail, ProjectListEntry,\n    11→    ProjectRecord, ProjectStatusSummary, RunSnapshot, RuntimeLogEntry, SessionStore,\n    12→};\n    13→use super::queries::{self, RunHistoryView, RunStatusView, RunTailView};\n    14→\n    15→/// Port for reading and writing project records.\n    16→pub trait ProjectStorePort {\n    17→    fn project_exists(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<bool>;\n    18→    fn read_project_record(\n    19→        &self,\n    20→        base_dir: &Path,\n    21→        project_id: &ProjectId,\n    22→    ) -> AppResult<ProjectRecord>;\n    23→    fn list_project_ids(&self, base_dir: &Path) -> AppResult<Vec<ProjectId>>;\n    24→\n    25→    /// Stage a project for deletion: makes it invisible to list/show but\n    26→    /// keeps data on disk for potential rollback.\n    27→    fn stage_delete(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<()>;\n    28→\n    29→    /// Finalize a staged delete: permanently removes the project data.\n    30→    fn commit_delete(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<()>;\n    31→\n    32→    /// Roll back a staged delete: restores the project to its canonical path.\n    33→    fn rollback_delete(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<()>;\n    34→\n    35→    /// Atomically stage and commit a new project. If any step fails,\n    36→    /// the project must not be visible to list/show.\n    37→    fn create_project_atomic(\n    38→        &self,\n    39→        ba