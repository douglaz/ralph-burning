{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01L8TD1tXi61wSA5y8kApa56","type":"tool_result","content":"     1→use std::path::{Path, PathBuf};\n     2→use std::time::Duration;\n     3→\n     4→use chrono::Utc;\n     5→\n     6→use crate::contexts::agent_execution::model::{\n     7→    CancellationToken, InvocationPayload, InvocationRequest,\n     8→};\n     9→use crate::contexts::agent_execution::service::{\n    10→    AgentExecutionPort, BackendSelectionConfig, RawOutputPort,\n    11→};\n    12→use crate::contexts::agent_execution::session::SessionStorePort;\n    13→use crate::contexts::agent_execution::AgentExecutionService;\n    14→use crate::contexts::project_run_record::journal;\n    15→use crate::contexts::project_run_record::model::{\n    16→    ActiveRun, ArtifactRecord, LogLevel, PayloadRecord, RunSnapshot, RunStatus, RuntimeLogEntry,\n    17→};\n    18→use crate::contexts::project_run_record::service::{\n    19→    JournalStorePort, PayloadArtifactWritePort, RunSnapshotPort, RunSnapshotWritePort,\n    20→    RuntimeLogWritePort,\n    21→};\n    22→use crate::contexts::workspace_governance::config::EffectiveConfig;\n    23→use crate::shared::domain::{\n    24→    BackendRole, FlowPreset, ProjectId, ResolvedBackendTarget, RunId, SessionPolicy, StageCursor,\n    25→    StageId,\n    26→};\n    27→use crate::shared::error::{AppError, AppResult};\n    28→\n    29→use super::contracts;\n    30→\n    31→/// Derives the executable stage plan for the standard flow given prompt_review config.\n    32→pub fn standard_stage_plan(prompt_review_enabled: bool) -> Vec<StageId> {\n    33→    let flow_def = super::flow_definition(FlowPreset::Standard);\n    34→    if prompt_review_enabled {\n    35→        flow_def.stages.to_vec()\n    36→    } else {\n    37→        flow_def\n    38→            .stages\n    39→            .iter()\n    40→            .copied()\n    41→            .filter(|s| *s != StageId::PromptReview)\n    42→            .collect()\n    43→    }\n    44→}\n    45→\n    46→/// Deterministic stage-to-role mapping per spec.\n    47→pub fn role_for_stage(stage_id: StageId) -> BackendRole {\n    48→    BackendRole::for_stage(stage_id)\n    49→}\n    50→\n    51→/// Resolved target per stage for preflight.\n    52→pub struct StagePlan {\n    53→    pub stage_id: StageId,\n    54→    pub role: BackendRole,\n    55→    pub contract: contracts::StageContract,\n    56→    pub target: ResolvedBackendTarget,\n    57→}\n    58→\n    59→/// Resolve all stage targets ahead of execution for preflight validation.\n    60→pub fn resolve_stage_plan(\n    61→    stages: &[StageId],\n    62→    resolver: &crate::contexts::agent_execution::service::BackendResolver,\n    63→    workspace_defaults: Option<&BackendSelectionConfig>,\n    64→) -> AppResult<Vec<StagePlan>> {\n    65→    let mut plan = Vec::with_capacity(stages.len());\n    66→    for &stage_id in stages {\n    67→        let role = role_for_stage(stage_id);\n    68→        let contract = contracts::contract_for_stage(stage_id);\n    69→        let target = resolver.resolve(role, None, None, workspace_defaults)?;\n    70→        plan.push(StagePlan {\n    71→            stage_id,\n    72→            role,\n    73→            contract,\n    74→            target,\n    75→        });\n    76→    }\n    77→    Ok(plan)\n    78→}\n    79→\n    80→/// Preflight: check capability and availability for every stage target.\n    81→pub async fn preflight_check<A: AgentExecutionPort>(\n    82→    adapter: &A,\n    83→    plan: &[StagePlan],\n    84→) -> AppResult<()> {\n    85→    for entry in plan {\n    86→        adapter\n    87→            .check_capability(&entry.target, &entry.contract)\n    88→            .await\n    89→            .map_err(|e| AppError::PreflightFailed {\n    90→                stage_id: entry.stage_id,\n    91→                details: e.to_string(),\n    92→            })?;\n    93→        adapter\n    94→            .check_availability(&entry.target)\n    95→            .await\n    96→            .map_err(|e| AppError::PreflightFailed {\n    97→                stage_id: entry.stage_id,\n    98→                details: e.to_string(),\n    99→            })?;\n   100→    }\n   101→    Ok(())\n   102→}\n   103→\n   104→/// Generate a new run ID from a timestamp.\n   105→fn generate_run_id() -> AppResult<RunId> {\n   106→    let now = Utc::now();\n   107→    RunId::new(format!(\"run-{}\", now.format(\"%Y%m%d%H%M%S\")))\n   108→}\n   109→\n   110→/// The standard-flow orchestration engine.\n   111→///\n   112→/// Executes all enabled standard stages in canonical order against the provided\n   113→/// backend adapter, persisting validated payloads and rendered artifacts at\n   114→/// durable stage boundaries.\n   115→#[allow(clippy::too_many_arguments)]\n   116→pub async fn execute_standard_run<A, R, S>(\n   117→    agent_service: &AgentExecutionService<A, R, S>,\n   118→    run_snapshot_read: &dyn RunSnapshotPort,\n   119→    run_snapshot_write: &dyn RunSnapshotWritePort,\n   120→    journal_store: &dyn JournalStorePort,\n   121→    artifact_write: &dyn PayloadArtifactWritePort,\n   122→    log_write: &dyn RuntimeLogWritePort,\n   123→    base_dir: &Path,\n   124→    project_id: &ProjectId,\n   125→    effective_config: &EffectiveConfig,\n   126→) -> AppResult<()>\n   127→where\n   128→    A: AgentExecutionPort,\n   129→    R: RawOutputPort,\n   130→    S: SessionStorePort,\n   131→{\n   132→    // 1. Read current snapshot and validate preconditions\n   133→    let snapshot = run_snapshot_read.read_run_snapshot(base_dir, project_id)?;\n   134→\n   135→    if snapshot.status != RunStatus::NotStarted {\n   136→        return Err(AppError::RunStartFailed {\n   137→            reason: format!(\n   138→                \"project snapshot status is '{}'; run start requires 'not_started'\",\n   139→                snapshot.status\n   140→            ),\n   141→        });\n   142→    }\n   143→    if snapshot.has_active_run() {\n   144→        return Err(AppError::RunStartFailed {\n   145→            reason: \"project already has an active run\".to_owned(),\n   146→        });\n   147→    }\n   148→\n   149→    // 2. Derive the stage plan\n   150→    let prompt_review_enabled = effective_config.prompt_review_enabled();\n   151→    let stages = standard_stage_plan(prompt_review_enabled);\n   152→\n   153→    // 3. Resolve backend targets for every stage\n   154→    let workspace_defaults = BackendSelectionConfig::from_effective_config(effective_config)?;\n   155→    let stage_plan = resolve_stage_plan(\n   156→        stages.as_slice(),\n   157→        agent_service.resolver(),\n   158→        Some(&workspace_defaults),\n   159→    )?;\n   160→\n   161→    // 4. Preflight checks — if any fail, leave all state unchanged\n   162→    preflight_check(agent_service.adapter(), &stage_plan).await?;\n   163→\n   164→    // 5. Generate run ID and read journal for sequence tracking\n   165→    let run_id = generate_run_id()?;\n   166→    let now = Utc::now();\n   167→    let events = journal_store.read_journal(base_dir, project_id)?;\n   168→    let mut seq = journal::last_sequence(&events);\n   169→\n   170→    let first_stage = stage_plan[0].stage_id;\n   171→\n   172→    // 6. Persist run_started: write run.json with running status FIRST, then journal events.\n   173→    // The snapshot must be durable before journal events become visible.\n   174→    let initial_cursor = StageCursor::initial(first_stage);\n   175→    let mut current_snapshot = RunSnapshot {\n   176→        active_run: Some(ActiveRun {\n   177→            run_id: run_id.as_str().to_owned(),\n   178→            stage_cursor: initial_cursor.clone(),\n   179→            started_at: now,\n   180→        }),\n   181→        status: RunStatus::Running,\n   182→        cycle_history: vec![],\n   183→        completion_rounds: 1,\n   184→        rollback_point_meta: snapshot.rollback_point_meta.clone(),\n   185→        amendment_queue: snapshot.amendment_queue.clone(),\n   186→        status_summary: format!(\"running: {}\", first_stage.display_name()),\n   187→    };\n   188→    run_snapshot_write.write_run_snapshot(base_dir, project_id, &current_snapshot)?;\n   189→\n   190→    seq += 1;\n   191→    let run_started = journal::run_started_event(seq, now, &run_id, first_stage);\n   192→    let run_started_line = journal::serialize_event(&run_started)?;\n   193→    if let Err(e) = journal_store.append_event(base_dir, project_id, &run_started_line) {\n   194→        seq -= 1; // event was not persisted\n   195→        return fail_run(\n   196→            &AppError::RunStartFailed {\n   197→                reason: format!(\"failed to persist run_started event: {}\", e),\n   198→            },\n   199→            first_stage,\n   200→            &run_id,\n   201→            &mut seq,\n   202→            &mut current_snapshot,\n   203→            journal_store,\n   204→            run_snapshot_write,\n   205→            base_dir,\n   206→            project_id,\n   207→        )\n   208→        .await;\n   209→    }\n   210→\n   211→    let project_root = project_root_path(base_dir, project_id);\n   212→\n   213→    // 7. Execute stages in order\n   214→    for (idx, stage_entry) in stage_plan.iter().enumerate() {\n   215→        let stage_id = stage_entry.stage_id;\n   216→        let cursor = StageCursor::initial(stage_id);\n   217→\n   218→        // Emit stage_entered — if journal append fails after run_started,\n   219→        // the run must persist failed state at this stage boundary.\n   220→        seq += 1;\n   221→        let stage_entered = journal::stage_entered_event(\n   222→            seq,\n   223→            Utc::now(),\n   224→            &run_id,\n   225→            stage_id,\n   226→            cursor.cycle,\n   227→            cursor.attempt,\n   228→        );\n   229→        let stage_entered_line = journal::serialize_event(&stage_entered)?;\n   230→        if let Err(e) = journal_store.append_event(base_dir, project_id, &stage_entered_line) {\n   231→            seq -= 1; // event was not persisted\n   232→            return fail_run(\n   233→                &AppError::RunStartFailed {\n   234→                    reason: format!(\n   235→                        \"failed to persist stage_entered event for {}: {}\",\n   236→                        stage_id.as_str(),\n   237→                        e\n   238→                    ),\n   239→                },\n   240→                stage_id,\n   241→                &run_id,\n   242→                &mut seq,\n   243→                &mut current_snapshot,\n   244→                journal_store,\n   245→                run_snapshot_write,\n   246→                base_dir,\n   247→                project_id,\n   248→            )\n   249→            .await;\n   250→        }\n   251→\n   252→        // Update cursor in snapshot — if this fails after stage_entered,\n   253→        // the run must persist failed state at this stage boundary.\n   254→        current_snapshot.active_run.as_mut().unwrap().stage_cursor = cursor.clone();\n   255→        current_snapshot.status_summary = format!(\"running: {}\", stage_id.display_name());\n   256→        if let Err(e) =\n   257→            run_snapshot_write.write_run_snapshot(base_dir, project_id, &current_snapshot)\n   258→        {\n   259→            return fail_run(\n   260→                &AppError::RunStartFailed {\n   261→                    reason: format!(\n   262→                        \"failed to update snapshot for stage {}: {}\",\n   263→                        stage_id.as_str(),\n   264→                        e\n   265→                    ),\n   266→                },\n   267→                stage_id,\n   268→                &run_id,\n   269→                &mut seq,\n   270→                &mut current_snapshot,\n   271→                journal_store,\n   272→                run_snapshot_write,\n   273→                base_dir,\n   274→                project_id,\n   275→            )\n   276→            .await;\n   277→        }\n   278→\n   279→        // Best-effort runtime log\n   280→        let _ = log_write.append_runtime_log(\n   281→            base_dir,\n   282→            project_id,\n   283→            &RuntimeLogEntry {\n   284→                timestamp: Utc::now(),\n   285→                level: LogLevel::Info,\n   286→                source: \"engine\".to_owned(),\n   287→                message: format!(\"stage_entered: {}\", stage_id.as_str()),\n   288→            },\n   289→        );\n   290→\n   291→        // Invoke the backend\n   292→        let invocation_id = format!(\n   293→            \"{}-{}-c{}-a{}\",\n   294→            run_id.as_str(),\n   295→            stage_id.as_str(),\n   296→            cursor.cycle,\n   297→            cursor.attempt\n   298→        );\n   299→        let request = InvocationRequest {\n   300→            invocation_id,\n   301→            project_root: project_root.clone(),\n   302→            stage_contract: stage_entry.contract,\n   303→            role: stage_entry.role,\n   304→            resolved_target: stage_entry.target.clone(),\n   305→            payload: InvocationPayload {\n   306→                prompt: format!(\"Execute stage: {}\", stage_id.display_name()),\n   307→                context: serde_json::json!({}),\n   308→            },\n   309→            timeout: Duration::from_secs(300),\n   310→            cancellation_token: CancellationToken::new(),\n   311→            session_policy: SessionPolicy::ReuseIfAllowed,\n   312→            prior_session: None,\n   313→            attempt_number: cursor.attempt,\n   314→        };\n   315→\n   316→        let envelope = match agent_service.invoke(request).await {\n   317→            Ok(env) => env,\n   318→            Err(e) => {\n   319→                return fail_run(\n   320→                    &e,\n   321→                    stage_id,\n   322→                    &run_id,\n   323→                    &mut seq,\n   324→                    &mut current_snapshot,\n   325→                    journal_store,\n   326→                    run_snapshot_write,\n   327→                    base_dir,\n   328→                    project_id,\n   329→                )\n   330→                .await;\n   331→            }\n   332→        };\n   333→\n   334→        // Evaluate the contract (schema + domain + outcome + render)\n   335→        let bundle = match stage_entry.contract.evaluate(&envelope.parsed_payload) {\n   336→            Ok(bundle) => bundle,\n   337→            Err(contract_err) => {\n   338→                let app_err = AppError::InvocationFailed {\n   339→                    backend: stage_entry.target.backend.family.to_string(),\n   340→                    stage_id,\n   341→                    failure_class: contract_err.failure_class(),\n   342→                    details: contract_err.to_string(),\n   343→                };\n   344→                return fail_run(\n   345→                    &app_err,\n   346→                    stage_id,\n   347→                    &run_id,\n   348→                    &mut seq,\n   349→                    &mut current_snapshot,\n   350→                    journal_store,\n   351→                    run_snapshot_write,\n   352→                    base_dir,\n   353→                    project_id,\n   354→                )\n   355→                .await;\n   356→            }\n   357→        };\n   358→\n   359→        // Persist payload + artifact pair atomically\n   360→        let stage_now = Utc::now();\n   361→        let payload_id = format!(\n   362→            \"{}-{}-c{}-a{}\",\n   363→            run_id.as_str(),\n   364→            stage_id.as_str(),\n   365→            cursor.cycle,\n   366→            cursor.attempt\n   367→        );\n   368→        let artifact_id = format!(\"{}-artifact\", payload_id);\n   369→\n   370→        let payload_record = PayloadRecord {\n   371→            payload_id: payload_id.clone(),\n   372→            stage_id,\n   373→            cycle: cursor.cycle,\n   374→            attempt: cursor.attempt,\n   375→            created_at: stage_now,\n   376→            payload: serde_json::to_value(&bundle.payload)?,\n   377→        };\n   378→        let artifact_record = ArtifactRecord {\n   379→            artifact_id: artifact_id.clone(),\n   380→            payload_id: payload_id.clone(),\n   381→            stage_id,\n   382→            created_at: stage_now,\n   383→            content: bundle.artifact.clone(),\n   384→        };\n   385→\n   386→        // Atomic stage commit: payload + artifact + snapshot + journal.\n   387→        // All four must succeed for the stage to become durably visible.\n   388→        // Order: payload/artifact → snapshot cursor → stage_completed journal.\n   389→        // This ensures that if any step fails, no stage_completed event leaks\n   390→        // into the journal without a matching snapshot and durable files.\n   391→\n   392→        // Step 1: Write payload + artifact pair.\n   393→        // If this fails after stage_entered, the run must persist failed state.\n   394→        // The fs adapter uses staging + rename so canonical files only appear on\n   395→        // full success, but as defense-in-depth we also call remove_payload_artifact_pair\n   396→        // to clean up any orphaned canonical files before failing the run.\n   397→        if let Err(e) =\n   398→            artifact_write.write_payload_artifact_pair(base_dir, project_id, &payload_record, &artifact_record)\n   399→        {\n   400→            // Defense-in-depth: remove any leaked canonical files.\n   401→            let _ = artifact_write.remove_payload_artifact_pair(\n   402→                base_dir,\n   403→                project_id,\n   404→                &payload_id,\n   405→                &artifact_id,\n   406→            );\n   407→            let commit_err = AppError::StageCommitFailed {\n   408→                stage_id,\n   409→                details: format!(\"payload/artifact persistence failed: {}\", e),\n   410→            };\n   411→            return fail_run(\n   412→                &commit_err,\n   413→                stage_id,\n   414→                &run_id,\n   415→                &mut seq,\n   416→                &mut current_snapshot,\n   417→                journal_store,\n   418→                run_snapshot_write,\n   419→                base_dir,\n   420→                project_id,\n   421→            )\n   422→            .await;\n   423→        }\n   424→\n   425→        // Step 2: Update snapshot cursor to reflect completed stage.\n   426→        // Written BEFORE stage_completed journal so that snapshot failure\n   427→        // never leaves a stage_completed event without a matching cursor.\n   428→        let pre_commit_snapshot = current_snapshot.clone();\n   429→        if idx + 1 < stage_plan.len() {\n   430→            let next_stage = stage_plan[idx + 1].stage_id;\n   431→            current_snapshot.active_run.as_mut().unwrap().stage_cursor =\n   432→                StageCursor::initial(next_stage);\n   433→            current_snapshot.status_summary = format!(\n   434→                \"running: completed {}, next {}\",\n   435→                stage_id.display_name(),\n   436→                next_stage.display_name()\n   437→            );\n   438→        }\n   439→        if let Err(e) = run_snapshot_write.write_run_snapshot(base_dir, project_id, &current_snapshot) {\n   440→            // Roll back payload/artifact; no stage_completed was written yet.\n   441→            // Propagate rollback failure so leaked durable history is surfaced.\n   442→            let rollback_detail = match artifact_write.remove_payload_artifact_pair(base_dir, project_id, &payload_id, &artifact_id) {\n   443→                Ok(()) => String::new(),\n   444→                Err(cleanup_err) => format!(\"; payload/artifact rollback failed: {} — leaked durable history may exist\", cleanup_err),\n   445→            };\n   446→            current_snapshot = pre_commit_snapshot;\n   447→            let commit_err = AppError::StageCommitFailed {\n   448→                stage_id,\n   449→                details: format!(\"snapshot write failed during stage commit: {}{}\", e, rollback_detail),\n   450→            };\n   451→            return fail_run(\n   452→                &commit_err,\n   453→                stage_id,\n   454→                &run_id,\n   455→                &mut seq,\n   456→                &mut current_snapshot,\n   457→                journal_store,\n   458→                run_snapshot_write,\n   459→                base_dir,\n   460→                project_id,\n   461→            )\n   462→            .await;\n   463→        }\n   464→\n   465→        // Step 3: Append stage_completed journal event.\n   466→        // If this fails, roll back payload/artifact and overwrite snapshot\n   467→        // via fail_run so the stage remains uncommitted.\n   468→        seq += 1;\n   469→        let stage_completed = journal::stage_completed_event(\n   470→            seq,\n   471→            Utc::now(),\n   472→            &run_id,\n   473→            stage_id,\n   474→            cursor.cycle,\n   475→            cursor.attempt,\n   476→            &payload_id,\n   477→            &artifact_id,\n   478→        );\n   479→        let stage_completed_line = journal::serialize_event(&stage_completed)?;\n   480→        if let Err(e) = journal_store.append_event(base_dir, project_id, &stage_completed_line) {\n   481→            // Roll back payload/artifact so no partial durable history is visible.\n   482→            // Propagate rollback failure so leaked durable history is surfaced.\n   483→            let rollback_detail = match artifact_write.remove_payload_artifact_pair(base_dir, project_id, &payload_id, &artifact_id) {\n   484→                Ok(()) => String::new(),\n   485→                Err(cleanup_err) => format!(\"; payload/artifact rollback failed: {} — leaked durable history may exist\", cleanup_err),\n   486→            };\n   487→            seq -= 1; // undo the seq increment since the event was not persisted\n   488→            let commit_err = AppError::StageCommitFailed {\n   489→                stage_id,\n   490→                details: format!(\"journal append failed during stage commit: {}{}\", e, rollback_detail),\n   491→            };\n   492→            return fail_run(\n   493→                &commit_err,\n   494→                stage_id,\n   495→                &run_id,\n   496→                &mut seq,\n   497→                &mut current_snapshot,\n   498→                journal_store,\n   499→                run_snapshot_write,\n   500→                base_dir,\n   501→                project_id,\n   502→            )\n   503→            .await;\n   504→        }\n   505→\n   506→        // Best-effort runtime log\n   507→        let _ = log_write.append_runtime_log(\n   508→            base_dir,\n   509→            project_id,\n   510→            &RuntimeLogEntry {\n   511→                timestamp: Utc::now(),\n   512→                level: LogLevel::Info,\n   513→                source: \"engine\".to_owned(),\n   514→                message: format!(\"stage_completed: {}\", stage_id.as_str()),\n   515→            },\n   516→        );\n   517→    }\n   518→\n   519→    // 8. All stages completed — mark run as completed.\n   520→    // Write completed snapshot FIRST so the run is marked as completed\n   521→    // even if journal append fails (consistent with snapshot-first ordering).\n   522→    current_snapshot.status = RunStatus::Completed;\n   523→    current_snapshot.active_run = None;\n   524→    current_snapshot.completion_rounds = 1;\n   525→    current_snapshot.status_summary = \"completed\".to_owned();\n   526→    run_snapshot_write.write_run_snapshot(base_dir, project_id, &current_snapshot)?;\n   527→\n   528→    seq += 1;\n   529→    let run_completed = journal::run_completed_event(seq, Utc::now(), &run_id, 1);\n   530→    let run_completed_line = journal::serialize_event(&run_completed)?;\n   531→    journal_store.append_event(base_dir, project_id, &run_completed_line)?;\n   532→\n   533→    Ok(())\n   534→}\n   535→\n   536→/// Record a run failure: persist failed snapshot, then journal event, return error.\n   537→///\n   538→/// The snapshot is written first (critical path) so the run is never left in an\n   539→/// ambiguous running state. The journal append is best-effort relative to the\n   540→/// snapshot — if it fails, the snapshot already reflects the failed state.\n   541→#[allow(clippy::too_many_arguments)]\n   542→async fn fail_run(\n   543→    err: &AppError,\n   544→    stage_id: StageId,\n   545→    run_id: &RunId,\n   546→    seq: &mut u64,\n   547→    snapshot: &mut RunSnapshot,\n   548→    journal_store: &dyn JournalStorePort,\n   549→    run_snapshot_write: &dyn RunSnapshotWritePort,\n   550→    base_dir: &Path,\n   551→    project_id: &ProjectId,\n   552→) -> AppResult<()> {\n   553→    let failure_class = err\n   554→        .failure_class()\n   555→        .map(|fc| format!(\"{:?}\", fc))\n   556→        .unwrap_or_else(|| \"unknown\".to_owned());\n   557→    let message = err.to_string();\n   558→\n   559→    // Critical: persist the failed snapshot first so the run is never\n   560→    // left in an ambiguous running state after any failure.\n   561→    snapshot.status = RunStatus::Failed;\n   562→    snapshot.active_run = None;\n   563→    snapshot.status_summary = format!(\"failed at {}: {}\", stage_id.display_name(), message);\n   564→    run_snapshot_write.write_run_snapshot(base_dir, project_id, snapshot)?;\n   565→\n   566→    // Best-effort: append run_failed journal event. If this fails,\n   567→    // the snapshot already reflects the failed state.\n   568→    *seq += 1;\n   569→    let run_failed =\n   570→        journal::run_failed_event(*seq, Utc::now(), run_id, stage_id, &failure_class, &message);\n   571→    if let Ok(run_failed_line) = journal::serialize_event(&run_failed) {\n   572→        let _ = journal_store.append_event(base_dir, project_id, &run_failed_line);\n   573→    }\n   574→\n   575→    Err(AppError::RunStartFailed {\n   576→        reason: format!(\"stage {} failed: {}\", stage_id.as_str(), message),\n   577→    })\n   578→}\n   579→\n   580→/// Helper to get project root path.\n   581→fn project_root_path(base_dir: &Path, project_id: &ProjectId) -> PathBuf {\n   582→    base_dir\n   583→        .join(\".ralph-burning\")\n   584→        .join(\"projects\")\n   585→        .join(project_id.as_str())\n   586→}\n   587→"}]},"parent_tool_use_id":null,"session_id":"04681ab0-f55e-4c96-b8ca-61b2a1e590bf","uuid":"0e93c0e1-4782-4baf-8dc9-6153085053b5","tool_use_result":{"type":"text","file":{"filePath":"/root/new-ralph-burning/ralph-burning-rewrite/src/contexts/workflow_composition/engine.rs","content":"use std::path::{Path, PathBuf};\nuse std::time::Duration;\n\nuse chrono::Utc;\n\nuse crate::contexts::agent_execution::model::{\n    CancellationToken, InvocationPayload, InvocationRequest,\n};\nuse crate::contexts::agent_execution::service::{\n    AgentExecutionPort, BackendSelectionConfig, RawOutputPort,\n};\nuse crate::contexts::agent_execution::session::SessionStorePort;\nuse crate::contexts::agent_execution::AgentExecutionService;\nuse crate::contexts::project_run_record::journal;\nuse crate::contexts::project_run_record::model::{\n    ActiveRun, ArtifactRecord, LogLevel, PayloadRecord, RunSnapshot, RunStatus, RuntimeLogEntry,\n};\nuse crate::contexts::project_run_record::service::{\n    JournalStorePort, PayloadArtifactWritePort, RunSnapshotPort, RunSnapshotWritePort,\n    RuntimeLogWritePort,\n};\nuse crate::contexts::workspace_governance::config::EffectiveConfig;\nuse crate::shared::domain::{\n    BackendRole, FlowPreset, ProjectId, ResolvedBackendTarget, RunId, SessionPolicy, StageCursor,\n    StageId,\n};\nuse crate::shared::error::{AppError, AppResult};\n\nuse super::contracts;\n\n/// Derives the executable stage plan for the standard flow given prompt_review config.\npub fn standard_stage_plan(prompt_review_enabled: bool) -> Vec<StageId> {\n    let flow_def = super::flow_definition(FlowPreset::Standard);\n    if prompt_review_enabled {\n        flow_def.stages.to_vec()\n    } else {\n        flow_def\n            .stages\n            .iter()\n            .copied()\n            .filter(|s| *s != StageId::PromptReview)\n            .collect()\n    }\n}\n\n/// Deterministic stage-to-role mapping per spec.\npub fn role_for_stage(stage_id: StageId) -> BackendRole {\n    BackendRole::for_stage(stage_id)\n}\n\n/// Resolved target per stage for preflight.\npub struct StagePlan {\n    pub stage_id: StageId,\n    pub role: BackendRole,\n    pub contract: contracts::StageContract,\n    pub target: ResolvedBackendTarget,\n}\n\n/// Resolve all stage targets ahead of execution for preflight validation.\npub fn resolve_stage_plan(\n    stages: &[StageId],\n    resolver: &crate::contexts::agent_execution::service::BackendResolver,\n    workspace_defaults: Option<&BackendSelectionConfig>,\n) -> AppResult<Vec<StagePlan>> {\n    let mut plan = Vec::with_capacity(stages.len());\n    for &stage_id in stages {\n        let role = role_for_stage(stage_id);\n        let contract = contracts::contract_for_stage(stage_id);\n        let target = resolver.resolve(role, None, None, workspace_defaults)?;\n        plan.push(StagePlan {\n            stage_id,\n            role,\n            contract,\n            target,\n        });\n    }\n    Ok(plan)\n}\n\n/// Preflight: check capability and availability for every stage target.\npub async fn preflight_check<A: AgentExecutionPort>(\n    adapter: &A,\n    plan: &[StagePlan],\n) -> AppResult<()> {\n    for entry in plan {\n        adapter\n            .check_capability(&entry.target, &entry.contract)\n            .await\n            .map_err(|e| AppError::PreflightFailed {\n                stage_id: entry.stage_id,\n                details: e.to_string(),\n            })?;\n        adapter\n            .check_availability(&entry.target)\n            .await\n            .map_err(|e| AppError::PreflightFailed {\n                stage_id: entry.stage_id,\n                details: e.to_string(),\n            })?;\n    }\n    Ok(())\n}\n\n/// Generate a new run ID from a timestamp.\nfn generate_run_id() -> AppResult<RunId> {\n    let now = Utc::now();\n    RunId::new(format!(\"run-{}\", now.format(\"%Y%m%d%H%M%S\")))\n}\n\n/// The standard-flow orchestration engine.\n///\n/// Executes all enabled standard stages in canonical order against the provided\n/// backend adapter, persisting validated payloads and rendered artifacts at\n/// durable stage boundaries.\n#[allow(clippy::too_many_arguments)]\npub async fn execute_standard_run<A, R, S>(\n    agent_service: &AgentExecutionService<A, R, S>,\n    run_snapshot_read: &dyn RunSnapshotPort,\n    run_snapshot_write: &dyn RunSnapshotWritePort,\n    journal_store: &dyn JournalStorePort,\n    artifact_write: &dyn PayloadArtifactWritePort,\n    log_write: &dyn RuntimeLogWritePort,\n    base_dir: &Path,\n    project_id: &ProjectId,\n    effective_config: &EffectiveConfig,\n) -> AppResult<()>\nwhere\n    A: AgentExecutionPort,\n    R: RawOutputPort,\n    S: SessionStorePort,\n{\n    // 1. Read current snapshot and validate preconditions\n    let snapshot = run_snapshot_read.read_run_snapshot(base_dir, project_id)?;\n\n    if snapshot.status != RunStatus::NotStarted {\n        return Err(AppError::RunStartFailed {\n            reason: format!(\n                \"project snapshot status is '{}'; run start requires 'not_started'\",\n                snapshot.status\n            ),\n        });\n    }\n    if snapshot.has_active_run() {\n        return Err(AppError::RunStartFailed {\n            reason: \"project already has an active run\".to_owned(),\n        });\n    }\n\n    // 2. Derive the stage plan\n    let prompt_review_enabled = effective_config.prompt_review_enabled();\n    let stages = standard_stage_plan(prompt_review_enabled);\n\n    // 3. Resolve backend targets for every stage\n    let workspace_defaults = BackendSelectionConfig::from_effective_config(effective_config)?;\n    let stage_plan = resolve_stage_plan(\n        stages.as_slice(),\n        agent_service.resolver(),\n        Some(&workspace_defaults),\n    )?;\n\n    // 4. Preflight checks — if any fail, leave all state unchanged\n    preflight_check(agent_service.adapter(), &stage_plan).await?;\n\n    // 5. Generate run ID and read journal for sequence tracking\n    let run_id = generate_run_id()?;\n    let now = Utc::now();\n    let events = journal_store.read_journal(base_dir, project_id)?;\n    let mut seq = journal::last_sequence(&events);\n\n    let first_stage = stage_plan[0].stage_id;\n\n    // 6. Persist run_started: write run.json with running status FIRST, then journal events.\n    // The snapshot must be durable before journal events become visible.\n    let initial_cursor = StageCursor::initial(first_stage);\n    let mut current_snapshot = RunSnapshot {\n        active_run: Some(ActiveRun {\n            run_id: run_id.as_str().to_owned(),\n            stage_cursor: initial_cursor.clone(),\n            started_at: now,\n        }),\n        status: RunStatus::Running,\n        cycle_history: vec![],\n        completion_rounds: 1,\n        rollback_point_meta: snapshot.rollback_point_meta.clone(),\n        amendment_queue: snapshot.amendment_queue.clone(),\n        status_summary: format!(\"running: {}\", first_stage.display_name()),\n    };\n    run_snapshot_write.write_run_snapshot(base_dir, project_id, &current_snapshot)?;\n\n    seq += 1;\n    let run_started = journal::run_started_event(seq, now, &run_id, first_stage);\n    let run_started_line = journal::serialize_event(&run_started)?;\n    if let Err(e) = journal_store.append_event(base_dir, project_id, &run_started_line) {\n        seq -= 1; // event was not persisted\n        return fail_run(\n            &AppError::RunStartFailed {\n                reason: format!(\"failed to persist run_started event: {}\", e),\n            },\n            first_stage,\n            &run_id,\n            &mut seq,\n            &mut current_snapshot,\n            journal_store,\n            run_snapshot_write,\n            base_dir,\n            project_id,\n        )\n        .await;\n    }\n\n    let project_root = project_root_path(base_dir, project_id);\n\n    // 7. Execute stages in order\n    for (idx, stage_entry) in stage_plan.iter().enumerate() {\n        let stage_id = stage_entry.stage_id;\n        let cursor = StageCursor::initial(stage_id);\n\n        // Emit stage_entered — if journal append fails after run_started,\n        // the run must persist failed state at this stage boundary.\n        seq += 1;\n        let stage_entered = journal::stage_entered_event(\n            seq,\n            Utc::now(),\n            &run_id,\n            stage_id,\n            cursor.cycle,\n            cursor.attempt,\n        );\n        let stage_entered_line = journal::serialize_event(&stage_entered)?;\n        if let Err(e) = journal_store.append_event(base_dir, project_id, &stage_entered_line) {\n            seq -= 1; // event was not persisted\n            return fail_run(\n                &AppError::RunStartFailed {\n                    reason: format!(\n                        \"failed to persist stage_entered event for {}: {}\",\n                        stage_id.as_str(),\n                        e\n                    ),\n                },\n                stage_id,\n                &run_id,\n                &mut seq,\n                &mut current_snapshot,\n                journal_store,\n                run_snapshot_write,\n                base_dir,\n                project_id,\n            )\n            .await;\n        }\n\n        // Update cursor in snapshot — if this fails after stage_entered,\n        // the run must persist failed state at this stage boundary.\n        current_snapshot.active_run.as_mut().unwrap().stage_cursor = cursor.clone();\n        current_snapshot.status_summary = format!(\"running: {}\", stage_id.display_name());\n        if let Err(e) =\n            run_snapshot_write.write_run_snapshot(base_dir, project_id, &current_snapshot)\n        {\n            return fail_run(\n                &AppError::RunStartFailed {\n                    reason: format!(\n                        \"failed to update snapshot for stage {}: {}\",\n                        stage_id.as_str(),\n                        e\n                    ),\n                },\n                stage_id,\n                &run_id,\n                &mut seq,\n                &mut current_snapshot,\n                journal_store,\n                run_snapshot_write,\n                base_dir,\n                project_id,\n            )\n            .await;\n        }\n\n        // Best-effort runtime log\n        let _ = log_write.append_runtime_log(\n            base_dir,\n            project_id,\n            &RuntimeLogEntry {\n                timestamp: Utc::now(),\n                level: LogLevel::Info,\n                source: \"engine\".to_owned(),\n                message: format!(\"stage_entered: {}\", stage_id.as_str()),\n            },\n        );\n\n        // Invoke the backend\n        let invocation_id = format!(\n            \"{}-{}-c{}-a{}\",\n            run_id.as_str(),\n            stage_id.as_str(),\n            cursor.cycle,\n            cursor.attempt\n        );\n        let request = InvocationRequest {\n            invocation_id,\n            project_root: project_root.clone(),\n            stage_contract: stage_entry.contract,\n            role: stage_entry.role,\n            resolved_target: stage_entry.target.clone(),\n            payload: InvocationPayload {\n                prompt: format!(\"Execute stage: {}\", stage_id.display_name()),\n                context: serde_json::json!({}),\n            },\n            timeout: Duration::from_secs(300),\n            cancellation_token: CancellationToken::new(),\n            session_policy: SessionPolicy::ReuseIfAllowed,\n            prior_session: None,\n            attempt_number: cursor.attempt,\n        };\n\n        let envelope = match agent_service.invoke(request).await {\n            Ok(env) => env,\n            Err(e) => {\n                return fail_run(\n                    &e,\n                    stage_id,\n                    &run_id,\n                    &mut seq,\n                    &mut current_snapshot,\n                    journal_store,\n                    run_snapshot_write,\n                    base_dir,\n                    project_id,\n                )\n                .await;\n            }\n        };\n\n        // Evaluate the contract (schema + domain + outcome + render)\n        let bundle = match stage_entry.contract.evaluate(&envelope.parsed_payload) {\n            Ok(bundle) => bundle,\n            Err(contract_err) => {\n                let app_err = AppError::InvocationFailed {\n                    backend: stage_entry.target.backend.family.to_string(),\n                    stage_id,\n                    failure_class: contract_err.failure_class(),\n                    details: contract_err.to_string(),\n                };\n                return fail_run(\n                    &app_err,\n                    stage_id,\n                    &run_id,\n                    &mut seq,\n                    &mut current_snapshot,\n                    journal_store,\n                    run_snapshot_write,\n                    base_dir,\n                    project_id,\n                )\n                .await;\n            }\n        };\n\n        // Persist payload + artifact pair atomically\n        let stage_now = Utc::now();\n        let payload_id = format!(\n            \"{}-{}-c{}-a{}\",\n            run_id.as_str(),\n            stage_id.as_str(),\n            cursor.cycle,\n            cursor.attempt\n        );\n        let artifact_id = format!(\"{}-artifact\", payload_id);\n\n        let payload_record = PayloadRecord {\n            payload_id: payload_id.clone(),\n            stage_id,\n            cycle: cursor.cycle,\n            attempt: cursor.attempt,\n            created_at: stage_now,\n            payload: serde_json::to_value(&bundle.payload)?,\n        };\n        let artifact_record = ArtifactRecord {\n            artifact_id: artifact_id.clone(),\n            payload_id: payload_id.clone(),\n            stage_id,\n            created_at: stage_now,\n            content: bundle.artifact.clone(),\n        };\n\n        // Atomic stage commit: payload + artifact + snapshot + journal.\n        // All four must succeed for the stage to become durably visible.\n        // Order: payload/artifact → snapshot cursor → stage_completed journal.\n        // This ensures that if any step fails, no stage_completed event leaks\n        // into the journal without a matching snapshot and durable files.\n\n        // Step 1: Write payload + artifact pair.\n        // If this fails after stage_entered, the run must persist failed state.\n        // The fs adapter uses staging + rename so canonical files only appear on\n        // full success, but as defense-in-depth we also call remove_payload_artifact_pair\n        // to clean up any orphaned canonical files before failing the run.\n        if let Err(e) =\n            artifact_write.write_payload_artifact_pair(base_dir, project_id, &payload_record, &artifact_record)\n        {\n            // Defense-in-depth: remove any leaked canonical files.\n            let _ = artifact_write.remove_payload_artifact_pair(\n                base_dir,\n                project_id,\n                &payload_id,\n                &artifact_id,\n            );\n            let commit_err = AppError::StageCommitFailed {\n                stage_id,\n                details: format!(\"payload/artifact persistence failed: {}\", e),\n            };\n            return fail_run(\n                &commit_err,\n                stage_id,\n                &run_id,\n                &mut seq,\n                &mut current_snapshot,\n                journal_store,\n                run_snapshot_write,\n                base_dir,\n                project_id,\n            )\n            .await;\n        }\n\n        // Step 2: Update snapshot cursor to reflect completed stage.\n        // Written BEFORE stage_completed journal so that snapshot failure\n        // never leaves a stage_completed event without a matching cursor.\n        let pre_commit_snapshot = current_snapshot.clone();\n        if idx + 1 < stage_plan.len() {\n            let next_stage = stage_plan[idx + 1].stage_id;\n            current_snapshot.active_run.as_mut().unwrap().stage_cursor =\n                StageCursor::initial(next_stage);\n            current_snapshot.status_summary = format!(\n                \"running: completed {}, next {}\",\n                stage_id.display_name(),\n                next_stage.display_name()\n            );\n        }\n        if let Err(e) = run_snapshot_write.write_run_snapshot(base_dir, project_id, &current_snapshot) {\n            // Roll back payload/artifact; no stage_completed was written yet.\n            // Propagate rollback failure so leaked durable history is surfaced.\n            let rollback_detail = match artifact_write.remove_payload_artifact_pair(base_dir, project_id, &payload_id, &artifact_id) {\n                Ok(()) => String::new(),\n                Err(cleanup_err) => format!(\"; payload/artifact rollback failed: {} — leaked durable history may exist\", cleanup_err),\n            };\n            current_snapshot = pre_commit_snapshot;\n            let commit_err = AppError::StageCommitFailed {\n                stage_id,\n                details: format!(\"snapshot write failed during stage commit: {}{}\", e, rollback_detail),\n            };\n            return fail_run(\n                &commit_err,\n                stage_id,\n                &run_id,\n                &mut seq,\n                &mut current_snapshot,\n                journal_store,\n                run_snapshot_write,\n                base_dir,\n                project_id,\n            )\n            .await;\n        }\n\n        // Step 3: Append stage_completed journal event.\n        // If this fails, roll back payload/artifact and overwrite snapshot\n        // via fail_run so the stage remains uncommitted.\n        seq += 1;\n        let stage_completed = journal::stage_completed_event(\n            seq,\n            Utc::now(),\n            &run_id,\n            stage_id,\n            cursor.cycle,\n            cursor.attempt,\n            &payload_id,\n            &artifact_id,\n        );\n        let stage_completed_line = journal::serialize_event(&stage_completed)?;\n        if let Err(e) = journal_store.append_event(base_dir, project_id, &stage_completed_line) {\n            // Roll back payload/artifact so no partial durable history is visible.\n            // Propagate rollback failure so leaked durable history is surfaced.\n            let rollback_detail = match artifact_write.remove_payload_artifact_pair(base_dir, project_id, &payload_id, &artifact_id) {\n                Ok(()) => String::new(),\n                Err(cleanup_err) => format!(\"; payload/artifact rollback failed: {} — leaked durable history may exist\", cleanup_err),\n            };\n            seq -= 1; // undo the seq increment since the event was not persisted\n            let commit_err = AppError::StageCommitFailed {\n                stage_id,\n                details: format!(\"journal append failed during stage commit: {}{}\", e, rollback_detail),\n            };\n            return fail_run(\n                &commit_err,\n                stage_id,\n                &run_id,\n                &mut seq,\n                &mut current_snapshot,\n                journal_store,\n                run_snapshot_write,\n                base_dir,\n                project_id,\n            )\n            .await;\n        }\n\n        // Best-effort runtime log\n        let _ = log_write.append_runtime_log(\n            base_dir,\n            project_id,\n            &RuntimeLogEntry {\n                timestamp: Utc::now(),\n                level: LogLevel::Info,\n                source: \"engine\".to_owned(),\n                message: format!(\"stage_completed: {}\", stage_id.as_str()),\n            },\n        );\n    }\n\n    // 8. All stages completed — mark run as completed.\n    // Write completed snapshot FIRST so the run is marked as completed\n    // even if journal append fails (consistent with snapshot-first ordering).\n    current_snapshot.status = RunStatus::Completed;\n    current_snapshot.active_run = None;\n    current_snapshot.completion_rounds = 1;\n    current_snapshot.status_summary = \"completed\".to_owned();\n    run_snapshot_write.write_run_snapshot(base_dir, project_id, &current_snapshot)?;\n\n    seq += 1;\n    let run_completed = journal::run_completed_event(seq, Utc::now(), &run_id, 1);\n    let run_completed_line = journal::serialize_event(&run_completed)?;\n    journal_store.append_event(base_dir, project_id, &run_completed_line)?;\n\n    Ok(())\n}\n\n/// Record a run failure: persist failed snapshot, then journal event, return error.\n///\n/// The snapshot is written first (critical path) so the run is never left in an\n/// ambiguous running state. The journal append is best-effort relative to the\n/// snapshot — if it fails, the snapshot already reflects the failed state.\n#[allow(clippy::too_many_arguments)]\nasync fn fail_run(\n    err: &AppError,\n    stage_id: StageId,\n    run_id: &RunId,\n    seq: &mut u64,\n    snapshot: &mut RunSnapshot,\n    journal_store: &dyn JournalStorePort,\n    run_snapshot_write: &dyn RunSnapshotWritePort,\n    base_dir: &Path,\n    project_id: &ProjectId,\n) -> AppResult<()> {\n    let failure_class = err\n        .failure_class()\n        .map(|fc| format!(\"{:?}\", fc))\n        .unwrap_or_else(|| \"unknown\".to_owned());\n    let message = err.to_string();\n\n    // Critical: persist the failed snapshot first so the run is never\n    // left in an ambiguous running state after any failure.\n    snapshot.status = RunStatus::Failed;\n    snapshot.active_run = None;\n    snapshot.status_summary = format!(\"failed at {}: {}\", stage_id.display_name(), message);\n    run_snapshot_write.write_run_snapshot(base_dir, project_id, snapshot)?;\n\n    // Best-effort: append run_failed journal event. If this fails,\n    // the snapshot already reflects the failed state.\n    *seq += 1;\n    let run_failed =\n        journal::run_failed_event(*seq, Utc::now(), run_id, stage_id, &failure_class, &message);\n    if let Ok(run_failed_line) = journal::serialize_event(&run_failed) {\n        let _ = journal_store.append_event(base_dir, project_id, &run_failed_line);\n    }\n\n    Err(AppError::RunStartFailed {\n        reason: format!(\"stage {} failed: {}\", stage_id.as_str(), message),\n    })\n}\n\n/// Helper to get project root path.\nfn project_root_path(base_dir: &Path, project_id: &ProjectId) -> PathBuf {\n    base_dir\n        .join(\".ralph-burning\")\n        .join(\"projects\")\n        .join(project_id.as_str())\n}\n","numLines":587,"startLine":1,"totalLines":587}}}
