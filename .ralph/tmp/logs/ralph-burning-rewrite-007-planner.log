1→    }\n    52→\n    53→    /// Configure a stage to pass preflight but fail during invocation.\n    54→    pub fn with_invoke_failure(mut self, stage_id: StageId) -> Self {\n    55→        self.fail_invoke_stages.insert(stage_id);\n    56→        self\n    57→    }\n    58→\n    59→    pub fn cancelled_invocations(&self) -> Vec<String> {\n    60→        self.cancelled_invocations\n    61→            .lock()\n    62→            .expect(\"cancelled invocation lock poisoned\")\n    63→            .clone()\n    64→    }\n    65→}\n    66→\n    67→impl AgentExecutionPort for StubBackendAdapter {\n    68→    async fn check_capability(\n    69→        &self,\n    70→        backend: &crate::shared::domain::ResolvedBackendTarget,\n    71→        stage_contract: &crate::contexts::workflow_composition::contracts::StageContract,\n    72→    ) -> AppResult<()> {\n    73→        if self.unsupported_stages.contains(&stage_contract.stage_id)\n    74→            || !backend.supports_stage(stage_contract.stage_id)\n    75→        {\n    76→            return Err(AppError::CapabilityMismatch {\n    77→                backend: backend.backend.family.to_string(),\n    78→                stage_id: stage_contract.stage_id,\n    79→                details: \"stub adapter does not support the requested stage\".to_owned(),\n    80→            });\n    81→        }\n    82→\n    83→        Ok(())\n    84→    }\n    85→\n    86→    async fn check_availability(\n    87→        &self,\n    88→        backend: &crate::shared::domain::ResolvedBackendTarget,\n    89→    ) -> AppResult<()> {\n    90→        if self.available {\n    91→            Ok(())\n    92→        } else {\n    93→            Err(AppError::BackendUnavailable {\n    94→                backend: backend.backend.family.to_string(),\n    95→                details: \"stub adapter configured as unavailable\".to_owned(),\n    96→            })\n    97→        }\n    98→    }\n    99→\n   100→    async fn invoke(&self, request: InvocationRequest) -> AppResult<InvocationEnvelope> {\n   101→        if request.cancellation_token.is_cancelled() {\n   102→            return Err(AppError::InvocationCancelled {\n   103→                backend: request.resolved_target.backend.family.to_string(),\n   104→                stage_id: request.stage_contract.stage_id,\n   105→            });\n   106→        }\n   107→\n   108→        if self\n   109→            .fail_invoke_stages\n   110→            .contains(&request.stage_contract.stage_id)\n   111→        {\n   112→            return Err(AppError::InvocationFailed {\n   113→                backend: request.resolved_target.backend.family.to_string(),\n   114→                stage_id: request.stage_contract.stage_id,\n   115→                failure_class: FailureClass::TransportFailure,\n   116→                details: \"stub adapter configured to fail invocation for this stage\".to_owned(),\n   117→            });\n   118→        }\n   119→\n   120→        if self.delay > Duration::from_millis(0) {\n   121→            tokio::select! {\n   122→                _ = request.cancellation_token.cancelled() => {\n   123→                    return Err(AppError::InvocationCancelled {\n   124→                        backend: request.resolved_target.backend.family.to_string(),\n   125→                        stage_id: request.stage_contract.stage_id,\n   126→                    });\n   127→                }\n   128→                _ = tokio::time::sleep(self.delay) => {}\n   129→            }\n   130→        }\n   131→\n   132→        let payload = canned_payload_for_stage(request.stage_contract.stage_id);\n   133→        let raw_output = serde_json::to_string_pretty(&payload)?;\n   134→        let prompt_token_count = count_tokens(&request.payload.prompt);\n   135→        let completion_token_count = count_tokens(&raw_output);\n   136→        let prompt_tokens = Some(prompt_token_count);\n   137→        let completion_tokens = Some(completion_token_count);\n   138→        let total_tokens = Some(prompt_token_count + completion_token_count);\n   139→\n   140→        let supports_reuse =\n   141→            request.role.allows_session_reuse() && request.resolved_target.supports_session_reuse();\n   142→        let session_reused = supports_reuse\n   143→            && matches!(request.session_policy, SessionPolicy::ReuseIfAllowed)\n   144→            && request.prior_session.is_some();\n   145→        let session_id = if supports_reuse {\n   146→            request\n   147→                .prior_session\n   148→                .as_ref()\n   149→                .map(|session| session.session_id.clone())\n   150→                .filter(|_| session_reused)"}]},"parent_tool_use_id":"toolu_012q9xj7KPtJBNnkjPYMMYq8","session_id":"04681ab0-f55e-4c96-b8ca-61b2a1e590bf","uuid":"1978caf4-6b07-411d-9ea2-3e650025a970"}
