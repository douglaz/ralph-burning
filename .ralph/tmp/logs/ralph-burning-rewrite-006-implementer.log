{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_018DvCcgwhAo9hEVNmkAp4W7","type":"tool_result","content":"     1→use clap::{Args, Subcommand};\n     2→\n     3→use crate::adapters::fs::{\n     4→    FsArtifactStore, FsJournalStore, FsPayloadArtifactWriteStore, FsProjectStore,\n     5→    FsRawOutputStore, FsRunSnapshotStore, FsRunSnapshotWriteStore, FsRuntimeLogStore,\n     6→    FsRuntimeLogWriteStore, FsSessionStore,\n     7→};\n     8→use crate::adapters::stub_backend::StubBackendAdapter;\n     9→use crate::contexts::agent_execution::service::AgentExecutionService;\n    10→use crate::contexts::project_run_record::service::{self, ProjectStorePort, RunSnapshotPort};\n    11→use crate::contexts::workflow_composition::engine;\n    12→use crate::contexts::workspace_governance;\n    13→use crate::contexts::workspace_governance::config::EffectiveConfig;\n    14→use crate::shared::domain::FlowPreset;\n    15→use crate::shared::error::{AppError, AppResult};\n    16→\n    17→#[derive(Debug, Args)]\n    18→pub struct RunCommand {\n    19→    #[command(subcommand)]\n    20→    pub command: RunSubcommand,\n    21→}\n    22→\n    23→#[derive(Debug, Subcommand)]\n    24→pub enum RunSubcommand {\n    25→    Start,\n    26→    Resume,\n    27→    Status,\n    28→    History,\n    29→    Tail {\n    30→        #[arg(long)]\n    31→        logs: bool,\n    32→    },\n    33→    Rollback {\n    34→        #[arg(long)]\n    35→        to: String,\n    36→        #[arg(long)]\n    37→        hard: bool,\n    38→    },\n    39→}\n    40→\n    41→pub async fn handle(command: RunCommand) -> AppResult<()> {\n    42→    match command.command {\n    43→        RunSubcommand::Status => handle_status().await,\n    44→        RunSubcommand::History => handle_history().await,\n    45→        RunSubcommand::Tail { logs } => handle_tail(logs).await,\n    46→        RunSubcommand::Start => handle_start().await,\n    47→        RunSubcommand::Resume => Err(AppError::NotYetImplemented {\n    48→            command: \"run resume\".to_owned(),\n    49→        }),\n    50→        RunSubcommand::Rollback { .. } => Err(AppError::NotYetImplemented {\n    51→            command: \"run rollback\".to_owned(),\n    52→        }),\n    53→    }\n    54→}\n    55→\n    56→pub fn build_agent_execution_service(\n    57→) -> AgentExecutionService<StubBackendAdapter, FsRawOutputStore, FsSessionStore> {\n    58→    AgentExecutionService::new(\n    59→        StubBackendAdapter::default(),\n    60→        FsRawOutputStore,\n    61→        FsSessionStore,\n    62→    )\n    63→}\n    64→\n    65→async fn handle_start() -> AppResult<()> {\n    66→    let current_dir = std::env::current_dir()?;\n    67→\n    68→    // Validate workspace version\n    69→    let config = workspace_governance::load_workspace_config(&current_dir)?;\n    70→    workspace_governance::ensure_supported_workspace_version(&config)?;\n    71→\n    72→    // Resolve active project\n    73→    let project_id = workspace_governance::resolve_active_project(&current_dir)?;\n    74→\n    75→    // Validate canonical project record\n    76→    let project_store = FsProjectStore;\n    77→    let project_record = project_store.read_project_record(&current_dir, &project_id)?;\n    78→\n    79→    // Only standard flow is supported in this slice\n    80→    if project_record.flow != FlowPreset::Standard {\n    81→        return Err(AppError::UnsupportedFlow {\n    82→            flow_id: project_record.flow.as_str().to_owned(),\n    83→        });\n    84→    }\n    85→\n    86→    // Validate run snapshot integrity\n    87→    let run_snapshot_read = FsRunSnapshotStore;\n    88→    let run_snapshot = run_snapshot_read.read_run_snapshot(&current_dir, &project_id)?;\n    89→\n    90→    // Check preconditions before engine call (fail fast with clear errors)\n    91→    if run_snapshot.status != crate::contexts::project_run_record::model::RunStatus::NotStarted {\n    92→        return Err(AppError::RunStartFailed {\n    93→            reason: format!(\n    94→                \"project snapshot status is '{}'; run start requires 'not_started'\",\n    95→                run_snapshot.status\n    96→            ),\n    97→        });\n    98→    }\n    99→    if run_snapshot.has_active_run() {\n   100→        return Err(AppError::RunStartFailed {\n   101→            reason: \"project already has an active run\".to_owned(),\n   102→        });\n   103→    }\n   104→\n   105→    let effective_config = EffectiveConfig::load(&current_dir)?;\n   106→\n   107→    let agent_service = build_agent_execution_service();\n   108→    let run_snapshot_write = FsRunSnapshotWriteStore;\n   109→    let journal_store = FsJournalStore;\n   110→    let artifact_write = FsPayloadArtifactWriteStore;\n   111→    let log_write = FsRuntimeLogWriteStore;\n   112→\n   113→    println!(\"Starting run for project '{}'...\", project_id);\n   114→\n   115→    engine::execute_standard_run(\n   116→        &agent_service,\n   117→        &run_snapshot_read,\n   118→        &run_snapshot_write,\n   119→        &journal_store,\n   120→        &artifact_write,\n   121→        &log_write,\n   122→        &current_dir,\n   123→        &project_id,\n   124→        &effective_config,\n   125→    )\n   126→    .await?;\n   127→\n   128→    println!(\"Run completed successfully.\");\n   129→    Ok(())\n   130→}\n   131→\n   132→async fn handle_status() -> AppResult<()> {\n   133→    let current_dir = std::env::current_dir()?;\n   134→\n   135→    let config = workspace_governance::load_workspace_config(&current_dir)?;\n   136→    workspace_governance::ensure_supported_workspace_version(&config)?;\n   137→\n   138→    let project_id = workspace_governance::resolve_active_project(&current_dir)?;\n   139→\n   140→    // Validate canonical project record before proceeding with run queries\n   141→    let project_store = FsProjectStore;\n   142→    let _ = project_store.read_project_record(&current_dir, &project_id)?;\n   143→\n   144→    let run_store = FsRunSnapshotStore;\n   145→    let status = service::run_status(&run_store, &current_dir, &project_id)?;\n   146→\n   147→    println!(\"Project: {}\", status.project_id);\n   148→    println!(\"Status: {}\", status.status);\n   149→    if let Some(ref stage) = status.stage {\n   150→        println!(\"Stage: {}\", stage);\n   151→    }\n   152→    if let Some(cycle) = status.cycle {\n   153→        println!(\"Cycle: {}\", cycle);\n   154→    }\n   155→    if let Some(round) = status.completion_round {\n   156→        println!(\"Completion round: {}\", round);\n   157→    }\n   158→    println!(\"Summary: {}\", status.summary);\n   159→\n   160→    Ok(())\n   161→}\n   162→\n   163→async fn handle_history() -> AppResult<()> {\n   164→    let current_dir = std::env::current_dir()?;\n   165→\n   166→    let config = workspace_governance::load_workspace_config(&current_dir)?;\n   167→    workspace_governance::ensure_supported_workspace_version(&config)?;\n   168→\n   169→    let project_id = workspace_governance::resolve_active_project(&current_dir)?;\n   170→\n   171→    // Validate canonical project record before proceeding with run queries\n   172→    let project_store = FsProjectStore;\n   173→    let _ = project_store.read_project_record(&current_dir, &project_id)?;\n   174→\n   175→    let journal_store = FsJournalStore;\n   176→    let artifact_store = FsArtifactStore;\n   177→\n   178→    let history = service::run_history(&journal_store, &artifact_store, &current_dir, &project_id)?;\n   179→\n   180→    println!(\"Project: {}\", history.project_id);\n   181→    println!(\"--- Journal Events ---\");\n   182→    for event in &history.events {\n   183→        println!(\n   184→            \"  [{}] {} - {:?}\",\n   185→            event.sequence, event.timestamp, event.event_type\n   186→        );\n   187→    }\n   188→\n   189→    if !history.payloads.is_empty() {\n   190→        println!(\"--- Payloads ---\");\n   191→        for payload in &history.payloads {\n   192→            println!(\n   193→                \"  {} ({}, cycle {}, attempt {})\",\n   194→                payload.payload_id, payload.stage_id, payload.cycle, payload.attempt\n   195→            );\n   196→        }\n   197→    }\n   198→\n   199→    if !history.artifacts.is_empty() {\n   200→        println!(\"--- Artifacts ---\");\n   201→        for artifact in &history.artifacts {\n   202→            println!(\n   203→                \"  {} (payload: {}, stage: {})\",\n   204→                artifact.artifact_id, artifact.payload_id, artifact.stage_id\n   205→            );\n   206→        }\n   207→    }\n   208→\n   209→    Ok(())\n   210→}\n   211→\n   212→async fn handle_tail(include_logs: bool) -> AppResult<()> {\n   213→    let current_dir = std::env::current_dir()?;\n   214→\n   215→    let config = workspace_governance::load_workspace_config(&current_dir)?;\n   216→    workspace_governance::ensure_supported_workspace_version(&config)?;\n   217→\n   218→    let project_id = workspace_governance::resolve_active_project(&current_dir)?;\n   219→\n   220→    // Validate canonical project record before proceeding with run queries\n   221→    let project_store = FsProjectStore;\n   222→    let _ = project_store.read_project_record(&current_dir, &project_id)?;\n   223→\n   224→    let journal_store = FsJournalStore;\n   225→    let artifact_store = FsArtifactStore;\n   226→    let log_store = FsRuntimeLogStore;\n   227→\n   228→    let tail = service::run_tail(\n   229→        &journal_store,\n   230→        &artifact_store,\n   231→        &log_store,\n   232→        &current_dir,\n   233→        &project_id,\n   234→        include_logs,\n   235→    )?;\n   236→\n   237→    println!(\"Project: {}\", tail.project_id);\n   238→    println!(\"--- Durable History ---\");\n   239→    for event in &tail.events {\n   240→        println!(\n   241→            \"  [{}] {} - {:?}\",\n   242→            event.sequence, event.timestamp, event.event_type\n   243→        );\n   244→    }\n   245→\n   246→    if !tail.payloads.is_empty() {\n   247→        println!(\"--- Payloads ---\");\n   248→        for payload in &tail.payloads {\n   249→            println!(\n   250→                \"  {} ({}, cycle {}, attempt {})\",\n   251→                payload.payload_id, payload.stage_id, payload.cycle, payload.attempt\n   252→            );\n   253→        }\n   254→    }\n   255→\n   256→    if !tail.artifacts.is_empty() {\n   257→        println!(\"--- Artifacts ---\");\n   258→        for artifact in &tail.artifacts {\n   259→            println!(\n   260→                \"  {} (payload: {}, stage: {})\",\n   261→                artifact.artifact_id, artifact.payload_id, artifact.stage_id\n   262→            );\n   263→        }\n   264→    }\n   265→\n   266→    if let Some(ref logs) = tail.runtime_logs {\n   267→        println!(\"--- Runtime Logs ---\");\n   268→        if logs.is_empty() {\n   269→            println!(\"  (no runtime logs)\");\n   270→        } else {\n   271→            for log in logs {\n   272→                println!(\n   273→                    \"  [{}] {:?} [{}] {}\",\n   274→                    log.timestamp, log.level, log.source, log.message\n   275→                );\n   276→            }\n   277→        }\n   278→    }\n   279→\n   280→    Ok(())\n   281→}\n   282→"}]},"parent_tool_use_id":"toolu_01VwuMdbo4Yfw9qb7NhghzrF","session_id":"19a33b10-b5a0-4ba2-8943-a7efa3e34818","uuid":"93f9e3b3-36a9-456f-975b-30b63d4d50c3"}
