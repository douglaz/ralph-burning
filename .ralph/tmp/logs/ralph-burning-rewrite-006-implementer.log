sessions.json`.\n#[derive(Debug, Clone, PartialEq, Serialize, Deserialize)]\npub struct SessionStore {\n    pub sessions: Vec<serde_json::Value>,\n}\n\nimpl SessionStore {\n    pub fn empty() -> Self {\n        Self {\n            sessions: Vec::new(),\n        }\n    }\n}\n\n/// Summary used in `project list` output.\n#[derive(Debug, Clone)]\npub struct ProjectListEntry {\n    pub id: ProjectId,\n    pub name: String,\n    pub flow: FlowPreset,\n    pub status_summary: ProjectStatusSummary,\n    pub created_at: DateTime<Utc>,\n    pub is_active: bool,\n}\n\n/// Detailed project view used in `project show` output.\n#[derive(Debug, Clone)]\npub struct ProjectDetail {\n    pub record: ProjectRecord,\n    pub run_snapshot: RunSnapshot,\n    pub journal_event_count: u64,\n    pub rollback_count: usize,\n    pub is_active: bool,\n}\n","numLines":242,"startLine":1,"totalLines":242}}}
