{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01F99Vg2wmZQcXco2fpJRaTY","type":"tool_result","content":"     1→#![forbid(unsafe_code)]\n     2→\n     3→//! Deterministic Markdown renderers for validated stage payloads.\n     4→//!\n     5→//! Each renderer produces byte-identical output for the same input, uses canonical\n     6→//! `cycle` terminology, and derives content only from validated structured fields —\n     7→//! never from raw backend text.\n     8→\n     9→use std::fmt::Write;\n    10→\n    11→use crate::shared::domain::StageId;\n    12→\n    13→use super::payloads::{ExecutionPayload, PlanningPayload, ValidationPayload};\n    14→\n    15→/// Render a planning payload to deterministic Markdown.\n    16→pub fn render_planning(stage_id: StageId, payload: &PlanningPayload) -> String {\n    17→    let mut out = String::new();\n    18→\n    19→    writeln!(out, \"# {}\", stage_id.display_name()).unwrap();\n    20→    writeln!(out).unwrap();\n    21→    writeln!(out, \"## Problem Framing\").unwrap();\n    22→    writeln!(out).unwrap();\n    23→    writeln!(out, \"{}\", payload.problem_framing).unwrap();\n    24→    writeln!(out).unwrap();\n    25→\n    26→    writeln!(out, \"## Assumptions and Open Questions\").unwrap();\n    27→    writeln!(out).unwrap();\n    28→    if payload.assumptions_or_open_questions.is_empty() {\n    29→        writeln!(out, \"None.\").unwrap();\n    30→    } else {\n    31→        for item in &payload.assumptions_or_open_questions {\n    32→            writeln!(out, \"- {item}\").unwrap();\n    33→        }\n    34→    }\n    35→    writeln!(out).unwrap();\n    36→\n    37→    writeln!(out, \"## Proposed Work\").unwrap();\n    38→    writeln!(out).unwrap();\n    39→    for item in &payload.proposed_work {\n    40→        writeln!(out, \"{}. **{}**\", item.order, item.summary).unwrap();\n    41→        if !item.details.is_empty() {\n    42→            writeln!(out, \"   {}\", item.details).unwrap();\n    43→        }\n    44→    }\n    45→    writeln!(out).unwrap();\n    46→\n    47→    writeln!(out, \"## Readiness\").unwrap();\n    48→    writeln!(out).unwrap();\n    49→    let ready_str = if payload.readiness.ready { \"Yes\" } else { \"No\" };\n    50→    writeln!(out, \"- **Ready:** {ready_str}\").unwrap();\n    51→    if payload.readiness.risks.is_empty() {\n    52→        writeln!(out, \"- **Risks:** None identified.\").unwrap();\n    53→    } else {\n    54→        writeln!(out, \"- **Risks:**\").unwrap();\n    55→        for risk in &payload.readiness.risks {\n    56→            writeln!(out, \"  - {risk}\").unwrap();\n    57→        }\n    58→    }\n    59→\n    60→    out\n    61→}\n    62→\n    63→/// Render an execution payload to deterministic Markdown.\n    64→pub fn render_execution(stage_id: StageId, payload: &ExecutionPayload) -> String {\n    65→    let mut out = String::new();\n    66→\n    67→    writeln!(out, \"# {}\", stage_id.display_name()).unwrap();\n    68→    writeln!(out).unwrap();\n    69→    writeln!(out, \"## Change Summary\").unwrap();\n    70→    writeln!(out).unwrap();\n    71→    writeln!(out, \"{}\", payload.change_summary).unwrap();\n    72→    writeln!(out).unwrap();\n    73→\n    74→    writeln!(out, \"## Steps\").unwrap();\n    75→    writeln!(out).unwrap();\n    76→    for step in &payload.steps {\n    77→        writeln!(\n    78→            out,\n    79→            \"{}. [{}] {}\",\n    80→            step.order, step.status, step.description"}]},"parent_tool_use_id":"toolu_01BNmMHXmrpqphqEoDzMeewD","session_id":"b9859e69-5579-4e82-ac66-49d19cc80e05","uuid":"10682633-364a-433d-adcd-c16f116c5da0"}
