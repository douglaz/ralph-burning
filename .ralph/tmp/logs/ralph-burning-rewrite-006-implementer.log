assert!(!unknown.status.success());\n   207→    assert!(String::from_utf8_lossy(&unknown.stderr).contains(\"unknown config key\"));\n   208→}\n   209→\n   210→#[test]\n   211→fn config_set_updates_valid_keys_and_rejects_invalid_values() {\n   212→    let temp_dir = initialize_workspace_fixture();\n   213→\n   214→    let valid = Command::new(binary())\n   215→        .args([\"config\", \"set\", \"default_flow\", \"quick_dev\"])\n   216→        .current_dir(temp_dir.path())\n   217→        .output()\n   218→        .expect(\"run config set\");\n   219→    assert!(valid.status.success());\n   220→    assert!(String::from_utf8_lossy(&valid.stdout).contains(\"Updated default_flow = quick_dev\"));\n   221→\n   222→    let workspace_config =\n   223→        fs::read_to_string(temp_dir.path().join(\".ralph-burning/workspace.toml\"))\n   224→            .expect(\"read workspace config\");\n   225→    assert!(workspace_config.contains(\"default_flow = \\\"quick_dev\\\"\"));\n   226→\n   227→    let invalid_value = Command::new(binary())\n   228→        .args([\"config\", \"set\", \"default_flow\", \"unknown_flow\"])\n   229→        .current_dir(temp_dir.path())\n   230→        .output()\n   231→        .expect(\"run invalid config set\");\n   232→    assert!(!invalid_value.status.success());\n   233→    assert!(String::from_utf8_lossy(&invalid_value.stderr).contains(\"invalid value\"));\n   234→\n   235→    let invalid_key = Command::new(binary())\n   236→        .args([\"config\", \"set\", \"unknown.key\", \"value\"])\n   237→        .current_dir(temp_dir.path())\n   238→        .output()\n   239→        .expect(\"run invalid key config set\");\n   240→    assert!(!invalid_key.status.success());\n   241→    assert!(String::from_utf8_lossy(&invalid_key.stderr).contains(\"unknown config key\"));\n   242→}\n   243→\n   244→#[test]\n   245→fn config_edit_revalidates_workspace_file() {\n   246→    let temp_dir = initialize_workspace_fixture();\n   247→    let editor = write_editor_script(\n   248→        temp_dir.path(),\n   249→        \"editor-valid.sh\",\n   250→        \"#!/bin/sh\\ncat <<'EOF' > \\\"$1\\\"\\nversion = 1\\ncreated_at = \\\"2026-03-11T17:50:55Z\\\"\\n\\n[settings]\\ndefault_backend = \\\"claude\\\"\\nEOF\\n\",\n   251→    );\n   252→\n   253→    let output = Command::new(binary())\n   254→        .args([\"config\", \"edit\"])\n   255→        .env(\"EDITOR\", &editor)\n   256→        .env_remove(\"VISUAL\")\n   257→        .current_dir(temp_dir.path())\n   258→        .output()\n   259→        .expect(\"run config edit\");\n   260→\n   261→    assert!(output.status.success());\n   262→    assert!(String::from_utf8_lossy(&output.stdout).contains(\"Validated workspace.toml\"));\n   263→}\n   264→\n   265→#[test]\n   266→fn config_edit_prefers_editor_over_visual() {\n   267→    let temp_dir = initialize_workspace_fixture();\n   268→    let editor = write_editor_script(\n   269→        temp_dir.path(),\n   270→        \"editor-wins.sh\",\n   271→        \"#!/bin/sh\\ncat <<'EOF' > \\\"$1\\\"\\nversion = 1\\ncreated_at = \\\"2026-03-11T17:50:55Z\\\"\\n\\n[settings]\\ndefault_backend = \\\"editor\\\"\\nEOF\\n\",\n   272→    );\n   273→    let visual = write_editor_script(\n   274→        temp_dir.path(),\n   275→        \"visual-loses.sh\",\n   276→        \"#!/bin/sh\\ncat <<'EOF' > \\\"$1\\\"\\nversion = 1\\ncreated_at = \\\"2026-03-11T17:50:55Z\\\"\\n\\n[settings]\\ndefault_backend = \\\"visual\\\"\\nEOF\\n\",\n   277→    );\n   278→\n   279→    let output = Command::new(binary())\n   280→        .args([\"config\", \"edit\"])\n   281→        .env(\"EDITOR\", &editor)\n   282→        .env(\"VISUAL\", &visual)\n   283→        .current_dir(temp_dir.path())\n   284→        .output()\n   285→        .expect(\"run config edit\");\n   286→\n   287→    assert!(output.status.success());\n   288→\n   289→    let workspace_config =\n   290→        fs::read_to_string(temp_dir.path().join(\".ralph-burning/workspace.toml\"))\n   291→            .expect(\"read workspace config\");\n   292→    assert!(workspace_config.contains(\"default_backend = \\\"editor\\\"\"));\n   293→    assert!(!workspace_config.contains(\"default_backend = \\\"visual\\\"\"));\n   294→}\n   295→\n   296→#[test]\n   297→fn config_edit_fails_when_editor_leaves_invalid_file() {\n   298→    let temp_dir = initialize_workspace_fixture();\n   299→    let editor = write_editor_script(\n   300→        temp_dir.path(),\n   301→        \"editor-invalid.sh\",\n   302→        \"#!/bin/sh\\nprintf '%s\\n' 'version = 999' 'created_at = \\\"2026-03-11T17:50:55Z\\\"' > \\\"$1\\\"\\n\",\n   303→    );\n   304→\n   305→    let output = Command::new(binary())\n   306→        .args([\"config\", \"edit\"])\n   307→        .env(\"EDITOR\", &editor)\n   308→        .env_remove(\"VISUAL\")\n   309→        .current_dir(temp_dir.path())\n   310→        .output()\n   311→        .expect(\"run invalid config edit\");\n   312→\n   313→    assert!(!output.status.success());\n   314→    let stderr = String::from_utf8_lossy(&output.stderr);\n   315→    assert!(stderr.contains(\"workspace.toml is invalid after editing\"));\n   316→    assert!(stderr.contains(\"unsupported workspace version 999\"));\n   317→}\n   318→\n   319→#[test]\n   320→fn project_select_sets_active_project_and_rejects_missing_projects() {\n   321→    let temp_dir = initialize_workspace_fixture();\n   322→    create_project_fixture(temp_dir.path(), \"alpha\");\n   323→\n   324→    let existing = Command::new(binary())\n   325→        .args([\"project\", \"select\", \"alpha\"])\n   326→        .current_dir(temp_dir.path())\n   327→        .output()\n   328→        .expect(\"run project select\");\n   329→    assert!(existing.status.success());\n   330→    assert!(String::from_utf8_lossy(&existing.stdout).contains(\"Selected project alpha\"));\n   331→    assert_eq!(\n   332→        \"alpha\",\n   333→        fs::read_to_string(temp_dir.path().join(\".ralph-burning/active-project\"))\n   3