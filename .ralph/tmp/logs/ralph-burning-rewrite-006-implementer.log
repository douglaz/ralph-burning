{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01MnXq7DzjWBwLNcKA22XqKJ","type":"tool_result","content":"     1→use std::fs;\n     2→use std::path::Path;\n     3→\n     4→use chrono::Utc;\n     5→use tempfile::tempdir;\n     6→\n     7→use ralph_burning::adapters::fs::{\n     8→    FsJournalStore, FsPayloadArtifactWriteStore, FsProjectStore, FsRawOutputStore,\n     9→    FsRunSnapshotStore, FsRunSnapshotWriteStore, FsRuntimeLogWriteStore, FsSessionStore,\n    10→};\n    11→use ralph_burning::adapters::stub_backend::StubBackendAdapter;\n    12→use ralph_burning::contexts::agent_execution::service::AgentExecutionService;\n    13→use ralph_burning::contexts::project_run_record::model::{\n    14→    JournalEventType, RunSnapshot, RunStatus,\n    15→};\n    16→use ralph_burning::contexts::project_run_record::service::{\n    17→    self, CreateProjectInput, JournalStorePort, RunSnapshotPort, RunSnapshotWritePort,\n    18→};\n    19→use ralph_burning::contexts::workflow_composition::engine;\n    20→use ralph_burning::contexts::workspace_governance;\n    21→use ralph_burning::contexts::workspace_governance::config::EffectiveConfig;\n    22→use ralph_burning::shared::domain::{FlowPreset, ProjectId, StageId};\n    23→\n    24→fn setup_workspace(base_dir: &Path) {\n    25→    workspace_governance::initialize_workspace(base_dir, Utc::now()).unwrap();\n    26→}\n    27→\n    28→fn create_standard_project(base_dir: &Path, project_id: &str) -> ProjectId {\n    29→    let pid = ProjectId::new(project_id).unwrap();\n    30→    let store = FsProjectStore;\n    31→    let journal_store = FsJournalStore;\n    32→    service::create_project(\n    33→        &store,\n    34→        &journal_store,\n    35→        base_dir,\n    36→        CreateProjectInput {\n    37→            id: pid.clone(),\n    38→            name: format!(\"Test {}\", project_id),\n    39→            flow: FlowPreset::Standard,\n    40→            prompt_path: \"prompt.md\".to_owned(),\n    41→            prompt_contents: \"# Test prompt\".to_owned(),\n    42→            prompt_hash: \"testhash123\".to_owned(),\n    43→            created_at: Utc::now(),\n    44→        },\n    45→    )\n    46→    .unwrap();\n    47→\n    48→    // Select as active\n    49→    workspace_governance::set_active_project(base_dir, &pid).unwrap();\n    50→    pid\n    51→}\n    52→\n    53→fn build_agent_service(\n    54→) -> AgentExecutionService<StubBackendAdapter, FsRawOutputStore, FsSessionStore> {\n    55→    AgentExecutionService::new(\n    56→        StubBackendAdapter::default(),\n    57→        FsRawOutputStore,\n    58→        FsSessionStore,\n    59→    )\n    60→}\n    61→\n    62→// ── Stage plan tests ────────────────────────────────────────────────────────\n    63→\n    64→#[test]\n    65→fn stage_plan_with_prompt_review_enabled() {\n    66→    let plan = engine::standard_stage_plan(true);\n    67→    assert_eq!(plan.len(), 8);\n    68→    assert_eq!(plan[0], StageId::PromptReview);\n    69→    assert_eq!(plan[1], StageId::Planning);\n    70→    assert_eq!(plan[7], StageId::FinalReview);\n    71→}\n    72→\n    73→#[test]\n    74→fn stage_plan_with_prompt_review_disabled() {\n    75→    let plan = engine::standard_stage_plan(false);\n    76→    assert_eq!(plan.len(), 7);\n    77→    assert_eq!(plan[0], StageId::Planning);\n    78→    assert!(!plan.contains(&StageId::PromptReview));\n    79→}\n    80→\n    81→#[test]\n    82→fn role_mapping_is_deterministic() {\n    83→    use ralph_burning::shared::domain::BackendRole;\n    84→    assert_eq!(engine::role_for_stage(StageId::PromptReview), BackendRole::Planner);\n    85→    assert_eq!(engine::role_for_stage(StageId::Planning), BackendRole::Planner);\n    86→    assert_eq!(engine::role_for_stage(StageId::Implementation), BackendRole::Implementer);\n    87→    assert_eq!(engine::role_for_stage(StageId::Qa), BackendRole::QaValidator);\n    88→    assert_eq!(engine::role_for_stage(StageId::Review), BackendRole::Reviewer);\n    89→    assert_eq!(engine::role_for_stage(StageId::CompletionPanel), BackendRole::CompletionJudge);\n    90→    assert_eq!(engine::role_for_stage(StageId::AcceptanceQa), BackendRole::QaValidator);\n    91→    assert_eq!(engine::role_for_stage(StageId::FinalReview), BackendRole::Reviewer);\n    92→}\n    93→\n    94→// ── Happy path tests ────────────────────────────────────────────────────────\n    95→\n    96→#[tokio::test]\n    97→async fn happy_path_standard_run_completes() {\n    98→    let tmp = tempdir().unwrap();\n    99→    let base_dir = tmp.path();\n   100→\n   101→    setup_workspace(base_dir);\n   102→    let pid = create_standard_project(base_dir, \"happy-test\");\n   103→\n   104→    let agent_service = build_agent_service();\n   105→    let config = EffectiveConfig::load(base_dir).unwrap();\n   106→\n   107→    let result = engine::execute_standard_run(\n   108→        &agent_service,\n   109→        &FsRunSnapshotStore,\n   110→        &FsRunSnapshotWriteStore,\n   111→        &FsJournalStore,\n   112→        &FsPayloadArtifactWriteStore,\n   113→        &FsRuntimeLogWriteStore,\n   114→        base_dir,\n   115→        &pid,\n   116→        &config,\n   117→    )\n   118→    .await;\n   119→\n   120→    assert!(result.is_ok(), \"execute_standard_run failed: {:?}\", result.err());\n   121→\n   122→    // Verify final run snapshot\n   123→    let snapshot = FsRunSnapshotStore.read_run_snapshot(base_dir, &pid).unwrap();\n   124→    assert_eq!(snapshot.status, RunStatus::Completed);\n   125→    assert!(snapshot.active_run.is_none());\n   126→    assert_eq!(snapshot.completion_rounds, 1);\n   127→    assert_eq!(snapshot.status_summary, \"completed\");\n   128→\n   129→    // Verify journal events\n   130→    let events = FsJournalStore.read_journal(base_dir, &pid).unwrap();\n   131→    // project_created + run_started + (8 * (stage_entered + stage_completed)) + run_completed\n   132→    // = 1 + 1 + 16 + 1 = 19 events (with prompt_review enabled by default)\n   133→    assert!(events.len() >= 19, \"expected >= 19 events, got {}\", events.len());\n   134→\n   135→    // First event should be project_created, second run_started\n   136→    assert_eq!(events[0].event_type, JournalEventType::ProjectCreated);\n   137→    assert_eq!(events[1].event_type, JournalEventType::RunStarted);\n   138→\n   139→    // Last event should be run_completed\n   140→    assert_eq!(events.last().unwrap().event_type, JournalEventType::RunCompleted);\n   141→\n   142→    // Verify payloads and artifacts were written\n   143→    let payloads_dir = base_dir\n   144→        .join(\".ralph-burning/projects/happy-test/history/payloads\");\n   145→    let artifacts_dir = base_dir\n   146→        .join(\".ralph-burning/projects/happy-test/history/artifacts\");\n   147→    let payload_count = fs::read_dir(&payloads_dir).unwrap().count();\n   148→    let artifact_count = fs::read_dir(&artifacts_dir).unwrap().count();\n   149→    assert_eq!(payload_count, 8, \"expected 8 payloads\");\n   150→    assert_eq!(artifact_count, 8, \"expected 8 artifacts\");\n   151→}\n   152→\n   153→#[tokio::test]\n   154→async fn happy_path_prompt_review_disabled() {\n   155→    let tmp = tempdir().unwrap();\n   156→    let base_dir = tmp.path();\n   157→\n   158→    setup_workspace(base_dir);\n   159→\n   160→    // Disable prompt review in config\n   161→    workspace_governance::config::EffectiveConfig::set(base_dir, \"prompt_review.enabled\", \"false\")\n   162→        .unwrap();\n   163→\n   164→    let pid = create_standard_project(base_dir, \"no-pr-test\");\n   165→\n   166→    let agent_service = build_agent_service();\n   167→    let config = EffectiveConfig::load(base_dir).unwrap();\n   168→    assert!(!config.prompt_review_enabled());\n   169→\n   170→    let result = engine::execute_standard_run(\n   171→        &agent_service,\n   172→        &FsRunSnapshotStore,\n   173→        &FsRunSnapshotWriteStore,\n   174→        &FsJournalStore,\n   175→        &FsPayloadArtifactWriteStore,\n   176→        &FsRuntimeLogWriteStore,\n   177→        base_dir,\n   178→        &pid,\n   179→        &config,\n   180→    )\n   181→    .await;\n   182→\n   183→    assert!(result.is_ok());\n   184→\n   185→    // Verify 7 stages completed (no prompt_review)\n   186→    let payloads_dir = base_dir\n   187→        .join(\".ralph-burning/projects/no-pr-test/history/payloads\");\n   188→    let payload_count = fs::read_dir(&payloads_dir).unwrap().count();\n   189→    assert_eq!(payload_count, 7, \"expected 7 payloads without prompt_review\");\n   190→\n   191→    // Verify no prompt_review stage_entered in journal\n   192→    let events = FsJournalStore.read_journal(base_dir, &pid).unwrap();\n   193→    let pr_events: Vec<_> = events\n   194→        .iter()\n   195→        .filter(|e| {\n   196→            if e.event_type == JournalEventType::StageEntered {\n   197→                e.details.get(\"stage_id\").and_then(|v| v.as_str()) == Some(\"prompt_review\")\n   198→            } else {\n   199→                false\n   200→            }\n   201→        })\n   202→        .collect();\n   203→    assert!(pr_events.is_empty(), \"prompt_review stage should not appear\");\n   204→}\n   205→\n   206→// ── Precondition failure tests ──────────────────────────────────────────────\n   207→\n   208→#[tokio::test]\n   209→async fn run_start_rejects_already_running() {\n   210→    let tmp = tempdir().unwrap();\n   211→    let base_dir = tmp.path();\n   212→\n   213→    setup_workspace(base_dir);\n   214→    let pid = create_standard_project(base_dir, \"running-test\");\n   215→\n   216→    // Manually set status to running\n   217→    let snapshot = RunSnapshot {\n   218→        active_run: Some(ralph_burning::contexts::project_run_record::model::ActiveRun {\n   219→            run_id: \"run-fake\".to_owned(),\n   220→            stage_cursor: ralph_burning::shared::domain::StageCursor::initial(StageId::Planning),\n   221→            started_at: Utc::now(),\n   222→        }),\n   223→        status: RunStatus::Running,\n   224→        cycle_history: vec![],\n   225→        completion_rounds: 0,\n   226→        rollback_point_meta: Default::default(),\n   227→        amendment_queue: Default::default(),\n   228→        status_summary: \"running\".to_owned(),\n   229→    };\n   230→    FsRunSnapshotWriteStore\n   231→        .write_run_snapshot(base_dir, &pid, &snapshot)\n   232→        .unwrap();\n   233→\n   234→    let agent_service = build_agent_service();\n   235→    let config = EffectiveConfig::load(base_dir).unwrap();\n   236→\n   237→    let result = engine::execute_standard_run(\n   238→        &agent_service,\n   239→        &FsRunSnapshotStore,\n   240→        &FsRunSnapshotWriteStore,\n   241→        &FsJournalStore,\n   242→        &FsPayloadArtifactWriteStore,\n   243→        &FsRuntimeLogWriteStore,\n   244→        base_dir,\n   245→        &pid,\n   246→        &config,\n   247→    )\n   248→    .await;\n   249→\n   250→    assert!(result.is_err());\n   251→    let err = result.unwrap_err().to_string();\n   252→    assert!(err.contains(\"not_started\"), \"unexpected error: {}\", err);\n   253→}\n   254→\n   255→#[tokio::test]\n   256→async fn run_start_rejects_completed_project() {\n   257→    let tmp = tempdir().unwrap();\n   258→    let base_dir = tmp.path();\n   259→\n   260→    setup_workspace(base_dir);\n   261→    let pid = create_standard_project(base_dir, \"completed-test\");\n   262→\n   263→    let snapshot = RunSnapshot {\n   264→        active_run: None,\n   265→        status: RunStatus::Completed,\n   266→        cycle_history: vec![],\n   267→        completion_rounds: 1,\n   268→        rollback_point_meta: Default::default(),\n   269→        amendment_queue: Default::default(),\n   270→        status_summary: \"completed\".to_owned(),\n   271→    };\n   272→    FsRunSnapshotWriteStore\n   273→        .write_run_snapshot(base_dir, &pid, &snapshot)\n   274→       