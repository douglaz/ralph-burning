d: self.completion_round,\n   473→        }\n   474→    }\n   475→\n   476→    pub fn advance_stage(&self, stage: StageId) -> Self {\n   477→        Self {\n   478→            stage,\n   479→            cycle: self.cycle,\n   480→            attempt: 1,\n   481→            completion_round: self.completion_round,\n   482→        }\n   483→    }\n   484→\n   485→    pub fn advance_cycle(&self, stage: StageId) -> Self {\n   486→        Self {\n   487→            stage,\n   488→            cycle: self.cycle + 1,\n   489→            attempt: 1,\n   490→            completion_round: self.completion_round,\n   491→        }\n   492→    }\n   493→\n   494→    pub fn advance_completion_round(&self, stage: StageId) -> Self {\n   495→        Self {\n   496→            stage,\n   497→            cycle: self.cycle,\n   498→            attempt: 1,\n   499→            completion_round: self.completion_round + 1,\n   500→        }\n   501→    }\n   502→}\n   503→\n   504→#[derive(Debug, Clone, PartialEq, Eq, Hash, Serialize, Deserialize)]\n   505→#[serde(transparent)]\n   506→pub struct ProjectId(String);\n   507→\n   508→impl ProjectId {\n   509→    pub fn new(value: impl Into<String>) -> AppResult<Self> {\n   510→        let normalized = value.into().trim().to_owned();\n   511→        if normalized.is_empty()\n   512→            || normalized == \".\"\n   513→            || normalized == \"..\"\n   514→            || normalized.contains('/')\n   515→            || normalized.contains('\\\\')\n   516→        {\n   517→            return Err(AppError::InvalidIdentifier { value: normalized });\n   518→        }\n   519→\n   520→        Ok(Self(normalized))\n   521→    }\n   522→\n   523→    pub fn as_str(&self) -> &str {\n   524→        &self.0\n   525→    }\n   526→}\n   527→\n   528→impl fmt::Display for ProjectId {\n   529→    fn fmt(&self, f: &mut fmt::Formatter<'_>) -> fmt::Result {\n   530→        f.write_str(self.as_str())\n   531→    }\n   532→}\n   533→\n   534→#[derive(De