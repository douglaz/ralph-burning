 596→    ) -> AppResult<RawOutputReference> {\n   597→        let path = project_root\n   598→            .join(\"runtime/backend\")\n   599→            .join(format!(\"{invocation_id}.raw\"));\n   600→        FileSystem::write_atomic(&path, contents)?;\n   601→        Ok(RawOutputReference::Stored(path))\n   602→    }\n   603→}\n   604→\n   605→/// Filesystem-backed implementation of `SessionStorePort`.\n   606→pub struct FsSessionStore;\n   607→\n   608→impl SessionStorePort for FsSessionStore {\n   609→    fn load_sessions(&self, project_root: &Path) -> AppResult<PersistedSessions> {\n   610→        let path = project_root.join(SESSIONS_FILE);\n   611→        match fs::read_to_string(&path) {\n   612→            Ok(raw) => serde_json::from_str(&raw).map_err(|error| AppError::CorruptRecord {\n   613→                file: format!(\"{}/{}\", project_root.display(), SESSIONS_FILE),\n   614→                details: error.to_string(),\n   615→            }),\n   616→            Err(error) if error.kind() == std::io::ErrorKind::NotFound => {\n   617→                Err(AppError::CorruptRecord {\n   618→                    file: format!(\"{}/{}\", project_root.display(), SESSIONS_FILE),\n   619→                    details: \"canonical file is missing\".to_owned(),\n   620→                })\n   621→            }\n   622→            Err(error) => Err(error.into()),\n   623→        }\n   624→    }\n   625→\n   626→    fn save_sessions(&self, project_root: &Path, sessions: &PersistedSessions) -> AppResult<()> {\n   627→        let path = project_root.join(SESSIONS_FILE);\n   628→        let contents = serde_json::to_string_pretty(sessions)?;\n   629→        FileSystem::write_atomic(&path, &contents)\n   630→    }\n   631→}\n   632→"}]},"parent_tool_use_id":"toolu_01BNmMHXmrpqphqEoDzMeewD","session_id":"b9859e69-5579-4e82-ac66-49d19cc80e05","uuid":"0566547c-b331-4f35-97ea-82f357ce00f4"}
