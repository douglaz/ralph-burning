 94→            })?;\n    95→        adapter\n    96→            .check_availability(&entry.target)\n    97→            .await\n    98→            .map_err(|e| AppError::PreflightFailed {\n    99→                stage_id: entry.stage_id,\n   100→                details: e.to_string(),\n   101→            })?;\n   102→    }\n   103→    Ok(())\n   104→}\n   105→\n   106→/// Generate a new run ID from a timestamp.\n   107→fn generate_run_id() -> AppResult<RunId> {\n   108→    let now = Utc::now();\n   109→    RunId::new(format!(\"run-{}\", now.format(\"%Y%m%d%H%M%S\")))\n   110→}\n   111→\n   112→/// The standard-flow orchestration engine.\n   113→///\n   114→/// Executes all enabled standard stages in canonical order against the provided\n   115→/// backend adapter, persisting validated payloads and rendered artifacts at\n   116→/// durable stage boundaries.\n   117→pub async fn execute_standard_run<A, R, S>(\n   118→    agent_service: &AgentExecutionService<A, R, S>,\n   119→    run_snapshot_read: &dyn RunSnapshotPort,\n   120→    run_snapshot_write: &dyn RunSnapshotWritePort,\n   121→    journal_store: &dyn JournalStorePort,\n   122→    artifact_write: &dyn PayloadArtifactWritePort,\n   123→    log_write: &dyn RuntimeLogWritePort,\n   124→    base_dir: &Path,\n   125→    project_id: &ProjectId,\n   126→    effective_config: &EffectiveConfig,\n   127→) -> AppResult<()>\n   128→where\n   129→    A: AgentExecutionPort,\n   130→    R: RawOutputPort,\n   131→    S: SessionStorePort,\n   132→{\n   133→    // 1. Read current snapshot and validate preconditions\n   134→    let snapshot = run_snapshot_read.read_run_snapshot(base_dir, project_id)?;\n   135→\n   136→    if snapshot.status != RunStatus::NotStarted {\n   137→        return Err(AppError::RunStartFailed {\n   138→            reason: format!(\n   139→                \"project snapshot status is '{}'; run start requires 'not_started'\",\n   140→                snapshot.status\n   141→            ),\n   142→        });\n   143→    }\n   144→    if snapshot.has_active_run() {\n   145→        return Err(AppError::RunStartFailed {\n   146→            reason: \"project already has an active run\".to_owned(),\n   147→        });\n   148→    }\n   149→\n   150→    // 2. Derive the stage plan\n   151→    let prompt_review_enabled = effective_config.prompt_review_enabled();\n   152→    let stages = standard_stage_plan(prompt_review_enabled);\n   153→\n   154→    // 3. Resolve backend targets for every stage\n   155→    let workspace_defaults = BackendSelectionConfig::from_effective_config(effective_config)?;\n   156→    let stage_plan = resolve_stage_plan(stages.as_slice(), agent_service.resolver(), Some(&workspace_defaults))?;\n   157→\n   158→    // 4. Preflight checks — if any fail, leave all state unchanged\n   159→    preflight_check(&InternalAdapter(agent_service), &stage_plan).await?;\n   160→\n   161→    // 5. Generate run ID and read journal for sequence tracking\n   162→    let run_id = generate_run_id()?;\n   163→    let now = Utc::now();\n   164→    let events = journal_store.read_journal(base_dir, project_id)?;\n   165→    let mut seq = journal::last_sequence(&events);\n   166→\n   167→    let first_stage = stage_plan[0].stage_id;\n   168→\n   169→    // 6. Persist run_started: create run.json with running status + journal events\n   170→    seq += 1;\n   171→    let run_started = journal::run_started_event(seq, now, &run_id, first_stage);\n   172→    let run_started_line = journal::serialize_event(&run_started)?;\n   173→    journal_store.append_event(base_dir, project_id, &run_started_line)?;\n   174→\n   175→    let initial_cursor = StageCursor::initial(first_stage);\n   176→    let mut current_snapshot = RunSnapshot {\n   177→        active_run: Some(ActiveRun {\n   178→            run_id: run_id.as_str().to_owned(),\n   179→            stage_cursor: initial_cursor.clone(),\n   180→            started_at: now,\n   181→        }),\n   182→        status: RunStatus::Running,\n   183→        cycle_history: vec![],\n   184→        completion_rounds: 1,\n   185→        rollback_point_meta: snapshot.rollback_point_meta.clone(),\n   186→        amendment_queue: snapshot.amendment_queue.clone(),\n   187→        status_summary: format!(\"running: {}\", first_stage.display_name()),\n   188→    };\n   189→    run_snapshot_write.write_run_snapshot(base_dir, project_id, &current_snapshot)?;\n   190→\n   191→    let project_root = project_root_path(base_dir, project_id);\n   192→\n   193→    // 7. Execute stages in order\n   194→    for (idx, stage_entry) in stage_plan.iter().enumerate() {\n   195→        let stage_id = stage_entry.stage_id;\n   196→        let cursor = if idx == 0 {\n   197→            initial_cursor.clone()\n   198→        } else {\n   199→            initial_cursor.advance_stage(stage_id)\n   200→        };\n   201→\n   202→        // Emit stage_entered\n   203→        seq += 1;\n   204→        let stage_entered = journal::stage_entered_event(\n   205→            seq,\n   206→            Utc::now(),\n   207→            &run_id,\n   208→            stage_id,\n   209→            cursor.cycle,\n   210→            cursor.attempt,\n   211→        );\n   212→        let stage_entered_line = journal::serialize_event(&stage_entered)?;\n   213→        journal_store.append_event(base_dir, project_id, &stage_entered_line)?;\n   214→\n   215→        // Update cursor in snapshot\n   216→        current_snapshot.active_run.as_mut().unwrap().stage_cursor =\n   217→            StageCursor::initial(stage_id);\n   218→        current_snapshot.status_summary = format!(\"running: {}\", stage_id.display_name());\n   219→        run_snapshot_write.write_run_snapshot(base_dir, project_id, &current_snapshot)?;\n   220→\n   221→        // Best-effort runtime log\n   222→        let _ = log_write.append_runtime_log(\n   223→            base_dir,\n   224→            project_id,\n   225→            &RuntimeLogEntry {\n   226→                timestamp: Utc::now(),\n   227→                level: LogLevel::Info,\n   228→                source: \"engine\".to_owned(),\n   229→                message: format!(\"stage_entered: {}\", stage_id.as_str()),\n   230→            },\n   231→        );\n   232→\n   233→        // Invoke the backend\n   234→        let invocation_id = format!(\n   235→            \"{}-{}-c{}-a{}\",\n   236→            run_id.as_str(),\n   237→            stage_id.as_str(),\n   238→            cursor.cycle,\n   239→            cursor.attempt\n   240→        );\n   241→        let request = InvocationRequest {\n   242→            invocation_id,\n   243→            project_root: project_root.clone(),\n   244→            stage_contract: stage_entry.contract,\n   245→            role: stage_entry.role,\n   246→            resolved_target: stage_entry.target.clone(),\n   247→            payload: InvocationPayload {\n   248→                prompt: format!(\"Execute stage: {}\", stage_id.display_name()),\n   249→                context: serde_json::json!({}),\n   250→            },\n   251→            timeout: Duration::from_secs(300),\n   252→            cancellation_token: CancellationToken::new(),\n   253→            session_policy: SessionPolicy::ReuseIfAllowed,\n   254→            prior_session: None,\n   255→            attempt_number: cursor.attempt,\n   256→        };\n   257→\n   258→        let envelope = match agent_service.invoke(request).await {\n   259→            Ok(env) => env,\n   260→            Err(e) => {\n   261→                // Stage invocation failed — mark run as failed\n   262→                let failure_class = e\n   263→                    .failure_class()\n   264→                    .map(|fc| format!(\"{:?}\", fc))\n   265→                    .unwrap_or_else(|| \"unknown\".to_owned());\n   266→                let message = e.to_string();\n   267→\n   268→                seq += 1;\n   269→                let run_failed = journal::run_failed_event(\n   270→                    seq,\n   271→                    Utc::now(),\n   272→                    &run_id,\n   273→                    stage_id,\n   274→                    &failure_class,\n   275→                    &message,\n   276→                );\n   277→                let run_failed_line = journal::serialize_event(&run_failed)?;\n   278→                journal_store.append_event(base_dir, project_id, &run_failed_line)?;\n   279→\n   280→                current_snapshot.status = RunStatus::Failed;\n   281→                current_snapshot.active_run = None;\n   282→                current_snapshot.status_summary =\n   283→                    format!(\"failed at {}: {}\", stage_id.display_name(), message);\n   284→                run_snapshot_write\n   285→                    .write_run_snapshot(base_dir, project_id, &current_snapshot)?;\n   286→\n   287→                return Err(e);\n   288→            }\n   289→        };\n   290→\n   291→        // Evaluate the contract (schema + domain + outcome + render)\n   292→        let bundle = match stage_entry.contract.evaluate(&envelope.parsed_payload) {\n   293→            Ok(bundle) => bundle,\n   294→            Err(contract_err) => {\n   295→                let failure_class = format!(\"{:?}\", contract_err.failure_class());\n   296→                let message = contract_err.to_string();\n   297→\n   298→                seq += 1;\n   299→                let run_failed = journal::run_failed_event(\n   300→                    seq,\n   301→                    Utc::now(),\n   302→                    &run_id,\n   303→                    stage_id,\n   304→                    &failure_class,\n   305→                    &message,\n   306→                );\n   307→                let run_failed_line = journal::serialize_event(&run_failed)?;\n   308→                journal_store.append_event(base_dir, project_id, &run_failed_line)?;\n   309→\n   310→                current_snapshot.status = RunStatus::Failed;\n   311→                current_snapshot.active_run = None;\n   312→                current_snapshot.status_summary =\n   313→                    format!(\"failed at {}: {}\", stage_id.display_name(), message);\n   314→                run_snapshot_write\n   315→                    .write_run_snapshot(base_dir, project_id, &current_snapshot)?;\n   316→\n   317→                return Err(AppError::InvocationFailed {\n   318→                    backend: stage_entry.target.backend.family.to_string(),\n   319→                    stage_id,\n   320→                    failure_class: contract_err.failure_class(),\n   321→                    details: contract_err.to_string(),\n   322→                });\n   323→            }\n   324→        };\n   325→\n   326→        // Persist payload + artifact pair atomically\n   327→        let stage_now = Utc::now();\n   328→        let payload_id = format!(\n   329→            \"{}-{}-c{}-a{}\",\n   330→            run_id.as_str(),\n   331→            stage_id.as_str(),\n   332→            cursor.cycle,\n   333→            cursor.attempt\n   334→        );\n   335→        let artifact_id = format!(\"{}-artifact\", payload_id);\n   336→\n   337→        let payload_record = PayloadRecord {\n   338→            payload_id: payload_id.clone(),\n   339→            stage_id,\n   340→            cycle: cursor.cycle,\n   341→            attempt: cursor.attempt,\n   342→            created_at: stage_now,\n   343→            payload: serde_json::to_value(&bundle.payload)?,\n   344→        };\n   345→        let artifact_record = ArtifactRecord {\n   346→            artifact_id: artifact_id.clone(),\n   347→            payload_id: payload_id.clone(),\n   348→            stage_id,\n   349→            created_at: stage_now,\n   350→            content: bundle.artifact.clone(),\n   351→        };\n   352→\n   353→        // Atomic stage commit: payload + artifact + journal + snapshot\n   354→        // If payload/artifact write fails, the stage remains uncommitted.\n   355→        artifact_write.write_payload_artifact_pair(\n   356→            base_dir,\n   357→            project_id,\n   358→            &payload_record,\n   359→            &artifact_record,\n   360→        ).map_err(|e| {\n   361→            AppError::StageCommitFailed {\n   362→                stage_id,\n   363→                details: format!(\"payload/artifact persistence failed: {}\", e),\n   364→            }\n   365→        })?;\n   366→\n   367→        // stage_completed journal event\n   368→        seq += 1;\n   369→        let stage_completed = journal::stage_completed_event(\n   370→            seq,\n   371→            Utc::now(),\n   372→            &run_id,\n   373→            stage_id,\n   374→            cursor.cycle,\n   375→            cursor.attempt,\n   376→            &payload_id,\n   377→            &artifact_id,\n   378→        );\n   379→        let stage_completed_line = journal::serialize_event(&stage_completed)?;\n   380→        if let Err(e) = journal_store.append_event(base_dir, project_id, &stage_completed_line) {\n   381→            // Journal write failed after payload/artifact — stage commit is incomplete.\n   382→            // Remove the payload/artifact pair to maintain the pairing invariant.\n   383→            // The stage has no stage_completed event, so it remains uncommitted.\n   384→            return Err(AppError::StageCommitFailed {\n   385→                stage_id,\n   386→                details: format!(\"journal append failed after payload/artifact write: {}\", e),\n   387→            });\n   388→        }\n   389→\n   390→        // Update snapshot cursor to reflect completed stage\n   391→        if idx + 1 < stage_plan.len() {\n   392→            let next_stage = stage_plan[idx + 1].stage_id;\n   393→            current_snapshot.active_run.as_mut().unwrap().stage_cursor =\n   394→                StageCursor::initial(next_stage);\n   395→            current_snapshot.status_summary =\n   396→                format!(\"running: completed {}, next {}\", stage_id.display_name(), next_stage.display_name());\n   397→        }\n   398→        run_snapshot_write.write_run_snapshot(base_dir, project_id, &current_snapshot)?;\n   399→\n   400→        // Best-effort runtime log\n   401→        let _ = log_write.append_runtime_log(\n   402→            base_dir,\n   403→            project_id,\n   404→            &RuntimeLogEntry {\n   405→                timestamp: Utc::now(),\n   406→                level: LogLevel::Info,\n   407→                source: \"engine\".to_owned(),\n   408→                message: format!(\"stage_completed: {}\", stage_id.as_str()),\n   409→            },\n   410→        );\n   411→    }\n   412→\n   413→    // 8. All stages completed — mark run as completed\n   414→    seq += 1;\n   415→    let run_completed = journal::run_completed_event(seq, Utc::now(), &run_id, 1);\n   416→    let run_completed_line = journal::serialize_event(&run_completed)?;\n   417→    journal_store.append_event(base_dir, project_id, &run_completed_line)?;\n   418→\n   419→    current_snapshot.status = RunStatus::Completed;\n   420→    current_snapshot.active_run = None;\n   421→    current_snapshot.completion_rounds = 1;\n   422→    current_snapshot.status_summary = \"completed\".to_owned();\n   423→    run_snapshot_write.write_run_snapshot(base_dir, project_id, &current_snapshot)?;\n   424→\n   425→    Ok(())\n   426→}\n   427→\n   428→/// Helper to get project root path.\n   429→fn project_root_path(base_dir: &Path, project_id: &ProjectId) -> PathBuf {\n   430→    base_dir\n   431→        .join(\".ralph-burning\")\n   432→        .join(\"projects\")\n   433→        .join(project_id.as_str())\n   434→}\n   435→\n   436→/// Internal wrapper so we can pass the AgentExecutionService adapter to preflight.\n   437→struct InternalAdapter<'a, A, R, S>(&'a AgentExecutionService<A, R, S>);\n   438→\n   439→impl<A, R, S> InternalAdapter<'_, A, R, S>\n   440→where\n   441→    A: AgentExecutionPort,\n   442→    R: RawOutputPort,\n   443→    S: SessionStorePort,\n   444→{\n   445→}\n   446→\n   447→/// We need a way to call check_capability and check_availability from the\n   448→/// underlying adapter through AgentExecutionService. Since AgentExecutionService\n   449→/// doesn't expose those directly, we refactor to accept the adapter directly\n   450→/// in the preflight function. This trait impl delegates to the adapter field.\n   451→///\n   452→/// Actually, since we need to access the adapter directly for preflight,\n   453→/// let's add a method on AgentExecutionService to expose the adapter.\n   454→impl<A, R, S> AgentExecutionService<A, R, S> {\n   455→    pub fn adapter(&self) -> &A {\n   456→        &self.adapter\n   457→    }\n   458→}\n   459→"}]},"parent_tool_use_id":null,"session_id":"b9859e69-5579-4e82-ac66-49d19cc80e05","uuid":"48f8ad28-6461-4bba-ade1-c80f66717c00","tool_use_result":{"type":"text","file":{"filePath":"/root/new-ralph-burning/ralph-burning-rewrite/src/contexts/workflow_composition/engine.rs","content":"use std::path::{Path, PathBuf};\nuse std::time::Duration;\n\nuse chrono::Utc;\n\nuse crate::contexts::agent_execution::model::{\n    CancellationToken, InvocationPayload, InvocationRequest,\n};\nuse crate::contexts::agent_execution::service::{\n    AgentExecutionPort, BackendResolver, BackendSelectionConfig, RawOutputPort,\n};\nuse crate::contexts::agent_execution::session::SessionStorePort;\nuse crate::contexts::agent_execution::AgentExecutionService;\nuse crate::contexts::project_run_record::journal;\nuse crate::contexts::project_run_record::model::{\n    ActiveRun, ArtifactRecord, FailedStageSummary, JournalEvent, PayloadRecord, RunSnapshot,\n    RunStatus, RuntimeLogEntry, LogLevel,\n};\nuse crate::contexts::project_run_record::service::{\n    JournalStorePort, PayloadArtifactWritePort, RunSnapshotPort, RunSnapshotWritePort,\n    RuntimeLogWritePort,\n};\nuse crate::contexts::workspace_governance::config::EffectiveConfig;\nuse crate::shared::domain::{\n    BackendRole, FlowPreset, ProjectId, ResolvedBackendTarget, RunId, StageCursor, SessionPolicy,\n    StageId,\n};\nuse crate::shared::error::{AppError, AppResult};\n\nuse super::contracts::{self, StageContract, ValidatedBundle};\nuse super::FlowDefinition;\n\n/// Derives the executable stage plan for the standard flow given prompt_review config.\npub fn standard_stage_plan(prompt_review_enabled: bool) -> Vec<StageId> {\n    let flow_def = super::flow_definition(FlowPreset::Standard);\n    if prompt_review_enabled {\n        flow_def.stages.to_vec()\n    } else {\n        flow_def\n            .stages\n            .iter()\n            .copied()\n            .filter(|s| *s != StageId::PromptReview)\n            .collect()\n    }\n}\n\n/// Deterministic stage-to-role mapping per spec.\npub fn role_for_stage(stage_id: StageId) -> BackendRole {\n    BackendRole::for_stage(stage_id)\n}\n\n/// Resolved target per stage for preflight.\npub struct StagePlan {\n    pub stage_id: StageId,\n    pub role: BackendRole,\n    pub contract: StageContract,\n    pub target: ResolvedBackendTarget,\n}\n\n/// Resolve all stage targets ahead of execution for preflight validation.\npub fn resolve_stage_plan(\n    stages: &[StageId],\n    resolver: &BackendResolver,\n    workspace_defaults: Option<&BackendSelectionConfig>,\n) -> AppResult<Vec<StagePlan>> {\n    let mut plan = Vec::with_capacity(stages.len());\n    for &stage_id in stages {\n        let role = role_for_stage(stage_id);\n        let contract = contracts::contract_for_stage(stage_id);\n        let target = resolver.resolve(role, None, None, workspace_defaults)?;\n        plan.push(StagePlan {\n            stage_id,\n            role,\n            contract,\n            target,\n        });\n    }\n    Ok(plan)\n}\n\n/// Preflight: check capability and availability for every stage target.\npub async fn preflight_check<A: AgentExecutionPort>(\n    adapter: &A,\n    plan: &[StagePlan],\n) -> AppResult<()> {\n    for entry in plan {\n        adapter\n            .check_capability(&entry.target, &entry.contract)\n            .await\n            .map_err(|e| AppError::PreflightFailed {\n                stage_id: entry.stage_id,\n                details: e.to_string(),\n            })?;\n        adapter\n            .check_availability(&entry.target)\n            .await\n            .map_err(|e| AppError::PreflightFailed {\n                stage_id: entry.stage_id,\n                details: e.to_string(),\n            })?;\n    }\n    Ok(())\n}\n\n/// Generate a new run ID from a timestamp.\nfn generate_run_id() -> AppResult<RunId> {\n    let now = Utc::now();\n    RunId::new(format!(\"run-{}\", now.format(\"%Y%m%d%H%M%S\")))\n}\n\n/// The standard-flow orchestration engine.\n///\n/// Executes all enabled standard stages in canonical order against the provided\n/// backend adapter, persisting validated payloads and rendered artifacts at\n/// durable stage boundaries.\npub async fn execute_standard_run<A, R, S>(\n    agent_service: &AgentExecutionService<A, R, S>,\n    run_snapshot_read: &dyn RunSnapshotPort,\n    run_snapshot_write: &dyn RunSnapshotWritePort,\n    journal_store: &dyn JournalStorePort,\n    artifact_write: &dyn PayloadArtifactWritePort,\n    log_write: &dyn RuntimeLogWritePort,\n    base_dir: &Path,\n    project_id: &ProjectId,\n    effective_config: &EffectiveConfig,\n) -> AppResult<()>\nwhere\n    A: AgentExecutionPort,\n    R: RawOutputPort,\n    S: SessionStorePort,\n{\n    // 1. Read current snapshot and validate preconditions\n    let snapshot = run_snapshot_read.read_run_snapshot(base_dir, project_id)?;\n\n    if snapshot.status != RunStatus::NotStarted {\n        return Err(AppError::RunStartFailed {\n            reason: format!(\n                \"project snapshot status is '{}'; run start requires 'not_started'\",\n                snapshot.status\n            ),\n        });\n    }\n    if snapshot.has_active_run() {\n        return Err(AppError::RunStartFailed {\n            reason: \"project already has an active run\".to_owned(),\n        });\n    }\n\n    // 2. Derive the stage plan\n    let prompt_review_enabled = effective_config.prompt_review_enabled();\n    let stages = standard_stage_plan(prompt_review_enabled);\n\n    // 3. Resolve backend targets for every stage\n    let workspace_defaults = BackendSelectionConfig::from_effective_config(effective_config)?;\n    let stage_plan = resolve_stage_plan(stages.as_slice(), agent_service.resolver(), Some(&workspace_defaults))?;\n\n    // 4. Preflight checks — if any fail, leave all state unchanged\n    preflight_check(&InternalAdapter(agent_service), &stage_plan).await?;\n\n    // 5. Generate run ID and read journal for sequence tracking\n    let run_id = generate_run_id()?;\n    let now = Utc::now();\n    let events = journal_store.read_journal(base_dir, project_id)?;\n    let mut seq = journal::last_sequence(&events);\n\n    let first_stage = stage_plan[0].stage_id;\n\n    // 6. Persist run_started: create run.json with running status + journal events\n    seq += 1;\n    let run_started = journal::run_started_event(seq, now, &run_id, first_stage);\n    let run_started_line = journal::serialize_event(&run_started)?;\n    journal_store.append_event(base_dir, project_id, &run_started_line)?;\n\n    let initial_cursor = StageCursor::initial(first_stage);\n    let mut current_snapshot = RunSnapshot {\n        active_run: Some(ActiveRun {\n            run_id: run_id.as_str().to_owned(),\n            stage_cursor: initial_cursor.clone(),\n            started_at: now,\n        }),\n        status: RunStatus::Running,\n        cycle_history: vec![],\n        completion_rounds: 1,\n        rollback_point_meta: snapshot.rollback_point_meta.clone(),\n        amendment_queue: snapshot.amendment_queue.clone(),\n        status_summary: format!(\"running: {}\", first_stage.display_name()),\n    };\n    run_snapshot_write.write_run_snapshot(base_dir, project_id, &current_snapshot)?;\n\n    let project_root = project_root_path(base_dir, project_id);\n\n    // 7. Execute stages in order\n    for (idx, stage_entry) in stage_plan.iter().enumerate() {\n        let stage_id = stage_entry.stage_id;\n        let cursor = if idx == 0 {\n            initial_cursor.clone()\n        } else {\n            initial_cursor.advance_stage(stage_id)\n        };\n\n        // Emit stage_entered\n        seq += 1;\n        let stage_entered = journal::stage_entered_event(\n            seq,\n            Utc::now(),\n            &run_id,\n            stage_id,\n            cursor.cycle,\n            cursor.attempt,\n        );\n        let stage_entered_line = journal::serialize_event(&stage_entered)?;\n        journal_store.append_event(base_dir, project_id, &stage_entered_line)?;\n\n        // Update cursor in snapshot\n        current_snapshot.active_run.as_mut().unwrap().stage_cursor =\n            StageCursor::initial(stage_id);\n        current_snapshot.status_summary = format!(\"running: {}\", stage_id.display_name());\n        run_snapshot_write.write_run_snapshot(base_dir, project_id, &current_snapshot)?;\n\n        // Best-effort runtime log\n        let _ = log_write.append_runtime_log(\n            base_dir,\n            project_id,\n            &RuntimeLogEntry {\n                timestamp: Utc::now(),\n                level: LogLevel::Info,\n                source: \"engine\".to_owned(),\n                message: format!(\"stage_entered: {}\", stage_id.as_str()),\n            },\n        );\n\n        // Invoke the backend\n        let invocation_id = format!(\n            \"{}-{}-c{}-a{}\",\n            run_id.as_str(),\n            stage_id.as_str(),\n            cursor.cycle,\n            cursor.attempt\n        );\n        let request = InvocationRequest {\n            invocation_id,\n            project_root: project_root.clone(),\n            stage_contract: stage_entry.contract,\n            role: stage_entry.role,\n            resolved_target: stage_entry.target.clone(),\n            payload: InvocationPayload {\n                prompt: format!(\"Execute stage: {}\", stage_id.display_name()),\n                context: serde_json::json!({}),\n            },\n            timeout: Duration::from_secs(300),\n            cancellation_token: CancellationToken::new(),\n            session_policy: SessionPolicy::ReuseIfAllowed,\n            prior_session: None,\n            attempt_number: cursor.attempt,\n        };\n\n        let envelope = match agent_service.invoke(request).await {\n            Ok(env) => env,\n            Err(e) => {\n                // Stage invocation failed — mark run as failed\n                let failure_class = e\n                    .failure_class()\n                    .map(|fc| format!(\"{:?}\", fc))\n                    .unwrap_or_else(|| \"unknown\".to_owned());\n                let message = e.to_string();\n\n                seq += 1;\n                let run_failed = journal::run_failed_event(\n                    seq,\n                    Utc::now(),\n                    &run_id,\n                    stage_id,\n                    &failure_class,\n                    &message,\n                );\n                let run_failed_line = journal::serialize_event(&run_failed)?;\n                journal_store.append_event(base_dir, project_id, &run_failed_line)?;\n\n                current_snapshot.status = RunStatus::Failed;\n                current_snapshot.active_run = None;\n                current_snapshot.status_summary =\n                    format!(\"failed at {}: {}\", stage_id.display_name(), message);\n                run_snapshot_write\n                    .write_run_snapshot(base_dir, project_id, &current_snapshot)?;\n\n                return Err(e);\n            }\n        };\n\n        // Evaluate the contract (schema + domain + outcome + render)\n        let bundle = match stage_entry.contract.evaluate(&envelope.parsed_payload) {\n            Ok(bundle) => bundle,\n            Err(contract_err) => {\n                let failure_class = format!(\"{:?}\", contract_err.failure_class());\n                let message = contract_err.to_string();\n\n                seq += 1;\n                let run_failed = journal::run_failed_event(\n                    seq,\n                    Utc::now(),\n                    &run_id,\n                    stage_id,\n                    &failure_class,\n                    &message,\n                );\n                let run_failed_line = journal::serialize_event(&run_failed)?;\n                journal_store.append_event(base_dir, project_id, &run_failed_line)?;\n\n                current_snapshot.status = RunStatus::Failed;\n                current_snapshot.active_run = None;\n                current_snapshot.status_summary =\n                    format!(\"failed at {}: {}\", stage_id.display_name(), message);\n                run_snapshot_write\n                    .write_run_snapshot(base_dir, project_id, &current_snapshot)?;\n\n                return Err(AppError::InvocationFailed {\n                    backend: stage_entry.target.backend.family.to_string(),\n                    stage_id,\n                    failure_class: contract_err.failure_class(),\n                    details: contract_err.to_string(),\n                });\n            }\n        };\n\n        // Persist payload + artifact pair atomically\n        let stage_now = Utc::now();\n        let payload_id = format!(\n            \"{}-{}-c{}-a{}\",\n            run_id.as_str(),\n            stage_id.as_str(),\n            cursor.cycle,\n            cursor.attempt\n        );\n        let artifact_id = format!(\"{}-artifact\", payload_id);\n\n        let payload_record = PayloadRecord {\n            payload_id: payload_id.clone(),\n            stage_id,\n            cycle: cursor.cycle,\n            attempt: cursor.attempt,\n            created_at: stage_now,\n            payload: serde_json::to_value(&bundle.payload)?,\n        };\n        let artifact_record = ArtifactRecord {\n            artifact_id: artifact_id.clone(),\n            payload_id: payload_id.clone(),\n            stage_id,\n            created_at: stage_now,\n            content: bundle.artifact.clone(),\n        };\n\n        // Atomic stage commit: payload + artifact + journal + snapshot\n        // If payload/artifact write fails, the stage remains uncommitted.\n        artifact_write.write_payload_artifact_pair(\n            base_dir,\n            project_id,\n            &payload_record,\n            &artifact_record,\n        ).map_err(|e| {\n            AppError::StageCommitFailed {\n                stage_id,\n                details: format!(\"payload/artifact persistence failed: {}\", e),\n            }\n        })?;\n\n        // stage_completed journal event\n        seq += 1;\n        let stage_completed = journal::stage_completed_event(\n            seq,\n            Utc::now(),\n            &run_id,\n            stage_id,\n            cursor.cycle,\n            cursor.attempt,\n            &payload_id,\n            &artifact_id,\n        );\n        let stage_completed_line = journal::serialize_event(&stage_completed)?;\n        if let Err(e) = journal_store.append_event(base_dir, project_id, &stage_completed_line) {\n            // Journal write failed after payload/artifact — stage commit is incomplete.\n            // Remove the payload/artifact pair to maintain the pairing invariant.\n            // The stage has no stage_completed event, so it remains uncommitted.\n            return Err(AppError::StageCommitFailed {\n                stage_id,\n                details: format!(\"journal append failed after payload/artifact write: {}\", e),\n            });\n        }\n\n        // Update snapshot cursor to reflect completed stage\n        if idx + 1 < stage_plan.len() {\n            let next_stage = stage_plan[idx + 1].stage_id;\n            current_snapshot.active_run.as_mut().unwrap().stage_cursor =\n                StageCursor::initial(next_stage);\n            current_snapshot.status_summary =\n                format!(\"running: completed {}, next {}\", stage_id.display_name(), next_stage.display_name());\n        }\n        run_snapshot_write.write_run_snapshot(base_dir, project_id, &current_snapshot)?;\n\n        // Best-effort runtime log\n        let _ = log_write.append_runtime_log(\n            base_dir,\n            project_id,\n            &RuntimeLogEntry {\n                timestamp: Utc::now(),\n                level: LogLevel::Info,\n                source: \"engine\".to_owned(),\n                message: format!(\"stage_completed: {}\", stage_id.as_str()),\n            },\n        );\n    }\n\n    // 8. All stages completed — mark run as completed\n    seq += 1;\n    let run_completed = journal::run_completed_event(seq, Utc::now(), &run_id, 1);\n    let run_completed_line = journal::serialize_event(&run_completed)?;\n    journal_store.append_event(base_dir, project_id, &run_completed_line)?;\n\n    current_snapshot.status = RunStatus::Completed;\n    current_snapshot.active_run = None;\n    current_snapshot.completion_rounds = 1;\n    current_snapshot.status_summary = \"completed\".to_owned();\n    run_snapshot_write.write_run_snapshot(base_dir, project_id, &current_snapshot)?;\n\n    Ok(())\n}\n\n/// Helper to get project root path.\nfn project_root_path(base_dir: &Path, project_id: &ProjectId) -> PathBuf {\n    base_dir\n        .join(\".ralph-burning\")\n        .join(\"projects\")\n        .join(project_id.as_str())\n}\n\n/// Internal wrapper so we can pass the AgentExecutionService adapter to preflight.\nstruct InternalAdapter<'a, A, R, S>(&'a AgentExecutionService<A, R, S>);\n\nimpl<A, R, S> InternalAdapter<'_, A, R, S>\nwhere\n    A: AgentExecutionPort,\n    R: RawOutputPort,\n    S: SessionStorePort,\n{\n}\n\n/// We need a way to call check_capability and check_availability from the\n/// underlying adapter through AgentExecutionService. Since AgentExecutionService\n/// doesn't expose those directly, we refactor to accept the adapter directly\n/// in the preflight function. This trait impl delegates to the adapter field.\n///\n/// Actually, since we need to access the adapter directly for preflight,\n/// let's add a method on AgentExecutionService to expose the adapter.\nimpl<A, R, S> AgentExecutionService<A, R, S> {\n    pub fn adapter(&self) -> &A {\n        &self.adapter\n    }\n}\n","numLines":459,"startLine":1,"totalLines":459}}}
