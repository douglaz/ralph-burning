{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Qc628ub7aA5z6bcqEZgiMs","type":"tool_result","content":"     1→pub mod contracts;\n     2→pub mod engine;\n     3→pub mod payloads;\n     4→pub mod renderers;\n     5→\n     6→use crate::shared::domain::{FlowPreset, StageId};\n     7→use crate::shared::error::AppResult;\n     8→\n     9→#[derive(Debug, Clone, Copy, PartialEq, Eq)]\n    10→pub struct ValidationProfile {\n    11→    pub name: &'static str,\n    12→    pub summary: &'static str,\n    13→    pub final_review_enabled: bool,\n    14→}\n    15→\n    16→#[derive(Debug, Clone, Copy, PartialEq, Eq)]\n    17→pub struct FlowDefinition {\n    18→    pub preset: FlowPreset,\n    19→    pub description: &'static str,\n    20→    pub stages: &'static [StageId],\n    21→    pub validation_profile: ValidationProfile,\n    22→}\n    23→\n    24→const STANDARD_STAGES: [StageId; 8] = [\n    25→    StageId::PromptReview,\n    26→    StageId::Planning,\n    27→    StageId::Implementation,\n    28→    StageId::Qa,\n    29→    StageId::Review,\n    30→    StageId::CompletionPanel,\n    31→    StageId::AcceptanceQa,\n    32→    StageId::FinalReview,\n    33→];\n    34→\n    35→const QUICK_DEV_STAGES: [StageId; 4] = [\n    36→    StageId::PlanAndImplement,\n    37→    StageId::Review,\n    38→    StageId::ApplyFixes,\n    39→    StageId::FinalReview,\n    40→];\n    41→\n    42→const DOCS_CHANGE_STAGES: [StageId; 4] = [\n    43→    StageId::DocsPlan,\n    44→    StageId::DocsUpdate,\n    45→    StageId::DocsValidation,\n    46→    StageId::Review,\n    47→];\n    48→\n    49→const CI_IMPROVEMENT_STAGES: [StageId; 4] = [\n    50→    StageId::CiPlan,\n    51→    StageId::CiUpdate,\n    52→    StageId::CiValidation,\n    53→    StageId::Review,\n    54→];\n    55→\n    56→const FLOW_DEFINITIONS: [FlowDefinition; 4] = [\n    57→    FlowDefinition {\n    58→        preset: FlowPreset::Standard,\n    59→        description:\n    60→            \"Full delivery flow with planning, implementation, QA, review, and acceptance.\",\n    61→        stages: &STANDARD_STAGES,\n    62→        validation_profile: ValidationProfile {\n    63→            name: \"standard-default\",\n    64→            summary: \"Full validation suite with completion and acceptance checks.\",\n    65→            final_review_enabled: true,\n    66→        },\n    67→    },\n    68→    FlowDefinition {\n    69→        preset: FlowPreset::QuickDev,\n    70→        description: \"Fast delivery flow for small code changes with lightweight review.\",\n    71→        stages: &QUICK_DEV_STAGES,\n    72→        validation_profile: ValidationProfile {\n    73→            name: \"quick-dev-default\",\n    74→            summary: \"Lightweight panel with final review enabled by default.\",\n    75→            final_review_enabled: true,\n    76→        },\n    77→    },\n    78→    FlowDefinition {\n    79→        preset: FlowPreset::DocsChange,\n    80→        description: \"Documentation-focused flow for planning, content updates, and validation.\",\n    81→        stages: &DOCS_CHANGE_STAGES,\n    82→        validation_profile: ValidationProfile {\n    83→            name: \"docs-default\",\n    84→            summary: \"Documentation validation with final review disabled by default.\",\n    85→            final_review_enabled: false,\n    86→        },\n    87→    },\n    88→    FlowDefinition {\n    89→        preset: FlowPreset::CiImprovement,\n    90→        description: \"CI improvement flow for automation planning, updates, and validation.\",\n    91→        stages: &CI_IMPROVEMENT_STAGES,\n    92→        validation_profile: ValidationProfile {\n    93→            name: \"ci-default\",\n    94→            summary: \"Automation validation with final review disabled by default.\",\n    95→            final_review_enabled: false,\n    96→        },\n    97→    },\n    98→];\n    99→\n   100→pub fn built_in_flows() -> &'static [FlowDefinition] {\n   101→    &FLOW_DEFINITIONS\n   102→}\n   103→\n   104→pub fn flow_definition(preset: FlowPreset) -> &'static FlowDefinition {\n   105→    match preset {\n   106→        FlowPreset::Standard => &FLOW_DEFINITIONS[0],\n   107→        FlowPreset::QuickDev => &FLOW_DEFINITIONS[1],\n   108→        FlowPreset::DocsChange => &FLOW_DEFINITIONS[2],\n   109→        FlowPreset::CiImprovement => &FLOW_DEFINITIONS[3],\n   110→    }\n   111→}\n   112→\n   113→pub fn flow_definition_by_id(flow_id: &str) -> AppResult<&'static FlowDefinition> {\n   114→    let preset = flow_id.parse::<FlowPreset>()?;\n   115→    Ok(flow_definition(preset))\n   116→}\n   117→"}]},"parent_tool_use_id":"toolu_01VwuMdbo4Yfw9qb7NhghzrF","session_id":"19a33b10-b5a0-4ba2-8943-a7efa3e34818","uuid":"c606ce26-c594-47aa-95ab-3d35e7300543"}
