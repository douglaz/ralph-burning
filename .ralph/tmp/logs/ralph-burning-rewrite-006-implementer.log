{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01GBrfYA1zSijQbkx3CLVC8w","type":"tool_result","content":"     1→use std::path::Path;\n     2→\n     3→use chrono::{DateTime, Utc};\n     4→\n     5→use crate::shared::domain::{FlowPreset, ProjectId};\n     6→use crate::shared::error::{AppError, AppResult};\n     7→\n     8→use super::journal;\n     9→use super::model::{\n    10→    ArtifactRecord, JournalEvent, JournalEventType, PayloadRecord, ProjectDetail, ProjectListEntry,\n    11→    ProjectRecord, ProjectStatusSummary, RunSnapshot, RuntimeLogEntry, SessionStore,\n    12→};\n    13→use super::queries::{self, RunHistoryView, RunStatusView, RunTailView};\n    14→\n    15→/// Port for reading and writing project records.\n    16→pub trait ProjectStorePort {\n    17→    fn project_exists(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<bool>;\n    18→    fn read_project_record(\n    19→        &self,\n    20→        base_dir: &Path,\n    21→        project_id: &ProjectId,\n    22→    ) -> AppResult<ProjectRecord>;\n    23→    fn list_project_ids(&self, base_dir: &Path) -> AppResult<Vec<ProjectId>>;\n    24→\n    25→    /// Stage a project for deletion: makes it invisible to list/show but\n    26→    /// keeps data on disk for potential rollback.\n    27→    fn stage_delete(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<()>;\n    28→\n    29→    /// Finalize a staged delete: permanently removes the project data.\n    30→    fn commit_delete(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<()>;\n    31→\n    32→    /// Roll back a staged delete: restores the project to its canonical path.\n    33→    fn rollback_delete(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<()>;\n    34→\n    35→    /// Atomically stage and commit a new project. If any step fails,\n    36→    /// the project must not be visible to list/show.\n    37→    fn create_project_atomic(\n    38→        &self,\n    39→        base_dir: &Path,\n    40→        record: &ProjectRecord,\n    41→        prompt_contents: &str,\n    42→        run_snapshot: &RunSnapshot,\n    43→        initial_journal_line: &str,\n    44→        sessions: &SessionStore,\n    45→    ) -> AppResult<()>;\n    46→}\n    47→\n    48→/// Port for reading and appending journal events.\n    49→pub trait JournalStorePort {\n    50→    fn read_journal(&self, base_dir: &Path, project_id: &ProjectId)\n    51→        -> AppResult<Vec<JournalEvent>>;\n    52→    fn append_event(&self, base_dir: &Path, project_id: &ProjectId, line: &str) -> AppResult<()>;\n    53→}\n    54→\n    55→/// Port for reading payload and artifact durable history.\n    56→pub trait ArtifactStorePort {\n    57→    fn list_payloads(\n    58→        &self,\n    59→        base_dir: &Path,\n    60→        project_id: &ProjectId,\n    61→    ) -> AppResult<Vec<PayloadRecord>>;\n    62→    fn list_artifacts(\n    63→        &self,\n    64→        base_dir: &Path,\n    65→        project_id: &ProjectId,\n    66→    ) -> AppResult<Vec<ArtifactRecord>>;\n    67→}\n    68→\n    69→/// Port for reading runtime logs (separate from durable history).\n    70→pub trait RuntimeLogStorePort {\n    71→    fn read_runtime_logs(\n    72→        &self,\n    73→        base_dir: &Path,\n    74→        project_id: &ProjectId,\n    75→    ) -> AppResult<Vec<RuntimeLogEntry>>;\n    76→}\n    77→\n    78→/// Port for reading/writing the run snapshot.\n    79→pub trait RunSnapshotPort {\n    80→    fn read_run_snapshot(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<RunSnapshot>;\n    81→}\n    82→\n    83→/// Port for writing the run snapshot atomically.\n    84→pub trait RunSnapshotWritePort {\n    85→    fn write_run_snapshot(\n    86→        &self,\n    87→        base_dir: &Path,\n    88→        project_id: &ProjectId,\n    89→        snapshot: &RunSnapshot,\n    90→    ) -> AppResult<()>;\n    91→}\n    92→\n    93→/// Port for writing payload and artifact records atomically as a pair.\n    94→pub trait PayloadArtifactWritePort {\n    95→    fn write_payload_artifact_pair(\n    96→        &self,\n    97→        base_dir: &Path,\n    98→        project_id: &ProjectId,\n    99→        payload: &PayloadRecord,\n   100→        artifact: &ArtifactRecord,\n   101→    ) -> AppResult<()>;\n   102→}\n   103→\n   104→/// Port for appending runtime log entries (best-effort, not durable history).\n   105→pub trait RuntimeLogWritePort {\n   106→    fn append_runtime_log(\n   107→        &self,\n   108→        base_dir: &Path,\n   109→        project_id: &ProjectId,\n   110→        entry: &RuntimeLogEntry,\n   111→    ) -> AppResult<()>;\n   112→}\n   113→\n   114→/// Port for reading/writing/clearing the active project pointer.\n   115→pub trait ActiveProjectPort {\n   116→    fn read_active_project_id(&self, base_dir: &Path) -> AppResult<Option<String>>;\n   117→    fn clear_active_project(&self, base_dir: &Path) -> AppResult<()>;\n   118→    fn write_active_project(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<()>;\n   119→}\n   120→\n   121→/// Input for the `project create` use case.\n   122→pub struct CreateProjectInput {\n   123→    pub id: ProjectId,\n   124→    pub name: String,\n   125→    pub flow: FlowPreset,\n   126→    pub prompt_path: String,\n   127→    pub prompt_contents: String,\n   128→    pub prompt_hash: String,\n   129→    pub created_at: DateTime<Utc>,\n   130→}\n   131→\n   132→/// Create a new project with all canonical files.\n   133→pub fn create_project(\n   134→    store: &dyn ProjectStorePort,\n   135→    journal_store: &dyn JournalStorePort,\n   136→    base_dir: &Path,\n   137→    input: CreateProjectInput,\n   138→) -> AppResult<ProjectRecord> {\n   139→    // Check for duplicate project ID\n   140→    if store.project_exists(base_dir, &input.id)? {\n   141→        return Err(AppError::DuplicateProject {\n   142→            project_id: input.id.to_string(),\n   143→        });\n   144→    }\n   145→\n   146→    let record = ProjectRecord {\n   147→        id: input.id.clone(),\n   148→        name: input.name,\n   149→        flow: input.flow,\n   150→        prompt_reference: \"prompt.md\".to_owned(),\n   151→        prompt_hash: input.prompt_hash,\n   152→        created_at: input.created_at,\n   153→        status_summary: ProjectStatusSummary::Created,\n   154→    };\n   155→\n   156→    let run_snapshot = RunSnapshot::initial();\n   157→    let sessions = SessionStore::empty();\n   158→\n   159→    // Create the initial journal event\n   160→    let initial_event = JournalEvent {\n   161→        sequence: 1,\n   162→        timestamp: input.created_at,\n   163→        event_type: JournalEventType::ProjectCreated,\n   164→        details: serde_json::json!({\n   165→            \"project_id\": record.id.as_str(),\n   166→            \"flow\": record.flow.as_str(),\n   167→        }),\n   168→    };\n   169→    let journal_line = journal::serialize_event(&initial_event)?;\n   170→\n   171→    // Atomic creation: all files or nothing\n   172→    store.create_project_atomic(\n   173→        base_dir,\n   174→        &record,\n   175→        &input.prompt_contents,\n   176→        &run_snapshot,\n   177→        &journal_line,\n   178→        &sessions,\n   179→    )?;\n   180→\n   181→    // create_project_atomic writes the journal as part of the atomic init,\n   182→    // but we don't call journal_store.append_event here because the atomic\n   183→    // creation already wrote the initial journal line. The journal_store\n   184→    // parameter is kept for interface consistency and future use.\n   185→    let _ = journal_store;\n   186→\n   187→    Ok(record)\n   188→}\n   189→\n   190→/// List all projects with summary data.\n   191→pub fn list_projects(\n   192→    store: &dyn ProjectStorePort,\n   193→    active_port: &dyn ActiveProjectPort,\n   194→    base_dir: &Path,\n   195→) -> AppResult<Vec<ProjectListEntry>> {\n   196→    let active_id = active_port.read_active_project_id(base_dir)?;\n   197→    let project_ids = store.list_project_ids(base_dir)?;\n   198→\n   199→    let mut entries = Vec::new();\n   200→    for pid in project_ids {\n   201→        let record = store.read_project_record(base_dir, &pid)?;\n   202→        let is_active = active_id.as_deref() == Some(pid.as_str());\n   203→        entries.push(ProjectListEntry {\n   204→            id: record.id,\n   205→            name: record.name,\n   206→            flow: record.flow,\n   207→            status_summary: record.status_summary,\n   208→            created_at: record.created_at,\n   209→            is_active,\n   210→        });\n   211→    }\n   212→\n   213→    Ok(entries)\n   214→}\n   215→\n   216→/// Show detailed project information.\n   217→pub fn show_project(\n   218→    store: &dyn ProjectStorePort,\n   219→    run_port: &dyn RunSnapshotPort,\n   220→    journal_port: &dyn JournalStorePort,\n   221→    active_port: &dyn ActiveProjectPort,\n   222→    base_dir: &Path,\n   223→    project_id: &ProjectId,\n   224→) -> AppResult<ProjectDetail> {\n   225→    if !store.project_exists(base_dir, project_id)? {\n   226→        return Err(AppError::ProjectNotFound {\n   227→            project_id: project_id.to_string(),\n   228→        });\n   229→    }\n   230→\n   231→    let record = store.read_project_record(base_dir, project_id)?;\n   232→    let run_snapshot = run_port.read_run_snapshot(base_dir, project_id)?;\n   233→    let events = journal_port.read_journal(base_dir, project_id)?;\n   234→    let journal_event_count = events.len() as u64;\n   235→    let active_id = active_port.read_active_project_id(base_dir)?;\n   236→    let is_active = active_id.as_deref() == Some(project_id.as_str());\n   237→\n   238→    // Count rollback points from journal events\n   239→    let rollback_count = events\n   240→        .iter()\n   241→        .filter(|e| e.event_type == JournalEventType::RollbackCreated)\n   242→        .count();\n   243→\n   244→    Ok(ProjectDetail {\n   245→        record,\n   246→        run_snapshot,\n   247→        journal_event_count,\n   248→        rollback_count,\n   249→        is_active,\n   250→    })\n   251→}\n   252→\n   253→/// Delete a project. Fails if project has an active run.\n   254→/// Clears active-project pointer if it pointed to the deleted project.\n   255→///\n   256→/// Transactional: if any post-validation step fails, the project remains\n   257→/// addressable at its canonical path and the active-project pointer is\n   258→/// unchanged.\n   259→pub fn delete_project(\n   260→    store: &dyn ProjectStorePort,\n   261→    run_port: &dyn RunSnapshotPort,\n   262→    active_port: &dyn ActiveProjectPort,\n   263→    base_dir: &Path,\n   264→    project_id: &ProjectId,\n   265→) -> AppResult<()> {\n   266→    if !store.project_exists(base_dir, project_id)? {\n   267→        return Err(AppError::ProjectNotFound {\n   268→            project_id: project_id.to_string(),\n   269→        });\n   270→    }\n   271→\n   272→    // Check for active run\n   273→    let run_snapshot = run_port.read_run_snapshot(base_dir, project_id)?;\n   274→    if run_snapshot.has_active_run() {\n   275→        return Err(AppError::ActiveRunDelete {\n   276→            project_id: project_id.to_string(),\n   277→        });\n   278→    }\n   279→\n   280→    // Check if this is the active project (before delete)\n   281→    let active_id = active_port.read_active_project_id(base_dir)?;\n   282→    let was_active = active_id.as_deref() == Some(project_id.as_str());\n   283→\n   284→    // Phase 1: Stage the delete — project becomes invisible to list/show\n   285→    // but data remains on disk for rollback.\n   286→    store.stage_delete(base_dir, project_id)?;\n   287→\n   288→    // Phase 2: Clear the active-project pointer if needed.\n   289→    // If this fails, roll back the staged delete so the project remains\n   290→    // addressable and the pointer is unchanged.\n   291→    if was_active {\n   292→        if let Err(clear_err) = active_port.clear_active_project(base_dir) {\n   293→            store\n   294→                .rollback_delete(base_dir, project_id)\n   295→                .map_err(|restore_err| AppError::CorruptRecord {\n   296→                    file: format!(\"projects/{}\", project_id),\n   297→                    details: format!(\n   298→                        \"delete partially failed: pointer clear error: {}, restore error: {}\",\n   299→                        clear_err, restore_err\n   300→                    ),\n   301→                })?;\n   302→            return Err(clear_err);\n   303→        }\n   304→    }\n   305→\n   306→    // Phase 3: Finalize — permanently remove the project data.\n   307→    // At this point the logical delete has succeeded (project is invisible,\n   308→    // pointer is cleared). Best-effort cleanup of the staged data.\n   309→    let _ = store.commit_delete(base_dir, project_id);\n   310→\n   311→    Ok(())\n   312→}\n   313→\n   314→/// Get run status for the active project.\n   315→pub fn run_status(\n   316→    run_port: &dyn RunSnapshotPort,\n   317→    base_dir: &Path,\n   318→    project_id: &ProjectId,\n   319→) -> AppResult<RunStatusView> {\n   320→    let snapshot = run_port.read_run_snapshot(base_dir, project_id)?;\n   321→    Ok(queries::build_status_view(project_id.as_str(), &snapshot))\n   322→}\n   323→\n   324→/// Get run history (durable only, no runtime logs).\n   325→pub fn run_history(\n   326→    journal_port: &dyn JournalStorePort,\n   327→    artifact_port: &dyn ArtifactStorePort,\n   328→    base_dir: &Path,\n   329→    project_id: &ProjectId,\n   330→) -> AppResult<RunHistoryView> {\n   331→    let events = journal_port.read_journal(base_dir, project_id)?;\n   332→    let payloads = artifact_port.list_payloads(base_dir, project_id)?;\n   333→    let artifacts = artifact_port.list_artifacts(base_dir, project_id)?;\n   334→\n   335→    queries::validate_history_consistency(&payloads, &artifacts)?;\n   336→\n   337→    Ok(queries::build_history_view(\n   338→        project_id.as_str(),\n   339→        events,\n   340→        payloads,\n   341→        artifacts,\n   342→    ))\n   343→}\n   344→\n   345→/// Get run tail: durable history by default, with optional runtime logs.\n   346→pub fn run_tail(\n   347→    journal_port: &dyn JournalStorePort,\n   348→    artifact_port: &dyn ArtifactStorePort,\n   349→    log_port: &dyn RuntimeLogStorePort,\n   350→    base_dir: &Path,\n   351→    project_id: &ProjectId,\n   352→    include_logs: bool,\n   353→) -> AppResult<RunTailView> {\n   354→    let events = journal_port.read_journal(base_dir, project_id)?;\n   355→    let payloads = artifact_port.list_payloads(base_dir, project_id)?;\n   356→    let artifacts = artifact_port.list_artifacts(base_dir, project_id)?;\n   357→\n   358→    queries::validate_history_consistency(&payloads, &artifacts)?;\n   359→\n   360→    let runtime_logs = if include_logs {\n   361→        log_port.read_runtime_logs(base_dir, project_id)?\n   362→    } else {\n   363→        Vec::new()\n   364→    };\n   365→\n   366→    Ok(queries::build_tail_view(\n   367→        project_id.as_str(),\n   368→        events,\n   369→        payloads,\n   370→        artifacts,\n   371→        include_logs,\n   372→        runtime_logs,\n   373→    ))\n   374→}\n   375→"}]},"parent_tool_use_id":null,"session_id":"19a33b10-b5a0-4ba2-8943-a7efa3e34818","uuid":"f2125725-a338-4e0e-b600-14b59c14281a","tool_use_result":{"type":"text","file":{"filePath":"/root/new-ralph-burning/ralph-burning-rewrite/src/contexts/project_run_record/service.rs","content":"use std::path::Path;\n\nuse chrono::{DateTime, Utc};\n\nuse crate::shared::domain::{FlowPreset, ProjectId};\nuse crate::shared::error::{AppError, AppResult};\n\nuse super::journal;\nuse super::model::{\n    ArtifactRecord, JournalEvent, JournalEventType, PayloadRecord, ProjectDetail, ProjectListEntry,\n    ProjectRecord, ProjectStatusSummary, RunSnapshot, RuntimeLogEntry, SessionStore,\n};\nuse super::queries::{self, RunHistoryView, RunStatusView, RunTailView};\n\n/// Port for reading and writing project records.\npub trait ProjectStorePort {\n    fn project_exists(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<bool>;\n    fn read_project_record(\n        &self,\n        base_dir: &Path,\n        project_id: &ProjectId,\n    ) -> AppResult<ProjectRecord>;\n    fn list_project_ids(&self, base_dir: &Path) -> AppResult<Vec<ProjectId>>;\n\n    /// Stage a project for deletion: makes it invisible to list/show but\n    /// keeps data on disk for potential rollback.\n    fn stage_delete(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<()>;\n\n    /// Finalize a staged delete: permanently removes the project data.\n    fn commit_delete(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<()>;\n\n    /// Roll back a staged delete: restores the project to its canonical path.\n    fn rollback_delete(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<()>;\n\n    /// Atomically stage and commit a new project. If any step fails,\n    /// the project must not be visible to list/show.\n    fn create_project_atomic(\n        &self,\n        base_dir: &Path,\n        record: &ProjectRecord,\n        prompt_contents: &str,\n        run_snapshot: &RunSnapshot,\n        initial_journal_line: &str,\n        sessions: &SessionStore,\n    ) -> AppResult<()>;\n}\n\n/// Port for reading and appending journal events.\npub trait JournalStorePort {\n    fn read_journal(&self, base_dir: &Path, project_id: &ProjectId)\n        -> AppResult<Vec<JournalEvent>>;\n    fn append_event(&self, base_dir: &Path, project_id: &ProjectId, line: &str) -> AppResult<()>;\n}\n\n/// Port for reading payload and artifact durable history.\npub trait ArtifactStorePort {\n    fn list_payloads(\n        &self,\n        base_dir: &Path,\n        project_id: &ProjectId,\n    ) -> AppResult<Vec<PayloadRecord>>;\n    fn list_artifacts(\n        &self,\n        base_dir: &Path,\n        project_id: &ProjectId,\n    ) -> AppResult<Vec<ArtifactRecord>>;\n}\n\n/// Port for reading runtime logs (separate from durable history).\npub trait RuntimeLogStorePort {\n    fn read_runtime_logs(\n        &self,\n        base_dir: &Path,\n        project_id: &ProjectId,\n    ) -> AppResult<Vec<RuntimeLogEntry>>;\n}\n\n/// Port for reading/writing the run snapshot.\npub trait RunSnapshotPort {\n    fn read_run_snapshot(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<RunSnapshot>;\n}\n\n/// Port for writing the run snapshot atomically.\npub trait RunSnapshotWritePort {\n    fn write_run_snapshot(\n        &self,\n        base_dir: &Path,\n        project_id: &ProjectId,\n        snapshot: &RunSnapshot,\n    ) -> AppResult<()>;\n}\n\n/// Port for writing payload and artifact records atomically as a pair.\npub trait PayloadArtifactWritePort {\n    fn write_payload_artifact_pair(\n        &self,\n        base_dir: &Path,\n        project_id: &ProjectId,\n        payload: &PayloadRecord,\n        artifact: &ArtifactRecord,\n    ) -> AppResult<()>;\n}\n\n/// Port for appending runtime log entries (best-effort, not durable history).\npub trait RuntimeLogWritePort {\n    fn append_runtime_log(\n        &self,\n        base_dir: &Path,\n        project_id: &ProjectId,\n        entry: &RuntimeLogEntry,\n    ) -> AppResult<()>;\n}\n\n/// Port for reading/writing/clearing the active project pointer.\npub trait ActiveProjectPort {\n    fn read_active_project_id(&self, base_dir: &Path) -> AppResult<Option<String>>;\n    fn clear_active_project(&self, base_dir: &Path) -> AppResult<()>;\n    fn write_active_project(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<()>;\n}\n\n/// Input for the `project create` use case.\npub struct CreateProjectInput {\n    pub id: ProjectId,\n    pub name: String,\n    pub flow: FlowPreset,\n    pub prompt_path: String,\n    pub prompt_contents: String,\n    pub prompt_hash: String,\n    pub created_at: DateTime<Utc>,\n}\n\n/// Create a new project with all canonical files.\npub fn create_project(\n    store: &dyn ProjectStorePort,\n    journal_store: &dyn JournalStorePort,\n    base_dir: &Path,\n    input: CreateProjectInput,\n) -> AppResult<ProjectRecord> {\n    // Check for duplicate project ID\n    if store.project_exists(base_dir, &input.id)? {\n        return Err(AppError::DuplicateProject {\n            project_id: input.id.to_string(),\n        });\n    }\n\n    let record = ProjectRecord {\n        id: input.id.clone(),\n        name: input.name,\n        flow: input.flow,\n        prompt_reference: \"prompt.md\".to_owned(),\n        prompt_hash: input.prompt_hash,\n        created_at: input.created_at,\n        status_summary: ProjectStatusSummary::Created,\n    };\n\n    let run_snapshot = RunSnapshot::initial();\n    let sessions = SessionStore::empty();\n\n    // Create the initial journal event\n    let initial_event = JournalEvent {\n        sequence: 1,\n        timestamp: input.created_at,\n        event_type: JournalEventType::ProjectCreated,\n        details: serde_json::json!({\n            \"project_id\": record.id.as_str(),\n            \"flow\": record.flow.as_str(),\n        }),\n    };\n    let journal_line = journal::serialize_event(&initial_event)?;\n\n    // Atomic creation: all files or nothing\n    store.create_project_atomic(\n        base_dir,\n        &record,\n        &input.prompt_contents,\n        &run_snapshot,\n        &journal_line,\n        &sessions,\n    )?;\n\n    // create_project_atomic writes the journal as part of the atomic init,\n    // but we don't call journal_store.append_event here because the atomic\n    // creation already wrote the initial journal line. The journal_store\n    // parameter is kept for interface consistency and future use.\n    let _ = journal_store;\n\n    Ok(record)\n}\n\n/// List all projects with summary data.\npub fn list_projects(\n    store: &dyn ProjectStorePort,\n    active_port: &dyn ActiveProjectPort,\n    base_dir: &Path,\n) -> AppResult<Vec<ProjectListEntry>> {\n    let active_id = active_port.read_active_project_id(base_dir)?;\n    let project_ids = store.list_project_ids(base_dir)?;\n\n    let mut entries = Vec::new();\n    for pid in project_ids {\n        let record = store.read_project_record(base_dir, &pid)?;\n        let is_active = active_id.as_deref() == Some(pid.as_str());\n        entries.push(ProjectListEntry {\n            id: record.id,\n            name: record.name,\n            flow: record.flow,\n            status_summary: record.status_summary,\n            created_at: record.created_at,\n            is_active,\n        });\n    }\n\n    Ok(entries)\n}\n\n/// Show detailed project information.\npub fn show_project(\n    store: &dyn ProjectStorePort,\n    run_port: &dyn RunSnapshotPort,\n    journal_port: &dyn JournalStorePort,\n    active_port: &dyn ActiveProjectPort,\n    base_dir: &Path,\n    project_id: &ProjectId,\n) -> AppResult<ProjectDetail> {\n    if !store.project_exists(base_dir, project_id)? {\n        return Err(AppError::ProjectNotFound {\n            project_id: project_id.to_string(),\n        });\n    }\n\n    let record = store.read_project_record(base_dir, project_id)?;\n    let run_snapshot = run_port.read_run_snapshot(base_dir, project_id)?;\n    let events = journal_port.read_journal(base_dir, project_id)?;\n    let journal_event_count = events.len() as u64;\n    let active_id = active_port.read_active_project_id(base_dir)?;\n    let is_active = active_id.as_deref() == Some(project_id.as_str());\n\n    // Count rollback points from journal events\n    let rollback_count = events\n        .iter()\n        .filter(|e| e.event_type == JournalEventType::RollbackCreated)\n        .count();\n\n    Ok(ProjectDetail {\n        record,\n        run_snapshot,\n        journal_event_count,\n        rollback_count,\n        is_active,\n    })\n}\n\n/// Delete a project. Fails if project has an active run.\n/// Clears active-project pointer if it pointed to the deleted project.\n///\n/// Transactional: if any post-validation step fails, the project remains\n/// addressable at its canonical path and the active-project pointer is\n/// unchanged.\npub fn delete_project(\n    store: &dyn ProjectStorePort,\n    run_port: &dyn RunSnapshotPort,\n    active_port: &dyn ActiveProjectPort,\n    base_dir: &Path,\n    project_id: &ProjectId,\n) -> AppResult<()> {\n    if !store.project_exists(base_dir, project_id)? {\n        return Err(AppError::ProjectNotFound {\n            project_id: project_id.to_string(),\n        });\n    }\n\n    // Check for active run\n    let run_snapshot = run_port.read_run_snapshot(base_dir, project_id)?;\n    if run_snapshot.has_active_run() {\n        return Err(AppError::ActiveRunDelete {\n            project_id: project_id.to_string(),\n        });\n    }\n\n    // Check if this is the active project (before delete)\n    let active_id = active_port.read_active_project_id(base_dir)?;\n    let was_active = active_id.as_deref() == Some(project_id.as_str());\n\n    // Phase 1: Stage the delete — project becomes invisible to list/show\n    // but data remains on disk for rollback.\n    store.stage_delete(base_dir, project_id)?;\n\n    // Phase 2: Clear the active-project pointer if needed.\n    // If this fails, roll back the staged delete so the project remains\n    // addressable and the pointer is unchanged.\n    if was_active {\n        if let Err(clear_err) = active_port.clear_active_project(base_dir) {\n            store\n                .rollback_delete(base_dir, project_id)\n                .map_err(|restore_err| AppError::CorruptRecord {\n                    file: format!(\"projects/{}\", project_id),\n                    details: format!(\n                        \"delete partially failed: pointer clear error: {}, restore error: {}\",\n                        clear_err, restore_err\n                    ),\n                })?;\n            return Err(clear_err);\n        }\n    }\n\n    // Phase 3: Finalize — permanently remove the project data.\n    // At this point the logical delete has succeeded (project is invisible,\n    // pointer is cleared). Best-effort cleanup of the staged data.\n    let _ = store.commit_delete(base_dir, project_id);\n\n    Ok(())\n}\n\n/// Get run status for the active project.\npub fn run_status(\n    run_port: &dyn RunSnapshotPort,\n    base_dir: &Path,\n    project_id: &ProjectId,\n) -> AppResult<RunStatusView> {\n    let snapshot = run_port.read_run_snapshot(base_dir, project_id)?;\n    Ok(queries::build_status_view(project_id.as_str(), &snapshot))\n}\n\n/// Get run history (durable only, no runtime logs).\npub fn run_history(\n    journal_port: &dyn JournalStorePort,\n    artifact_port: &dyn ArtifactStorePort,\n    base_dir: &Path,\n    project_id: &ProjectId,\n) -> AppResult<RunHistoryView> {\n    let events = journal_port.read_journal(base_dir, project_id)?;\n    let payloads = artifact_port.list_payloads(base_dir, project_id)?;\n    let artifacts = artifact_port.list_artifacts(base_dir, project_id)?;\n\n    queries::validate_history_consistency(&payloads, &artifacts)?;\n\n    Ok(queries::build_history_view(\n        project_id.as_str(),\n        events,\n        payloads,\n        artifacts,\n    ))\n}\n\n/// Get run tail: durable history by default, with optional runtime logs.\npub fn run_tail(\n    journal_port: &dyn JournalStorePort,\n    artifact_port: &dyn ArtifactStorePort,\n    log_port: &dyn RuntimeLogStorePort,\n    base_dir: &Path,\n    project_id: &ProjectId,\n    include_logs: bool,\n) -> AppResult<RunTailView> {\n    let events = journal_port.read_journal(base_dir, project_id)?;\n    let payloads = artifact_port.list_payloads(base_dir, project_id)?;\n    let artifacts = artifact_port.list_artifacts(base_dir, project_id)?;\n\n    queries::validate_history_consistency(&payloads, &artifacts)?;\n\n    let runtime_logs = if include_logs {\n        log_port.read_runtime_logs(base_dir, project_id)?\n    } else {\n        Vec::new()\n    };\n\n    Ok(queries::build_tail_view(\n        project_id.as_str(),\n        events,\n        payloads,\n        artifacts,\n        include_logs,\n        runtime_logs,\n    ))\n}\n","numLines":375,"startLine":1,"totalLines":375}}}
