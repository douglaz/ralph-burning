oject_id)?;\n   143→\n   144→    let run_store = FsRunSnapshotStore;\n   145→    let status = service::run_status(&run_store, &current_dir, &project_id)?;\n   146→\n   147→    println!(\"Project: {}\", status.project_id);\n   148→    println!(\"Status: {}\", status.status);\n   149→    if let Some(ref stage) = status.stage {\n   150→        println!(\"Stage: {}\", stage);\n   151→    }\n   152→    if let Some(cycle) = status.cycle {\n   153→        println!(\"Cycle: {}\", cycle);\n   154→    }\n   155→    if let Some(round) = status.completion_round {\n   156→        println!(\"Completion round: {}\", round);\n   157→    }\n   158→    println!(\"Summary: {}\", status.summary);\n   159→\n   160→    Ok(())\n   161→}\n   162→\n   163→async fn handle_history() -> AppResult<()> {\n   164→    let current_dir = std::env::current_dir()?;\n   165→\n   166→    let config = workspace_governance::load_workspace_config(&current_dir)?;\n   167→    workspace_governance::ensure_supported_workspace_version(&config)?;\n   168→\n   169→    let project_id = workspace_governance::resolve_active_project(&current_dir)?;\n   170→\n   171→    // Validate canonical project record before proceeding with run queries\n   172→    let project_store = FsProjectStore;\n   173→    let _ = project_store.read_project_record(&current_dir, &project_id)?;\n   174→\n   175→    let journal_store = FsJournalStore;\n   176→    let artifact_store = FsArtifactStore;\n   177→\n   178→    let history = service::run_history(&journal_store, &artifact_store, &current_dir, &project_id)?;\n   179→\n   180→    println!(\"Project: {}\", history.project_id);\n   181→    println!(\"--- Journal Events ---\");\n   182→    for event in &history.events {\n   183→        println!(\n   184→            \"  [{}] {} - {:?}\",\n   185→            event.sequence, event.timestamp, event.event_type\n   186→        );\n   187→    }\n   188→\n   189→    if !history.payloads.is_empty() {\n   190→        println!(\"--- Payloads ---\");\n