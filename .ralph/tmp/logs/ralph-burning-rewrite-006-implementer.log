{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01CQszkdHiKhuiZf3wMimPDp","type":"tool_result","content":"     1→use crate::shared::error::{AppError, AppResult};\n     2→\n     3→use super::model::{JournalEvent, JournalEventType};\n     4→\n     5→/// Validates that a new event's sequence follows the last known sequence.\n     6→/// The first event must have sequence 1.\n     7→pub fn validate_sequence(last_sequence: u64, event: &JournalEvent) -> AppResult<()> {\n     8→    let expected = last_sequence + 1;\n     9→    if event.sequence != expected {\n    10→        return Err(AppError::JournalSequence {\n    11→            details: format!(\"expected sequence {expected}, got {}\", event.sequence),\n    12→        });\n    13→    }\n    14→    Ok(())\n    15→}\n    16→\n    17→/// Serializes a journal event to a single NDJSON line (no trailing newline).\n    18→pub fn serialize_event(event: &JournalEvent) -> AppResult<String> {\n    19→    Ok(serde_json::to_string(event)?)\n    20→}\n    21→\n    22→/// Deserializes a single NDJSON line into a journal event.\n    23→pub fn deserialize_event(line: &str) -> AppResult<JournalEvent> {\n    24→    let trimmed = line.trim();\n    25→    if trimmed.is_empty() {\n    26→        return Err(AppError::CorruptRecord {\n    27→            file: \"journal.ndjson\".to_owned(),\n    28→            details: \"empty line in journal\".to_owned(),\n    29→        });\n    30→    }\n    31→    serde_json::from_str(trimmed).map_err(|e| AppError::CorruptRecord {\n    32→        file: \"journal.ndjson\".to_owned(),\n    33→        details: format!(\"invalid journal event: {e}\"),\n    34→    })\n    35→}\n    36→\n    37→/// Parses the full contents of a journal.ndjson file into ordered events.\n    38→/// Validates monotonic sequence ordering and journal integrity (first event\n    39→/// must be `project_created` with sequence 1).\n    40→pub fn parse_journal(contents: &str) -> AppResult<Vec<JournalEvent>> {\n    41→    let mut events = Vec::new();\n    42→    let mut last_sequence = 0u64;\n    43→\n    44→    for line in contents.lines() {\n    45→        if line.trim().is_empty() {\n    46→            continue;\n    47→        }\n    48→        let event = deserialize_event(line)?;\n    49→        validate_sequence(last_sequence, &event)?;\n    50→        last_sequence = event.sequence;\n    51→        events.push(event);\n    52→    }\n    53→\n    54→    validate_journal_integrity(&events)?;\n    55→\n    56→    Ok(events)\n    57→}\n    58→\n    59→/// Validates that a journal has the required structure:\n    60→/// - Must not be empty (must contain at least the initial `project_created` event)\n    61→/// - First event must be `project_created` with sequence 1\n    62→pub fn validate_journal_integrity(events: &[JournalEvent]) -> AppResult<()> {\n    63→    if events.is_empty() {\n    64→        return Err(AppError::CorruptRecord {\n    65→            file: \"journal.ndjson\".to_owned(),\n    66→            details: \"journal is empty — must contain at least the initial project_created event\"\n    67→                .to_owned(),\n    68→        });\n    69→    }\n    70→\n    71→    let first = &events[0];\n    72→    if first.event_type != JournalEventType::ProjectCreated {\n    73→        return Err(AppError::CorruptRecord {\n    74→            file: \"journal.ndjson\".to_owned(),\n    75→            details: format!(\n    76→                \"first journal event type is '{:?}', expected 'project_created'\",\n    77→                first.event_type\n    78→            ),\n    79→        });\n    80→    }\n    81→\n    82→    Ok(())\n    83→}\n    84→\n    85→/// Returns the last sequence number from a set of events, or 0 if empty.\n    86→pub fn last_sequence(events: &[JournalEvent]) -> u64 {\n    87→    events.last().map_or(0, |e| e.sequence)\n    88→}\n    89→"}]},"parent_tool_use_id":null,"session_id":"b9859e69-5579-4e82-ac66-49d19cc80e05","uuid":"fde60744-7f69-41d3-8e30-a4904127ebc1","tool_use_result":{"type":"text","file":{"filePath":"/root/new-ralph-burning/ralph-burning-rewrite/src/contexts/project_run_record/journal.rs","content":"use crate::shared::error::{AppError, AppResult};\n\nuse super::model::{JournalEvent, JournalEventType};\n\n/// Validates that a new event's sequence follows the last known sequence.\n/// The first event must have sequence 1.\npub fn validate_sequence(last_sequence: u64, event: &JournalEvent) -> AppResult<()> {\n    let expected = last_sequence + 1;\n    if event.sequence != expected {\n        return Err(AppError::JournalSequence {\n            details: format!(\"expected sequence {expected}, got {}\", event.sequence),\n        });\n    }\n    Ok(())\n}\n\n/// Serializes a journal event to a single NDJSON line (no trailing newline).\npub fn serialize_event(event: &JournalEvent) -> AppResult<String> {\n    Ok(serde_json::to_string(event)?)\n}\n\n/// Deserializes a single NDJSON line into a journal event.\npub fn deserialize_event(line: &str) -> AppResult<JournalEvent> {\n    let trimmed = line.trim();\n    if trimmed.is_empty() {\n        return Err(AppError::CorruptRecord {\n            file: \"journal.ndjson\".to_owned(),\n            details: \"empty line in journal\".to_owned(),\n        });\n    }\n    serde_json::from_str(trimmed).map_err(|e| AppError::CorruptRecord {\n        file: \"journal.ndjson\".to_owned(),\n        details: format!(\"invalid journal event: {e}\"),\n    })\n}\n\n/// Parses the full contents of a journal.ndjson file into ordered events.\n/// Validates monotonic sequence ordering and journal integrity (first event\n/// must be `project_created` with sequence 1).\npub fn parse_journal(contents: &str) -> AppResult<Vec<JournalEvent>> {\n    let mut events = Vec::new();\n    let mut last_sequence = 0u64;\n\n    for line in contents.lines() {\n        if line.trim().is_empty() {\n            continue;\n        }\n        let event = deserialize_event(line)?;\n        validate_sequence(last_sequence, &event)?;\n        last_sequence = event.sequence;\n        events.push(event);\n    }\n\n    validate_journal_integrity(&events)?;\n\n    Ok(events)\n}\n\n/// Validates that a journal has the required structure:\n/// - Must not be empty (must contain at least the initial `project_created` event)\n/// - First event must be `project_created` with sequence 1\npub fn validate_journal_integrity(events: &[JournalEvent]) -> AppResult<()> {\n    if events.is_empty() {\n        return Err(AppError::CorruptRecord {\n            file: \"journal.ndjson\".to_owned(),\n            details: \"journal is empty — must contain at least the initial project_created event\"\n                .to_owned(),\n        });\n    }\n\n    let first = &events[0];\n    if first.event_type != JournalEventType::ProjectCreated {\n        return Err(AppError::CorruptRecord {\n            file: \"journal.ndjson\".to_owned(),\n            details: format!(\n                \"first journal event type is '{:?}', expected 'project_created'\",\n                first.event_type\n            ),\n        });\n    }\n\n    Ok(())\n}\n\n/// Returns the last sequence number from a set of events, or 0 if empty.\npub fn last_sequence(events: &[JournalEvent]) -> u64 {\n    events.last().map_or(0, |e| e.sequence)\n}\n","numLines":89,"startLine":1,"totalLines":89}}}
