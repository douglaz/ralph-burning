xpect(\"run status\");\n   948→\n   949→    assert!(output.status.success());\n   950→    let stdout = String::from_utf8_lossy(&output.stdout);\n   951→    assert!(stdout.contains(\"Status: not started\"));\n   952→}\n   953→\n   954→// ── Run History ──\n   955→\n   956→#[test]\n   957→fn run_history_shows_journal_events_for_new_project() {\n   958→    let temp_dir = initialize_workspace_fixture();\n   959→    let prompt = write_prompt_fixture(temp_dir.path());\n   960→\n   961→    Command::new(binary())\n   962→        .args([\n   963→            \"project\",\n   964→            \"create\",\n   965→            \"--id\",\n   966→            \"hist-test\",\n   967→            \"--name\",\n   968→            \"History Test\",\n   969→            \"--prompt\",\n   970→            prompt.to_str().unwrap(),\n   971→            \"--flow\",\n   972→            \"standard\",\n   973→        ])\n   974→        .current_dir(temp_dir.path())\n   975→        .output()\n   976→        .expect(\"create project\");\n   977→\n   978→    Command::new(binary())\n   979→        .args([\"project\", \"select\", \"hist-test\"])\n   980→        .current_dir(temp_dir.path())\n   981→        .output()\n   982→        .expect(\"select project\");\n   983→\n   984→    let output = Command::new(binary())\n   985→        .args([\"run\", \"history\"])\n   986→        .current_dir(temp_dir.path())\n   987→        .output()\n   988→        .expect(\"run history\");\n   989→\n   990→    assert!(output.status.success());\n   991→    let stdout = String::from_utf8_lossy(&output.stdout);\n   992→    assert!(stdout.contains(\"Journal Events\"));\n   993→    assert!(stdout.contains(\"ProjectCreated\"));\n   994→}\n   995→\n   996→// ── Run Tail ──\n   997→\n   998→#[test]\n   999→fn run_tail_shows_durable_history_only_by_default() {\n  1000→    let temp_dir = initialize_workspace_fixture();\n  1001→    let prompt = write_prompt_fixture(temp_dir.path());\n  1002→\n  1003→    Command::new(binary())\n  1004→        .args([\n  1005→            \"project\",\n  1006→            \"create\",\n  1007→            \"--id\",\n  1008→            \"tail-test\",\n  1009→            \"--name\",\n  1010→            \"Tail Test\",\n  1011→            \"--prompt\",\n  1012→            prompt.to_str().unwrap(),\n  1013→            \"--flow\",\n  1014→            \"standard\",\n  1015→        ])\n  1016→        .current_dir(temp_dir.path())\n  1017→        .output()\n  1018→        .expect(\"create project\");\n  1019→\n  1020→    Command::new(binary())\n  1021→        .args([\"project\", \"select\", \"tail-test\"])\n  1022→        .current_dir(temp_dir.path())\n  1023→        .output()\n  1024→        .expect(\"select project\");\n  1025→\n  1026→    let output = Command::new(binary())\n  1027→        .args([\"run\", \"tail\"])\n  1028→        .current_dir(temp_dir.path())\n  1029→        .output()\n  1030→        .expect(\"run tail\");\n  1031→\n  1032→    assert!(output.status.success());\n  1033→    let stdout = String::from_utf8_lossy(&output.stdout);\n  1034→    assert!(stdout.contains(\"Durable History\"));\n  1035→    // No runtime logs section when --logs not passed\n  1036→    assert!(!stdout.contains(\"Runtime Logs\"));\n  1037→}\n  1038→\n  1039→#[test]\n  1040→fn run_tail_with_logs_includes_runtime_logs_section() {\n  1041→    let temp_dir = initialize_workspace_fixture();\n  1042→    let prompt = write_prompt_fixture(temp_dir.path());\n  1043→\n  1044→    Command::new(binary())\n  1045→        .args([\n  1046→            \"project\",\n  1047→            \"create\",\n  1048→            \"--id\",\n  1049→            \"tail-logs\",\n  1050→            \"--name\",\n  1051→            \"Tail Logs\",\n  1052→            \"--prompt\",\n  1053→            prompt.to_str().unwrap(),\n  1054→            \"--flow\",\n  1055→            \"standard\",\n  1056→        ])\n  1057→        .current_dir(temp_dir.path())\n  1058→        .output()\n  1059→        .expect(\"create project\")