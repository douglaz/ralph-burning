nalReview => Self::Reviewer,\n   253→        }\n   254→    }\n   255→}\n   256→\n   257→impl fmt::Display for BackendRole {\n   258→    fn fmt(&self, f: &mut fmt::Formatter<'_>) -> fmt::Result {\n   259→        f.write_str(self.as_str())\n   260→    }\n   261→}\n   262→\n   263→#[derive(Debug, Clone, Copy, PartialEq, Eq, Hash, Serialize, Deserialize)]\n   264→#[serde(rename_all = \"snake_case\")]\n   265→pub enum SessionPolicy {\n   266→    NewSession,\n   267→    ReuseIfAllowed,\n   268→}\n   269→\n   270→#[derive(Debug, Clone, Copy, PartialEq, Eq, Hash, Serialize, Deserialize)]\n   271→#[serde(rename_all = \"snake_case\")]\n   272→pub enum FlowPreset {\n   273→    Standard,\n   274→    QuickDev,\n   275→    DocsChange,\n   276→    CiImprovement,\n   277→}\n   278→\n   279→impl FlowPreset {\n   280→    pub const ALL: [Self; 4] = [\n   281→        Self::Standard,\n   282→        Self::QuickDev,\n   283→        Self::DocsChange,\n   284→        Self::CiImprovement,\n   285→    ];\n   286→\n   287→    pub fn all() -> &'static [Self] {\n   288→        &Self::ALL\n   289→    }\n   290→\n   291→    pub fn as_str(self) -> &'static str {\n   292→        match self {\n   293→            Self::Standard => \"standard\",\n   294→            Self::QuickDev => \"quick_dev\",\n   295→            Self::DocsChange => \"docs_change\",\n   296→            Self::CiImprovement => \"ci_improvement\",\n   297→        }\n   298→    }\n   299→\n   300→    pub fn description(self) -> &'static str {\n   301→        match self {\n   302→            Self::Standard => {\n   303→                \"Full delivery flow with planning, implementation, QA, review, and acceptance.\"\n   304→            }\n   305→            Self::QuickDev => \"Fast delivery flow for small code changes with lightweight review.\",\n   306→            Self::DocsChange => {\n   307→                \"Documentation-focused flow for planning, content updates, and validation.\"\n   308→            }\n   309→            Self::CiImprovement => {\n   310→                \"CI improvement flow for automation planning, updates, and validation.\"\n   311→            }\n   312→        }\n   313→    }\n   314→}\n   315→\n   316→impl fmt::Display for FlowPreset {\n   317→    fn fmt(&self, f: &mut fmt::Formatter<'_>) -> fmt::Result {\n   318→        f.write_str(self.as_str())\n   319→    }\n   320→}\n   321→\n   322→impl FromStr for FlowPreset {\n   323→    type Err = AppError;\n   324→\n   325→    fn from_str(value: &str) -> Result<Self, Self::Err> {\n   326→        match value {\n   327→            \"standard\" => Ok(Self::Standard),\n   328→            \"quick_dev\" => Ok(Self::QuickDev),\n   329→            \"docs_change\" => Ok(Self::DocsChange),\n   330→            \"ci_improvement\" => Ok(Self::CiImprovement),\n   331→            _ => Err(AppError::InvalidFlowPreset {\n   332→                flow_id: value.to_owned(),\n   333→            }),\n   334→        }\n   335→    }\n   336→}\n   337→\n   338→#[derive(Debug, Clone, Copy, PartialEq, Eq, Hash, Serialize, Deserialize)]\n   339→#[serde(rename_all = \"snake_case\")]\n   340→pub enum StageId {\n   341→    PromptReview,\n   342→    Planning,\n   343→    Implementation,\n   344→    Qa,\n   345→    Review,\n   346→    CompletionPanel,\n   347→    AcceptanceQa,\n   348→    FinalReview,\n   349→    PlanAndImplement,\n   350→    ApplyFixes,\n   351→    DocsPlan,\n   352→    DocsUpdate,\n   353→    DocsValidation,\n   354→    CiPlan,\n   355→    CiUpdate,\n   356→    CiValidation,\n   357→}\n   358→\n   359→impl StageId {\n   360→    pub const ALL: [Self; 16] = [\n   361→        Self::PromptReview,\n   362→        Self::Planning,\n   363→        Self::Implementation,\n   364→        Self::Qa,\n   365→        Self::Review,\n   366→        Self::CompletionPanel,\n   367→        Self::AcceptanceQa,\n   368→        Self::FinalReview,\n   369→        Self::PlanAndImplement,\n   370→        Self::ApplyFixes,\n   371→        Self::DocsPlan,\n   372→      