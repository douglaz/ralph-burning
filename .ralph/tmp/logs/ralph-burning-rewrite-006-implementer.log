{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01QsgEJAh2ouRyQkUTXiF5J2","type":"tool_result","content":"     1→use crate::shared::error::{AppError, AppResult};\n     2→\n     3→use super::model::{JournalEvent, JournalEventType};\n     4→\n     5→/// Validates that a new event's sequence follows the last known sequence.\n     6→/// The first event must have sequence 1.\n     7→pub fn validate_sequence(last_sequence: u64, event: &JournalEvent) -> AppResult<()> {\n     8→    let expected = last_sequence + 1;\n     9→    if event.sequence != expected {\n    10→        return Err(AppError::JournalSequence {\n    11→            details: format!(\"expected sequence {expected}, got {}\", event.sequence),\n    12→        });\n    13→    }\n    14→    Ok(())\n    15→}\n    16→\n    17→/// Serializes a journal event to a single NDJSON line (no trailing newline).\n    18→pub fn serialize_event(event: &JournalEvent) -> AppResult<String> {\n    19→    Ok(serde_json::to_string(event)?)\n    20→}\n    21→\n    22→/// Deserializes a single NDJSON line into a journal event.\n    23→pub fn deserialize_event(line: &str) -> AppResult<JournalEvent> {\n    24→    let trimmed = line.trim();\n    25→    if trimmed.is_empty() {\n    26→        return Err(AppError::CorruptRecord {\n    27→            file: \"journal.ndjson\".to_owned(),\n    28→            details: \"empty line in journal\".to_owned(),\n    29→        });\n    30→    }\n    31→    serde_json::from_str(trimmed).map_err(|e| AppError::CorruptRecord {\n    32→        file: \"journal.ndjson\".to_owned(),\n    33→        details: format!(\"invalid journal event: {e}\"),\n    34→    })\n    35→}\n    36→\n    37→/// Parses the full contents of a journal.ndjson file into ordered events.\n    38→/// Validates monotonic sequence ordering and journal integrity (first event\n    39→/// must be `project_created` with sequence 1).\n    40→pub fn parse_journal(contents: &str) -> AppResult<Vec<JournalEvent>> {\n    41→    let mut events = Vec::new();\n    42→    let mut last_sequence = 0u64;\n    43→\n    44→    for line in contents.lines() {\n    45→        if line.trim().is_empty() {\n    46→            continue;\n    47→        }\n    48→        let event = deserialize_event(line)?;\n    49→        validate_sequence(last_sequence, &event)?;\n    50→        last_sequence = event.sequence;\n    51→        events.push(event);\n    52→    }\n    53→\n    54→    validate_journal_integrity(&events)?;\n    55→\n    56→    Ok(events)\n    57→}\n    58→\n    59→/// Validates that a journal has the required structure:\n    60→/// - Must not be empty (must contain at least the initial `project_created` event)\n    61→/// - First event must be `project_created` with sequence 1\n    62→pub fn validate_journal_integrity(events: &[JournalEvent]) -> AppResult<()> {\n    63→    if events.is_empty() {\n    64→        return Err(AppError::CorruptRecord {\n    65→            file: \"journal.ndjson\".to_owned(),\n    66→            details: \"journal is empty — must contain at least the initial project_created event\"\n    67→                .to_owned(),\n    68→        });\n    69→    }\n    70→\n    71→    let first = &events[0];\n    72→    if first.event_type != JournalEventType::ProjectCreated {\n    73→        return Err(AppError::CorruptRecord {\n    74→            file: \"journal.ndjson\".to_owned(),\n    75→            details: format!(\n    76→                \"first journal event type is '{:?}', expected 'project_created'\",\n    77→                first.event_type\n    78→            ),\n    79→        });\n    80→    }\n    81→\n    82→    Ok(())\n    83→}\n    84→\n    85→/// Returns the last sequence number from a set of events, or 0 if empty.\n    86→pub fn last_sequence(events: &[JournalEvent]) -> u64 {\n    87→    events.last().map_or(0, |e| e.sequence)\n    88→}\n    89→\n    90→// ── Lifecycle event builders ────────────────────────────────────────────────\n    91→\n    92→use chrono::{DateTime, Utc};\n    93→use crate::shared::domain::{RunId, StageId};\n    94→\n    95→/// Build a `run_started` journal event.\n    96→pub fn run_started_event(\n    97→    sequence: u64,\n    98→    timestamp: DateTime<Utc>,\n    99→    run_id: &RunId,\n   100→    first_stage: StageId,\n   101→) -> JournalEvent {\n   102→    JournalEvent {\n   103→        sequence,\n   104→        timestamp,\n   105→        event_type: JournalEventType::RunStarted,\n   106→        details: serde_json::json!({\n   107→            \"run_id\": run_id.as_str(),\n   108→            \"first_stage\": first_stage.as_str(),\n   109→        }),\n   110→    }\n   111→}\n   112→\n   113→/// Build a `stage_entered` journal event.\n   114→pub fn stage_entered_event(\n   115→    sequence: u64,\n   116→    timestamp: DateTime<Utc>,\n   117→    run_id: &RunId,\n   118→    stage_id: StageId,\n   119→    cycle: u32,\n   120→    attempt: u32,\n   121→) -> JournalEvent {\n   122→    JournalEvent {\n   123→        sequence,\n   124→        timestamp,\n   125→        event_type: JournalEventType::StageEntered,\n   126→        details: serde_json::json!({\n   127→            \"run_id\": run_id.as_str(),\n   128→            \"stage_id\": stage_id.as_str(),\n   129→            \"cycle\": cycle,\n   130→            \"attempt\": attempt,\n   131→        }),\n   132→    }\n   133→}\n   134→\n   135→/// Build a `stage_completed` journal event.\n   136→#[allow(clippy::too_many_arguments)]\n   137→pub fn stage_completed_event(\n   138→    sequence: u64,\n   139→    timestamp: DateTime<Utc>,\n   140→    run_id: &RunId,\n   141→    stage_id: StageId,\n   142→    cycle: u32,\n   143→    attempt: u32,\n   144→    payload_id: &str,\n   145→    artifact_id: &str,\n   146→) -> JournalEvent {\n   147→    JournalEvent {\n   148→        sequence,\n   149→        timestamp,\n   150→        event_type: JournalEventType::StageCompleted,\n   151→        details: serde_json::json!({\n   152→            \"run_id\": run_id.as_str(),\n   153→            \"stage_id\": stage_id.as_str(),\n   154→            \"cycle\": cycle,\n   155→            \"attempt\": attempt,\n   156→            \"payload_id\": payload_id,\n   157→            \"artifact_id\": artifact_id,\n   158→        }),\n   159→    }\n   160→}\n   161→\n   162→/// Build a `run_completed` journal event.\n   163→pub fn run_completed_event(\n   164→    sequence: u64,\n   165→    timestamp: DateTime<Utc>,\n   166→    run_id: &RunId,\n   167→    completion_rounds: u32,\n   168→) -> JournalEvent {\n   169→    JournalEvent {\n   170→        sequence,\n   171→        timestamp,\n   172→        event_type: JournalEventType::RunCompleted,\n   173→        details: serde_json::json!({\n   174→            \"run_id\": run_id.as_str(),\n   175→            \"completion_rounds\": completion_rounds,\n   176→        }),\n   177→    }\n   178→}\n   179→\n   180→/// Build a `run_failed` journal event.\n   181→pub fn run_failed_event(\n   182→    sequence: u64,\n   183→    timestamp: DateTime<Utc>,\n   184→    run_id: &RunId,\n   185→    stage_id: StageId,\n   186→    failure_class: &str,\n   187→    message: &str,\n   188→) -> JournalEvent {\n   189→    JournalEvent {\n   190→        sequence,\n   191→        timestamp,\n   192→        event_type: JournalEventType::RunFailed,\n   193→        details: serde_json::json!({\n   194→            \"run_id\": run_id.as_str(),\n   195→            \"stage_id\": stage_id.as_str(),\n   196→            \"failure_class\": failure_class,\n   197→            \"message\": message,\n   198→        }),\n   199→    }\n   200→}\n   201→"}]},"parent_tool_use_id":"toolu_01VwuMdbo4Yfw9qb7NhghzrF","session_id":"19a33b10-b5a0-4ba2-8943-a7efa3e34818","uuid":"a7d7dcac-34ef-442f-8183-5e1ddd8ab574"}
