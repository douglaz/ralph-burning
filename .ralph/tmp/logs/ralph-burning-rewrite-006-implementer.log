at!(\"\\\"{}\\\"\", value.as_str()),\n    53→            Self::String(Some(value)) => format!(\"\\\"{value}\\\"\"),\n    54→            Self::String(None) => \"\\\"<unset>\\\"\".to_owned(),\n    55→        }\n    56→    }\n    57→}\n    58→\n    59→#[derive(Debug, Clone, PartialEq, Eq)]\n    60→pub struct ConfigEntry {\n    61→    pub key: &'static str,\n    62→    pub value: ConfigValue,\n    63→    pub source: ConfigValueSource,\n    64→}\n    65→\n    66→#[derive(Debug, Clone, PartialEq, Eq)]\n    67→struct ResolvedValue<T> {\n    68→    value: T,\n    69→    source: ConfigValueSource,\n    70→}\n    71→\n    72→#[derive(Debug, Clone, PartialEq, Eq)]\n    73→pub struct EffectiveConfig {\n    74→    prompt_review_enabled: ResolvedValue<bool>,\n    75→    default_flow: ResolvedValue<FlowPreset>,\n    76→    default_backend: ResolvedValue<Option<String>>,\n    77→    default_model: ResolvedValue<Option<String>>,\n    78→}\n    79→\n    80→impl EffectiveConfig {"}]},"parent_tool_use_id":"toolu_01BNmMHXmrpqphqEoDzMeewD","session_id":"b9859e69-5579-4e82-ac66-49d19cc80e05","uuid":"701a7bdd-431b-4a90-9463-6bf31b4cddf2"}
