{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01QkMpBe8qtkYw1EZ7eqJR5N","type":"tool_result","content":"     1→use std::path::Path;\n     2→\n     3→use chrono::{TimeZone, Utc};\n     4→\n     5→use ralph_burning::contexts::project_run_record::model::*;\n     6→use ralph_burning::contexts::project_run_record::service::*;\n     7→use ralph_burning::shared::domain::{FlowPreset, ProjectId};\n     8→use ralph_burning::shared::error::{AppError, AppResult};\n     9→\n    10→// ── Fake implementations of ports for service-level testing ──\n    11→\n    12→struct FakeProjectStore {\n    13→    existing_ids: Vec<String>,\n    14→}\n    15→\n    16→impl FakeProjectStore {\n    17→    fn empty() -> Self {\n    18→        Self {\n    19→            existing_ids: Vec::new(),\n    20→        }\n    21→    }\n    22→\n    23→    fn with_existing(ids: &[&str]) -> Self {\n    24→        Self {\n    25→            existing_ids: ids.iter().map(|s| s.to_string()).collect(),\n    26→        }\n    27→    }\n    28→}\n    29→\n    30→impl ProjectStorePort for FakeProjectStore {\n    31→    fn project_exists(&self, _base_dir: &Path, project_id: &ProjectId) -> AppResult<bool> {\n    32→        Ok(self.existing_ids.contains(&project_id.to_string()))\n    33→    }\n    34→\n    35→    fn read_project_record(\n    36→        &self,\n    37→        _base_dir: &Path,\n    38→        project_id: &ProjectId,\n    39→    ) -> AppResult<ProjectRecord> {\n    40→        if !self.existing_ids.contains(&project_id.to_string()) {\n    41→            return Err(AppError::ProjectNotFound {\n    42→                project_id: project_id.to_string(),\n    43→            });\n    44→        }\n    45→        Ok(make_project_record(project_id.as_str()))\n    46→    }\n    47→\n    48→    fn list_project_ids(&self, _base_dir: &Path) -> AppResult<Vec<ProjectId>> {\n    49→        self.existing_ids\n    50→            .iter()\n    51→            .map(|id| ProjectId::new(id.as_str()))\n    52→            .collect()\n    53→    }\n    54→\n    55→    fn stage_delete(&self, _base_dir: &Path, project_id: &ProjectId) -> AppResult<()> {\n    56→        if !self.existing_ids.contains(&project_id.to_string()) {\n    57→            return Err(AppError::ProjectNotFound {\n    58→                project_id: project_id.to_string(),\n    59→            });\n    60→        }\n    61→        Ok(())\n    62→    }\n    63→\n    64→    fn commit_delete(&self, _base_dir: &Path, _project_id: &ProjectId) -> AppResult<()> {\n    65→        Ok(())\n    66→    }\n    67→\n    68→    fn rollback_delete(&self, _base_dir: &Path, _project_id: &ProjectId) -> AppResult<()> {\n    69→        Ok(())\n    70→    }\n    71→\n    72→    fn create_project_atomic(\n    73→        &self,\n    74→        _base_dir: &Path,\n    75→        _record: &ProjectRecord,\n    76→        _prompt_contents: &str,\n    77→        _run_snapshot: &RunSnapshot,\n    78→        _initial_journal_line: &str,\n    79→        _sessions: &SessionStore,\n    80→    ) -> AppResult<()> {\n    81→        Ok(())\n    82→    }\n    83→}\n    84→\n    85→struct FakeJournalStore;\n    86→\n    87→impl JournalStorePort for FakeJournalStore {\n    88→    fn read_journal(\n    89→        &self,\n    90→        _base_dir: &Path,\n    91→        _project_id: &ProjectId,\n    92→    ) -> AppResult<Vec<JournalEvent>> {\n    93→        Ok(vec![make_project_created_event()])\n    94→    }\n    95→\n    96→    fn append_event(\n    97→        &self,\n    98→        _base_dir: &Path,\n    99→        _project_id: &ProjectId,\n   100→        _line: &str,\n   101→    ) -> AppResult<()> {\n   102→        Ok(())\n   103→    }\n   104→}\n   105→\n   106→struct FakeRunSnapshotStore {\n   107→    has_active_run: bool,\n   108→}\n   109→\n   110→impl FakeRunSnapshotStore {\n   111→    fn no_run() -> Self {\n   112→        Self {\n   113→            has_active_run: false,\n   114→        }\n   115→    }\n   116→\n   117→    fn active_run() -> Self {\n   118→        Self {\n   119→            has_active_run: true,\n   120→        }\n   121→    }\n   122→}\n   123→\n   124→impl RunSnapshotPort for FakeRunSnapshotStore {\n   125→    fn read_run_snapshot(\n   126→        &self,\n   127→        _base_dir: &Path,\n   128→        _project_id: &ProjectId,\n   129→    ) -> AppResult<RunSnapshot> {\n   130→        if self.has_active_run {\n   131→            Ok(RunSnapshot {\n   132→                active_run: Some(ActiveRun {\n   133→                    run_id: \"run-1\".to_owned(),\n   134→                    stage_cursor: ralph_burning::shared::domain::StageCursor::initial(\n   135→                        ralph_burning::shared::domain::StageId::Planning,\n   136→                    ),\n   137→                    started_at: test_timestamp(),\n   138→                }),\n   139→                status: RunStatus::Running,\n   140→                cycle_history: Vec::new(),\n   141→                completion_rounds: 0,\n   142→                rollback_point_meta: RollbackPointMeta::default(),\n   143→                amendment_queue: AmendmentQueueState::default(),\n   144→                status_summary: \"running\".to_owned(),\n   145→            })\n   146→        } else {\n   147→            Ok(RunSnapshot::initial())\n   148→        }\n   149→    }\n   150→}\n   151→\n   152→struct FakeActiveProjectStore {\n   153→    active_id: Option<String>,\n   154→}\n   155→\n   156→impl FakeActiveProjectStore {\n   157→    fn none() -> Self {\n   158→        Self { active_id: None }\n   159→    }\n   160→\n   161→    fn with_active(id: &str) -> Self {\n   162→        Self {\n   163→            active_id: Some(id.to_owned()),\n   164→        }\n   165→    }\n   166→}\n   167→\n   168→impl ActiveProjectPort for FakeActiveProjectStore {\n   169→    fn read_active_project_id(&self, _base_dir: &Path) -> AppResult<Option<String>> {\n   170→        Ok(self.active_id.clone())\n   171→    }\n   172→\n   173→    fn clear_active_project(&self, _base_dir: &Path) -> AppResult<()> {\n   174→        Ok(())\n   175→    }\n   176→\n   177→    fn write_active_project(&self, _base_dir: &Path, _project_id: &ProjectId) -> AppResult<()> {\n   178→        Ok(())\n   179→    }\n   180→}\n   181→\n   182→// ── Helpers ──\n   183→\n   184→fn test_timestamp() -> chrono::DateTime<Utc> {\n   185→    Utc.with_ymd_and_hms(2026, 3, 11, 19, 0, 0)\n   186→        .single()\n   187→        .expect(\"valid timestamp\")\n   188→}\n   189→\n   190→fn make_project_record(id: &str) -> ProjectRecord {\n   191→    ProjectRecord {\n   192→        id: ProjectId::new(id).unwrap(),\n   193→        name: format!(\"Project {id}\"),\n   194→        flow: FlowPreset::Standard,\n   195→        prompt_reference: \"prompt.md\".to_owned(),\n   196→        prompt_hash: \"abc123\".to_owned(),\n   197→        created_at: test_timestamp(),\n   198→        status_summary: ProjectStatusSummary::Created,\n   199→    }\n   200→}\n   201→\n   202→fn make_project_created_event() -> JournalEvent {\n   203→    JournalEvent {\n   204→        sequence: 1,\n   205→        timestamp: test_timestamp(),\n   206→        event_type: JournalEventType::ProjectCreated,\n   207→        details: serde_json::json!({\"project_id\": \"alpha\", \"flow\": \"standard\"}),\n   208→    }\n   209→}\n   210→\n   211→fn dummy_base_dir() -> std::path::PathBuf {\n   212→    std::path::PathBuf::from(\"/tmp/test\")\n   213→}\n   214→\n   215→// ── Domain Tests ──\n   216→\n   217→#[test]\n   218→fn run_snapshot_initial_has_no_active_run() {\n   219→    let snapshot = RunSnapshot::initial();\n   220→    assert!(!snapshot.has_active_run());\n   221→    assert_eq!(snapshot.status, RunStatus::NotStarted);\n   222→}\n   223→\n   224→#[test]\n   225→fn session_store_empty_has_no_sessions() {\n   226→    let store = SessionStore::empty();\n   227→    assert!(store.sessions.is_empty());\n   228→}\n   229→\n   230→#[test]\n   231→fn project_record_flow_is_immutable_after_creation() {\n   232→    let record = make_project_record(\"alpha\");\n   233→    assert_eq!(record.flow, FlowPreset::Standard);\n   234→    // Flow is a plain field with no setter — immutability enforced by\n   235→    // not providing mutation methods on ProjectRecord.\n   236→}\n   237→\n   238→#[test]\n   239→fn journal_event_types_serialize_to_snake_case() {\n   240→    let event = make_project_created_event();\n   241→    let json = serde_json::to_string(&event).expect(\"serialize\");\n   242→    assert!(json.contains(\"\\\"project_created\\\"\"));\n   243→}\n   244→\n   245→// ── Service Tests with Fake Ports ──\n   246→\n   247→#[test]\n   248→fn create_project_succeeds_with_valid_input() {\n   249→    let store = FakeProjectStore::empty();\n   250→    let journal_store = FakeJournalStore;\n   251→    let base_dir = dummy_base_dir();\n   252→\n   253→    let input = CreateProjectInput {\n   254→        id: ProjectId::new(\"alpha\").unwrap(),\n   255→        name: \"Alpha Project\".to_owned(),\n   256→        flow: FlowPreset::Standard,\n   257→        prompt_path: \"prompt.md\".to_owned(),\n   258→        prompt_contents: \"# My prompt\\nDo something.\".to_owned(),\n   259→        prompt_hash: \"hash123\".to_owned(),\n   260→        created_at: test_timestamp(),\n   261→    };\n   262→\n   263→    let result = create_project(&store, &journal_store, &base_dir, input);\n   264→    assert!(result.is_ok());\n   265→\n   266→    let record = result.unwrap();\n   267→    assert_eq!(record.id.as_str(), \"alpha\");\n   268→    assert_eq!(record.flow, FlowPreset::Standard);\n   269→    assert_eq!(record.status_summary, ProjectStatusSummary::Created);\n   270→}\n   271→\n   272→#[test]\n   273→fn create_project_fails_on_duplicate_id() {\n   274→    let store = FakeProjectStore::with_existing(&[\"alpha\"]);\n   275→    let journal_store = FakeJournalStore;\n   276→    let base_dir = dummy_base_dir();\n   277→\n   278→    let input = CreateProjectInput {\n   279→        id: ProjectId::new(\"alpha\").unwrap(),\n   280→        name: \"Alpha Again\".to_owned(),\n   281→        flow: FlowPreset::Standard,\n   282→        prompt_path: \"prompt.md\".to_owned(),\n   283→        prompt_contents: \"content\".to_owned(),\n   284→        prompt_hash: \"hash\".to_owned(),\n   285→        created_at: test_timestamp(),\n   286→    };\n   287→\n   288→    let result = create_project(&store, &journal_store, &base_dir, input);\n   289→    assert!(result.is_err());\n   290→    assert!(matches!(\n   291→        result.unwrap_err(),\n   292→        AppError::DuplicateProject { .. }\n   293→    ));\n   294→}\n   295→\n   296→#[test]\n   297→fn list_projects_returns_entries_with_active_flag() {\n   298→    let store = FakeProjectStore::with_existing(&[\"alpha\", \"beta\"]);\n   299→    let active_store = FakeActiveProjectStore::with_active(\"alpha\");\n   300→    let base_dir = dummy_base_dir();\n   301→\n   302→    let entries = list_projects(&store, &active_store, &base_dir).unwrap();\n   303→    assert_eq!(entries.len(), 2);\n   304→\n   305→    let alpha = entries.iter().find(|e| e.id.as_str() == \"alpha\").unwrap();\n   306→    assert!(alpha.is_active);\n   307→\n   308→    let beta = entries.iter().find(|e| e.id.as_str() == \"beta\").unwrap();\n   309→    assert!(!beta.is_active);\n   310→}\n   311→\n   312→#[test]\n   313→fn list_projects_with_no_active_project() {\n   314→    let store = FakeProjectStore::with_existing(&[\"alpha\"]);\n   315→    let active_store = FakeActiveProjectStore::none();\n   316→    let base_dir = dummy_base_dir();\n   317→\n   318→    let entries = list_projects(&store, &active_store, &base_dir).unwrap();\n   319→    assert_eq!(entries.len(), 1);\n   320→    assert!(!entries[0].is_active);\n   321→}\n   322→\n   323→#[test]\n   324→fn show_project_returns_detail() {\n   325→    let store = FakeProjectStore::with_existing(&[\"alpha\"]);\n   326→    let run_store = FakeRunSnapshotStore::no_run();\n   327→    let journal_store = FakeJournalStore;\n   328→    let active_store = FakeActiveProjectStore::with_active(\"alpha\");\n   329→    let base_dir = dummy_base_dir();\n   330→    let pid = ProjectId::new(\"alpha\").unwrap();\n   331→\n   332→    let detail = show_project(\n   333→        &store,\n   334→        &run_store,\n   335→        &journal_store,\n   336→        &active_store,\n   337→        &base_dir,\n   338→        &pid,\n   339→    )\n   340→    .unwrap();\n   341→\n   342→    assert_eq!(detail.record.id.as_str(), \"alpha\");\n   343→    assert!(detail.is_active);\n   344→    assert_eq!(detail.journal_event_count, 1);\n   345→    assert!(!detail.run_snapshot.has_active_run());\n   346→}\n   347→\n   348→#[test]\n   349→fn show_project_fails_for_missing_project() {\n   350→    let store = FakeProjectStore::empty();\n   351→    let run_store = FakeRunSnapshotStore::no_run();\n   352→    let journal_store = FakeJournalStore;\n   353→    let active_store = FakeActiveProjectStore::none();\n   354→    let base_dir = dummy_base_dir();\n   355→    let pid = ProjectId::new(\"missing\").unwrap();\n   356→\n   357→    let result = show_project(\n   358→        &store,\n   359→        &run_store,\n   360→        &journal_store,\n   361→        &active_store,\n   362→        &base_dir,\n   363→        &pid,\n   364→    );\n   365→    assert!(matches!(\n   366→        result.unwrap_err(),\n   367→        AppError::ProjectNotFound { .. }\n   368→    ));\n   369→}\n   370→\n   371→#[test]\n   372→fn delete_project_succeeds_when_no_active_run() {\n   373→    let store = FakeProjectStore::with_existing(&[\"alpha\"]);\n   374→    let run_store = FakeRunSnapshotStore::no_run();\n   375→    let active_store = FakeActiveProjectStore::none();\n   376→    let base_dir = dummy_base_dir();\n   377→    let pid = ProjectId::new(\"alpha\").unwrap();\n   378→\n   379→    let result = delete_project(&store, &run_store, &active_store, &base_dir, &pid);\n   380→    assert!(result.is_ok());\n   381→}\n   382→\n   383→#[test]\n   384→fn delete_project_fails_with_active_run() {\n   385→    let store = FakeProjectStore::with_existing(&[\"alpha\"]);\n   386→    let run_store = FakeRunSnapshotStore::active_run();\n   387→    let active_store = FakeActiveProjectStore::none();\n   388→    let base_dir = dummy_base_dir();\n   389→    let pid = ProjectId::new(\"alpha\").unwrap();\n   390→\n   391→    let result = delete_project(&store, &run_store, &active_store, &base_dir, &pid);\n   392→    assert!(matches!(\n   393→        result.unwrap_err(),\n   394→        AppError::ActiveRunDelete { .. }\n   395→    ));\n   396→}\n   397→\n   398→#[test]\n   399→fn delete_project_fails_for_missing_project() {\n   400→    let store = FakeProjectStore::empty();\n   401→    let run_store = FakeRunSnapshotStore::no_run();\n   402→    let active_store = FakeActiveProjectStore::none();\n   403→    let base_dir = dummy_base_dir();\n   404→    let pid = ProjectId::new(\"missing\").unwrap();\n   405→\n   406→    let result = delete_project(&store, &run_store, &active_store, &base_dir, &pid);\n   407→    assert!(matches!(\n   408→        result.unwrap_err(),\n   409→        AppError::ProjectNotFound { .. }\n   410→    ));\n   411→}\n   412→\n   413→#[test]\n   414→fn run_status_reports_not_started_when_no_active_run() {\n   415→    let run_store = FakeRunSnapshotStore::no_run();\n   416→    let base_dir = dummy_base_dir();\n   417→    let pid = ProjectId::new(\"alpha\").unwrap();\n   418→\n   419→    let status = run_status(&run_store, &base_dir, &pid).unwrap();\n   420→    assert_eq!(status.status, \"not started\");\n   421→    assert!(status.stage.is_none());\n   422→    assert!(status.cycle.is_none());\n   423→}\n   424→\n   425→#[test]\n   426→fn run_status_reports_running_with_stage_cursor() {\n   427→    let run_store = FakeRunSnapshotStore::active_run();\n   428→    let base_dir = dummy_base_dir();\n   429→    let pid = ProjectId::new(\"alpha\").unwrap();\n   430→\n   431→    let status = run_status(&run_store, &base_dir, &pid).unwrap();\n   432→    assert_eq!(status.status, \"running\");\n   433→    assert_eq!(status.stage, Some(\"planning\".to_owned()));\n   434→    assert_eq!(status.cycle, Some(1));\n   435→}\n   436→\n   437→// ── Semantic Validation ──\n   438→\n   439→#[test]\n   440→fn run_snapshot_validates_running_without_active_run_as_corrupt() {\n   441→    let snapshot = RunSnapshot {\n   442→        active_run: None,\n   443→        status: RunStatus::Running,\n   444→        cycle_history: Vec::new(),\n   445→        completion_rounds: 0,\n   446→        rollback_point_meta: RollbackPointMeta::default(),\n   447→        amendment_queue: AmendmentQueueState::default(),\n   448→        status_summary: \"running\".to_owned(),\n   449→    };\n   450→    let result = snapshot.validate_semantics();\n   451→    assert!(result.is_err());\n   452→    assert!(result.unwrap_err().contains(\"running\"));\n   453→}\n   454→\n   455→#[test]\n   456→fn run_snapshot_validates_paused_without_active_run_as_corrupt() {\n   457→    let snapshot = RunSnapshot {\n   458→        active_run: None,\n   459→        status: RunStatus::Paused,\n   460→        cycle_history: Vec::new(),\n   461→        completion_rounds: 0,\n   462→        rollback_point_meta: RollbackPointMeta::default(),\n   463→        amendment_queue: AmendmentQueueState::default(),\n   464→        status_summary: \"paused\".to_owned(),\n   465→    };\n   466→    let result = snapshot.validate_semantics();\n   467→    assert!(result.is_err());\n   468→    assert!(result.unwrap_err().contains(\"paused\"));\n   469→}\n   470→\n   471→#[test]\n   472→fn run_snapshot_validates_not_started_with_active_run_as_corrupt() {\n   473→    let snapshot = RunSnapshot {\n   474→        active_run: Some(ActiveRun {\n   475→            run_id: \"run-1\".to_owned(),\n   476→            stage_cursor: ralph_burning::shared::domain::StageCursor::initial(\n   477→                ralph_burning::shared::domain::StageId::Planning,\n   478→            ),\n   479→            started_at: test_timestamp(),\n   480→        }),\n   481→        status: RunStatus::NotStarted,\n   482→        cycle_history: Vec::new(),\n   483→        completion_rounds: 0,\n   484→        rollback_point_meta: RollbackPointMeta::default(),\n   485→        amendment_queue: AmendmentQueueState::default(),\n   486→        status_summary: \"not started\".to_owned(),\n   487→    };\n   488→    let result = snapshot.validate_semantics();\n   489→    assert!(result.is_err());\n   490→    assert!(result.unwrap_err().contains(\"not_started\"));\n   491→}\n   492→\n   493→#[test]\n   494→fn run_snapshot_validates_completed_without_active_run_as_valid() {\n   495→    let snapshot = RunSnapshot {\n   496→        active_run: None,\n   497→        status: RunStatus::Completed,\n   498→        cycle_history: Vec::new(),\n   499→        completion_rounds: 3,\n   500→        rollback_point_meta: RollbackPointMeta::default(),\n   501→        amendment_queue: AmendmentQueueState::default(),\n   502→        status_summary: \"completed\".to_owned(),\n   503→    };\n   504→    assert!(snapshot.validate_semantics().is_ok());\n   505→}\n   506→\n   507→#[test]\n   508→fn run_snapshot_validates_failed_without_active_run_as_valid() {\n   509→    let snapshot = RunSnapshot {\n   510→        active_run: None,\n   511→        status: RunStatus::Failed,\n   512→        cycle_history: Vec::new(),\n   513→        completion_rounds: 0,\n   514→        rollback_point_meta: RollbackPointMeta::default(),\n   515→        amendment_queue: AmendmentQueueState::default(),\n   516→        status_summary: \"failed\".to_owned(),\n   517→    };\n   518→    assert!(snapshot.validate_semantics().is_ok());\n   519→}\n   520→\n   521→// ── Terminal State Run Status Reporting ──\n   522→\n   523→struct FakeTerminalRunSnapshotStore {\n   524→    status: RunStatus,\n   525→    summary: String,\n   526→}\n   527→\n   528→impl RunSnapshotPort for FakeTerminalRunSnapshotStore {\n   529→    fn read_run_snapshot(\n   530→        &self,\n   531→        _base_dir: &Path,\n   532→        _project_id: &ProjectId,\n   533→    ) -> AppResult<RunSnapshot> {\n   534→        Ok(RunSnapshot {\n   535→            active_run: None,\n   536→            status: self.status,\n   537→            cycle_history: Vec::new(),\n   538→            completion_rounds: 0,\n   539→            rollback_point_meta: RollbackPointMeta::default(),\n   540→            amendment_queue: AmendmentQueueState::default(),\n   541→            status_summary: self.summary.clone(),\n   542→        })\n   543→    }\n   544→}\n   545→\n   546→#[test]\n   547→fn run_status_reports_completed_for_terminal_snapshot() {\n   548→    let run_store = FakeTerminalRunSnapshotStore {\n   549→        status: RunStatus::Completed,\n   550→        summary: \"done\".to_owned(),\n   551→    };\n   552→    let base_dir = dummy_base_dir();\n   553→    let pid = ProjectId::new(\"alpha\").unwrap();\n   554→\n   555→    let status = run_status(&run_store, &base_dir, &pid).unwrap();\n   556→    assert_eq!(status.status, \"completed\");\n   557→}\n   558→\n   559→#[test]\n   560→fn run_status_reports_failed_for_terminal_snapshot() {\n   561→    let run_store = FakeTerminalRunSnapshotStore {\n   562→        status: RunStatus::Failed,\n   563→        summary: \"error\".to_owned(),\n   564→    };\n   565→    let base_dir = dummy_base_dir();\n   566→    let pid = ProjectId::new(\"alpha\").unwrap();\n   567→\n   568→    let status = run_status(&run_store, &base_dir, &pid).unwrap();\n   569→    assert_eq!(status.status, \"failed\");\n   570→}\n   571→\n   572→#[test]\n   573→fn delete_project_does_not_touch_pointer_on_stage_failure() {\n   574→    use std::cell::Cell;\n   575→\n   576→    struct FailingStageStore {\n   577→        existing_ids: Vec<String>,\n   578→    }\n   579→\n   580→    impl ProjectStorePort for FailingStageStore {\n   581→        fn project_exists(&self, _base_dir: &Path, project_id: &ProjectId) -> AppResult<bool> {\n   582→            Ok(self.existing_ids.contains(&project_id.to_string()))\n   583→        }\n   584→\n   585→        fn read_project_record(\n   586→            &self,\n   587→            _base_dir: &Path,\n   588→            project_id: &ProjectId,\n   589→        ) -> AppResult<ProjectRecord> {\n   590→            Ok(make_project_record(project_id.as_str()))\n   591→        }\n   592→\n   593→        fn list_project_ids(&self, _base_dir: &Path) -> AppResult<Vec<ProjectId>> {\n   594→            self.existing_ids.iter().map(ProjectId::new).collect()\n   595→        }\n   596→\n   597→        fn stage_delete(&self, _base_dir: &Path, _project_id: &ProjectId) -> AppResult<()> {\n   598→            Err(AppError::Io(std::io::Error::new(\n   599→                std::io::ErrorKind::PermissionDenied,\n   600→                \"simulated stage failure\",\n   601→            )))\n   602→        }\n   603→\n   604→        fn commit_delete(&self, _base_dir: &Path, _project_id: &ProjectId) -> AppResult<()> {\n   605→            Ok(())\n   606→        }\n   607→\n   608→        fn rollback_delete(&self, _base_dir: &Path, _project_id: &ProjectId) -> AppResult<()> {\n   609→            Ok(())\n   610→        }\n   611→\n   612→        fn create_project_atomic(\n   613→            &self,\n   614→            _base_dir: &Path,\n   615→            _record: &ProjectRecord,\n   616→            _prompt_contents: &str,\n   617→            _run_snapshot: &RunSnapshot,\n   618→            _initial_journal_line: &str,\n   619→            _sessions: &SessionStore,\n   620→        ) -> AppResult<()> {\n   621→            Ok(())\n   622→        }\n   623→    }\n   624→\n   625→    struct TrackingActiveStore {\n   626→        active_id: Option<String>,\n   627→        clear_called: Cell<bool>,\n   628→        write_called: Cell<bool>,\n   629→    }\n   630→\n   631→    impl ActiveProjectPort for TrackingActiveStore {\n   632→        fn read_active_project_id(&self, _base_dir: &Path) -> AppResult<Option<String>> {\n   633→            Ok(self.active_id.clone())\n   634→        }\n   635→\n   636→        fn clear_active_project(&self, _base_dir: &Path) -> AppResult<()> {\n   637→            self.clear_called.set(true);\n   638→            Ok(())\n   639→        }\n   640→\n   641→        fn write_active_project(&self, _base_dir: &Path, _project_id: &ProjectId) -> AppResult<()> {\n   642→            self.write_called.set(true);\n   643→            Ok(())\n   644→        }\n   645→    }\n   646→\n   647→    let store = FailingStageStore {\n   648→        existing_ids: vec![\"alpha\".to_owned()],\n   649→    };\n   650→    let run_store = FakeRunSnapshotStore::no_run();\n   651→    let active_store = TrackingActiveStore {\n   652→        active_id: Some(\"alpha\".to_owned()),\n   653→        clear_called: Cell::new(false),\n   654→        write_called: Cell::new(false),\n   655→    };\n   656→    let base_dir = dummy_base_dir();\n   657→    let pid = ProjectId::new(\"alpha\").unwrap();\n   658→\n   659→    let result = delete_project(&store, &run_store, &active_store, &base_dir, &pid);\n   660→    assert!(result.is_err(), \"delete should fail\");\n   661→    // The pointer must never be cleared or written when stage fails —\n   662→    // the project remains fully addressable with the original pointer.\n   663→    assert!(\n   664→        !active_store.clear_called.get(),\n   665→        \"clear_active_project must not be called when stage fails\"\n   666→    );\n   667→    assert!(\n   668→        !active_store.write_called.get(),\n   669→        \"write_active_project must not be called when stage fails\"\n   670→    );\n   671→}\n   672→\n   673→#[test]\n   674→fn delete_project_rolls_back_on_clear_pointer_failure() {\n   675→    use std::cell::Cell;\n   676→\n   677→    struct TrackingDeleteStore {\n   678→        existing_ids: Vec<String>,\n   679→        rollback_called: Cell<bool>,\n   680→    }\n   681→\n   682→    impl ProjectStorePort for TrackingDeleteStore {\n   683→        fn project_exists(&self, _base_dir: &Path, project_id: &ProjectId) -> AppResult<bool> {\n   684→            Ok(self.existing_ids.contains(&project_id.to_string()))\n   685→        }\n   686→\n   687→        fn read_project_record(\n   688→            &self,\n   689→            _base_dir: &Path,\n   690→            project_id: &ProjectId,\n   691→        ) -> AppResult<ProjectRecord> {\n   692→            Ok(make_project_record(project_id.as_str()))\n   693→        }\n   694→\n   695→        fn list_project_ids(&self, _base_dir: &Path) -> AppResult<Vec<ProjectId>> {\n   696→            self.existing_ids.iter().map(ProjectId::new).collect()\n   697→        }\n   698→\n   699→        fn stage_delete(&self, _base_dir: &Path, _project_id: &ProjectId) -> AppResult<()> {\n   700→            Ok(())\n   701→        }\n   702→\n   703→        fn commit_delete(&self, _base_dir: &Path, _project_id: &ProjectId) -> AppResult<()> {\n   704→            Ok(())\n   705→        }\n   706→\n   707→        fn rollback_delete(&self, _base_dir: &Path, _project_id: &ProjectId) -> AppResult<()> {\n   708→            self.rollback_called.set(true);\n   709→            Ok(())\n   710→        }\n   711→\n   712→        fn create_project_atomic(\n   713→            &self,\n   714→            _base_dir: &Path,\n   715→            _record: &ProjectRecord,\n   716→            _prompt_contents: &str,\n   717→            _run_snapshot: &RunSnapshot,\n   718→            _initial_journal_line: &str,\n   719→            _sessions: &SessionStore,\n   720→        ) -> AppResult<()> {\n   721→            Ok(())\n   722→        }\n   723→    }\n   724→\n   725→    struct FailingClearActiveStore {\n   726→        active_id: Option<String>,\n   727→    }\n   728→\n   729→    impl ActiveProjectPort for FailingClearActiveStore {\n   730→        fn read_active_project_id(&self, _base_dir: &Path) -> AppResult<Option<String>> {\n   731→            Ok(self.active_id.clone())\n   732→        }\n   733→\n   734→        fn clear_active_project(&self, _base_dir: &Path) -> AppResult<()> {\n   735→            Err(AppError::Io(std::io::Error::new(\n   736→                std::io::ErrorKind::PermissionDenied,\n   737→                \"simulated clear failure\",\n   738→            )))\n   739→        }\n   740→\n   741→        fn write_active_project(&self, _base_dir: &Path, _project_id: &ProjectId) -> AppResult<()> {\n   742→            Ok(())\n   743→        }\n   744→    }\n   745→\n   746→    let store = TrackingDeleteStore {\n   747→        existing_ids: vec![\"alpha\".to_owned()],\n   748→        rollback_called: Cell::new(false),\n   749→    };\n   750→    let run_store = FakeRunSnapshotStore::no_run();\n   751→    let active_store = FailingClearActiveStore {\n   752→        active_id: Some(\"alpha\".to_owned()),\n   753→    };\n   754→    let base_dir = dummy_base_dir();\n   755→    let pid = ProjectId::new(\"alpha\").unwrap();\n   756→\n   757→    let result = delete_project(&store, &run_store, &active_store, &base_dir, &pid);\n   758→    // Stage succeeded but pointer clear failed — the project must be\n   759→    // rolled back so it remains addressable.\n   760→    assert!(result.is_err(), \"should propagate clear-pointer failure\");\n   761→    assert!(\n   762→        store.rollback_called.get(),\n   763→        \"rollback_delete must be called when clear_active_project fails\"\n   764→    );\n   765→}\n   766→\n   767→#[test]\n   768→fn delete_project_succeeds_for_completed_terminal_state() {\n   769→    let store = FakeProjectStore::with_existing(&[\"alpha\"]);\n   770→    let run_store = FakeTerminalRunSnapshotStore {\n   771→        status: RunStatus::Completed,\n   772→        summary: \"done\".to_owned(),\n   773→    };\n   774→    let active_store = FakeActiveProjectStore::none();\n   775→    let base_dir = dummy_base_dir();\n   776→    let pid = ProjectId::new(\"alpha\").unwrap();\n   777→\n   778→    let result = delete_project(&store, &run_store, &active_store, &base_dir, &pid);\n   779→    assert!(result.is_ok());\n   780→}\n   781→\n   782→// ── Failed Stage Summary model tests ──\n   783→\n   784→#[test]\n   785→fn failed_stage_summary_serializes_correctly() {\n   786→    let summary = FailedStageSummary {\n   787→        stage_id: ralph_burning::shared::domain::StageId::Qa,\n   788→        cycle: 1,\n   789→        attempt: 1,\n   790→        failure_class: \"QaReviewOutcomeFailure\".to_owned(),\n   791→        message: \"non-passing outcome\".to_owned(),\n   792→        failed_at: test_timestamp(),\n   793→    };\n   794→    let json = serde_json::to_string(&summary).unwrap();\n   795→    assert!(json.contains(\"qa\"));\n   796→    assert!(json.contains(\"QaReviewOutcomeFailure\"));\n   797→\n   798→    let roundtrip: FailedStageSummary = serde_json::from_str(&json).unwrap();\n   799→    assert_eq!(roundtrip.stage_id, ralph_burning::shared::domain::StageId::Qa);\n   800→}\n   801→\n   802→#[test]\n   803→fn run_status_display_matches_display_str() {\n   804→    assert_eq!(format!(\"{}\", RunStatus::NotStarted), \"not started\");\n   805→    assert_eq!(format!(\"{}\", RunStatus::Running), \"running\");\n   806→    assert_eq!(format!(\"{}\", RunStatus::Completed), \"completed\");\n   807→    assert_eq!(format!(\"{}\", RunStatus::Failed), \"failed\");\n   808→    assert_eq!(format!(\"{}\", RunStatus::Paused), \"paused\");\n   809→}\n   810→\n   811→#[test]\n   812→fn run_snapshot_completed_has_no_active_run() {\n   813→    let snapshot = RunSnapshot {\n   814→        active_run: None,\n   815→        status: RunStatus::Completed,\n   816→        cycle_history: Vec::new(),\n   817→        completion_rounds: 1,\n   818→        rollback_point_meta: RollbackPointMeta::default(),\n   819→        amendment_queue: AmendmentQueueState::default(),\n   820→        status_summary: \"completed\".to_owned(),\n   821→    };\n   822→    assert!(snapshot.validate_semantics().is_ok());\n   823→    assert!(!snapshot.has_active_run());\n   824→}\n   825→\n   826→#[test]\n   827→fn run_snapshot_failed_has_no_active_run() {\n   828→    let snapshot = RunSnapshot {\n   829→        active_run: None,\n   830→        status: RunStatus::Failed,\n   831→        cycle_history: Vec::new(),\n   832→        completion_rounds: 0,\n   833→        rollback_point_meta: RollbackPointMeta::default(),\n   834→        amendment_queue: AmendmentQueueState::default(),\n   835→        status_summary: \"failed at QA\".to_owned(),\n   836→    };\n   837→    assert!(snapshot.validate_semantics().is_ok());\n   838→    assert!(!snapshot.has_active_run());\n   839→}\n   840→"}]},"parent_tool_use_id":"toolu_01VwuMdbo4Yfw9qb7NhghzrF","session_id":"19a33b10-b5a0-4ba2-8943-a7efa3e34818","uuid":"ed279188-488f-4c76-bfbc-f7232e9f9d98"}
