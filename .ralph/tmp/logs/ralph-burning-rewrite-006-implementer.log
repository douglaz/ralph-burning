535→        .args([\n   536→            \"project\",\n   537→            \"create\",\n   538→            \"--id\",\n   539→            \"dup\",\n   540→            \"--name\",\n   541→            \"First\",\n   542→            \"--prompt\",\n   543→            prompt.to_str().unwrap(),\n   544→            \"--flow\",\n   545→            \"standard\",\n   546→        ])\n   547→        .current_dir(temp_dir.path())\n   548→        .output()\n   549→        .expect(\"first create\");\n   550→    assert!(first.status.success());\n   551→\n   552→    let second = Command::new(binary())\n   553→        .args([\n   554→            \"project\",\n   555→            \"create\",\n   556→            \"--id\",\n   557→            \"dup\",\n   558→            \"--name\",\n   559→            \"Second\",\n   560→            \"--prompt\",\n   561→            prompt.to_str().unwrap(),\n   562→            \"--flow\",\n   563→            \"standard\",\n   564→        ])\n   565→        .current_dir(temp_dir.path())\n   566→        .output()\n   567→        .expect(\"second create\");\n   568→\n   569→    assert!(!second.status.success());\n   570→    let stderr = String::from_utf8_lossy(&second.stderr);\n   571→    assert!(stderr.contains(\"already exists\"));\n   572→}\n   573→\n   574→#[test]\n   575→fn project_create_fails_on_invalid_flow() {\n   576→    let temp_dir = initialize_workspace_fixture();\n   577→    let prompt = write_prompt_fixture(temp_dir.path());\n   578→\n   579→    let output = Command::new(binary())\n   580→        .args([\n   581→            \"project\",\n   582→            \"create\",\n   583→            \"--id\",\n   584→            \"bad-flow\",\n   585→            \"--name\",\n   586→            \"Bad Flow\",\n   587→            \"--prompt\",\n   588→            prompt.to_str().unwrap(),\n   589→            \"--flow\",\n   590→            \"nonexistent\",\n   591→        ])\n   592→        .current_dir(temp_dir.path())\n   593→        .output()\n   594→    