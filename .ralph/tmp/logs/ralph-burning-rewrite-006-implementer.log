codex\",\n    56→            Self::OpenRouter => \"openai/gpt-5\",\n    57→            Self::Stub => \"stub-default\",\n    58→        }\n    59→    }\n    60→}\n    61→\n    62→impl fmt::Display for BackendFamily {\n    63→    fn fmt(&self, f: &mut fmt::Formatter<'_>) -> fmt::Result {\n    64→        f.write_str(self.as_str())\n    65→    }\n    66→}\n    67→\n    68→impl FromStr for BackendFamily {\n    69→    type Err = AppError;\n    70→\n    71→    fn from_str(value: &str) -> Result<Self, Self::Err> {\n    72→        match value {\n    73→            \"claude\" => Ok(Self::Claude),\n    74→            \"codex\" => Ok(Self::Codex),\n    75→            \"openrouter\" => Ok(Self::OpenRouter),\n    76→            \"stub\" => Ok(Self::Stub),\n    77→            _ => Err(AppError::InvalidConfigValue {\n    78→                key: \"backend\".to_owned(),\n    79→                value: value.to_owned(),\n    80→                reason: \"expected one of claude, codex, openrouter, stub\".to_owned(),\n    81→            }),\n    82→        }\n    83→    }\n    84→}\n    85→\n    86→#[derive(Debug, Clone, PartialEq, Eq, Serialize, Deserialize)]\n    87→pub struct CapabilityMetadata {\n    88→    pub supports_structured_output: bool,\n    89→    pub supports_session_reuse: bool,\n    90→    pub supports_cancellation: bool,\n    91→    pub supported_stages: Vec<StageId>,\n    92→}\n    93→\n    94→impl CapabilityMetadata {\n    95→    pub fn for_all_stages(supports_session_reuse: bool, supports_cancellation: bool) -> Self {\n    96→        Self {\n    97→            supports_structured_output: true,\n    98→            supports_session_reuse,\n    99→            supports_cancellation,\n   100→            supported_stages: StageId::ALL.to_vec(),\n   101→        }\n   102→    }\n   103→\n   104→    pub fn supports_stage(&self, stage_id: StageId) -> bool {\n   105→        self.supported_stages.contains(&stage_id)\n   106→    }\n   107→}\n   108→\n   109→#[derive(Debug, Clone, PartialEq, Eq, Serialize, Deserialize)]\n   110→pub struct BackendSpec {\n   111→    pub family: BackendFamily,\n   112→    pub display_name: String,\n   113→    pub capabilities: CapabilityMetadata,\n   114→}\n   115→\n   116→impl BackendSpec {\n   117→    pub fn from_family(family: BackendFamily) -> Self {\n   118→        let supports_session_reuse = !matches!(family, BackendFamily::OpenRouter);\n   119→        Self {\n   120→            family,\n   121→            display_name: family.display_name().to_owned(),\n   122→            capabilities: CapabilityMetadata::for_all_stages(supports_session_reuse, true),\n   123→        }\n   124→    }\n   125→}\n   126→\n   127→impl fmt::Display for BackendSpec {\n   128→    fn fmt(&self, f: &mut fmt::Formatter<'_>) -> fmt::Result {\n   129→        f.write_str(&self.display_name)\n   130→    }\n   131→}\n   132→\n   133→#[derive(Debug, Clone, PartialEq, Eq, Serialize, Deserialize)]\n   134→pub struct ModelSpec {\n   135→    pub backend_family: BackendFamily,\n   136→    pub model_id: String,\n   137→    pub display_name: String,\n   138→    pub capabilities: CapabilityMetadata,\n   139→}\n   140→\n   141→impl ModelSpec {\n   142→    pub fn new(backend_family: BackendFamily, model_id: impl Into<String>) -> Self {\n   143→        let model_id = model_id.into();\n   144→        let display_name = format!(\"{} {}\", backend_family.display_name(), model_id);\n   145→        let supports_session_reuse = !matches!(backend_family, BackendFamily::OpenRouter);\n   146→        Self {\n   147→            backend_family,\n   148→            model_id,\n   149→            display_name,\n   150→            capabilities: CapabilityMetadata::for_all_stages(supports_session_reuse, true),\n   151→        }\n   152→    }\n   153→\n   154→    pub fn default_for_backend(backend_family: BackendFamily) -> Self {\n   155→        Self::new(backend_family, backend_family.default_model_id())\n   156→    }\n   157→}\n   158→\n   159→impl fmt::Display for ModelSpec {\n   160→    fn fmt(&self, f: &mut fmt::Formatter<'_>) -> fmt::Result {\n   161→        f.write_str(&self.display_name)\n   162→    }\n   163→}\n   164→\n   165→#[derive(Debug, Clone, PartialEq, Eq, Serialize, Deserialize)]\n   166→pub struct ResolvedBackendTarget {\n   167→    pub backend: BackendSpec,\n   168→    pub model: ModelSpec,\n   169→}\n   170→\n   171→impl ResolvedBackendTarget {\n   172→    pub fn new(backend_family: BackendFamily, model_id: impl Into<String>) -> Self {\n   173→        Self {\n   174→            backend: BackendSpec::from_family(backend_family),\n   175→            model: ModelSpec::new(backend_family, model_id),\n   176→        }\n   177→    }\n   178→\n   179→    pub fn supports_stage(&self, stage_id: StageId) -> bool {\n   180→        self.backend.capabilities.supports_stage(stage_id)\n   181→            && self.model.capabilities.supports_stage(stage_id)\n   182→    }\n   183→\n   184→    pub fn supports_session_reuse(&self) -> bool {\n   185→        self.backend.capabilities.supports_session_reuse\n   186→            && self.model.capabilities.supports_session_reuse\n   187→    }\n   188→}\n   189→\n   190→#[derive(Debug, Clone, Copy, PartialEq, Eq, Hash, Serialize, Deserialize)]\n   191→#[serde(rename_all = \"snake_case\")]\n   192→pub enum BackendRole {\n   193→    Planner,\n   194→    Implementer,\n   195→    Reviewer,\n   196→    QaValidator,\n   197→    CompletionJudge,\n   198→}\n   199→\n   200→impl BackendRole {\n   201→    pub fn as_str(self) -> &'static str {\n   202→        match self {\n   203→            Self::Planner => \"planner\",\n   204→            Self::Implementer => \"implementer\",\n   205→            Self::Reviewer => \"reviewer\",\n   206→            Self::QaValidator => \"qa_validator\",\n   207→            Self::CompletionJudge => \"completion_judge\",\n   208→        }\n   209→    }\n   210→\n   211→    pub fn display_name(self) -> &'static str {\n   212→        match self {\n   213→          