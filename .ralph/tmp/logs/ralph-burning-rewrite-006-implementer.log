{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_014yPoWe7a36xR8vioZNrXvz","type":"tool_result","content":"     1→use std::fs;\n     2→use std::path::Path;\n     3→\n     4→use chrono::Utc;\n     5→use tempfile::tempdir;\n     6→\n     7→use ralph_burning::adapters::fs::{\n     8→    FsJournalStore, FsPayloadArtifactWriteStore, FsProjectStore, FsRawOutputStore,\n     9→    FsRunSnapshotStore, FsRunSnapshotWriteStore, FsRuntimeLogWriteStore, FsSessionStore,\n    10→};\n    11→use ralph_burning::adapters::stub_backend::StubBackendAdapter;\n    12→use ralph_burning::contexts::agent_execution::service::AgentExecutionService;\n    13→use ralph_burning::contexts::project_run_record::model::{\n    14→    JournalEvent, JournalEventType, RunSnapshot, RunStatus,\n    15→};\n    16→use ralph_burning::contexts::project_run_record::service::{\n    17→    self, CreateProjectInput, JournalStorePort, RunSnapshotPort, RunSnapshotWritePort,\n    18→};\n    19→use ralph_burning::shared::error::{AppError, AppResult};\n    20→use ralph_burning::contexts::workflow_composition::engine;\n    21→use ralph_burning::contexts::workspace_governance;\n    22→use ralph_burning::contexts::workspace_governance::config::EffectiveConfig;\n    23→use ralph_burning::shared::domain::{FlowPreset, ProjectId, StageId};\n    24→\n    25→fn setup_workspace(base_dir: &Path) {\n    26→    workspace_governance::initialize_workspace(base_dir, Utc::now()).unwrap();\n    27→}\n    28→\n    29→fn create_standard_project(base_dir: &Path, project_id: &str) -> ProjectId {\n    30→    let pid = ProjectId::new(project_id).unwrap();\n    31→    let store = FsProjectStore;\n    32→    let journal_store = FsJournalStore;\n    33→    service::create_project(\n    34→        &store,\n    35→        &journal_store,\n    36→        base_dir,\n    37→        CreateProjectInput {\n    38→            id: pid.clone(),\n    39→            name: format!(\"Test {}\", project_id),\n    40→            flow: FlowPreset::Standard,\n    41→            prompt_path: \"prompt.md\".to_owned(),\n    42→            prompt_contents: \"# Test prompt\".to_owned(),\n    43→            prompt_hash: \"testhash123\".to_owned(),\n    44→            created_at: Utc::now(),\n    45→        },\n    46→    )\n    47→    .unwrap();\n    48→\n    49→    // Select as active\n    50→    workspace_governance::set_active_project(base_dir, &pid).unwrap();\n    51→    pid\n    52→}\n    53→\n    54→fn build_agent_service(\n    55→) -> AgentExecutionService<StubBackendAdapter, FsRawOutputStore, FsSessionStore> {\n    56→    AgentExecutionService::new(\n    57→        StubBackendAdapter::default(),\n    58→        FsRawOutputStore,\n    59→        FsSessionStore,\n    60→    )\n    61→}\n    62→\n    63→// ── Stage plan tests ────────────────────────────────────────────────────────\n    64→\n    65→#[test]\n    66→fn stage_plan_with_prompt_review_enabled() {\n    67→    let plan = engine::standard_stage_plan(true);\n    68→    assert_eq!(plan.len(), 8);\n    69→    assert_eq!(plan[0], StageId::PromptReview);\n    70→    assert_eq!(plan[1], StageId::Planning);\n    71→    assert_eq!(plan[7], StageId::FinalReview);\n    72→}\n    73→\n    74→#[test]\n    75→fn stage_plan_with_prompt_review_disabled() {\n    76→    let plan = engine::standard_stage_plan(false);\n    77→    assert_eq!(plan.len(), 7);\n    78→    assert_eq!(plan[0], StageId::Planning);\n    79→    assert!(!plan.contains(&StageId::PromptReview));\n    80→}\n    81→\n    82→#[test]\n    83→fn role_mapping_is_deterministic() {\n    84→    use ralph_burning::shared::domain::BackendRole;\n    85→    assert_eq!(engine::role_for_stage(StageId::PromptReview), BackendRole::Planner);\n    86→    assert_eq!(engine::role_for_stage(StageId::Planning), BackendRole::Planner);\n    87→    assert_eq!(engine::role_for_stage(StageId::Implementation), BackendRole::Implementer);\n    88→    assert_eq!(engine::role_for_stage(StageId::Qa), BackendRole::QaValidator);\n    89→    assert_eq!(engine::role_for_stage(StageId::Review), BackendRole::Reviewer);\n    90→    assert_eq!(engine::role_for_stage(StageId::CompletionPanel), BackendRole::CompletionJudge);\n    91→    assert_eq!(engine::role_for_stage(StageId::AcceptanceQa), BackendRole::QaValidator);\n    92→    assert_eq!(engine::role_for_stage(StageId::FinalReview), BackendRole::CompletionJudge);\n    93→}\n    94→\n    95→// ── Happy path tests ────────────────────────────────────────────────────────\n    96→\n    97→#[tokio::test]\n    98→async fn happy_path_standard_run_completes() {\n    99→    let tmp = tempdir().unwrap();\n   100→    let base_dir = tmp.path();\n   101→\n   102→    setup_workspace(base_dir);\n   103→    let pid = create_standard_project(base_dir, \"happy-test\");\n   104→\n   105→    let agent_service = build_agent_service();\n   106→    let config = EffectiveConfig::load(base_dir).unwrap();\n   107→\n   108→    let result = engine::execute_standard_run(\n   109→        &agent_service,\n   110→        &FsRunSnapshotStore,\n   111→        &FsRunSnapshotWriteStore,\n   112→        &FsJournalStore,\n   113→        &FsPayloadArtifactWriteStore,\n   114→        &FsRuntimeLogWriteStore,\n   115→        base_dir,\n   116→        &pid,\n   117→        &config,\n   118→    )\n   119→    .await;\n   120→\n   121→    assert!(result.is_ok(), \"execute_standard_run failed: {:?}\", result.err());\n   122→\n   123→    // Verify final run snapshot\n   124→    let snapshot = FsRunSnapshotStore.read_run_snapshot(base_dir, &pid).unwrap();\n   125→    assert_eq!(snapshot.status, RunStatus::Completed);\n   126→    assert!(snapshot.active_run.is_none());\n   127→    assert_eq!(snapshot.completion_rounds, 1);\n   128→    assert_eq!(snapshot.status_summary, \"completed\");\n   129→\n   130→    // Verify journal events\n   131→    let events = FsJournalStore.read_journal(base_dir, &pid).unwrap();\n   132→    // project_created + run_started + (8 * (stage_entered + stage_completed)) + run_completed\n   133→    // = 1 + 1 + 16 + 1 = 19 events (with prompt_review enabled by default)\n   134→    assert!(events.len() >= 19, \"expected >= 19 events, got {}\", events.len());\n   135→\n   136→    // First event should be project_created, second run_started\n   137→    assert_eq!(events[0].event_type, JournalEventType::ProjectCreated);\n   138→    assert_eq!(events[1].event_type, JournalEventType::RunStarted);\n   139→\n   140→    // Last event should be run_completed\n   141→    assert_eq!(events.last().unwrap().event_type, JournalEventType::RunCompleted);\n   142→\n   143→    // Verify payloads and artifacts were written\n   144→    let payloads_dir = base_dir\n   145→        .join(\".ralph-burning/projects/happy-test/history/payloads\");\n   146→    let artifacts_dir = base_dir\n   147→        .join(\".ralph-burning/projects/happy-test/history/artifacts\");\n   148→    let payload_count = fs::read_dir(&payloads_dir).unwrap().count();\n   149→    let artifact_count = fs::read_dir(&artifacts_dir).unwrap().count();\n   150→    assert_eq!(payload_count, 8, \"expected 8 payloads\");\n   151→    assert_eq!(artifact_count, 8, \"expected 8 artifacts\");\n   152→}\n   153→\n   154→#[tokio::test]\n   155→async fn happy_path_prompt_review_disabled() {\n   156→    let tmp = tempdir().unwrap();\n   157→    let base_dir = tmp.path();\n   158→\n   159→    setup_workspace(base_dir);\n   160→\n   161→    // Disable prompt review in config\n   162→    workspace_governance::config::EffectiveConfig::set(base_dir, \"prompt_review.enabled\", \"false\")\n   163→        .unwrap();\n   164→\n   165→    let pid = create_standard_project(base_dir, \"no-pr-test\");\n   166→\n   167→    let agent_service = build_agent_service();\n   168→    let config = EffectiveConfig::load(base_dir).unwrap();\n   169→    assert!(!config.prompt_review_enabled());\n   170→\n   171→    let result = engine::execute_standard_run(\n   172→        &agent_service,\n   173→        &FsRunSnapshotStore,\n   174→        &FsRunSnapshotWriteStore,\n   175→        &FsJournalStore,\n   176→        &FsPayloadArtifactWriteStore,\n   177→        &FsRuntimeLogWriteStore,\n   178→        base_dir,\n   179→        &pid,\n   180→        &config,\n   181→    )\n   182→    .await;\n   183→\n   184→    assert!(result.is_ok());\n   185→\n   186→    // Verify 7 stages completed (no prompt_review)\n   187→    let payloads_dir = base_dir\n   188→        .join(\".ralph-burning/projects/no-pr-test/history/payloads\");\n   189→    let payload_count = fs::read_dir(&payloads_dir).unwrap().count();\n   190→    assert_eq!(payload_count, 7, \"expected 7 payloads without prompt_review\");\n   191→\n   192→    // Verify no prompt_review stage_entered in journal\n   193→    let events = FsJournalStore.read_journal(base_dir, &pid).unwrap();\n   194→    let pr_events: Vec<_> = events\n   195→        .iter()\n   196→        .filter(|e| {\n   197→            if e.event_type == JournalEventType::StageEntered {\n   198→                e.details.get(\"stage_id\").and_then(|v| v.as_str()) == Some(\"prompt_review\")\n   199→            } else {\n   200→                false\n   201→            }\n   202→        })\n   203→        .collect();\n   204→    assert!(pr_events.is_empty(), \"prompt_review stage should not appear\");\n   205→}\n   206→\n   207→// ── Precondition failure tests ──────────────────────────────────────────────\n   208→\n   209→#[tokio::test]\n   210→async fn run_start_rejects_already_running() {\n   211→    let tmp = tempdir().unwrap();\n   212→    let base_dir = tmp.path();\n   213→\n   214→    setup_workspace(base_dir);\n   215→    let pid = create_standard_project(base_dir, \"running-test\");\n   216→\n   217→    // Manually set status to running\n   218→    let snapshot = RunSnapshot {\n   219→        active_run: Some(ralph_burning::contexts::project_run_record::model::ActiveRun {\n   220→            run_id: \"run-fake\".to_owned(),\n   221→            stage_cursor: ralph_burning::shared::domain::StageCursor::initial(StageId::Planning),\n   222→            started_at: Utc::now(),\n   223→        }),\n   224→        status: RunStatus::Running,\n   225→        cycle_history: vec![],\n   226→        completion_rounds: 0,\n   227→        rollback_point_meta: Default::default(),\n   228→        amendment_queue: Default::default(),\n   229→        status_summary: \"running\".to_owned(),\n   230→    };\n   231→    FsRunSnapshotWriteStore\n   232→        .write_run_snapshot(base_dir, &pid, &snapshot)\n   233→        .unwrap();\n   234→\n   235→    let agent_service = build_agent_service();\n   236→    let config = EffectiveConfig::load(base_dir).unwrap();\n   237→\n   238→    let result = engine::execute_standard_run(\n   239→        &agent_service,\n   240→        &FsRunSnapshotStore,\n   241→        &FsRunSnapshotWriteStore,\n   242→        &FsJournalStore,\n   243→        &FsPayloadArtifactWriteStore,\n   244→        &FsRuntimeLogWriteStore,\n   245→        base_dir,\n   246→        &pid,\n   247→        &config,\n   248→    )\n   249→    .await;\n   250→\n   251→    assert!(result.is_err());\n   252→    let err = result.unwrap_err().to_string();\n   253→    assert!(err.contains(\"not_started\"), \"unexpected error: {}\", err);\n   254→}\n   255→\n   256→#[tokio::test]\n   257→async fn run_start_rejects_completed_project() {\n   258→    let tmp = tempdir().unwrap();\n   259→    let base_dir = tmp.path();\n   260→\n   261→    setup_workspace(base_dir);\n   262→    let pid = create_standard_project(base_dir, \"completed-test\");\n   263→\n   264→    let snapshot = RunSnapshot {\n   265→        active_run: None,\n   266→        status: RunStatus::Completed,\n   267→        cycle_history: vec![],\n   268→        completion_rounds: 1,\n   269→        rollback_point_meta: Default::default(),\n   270→        amendment_queue: Default::default(),\n   271→        status_summary: \"completed\".to_owned(),\n   272→    };\n   273→    FsRunSnapshotWriteStore\n   274→        .write_run_snapshot(base_dir, &pid, &snapshot)\n   275→        .unwrap();\n   276→\n   277→    let agent_service = build_agent_service();\n   278→    let config = EffectiveConfig::load(base_dir).unwrap();\n   279→\n   280→    let result = engine::execute_standard_run(\n   281→        &agent_service,\n   282→        &FsRunSnapshotStore,\n   283→        &FsRunSnapshotWriteStore,\n   284→        &FsJournalStore,\n   285→        &FsPayloadArtifactWriteStore,\n   286→        &FsRuntimeLogWriteStore,\n   287→        base_dir,\n   288→        &pid,\n   289→        &config,\n   290→    )\n   291→    .await;\n   292→\n   293→    assert!(result.is_err());\n   294→}\n   295→\n   296→// ── Preflight failure tests ─────────────────────────────────────────────────\n   297→\n   298→#[tokio::test]\n   299→async fn preflight_failure_leaves_state_unchanged() {\n   300→    let tmp = tempdir().unwrap();\n   301→    let base_dir = tmp.path();\n   302→\n   303→    setup_workspace(base_dir);\n   304→    let pid = create_standard_project(base_dir, \"preflight-test\");\n   305→\n   306→    // Use an unavailable backend to trigger preflight failure\n   307→    let agent_service = AgentExecutionService::new(\n   308→        StubBackendAdapter::default().unavailable(),\n   309→        FsRawOutputStore,\n   310→        FsSessionStore,\n   311→    );\n   312→    let config = EffectiveConfig::load(base_dir).unwrap();\n   313→\n   314→    let result = engine::execute_standard_run(\n   315→        &agent_service,\n   316→        &FsRunSnapshotStore,\n   317→        &FsRunSnapshotWriteStore,\n   318→        &FsJournalStore,\n   319→        &FsPayloadArtifactWriteStore,\n   320→        &FsRuntimeLogWriteStore,\n   321→        base_dir,\n   322→        &pid,\n   323→        &config,\n   324→    )\n   325→    .await;\n   326→\n   327→    assert!(result.is_err());\n   328→\n   329→    // Verify run.json is still not_started\n   330→    let snapshot = FsRunSnapshotStore.read_run_snapshot(base_dir, &pid).unwrap();\n   331→    assert_eq!(snapshot.status, RunStatus::NotStarted);\n   332→    assert!(snapshot.active_run.is_none());\n   333→\n   334→    // Verify journal only has project_created\n   335→    let events = FsJournalStore.read_journal(base_dir, &pid).unwrap();\n   336→    assert_eq!(events.len(), 1);\n   337→    assert_eq!(events[0].event_type, JournalEventType::ProjectCreated);\n   338→\n   339→    // Verify no payloads or artifacts created\n   340→    let payloads_dir = base_dir\n   341→        .join(\".ralph-burning/projects/preflight-test/history/payloads\");\n   342→    let payload_count = fs::read_dir(&payloads_dir).unwrap().count();\n   343→    assert_eq!(payload_count, 0);\n   344→}\n   345→\n   346→// ── Stage plan resolution tests ─────────────────────────────────────────────\n   347→\n   348→#[test]\n   349→fn resolve_stage_plan_produces_correct_targets() {\n   350→    let resolver = ralph_burning::contexts::agent_execution::service::BackendResolver::new();\n   351→    let stages = engine::standard_stage_plan(true);\n   352→    let plan = engine::resolve_stage_plan(&stages, &resolver, None).unwrap();\n   353→\n   354→    assert_eq!(plan.len(), 8);\n   355→    assert_eq!(plan[0].stage_id, StageId::PromptReview);\n   356→    assert_eq!(\n   357→        plan[0].role,\n   358→        ralph_burning::shared::domain::BackendRole::Planner\n   359→    );\n   360→    assert_eq!(plan[2].stage_id, StageId::Implementation);\n   361→    assert_eq!(\n   362→        plan[2].role,\n   363→        ralph_burning::shared::domain::BackendRole::Implementer\n   364→    );\n   365→}\n   366→\n   367→// ── Preflight check unit test ───────────────────────────────────────────────\n   368→\n   369→#[tokio::test]\n   370→async fn preflight_check_succeeds_with_default_stub() {\n   371→    let resolver = ralph_burning::contexts::agent_execution::service::BackendResolver::new();\n   372→    let stages = engine::standard_stage_plan(true);\n   373→    let plan = engine::resolve_stage_plan(&stages, &resolver, None).unwrap();\n   374→\n   375→    let adapter = StubBackendAdapter::default();\n   376→    let result = engine::preflight_check(&adapter, &plan).await;\n   377→    assert!(result.is_ok());\n   378→}\n   379→\n   380→#[tokio::test]\n   381→async fn preflight_check_fails_with_unavailable_backend() {\n   382→    let resolver = ralph_burning::contexts::agent_execution::service::BackendResolver::new();\n   383→    let stages = engine::standard_stage_plan(true);\n   384→    let plan = engine::resolve_stage_plan(&stages, &resolver, None).unwrap();\n   385→\n   386→    let adapter = StubBackendAdapter::default().unavailable();\n   387→    let result = engine::preflight_check(&adapter, &plan).await;\n   388→    assert!(result.is_err());\n   389→}\n   390→\n   391→// ── Failing-port tests: journal-append and snapshot-write errors ─────────\n   392→\n   393→use std::sync::atomic::{AtomicU32, Ordering};\n   394→\n   395→/// A journal store that delegates to `FsJournalStore` but fails on the Nth\n   396→/// append_event call (1-indexed). This lets us test failure at specific\n   397→/// stage-commit boundaries.\n   398→struct FailingJournalStore {\n   399→    call_count: AtomicU32,\n   400→    fail_on_call: u32,\n   401→}\n   402→\n   403→impl FailingJournalStore {\n   404→    fn new(fail_on_call: u32) -> Self {\n   405→        Self {\n   406→            call_count: AtomicU32::new(0),\n   407→            fail_on_call,\n   408→        }\n   409→    }\n   410→}\n   411→\n   412→impl JournalStorePort for FailingJournalStore {\n   413→    fn read_journal(\n   414→        &self,\n   415→        base_dir: &Path,\n   416→        project_id: &ralph_burning::shared::domain::ProjectId,\n   417→    ) -> AppResult<Vec<JournalEvent>> {\n   418→        FsJournalStore.read_journal(base_dir, project_id)\n   419→    }\n   420→\n   421→    fn append_event(\n   422→        &self,\n   423→        base_dir: &Path,\n   424→        project_id: &ralph_burning::shared::domain::ProjectId,\n   425→        line: &str,\n   426→    ) -> AppResult<()> {\n   427→        let n = self.call_count.fetch_add(1, Ordering::SeqCst) + 1;\n   428→        if n == self.fail_on_call {\n   429→            return Err(AppError::Io(std::io::Error::new(\n   430→                std::io::ErrorKind::Other,\n   431→                \"simulated journal append failure\",\n   432→            )));\n   433→        }\n   434→        FsJournalStore.append_event(base_dir, project_id, line)\n   435→    }\n   436→}\n   437→\n   438→/// A snapshot write store that delegates to `FsRunSnapshotWriteStore` but fails\n   439→/// on the Nth write call (1-indexed).\n   440→struct FailingSnapshotWriteStore {\n   441→    call_count: AtomicU32,\n   442→    fail_on_call: u32,\n   443→}\n   444→\n   445→impl FailingSnapshotWriteStore {\n   446→    fn new(fail_on_call: u32) -> Self {\n   447→        Self {\n   448→            call_count: AtomicU32::new(0),\n   449→            fail_on_call,\n   450→        }\n   451→    }\n   452→}\n   453→\n   454→impl RunSnapshotWritePort for FailingSnapshotWriteStore {\n   455→    fn write_run_snapshot(\n   456→        &self,\n   457→        base_dir: &Path,\n   458→        project_id: &ralph_burning::shared::domain::ProjectId,\n   459→        snapshot: &RunSnapshot,\n   460→    ) -> AppResult<()> {\n   461→        let n = self.call_count.fetch_add(1, Ordering::SeqCst) + 1;\n   462→        if n == self.fail_on_call {\n   463→            return Err(AppError::Io(std::io::Error::new(\n   464→                std::io::ErrorKind::Other,\n   465→                \"simulated snapshot write failure\",\n   466→            )));\n   467→        }\n   468→        FsRunSnapshotWriteStore.write_run_snapshot(base_dir, project_id, snapshot)\n   469→    }\n   470→}\n   471→\n   472→/// Journal append failure after payload/artifact write must roll back the\n   473→/// payload/artifact pair so no partial durable history is visible, and the\n   474→/// run must end in failed state.\n   475→#[tokio::test]\n   476→async fn journal_failure_after_payload_rolls_back_and_fails_run() {\n   477→    let tmp = tempdir().unwrap();\n   478→    let base_dir = tmp.path();\n   479→\n   480→    setup_workspace(base_dir);\n   481→    let pid = create_standard_project(base_dir, \"journal-fail\");\n   482→\n   483→    let agent_service = build_agent_service();\n   484→    let config = EffectiveConfig::load(base_dir).unwrap();\n   485→\n   486→    // The engine calls append_event for:\n   487→    //   1: run_started\n   488→    //   2: stage_entered (stage 1)\n   489→    //   3: stage_completed (stage 1) — fail here\n   490→    let failing_journal = FailingJournalStore::new(3);\n   491→\n   492→    let result = engine::execute_standard_run(\n   493→        &agent_service,\n   494→        &FsRunSnapshotStore,\n   495→        &FsRunSnapshotWriteStore,\n   496→        &failing_journal,\n   497→        &FsPayloadArtifactWriteStore,\n   498→        &FsRuntimeLogWriteStore,\n   499→        base_dir,\n   500→        &pid,\n   501→        &config,\n   502→    )\n   503→    .await;\n   504→\n   505→    assert!(result.is_err(), \"run should fail on journal failure\");\n   506→\n   507→    // Run must be in failed state\n   508→    let snapshot = FsRunSnapshotStore.read_run_snapshot(base_dir, &pid).unwrap();\n   509→    assert_eq!(snapshot.status, RunStatus::Failed);\n   510→    assert!(snapshot.active_run.is_none());\n   511→\n   512→    // No payload/artifact should be visible for the first stage since it was\n   513→    // rolled back after journal failure\n   514→    let payloads_dir = base_dir\n   515→        .join(\".ralph-burning/projects/journal-fail/history/payloads\");\n   516→    let payload_count = fs::read_dir(&payloads_dir).unwrap().count();\n   517→    assert_eq!(payload_count, 0, \"payload should have been rolled back\");\n   518→\n   519→    let artifacts_dir = base_dir\n   520→        .join(\".ralph-burning/projects/journal-fail/history/artifacts\");\n   521→    let artifact_count = fs::read_dir(&artifacts_dir).unwrap().count();\n   522→    assert_eq!(artifact_count, 0, \"artifact should have been rolled back\");\n   523→}\n   524→\n   525→/// Snapshot write failure after stage_completed journal should roll back the\n   526→/// payload/artifact pair and mark the run as failed.\n   527→#[tokio::test]\n   528→async fn snapshot_failure_after_stage_completed_rolls_back_and_fails_run() {\n   529→    let tmp = tempdir().unwrap();\n   530→    let base_dir = tmp.path();\n   531→\n   532→    setup_workspace(base_dir);\n   533→    let pid = create_standard_project(base_dir, \"snap-fail\");\n   534→\n   535→    let agent_service = build_agent_service();\n   536→    let config = EffectiveConfig::load(base_dir).unwrap();\n   537→\n   538→    // The engine calls write_run_snapshot for:\n   539→    //   1: initial Running snapshot (run start)\n   540→    //   2: stage_entered cursor update (stage 1)\n   541→    //   3: stage_completed cursor update (stage 1) — fail here\n   542→    let failing_snapshot = FailingSnapshotWriteStore::new(3);\n   543→\n   544→    let result = engine::execute_standard_run(\n   545→        &agent_service,\n   546→        &FsRunSnapshotStore,\n   547→        &failing_snapshot,\n   548→        &FsJournalStore,\n   549→        &FsPayloadArtifactWriteStore,\n   550→        &FsRuntimeLogWriteStore,\n   551→        base_dir,\n   552→        &pid,\n   553→        &config,\n   554→    )\n   555→    .await;\n   556→\n   557→    assert!(result.is_err(), \"run should fail on snapshot failure\");\n   558→\n   559→    // The run must end in failed state. Since the failing store only fails\n   560→    // on call 3, the fail_run recovery can still write the failed snapshot\n   561→    // (calls 4+).\n   562→    let snapshot = FsRunSnapshotStore.read_run_snapshot(base_dir, &pid).unwrap();\n   563→    assert_eq!(snapshot.status, RunStatus::Failed);\n   564→    assert!(snapshot.active_run.is_none());\n   565→\n   566→    // No payload/artifact should be visible for the first stage\n   567→    let payloads_dir = base_dir\n   568→        .join(\".ralph-burning/projects/snap-fail/history/payloads\");\n   569→    let payload_count = fs::read_dir(&payloads_dir).unwrap().count();\n   570→    assert_eq!(payload_count, 0, \"payload should have been rolled back\");\n   571→\n   572→    let artifacts_dir = base_dir\n   573→        .join(\".ralph-burning/projects/snap-fail/history/artifacts\");\n   574→    let artifact_count = fs::read_dir(&artifacts_dir).unwrap().count();\n   575→    assert_eq!(artifact_count, 0, \"artifact should have been rolled back\");\n   576→}\n   577→"}]},"parent_tool_use_id":null,"session_id":"19a33b10-b5a0-4ba2-8943-a7efa3e34818","uuid":"21038f3b-d807-456e-af8c-08f2e2cf106b","tool_use_result":{"type":"text","file":{"filePath":"/root/new-ralph-burning/ralph-burning-rewrite/tests/unit/workflow_engine_test.rs","content":"use std::fs;\nuse std::path::Path;\n\nuse chrono::Utc;\nuse tempfile::tempdir;\n\nuse ralph_burning::adapters::fs::{\n    FsJournalStore, FsPayloadArtifactWriteStore, FsProjectStore, FsRawOutputStore,\n    FsRunSnapshotStore, FsRunSnapshotWriteStore, FsRuntimeLogWriteStore, FsSessionStore,\n};\nuse ralph_burning::adapters::stub_backend::StubBackendAdapter;\nuse ralph_burning::contexts::agent_execution::service::AgentExecutionService;\nuse ralph_burning::contexts::project_run_record::model::{\n    JournalEvent, JournalEventType, RunSnapshot, RunStatus,\n};\nuse ralph_burning::contexts::project_run_record::service::{\n    self, CreateProjectInput, JournalStorePort, RunSnapshotPort, RunSnapshotWritePort,\n};\nuse ralph_burning::shared::error::{AppError, AppResult};\nuse ralph_burning::contexts::workflow_composition::engine;\nuse ralph_burning::contexts::workspace_governance;\nuse ralph_burning::contexts::workspace_governance::config::EffectiveConfig;\nuse ralph_burning::shared::domain::{FlowPreset, ProjectId, StageId};\n\nfn setup_workspace(base_dir: &Path) {\n    workspace_governance::initialize_workspace(base_dir, Utc::now()).unwrap();\n}\n\nfn create_standard_project(base_dir: &Path, project_id: &str) -> ProjectId {\n    let pid = ProjectId::new(project_id).unwrap();\n    let store = FsProjectStore;\n    let journal_store = FsJournalStore;\n    service::create_project(\n        &store,\n        &journal_store,\n        base_dir,\n        CreateProjectInput {\n            id: pid.clone(),\n            name: format!(\"Test {}\", project_id),\n            flow: FlowPreset::Standard,\n            prompt_path: \"prompt.md\".to_owned(),\n            prompt_contents: \"# Test prompt\".to_owned(),\n            prompt_hash: \"testhash123\".to_owned(),\n            created_at: Utc::now(),\n        },\n    )\n    .unwrap();\n\n    // Select as active\n    workspace_governance::set_active_project(base_dir, &pid).unwrap();\n    pid\n}\n\nfn build_agent_service(\n) -> AgentExecutionService<StubBackendAdapter, FsRawOutputStore, FsSessionStore> {\n    AgentExecutionService::new(\n        StubBackendAdapter::default(),\n        FsRawOutputStore,\n        FsSessionStore,\n    )\n}\n\n// ── Stage plan tests ────────────────────────────────────────────────────────\n\n#[test]\nfn stage_plan_with_prompt_review_enabled() {\n    let plan = engine::standard_stage_plan(true);\n    assert_eq!(plan.len(), 8);\n    assert_eq!(plan[0], StageId::PromptReview);\n    assert_eq!(plan[1], StageId::Planning);\n    assert_eq!(plan[7], StageId::FinalReview);\n}\n\n#[test]\nfn stage_plan_with_prompt_review_disabled() {\n    let plan = engine::standard_stage_plan(false);\n    assert_eq!(plan.len(), 7);\n    assert_eq!(plan[0], StageId::Planning);\n    assert!(!plan.contains(&StageId::PromptReview));\n}\n\n#[test]\nfn role_mapping_is_deterministic() {\n    use ralph_burning::shared::domain::BackendRole;\n    assert_eq!(engine::role_for_stage(StageId::PromptReview), BackendRole::Planner);\n    assert_eq!(engine::role_for_stage(StageId::Planning), BackendRole::Planner);\n    assert_eq!(engine::role_for_stage(StageId::Implementation), BackendRole::Implementer);\n    assert_eq!(engine::role_for_stage(StageId::Qa), BackendRole::QaValidator);\n    assert_eq!(engine::role_for_stage(StageId::Review), BackendRole::Reviewer);\n    assert_eq!(engine::role_for_stage(StageId::CompletionPanel), BackendRole::CompletionJudge);\n    assert_eq!(engine::role_for_stage(StageId::AcceptanceQa), BackendRole::QaValidator);\n    assert_eq!(engine::role_for_stage(StageId::FinalReview), BackendRole::CompletionJudge);\n}\n\n// ── Happy path tests ────────────────────────────────────────────────────────\n\n#[tokio::test]\nasync fn happy_path_standard_run_completes() {\n    let tmp = tempdir().unwrap();\n    let base_dir = tmp.path();\n\n    setup_workspace(base_dir);\n    let pid = create_standard_project(base_dir, \"happy-test\");\n\n    let agent_service = build_agent_service();\n    let config = EffectiveConfig::load(base_dir).unwrap();\n\n    let result = engine::execute_standard_run(\n        &agent_service,\n        &FsRunSnapshotStore,\n        &FsRunSnapshotWriteStore,\n        &FsJournalStore,\n        &FsPayloadArtifactWriteStore,\n        &FsRuntimeLogWriteStore,\n        base_dir,\n        &pid,\n        &config,\n    )\n    .await;\n\n    assert!(result.is_ok(), \"execute_standard_run failed: {:?}\", result.err());\n\n    // Verify final run snapshot\n    let snapshot = FsRunSnapshotStore.read_run_snapshot(base_dir, &pid).unwrap();\n    assert_eq!(snapshot.status, RunStatus::Completed);\n    assert!(snapshot.active_run.is_none());\n    assert_eq!(snapshot.completion_rounds, 1);\n    assert_eq!(snapshot.status_summary, \"completed\");\n\n    // Verify journal events\n    let events = FsJournalStore.read_journal(base_dir, &pid).unwrap();\n    // project_created + run_started + (8 * (stage_entered + stage_completed)) + run_completed\n    // = 1 + 1 + 16 + 1 = 19 events (with prompt_review enabled by default)\n    assert!(events.len() >= 19, \"expected >= 19 events, got {}\", events.len());\n\n    // First event should be project_created, second run_started\n    assert_eq!(events[0].event_type, JournalEventType::ProjectCreated);\n    assert_eq!(events[1].event_type, JournalEventType::RunStarted);\n\n    // Last event should be run_completed\n    assert_eq!(events.last().unwrap().event_type, JournalEventType::RunCompleted);\n\n    // Verify payloads and artifacts were written\n    let payloads_dir = base_dir\n        .join(\".ralph-burning/projects/happy-test/history/payloads\");\n    let artifacts_dir = base_dir\n        .join(\".ralph-burning/projects/happy-test/history/artifacts\");\n    let payload_count = fs::read_dir(&payloads_dir).unwrap().count();\n    let artifact_count = fs::read_dir(&artifacts_dir).unwrap().count();\n    assert_eq!(payload_count, 8, \"expected 8 payloads\");\n    assert_eq!(artifact_count, 8, \"expected 8 artifacts\");\n}\n\n#[tokio::test]\nasync fn happy_path_prompt_review_disabled() {\n    let tmp = tempdir().unwrap();\n    let base_dir = tmp.path();\n\n    setup_workspace(base_dir);\n\n    // Disable prompt review in config\n    workspace_governance::config::EffectiveConfig::set(base_dir, \"prompt_review.enabled\", \"false\")\n        .unwrap();\n\n    let pid = create_standard_project(base_dir, \"no-pr-test\");\n\n    let agent_service = build_agent_service();\n    let config = EffectiveConfig::load(base_dir).unwrap();\n    assert!(!config.prompt_review_enabled());\n\n    let result = engine::execute_standard_run(\n        &agent_service,\n        &FsRunSnapshotStore,\n        &FsRunSnapshotWriteStore,\n        &FsJournalStore,\n        &FsPayloadArtifactWriteStore,\n        &FsRuntimeLogWriteStore,\n        base_dir,\n        &pid,\n        &config,\n    )\n    .await;\n\n    assert!(result.is_ok());\n\n    // Verify 7 stages completed (no prompt_review)\n    let payloads_dir = base_dir\n        .join(\".ralph-burning/projects/no-pr-test/history/payloads\");\n    let payload_count = fs::read_dir(&payloads_dir).unwrap().count();\n    assert_eq!(payload_count, 7, \"expected 7 payloads without prompt_review\");\n\n    // Verify no prompt_review stage_entered in journal\n    let events = FsJournalStore.read_journal(base_dir, &pid).unwrap();\n    let pr_events: Vec<_> = events\n        .iter()\n        .filter(|e| {\n            if e.event_type == JournalEventType::StageEntered {\n                e.details.get(\"stage_id\").and_then(|v| v.as_str()) == Some(\"prompt_review\")\n            } else {\n                false\n            }\n        })\n        .collect();\n    assert!(pr_events.is_empty(), \"prompt_review stage should not appear\");\n}\n\n// ── Precondition failure tests ──────────────────────────────────────────────\n\n#[tokio::test]\nasync fn run_start_rejects_already_running() {\n    let tmp = tempdir().unwrap();\n    let base_dir = tmp.path();\n\n    setup_workspace(base_dir);\n    let pid = create_standard_project(base_dir, \"running-test\");\n\n    // Manually set status to running\n    let snapshot = RunSnapshot {\n        active_run: Some(ralph_burning::contexts::project_run_record::model::ActiveRun {\n            run_id: \"run-fake\".to_owned(),\n            stage_cursor: ralph_burning::shared::domain::StageCursor::initial(StageId::Planning),\n            started_at: Utc::now(),\n        }),\n        status: RunStatus::Running,\n        cycle_history: vec![],\n        completion_rounds: 0,\n        rollback_point_meta: Default::default(),\n        amendment_queue: Default::default(),\n        status_summary: \"running\".to_owned(),\n    };\n    FsRunSnapshotWriteStore\n        .write_run_snapshot(base_dir, &pid, &snapshot)\n        .unwrap();\n\n    let agent_service = build_agent_service();\n    let config = EffectiveConfig::load(base_dir).unwrap();\n\n    let result = engine::execute_standard_run(\n        &agent_service,\n        &FsRunSnapshotStore,\n        &FsRunSnapshotWriteStore,\n        &FsJournalStore,\n        &FsPayloadArtifactWriteStore,\n        &FsRuntimeLogWriteStore,\n        base_dir,\n        &pid,\n        &config,\n    )\n    .await;\n\n    assert!(result.is_err());\n    let err = result.unwrap_err().to_string();\n    assert!(err.contains(\"not_started\"), \"unexpected error: {}\", err);\n}\n\n#[tokio::test]\nasync fn run_start_rejects_completed_project() {\n    let tmp = tempdir().unwrap();\n    let base_dir = tmp.path();\n\n    setup_workspace(base_dir);\n    let pid = create_standard_project(base_dir, \"completed-test\");\n\n    let snapshot = RunSnapshot {\n        active_run: None,\n        status: RunStatus::Completed,\n        cycle_history: vec![],\n        completion_rounds: 1,\n        rollback_point_meta: Default::default(),\n        amendment_queue: Default::default(),\n        status_summary: \"completed\".to_owned(),\n    };\n    FsRunSnapshotWriteStore\n        .write_run_snapshot(base_dir, &pid, &snapshot)\n        .unwrap();\n\n    let agent_service = build_agent_service();\n    let config = EffectiveConfig::load(base_dir).unwrap();\n\n    let result = engine::execute_standard_run(\n        &agent_service,\n        &FsRunSnapshotStore,\n        &FsRunSnapshotWriteStore,\n        &FsJournalStore,\n        &FsPayloadArtifactWriteStore,\n        &FsRuntimeLogWriteStore,\n        base_dir,\n        &pid,\n        &config,\n    )\n    .await;\n\n    assert!(result.is_err());\n}\n\n// ── Preflight failure tests ─────────────────────────────────────────────────\n\n#[tokio::test]\nasync fn preflight_failure_leaves_state_unchanged() {\n    let tmp = tempdir().unwrap();\n    let base_dir = tmp.path();\n\n    setup_workspace(base_dir);\n    let pid = create_standard_project(base_dir, \"preflight-test\");\n\n    // Use an unavailable backend to trigger preflight failure\n    let agent_service = AgentExecutionService::new(\n        StubBackendAdapter::default().unavailable(),\n        FsRawOutputStore,\n        FsSessionStore,\n    );\n    let config = EffectiveConfig::load(base_dir).unwrap();\n\n    let result = engine::execute_standard_run(\n        &agent_service,\n        &FsRunSnapshotStore,\n        &FsRunSnapshotWriteStore,\n        &FsJournalStore,\n        &FsPayloadArtifactWriteStore,\n        &FsRuntimeLogWriteStore,\n        base_dir,\n        &pid,\n        &config,\n    )\n    .await;\n\n    assert!(result.is_err());\n\n    // Verify run.json is still not_started\n    let snapshot = FsRunSnapshotStore.read_run_snapshot(base_dir, &pid).unwrap();\n    assert_eq!(snapshot.status, RunStatus::NotStarted);\n    assert!(snapshot.active_run.is_none());\n\n    // Verify journal only has project_created\n    let events = FsJournalStore.read_journal(base_dir, &pid).unwrap();\n    assert_eq!(events.len(), 1);\n    assert_eq!(events[0].event_type, JournalEventType::ProjectCreated);\n\n    // Verify no payloads or artifacts created\n    let payloads_dir = base_dir\n        .join(\".ralph-burning/projects/preflight-test/history/payloads\");\n    let payload_count = fs::read_dir(&payloads_dir).unwrap().count();\n    assert_eq!(payload_count, 0);\n}\n\n// ── Stage plan resolution tests ─────────────────────────────────────────────\n\n#[test]\nfn resolve_stage_plan_produces_correct_targets() {\n    let resolver = ralph_burning::contexts::agent_execution::service::BackendResolver::new();\n    let stages = engine::standard_stage_plan(true);\n    let plan = engine::resolve_stage_plan(&stages, &resolver, None).unwrap();\n\n    assert_eq!(plan.len(), 8);\n    assert_eq!(plan[0].stage_id, StageId::PromptReview);\n    assert_eq!(\n        plan[0].role,\n        ralph_burning::shared::domain::BackendRole::Planner\n    );\n    assert_eq!(plan[2].stage_id, StageId::Implementation);\n    assert_eq!(\n        plan[2].role,\n        ralph_burning::shared::domain::BackendRole::Implementer\n    );\n}\n\n// ── Preflight check unit test ───────────────────────────────────────────────\n\n#[tokio::test]\nasync fn preflight_check_succeeds_with_default_stub() {\n    let resolver = ralph_burning::contexts::agent_execution::service::BackendResolver::new();\n    let stages = engine::standard_stage_plan(true);\n    let plan = engine::resolve_stage_plan(&stages, &resolver, None).unwrap();\n\n    let adapter = StubBackendAdapter::default();\n    let result = engine::preflight_check(&adapter, &plan).await;\n    assert!(result.is_ok());\n}\n\n#[tokio::test]\nasync fn preflight_check_fails_with_unavailable_backend() {\n    let resolver = ralph_burning::contexts::agent_execution::service::BackendResolver::new();\n    let stages = engine::standard_stage_plan(true);\n    let plan = engine::resolve_stage_plan(&stages, &resolver, None).unwrap();\n\n    let adapter = StubBackendAdapter::default().unavailable();\n    let result = engine::preflight_check(&adapter, &plan).await;\n    assert!(result.is_err());\n}\n\n// ── Failing-port tests: journal-append and snapshot-write errors ─────────\n\nuse std::sync::atomic::{AtomicU32, Ordering};\n\n/// A journal store that delegates to `FsJournalStore` but fails on the Nth\n/// append_event call (1-indexed). This lets us test failure at specific\n/// stage-commit boundaries.\nstruct FailingJournalStore {\n    call_count: AtomicU32,\n    fail_on_call: u32,\n}\n\nimpl FailingJournalStore {\n    fn new(fail_on_call: u32) -> Self {\n        Self {\n            call_count: AtomicU32::new(0),\n            fail_on_call,\n        }\n    }\n}\n\nimpl JournalStorePort for FailingJournalStore {\n    fn read_journal(\n        &self,\n        base_dir: &Path,\n        project_id: &ralph_burning::shared::domain::ProjectId,\n    ) -> AppResult<Vec<JournalEvent>> {\n        FsJournalStore.read_journal(base_dir, project_id)\n    }\n\n    fn append_event(\n        &self,\n        base_dir: &Path,\n        project_id: &ralph_burning::shared::domain::ProjectId,\n        line: &str,\n    ) -> AppResult<()> {\n        let n = self.call_count.fetch_add(1, Ordering::SeqCst) + 1;\n        if n == self.fail_on_call {\n            return Err(AppError::Io(std::io::Error::new(\n                std::io::ErrorKind::Other,\n                \"simulated journal append failure\",\n            )));\n        }\n        FsJournalStore.append_event(base_dir, project_id, line)\n    }\n}\n\n/// A snapshot write store that delegates to `FsRunSnapshotWriteStore` but fails\n/// on the Nth write call (1-indexed).\nstruct FailingSnapshotWriteStore {\n    call_count: AtomicU32,\n    fail_on_call: u32,\n}\n\nimpl FailingSnapshotWriteStore {\n    fn new(fail_on_call: u32) -> Self {\n        Self {\n            call_count: AtomicU32::new(0),\n            fail_on_call,\n        }\n    }\n}\n\nimpl RunSnapshotWritePort for FailingSnapshotWriteStore {\n    fn write_run_snapshot(\n        &self,\n        base_dir: &Path,\n        project_id: &ralph_burning::shared::domain::ProjectId,\n        snapshot: &RunSnapshot,\n    ) -> AppResult<()> {\n        let n = self.call_count.fetch_add(1, Ordering::SeqCst) + 1;\n        if n == self.fail_on_call {\n            return Err(AppError::Io(std::io::Error::new(\n                std::io::ErrorKind::Other,\n                \"simulated snapshot write failure\",\n            )));\n        }\n        FsRunSnapshotWriteStore.write_run_snapshot(base_dir, project_id, snapshot)\n    }\n}\n\n/// Journal append failure after payload/artifact write must roll back the\n/// payload/artifact pair so no partial durable history is visible, and the\n/// run must end in failed state.\n#[tokio::test]\nasync fn journal_failure_after_payload_rolls_back_and_fails_run() {\n    let tmp = tempdir().unwrap();\n    let base_dir = tmp.path();\n\n    setup_workspace(base_dir);\n    let pid = create_standard_project(base_dir, \"journal-fail\");\n\n    let agent_service = build_agent_service();\n    let config = EffectiveConfig::load(base_dir).unwrap();\n\n    // The engine calls append_event for:\n    //   1: run_started\n    //   2: stage_entered (stage 1)\n    //   3: stage_completed (stage 1) — fail here\n    let failing_journal = FailingJournalStore::new(3);\n\n    let result = engine::execute_standard_run(\n        &agent_service,\n        &FsRunSnapshotStore,\n        &FsRunSnapshotWriteStore,\n        &failing_journal,\n        &FsPayloadArtifactWriteStore,\n        &FsRuntimeLogWriteStore,\n        base_dir,\n        &pid,\n        &config,\n    )\n    .await;\n\n    assert!(result.is_err(), \"run should fail on journal failure\");\n\n    // Run must be in failed state\n    let snapshot = FsRunSnapshotStore.read_run_snapshot(base_dir, &pid).unwrap();\n    assert_eq!(snapshot.status, RunStatus::Failed);\n    assert!(snapshot.active_run.is_none());\n\n    // No payload/artifact should be visible for the first stage since it was\n    // rolled back after journal failure\n    let payloads_dir = base_dir\n        .join(\".ralph-burning/projects/journal-fail/history/payloads\");\n    let payload_count = fs::read_dir(&payloads_dir).unwrap().count();\n    assert_eq!(payload_count, 0, \"payload should have been rolled back\");\n\n    let artifacts_dir = base_dir\n        .join(\".ralph-burning/projects/journal-fail/history/artifacts\");\n    let artifact_count = fs::read_dir(&artifacts_dir).unwrap().count();\n    assert_eq!(artifact_count, 0, \"artifact should have been rolled back\");\n}\n\n/// Snapshot write failure after stage_completed journal should roll back the\n/// payload/artifact pair and mark the run as failed.\n#[tokio::test]\nasync fn snapshot_failure_after_stage_completed_rolls_back_and_fails_run() {\n    let tmp = tempdir().unwrap();\n    let base_dir = tmp.path();\n\n    setup_workspace(base_dir);\n    let pid = create_standard_project(base_dir, \"snap-fail\");\n\n    let agent_service = build_agent_service();\n    let config = EffectiveConfig::load(base_dir).unwrap();\n\n    // The engine calls write_run_snapshot for:\n    //   1: initial Running snapshot (run start)\n    //   2: stage_entered cursor update (stage 1)\n    //   3: stage_completed cursor update (stage 1) — fail here\n    let failing_snapshot = FailingSnapshotWriteStore::new(3);\n\n    let result = engine::execute_standard_run(\n        &agent_service,\n        &FsRunSnapshotStore,\n        &failing_snapshot,\n        &FsJournalStore,\n        &FsPayloadArtifactWriteStore,\n        &FsRuntimeLogWriteStore,\n        base_dir,\n        &pid,\n        &config,\n    )\n    .await;\n\n    assert!(result.is_err(), \"run should fail on snapshot failure\");\n\n    // The run must end in failed state. Since the failing store only fails\n    // on call 3, the fail_run recovery can still write the failed snapshot\n    // (calls 4+).\n    let snapshot = FsRunSnapshotStore.read_run_snapshot(base_dir, &pid).unwrap();\n    assert_eq!(snapshot.status, RunStatus::Failed);\n    assert!(snapshot.active_run.is_none());\n\n    // No payload/artifact should be visible for the first stage\n    let payloads_dir = base_dir\n        .join(\".ralph-burning/projects/snap-fail/history/payloads\");\n    let payload_count = fs::read_dir(&payloads_dir).unwrap().count();\n    assert_eq!(payload_count, 0, \"payload should have been rolled back\");\n\n    let artifacts_dir = base_dir\n        .join(\".ralph-burning/projects/snap-fail/history/artifacts\");\n    let artifact_count = fs::read_dir(&artifacts_dir).unwrap().count();\n    assert_eq!(artifact_count, 0, \"artifact should have been rolled back\");\n}\n","numLines":577,"startLine":1,"totalLines":577}}}
