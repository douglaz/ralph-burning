t '{project_id}': it has an active run\")]\n    ActiveRunDelete { project_id: String },\n    #[error(\"journal sequence error: {details}\")]\n    JournalSequence { details: String },\n    #[error(\"cannot start run: {reason}\")]\n    RunStartFailed { reason: String },\n    #[error(\"flow '{flow_id}' is not yet supported for `run start`; only 'standard' is supported in this slice\")]\n    UnsupportedFlow { flow_id: String },\n    #[error(\"preflight check failed for stage '{stage_id}': {details}\")]\n    PreflightFailed { stage_id: StageId, details: String },\n    #[error(\"stage commit failed for stage '{stage_id}': {details}\")]\n    StageCommitFailed { stage_id: StageId, details: String },\n    #[error(\"{command} is not yet implemented\")]\n    NotYetImplemented { command: String },\n    #[error(\"backend '{backend}' is unavailable: {details}\")]\n    BackendUnavailable { backend: String, details: String },\n    #[error(\"backend '{backend}' cannot satisfy stage '{stage_id}': {details}\")]\n    CapabilityMismatch {\n        backend: String,\n        stage_id: StageId,\n        details: String,\n    },\n    #[error(\"backend invocation failed for stage '{stage_id}' via '{backend}': {details}\")]\n    InvocationFailed {\n        backend: String,\n        stage_id: StageId,\n        failure_class: FailureClass,\n        details: String,\n    },\n    #[error(\n        \"backend invocation timed out for stage '{stage_id}' via '{backend}' after {timeout_ms} ms\"\n    )]\n    InvocationTimeout {\n        backend: String,\n        stage_id: StageId,\n        timeout_ms: u64,\n    },\n    #[error(\"backend invocation cancelled for stage '{stage_id}' via '{backend}'\")]\n    InvocationCancelled { backend: String, stage_id: StageId },\n    #[error(transparent)]\n    Io(#[from] std::io::Error),\n    #[error(transparent)]\n    TomlDeserialize(#[from] toml::de::Error),\n    #[error(transparent)]\n    TomlSerialize(#[from] toml::ser::Error),\n    #[error(transparent)]\n    Toml