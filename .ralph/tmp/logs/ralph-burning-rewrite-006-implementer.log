{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01CgjsEUWcTGSLbCaV6Z8S2T","type":"tool_result","content":"     1→use std::fmt;\n     2→use std::str::FromStr;\n     3→\n     4→use chrono::{DateTime, Utc};\n     5→use serde::{Deserialize, Serialize};\n     6→use toml::Table;\n     7→\n     8→use crate::shared::error::{AppError, AppResult};\n     9→\n    10→pub const CURRENT_WORKSPACE_VERSION: u32 = 1;\n    11→\n    12→/// Canonical failure classes for stage contract evaluation and retry semantics.\n    13→#[derive(Debug, Clone, Copy, PartialEq, Eq, Hash, Serialize, Deserialize)]\n    14→#[serde(rename_all = \"snake_case\")]\n    15→pub enum FailureClass {\n    16→    TransportFailure,\n    17→    SchemaValidationFailure,\n    18→    DomainValidationFailure,\n    19→    Timeout,\n    20→    Cancellation,\n    21→    QaReviewOutcomeFailure,\n    22→}\n    23→\n    24→#[derive(Debug, Clone, Copy, PartialEq, Eq, Hash, Serialize, Deserialize)]\n    25→#[serde(rename_all = \"snake_case\")]\n    26→pub enum BackendFamily {\n    27→    Claude,\n    28→    Codex,\n    29→    OpenRouter,\n    30→    Stub,\n    31→}\n    32→\n    33→impl BackendFamily {\n    34→    pub fn as_str(self) -> &'static str {\n    35→        match self {\n    36→            Self::Claude => \"claude\",\n    37→            Self::Codex => \"codex\",\n    38→            Self::OpenRouter => \"openrouter\",\n    39→            Self::Stub => \"stub\",\n    40→        }\n    41→    }\n    42→\n    43→    pub fn display_name(self) -> &'static str {\n    44→        match self {\n    45→            Self::Claude => \"Claude\",\n    46→            Self::Codex => \"Codex\",\n    47→            Self::OpenRouter => \"OpenRouter\",\n    48→            Self::Stub => \"Stub\",\n    49→        }\n    50→    }\n    51→\n    52→    pub fn default_model_id(self) -> &'static str {\n    53→        match self {\n    54→            Self::Claude => \"opus-4.1\",\n    55→            Self::Codex => \"gpt-5-codex\",\n    56→            Self::OpenRouter => \"openai/gpt-5\",\n    57→            Self::Stub => \"stub-default\",\n    58→        }\n    59→    }\n    60→}\n    61→\n    62→impl fmt::Display for BackendFamily {\n    63→    fn fmt(&self, f: &mut fmt::Formatter<'_>) -> fmt::Result {\n    64→        f.write_str(self.as_str())\n    65→    }\n    66→}\n    67→\n    68→impl FromStr for BackendFamily {\n    69→    type Err = AppError;\n    70→\n    71→    fn from_str(value: &str) -> Result<Self, Self::Err> {\n    72→        match value {\n    73→            \"claude\" => Ok(Self::Claude),\n    74→            \"codex\" => Ok(Self::Codex),\n    75→            \"openrouter\" => Ok(Self::OpenRouter),\n    76→            \"stub\" => Ok(Self::Stub),\n    77→            _ => Err(AppError::InvalidConfigValue {\n    78→                key: \"backend\".to_owned(),\n    79→                value: value.to_owned(),\n    80→                reason: \"expected one of claude, codex, openrouter, stub\".to_owned(),\n    81→            }),\n    82→        }\n    83→    }\n    84→}\n    85→\n    86→#[derive(Debug, Clone, PartialEq, Eq, Serialize, Deserialize)]\n    87→pub struct CapabilityMetadata {\n    88→    pub supports_structured_output: bool,\n    89→    pub supports_session_reuse: bool,\n    90→    pub supports_cancellation: bool,\n    91→    pub supported_stages: Vec<StageId>,\n    92→}\n    93→\n    94→impl CapabilityMetadata {\n    95→    pub fn for_all_stages(supports_session_reuse: bool, supports_cancellation: bool) -> Self {\n    96→        Self {\n    97→            supports_structured_output: true,\n    98→            supports_session_reuse,\n    99→            supports_cancellation,\n   100→            supported_stages: StageId::ALL.to_vec(),\n   101→        }\n   102→    }\n   103→\n   104→    pub fn supports_stage(&self, stage_id: StageId) -> bool {\n   105→        self.supported_stages.contains(&stage_id)\n   106→    }\n   107→}\n   108→\n   109→#[derive(Debug, Clone, P