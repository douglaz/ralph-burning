{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Q5vd1c8fDcZj3S3h9mz7Ap","type":"tool_result","content":"     1→use std::path::Path;\n     2→\n     3→use chrono::{DateTime, Utc};\n     4→\n     5→use crate::shared::domain::{FlowPreset, ProjectId};\n     6→use crate::shared::error::{AppError, AppResult};\n     7→\n     8→use super::journal;\n     9→use super::model::{\n    10→    ArtifactRecord, JournalEvent, JournalEventType, PayloadRecord, ProjectDetail, ProjectListEntry,\n    11→    ProjectRecord, ProjectStatusSummary, RunSnapshot, RuntimeLogEntry, SessionStore,\n    12→};\n    13→use super::queries::{self, RunHistoryView, RunStatusView, RunTailView};\n    14→\n    15→/// Port for reading and writing project records.\n    16→pub trait ProjectStorePort {\n    17→    fn project_exists(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<bool>;\n    18→    fn read_project_record(\n    19→        &self,\n    20→        base_dir: &Path,\n    21→        project_id: &ProjectId,\n    22→    ) -> AppResult<ProjectRecord>;\n    23→    fn list_project_ids(&self, base_dir: &Path) -> AppResult<Vec<ProjectId>>;\n    24→\n    25→    /// Stage a project for deletion: makes it invisible to list/show but\n    26→    /// keeps data on disk for potential rollback.\n    27→    fn stage_delete(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<()>;\n    28→\n    29→    /// Finalize a staged delete: permanently removes the project data.\n    30→    fn commit_delete(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<()>;\n    31→\n    32→    /// Roll back a staged delete: restores the project to its canonical path.\n    33→    fn rollback_delete(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<()>;\n    34→\n    35→    /// Atomically stage and commit a new project. If any step fails,\n    36→    /// the project must not be visible to list/show.\n    37→    fn create_project_atomic(\n    38→        &self,\n    39→        base_dir: &Path,\n    40→        record: &ProjectRecord,\n    41→        prompt_contents: &str,\n    42→        run_snapshot: &RunSnapshot,\n    43→        initial_journal_line: &str,\n    44→        sessions: &SessionStore,\n    45→    ) -> AppResult<()>;\n    46→}\n    47→\n    48→/// Port for reading and appending journal events.\n    49→pub trait JournalStorePort {\n    50→    fn read_journal(&self, base_dir: &Path, project_id: &ProjectId)\n    51→        -> AppResult<Vec<JournalEvent>>;\n    52→    fn append_event(&self, base_dir: &Path, project_id: &ProjectId, line: &str) -> AppResult<()>;\n    53→}\n    54→\n    55→/// Port for reading payload and artifact durable history.\n    56→pub trait ArtifactStorePort {\n    57→    fn list_payloads(\n    58→        &self,\n    59→        base_dir: &Path,\n    60→        project_id: &ProjectId,\n    61→    ) -> AppResult<Vec<PayloadRecord>>;\n    62→    fn list_artifacts(\n    63→        &self,\n    64→        base_dir: &Path,\n    65→        project_id: &ProjectId,\n    66→    ) -> AppResult<Vec<ArtifactRecord>>;\n    67→}\n    68→\n    69→/// Port for reading runtime logs (separate from durable history).\n    70→pub trait RuntimeLogStorePort {\n    71→    fn read_runtime_logs(\n    72→        &self,\n    73→        base_dir: &Path,\n    74→        project_id: &ProjectId,\n    75→    ) -> AppResult<Vec<RuntimeLogEntry>>;\n    76→}\n    77→\n    78→/// Port for reading/writing the run snapshot.\n    79→pub trait RunSnapshotPort {\n    80→    fn read_run_snapshot(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<RunSnapshot>;\n    81→}\n    82→\n    83→/// Port for reading/writing/clearing the active project pointer.\n    84→pub trait ActiveProjectPort {\n    85→    fn read_active_project_id(&self, base_dir: &Path) -> AppResult<Option<String>>;\n    86→    fn clear_active_project(&self, base_dir: &Path) -> AppResult<()>;\n    87→    fn write_active_project(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<()>;\n    88→}\n    89→\n    90→/// Input for the `project create` use case.\n    91→pub struct CreateProjectInput {\n    92→    pub id: ProjectId,\n    93→    pub name: String,\n    94→    pub flow: FlowPreset,\n    95→    pub prompt_path: String,\n    96→    pub prompt_contents: String,\n    97→    pub prompt_hash: String,\n    98→    pub created_at: DateTime<Utc>,\n    99→}\n   100→\n   101→/// Create a new project with all canonical files.\n   102→pub fn create_project(\n   103→    store: &dyn ProjectStorePort,\n   104→    journal_store: &dyn JournalStorePort,\n   105→    base_dir: &Path,\n   106→    input: CreateProjectInput,\n   107→) -> AppResult<ProjectRecord> {\n   108→    // Check for duplicate project ID\n   109→    if store.project_exists(base_dir, &input.id)? {\n   110→        return Err(AppError::DuplicateProject {\n   111→            project_id: input.id.to_string(),\n   112→        });\n   113→    }\n   114→\n   115→    let record = ProjectRecord {\n   116→        id: input.id.clone(),\n   117→        name: input.name,\n   118→        flow: input.flow,\n   119→        prompt_reference: \"prompt.md\".to_owned(),\n   120→        prompt_hash: input.prompt_hash,\n   121→        created_at: input.created_at,\n   122→        status_summary: ProjectStatusSummary::Created,\n   123→    };\n   124→\n   125→    let run_snapshot = RunSnapshot::initial();\n   126→    let sessions = SessionStore::empty();\n   127→\n   128→    // Create the initial journal event\n   129→    let initial_event = JournalEvent {\n   130→        sequence: 1,\n   131→        timestamp: input.created_at,\n   132→        event_type: JournalEventType::ProjectCreated,\n   133→        details: serde_json::json!({\n   134→            \"project_id\": record.id.as_str(),\n   135→            \"flow\": record.flow.as_str(),\n   136→        }),\n   137→    };\n   138→    let journal_line = journal::serialize_event(&initial_event)?;\n   139→\n   140→    // Atomic creation: all files or nothing\n   141→    store.create_project_atomic(\n   142→        base_dir,\n   143→        &record,\n   144→        &input.prompt_contents,\n   145→        &run_snapshot,\n   146→        &journal_line,\n   147→        &sessions,\n   148→    )?;\n   149→\n   150→    // create_project_atomic writes the journal as part of the atomic init,\n   151→    // but we don't call journal_store.append_event here because the atomic\n   152→    // creation already wrote the initial journal line. The journal_store\n   153→    // parameter is kept for interface consistency and future use.\n   154→    let _ = journal_store;\n   155→\n   156→    Ok(record)\n   157→}\n   158→\n   159→/// List all projects with summary data.\n   160→pub fn list_projects(\n   161→    store: &dyn ProjectStorePort,\n   162→    active_port: &dyn ActiveProjectPort,\n   163→    base_dir: &Path,\n   164→) -> AppResult<Vec<ProjectListEntry>> {\n   165→    let active_id = active_port.read_active_project_id(base_dir)?;\n   166→    let project_ids = store.list_project_ids(base_dir)?;\n   167→\n   168→    let mut entries = Vec::new();\n   169→    for pid in project_ids {\n   170→        let record = store.read_project_record(base_dir, &pid)?;\n   171→        let is_active = active_id.as_deref() == Some(pid.as_str());\n   172→        entries.push(ProjectListEntry {\n   173→            id: record.id,\n   174→            name: record.name,\n   175→            flow: record.flow,\n   176→            status_summary: record.status_summary,\n   177→            created_at: record.created_at,\n   178→            is_active,\n   179→        });\n   180→    }\n   181→\n   182→    Ok(entries)\n   183→}\n   184→\n   185→/// Show detailed project information.\n   186→pub fn show_project(\n   187→    store: &dyn ProjectStorePort,\n   188→    run_port: &dyn RunSnapshotPort,\n   189→    journal_port: &dyn JournalStorePort,\n   190→    active_port: &dyn ActiveProjectPort,\n   191→    base_dir: &Path,\n   192→    project_id: &ProjectId,\n   193→) -> AppResult<ProjectDetail> {\n   194→    if !store.project_exists(base_dir, project_id)? {\n   195→        return Err(AppError::ProjectNotFound {\n   196→            project_id: project_id.to_string(),\n   197→        });\n   198→    }\n   199→\n   200→    let record = store.read_project_record(base_dir, project_id)?;\n   201→    let run_snapshot = run_port.read_run_snapshot(base_dir, project_id)?;\n   202→    let events = journal_port.read_journal(base_dir, project_id)?;\n   203→    let journal_event_count = events.len() as u64;\n   204→    let active_id = active_port.read_active_project_id(base_dir)?;\n   205→    let is_active = active_id.as_deref() == Some(project_id.as_str());\n   206→\n   207→    // Count rollback points from journal events\n   208→    let rollback_count = events\n   209→        .iter()\n   210→        .filter(|e| e.event_type == JournalEventType::RollbackCreated)\n   211→        .count();\n   212→\n   213→    Ok(ProjectDetail {\n   214→        record,\n   215→        run_snapshot,\n   216→        journal_event_count,\n   217→        rollback_count,\n   218→        is_active,\n   219→    })\n   220→}\n   221→\n   222→/// Delete a project. Fails if project has an active run.\n   223→/// Clears active-project pointer if it pointed to the deleted project.\n   224→///\n   225→/// Transactional: if any post-validation step fails, the project remains\n   226→/// addressable at its canonical path and the active-project pointer is\n   227→/// unchanged.\n   228→pub fn delete_project(\n   229→    store: &dyn ProjectStorePort,\n   230→    run_port: &dyn RunSnapshotPort,\n   231→    active_port: &dyn ActiveProjectPort,\n   232→    base_dir: &Path,\n   233→    project_id: &ProjectId,\n   234→) -> AppResult<()> {\n   235→    if !store.project_exists(base_dir, project_id)? {\n   236→        return Err(AppError::ProjectNotFound {\n   237→            project_id: project_id.to_string(),\n   238→        });\n   239→    }\n   240→\n   241→    // Check for active run\n   242→    let run_snapshot = run_port.read_run_snapshot(base_dir, project_id)?;\n   243→    if run_snapshot.has_active_run() {\n   244→        return Err(AppError::ActiveRunDelete {\n   245→            project_id: project_id.to_string(),\n   246→        });\n   247→    }\n   248→\n   249→    // Check if this is the active project (before delete)\n   250→    let active_id = active_port.read_active_project_id(base_dir)?;\n   251→    let was_active = active_id.as_deref() == Some(project_id.as_str());\n   252→\n   253→    // Phase 1: Stage the delete — project becomes invisible to list/show\n   254→    // but data remains on disk for rollback.\n   255→    store.stage_delete(base_dir, project_id)?;\n   256→\n   257→    // Phase 2: Clear the active-project pointer if needed.\n   258→    // If this fails, roll back the staged delete so the project remains\n   259→    // addressable and the pointer is unchanged.\n   260→    if was_active {\n   261→        if let Err(clear_err) = active_port.clear_active_project(base_dir) {\n   262→            store\n   263→                .rollback_delete(base_dir, project_id)\n   264→                .map_err(|restore_err| AppError::CorruptRecord {\n   265→                    file: format!(\"projects/{}\", project_id),\n   266→                    details: format!(\n   267→                        \"delete partially failed: pointer clear error: {}, restore error: {}\",\n   268→                        clear_err, restore_err\n   269→                    ),\n   270→                })?;\n   271→            return Err(clear_err);\n   272→        }\n   273→    }\n   274→\n   275→    // Phase 3: Finalize — permanently remove the project data.\n   276→    // At this point the logical delete has succeeded (project is invisible,\n   277→    // pointer is cleared). Best-effort cleanup of the staged data.\n   278→    let _ = store.commit_delete(base_dir, project_id);\n   279→\n   280→    Ok(())\n   281→}\n   282→\n   283→/// Get run status for the active project.\n   284→pub fn run_status(\n   285→    run_port: &dyn RunSnapshotPort,\n   286→    base_dir: &Path,\n   287→    project_id: &ProjectId,\n   288→) -> AppResult<RunStatusView> {\n   289→    let snapshot = run_port.read_run_snapshot(base_dir, project_id)?;\n   290→    Ok(queries::build_status_view(project_id.as_str(), &snapshot))\n   291→}\n   292→\n   293→/// Get run history (durable only, no runtime logs).\n   294→pub fn run_history(\n   295→    journal_port: &dyn JournalStorePort,\n   296→    artifact_port: &dyn ArtifactStorePort,\n   297→    base_dir: &Path,\n   298→    project_id: &ProjectId,\n   299→) -> AppResult<RunHistoryView> {\n   300→    let events = journal_port.read_journal(base_dir, project_id)?;\n   301→    let payloads = artifact_port.list_payloads(base_dir, project_id)?;\n   302→    let artifacts = artifact_port.list_artifacts(base_dir, project_id)?;\n   303→\n   304→    queries::validate_history_consistency(&payloads, &artifacts)?;\n   305→\n   306→    Ok(queries::build_history_view(\n   307→        project_id.as_str(),\n   308→        events,\n   309→        payloads,\n   310→        artifacts,\n   311→    ))\n   312→}\n   313→\n   314→/// Get run tail: durable history by default, with optional runtime logs.\n   315→pub fn run_tail(\n   316→    journal_port: &dyn JournalStorePort,\n   317→    artifact_port: &dyn ArtifactStorePort,\n   318→    log_port: &dyn RuntimeLogStorePort,\n   319→    base_dir: &Path,\n   320→    project_id: &ProjectId,\n   321→    include_logs: bool,\n   322→) -> AppResult<RunTailView> {\n   323→    let events = journal_port.read_journal(base_dir, project_id)?;\n   324→    let payloads = artifact_port.list_payloads(base_dir, project_id)?;\n   325→    let artifacts = artifact_port.list_artifacts(base_dir, project_id)?;\n   326→\n   327→    queries::validate_history_consistency(&payloads, &artifacts)?;\n   328→\n   329→    let runtime_logs = if include_logs {\n   330→        log_port.read_runtime_logs(base_dir, project_id)?\n   331→    } else {\n   332→        Vec::new()\n   333→    };\n   334→\n   335→    Ok(queries::build_tail_view(\n   336→        project_id.as_str(),\n   337→        events,\n   338→        payloads,\n   339→        artifacts,\n   340→        include_logs,\n   341→        runtime_logs,\n   342→    ))\n   343→}\n   344→"}]},"parent_tool_use_id":null,"session_id":"b9859e69-5579-4e82-ac66-49d19cc80e05","uuid":"0a130a8b-4084-4646-bfaf-32624be2d0fc","tool_use_result":{"type":"text","file":{"filePath":"/root/new-ralph-burning/ralph-burning-rewrite/src/contexts/project_run_record/service.rs","content":"use std::path::Path;\n\nuse chrono::{DateTime, Utc};\n\nuse crate::shared::domain::{FlowPreset, ProjectId};\nuse crate::shared::error::{AppError, AppResult};\n\nuse super::journal;\nuse super::model::{\n    ArtifactRecord, JournalEvent, JournalEventType, PayloadRecord, ProjectDetail, ProjectListEntry,\n    ProjectRecord, ProjectStatusSummary, RunSnapshot, RuntimeLogEntry, SessionStore,\n};\nuse super::queries::{self, RunHistoryView, RunStatusView, RunTailView};\n\n/// Port for reading and writing project records.\npub trait ProjectStorePort {\n    fn project_exists(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<bool>;\n    fn read_project_record(\n        &self,\n        base_dir: &Path,\n        project_id: &ProjectId,\n    ) -> AppResult<ProjectRecord>;\n    fn list_project_ids(&self, base_dir: &Path) -> AppResult<Vec<ProjectId>>;\n\n    /// Stage a project for deletion: makes it invisible to list/show but\n    /// keeps data on disk for potential rollback.\n    fn stage_delete(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<()>;\n\n    /// Finalize a staged delete: permanently removes the project data.\n    fn commit_delete(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<()>;\n\n    /// Roll back a staged delete: restores the project to its canonical path.\n    fn rollback_delete(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<()>;\n\n    /// Atomically stage and commit a new project. If any step fails,\n    /// the project must not be visible to list/show.\n    fn create_project_atomic(\n        &self,\n        base_dir: &Path,\n        record: &ProjectRecord,\n        prompt_contents: &str,\n        run_snapshot: &RunSnapshot,\n        initial_journal_line: &str,\n        sessions: &SessionStore,\n    ) -> AppResult<()>;\n}\n\n/// Port for reading and appending journal events.\npub trait JournalStorePort {\n    fn read_journal(&self, base_dir: &Path, project_id: &ProjectId)\n        -> AppResult<Vec<JournalEvent>>;\n    fn append_event(&self, base_dir: &Path, project_id: &ProjectId, line: &str) -> AppResult<()>;\n}\n\n/// Port for reading payload and artifact durable history.\npub trait ArtifactStorePort {\n    fn list_payloads(\n        &self,\n        base_dir: &Path,\n        project_id: &ProjectId,\n    ) -> AppResult<Vec<PayloadRecord>>;\n    fn list_artifacts(\n        &self,\n        base_dir: &Path,\n        project_id: &ProjectId,\n    ) -> AppResult<Vec<ArtifactRecord>>;\n}\n\n/// Port for reading runtime logs (separate from durable history).\npub trait RuntimeLogStorePort {\n    fn read_runtime_logs(\n        &self,\n        base_dir: &Path,\n        project_id: &ProjectId,\n    ) -> AppResult<Vec<RuntimeLogEntry>>;\n}\n\n/// Port for reading/writing the run snapshot.\npub trait RunSnapshotPort {\n    fn read_run_snapshot(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<RunSnapshot>;\n}\n\n/// Port for reading/writing/clearing the active project pointer.\npub trait ActiveProjectPort {\n    fn read_active_project_id(&self, base_dir: &Path) -> AppResult<Option<String>>;\n    fn clear_active_project(&self, base_dir: &Path) -> AppResult<()>;\n    fn write_active_project(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<()>;\n}\n\n/// Input for the `project create` use case.\npub struct CreateProjectInput {\n    pub id: ProjectId,\n    pub name: String,\n    pub flow: FlowPreset,\n    pub prompt_path: String,\n    pub prompt_contents: String,\n    pub prompt_hash: String,\n    pub created_at: DateTime<Utc>,\n}\n\n/// Create a new project with all canonical files.\npub fn create_project(\n    store: &dyn ProjectStorePort,\n    journal_store: &dyn JournalStorePort,\n    base_dir: &Path,\n    input: CreateProjectInput,\n) -> AppResult<ProjectRecord> {\n    // Check for duplicate project ID\n    if store.project_exists(base_dir, &input.id)? {\n        return Err(AppError::DuplicateProject {\n            project_id: input.id.to_string(),\n        });\n    }\n\n    let record = ProjectRecord {\n        id: input.id.clone(),\n        name: input.name,\n        flow: input.flow,\n        prompt_reference: \"prompt.md\".to_owned(),\n        prompt_hash: input.prompt_hash,\n        created_at: input.created_at,\n        status_summary: ProjectStatusSummary::Created,\n    };\n\n    let run_snapshot = RunSnapshot::initial();\n    let sessions = SessionStore::empty();\n\n    // Create the initial journal event\n    let initial_event = JournalEvent {\n        sequence: 1,\n        timestamp: input.created_at,\n        event_type: JournalEventType::ProjectCreated,\n        details: serde_json::json!({\n            \"project_id\": record.id.as_str(),\n            \"flow\": record.flow.as_str(),\n        }),\n    };\n    let journal_line = journal::serialize_event(&initial_event)?;\n\n    // Atomic creation: all files or nothing\n    store.create_project_atomic(\n        base_dir,\n        &record,\n        &input.prompt_contents,\n        &run_snapshot,\n        &journal_line,\n        &sessions,\n    )?;\n\n    // create_project_atomic writes the journal as part of the atomic init,\n    // but we don't call journal_store.append_event here because the atomic\n    // creation already wrote the initial journal line. The journal_store\n    // parameter is kept for interface consistency and future use.\n    let _ = journal_store;\n\n    Ok(record)\n}\n\n/// List all projects with summary data.\npub fn list_projects(\n    store: &dyn ProjectStorePort,\n    active_port: &dyn ActiveProjectPort,\n    base_dir: &Path,\n) -> AppResult<Vec<ProjectListEntry>> {\n    let active_id = active_port.read_active_project_id(base_dir)?;\n    let project_ids = store.list_project_ids(base_dir)?;\n\n    let mut entries = Vec::new();\n    for pid in project_ids {\n        let record = store.read_project_record(base_dir, &pid)?;\n        let is_active = active_id.as_deref() == Some(pid.as_str());\n        entries.push(ProjectListEntry {\n            id: record.id,\n            name: record.name,\n            flow: record.flow,\n            status_summary: record.status_summary,\n            created_at: record.created_at,\n            is_active,\n        });\n    }\n\n    Ok(entries)\n}\n\n/// Show detailed project information.\npub fn show_project(\n    store: &dyn ProjectStorePort,\n    run_port: &dyn RunSnapshotPort,\n    journal_port: &dyn JournalStorePort,\n    active_port: &dyn ActiveProjectPort,\n    base_dir: &Path,\n    project_id: &ProjectId,\n) -> AppResult<ProjectDetail> {\n    if !store.project_exists(base_dir, project_id)? {\n        return Err(AppError::ProjectNotFound {\n            project_id: project_id.to_string(),\n        });\n    }\n\n    let record = store.read_project_record(base_dir, project_id)?;\n    let run_snapshot = run_port.read_run_snapshot(base_dir, project_id)?;\n    let events = journal_port.read_journal(base_dir, project_id)?;\n    let journal_event_count = events.len() as u64;\n    let active_id = active_port.read_active_project_id(base_dir)?;\n    let is_active = active_id.as_deref() == Some(project_id.as_str());\n\n    // Count rollback points from journal events\n    let rollback_count = events\n        .iter()\n        .filter(|e| e.event_type == JournalEventType::RollbackCreated)\n        .count();\n\n    Ok(ProjectDetail {\n        record,\n        run_snapshot,\n        journal_event_count,\n        rollback_count,\n        is_active,\n    })\n}\n\n/// Delete a project. Fails if project has an active run.\n/// Clears active-project pointer if it pointed to the deleted project.\n///\n/// Transactional: if any post-validation step fails, the project remains\n/// addressable at its canonical path and the active-project pointer is\n/// unchanged.\npub fn delete_project(\n    store: &dyn ProjectStorePort,\n    run_port: &dyn RunSnapshotPort,\n    active_port: &dyn ActiveProjectPort,\n    base_dir: &Path,\n    project_id: &ProjectId,\n) -> AppResult<()> {\n    if !store.project_exists(base_dir, project_id)? {\n        return Err(AppError::ProjectNotFound {\n            project_id: project_id.to_string(),\n        });\n    }\n\n    // Check for active run\n    let run_snapshot = run_port.read_run_snapshot(base_dir, project_id)?;\n    if run_snapshot.has_active_run() {\n        return Err(AppError::ActiveRunDelete {\n            project_id: project_id.to_string(),\n        });\n    }\n\n    // Check if this is the active project (before delete)\n    let active_id = active_port.read_active_project_id(base_dir)?;\n    let was_active = active_id.as_deref() == Some(project_id.as_str());\n\n    // Phase 1: Stage the delete — project becomes invisible to list/show\n    // but data remains on disk for rollback.\n    store.stage_delete(base_dir, project_id)?;\n\n    // Phase 2: Clear the active-project pointer if needed.\n    // If this fails, roll back the staged delete so the project remains\n    // addressable and the pointer is unchanged.\n    if was_active {\n        if let Err(clear_err) = active_port.clear_active_project(base_dir) {\n            store\n                .rollback_delete(base_dir, project_id)\n                .map_err(|restore_err| AppError::CorruptRecord {\n                    file: format!(\"projects/{}\", project_id),\n                    details: format!(\n                        \"delete partially failed: pointer clear error: {}, restore error: {}\",\n                        clear_err, restore_err\n                    ),\n                })?;\n            return Err(clear_err);\n        }\n    }\n\n    // Phase 3: Finalize — permanently remove the project data.\n    // At this point the logical delete has succeeded (project is invisible,\n    // pointer is cleared). Best-effort cleanup of the staged data.\n    let _ = store.commit_delete(base_dir, project_id);\n\n    Ok(())\n}\n\n/// Get run status for the active project.\npub fn run_status(\n    run_port: &dyn RunSnapshotPort,\n    base_dir: &Path,\n    project_id: &ProjectId,\n) -> AppResult<RunStatusView> {\n    let snapshot = run_port.read_run_snapshot(base_dir, project_id)?;\n    Ok(queries::build_status_view(project_id.as_str(), &snapshot))\n}\n\n/// Get run history (durable only, no runtime logs).\npub fn run_history(\n    journal_port: &dyn JournalStorePort,\n    artifact_port: &dyn ArtifactStorePort,\n    base_dir: &Path,\n    project_id: &ProjectId,\n) -> AppResult<RunHistoryView> {\n    let events = journal_port.read_journal(base_dir, project_id)?;\n    let payloads = artifact_port.list_payloads(base_dir, project_id)?;\n    let artifacts = artifact_port.list_artifacts(base_dir, project_id)?;\n\n    queries::validate_history_consistency(&payloads, &artifacts)?;\n\n    Ok(queries::build_history_view(\n        project_id.as_str(),\n        events,\n        payloads,\n        artifacts,\n    ))\n}\n\n/// Get run tail: durable history by default, with optional runtime logs.\npub fn run_tail(\n    journal_port: &dyn JournalStorePort,\n    artifact_port: &dyn ArtifactStorePort,\n    log_port: &dyn RuntimeLogStorePort,\n    base_dir: &Path,\n    project_id: &ProjectId,\n    include_logs: bool,\n) -> AppResult<RunTailView> {\n    let events = journal_port.read_journal(base_dir, project_id)?;\n    let payloads = artifact_port.list_payloads(base_dir, project_id)?;\n    let artifacts = artifact_port.list_artifacts(base_dir, project_id)?;\n\n    queries::validate_history_consistency(&payloads, &artifacts)?;\n\n    let runtime_logs = if include_logs {\n        log_port.read_runtime_logs(base_dir, project_id)?\n    } else {\n        Vec::new()\n    };\n\n    Ok(queries::build_tail_view(\n        project_id.as_str(),\n        events,\n        payloads,\n        artifacts,\n        include_logs,\n        runtime_logs,\n    ))\n}\n","numLines":344,"startLine":1,"totalLines":344}}}
