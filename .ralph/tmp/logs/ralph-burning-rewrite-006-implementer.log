{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01GtXiPQ54jo2aq2qTWjKXZq","type":"tool_result","content":"     1→#![forbid(unsafe_code)]\n     2→\n     3→//! Typed stage payload models for each contract family.\n     4→//!\n     5→//! Three payload families cover all 16 stages:\n     6→//! - **Planning**: prompt_review, planning, docs_plan, ci_plan\n     7→//! - **Execution**: implementation, plan_and_implement, apply_fixes, docs_update, ci_update\n     8→//! - **Validation**: qa, docs_validation, ci_validation, acceptance_qa, review, final_review,\n     9→//!   completion_panel\n    10→\n    11→use schemars::JsonSchema;\n    12→use serde::{Deserialize, Serialize};\n    13→\n    14→// ── Planning family ─────────────────────────────────────────────────────────\n    15→\n    16→/// Payload for planning-style stages.\n    17→///\n    18→/// Requires structured problem framing, assumptions or open questions,\n    19→/// ordered proposed work, and explicit readiness/risk fields.\n    20→#[derive(Debug, Clone, PartialEq, Eq, Serialize, Deserialize, JsonSchema)]\n    21→pub struct PlanningPayload {\n    22→    pub problem_framing: String,\n    23→    pub assumptions_or_open_questions: Vec<String>,\n    24→    pub proposed_work: Vec<ProposedWorkItem>,\n    25→    pub readiness: ReadinessAssessment,\n    26→}\n    27→\n    28→#[derive(Debug, Clone, PartialEq, Eq, Serialize, Deserialize, JsonSchema)]\n    29→pub struct ProposedWorkItem {\n    30→    pub order: u32,\n    31→    pub summary: String,\n    32→    pub details: String,\n    33→}\n    34→\n    35→#[derive(Debug, Clone, PartialEq, Eq, Serialize, Deserialize, JsonSchema)]\n    36→pub struct ReadinessAssessment {\n    37→    pub ready: bool,\n    38→    pub risks: Vec<String>,\n    39→}\n    40→\n    41→// ── Execution family ────────────────────────────────────────────────────────\n    42→\n    43→/// Payload for execution/update stages.\n    44→///\n    45→/// Requires structured change summaries, intended or completed steps,\n    46→/// validation evidence or plans, and outstanding-risk fields.\n    47→#[derive(Debug, Clone, PartialEq, Eq, Serialize, Deserialize, JsonSchema)]\n    48→pub struct ExecutionPayload {\n    49→    pub change_summary: String,\n    50→    pub steps: Vec<ExecutionStep>,\n    51→    pub validation_evidence: Vec<String>,\n    52→    pub outstanding_risks: Vec<String>,\n    53→}\n    54→\n    55→#[derive(Debug, Clone, PartialEq, Eq, Serialize, Deserialize, JsonSchema)]\n    56→pub struct ExecutionStep {\n    57→    pub order: u32,\n    58→    pub description: String,\n    59→    pub status: StepStatus,\n    60→}\n    61→\n    62→#[derive(Debug, Clone, Copy, PartialEq, Eq, Serialize, Deserialize, JsonSchema)]\n    63→#[serde(rename_all = \"snake_case\")]\n    64→pub enum StepStatus {\n    65→    Intended,\n    66→    Completed,\n    67→    Skipped,\n    68→}\n    69→\n    70→impl std::fmt::Display for StepStatus {\n    71→    fn fmt(&self, f: &mut std::fmt::Formatter<'_>) -> std::fmt::Result {\n    72→        match self {\n    73→            Self::Intended => f.write_str(\"Intended\"),\n    74→            Self::Completed => f.write_str(\"Completed\"),\n    75→            Self::Skipped => f.write_str(\"Skipped\"),\n    76→        }\n    77→    }\n    78→}\n    79→\n    80→// ── Validation / Review family ──────────────────────────────────────────────\n    81→\n    82→/// Payload for validation/review stages.\n    83→///\n    84→/// Requires an explicit outcome/decision enum plus evidence, findings or gaps,\n    85→/// and follow-up or amendment data when the outcome is not cleanly approved.\n    86→#[derive(Debug, Clone, PartialEq, Eq, Serialize, Deserialize, JsonSchema)]\n    87→pub struct ValidationPayload {\n    88→    pub outcome: ReviewOutcome,\n    89→    pub evidence: Vec<String>,\n    90→    pub findings_or_gaps: Vec<String>,\n    91→    pub follow_up_or_amendments: Vec<String>,\n    92→}\n    93→\n    94→#[derive(Debug, Clone, Copy, PartialEq, Eq, Serialize, Deserialize, JsonSchema)]\n    95→#[serde(rename_all = \"snake_case\")]\n    96→pub enum ReviewOutcome {\n    97→    Approved,\n    98→    ConditionallyApproved,\n    99→    RequestChanges,\n   100→    Rejected,\n   101→}\n   102→\n   103→impl ReviewOutcome {\n   104→    /// Returns `true` only for a clean approval with no conditions.\n   105→    pub fn is_passing(self) -> bool {\n   106→        matches!(self, Self::Approved)\n   107→    }\n   108→}\n   109→\n   110→impl std::fmt::Display for ReviewOutcome {\n   111→    fn fmt(&self, f: &mut std::fmt::Formatter<'_>) -> std::fmt::Result {\n   112→        match self {\n   113→            Self::Approved => f.write_str(\"Approved\"),\n   114→            Self::ConditionallyApproved => f.write_str(\"Conditionally Approved\"),\n   115→            Self::RequestChanges => f.write_str(\"Request Changes\"),\n   116→            Self::Rejected => f.write_str(\"Rejected\"),\n   117→        }\n   118→    }\n   119→}\n   120→\n   121→// ── Wrapper enum ────────────────────────────────────────────────────────────\n   122→\n   123→/// Typed stage payload, wrapping one of the three contract families.\n   124→#[derive(Debug, Clone, PartialEq, Eq, Serialize, Deserialize)]\n   125→#[serde(tag = \"family\", content = \"data\")]\n   126→pub enum StagePayload {\n   127→    Planning(PlanningPayload),\n   128→    Execution(ExecutionPayload),\n   129→    Validation(ValidationPayload),\n   130→}\n   131→"}]},"parent_tool_use_id":"toolu_01VwuMdbo4Yfw9qb7NhghzrF","session_id":"19a33b10-b5a0-4ba2-8943-a7efa3e34818","uuid":"ffe83329-de1f-405f-b126-84f987b9db8d"}
