{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_015PVSQAo4HWyYP4weXDpR92","type":"tool_result","content":"     1→use std::path::PathBuf;\n     2→\n     3→use thiserror::Error;\n     4→\n     5→use crate::shared::domain::{FailureClass, StageId};\n     6→\n     7→pub type AppResult<T> = Result<T, AppError>;\n     8→\n     9→#[derive(Debug, Error)]\n    10→pub enum AppError {\n    11→    #[error(\"workspace already initialized at {path}\")]\n    12→    AlreadyInitialized { path: PathBuf },\n    13→    #[error(\n    14→        \"cannot initialize workspace because {path} already exists without a workspace configuration\"\n    15→    )]\n    16→    WorkspaceConflict { path: PathBuf },\n    17→    #[error(\"invalid {field}: must be greater than zero\")]\n    18→    InvalidStageCursorField { field: &'static str },\n    19→    #[error(\"invalid identifier '{value}': identifiers must be non-empty single path segments\")]\n    20→    InvalidIdentifier { value: String },\n    21→    #[error(\n    22→        \"unknown flow preset '{flow_id}'. supported presets: standard, quick_dev, docs_change, ci_improvement\"\n    23→    )]\n    24→    InvalidFlowPreset { flow_id: String },\n    25→    #[error(\"unsupported workspace version {version}; supported version is {supported}\")]\n    26→    UnsupportedWorkspaceVersion { version: u32, supported: u32 },\n    27→    #[error(\n    28→        \"unknown config key '{key}'. supported keys: prompt_review.enabled, default_flow, default_backend, default_model\"\n    29→    )]\n    30→    UnknownConfigKey { key: String },\n    31→    #[error(\"invalid value '{value}' for config key '{key}': {reason}\")]\n    32→    InvalidConfigValue {\n    33→        key: String,\n    34→        value: String,\n    35→        reason: String,\n    36→    },\n    37→    #[error(\"no active project selected; run `ralph-burning project select <id>`\")]\n    38→    NoActiveProject,\n    39→    #[error(\n    40→        \"project '{project_id}' was not found under .ralph-burning/projects/ or is missing project.toml\"\n    41→    )]\n    42→    ProjectNotFound { project_id: String },\n    43→    #[error(\"editor '{editor}' failed{details}\")]\n    44→    EditorFailed { editor: String, details: String },\n    45→    #[error(\"project '{project_id}' already exists\")]\n    46→    DuplicateProject { project_id: String },\n    47→    #[error(\"corrupt record in {file}: {details}\")]\n    48→    CorruptRecord { file: String, details: String },\n    49→    #[error(\"invalid prompt file '{path}': {reason}\")]\n    50→    InvalidPrompt { path: String, reason: String },\n    51→    #[error(\"cannot delete project '{project_id}': it has an active run\")]\n    52→    ActiveRunDelete { project_id: String },\n    53→    #[error(\"journal sequence error: {details}\")]\n    54→    JournalSequence { details: String },\n    55→    #[error(\"cannot start run: {reason}\")]\n    56→    RunStartFailed { reason: String },\n    57→    #[error(\"flow '{flow_id}' is not yet supported for `run start`; only 'standard' is supported in this slice\")]\n    58→    UnsupportedFlow { flow_id: String },\n    59→    #[error(\"preflight check failed for stage '{stage_id}': {details}\")]\n    60→    PreflightFailed { stage_id: StageId, details: String },\n    61→    #[error(\"stage commit failed for stage '{stage_id}': {details}\")]\n    62→    StageCommitFailed { stage_id: StageId, details: String },\n    63→    #[error(\"{command} is not yet implemented\")]\n    64→    NotYetImplemented { command: String },\n    65→    #[error(\"backend '{backend}' is unavailable: {details}\")]\n    66→    BackendUnavailable { backend: String, details: String },\n    67→    #[error(\"backend '{backend}' cannot satisfy stage '{stage_id}': {details}\")]\n    68→    CapabilityMismatch {\n    69→        backend: String,\n    70→        stage_id: StageId,\n    71→        details: String,\n    72→    },\n    73→    #[error(\"backend invocation failed for stage '{stage_id}' via '{backend}': {details}\")]\n    74→    InvocationFailed {\n    75→        backend: String,\n    76→        stage_id: StageId,\n    77→        failure_class: FailureClass,\n    78→        details: String,\n    79→    },\n    80→    #[error(\n    81→        \"backend invocation timed out for stage '{stage_id}' via '{backend}' after {timeout_ms} ms\"\n    82→    )]\n    83→    InvocationTimeout {\n    84→        backend: String,\n    85→        stage_id: StageId,\n    86→        timeout_ms: u64,\n    87→    },\n    88→    #[error(\"backend invocation cancelled for stage '{stage_id}' via '{backend}'\")]\n    89→    InvocationCancelled { backend: String, stage_id: StageId },\n    90→    #[error(transparent)]\n    91→    Io(#[from] std::io::Error),\n    92→    #[error(transparent)]\n    93→    TomlDeserialize(#[from] toml::de::Error),\n    94→    #[error(transparent)]\n    95→    TomlSerialize(#[from] toml::ser::Error),\n    96→    #[error(transparent)]\n    97→    TomlEdit(#[from] toml_edit::TomlError),\n    98→    #[error(transparent)]\n    99→    SerdeJson(#[from] serde_json::Error),\n   100→}\n   101→\n   102→/// Errors specific to stage contract evaluation.\n   103→///\n   104→/// Each variant maps to a distinct [`FailureClass`] for retry/terminal policy.\n   105→#[derive(Debug, Error)]\n   106→pub enum ContractError {\n   107→    #[error(\"schema validation failed for stage '{stage_id}': {details}\")]\n   108→    SchemaValidation { stage_id: StageId, details: String },\n   109→\n   110→    #[error(\"domain validation failed for stage '{stage_id}': {details}\")]\n   111→    DomainValidation { stage_id: StageId, details: String },\n   112→\n   113→    #[error(\"rendering failed for stage '{stage_id}': {details}\")]\n   114→    RenderError { stage_id: StageId, details: String },\n   115→\n   116→    #[error(\"non-passing QA/review outcome for stage '{stage_id}': {outcome}\")]\n   117→    QaReviewOutcome { stage_id: StageId, outcome: String },\n   118→}\n   119→\n   120→impl ContractError {\n   121→    pub fn failure_class(&self) -> FailureClass {\n   122→        match self {\n   123→            Self::SchemaValidation { .. } => FailureClass::SchemaValidationFailure,\n   124→            Self::DomainValidation { .. } | Self::RenderError { .. } => {\n   125→                FailureClass::DomainValidationFailure\n   126→            }\n   127→            Self::QaReviewOutcome { .. } => FailureClass::QaReviewOutcomeFailure,\n   128→        }\n   129→    }\n   130→\n   131→    pub fn stage_id(&self) -> StageId {\n   132→        match self {\n   133→            Self::SchemaValidation { stage_id, .. }\n   134→            | Self::DomainValidation { stage_id, .. }\n   135→            | Self::RenderError { stage_id, .. }\n   136→            | Self::QaReviewOutcome { stage_id, .. } => *stage_id,\n   137→        }\n   138→    }\n   139→}\n   140→\n   141→impl AppError {\n   142→    pub fn failure_class(&self) -> Option<FailureClass> {\n   143→        match self {\n   144→            Self::BackendUnavailable { .. } => Some(FailureClass::TransportFailure),\n   145→            Self::CapabilityMismatch { .. } => Some(FailureClass::DomainValidationFailure),\n   146→            Self::InvocationFailed { failure_class, .. } => Some(*failure_class),\n   147→            Self::InvocationTimeout { .. } => Some(FailureClass::Timeout),\n   148→            Self::InvocationCancelled { .. } => Some(FailureClass::Cancellation),\n   149→            _ => None,\n   150→        }\n   151→    }\n   152→}\n   153→"}]},"parent_tool_use_id":"toolu_01VwuMdbo4Yfw9qb7NhghzrF","session_id":"19a33b10-b5a0-4ba2-8943-a7efa3e34818","uuid":"a818b3e8-0485-4552-8a05-79a2168215e2"}
