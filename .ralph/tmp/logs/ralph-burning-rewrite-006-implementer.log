{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01TFBLceEb2gh3TXHBUmo71k","type":"tool_result","content":"     1→use std::path::{Path, PathBuf};\n     2→use std::time::Duration;\n     3→\n     4→use chrono::Utc;\n     5→\n     6→use crate::contexts::agent_execution::model::{\n     7→    CancellationToken, InvocationPayload, InvocationRequest,\n     8→};\n     9→use crate::contexts::agent_execution::service::{\n    10→    AgentExecutionPort, BackendSelectionConfig, RawOutputPort,\n    11→};\n    12→use crate::contexts::agent_execution::session::SessionStorePort;\n    13→use crate::contexts::agent_execution::AgentExecutionService;\n    14→use crate::contexts::project_run_record::journal;\n    15→use crate::contexts::project_run_record::model::{\n    16→    ActiveRun, ArtifactRecord, LogLevel, PayloadRecord, RunSnapshot, RunStatus, RuntimeLogEntry,\n    17→};\n    18→use crate::contexts::project_run_record::service::{\n    19→    JournalStorePort, PayloadArtifactWritePort, RunSnapshotPort, RunSnapshotWritePort,\n    20→    RuntimeLogWritePort,\n    21→};\n    22→use crate::contexts::workspace_governance::config::EffectiveConfig;\n    23→use crate::shared::domain::{\n    24→    BackendRole, FlowPreset, ProjectId, ResolvedBackendTarget, RunId, SessionPolicy, StageCursor,\n    25→    StageId,\n    26→};\n    27→use crate::shared::error::{AppError, AppResult};\n    28→\n    29→use super::contracts;\n    30→\n    31→/// Derives the executable stage plan for the standard flow given prompt_review config.\n    32→pub fn standard_stage_plan(prompt_review_enabled: bool) -> Vec<StageId> {\n    33→    let flow_def = super::flow_definition(FlowPreset::Standard);\n    34→    if prompt_review_enabled {\n    35→        flow_def.stages.to_vec()\n    36→    } else {\n    37→        flow_def\n    38→            .stages\n    39→            .iter()\n    40→            .copied()\n    41→            .filter(|s| *s != StageId::PromptReview)\n    42→            .collect()\n    43→    }\n    44→}\n    45→\n    46→/// Deterministic stage-to-role mapping per spec.\n    47→pub fn role_for_stage(stage_id: StageId) -> BackendRole {\n    48→    BackendRole::for_stage(stage_id)\n    49→}\n    50→\n    51→/// Resolved target per stage for preflight.\n    52→pub struct StagePlan {\n    53→    pub stage_id: StageId,\n    54→    pub role: BackendRole,\n    55→    pub contract: contracts::StageContract,\n    56→    pub target: ResolvedBackendTarget,\n    57→}\n    58→\n    59→/// Resolve all stage targets ahead of execution for preflight validation.\n    60→pub fn resolve_stage_plan(\n    61→    stages: &[StageId],\n    62→    resolver: &crate::contexts::agent_execution::service::BackendResolver,\n    63→    workspace_defaults: Option<&BackendSelectionConfig>,\n    64→) -> AppResult<Vec<StagePlan>> {\n    65→    let mut plan = Vec::with_capacity(stages.len());\n    66→    for &stage_id in stages {\n    67→        let role = role_for_stage(stage_id);\n    68→        let contract = contracts::contract_for_stage(stage_id);\n    69→        let target = resolver.resolve(role, None, None, workspace_defaults)?;\n    70→        plan.push(StagePlan {\n    71→            stage_id,\n    72→            role,\n    73→            contract,\n    74→            target,\n    75→        });\n    76→    }\n    77→    Ok(plan)\n    78→}\n    79→\n    80→/// Preflight: check capability and availability for every stage target.\n    81→pub async fn preflight_check<A: AgentExecutionPort>(\n    82→    adapter: &A,\n    83→    plan: &[StagePlan],\n    84→) -> AppResult<()> {\n    85→    for entry in plan {\n    86→        adapter\n    87→            .check_capability(&entry.target, &entry.contract)\n    88→            .await\n    89→            .map_err(|e| AppError::PreflightFailed {\n    90→                stage_id: entry.stage_id,\n    91→                details: e.to_string(),\n    92→            })?;\n    93→        adapter\n    94→            .check_availability(&entry.target)\n    95→            .await\n    96→            .map_err(|e| AppError::PreflightFailed {\n    97→                stage_id: entry.stage_id,\n    98→                details: e.to_string(),\n    99→            })?;\n   100→    }\n   101→    Ok(())\n   102→}\n   103→\n   104→/// Generate a new run ID from a timestamp.\n   105→fn generate_run_id() -> AppResult<RunId> {\n   106→    let now = Utc::now();\n   107→    RunId::new(format!(\"run-{}\", now.format(\"%Y%m%d%H%M%S\")))\n   108→}\n   109→\n   110→/// The standard-flow orchestration engine.\n   111→///\n   112→/// Executes all enabled standard stages in canonical order against the provided\n   113→/// backend adapter, persisting validated payloads and rendered artifacts at\n   114→/// durable stage boundaries.\n   115→#[allow(clippy::too_many_arguments)]\n   116→pub async fn execute_standard_run<A, R, S>(\n   117→    agent_service: &AgentExecutionService<A, R, S>,\n   118→    run_snapshot_read: &dyn RunSnapshotPort,\n   119→    run_snapshot_write: &dyn RunSnapshotWritePort,\n   120→    journal_store: &dyn JournalStorePort,\n   121→    artifact_write: &dyn PayloadArtifactWritePort,\n   122→    log_write: &dyn RuntimeLogWritePort,\n   123→    base_dir: &Path,\n   124→    project_id: &ProjectId,\n   125→    effective_config: &EffectiveConfig,\n   126→) -> AppResult<()>\n   127→where\n   128→    A: AgentExecutionPort,\n   129→    R: RawOutputPort,\n   130→    S: SessionStorePort,\n   131→{\n   132→    // 1. Read current snapshot and validate preconditions\n   133→    let snapshot = run_snapshot_read.read_run_snapshot(base_dir, project_id)?;\n   134→\n   135→    if snapshot.status != RunStatus::NotStarted {\n   136→        return Err(AppError::RunStartFailed {\n   137→            reason: format!(\n   138→                \"project snapshot status is '{}'; run start requires 'not_started'\",\n   139→                snapshot.status\n   140→            ),\n   141→        });\n   142→    }\n   143→    if snapshot.has_active_run() {\n   144→        return Err(AppError::RunStartFailed {\n   145→            reason: \"project already has an active run\".to_owned(),\n   146→        });\n   147→    }\n   148→\n   149→    // 2. Derive the stage plan\n   150→    let prompt_review_enabled = effective_config.prompt_review_enabled();\n   151→    let stages = standard_stage_plan(prompt_review_enabled);\n   152→\n   153→    // 3. Resolve backend targets for every stage\n   154→    let workspace_defaults = BackendSelectionConfig::from_effective_config(effective_config)?;\n   155→    let stage_plan = resolve_stage_plan(\n   156→        stages.as_slice(),\n   157→        agent_service.resolver(),\n   158→        Some(&workspace_defaults),\n   159→    )?;\n   160→\n   161→    // 4. Preflight checks — if any fail, leave all state unchanged\n   162→    preflight_check(agent_service.adapter(), &stage_plan).await?;\n   163→\n   164→    // 5. Generate run ID and read journal for sequence tracking\n   165→    let run_id = generate_run_id()?;\n   166→    let now = Utc::now();\n   167→    let events = journal_store.read_journal(base_dir, project_id)?;\n   168→    let mut seq = journal::last_sequence(&events);\n   169→\n   170→    let first_stage = stage_plan[0].stage_id;\n   171→\n   172→    // 6. Persist run_started: create run.json with running status + journal events\n   173→    seq += 1;\n   174→    let run_started = journal::run_started_event(seq, now, &run_id, first_stage);\n   175→    let run_started_line = journal::serialize_event(&run_started)?;\n   176→    journal_store.append_event(base_dir, project_id, &run_started_line)?;\n   177→\n   178→    let initial_cursor = StageCursor::initial(first_stage);\n   179→    let mut current_snapshot = RunSnapshot {\n   180→        active_run: Some(ActiveRun {\n   181→            run_id: run_id.as_str().to_owned(),\n   182→            stage_cursor: initial_cursor.clone(),\n   183→            started_at: now,\n   184→        }),\n   185→        status: RunStatus::Running,\n   186→        cycle_history: vec![],\n   187→        completion_rounds: 1,\n   188→        rollback_point_meta: snapshot.rollback_point_meta.clone(),\n   189→        amendment_queue: snapshot.amendment_queue.clone(),\n   190→        status_summary: format!(\"running: {}\", first_stage.display_name()),\n   191→    };\n   192→    run_snapshot_write.write_run_snapshot(base_dir, project_id, &current_snapshot)?;\n   193→\n   194→    let project_root = project_root_path(base_dir, project_id);\n   195→\n   196→    // 7. Execute stages in order\n   197→    for (idx, stage_entry) in stage_plan.iter().enumerate() {\n   198→        let stage_id = stage_entry.stage_id;\n   199→        let cursor = StageCursor::initial(stage_id);\n   200→\n   201→        // Emit stage_entered\n   202→        seq += 1;\n   203→        let stage_entered = journal::stage_entered_event(\n   204→            seq,\n   205→            Utc::now(),\n   206→            &run_id,\n   207→            stage_id,\n   208→            cursor.cycle,\n   209→            cursor.attempt,\n   210→        );\n   211→        let stage_entered_line = journal::serialize_event(&stage_entered)?;\n   212→        journal_store.append_event(base_dir, project_id, &stage_entered_line)?;\n   213→\n   214→        // Update cursor in snapshot\n   215→        current_snapshot.active_run.as_mut().unwrap().stage_cursor = cursor.clone();\n   216→        current_snapshot.status_summary = format!(\"running: {}\", stage_id.display_name());\n   217→        run_snapshot_write.write_run_snapshot(base_dir, project_id, &current_snapshot)?;\n   218→\n   219→        // Best-effort runtime log\n   220→        let _ = log_write.append_runtime_log(\n   221→            base_dir,\n   222→            project_id,\n   223→            &RuntimeLogEntry {\n   224→                timestamp: Utc::now(),\n   225→                level: LogLevel::Info,\n   226→                source: \"engine\".to_owned(),\n   227→                message: format!(\"stage_entered: {}\", stage_id.as_str()),\n   228→            },\n   229→        );\n   230→\n   231→        // Invoke the backend\n   232→        let invocation_id = format!(\n   233→            \"{}-{}-c{}-a{}\",\n   234→            run_id.as_str(),\n   235→            stage_id.as_str(),\n   236→            cursor.cycle,\n   237→            cursor.attempt\n   238→        );\n   239→        let request = InvocationRequest {\n   240→            invocation_id,\n   241→            project_root: project_root.clone(),\n   242→            stage_contract: stage_entry.contract,\n   243→            role: stage_entry.role,\n   244→            resolved_target: stage_entry.target.clone(),\n   245→            payload: InvocationPayload {\n   246→                prompt: format!(\"Execute stage: {}\", stage_id.display_name()),\n   247→                context: serde_json::json!({}),\n   248→            },\n   249→            timeout: Duration::from_secs(300),\n   250→            cancellation_token: CancellationToken::new(),\n   251→            session_policy: SessionPolicy::ReuseIfAllowed,\n   252→            prior_session: None,\n   253→            attempt_number: cursor.attempt,\n   254→        };\n   255→\n   256→        let envelope = match agent_service.invoke(request).await {\n   257→            Ok(env) => env,\n   258→            Err(e) => {\n   259→                return fail_run(\n   260→                    &e,\n   261→                    stage_id,\n   262→                    &run_id,\n   263→                    &mut seq,\n   264→                    &mut current_snapshot,\n   265→                    journal_store,\n   266→                    run_snapshot_write,\n   267→                    base_dir,\n   268→                    project_id,\n   269→                )\n   270→                .await;\n   271→            }\n   272→        };\n   273→\n   274→        // Evaluate the contract (schema + domain + outcome + render)\n   275→        let bundle = match stage_entry.contract.evaluate(&envelope.parsed_payload) {\n   276→            Ok(bundle) => bundle,\n   277→            Err(contract_err) => {\n   278→                let app_err = AppError::InvocationFailed {\n   279→                    backend: stage_entry.target.backend.family.to_string(),\n   280→                    stage_id,\n   281→                    failure_class: contract_err.failure_class(),\n   282→                    details: contract_err.to_string(),\n   283→                };\n   284→                return fail_run(\n   285→                    &app_err,\n   286→                    stage_id,\n   287→                    &run_id,\n   288→                    &mut seq,\n   289→                    &mut current_snapshot,\n   290→                    journal_store,\n   291→                    run_snapshot_write,\n   292→                    base_dir,\n   293→                    project_id,\n   294→                )\n   295→                .await;\n   296→            }\n   297→        };\n   298→\n   299→        // Persist payload + artifact pair atomically\n   300→        let stage_now = Utc::now();\n   301→        let payload_id = format!(\n   302→            \"{}-{}-c{}-a{}\",\n   303→            run_id.as_str(),\n   304→            stage_id.as_str(),\n   305→            cursor.cycle,\n   306→            cursor.attempt\n   307→        );\n   308→        let artifact_id = format!(\"{}-artifact\", payload_id);\n   309→\n   310→        let payload_record = PayloadRecord {\n   311→            payload_id: payload_id.clone(),\n   312→            stage_id,\n   313→            cycle: cursor.cycle,\n   314→            attempt: cursor.attempt,\n   315→            created_at: stage_now,\n   316→            payload: serde_json::to_value(&bundle.payload)?,\n   317→        };\n   318→        let artifact_record = ArtifactRecord {\n   319→            artifact_id: artifact_id.clone(),\n   320→            payload_id: payload_id.clone(),\n   321→            stage_id,\n   322→            created_at: stage_now,\n   323→            content: bundle.artifact.clone(),\n   324→        };\n   325→\n   326→        // Atomic stage commit: payload + artifact + journal + snapshot\n   327→        artifact_write\n   328→            .write_payload_artifact_pair(base_dir, project_id, &payload_record, &artifact_record)\n   329→            .map_err(|e| AppError::StageCommitFailed {\n   330→                stage_id,\n   331→                details: format!(\"payload/artifact persistence failed: {}\", e),\n   332→            })?;\n   333→\n   334→        // stage_completed journal event\n   335→        seq += 1;\n   336→        let stage_completed = journal::stage_completed_event(\n   337→            seq,\n   338→            Utc::now(),\n   339→            &run_id,\n   340→            stage_id,\n   341→            cursor.cycle,\n   342→            cursor.attempt,\n   343→            &payload_id,\n   344→            &artifact_id,\n   345→        );\n   346→        let stage_completed_line = journal::serialize_event(&stage_completed)?;\n   347→        if let Err(e) = journal_store.append_event(base_dir, project_id, &stage_completed_line) {\n   348→            return Err(AppError::StageCommitFailed {\n   349→                stage_id,\n   350→                details: format!(\"journal append failed after payload/artifact write: {}\", e),\n   351→            });\n   352→        }\n   353→\n   354→        // Update snapshot cursor to reflect completed stage\n   355→        if idx + 1 < stage_plan.len() {\n   356→            let next_stage = stage_plan[idx + 1].stage_id;\n   357→            current_snapshot.active_run.as_mut().unwrap().stage_cursor =\n   358→                StageCursor::initial(next_stage);\n   359→            current_snapshot.status_summary = format!(\n   360→                \"running: completed {}, next {}\",\n   361→                stage_id.display_name(),\n   362→                next_stage.display_name()\n   363→            );\n   364→        }\n   365→        run_snapshot_write.write_run_snapshot(base_dir, project_id, &current_snapshot)?;\n   366→\n   367→        // Best-effort runtime log\n   368→        let _ = log_write.append_runtime_log(\n   369→            base_dir,\n   370→            project_id,\n   371→            &RuntimeLogEntry {\n   372→                timestamp: Utc::now(),\n   373→                level: LogLevel::Info,\n   374→                source: \"engine\".to_owned(),\n   375→                message: format!(\"stage_completed: {}\", stage_id.as_str()),\n   376→            },\n   377→        );\n   378→    }\n   379→\n   380→    // 8. All stages completed — mark run as completed\n   381→    seq += 1;\n   382→    let run_completed = journal::run_completed_event(seq, Utc::now(), &run_id, 1);\n   383→    let run_completed_line = journal::serialize_event(&run_completed)?;\n   384→    journal_store.append_event(base_dir, project_id, &run_completed_line)?;\n   385→\n   386→    current_snapshot.status = RunStatus::Completed;\n   387→    current_snapshot.active_run = None;\n   388→    current_snapshot.completion_rounds = 1;\n   389→    current_snapshot.status_summary = \"completed\".to_owned();\n   390→    run_snapshot_write.write_run_snapshot(base_dir, project_id, &current_snapshot)?;\n   391→\n   392→    Ok(())\n   393→}\n   394→\n   395→/// Record a run failure: persist journal event, update snapshot, return error.\n   396→#[allow(clippy::too_many_arguments)]\n   397→async fn fail_run(\n   398→    err: &AppError,\n   399→    stage_id: StageId,\n   400→    run_id: &RunId,\n   401→    seq: &mut u64,\n   402→    snapshot: &mut RunSnapshot,\n   403→    journal_store: &dyn JournalStorePort,\n   404→    run_snapshot_write: &dyn RunSnapshotWritePort,\n   405→    base_dir: &Path,\n   406→    project_id: &ProjectId,\n   407→) -> AppResult<()> {\n   408→    let failure_class = err\n   409→        .failure_class()\n   410→        .map(|fc| format!(\"{:?}\", fc))\n   411→        .unwrap_or_else(|| \"unknown\".to_owned());\n   412→    let message = err.to_string();\n   413→\n   414→    *seq += 1;\n   415→    let run_failed =\n   416→        journal::run_failed_event(*seq, Utc::now(), run_id, stage_id, &failure_class, &message);\n   417→    let run_failed_line = journal::serialize_event(&run_failed)?;\n   418→    journal_store.append_event(base_dir, project_id, &run_failed_line)?;\n   419→\n   420→    snapshot.status = RunStatus::Failed;\n   421→    snapshot.active_run = None;\n   422→    snapshot.status_summary = format!(\"failed at {}: {}\", stage_id.display_name(), message);\n   423→    run_snapshot_write.write_run_snapshot(base_dir, project_id, snapshot)?;\n   424→\n   425→    Err(AppError::RunStartFailed {\n   426→        reason: format!(\"stage {} failed: {}\", stage_id.as_str(), message),\n   427→    })\n   428→}\n   429→\n   430→/// Helper to get project root path.\n   431→fn project_root_path(base_dir: &Path, project_id: &ProjectId) -> PathBuf {\n   432→    base_dir\n   433→        .join(\".ralph-burning\")\n   434→        .join(\"projects\")\n   435→        .join(project_id.as_str())\n   436→}\n   437→"}]},"parent_tool_use_id":null,"session_id":"b9859e69-5579-4e82-ac66-49d19cc80e05","uuid":"1e4f7b2c-e934-4144-87f7-c6afd288f434","tool_use_result":{"type":"text","file":{"filePath":"/root/new-ralph-burning/ralph-burning-rewrite/src/contexts/workflow_composition/engine.rs","content":"use std::path::{Path, PathBuf};\nuse std::time::Duration;\n\nuse chrono::Utc;\n\nuse crate::contexts::agent_execution::model::{\n    CancellationToken, InvocationPayload, InvocationRequest,\n};\nuse crate::contexts::agent_execution::service::{\n    AgentExecutionPort, BackendSelectionConfig, RawOutputPort,\n};\nuse crate::contexts::agent_execution::session::SessionStorePort;\nuse crate::contexts::agent_execution::AgentExecutionService;\nuse crate::contexts::project_run_record::journal;\nuse crate::contexts::project_run_record::model::{\n    ActiveRun, ArtifactRecord, LogLevel, PayloadRecord, RunSnapshot, RunStatus, RuntimeLogEntry,\n};\nuse crate::contexts::project_run_record::service::{\n    JournalStorePort, PayloadArtifactWritePort, RunSnapshotPort, RunSnapshotWritePort,\n    RuntimeLogWritePort,\n};\nuse crate::contexts::workspace_governance::config::EffectiveConfig;\nuse crate::shared::domain::{\n    BackendRole, FlowPreset, ProjectId, ResolvedBackendTarget, RunId, SessionPolicy, StageCursor,\n    StageId,\n};\nuse crate::shared::error::{AppError, AppResult};\n\nuse super::contracts;\n\n/// Derives the executable stage plan for the standard flow given prompt_review config.\npub fn standard_stage_plan(prompt_review_enabled: bool) -> Vec<StageId> {\n    let flow_def = super::flow_definition(FlowPreset::Standard);\n    if prompt_review_enabled {\n        flow_def.stages.to_vec()\n    } else {\n        flow_def\n            .stages\n            .iter()\n            .copied()\n            .filter(|s| *s != StageId::PromptReview)\n            .collect()\n    }\n}\n\n/// Deterministic stage-to-role mapping per spec.\npub fn role_for_stage(stage_id: StageId) -> BackendRole {\n    BackendRole::for_stage(stage_id)\n}\n\n/// Resolved target per stage for preflight.\npub struct StagePlan {\n    pub stage_id: StageId,\n    pub role: BackendRole,\n    pub contract: contracts::StageContract,\n    pub target: ResolvedBackendTarget,\n}\n\n/// Resolve all stage targets ahead of execution for preflight validation.\npub fn resolve_stage_plan(\n    stages: &[StageId],\n    resolver: &crate::contexts::agent_execution::service::BackendResolver,\n    workspace_defaults: Option<&BackendSelectionConfig>,\n) -> AppResult<Vec<StagePlan>> {\n    let mut plan = Vec::with_capacity(stages.len());\n    for &stage_id in stages {\n        let role = role_for_stage(stage_id);\n        let contract = contracts::contract_for_stage(stage_id);\n        let target = resolver.resolve(role, None, None, workspace_defaults)?;\n        plan.push(StagePlan {\n            stage_id,\n            role,\n            contract,\n            target,\n        });\n    }\n    Ok(plan)\n}\n\n/// Preflight: check capability and availability for every stage target.\npub async fn preflight_check<A: AgentExecutionPort>(\n    adapter: &A,\n    plan: &[StagePlan],\n) -> AppResult<()> {\n    for entry in plan {\n        adapter\n            .check_capability(&entry.target, &entry.contract)\n            .await\n            .map_err(|e| AppError::PreflightFailed {\n                stage_id: entry.stage_id,\n                details: e.to_string(),\n            })?;\n        adapter\n            .check_availability(&entry.target)\n            .await\n            .map_err(|e| AppError::PreflightFailed {\n                stage_id: entry.stage_id,\n                details: e.to_string(),\n            })?;\n    }\n    Ok(())\n}\n\n/// Generate a new run ID from a timestamp.\nfn generate_run_id() -> AppResult<RunId> {\n    let now = Utc::now();\n    RunId::new(format!(\"run-{}\", now.format(\"%Y%m%d%H%M%S\")))\n}\n\n/// The standard-flow orchestration engine.\n///\n/// Executes all enabled standard stages in canonical order against the provided\n/// backend adapter, persisting validated payloads and rendered artifacts at\n/// durable stage boundaries.\n#[allow(clippy::too_many_arguments)]\npub async fn execute_standard_run<A, R, S>(\n    agent_service: &AgentExecutionService<A, R, S>,\n    run_snapshot_read: &dyn RunSnapshotPort,\n    run_snapshot_write: &dyn RunSnapshotWritePort,\n    journal_store: &dyn JournalStorePort,\n    artifact_write: &dyn PayloadArtifactWritePort,\n    log_write: &dyn RuntimeLogWritePort,\n    base_dir: &Path,\n    project_id: &ProjectId,\n    effective_config: &EffectiveConfig,\n) -> AppResult<()>\nwhere\n    A: AgentExecutionPort,\n    R: RawOutputPort,\n    S: SessionStorePort,\n{\n    // 1. Read current snapshot and validate preconditions\n    let snapshot = run_snapshot_read.read_run_snapshot(base_dir, project_id)?;\n\n    if snapshot.status != RunStatus::NotStarted {\n        return Err(AppError::RunStartFailed {\n            reason: format!(\n                \"project snapshot status is '{}'; run start requires 'not_started'\",\n                snapshot.status\n            ),\n        });\n    }\n    if snapshot.has_active_run() {\n        return Err(AppError::RunStartFailed {\n            reason: \"project already has an active run\".to_owned(),\n        });\n    }\n\n    // 2. Derive the stage plan\n    let prompt_review_enabled = effective_config.prompt_review_enabled();\n    let stages = standard_stage_plan(prompt_review_enabled);\n\n    // 3. Resolve backend targets for every stage\n    let workspace_defaults = BackendSelectionConfig::from_effective_config(effective_config)?;\n    let stage_plan = resolve_stage_plan(\n        stages.as_slice(),\n        agent_service.resolver(),\n        Some(&workspace_defaults),\n    )?;\n\n    // 4. Preflight checks — if any fail, leave all state unchanged\n    preflight_check(agent_service.adapter(), &stage_plan).await?;\n\n    // 5. Generate run ID and read journal for sequence tracking\n    let run_id = generate_run_id()?;\n    let now = Utc::now();\n    let events = journal_store.read_journal(base_dir, project_id)?;\n    let mut seq = journal::last_sequence(&events);\n\n    let first_stage = stage_plan[0].stage_id;\n\n    // 6. Persist run_started: create run.json with running status + journal events\n    seq += 1;\n    let run_started = journal::run_started_event(seq, now, &run_id, first_stage);\n    let run_started_line = journal::serialize_event(&run_started)?;\n    journal_store.append_event(base_dir, project_id, &run_started_line)?;\n\n    let initial_cursor = StageCursor::initial(first_stage);\n    let mut current_snapshot = RunSnapshot {\n        active_run: Some(ActiveRun {\n            run_id: run_id.as_str().to_owned(),\n            stage_cursor: initial_cursor.clone(),\n            started_at: now,\n        }),\n        status: RunStatus::Running,\n        cycle_history: vec![],\n        completion_rounds: 1,\n        rollback_point_meta: snapshot.rollback_point_meta.clone(),\n        amendment_queue: snapshot.amendment_queue.clone(),\n        status_summary: format!(\"running: {}\", first_stage.display_name()),\n    };\n    run_snapshot_write.write_run_snapshot(base_dir, project_id, &current_snapshot)?;\n\n    let project_root = project_root_path(base_dir, project_id);\n\n    // 7. Execute stages in order\n    for (idx, stage_entry) in stage_plan.iter().enumerate() {\n        let stage_id = stage_entry.stage_id;\n        let cursor = StageCursor::initial(stage_id);\n\n        // Emit stage_entered\n        seq += 1;\n        let stage_entered = journal::stage_entered_event(\n            seq,\n            Utc::now(),\n            &run_id,\n            stage_id,\n            cursor.cycle,\n            cursor.attempt,\n        );\n        let stage_entered_line = journal::serialize_event(&stage_entered)?;\n        journal_store.append_event(base_dir, project_id, &stage_entered_line)?;\n\n        // Update cursor in snapshot\n        current_snapshot.active_run.as_mut().unwrap().stage_cursor = cursor.clone();\n        current_snapshot.status_summary = format!(\"running: {}\", stage_id.display_name());\n        run_snapshot_write.write_run_snapshot(base_dir, project_id, &current_snapshot)?;\n\n        // Best-effort runtime log\n        let _ = log_write.append_runtime_log(\n            base_dir,\n            project_id,\n            &RuntimeLogEntry {\n                timestamp: Utc::now(),\n                level: LogLevel::Info,\n                source: \"engine\".to_owned(),\n                message: format!(\"stage_entered: {}\", stage_id.as_str()),\n            },\n        );\n\n        // Invoke the backend\n        let invocation_id = format!(\n            \"{}-{}-c{}-a{}\",\n            run_id.as_str(),\n            stage_id.as_str(),\n            cursor.cycle,\n            cursor.attempt\n        );\n        let request = InvocationRequest {\n            invocation_id,\n            project_root: project_root.clone(),\n            stage_contract: stage_entry.contract,\n            role: stage_entry.role,\n            resolved_target: stage_entry.target.clone(),\n            payload: InvocationPayload {\n                prompt: format!(\"Execute stage: {}\", stage_id.display_name()),\n                context: serde_json::json!({}),\n            },\n            timeout: Duration::from_secs(300),\n            cancellation_token: CancellationToken::new(),\n            session_policy: SessionPolicy::ReuseIfAllowed,\n            prior_session: None,\n            attempt_number: cursor.attempt,\n        };\n\n        let envelope = match agent_service.invoke(request).await {\n            Ok(env) => env,\n            Err(e) => {\n                return fail_run(\n                    &e,\n                    stage_id,\n                    &run_id,\n                    &mut seq,\n                    &mut current_snapshot,\n                    journal_store,\n                    run_snapshot_write,\n                    base_dir,\n                    project_id,\n                )\n                .await;\n            }\n        };\n\n        // Evaluate the contract (schema + domain + outcome + render)\n        let bundle = match stage_entry.contract.evaluate(&envelope.parsed_payload) {\n            Ok(bundle) => bundle,\n            Err(contract_err) => {\n                let app_err = AppError::InvocationFailed {\n                    backend: stage_entry.target.backend.family.to_string(),\n                    stage_id,\n                    failure_class: contract_err.failure_class(),\n                    details: contract_err.to_string(),\n                };\n                return fail_run(\n                    &app_err,\n                    stage_id,\n                    &run_id,\n                    &mut seq,\n                    &mut current_snapshot,\n                    journal_store,\n                    run_snapshot_write,\n                    base_dir,\n                    project_id,\n                )\n                .await;\n            }\n        };\n\n        // Persist payload + artifact pair atomically\n        let stage_now = Utc::now();\n        let payload_id = format!(\n            \"{}-{}-c{}-a{}\",\n            run_id.as_str(),\n            stage_id.as_str(),\n            cursor.cycle,\n            cursor.attempt\n        );\n        let artifact_id = format!(\"{}-artifact\", payload_id);\n\n        let payload_record = PayloadRecord {\n            payload_id: payload_id.clone(),\n            stage_id,\n            cycle: cursor.cycle,\n            attempt: cursor.attempt,\n            created_at: stage_now,\n            payload: serde_json::to_value(&bundle.payload)?,\n        };\n        let artifact_record = ArtifactRecord {\n            artifact_id: artifact_id.clone(),\n            payload_id: payload_id.clone(),\n            stage_id,\n            created_at: stage_now,\n            content: bundle.artifact.clone(),\n        };\n\n        // Atomic stage commit: payload + artifact + journal + snapshot\n        artifact_write\n            .write_payload_artifact_pair(base_dir, project_id, &payload_record, &artifact_record)\n            .map_err(|e| AppError::StageCommitFailed {\n                stage_id,\n                details: format!(\"payload/artifact persistence failed: {}\", e),\n            })?;\n\n        // stage_completed journal event\n        seq += 1;\n        let stage_completed = journal::stage_completed_event(\n            seq,\n            Utc::now(),\n            &run_id,\n            stage_id,\n            cursor.cycle,\n            cursor.attempt,\n            &payload_id,\n            &artifact_id,\n        );\n        let stage_completed_line = journal::serialize_event(&stage_completed)?;\n        if let Err(e) = journal_store.append_event(base_dir, project_id, &stage_completed_line) {\n            return Err(AppError::StageCommitFailed {\n                stage_id,\n                details: format!(\"journal append failed after payload/artifact write: {}\", e),\n            });\n        }\n\n        // Update snapshot cursor to reflect completed stage\n        if idx + 1 < stage_plan.len() {\n            let next_stage = stage_plan[idx + 1].stage_id;\n            current_snapshot.active_run.as_mut().unwrap().stage_cursor =\n                StageCursor::initial(next_stage);\n            current_snapshot.status_summary = format!(\n                \"running: completed {}, next {}\",\n                stage_id.display_name(),\n                next_stage.display_name()\n            );\n        }\n        run_snapshot_write.write_run_snapshot(base_dir, project_id, &current_snapshot)?;\n\n        // Best-effort runtime log\n        let _ = log_write.append_runtime_log(\n            base_dir,\n            project_id,\n            &RuntimeLogEntry {\n                timestamp: Utc::now(),\n                level: LogLevel::Info,\n                source: \"engine\".to_owned(),\n                message: format!(\"stage_completed: {}\", stage_id.as_str()),\n            },\n        );\n    }\n\n    // 8. All stages completed — mark run as completed\n    seq += 1;\n    let run_completed = journal::run_completed_event(seq, Utc::now(), &run_id, 1);\n    let run_completed_line = journal::serialize_event(&run_completed)?;\n    journal_store.append_event(base_dir, project_id, &run_completed_line)?;\n\n    current_snapshot.status = RunStatus::Completed;\n    current_snapshot.active_run = None;\n    current_snapshot.completion_rounds = 1;\n    current_snapshot.status_summary = \"completed\".to_owned();\n    run_snapshot_write.write_run_snapshot(base_dir, project_id, &current_snapshot)?;\n\n    Ok(())\n}\n\n/// Record a run failure: persist journal event, update snapshot, return error.\n#[allow(clippy::too_many_arguments)]\nasync fn fail_run(\n    err: &AppError,\n    stage_id: StageId,\n    run_id: &RunId,\n    seq: &mut u64,\n    snapshot: &mut RunSnapshot,\n    journal_store: &dyn JournalStorePort,\n    run_snapshot_write: &dyn RunSnapshotWritePort,\n    base_dir: &Path,\n    project_id: &ProjectId,\n) -> AppResult<()> {\n    let failure_class = err\n        .failure_class()\n        .map(|fc| format!(\"{:?}\", fc))\n        .unwrap_or_else(|| \"unknown\".to_owned());\n    let message = err.to_string();\n\n    *seq += 1;\n    let run_failed =\n        journal::run_failed_event(*seq, Utc::now(), run_id, stage_id, &failure_class, &message);\n    let run_failed_line = journal::serialize_event(&run_failed)?;\n    journal_store.append_event(base_dir, project_id, &run_failed_line)?;\n\n    snapshot.status = RunStatus::Failed;\n    snapshot.active_run = None;\n    snapshot.status_summary = format!(\"failed at {}: {}\", stage_id.display_name(), message);\n    run_snapshot_write.write_run_snapshot(base_dir, project_id, snapshot)?;\n\n    Err(AppError::RunStartFailed {\n        reason: format!(\"stage {} failed: {}\", stage_id.as_str(), message),\n    })\n}\n\n/// Helper to get project root path.\nfn project_root_path(base_dir: &Path, project_id: &ProjectId) -> PathBuf {\n    base_dir\n        .join(\".ralph-burning\")\n        .join(\"projects\")\n        .join(project_id.as_str())\n}\n","numLines":437,"startLine":1,"totalLines":437}}}
