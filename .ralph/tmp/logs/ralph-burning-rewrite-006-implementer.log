st]\n   399→fn delete_project_fails_for_missing_project() {\n   400→    let store = FakeProjectStore::empty();\n   401→    let run_store = FakeRunSnapshotStore::no_run();\n   402→    let active_store = FakeActiveProjectStore::none();\n   403→    let base_dir = dummy_base_dir();\n   404→    let pid = ProjectId::new(\"missing\").unwrap();\n   405→\n   406→    let result = delete_project(&store, &run_store, &active_store, &base_dir, &pid);\n   407→    assert!(matches!(\n   408→        result.unwrap_err(),\n   409→        AppError::ProjectNotFound { .. }\n   410→    ));\n   411→}\n   412→\n   413→#[test]\n   414→fn run_status_reports_not_started_when_no_active_run() {\n   415→    let run_store = FakeRunSnapshotStore::no_run();\n   416→    let base_dir = dummy_base_dir();\n   417→    let pid = ProjectId::new(\"alpha\").unwrap();\n   418→\n   419→    let status = run_status(&run_store, &base_dir, &pid).unwrap();\n   420→    assert_eq!(status.status, \"not started\");\n   421→    assert!(status.stage.is_none());\n   422→    assert!(status.cycle.is_none());\n   423→}\n   424→\n   425→#[test]\n   426→fn run_status_reports_running_with_stage_cursor() {\n   427→    let run_store = FakeRunSnapshotStore::active_run();\n   428→    let base_dir = dummy_base_dir();\n   429→    let pid = ProjectId::new(\"alpha\").unwrap();\n   430→\n   431→    let status = run_status(&run_store, &base_dir, &pid).unwrap();\n   432→    assert_eq!(status.status, \"running\");\n   433→    assert_eq!(status.stage, Some(\"planning\".to_owned()));\n   434→    assert_eq!(status.cycle, Some(1));\n   435→}\n   436→\n   437→// ── Semantic Validation ──\n   438→\n   439→#[test]\n   440→fn run_snapshot_validates_running_without_active_run_as_corrupt() {\n   441→    let snapshot = RunSnapshot {\n   442→        active_run: None,\n   443→        status: RunStatus::Running,\n   444→        cycle_history: Vec::new(),\n   445→        completion_rounds: 0,\n   446→        rollback_point_meta: RollbackPointMeta::default