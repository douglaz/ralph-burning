mily, model_id.clone());\n    92→        }\n    93→    }\n    94→\n    95→    fn apply_model_override(target: &mut ResolvedBackendTarget, model_override: ModelSpec) {\n    96→        if target.backend.family != model_override.backend_family {\n    97→            target.backend = BackendSpec::from_family(model_override.backend_family);\n    98→        }\n    99→        target.model = model_override;\n   100→    }\n   101→}\n   102→\n   103→#[allow(async_fn_in_trait)]\n   104→pub trait AgentExecutionPort {\n   105→    async fn check_capability(\n   106→        &self,\n   107→        backend: &ResolvedBackendTarget,\n   108→        stage_contract: &StageContract,\n   109→    ) -> AppResult<()>;\n   110→\n   111→    async fn check_availability(&self, backend: &ResolvedBackendTarget) -> AppResult<()>;\n   112→\n   113→    async fn invoke(&self, request: InvocationRequest) -> AppResult<InvocationEnvelope>;\n   114→\n   115→    async fn cancel(&self, invocation_id: &str) -> AppResult<()>;\n   116→}\n   117→\n   118→pub trait RawOutputPort {\n   119→    fn persist_raw_output(\n   120→        &self,\n   121→        project_root: &Path,\n   122→        invocation_id: &str,\n   123→        contents: &str,\n   124→    ) -> AppResult<RawOutputReference>;\n   125→}\n   126→\n   127→pub struct AgentExecutionService<A, R, S> {\n   128→    adapter: A,\n   129→    raw_output_store: R,\n   130→    session_manager: SessionManager<S>,\n   131→    resolver: BackendResolver,\n   132→}\n   133→\n   134→impl<A, R, S> AgentExecutionService<A, R, S> {\n   135→    pub fn new(adapter: A, raw_output_store: R, session_store: S) -> Self {\n   136→        Self {\n   137→            adapter,\n   138→            raw_output_store,\n   139→            session_manager: SessionManager::new(session_store),\n   140→            resolver: BackendResolver::new(),\n   141→        }\n   142→    }\n   143→\n   144→    pub fn resolver(&self) -> &BackendResolver {\n   145→        &self.resolver\n   146→    }\n   1