{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Md59RhkDXdyHpFMQJ5iSQu","type":"tool_result","content":"     1→use std::env;\n     2→use std::fs::{self, OpenOptions};\n     3→use std::io::Write;\n     4→use std::path::{Path, PathBuf};\n     5→use std::process::Command;\n     6→use std::time::{SystemTime, UNIX_EPOCH};\n     7→\n     8→use crate::contexts::agent_execution::model::RawOutputReference;\n     9→use crate::contexts::agent_execution::service::RawOutputPort;\n    10→use crate::contexts::agent_execution::session::{PersistedSessions, SessionStorePort};\n    11→use crate::contexts::project_run_record::journal;\n    12→use crate::contexts::project_run_record::model::{\n    13→    ArtifactRecord, JournalEvent, PayloadRecord, ProjectRecord, RunSnapshot, RuntimeLogEntry,\n    14→    SessionStore,\n    15→};\n    16→use crate::contexts::project_run_record::service::{\n    17→    ActiveProjectPort, ArtifactStorePort, JournalStorePort, PayloadArtifactWritePort,\n    18→    ProjectStorePort, RunSnapshotPort, RunSnapshotWritePort, RuntimeLogStorePort,\n    19→    RuntimeLogWritePort,\n    20→};\n    21→use crate::shared::domain::{ProjectId, WorkspaceConfig};\n    22→use crate::shared::error::{AppError, AppResult};\n    23→\n    24→const ACTIVE_PROJECT_FILE: &str = \"active-project\";\n    25→const WORKSPACE_DIR: &str = \".ralph-burning\";\n    26→const PROJECTS_DIR: &str = \"projects\";\n    27→const PROJECT_CONFIG_FILE: &str = \"project.toml\";\n    28→const RUN_FILE: &str = \"run.json\";\n    29→const JOURNAL_FILE: &str = \"journal.ndjson\";\n    30→const SESSIONS_FILE: &str = \"sessions.json\";\n    31→const PROMPT_FILE: &str = \"prompt.md\";\n    32→\n    33→/// Required subdirectories inside a project.\n    34→const PROJECT_SUBDIRS: &[&str] = &[\n    35→    \"history/payloads\",\n    36→    \"history/artifacts\",\n    37→    \"runtime/logs\",\n    38→    \"runtime/backend\",\n    39→    \"runtime/temp\",\n    40→    \"amendments\",\n    41→    \"rollback\",\n    42→];\n    43→\n    44→pub struct FileSystem;\n    45→\n    46→impl FileSystem {\n    47→    pub fn create_workspace(\n    48→        workspace_root: &Path,\n    49→        workspace_config: &str,\n    50→        required_directories: &[&str],\n    51→    ) -> AppResult<()> {\n    52→        fs::create_dir_all(workspace_root)?;\n    53→\n    54→        for directory in required_directories {\n    55→            fs::create_dir_all(workspace_root.join(directory))?;\n    56→        }\n    57→\n    58→        Self::write_atomic(&workspace_root.join(\"workspace.toml\"), workspace_config)?;\n    59→        Ok(())\n    60→    }\n    61→\n    62→    pub fn read_to_string(path: &Path) -> AppResult<String> {\n    63→        Ok(fs::read_to_string(path)?)\n    64→    }\n    65→\n    66→    pub fn write_atomic(path: &Path, contents: &str) -> AppResult<()> {\n    67→        let parent = path.parent().ok_or_else(|| {\n    68→            AppError::Io(std::io::Error::new(\n    69→                std::io::ErrorKind::InvalidInput,\n    70→                format!(\"path '{}' has no parent directory\", path.display()),\n    71→            ))\n    72→        })?;\n    73→        fs::create_dir_all(parent)?;\n    74→\n    75→        let timestamp = SystemTime::now()\n    76→            .duration_since(UNIX_EPOCH)\n    77→            .map(|duration| duration.as_nanos())\n    78→            .unwrap_or_default();\n    79→        let temp_path = parent.join(format!(\n    80→            \".{}.{}.{}.tmp\",\n    81→            path.file_name()\n    82→                .and_then(|value| value.to_str())\n    83→                .unwrap_or(\"workspace\"),\n    84→            std::process::id(),\n    85→            timestamp\n    86→        ));\n    87→\n    88→        let mut file = OpenOptions::new()\n    89→            .create_new(true)\n    90→            .write(true)\n    91→            .open(&temp_path)?;\n    92→        file.write_all(contents.as_bytes())?;\n    93→        file.sync_all()?;\n    94→        drop(file);\n    95→\n    96→        if let Err(error) = fs::rename(&temp_path, path) {\n    97→            let _ = fs::remove_file(&temp_path);\n    98→            return Err(error.into());\n    99→        }\n   100→\n   101→        Ok(())\n   102→    }\n   103→\n   104→    pub fn render_workspace_config(config: &WorkspaceConfig) -> AppResult<String> {\n   105→        Ok(toml::to_string_pretty(config)?)\n   106→    }\n   107→\n   108→    pub fn read_active_project(workspace_root: &Path) -> AppResult<Option<String>> {\n   109→        let path = workspace_root.join(ACTIVE_PROJECT_FILE);\n   110→        match fs::read_to_string(path) {\n   111→            Ok(raw) => {\n   112→                let trimmed = raw.trim();\n   113→                if trimmed.is_empty() {\n   114→                    Ok(None)\n   115→                } else {\n   116→                    Ok(Some(trimmed.to_owned()))\n   117→                }\n   118→            }\n   119→            Err(error) if error.kind() == std::io::ErrorKind::NotFound => Ok(None),\n   120→            Err(error) => Err(error.into()),\n   121→        }\n   122→    }\n   123→\n   124→    pub fn write_active_project(workspace_root: &Path, project_id: &str) -> AppResult<()> {\n   125→        Self::write_atomic(&workspace_root.join(ACTIVE_PROJECT_FILE), project_id)\n   126→    }\n   127→\n   128→    pub fn open_editor(path: &Path) -> AppResult<()> {\n   129→        let editor = env::var(\"EDITOR\")\n   130→            .ok()\n   131→            .filter(|value| !value.trim().is_empty())\n   132→            .or_else(|| {\n   133→                env::var(\"VISUAL\")\n   134→                    .ok()\n   135→                    .filter(|value| !value.trim().is_empty())\n   136→            })\n   137→            .unwrap_or_else(|| \"vi\".to_owned());\n   138→\n   139→        let mut parts = editor.split_whitespace();\n   140→        let program = parts.next().ok_or_else(|| AppError::EditorFailed {\n   141→            editor: editor.clone(),\n   142→            details: \": empty editor command\".to_owned(),\n   143→        })?;\n   144→        let status = Command::new(program).args(parts).arg(path).status()?;\n   145→\n   146→        if status.success() {\n   147→            Ok(())\n   148→        } else {\n   149→            let details = match status.code() {\n   150→                Some(code) => format!(\" with exit code {code}\"),\n   151→                None => \" after being terminated by a signal\".to_owned(),\n   152→            };\n   153→            Err(AppError::EditorFailed { editor, details })\n   154→        }\n   155→    }\n   156→\n   157→    /// Compute a simple hash of content for prompt integrity tracking.\n   158→    pub fn prompt_hash(contents: &str) -> String {\n   159→        use std::collections::hash_map::DefaultHasher;\n   160→        use std::hash::{Hash, Hasher};\n   161→        let mut hasher = DefaultHasher::new();\n   162→        contents.hash(&mut hasher);\n   163→        format!(\"{:016x}\", hasher.finish())\n   164→    }\n   165→\n   166→    // ── Helpers for project filesystem layout ──\n   167→\n   168→    fn workspace_root_path(base_dir: &Path) -> PathBuf {\n   169→        base_dir.join(WORKSPACE_DIR)\n   170→    }\n   171→\n   172→    fn project_root(base_dir: &Path, project_id: &ProjectId) -> PathBuf {\n   173→        Self::workspace_root_path(base_dir)\n   174→            .join(PROJECTS_DIR)\n   175→            .join(project_id.as_str())\n   176→    }\n   177→\n   178→    fn pending_delete_path(base_dir: &Path, project_id: &ProjectId) -> PathBuf {\n   179→        Self::workspace_root_path(base_dir)\n   180→            .join(PROJECTS_DIR)\n   181→            .join(format!(\".{}.pending-delete\", project_id))\n   182→    }\n   183→\n   184→    fn append_line(path: &Path, line: &str) -> AppResult<()> {\n   185→        let parent = path.parent().ok_or_else(|| {\n   186→            AppError::Io(std::io::Error::new(\n   187→                std::io::ErrorKind::InvalidInput,\n   188→                format!(\"path '{}' has no parent directory\", path.display()),\n   189→            ))\n   190→        })?;\n   191→        fs::create_dir_all(parent)?;\n   192→\n   193→        let mut file = OpenOptions::new().create(true).append(true).open(path)?;\n   194→        writeln!(file, \"{}\", line)?;\n   195→        file.sync_all()?;\n   196→        Ok(())\n   197→    }\n   198→}\n   199→\n   200→/// Filesystem-backed implementation of `ProjectStorePort`.\n   201→pub struct FsProjectStore;\n   202→\n   203→impl ProjectStorePort for FsProjectStore {\n   204→    fn project_exists(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<bool> {\n   205→        let project_root = FileSystem::project_root(base_dir, project_id);\n   206→        if !project_root.is_dir() {\n   207→            return Ok(false);\n   208→        }\n   209→        if !project_root.join(PROJECT_CONFIG_FILE).is_file() {\n   210→            return Err(AppError::CorruptRecord {\n   211→                file: format!(\"projects/{}/project.toml\", project_id),\n   212→                details: \"project directory exists but canonical project.toml is missing\"\n   213→                    .to_owned(),\n   214→            });\n   215→        }\n   216→        Ok(true)\n   217→    }\n   218→\n   219→    fn read_project_record(\n   220→        &self,\n   221→        base_dir: &Path,\n   222→        project_id: &ProjectId,\n   223→    ) -> AppResult<ProjectRecord> {\n   224→        let project_root = FileSystem::project_root(base_dir, project_id);\n   225→        let path = project_root.join(PROJECT_CONFIG_FILE);\n   226→        let raw = fs::read_to_string(&path).map_err(|e| {\n   227→            if e.kind() == std::io::ErrorKind::NotFound {\n   228→                if project_root.is_dir() {\n   229→                    // Directory exists but project.toml is missing — corruption\n   230→                    AppError::CorruptRecord {\n   231→                        file: format!(\"projects/{}/project.toml\", project_id),\n   232→                        details: \"project directory exists but canonical project.toml is missing\"\n   233→                            .to_owned(),\n   234→                    }\n   235→                } else {\n   236→                    AppError::ProjectNotFound {\n   237→                        project_id: project_id.to_string(),\n   238→                    }\n   239→                }\n   240→            } else {\n   241→                e.into()\n   242→            }\n   243→        })?;\n   244→        toml::from_str(&raw).map_err(|e| AppError::CorruptRecord {\n   245→            file: format!(\"projects/{}/project.toml\", project_id),\n   246→            details: e.to_string(),\n   247→        })\n   248→    }\n   249→\n   250→    fn list_project_ids(&self, base_dir: &Path) -> AppResult<Vec<ProjectId>> {\n   251→        let projects_dir = FileSystem::workspace_root_path(base_dir).join(PROJECTS_DIR);\n   252→        if !projects_dir.is_dir() {\n   253→            return Ok(Vec::new());\n   254→        }\n   255→\n   256→        let mut ids = Vec::new();\n   257→        for entry in fs::read_dir(&projects_dir)? {\n   258→            let entry = entry?;\n   259→            if !entry.file_type()?.is_dir() {\n   260→                continue;\n   261→            }\n   262→            let name = entry.file_name();\n   263→            let name_str = name.to_string_lossy();\n   264→            // Skip hidden directories (staging/trash from transactional operations)\n   265→            if name_str.starts_with('.') {\n   266→                continue;\n   267→            }\n   268→            if let Ok(pid) = ProjectId::new(name_str.as_ref()) {\n   269→                if !entry.path().join(PROJECT_CONFIG_FILE).is_file() {\n   270→                    return Err(AppError::CorruptRecord {\n   271→                        file: format!(\"projects/{}/project.toml\", name_str),\n   272→                        details: \"project directory exists but canonical project.toml is missing\"\n   273→                            .to_owned(),\n   274→                    });\n   275→                }\n   276→                ids.push(pid);\n   277→            }\n   278→        }\n   279→\n   280→        ids.sort_by(|a, b| a.as_str().cmp(b.as_str()));\n   281→        Ok(ids)\n   282→    }\n   283→\n   284→    fn stage_delete(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<()> {\n   285→        let project_root = FileSystem::project_root(base_dir, project_id);\n   286→        if !project_root.is_dir() {\n   287→            return Err(AppError::ProjectNotFound {\n   288→                project_id: project_id.to_string(),\n   289→            });\n   290→        }\n   291→\n   292→        let pending_path = FileSystem::pending_delete_path(base_dir, project_id);\n   293→\n   294→        // Clean up any leftover pending-delete from a previous crash\n   295→        if pending_path.exists() {\n   296→            fs::remove_dir_all(&pending_path)?;\n   297→        }\n   298→\n   299→        // Atomic rename to pending-delete location — project becomes\n   300→        // invisible to list/show but data stays on disk.\n   301→        fs::rename(&project_root, &pending_path)?;\n   302→        Ok(())\n   303→    }\n   304→\n   305→    fn commit_delete(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<()> {\n   306→        let pending_path = FileSystem::pending_delete_path(base_dir, project_id);\n   307→        if pending_path.is_dir() {\n   308→            fs::remove_dir_all(&pending_path)?;\n   309→        }\n   310→        Ok(())\n   311→    }\n   312→\n   313→    fn rollback_delete(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<()> {\n   314→        let project_root = FileSystem::project_root(base_dir, project_id);\n   315→        let pending_path = FileSystem::pending_delete_path(base_dir, project_id);\n   316→\n   317→        if !pending_path.is_dir() {\n   318→            return Ok(());\n   319→        }\n   320→\n   321→        fs::rename(&pending_path, &project_root)?;\n   322→        Ok(())\n   323→    }\n   324→\n   325→    fn create_project_atomic(\n   326→        &self,\n   327→        base_dir: &Path,\n   328→        record: &ProjectRecord,\n   329→        prompt_contents: &str,\n   330→        run_snapshot: &RunSnapshot,\n   331→        initial_journal_line: &str,\n   332→        sessions: &SessionStore,\n   333→    ) -> AppResult<()> {\n   334→        let project_root = FileSystem::project_root(base_dir, &record.id);\n   335→\n   336→        // Stage into a temporary directory alongside the final location\n   337→        let staging_name = format!(\".{}.staging.{}\", record.id, std::process::id());\n   338→        let staging_root = project_root\n   339→            .parent()\n   340→            .expect(\"project root has parent\")\n   341→            .join(&staging_name);\n   342→\n   343→        // Clean up any leftover staging dir\n   344→        if staging_root.exists() {\n   345→            fs::remove_dir_all(&staging_root)?;\n   346→        }\n   347→\n   348→        // Create staging directory and all subdirs\n   349→        fs::create_dir_all(&staging_root)?;\n   350→        for subdir in PROJECT_SUBDIRS {\n   351→            fs::create_dir_all(staging_root.join(subdir))?;\n   352→        }\n   353→\n   354→        // Write all canonical files into staging\n   355→        let write_result = (|| -> AppResult<()> {\n   356→            // project.toml\n   357→            let project_toml = toml::to_string_pretty(record)\n   358→                .map_err(|e| AppError::Io(std::io::Error::other(e.to_string())))?;\n   359→            fs::write(staging_root.join(PROJECT_CONFIG_FILE), project_toml)?;\n   360→\n   361→            // prompt.md\n   362→            fs::write(staging_root.join(PROMPT_FILE), prompt_contents)?;\n   363→\n   364→            // run.json\n   365→            let run_json = serde_json::to_string_pretty(run_snapshot)?;\n   366→            fs::write(staging_root.join(RUN_FILE), run_json)?;\n   367→\n   368→            // journal.ndjson (with initial event)\n   369→            let mut journal_content = initial_journal_line.to_owned();\n   370→            journal_content.push('\\n');\n   371→            fs::write(staging_root.join(JOURNAL_FILE), journal_content)?;\n   372→\n   373→            // sessions.json\n   374→            let sessions_json = serde_json::to_string_pretty(sessions)?;\n   375→            fs::write(staging_root.join(SESSIONS_FILE), sessions_json)?;\n   376→\n   377→            Ok(())\n   378→        })();\n   379→\n   380→        if let Err(e) = write_result {\n   381→            // Clean up staging on failure\n   382→            let _ = fs::remove_dir_all(&staging_root);\n   383→            return Err(e);\n   384→        }\n   385→\n   386→        // Atomic rename from staging to final location\n   387→        if let Err(e) = fs::rename(&staging_root, &project_root) {\n   388→            let _ = fs::remove_dir_all(&staging_root);\n   389→            return Err(e.into());\n   390→        }\n   391→\n   392→        Ok(())\n   393→    }\n   394→}\n   395→\n   396→/// Filesystem-backed implementation of `JournalStorePort`.\n   397→pub struct FsJournalStore;\n   398→\n   399→impl JournalStorePort for FsJournalStore {\n   400→    fn read_journal(\n   401→        &self,\n   402→        base_dir: &Path,\n   403→        project_id: &ProjectId,\n   404→    ) -> AppResult<Vec<JournalEvent>> {\n   405→        let path = FileSystem::project_root(base_dir, project_id).join(JOURNAL_FILE);\n   406→        match fs::read_to_string(&path) {\n   407→            Ok(contents) => journal::parse_journal(&contents),\n   408→            Err(e) if e.kind() == std::io::ErrorKind::NotFound => Err(AppError::CorruptRecord {\n   409→                file: format!(\"projects/{}/journal.ndjson\", project_id),\n   410→                details: \"canonical file is missing\".to_owned(),\n   411→            }),\n   412→            Err(e) => Err(e.into()),\n   413→        }\n   414→    }\n   415→\n   416→    fn append_event(&self, base_dir: &Path, project_id: &ProjectId, line: &str) -> AppResult<()> {\n   417→        let path = FileSystem::project_root(base_dir, project_id).join(JOURNAL_FILE);\n   418→        FileSystem::append_line(&path, line)\n   419→    }\n   420→}\n   421→\n   422→/// Filesystem-backed implementation of `ArtifactStorePort`.\n   423→pub struct FsArtifactStore;\n   424→\n   425→impl ArtifactStorePort for FsArtifactStore {\n   426→    fn list_payloads(\n   427→        &self,\n   428→        base_dir: &Path,\n   429→        project_id: &ProjectId,\n   430→    ) -> AppResult<Vec<PayloadRecord>> {\n   431→        let dir = FileSystem::project_root(base_dir, project_id).join(\"history/payloads\");\n   432→        if !dir.is_dir() {\n   433→            return Ok(Vec::new());\n   434→        }\n   435→\n   436→        let mut records = Vec::new();\n   437→        for entry in fs::read_dir(&dir)? {\n   438→            let entry = entry?;\n   439→            let path = entry.path();\n   440→            if path.extension().is_some_and(|ext| ext == \"json\") {\n   441→                let raw = fs::read_to_string(&path)?;\n   442→                let record: PayloadRecord =\n   443→                    serde_json::from_str(&raw).map_err(|e| AppError::CorruptRecord {\n   444→                        file: format!(\n   445→                            \"history/payloads/{}\",\n   446→                            path.file_name().unwrap_or_default().to_string_lossy()\n   447→                        ),\n   448→                        details: e.to_string(),\n   449→                    })?;\n   450→                records.push(record);\n   451→            }\n   452→        }\n   453→\n   454→        records.sort_by_key(|r| r.created_at);\n   455→        Ok(records)\n   456→    }\n   457→\n   458→    fn list_artifacts(\n   459→        &self,\n   460→        base_dir: &Path,\n   461→        project_id: &ProjectId,\n   462→    ) -> AppResult<Vec<ArtifactRecord>> {\n   463→        let dir = FileSystem::project_root(base_dir, project_id).join(\"history/artifacts\");\n   464→        if !dir.is_dir() {\n   465→            return Ok(Vec::new());\n   466→        }\n   467→\n   468→        let mut records = Vec::new();\n   469→        for entry in fs::read_dir(&dir)? {\n   470→            let entry = entry?;\n   471→            let path = entry.path();\n   472→            if path.extension().is_some_and(|ext| ext == \"json\") {\n   473→                let raw = fs::read_to_string(&path)?;\n   474→                let record: ArtifactRecord =\n   475→                    serde_json::from_str(&raw).map_err(|e| AppError::CorruptRecord {\n   476→                        file: format!(\n   477→                            \"history/artifacts/{}\",\n   478→                            path.file_name().unwrap_or_default().to_string_lossy()\n   479→                        ),\n   480→                        details: e.to_string(),\n   481→                    })?;\n   482→                records.push(record);\n   483→            }\n   484→        }\n   485→\n   486→        records.sort_by_key(|r| r.created_at);\n   487→        Ok(records)\n   488→    }\n   489→}\n   490→\n   491→/// Filesystem-backed implementation of `RuntimeLogStorePort`.\n   492→pub struct FsRuntimeLogStore;\n   493→\n   494→impl RuntimeLogStorePort for FsRuntimeLogStore {\n   495→    fn read_runtime_logs(\n   496→        &self,\n   497→        base_dir: &Path,\n   498→        project_id: &ProjectId,\n   499→    ) -> AppResult<Vec<RuntimeLogEntry>> {\n   500→        let dir = FileSystem::project_root(base_dir, project_id).join(\"runtime/logs\");\n   501→        if !dir.is_dir() {\n   502→            return Ok(Vec::new());\n   503→        }\n   504→\n   505→        let mut entries = Vec::new();\n   506→        let mut paths: Vec<_> = fs::read_dir(&dir)?\n   507→            .filter_map(|e| e.ok())\n   508→            .map(|e| e.path())\n   509→            .filter(|p| p.extension().is_some_and(|ext| ext == \"ndjson\"))\n   510→            .collect();\n   511→        paths.sort();\n   512→\n   513→        // Only read the newest/latest log file per spec:\n   514→        // \"run tail --logs appends the newest runtime logs\"\n   515→        if let Some(path) = paths.last() {\n   516→            let contents = fs::read_to_string(path)?;\n   517→            for line in contents.lines() {\n   518→                let trimmed = line.trim();\n   519→                if trimmed.is_empty() {\n   520→                    continue;\n   521→                }\n   522→                if let Ok(entry) = serde_json::from_str::<RuntimeLogEntry>(trimmed) {\n   523→                    entries.push(entry);\n   524→                }\n   525→            }\n   526→        }\n   527→\n   528→        Ok(entries)\n   529→    }\n   530→}\n   531→\n   532→/// Filesystem-backed implementation of `RunSnapshotPort`.\n   533→pub struct FsRunSnapshotStore;\n   534→\n   535→impl RunSnapshotPort for FsRunSnapshotStore {\n   536→    fn read_run_snapshot(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<RunSnapshot> {\n   537→        let path = FileSystem::project_root(base_dir, project_id).join(RUN_FILE);\n   538→        match fs::read_to_string(&path) {\n   539→            Ok(raw) => {\n   540→                let snapshot: RunSnapshot =\n   541→                    serde_json::from_str(&raw).map_err(|e| AppError::CorruptRecord {\n   542→                        file: format!(\"projects/{}/run.json\", project_id),\n   543→                        details: e.to_string(),\n   544→                    })?;\n   545→                // Semantic validation: reject inconsistent status/active_run combinations\n   546→                snapshot\n   547→                    .validate_semantics()\n   548→                    .map_err(|details| AppError::CorruptRecord {\n   549→                        file: format!(\"projects/{}/run.json\", project_id),\n   550→                        details,\n   551→                    })?;\n   552→                Ok(snapshot)\n   553→            }\n   554→            Err(e) if e.kind() == std::io::ErrorKind::NotFound => Err(AppError::CorruptRecord {\n   555→                file: format!(\"projects/{}/run.json\", project_id),\n   556→                details: \"canonical file is missing\".to_owned(),\n   557→            }),\n   558→            Err(e) => Err(e.into()),\n   559→        }\n   560→    }\n   561→}\n   562→\n   563→/// Filesystem-backed implementation of `ActiveProjectPort`.\n   564→pub struct FsActiveProjectStore;\n   565→\n   566→impl ActiveProjectPort for FsActiveProjectStore {\n   567→    fn read_active_project_id(&self, base_dir: &Path) -> AppResult<Option<String>> {\n   568→        FileSystem::read_active_project(&FileSystem::workspace_root_path(base_dir))\n   569→    }\n   570→\n   571→    fn clear_active_project(&self, base_dir: &Path) -> AppResult<()> {\n   572→        let path = FileSystem::workspace_root_path(base_dir).join(ACTIVE_PROJECT_FILE);\n   573→        match fs::remove_file(&path) {\n   574→            Ok(()) => Ok(()),\n   575→            Err(e) if e.kind() == std::io::ErrorKind::NotFound => Ok(()),\n   576→            Err(e) => Err(e.into()),\n   577→        }\n   578→    }\n   579→\n   580→    fn write_active_project(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<()> {\n   581→        FileSystem::write_active_project(\n   582→            &FileSystem::workspace_root_path(base_dir),\n   583→            project_id.as_str(),\n   584→        )\n   585→    }\n   586→}\n   587→\n   588→/// Filesystem-backed implementation of `RawOutputPort`.\n   589→pub struct FsRawOutputStore;\n   590→\n   591→impl RawOutputPort for FsRawOutputStore {\n   592→    fn persist_raw_output(\n   593→        &self,\n   594→        project_root: &Path,\n   595→        invocation_id: &str,\n   596→        contents: &str,\n   597→    ) -> AppResult<RawOutputReference> {\n   598→        let path = project_root\n   599→            .join(\"runtime/backend\")\n   600→            .join(format!(\"{invocation_id}.raw\"));\n   601→        FileSystem::write_atomic(&path, contents)?;\n   602→        Ok(RawOutputReference::Stored(path))\n   603→    }\n   604→}\n   605→\n   606→/// Filesystem-backed implementation of `SessionStorePort`.\n   607→pub struct FsSessionStore;\n   608→\n   609→impl SessionStorePort for FsSessionStore {\n   610→    fn load_sessions(&self, project_root: &Path) -> AppResult<PersistedSessions> {\n   611→        let path = project_root.join(SESSIONS_FILE);\n   612→        match fs::read_to_string(&path) {\n   613→            Ok(raw) => serde_json::from_str(&raw).map_err(|error| AppError::CorruptRecord {\n   614→                file: format!(\"{}/{}\", project_root.display(), SESSIONS_FILE),\n   615→                details: error.to_string(),\n   616→            }),\n   617→            Err(error) if error.kind() == std::io::ErrorKind::NotFound => {\n   618→                Err(AppError::CorruptRecord {\n   619→                    file: format!(\"{}/{}\", project_root.display(), SESSIONS_FILE),\n   620→                    details: \"canonical file is missing\".to_owned(),\n   621→                })\n   622→            }\n   623→            Err(error) => Err(error.into()),\n   624→        }\n   625→    }\n   626→\n   627→    fn save_sessions(&self, project_root: &Path, sessions: &PersistedSessions) -> AppResult<()> {\n   628→        let path = project_root.join(SESSIONS_FILE);\n   629→        let contents = serde_json::to_string_pretty(sessions)?;\n   630→        FileSystem::write_atomic(&path, &contents)\n   631→    }\n   632→}\n   633→\n   634→/// Filesystem-backed implementation of `RunSnapshotWritePort`.\n   635→pub struct FsRunSnapshotWriteStore;\n   636→\n   637→impl RunSnapshotWritePort for FsRunSnapshotWriteStore {\n   638→    fn write_run_snapshot(\n   639→        &self,\n   640→        base_dir: &Path,\n   641→        project_id: &ProjectId,\n   642→        snapshot: &RunSnapshot,\n   643→    ) -> AppResult<()> {\n   644→        let path = FileSystem::project_root(base_dir, project_id).join(RUN_FILE);\n   645→        let contents = serde_json::to_string_pretty(snapshot)?;\n   646→        FileSystem::write_atomic(&path, &contents)\n   647→    }\n   648→}\n   649→\n   650→/// Filesystem-backed implementation of `PayloadArtifactWritePort`.\n   651→pub struct FsPayloadArtifactWriteStore;\n   652→\n   653→impl PayloadArtifactWritePort for FsPayloadArtifactWriteStore {\n   654→    fn write_payload_artifact_pair(\n   655→        &self,\n   656→        base_dir: &Path,\n   657→        project_id: &ProjectId,\n   658→        payload: &PayloadRecord,\n   659→        artifact: &ArtifactRecord,\n   660→    ) -> AppResult<()> {\n   661→        let project_root = FileSystem::project_root(base_dir, project_id);\n   662→\n   663→        // Write payload first\n   664→        let payload_path = project_root\n   665→            .join(\"history/payloads\")\n   666→            .join(format!(\"{}.json\", payload.payload_id));\n   667→        let payload_json = serde_json::to_string_pretty(payload)?;\n   668→        FileSystem::write_atomic(&payload_path, &payload_json)?;\n   669→\n   670→        // Write artifact second — if this fails, remove the payload to maintain pairing invariant\n   671→        let artifact_path = project_root\n   672→            .join(\"history/artifacts\")\n   673→            .join(format!(\"{}.json\", artifact.artifact_id));\n   674→        let artifact_json = serde_json::to_string_pretty(artifact)?;\n   675→        if let Err(e) = FileSystem::write_atomic(&artifact_path, &artifact_json) {\n   676→            let _ = fs::remove_file(&payload_path);\n   677→            return Err(e);\n   678→        }\n   679→\n   680→        Ok(())\n   681→    }\n   682→}\n   683→\n   684→/// Filesystem-backed implementation of `RuntimeLogWritePort`.\n   685→pub struct FsRuntimeLogWriteStore;\n   686→\n   687→impl RuntimeLogWritePort for FsRuntimeLogWriteStore {\n   688→    fn append_runtime_log(\n   689→        &self,\n   690→        base_dir: &Path,\n   691→        project_id: &ProjectId,\n   692→        entry: &RuntimeLogEntry,\n   693→    ) -> AppResult<()> {\n   694→        let dir = FileSystem::project_root(base_dir, project_id).join(\"runtime/logs\");\n   695→        fs::create_dir_all(&dir)?;\n   696→        let path = dir.join(\"run.ndjson\");\n   697→        let line = serde_json::to_string(entry)?;\n   698→        FileSystem::append_line(&path, &line)\n   699→    }\n   700→}\n   701→"}]},"parent_tool_use_id":null,"session_id":"19a33b10-b5a0-4ba2-8943-a7efa3e34818","uuid":"b778ad45-fbb8-474e-8454-59582e00c575","tool_use_result":{"type":"text","file":{"filePath":"/root/new-ralph-burning/ralph-burning-rewrite/src/adapters/fs.rs","content":"use std::env;\nuse std::fs::{self, OpenOptions};\nuse std::io::Write;\nuse std::path::{Path, PathBuf};\nuse std::process::Command;\nuse std::time::{SystemTime, UNIX_EPOCH};\n\nuse crate::contexts::agent_execution::model::RawOutputReference;\nuse crate::contexts::agent_execution::service::RawOutputPort;\nuse crate::contexts::agent_execution::session::{PersistedSessions, SessionStorePort};\nuse crate::contexts::project_run_record::journal;\nuse crate::contexts::project_run_record::model::{\n    ArtifactRecord, JournalEvent, PayloadRecord, ProjectRecord, RunSnapshot, RuntimeLogEntry,\n    SessionStore,\n};\nuse crate::contexts::project_run_record::service::{\n    ActiveProjectPort, ArtifactStorePort, JournalStorePort, PayloadArtifactWritePort,\n    ProjectStorePort, RunSnapshotPort, RunSnapshotWritePort, RuntimeLogStorePort,\n    RuntimeLogWritePort,\n};\nuse crate::shared::domain::{ProjectId, WorkspaceConfig};\nuse crate::shared::error::{AppError, AppResult};\n\nconst ACTIVE_PROJECT_FILE: &str = \"active-project\";\nconst WORKSPACE_DIR: &str = \".ralph-burning\";\nconst PROJECTS_DIR: &str = \"projects\";\nconst PROJECT_CONFIG_FILE: &str = \"project.toml\";\nconst RUN_FILE: &str = \"run.json\";\nconst JOURNAL_FILE: &str = \"journal.ndjson\";\nconst SESSIONS_FILE: &str = \"sessions.json\";\nconst PROMPT_FILE: &str = \"prompt.md\";\n\n/// Required subdirectories inside a project.\nconst PROJECT_SUBDIRS: &[&str] = &[\n    \"history/payloads\",\n    \"history/artifacts\",\n    \"runtime/logs\",\n    \"runtime/backend\",\n    \"runtime/temp\",\n    \"amendments\",\n    \"rollback\",\n];\n\npub struct FileSystem;\n\nimpl FileSystem {\n    pub fn create_workspace(\n        workspace_root: &Path,\n        workspace_config: &str,\n        required_directories: &[&str],\n    ) -> AppResult<()> {\n        fs::create_dir_all(workspace_root)?;\n\n        for directory in required_directories {\n            fs::create_dir_all(workspace_root.join(directory))?;\n        }\n\n        Self::write_atomic(&workspace_root.join(\"workspace.toml\"), workspace_config)?;\n        Ok(())\n    }\n\n    pub fn read_to_string(path: &Path) -> AppResult<String> {\n        Ok(fs::read_to_string(path)?)\n    }\n\n    pub fn write_atomic(path: &Path, contents: &str) -> AppResult<()> {\n        let parent = path.parent().ok_or_else(|| {\n            AppError::Io(std::io::Error::new(\n                std::io::ErrorKind::InvalidInput,\n                format!(\"path '{}' has no parent directory\", path.display()),\n            ))\n        })?;\n        fs::create_dir_all(parent)?;\n\n        let timestamp = SystemTime::now()\n            .duration_since(UNIX_EPOCH)\n            .map(|duration| duration.as_nanos())\n            .unwrap_or_default();\n        let temp_path = parent.join(format!(\n            \".{}.{}.{}.tmp\",\n            path.file_name()\n                .and_then(|value| value.to_str())\n                .unwrap_or(\"workspace\"),\n            std::process::id(),\n            timestamp\n        ));\n\n        let mut file = OpenOptions::new()\n            .create_new(true)\n            .write(true)\n            .open(&temp_path)?;\n        file.write_all(contents.as_bytes())?;\n        file.sync_all()?;\n        drop(file);\n\n        if let Err(error) = fs::rename(&temp_path, path) {\n            let _ = fs::remove_file(&temp_path);\n            return Err(error.into());\n        }\n\n        Ok(())\n    }\n\n    pub fn render_workspace_config(config: &WorkspaceConfig) -> AppResult<String> {\n        Ok(toml::to_string_pretty(config)?)\n    }\n\n    pub fn read_active_project(workspace_root: &Path) -> AppResult<Option<String>> {\n        let path = workspace_root.join(ACTIVE_PROJECT_FILE);\n        match fs::read_to_string(path) {\n            Ok(raw) => {\n                let trimmed = raw.trim();\n                if trimmed.is_empty() {\n                    Ok(None)\n                } else {\n                    Ok(Some(trimmed.to_owned()))\n                }\n            }\n            Err(error) if error.kind() == std::io::ErrorKind::NotFound => Ok(None),\n            Err(error) => Err(error.into()),\n        }\n    }\n\n    pub fn write_active_project(workspace_root: &Path, project_id: &str) -> AppResult<()> {\n        Self::write_atomic(&workspace_root.join(ACTIVE_PROJECT_FILE), project_id)\n    }\n\n    pub fn open_editor(path: &Path) -> AppResult<()> {\n        let editor = env::var(\"EDITOR\")\n            .ok()\n            .filter(|value| !value.trim().is_empty())\n            .or_else(|| {\n                env::var(\"VISUAL\")\n                    .ok()\n                    .filter(|value| !value.trim().is_empty())\n            })\n            .unwrap_or_else(|| \"vi\".to_owned());\n\n        let mut parts = editor.split_whitespace();\n        let program = parts.next().ok_or_else(|| AppError::EditorFailed {\n            editor: editor.clone(),\n            details: \": empty editor command\".to_owned(),\n        })?;\n        let status = Command::new(program).args(parts).arg(path).status()?;\n\n        if status.success() {\n            Ok(())\n        } else {\n            let details = match status.code() {\n                Some(code) => format!(\" with exit code {code}\"),\n                None => \" after being terminated by a signal\".to_owned(),\n            };\n            Err(AppError::EditorFailed { editor, details })\n        }\n    }\n\n    /// Compute a simple hash of content for prompt integrity tracking.\n    pub fn prompt_hash(contents: &str) -> String {\n        use std::collections::hash_map::DefaultHasher;\n        use std::hash::{Hash, Hasher};\n        let mut hasher = DefaultHasher::new();\n        contents.hash(&mut hasher);\n        format!(\"{:016x}\", hasher.finish())\n    }\n\n    // ── Helpers for project filesystem layout ──\n\n    fn workspace_root_path(base_dir: &Path) -> PathBuf {\n        base_dir.join(WORKSPACE_DIR)\n    }\n\n    fn project_root(base_dir: &Path, project_id: &ProjectId) -> PathBuf {\n        Self::workspace_root_path(base_dir)\n            .join(PROJECTS_DIR)\n            .join(project_id.as_str())\n    }\n\n    fn pending_delete_path(base_dir: &Path, project_id: &ProjectId) -> PathBuf {\n        Self::workspace_root_path(base_dir)\n            .join(PROJECTS_DIR)\n            .join(format!(\".{}.pending-delete\", project_id))\n    }\n\n    fn append_line(path: &Path, line: &str) -> AppResult<()> {\n        let parent = path.parent().ok_or_else(|| {\n            AppError::Io(std::io::Error::new(\n                std::io::ErrorKind::InvalidInput,\n                format!(\"path '{}' has no parent directory\", path.display()),\n            ))\n        })?;\n        fs::create_dir_all(parent)?;\n\n        let mut file = OpenOptions::new().create(true).append(true).open(path)?;\n        writeln!(file, \"{}\", line)?;\n        file.sync_all()?;\n        Ok(())\n    }\n}\n\n/// Filesystem-backed implementation of `ProjectStorePort`.\npub struct FsProjectStore;\n\nimpl ProjectStorePort for FsProjectStore {\n    fn project_exists(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<bool> {\n        let project_root = FileSystem::project_root(base_dir, project_id);\n        if !project_root.is_dir() {\n            return Ok(false);\n        }\n        if !project_root.join(PROJECT_CONFIG_FILE).is_file() {\n            return Err(AppError::CorruptRecord {\n                file: format!(\"projects/{}/project.toml\", project_id),\n                details: \"project directory exists but canonical project.toml is missing\"\n                    .to_owned(),\n            });\n        }\n        Ok(true)\n    }\n\n    fn read_project_record(\n        &self,\n        base_dir: &Path,\n        project_id: &ProjectId,\n    ) -> AppResult<ProjectRecord> {\n        let project_root = FileSystem::project_root(base_dir, project_id);\n        let path = project_root.join(PROJECT_CONFIG_FILE);\n        let raw = fs::read_to_string(&path).map_err(|e| {\n            if e.kind() == std::io::ErrorKind::NotFound {\n                if project_root.is_dir() {\n                    // Directory exists but project.toml is missing — corruption\n                    AppError::CorruptRecord {\n                        file: format!(\"projects/{}/project.toml\", project_id),\n                        details: \"project directory exists but canonical project.toml is missing\"\n                            .to_owned(),\n                    }\n                } else {\n                    AppError::ProjectNotFound {\n                        project_id: project_id.to_string(),\n                    }\n                }\n            } else {\n                e.into()\n            }\n        })?;\n        toml::from_str(&raw).map_err(|e| AppError::CorruptRecord {\n            file: format!(\"projects/{}/project.toml\", project_id),\n            details: e.to_string(),\n        })\n    }\n\n    fn list_project_ids(&self, base_dir: &Path) -> AppResult<Vec<ProjectId>> {\n        let projects_dir = FileSystem::workspace_root_path(base_dir).join(PROJECTS_DIR);\n        if !projects_dir.is_dir() {\n            return Ok(Vec::new());\n        }\n\n        let mut ids = Vec::new();\n        for entry in fs::read_dir(&projects_dir)? {\n            let entry = entry?;\n            if !entry.file_type()?.is_dir() {\n                continue;\n            }\n            let name = entry.file_name();\n            let name_str = name.to_string_lossy();\n            // Skip hidden directories (staging/trash from transactional operations)\n            if name_str.starts_with('.') {\n                continue;\n            }\n            if let Ok(pid) = ProjectId::new(name_str.as_ref()) {\n                if !entry.path().join(PROJECT_CONFIG_FILE).is_file() {\n                    return Err(AppError::CorruptRecord {\n                        file: format!(\"projects/{}/project.toml\", name_str),\n                        details: \"project directory exists but canonical project.toml is missing\"\n                            .to_owned(),\n                    });\n                }\n                ids.push(pid);\n            }\n        }\n\n        ids.sort_by(|a, b| a.as_str().cmp(b.as_str()));\n        Ok(ids)\n    }\n\n    fn stage_delete(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<()> {\n        let project_root = FileSystem::project_root(base_dir, project_id);\n        if !project_root.is_dir() {\n            return Err(AppError::ProjectNotFound {\n                project_id: project_id.to_string(),\n            });\n        }\n\n        let pending_path = FileSystem::pending_delete_path(base_dir, project_id);\n\n        // Clean up any leftover pending-delete from a previous crash\n        if pending_path.exists() {\n            fs::remove_dir_all(&pending_path)?;\n        }\n\n        // Atomic rename to pending-delete location — project becomes\n        // invisible to list/show but data stays on disk.\n        fs::rename(&project_root, &pending_path)?;\n        Ok(())\n    }\n\n    fn commit_delete(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<()> {\n        let pending_path = FileSystem::pending_delete_path(base_dir, project_id);\n        if pending_path.is_dir() {\n            fs::remove_dir_all(&pending_path)?;\n        }\n        Ok(())\n    }\n\n    fn rollback_delete(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<()> {\n        let project_root = FileSystem::project_root(base_dir, project_id);\n        let pending_path = FileSystem::pending_delete_path(base_dir, project_id);\n\n        if !pending_path.is_dir() {\n            return Ok(());\n        }\n\n        fs::rename(&pending_path, &project_root)?;\n        Ok(())\n    }\n\n    fn create_project_atomic(\n        &self,\n        base_dir: &Path,\n        record: &ProjectRecord,\n        prompt_contents: &str,\n        run_snapshot: &RunSnapshot,\n        initial_journal_line: &str,\n        sessions: &SessionStore,\n    ) -> AppResult<()> {\n        let project_root = FileSystem::project_root(base_dir, &record.id);\n\n        // Stage into a temporary directory alongside the final location\n        let staging_name = format!(\".{}.staging.{}\", record.id, std::process::id());\n        let staging_root = project_root\n            .parent()\n            .expect(\"project root has parent\")\n            .join(&staging_name);\n\n        // Clean up any leftover staging dir\n        if staging_root.exists() {\n            fs::remove_dir_all(&staging_root)?;\n        }\n\n        // Create staging directory and all subdirs\n        fs::create_dir_all(&staging_root)?;\n        for subdir in PROJECT_SUBDIRS {\n            fs::create_dir_all(staging_root.join(subdir))?;\n        }\n\n        // Write all canonical files into staging\n        let write_result = (|| -> AppResult<()> {\n            // project.toml\n            let project_toml = toml::to_string_pretty(record)\n                .map_err(|e| AppError::Io(std::io::Error::other(e.to_string())))?;\n            fs::write(staging_root.join(PROJECT_CONFIG_FILE), project_toml)?;\n\n            // prompt.md\n            fs::write(staging_root.join(PROMPT_FILE), prompt_contents)?;\n\n            // run.json\n            let run_json = serde_json::to_string_pretty(run_snapshot)?;\n            fs::write(staging_root.join(RUN_FILE), run_json)?;\n\n            // journal.ndjson (with initial event)\n            let mut journal_content = initial_journal_line.to_owned();\n            journal_content.push('\\n');\n            fs::write(staging_root.join(JOURNAL_FILE), journal_content)?;\n\n            // sessions.json\n            let sessions_json = serde_json::to_string_pretty(sessions)?;\n            fs::write(staging_root.join(SESSIONS_FILE), sessions_json)?;\n\n            Ok(())\n        })();\n\n        if let Err(e) = write_result {\n            // Clean up staging on failure\n            let _ = fs::remove_dir_all(&staging_root);\n            return Err(e);\n        }\n\n        // Atomic rename from staging to final location\n        if let Err(e) = fs::rename(&staging_root, &project_root) {\n            let _ = fs::remove_dir_all(&staging_root);\n            return Err(e.into());\n        }\n\n        Ok(())\n    }\n}\n\n/// Filesystem-backed implementation of `JournalStorePort`.\npub struct FsJournalStore;\n\nimpl JournalStorePort for FsJournalStore {\n    fn read_journal(\n        &self,\n        base_dir: &Path,\n        project_id: &ProjectId,\n    ) -> AppResult<Vec<JournalEvent>> {\n        let path = FileSystem::project_root(base_dir, project_id).join(JOURNAL_FILE);\n        match fs::read_to_string(&path) {\n            Ok(contents) => journal::parse_journal(&contents),\n            Err(e) if e.kind() == std::io::ErrorKind::NotFound => Err(AppError::CorruptRecord {\n                file: format!(\"projects/{}/journal.ndjson\", project_id),\n                details: \"canonical file is missing\".to_owned(),\n            }),\n            Err(e) => Err(e.into()),\n        }\n    }\n\n    fn append_event(&self, base_dir: &Path, project_id: &ProjectId, line: &str) -> AppResult<()> {\n        let path = FileSystem::project_root(base_dir, project_id).join(JOURNAL_FILE);\n        FileSystem::append_line(&path, line)\n    }\n}\n\n/// Filesystem-backed implementation of `ArtifactStorePort`.\npub struct FsArtifactStore;\n\nimpl ArtifactStorePort for FsArtifactStore {\n    fn list_payloads(\n        &self,\n        base_dir: &Path,\n        project_id: &ProjectId,\n    ) -> AppResult<Vec<PayloadRecord>> {\n        let dir = FileSystem::project_root(base_dir, project_id).join(\"history/payloads\");\n        if !dir.is_dir() {\n            return Ok(Vec::new());\n        }\n\n        let mut records = Vec::new();\n        for entry in fs::read_dir(&dir)? {\n            let entry = entry?;\n            let path = entry.path();\n            if path.extension().is_some_and(|ext| ext == \"json\") {\n                let raw = fs::read_to_string(&path)?;\n                let record: PayloadRecord =\n                    serde_json::from_str(&raw).map_err(|e| AppError::CorruptRecord {\n                        file: format!(\n                            \"history/payloads/{}\",\n                            path.file_name().unwrap_or_default().to_string_lossy()\n                        ),\n                        details: e.to_string(),\n                    })?;\n                records.push(record);\n            }\n        }\n\n        records.sort_by_key(|r| r.created_at);\n        Ok(records)\n    }\n\n    fn list_artifacts(\n        &self,\n        base_dir: &Path,\n        project_id: &ProjectId,\n    ) -> AppResult<Vec<ArtifactRecord>> {\n        let dir = FileSystem::project_root(base_dir, project_id).join(\"history/artifacts\");\n        if !dir.is_dir() {\n            return Ok(Vec::new());\n        }\n\n        let mut records = Vec::new();\n        for entry in fs::read_dir(&dir)? {\n            let entry = entry?;\n            let path = entry.path();\n            if path.extension().is_some_and(|ext| ext == \"json\") {\n                let raw = fs::read_to_string(&path)?;\n                let record: ArtifactRecord =\n                    serde_json::from_str(&raw).map_err(|e| AppError::CorruptRecord {\n                        file: format!(\n                            \"history/artifacts/{}\",\n                            path.file_name().unwrap_or_default().to_string_lossy()\n                        ),\n                        details: e.to_string(),\n                    })?;\n                records.push(record);\n            }\n        }\n\n        records.sort_by_key(|r| r.created_at);\n        Ok(records)\n    }\n}\n\n/// Filesystem-backed implementation of `RuntimeLogStorePort`.\npub struct FsRuntimeLogStore;\n\nimpl RuntimeLogStorePort for FsRuntimeLogStore {\n    fn read_runtime_logs(\n        &self,\n        base_dir: &Path,\n        project_id: &ProjectId,\n    ) -> AppResult<Vec<RuntimeLogEntry>> {\n        let dir = FileSystem::project_root(base_dir, project_id).join(\"runtime/logs\");\n        if !dir.is_dir() {\n            return Ok(Vec::new());\n        }\n\n        let mut entries = Vec::new();\n        let mut paths: Vec<_> = fs::read_dir(&dir)?\n            .filter_map(|e| e.ok())\n            .map(|e| e.path())\n            .filter(|p| p.extension().is_some_and(|ext| ext == \"ndjson\"))\n            .collect();\n        paths.sort();\n\n        // Only read the newest/latest log file per spec:\n        // \"run tail --logs appends the newest runtime logs\"\n        if let Some(path) = paths.last() {\n            let contents = fs::read_to_string(path)?;\n            for line in contents.lines() {\n                let trimmed = line.trim();\n                if trimmed.is_empty() {\n                    continue;\n                }\n                if let Ok(entry) = serde_json::from_str::<RuntimeLogEntry>(trimmed) {\n                    entries.push(entry);\n                }\n            }\n        }\n\n        Ok(entries)\n    }\n}\n\n/// Filesystem-backed implementation of `RunSnapshotPort`.\npub struct FsRunSnapshotStore;\n\nimpl RunSnapshotPort for FsRunSnapshotStore {\n    fn read_run_snapshot(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<RunSnapshot> {\n        let path = FileSystem::project_root(base_dir, project_id).join(RUN_FILE);\n        match fs::read_to_string(&path) {\n            Ok(raw) => {\n                let snapshot: RunSnapshot =\n                    serde_json::from_str(&raw).map_err(|e| AppError::CorruptRecord {\n                        file: format!(\"projects/{}/run.json\", project_id),\n                        details: e.to_string(),\n                    })?;\n                // Semantic validation: reject inconsistent status/active_run combinations\n                snapshot\n                    .validate_semantics()\n                    .map_err(|details| AppError::CorruptRecord {\n                        file: format!(\"projects/{}/run.json\", project_id),\n                        details,\n                    })?;\n                Ok(snapshot)\n            }\n            Err(e) if e.kind() == std::io::ErrorKind::NotFound => Err(AppError::CorruptRecord {\n                file: format!(\"projects/{}/run.json\", project_id),\n                details: \"canonical file is missing\".to_owned(),\n            }),\n            Err(e) => Err(e.into()),\n        }\n    }\n}\n\n/// Filesystem-backed implementation of `ActiveProjectPort`.\npub struct FsActiveProjectStore;\n\nimpl ActiveProjectPort for FsActiveProjectStore {\n    fn read_active_project_id(&self, base_dir: &Path) -> AppResult<Option<String>> {\n        FileSystem::read_active_project(&FileSystem::workspace_root_path(base_dir))\n    }\n\n    fn clear_active_project(&self, base_dir: &Path) -> AppResult<()> {\n        let path = FileSystem::workspace_root_path(base_dir).join(ACTIVE_PROJECT_FILE);\n        match fs::remove_file(&path) {\n            Ok(()) => Ok(()),\n            Err(e) if e.kind() == std::io::ErrorKind::NotFound => Ok(()),\n            Err(e) => Err(e.into()),\n        }\n    }\n\n    fn write_active_project(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<()> {\n        FileSystem::write_active_project(\n            &FileSystem::workspace_root_path(base_dir),\n            project_id.as_str(),\n        )\n    }\n}\n\n/// Filesystem-backed implementation of `RawOutputPort`.\npub struct FsRawOutputStore;\n\nimpl RawOutputPort for FsRawOutputStore {\n    fn persist_raw_output(\n        &self,\n        project_root: &Path,\n        invocation_id: &str,\n        contents: &str,\n    ) -> AppResult<RawOutputReference> {\n        let path = project_root\n            .join(\"runtime/backend\")\n            .join(format!(\"{invocation_id}.raw\"));\n        FileSystem::write_atomic(&path, contents)?;\n        Ok(RawOutputReference::Stored(path))\n    }\n}\n\n/// Filesystem-backed implementation of `SessionStorePort`.\npub struct FsSessionStore;\n\nimpl SessionStorePort for FsSessionStore {\n    fn load_sessions(&self, project_root: &Path) -> AppResult<PersistedSessions> {\n        let path = project_root.join(SESSIONS_FILE);\n        match fs::read_to_string(&path) {\n            Ok(raw) => serde_json::from_str(&raw).map_err(|error| AppError::CorruptRecord {\n                file: format!(\"{}/{}\", project_root.display(), SESSIONS_FILE),\n                details: error.to_string(),\n            }),\n            Err(error) if error.kind() == std::io::ErrorKind::NotFound => {\n                Err(AppError::CorruptRecord {\n                    file: format!(\"{}/{}\", project_root.display(), SESSIONS_FILE),\n                    details: \"canonical file is missing\".to_owned(),\n                })\n            }\n            Err(error) => Err(error.into()),\n        }\n    }\n\n    fn save_sessions(&self, project_root: &Path, sessions: &PersistedSessions) -> AppResult<()> {\n        let path = project_root.join(SESSIONS_FILE);\n        let contents = serde_json::to_string_pretty(sessions)?;\n        FileSystem::write_atomic(&path, &contents)\n    }\n}\n\n/// Filesystem-backed implementation of `RunSnapshotWritePort`.\npub struct FsRunSnapshotWriteStore;\n\nimpl RunSnapshotWritePort for FsRunSnapshotWriteStore {\n    fn write_run_snapshot(\n        &self,\n        base_dir: &Path,\n        project_id: &ProjectId,\n        snapshot: &RunSnapshot,\n    ) -> AppResult<()> {\n        let path = FileSystem::project_root(base_dir, project_id).join(RUN_FILE);\n        let contents = serde_json::to_string_pretty(snapshot)?;\n        FileSystem::write_atomic(&path, &contents)\n    }\n}\n\n/// Filesystem-backed implementation of `PayloadArtifactWritePort`.\npub struct FsPayloadArtifactWriteStore;\n\nimpl PayloadArtifactWritePort for FsPayloadArtifactWriteStore {\n    fn write_payload_artifact_pair(\n        &self,\n        base_dir: &Path,\n        project_id: &ProjectId,\n        payload: &PayloadRecord,\n        artifact: &ArtifactRecord,\n    ) -> AppResult<()> {\n        let project_root = FileSystem::project_root(base_dir, project_id);\n\n        // Write payload first\n        let payload_path = project_root\n            .join(\"history/payloads\")\n            .join(format!(\"{}.json\", payload.payload_id));\n        let payload_json = serde_json::to_string_pretty(payload)?;\n        FileSystem::write_atomic(&payload_path, &payload_json)?;\n\n        // Write artifact second — if this fails, remove the payload to maintain pairing invariant\n        let artifact_path = project_root\n            .join(\"history/artifacts\")\n            .join(format!(\"{}.json\", artifact.artifact_id));\n        let artifact_json = serde_json::to_string_pretty(artifact)?;\n        if let Err(e) = FileSystem::write_atomic(&artifact_path, &artifact_json) {\n            let _ = fs::remove_file(&payload_path);\n            return Err(e);\n        }\n\n        Ok(())\n    }\n}\n\n/// Filesystem-backed implementation of `RuntimeLogWritePort`.\npub struct FsRuntimeLogWriteStore;\n\nimpl RuntimeLogWritePort for FsRuntimeLogWriteStore {\n    fn append_runtime_log(\n        &self,\n        base_dir: &Path,\n        project_id: &ProjectId,\n        entry: &RuntimeLogEntry,\n    ) -> AppResult<()> {\n        let dir = FileSystem::project_root(base_dir, project_id).join(\"runtime/logs\");\n        fs::create_dir_all(&dir)?;\n        let path = dir.join(\"run.ndjson\");\n        let line = serde_json::to_string(entry)?;\n        FileSystem::append_line(&path, &line)\n    }\n}\n","numLines":701,"startLine":1,"totalLines":701}}}
