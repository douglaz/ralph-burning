{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Bh7ot6c7cmdeahazAbB3fx","type":"tool_result","content":"     1→use std::env;\n     2→use std::fs::{self, OpenOptions};\n     3→use std::io::Write;\n     4→use std::path::{Path, PathBuf};\n     5→use std::process::Command;\n     6→use std::time::{SystemTime, UNIX_EPOCH};\n     7→\n     8→use crate::contexts::agent_execution::model::RawOutputReference;\n     9→use crate::contexts::agent_execution::service::RawOutputPort;\n    10→use crate::contexts::agent_execution::session::{PersistedSessions, SessionStorePort};\n    11→use crate::contexts::project_run_record::journal;\n    12→use crate::contexts::project_run_record::model::{\n    13→    ArtifactRecord, JournalEvent, PayloadRecord, ProjectRecord, RunSnapshot, RuntimeLogEntry,\n    14→    SessionStore,\n    15→};\n    16→use crate::contexts::project_run_record::service::{\n    17→    ActiveProjectPort, ArtifactStorePort, JournalStorePort, ProjectStorePort, RunSnapshotPort,\n    18→    RuntimeLogStorePort,\n    19→};\n    20→use crate::shared::domain::{ProjectId, WorkspaceConfig};\n    21→use crate::shared::error::{AppError, AppResult};\n    22→\n    23→const ACTIVE_PROJECT_FILE: &str = \"active-project\";\n    24→const WORKSPACE_DIR: &str = \".ralph-burning\";\n    25→const PROJECTS_DIR: &str = \"projects\";\n    26→const PROJECT_CONFIG_FILE: &str = \"project.toml\";\n    27→const RUN_FILE: &str = \"run.json\";\n    28→const JOURNAL_FILE: &str = \"journal.ndjson\";\n    29→const SESSIONS_FILE: &str = \"sessions.json\";\n    30→const PROMPT_FILE: &str = \"prompt.md\";\n    31→\n    32→/// Required subdirectories inside a project.\n    33→const PROJECT_SUBDIRS: &[&str] = &[\n    34→    \"history/payloads\",\n    35→    \"history/artifacts\",\n    36→    \"runtime/logs\",\n    37→    \"runtime/backend\",\n    38→    \"runtime/temp\",\n    39→    \"amendments\",\n    40→    \"rollback\",\n    41→];\n    42→\n    43→pub struct FileSystem;\n    44→\n    45→impl FileSystem {\n    46→    pub fn create_workspace(\n    47→        workspace_root: &Path,\n    48→        workspace_config: &str,\n    49→        required_directories: &[&str],\n    50→    ) -> AppResult<()> {\n    51→        fs::create_dir_all(workspace_root)?;\n    52→\n    53→        for directory in required_directories {\n    54→            fs::create_dir_all(workspace_root.join(directory))?;\n    55→        }\n    56→\n    57→        Self::write_atomic(&workspace_root.join(\"workspace.toml\"), workspace_config)?;\n    58→        Ok(())\n    59→    }\n    60→\n    61→    pub fn read_to_string(path: &Path) -> AppResult<String> {\n    62→        Ok(fs::read_to_string(path)?)\n    63→    }\n    64→\n    65→    pub fn write_atomic(path: &Path, contents: &str) -> AppResult<()> {\n    66→        let parent = path.parent().ok_or_else(|| {\n    67→            AppError::Io(std::io::Error::new(\n    68→                std::io::ErrorKind::InvalidInput,\n    69→                format!(\"path '{}' has no parent directory\", path.display()),\n    70→            ))\n    71→        })?;\n    72→        fs::create_dir_all(parent)?;\n    73→\n    74→        let timestamp = SystemTime::now()\n    75→            .duration_since(UNIX_EPOCH)\n    76→            .map(|duration| duration.as_nanos())\n    77→            .unwrap_or_default();\n    78→        let temp_path = parent.join(format!(\n    79→            \".{}.{}.{}.tmp\",\n    80→            path.file_name()\n    81→                .and_then(|value| value.to_str())\n    82→                .unwrap_or(\"workspace\"),\n    83→            std::process::id(),\n    84→            timestamp\n    85→        ));\n    86→\n    87→        let mut file = OpenOptions::new()\n    88→            .create_new(true)\n    89→            .write(true)\n    90→            .open(&temp_path)?;\n    91→        file.write_all(contents.as_bytes())?;\n    92→        file.sync_all()?;\n    93→        drop(file);\n    94→\n    95→        if let Err(error) = fs::rename(&temp_path, path) {\n    96→            let _ = fs::remove_file(&temp_path);\n    97→            return Err(error.into());\n    98→        }\n    99→\n   100→        Ok(())\n   101→    }\n   102→\n   103→    pub fn render_workspace_config(config: &WorkspaceConfig) -> AppResult<String> {\n   104→        Ok(toml::to_string_pretty(config)?)\n   105→    }\n   106→\n   107→    pub fn read_active_project(workspace_root: &Path) -> AppResult<Option<String>> {\n   108→        let path = workspace_root.join(ACTIVE_PROJECT_FILE);\n   109→        match fs::read_to_string(path) {\n   110→            Ok(raw) => {\n   111→                let trimmed = raw.trim();\n   112→                if trimmed.is_empty() {\n   113→                    Ok(None)\n   114→                } else {\n   115→                    Ok(Some(trimmed.to_owned()))\n   116→                }\n   117→            }\n   118→            Err(error) if error.kind() == std::io::ErrorKind::NotFound => Ok(None),\n   119→            Err(error) => Err(error.into()),\n   120→        }\n   121→    }\n   122→\n   123→    pub fn write_active_project(workspace_root: &Path, project_id: &str) -> AppResult<()> {\n   124→        Self::write_atomic(&workspace_root.join(ACTIVE_PROJECT_FILE), project_id)\n   125→    }\n   126→\n   127→    pub fn open_editor(path: &Path) -> AppResult<()> {\n   128→        let editor = env::var(\"EDITOR\")\n   129→            .ok()\n   130→            .filter(|value| !value.trim().is_empty())\n   131→            .or_else(|| {\n   132→                env::var(\"VISUAL\")\n   133→                    .ok()\n   134→                    .filter(|value| !value.trim().is_empty())\n   135→            })\n   136→            .unwrap_or_else(|| \"vi\".to_owned());\n   137→\n   138→        let mut parts = editor.split_whitespace();\n   139→        let program = parts.next().ok_or_else(|| AppError::EditorFailed {\n   140→            editor: editor.clone(),\n   141→            details: \": empty editor command\".to_owned(),\n   142→        })?;\n   143→        let status = Command::new(program).args(parts).arg(path).status()?;\n   144→\n   145→        if status.success() {\n   146→            Ok(())\n   147→        } else {\n   148→            let details = match status.code() {\n   149→                Some(code) => format!(\" with exit code {code}\"),\n   150→                None => \" after being terminated by a signal\".to_owned(),\n   151→            };\n   152→            Err(AppError::EditorFailed { editor, details })\n   153→        }\n   154→    }\n   155→\n   156→    /// Compute a simple hash of content for prompt integrity tracking.\n   157→    pub fn prompt_hash(contents: &str) -> String {\n   158→        use std::collections::hash_map::DefaultHasher;\n   159→        use std::hash::{Hash, Hasher};\n   160→        let mut hasher = DefaultHasher::new();\n   161→        contents.hash(&mut hasher);\n   162→        format!(\"{:016x}\", hasher.finish())\n   163→    }\n   164→\n   165→    // ── Helpers for project filesystem layout ──\n   166→\n   167→    fn workspace_root_path(base_dir: &Path) -> PathBuf {\n   168→        base_dir.join(WORKSPACE_DIR)\n   169→    }\n   170→\n   171→    fn project_root(base_dir: &Path, project_id: &ProjectId) -> PathBuf {\n   172→        Self::workspace_root_path(base_dir)\n   173→            .join(PROJECTS_DIR)\n   174→            .join(project_id.as_str())\n   175→    }\n   176→\n   177→    fn pending_delete_path(base_dir: &Path, project_id: &ProjectId) -> PathBuf {\n   178→        Self::workspace_root_path(base_dir)\n   179→            .join(PROJECTS_DIR)\n   180→            .join(format!(\".{}.pending-delete\", project_id))\n   181→    }\n   182→\n   183→    fn append_line(path: &Path, line: &str) -> AppResult<()> {\n   184→        let parent = path.parent().ok_or_else(|| {\n   185→            AppError::Io(std::io::Error::new(\n   186→                std::io::ErrorKind::InvalidInput,\n   187→                format!(\"path '{}' has no parent directory\", path.display()),\n   188→            ))\n   189→        })?;\n   190→        fs::create_dir_all(parent)?;\n   191→\n   192→        let mut file = OpenOptions::new().create(true).append(true).open(path)?;\n   193→        writeln!(file, \"{}\", line)?;\n   194→        file.sync_all()?;\n   195→        Ok(())\n   196→    }\n   197→}\n   198→\n   199→/// Filesystem-backed implementation of `ProjectStorePort`.\n   200→pub struct FsProjectStore;\n   201→\n   202→impl ProjectStorePort for FsProjectStore {\n   203→    fn project_exists(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<bool> {\n   204→        let project_root = FileSystem::project_root(base_dir, project_id);\n   205→        if !project_root.is_dir() {\n   206→            return Ok(false);\n   207→        }\n   208→        if !project_root.join(PROJECT_CONFIG_FILE).is_file() {\n   209→            return Err(AppError::CorruptRecord {\n   210→                file: format!(\"projects/{}/project.toml\", project_id),\n   211→                details: \"project directory exists but canonical project.toml is missing\"\n   212→                    .to_owned(),\n   213→            });\n   214→        }\n   215→        Ok(true)\n   216→    }\n   217→\n   218→    fn read_project_record(\n   219→        &self,\n   220→        base_dir: &Path,\n   221→        project_id: &ProjectId,\n   222→    ) -> AppResult<ProjectRecord> {\n   223→        let project_root = FileSystem::project_root(base_dir, project_id);\n   224→        let path = project_root.join(PROJECT_CONFIG_FILE);\n   225→        let raw = fs::read_to_string(&path).map_err(|e| {\n   226→            if e.kind() == std::io::ErrorKind::NotFound {\n   227→                if project_root.is_dir() {\n   228→                    // Directory exists but project.toml is missing — corruption\n   229→                    AppError::CorruptRecord {\n   230→                        file: format!(\"projects/{}/project.toml\", project_id),\n   231→                        details: \"project directory exists but canonical project.toml is missing\"\n   232→                            .to_owned(),\n   233→                    }\n   234→                } else {\n   235→                    AppError::ProjectNotFound {\n   236→                        project_id: project_id.to_string(),\n   237→                    }\n   238→                }\n   239→            } else {\n   240→                e.into()\n   241→            }\n   242→        })?;\n   243→        toml::from_str(&raw).map_err(|e| AppError::CorruptRecord {\n   244→            file: format!(\"projects/{}/project.toml\", project_id),\n   245→            details: e.to_string(),\n   246→        })\n   247→    }\n   248→\n   249→    fn list_project_ids(&self, base_dir: &Path) -> AppResult<Vec<ProjectId>> {\n   250→        let projects_dir = FileSystem::workspace_root_path(base_dir).join(PROJECTS_DIR);\n   251→        if !projects_dir.is_dir() {\n   252→            return Ok(Vec::new());\n   253→        }\n   254→\n   255→        let mut ids = Vec::new();\n   256→        for entry in fs::read_dir(&projects_dir)? {\n   257→            let entry = entry?;\n   258→            if !entry.file_type()?.is_dir() {\n   259→                continue;\n   260→            }\n   261→            let name = entry.file_name();\n   262→            let name_str = name.to_string_lossy();\n   263→            // Skip hidden directories (staging/trash from transactional operations)\n   264→            if name_str.starts_with('.') {\n   265→                continue;\n   266→            }\n   267→            if let Ok(pid) = ProjectId::new(name_str.as_ref()) {\n   268→                if !entry.path().join(PROJECT_CONFIG_FILE).is_file() {\n   269→                    return Err(AppError::CorruptRecord {\n   270→                        file: format!(\"projects/{}/project.toml\", name_str),\n   271→                        details: \"project directory exists but canonical project.toml is missing\"\n   272→                            .to_owned(),\n   273→                    });\n   274→                }\n   275→                ids.push(pid);\n   276→            }\n   277→        }\n   278→\n   279→        ids.sort_by(|a, b| a.as_str().cmp(b.as_str()));\n   280→        Ok(ids)\n   281→    }\n   282→\n   283→    fn stage_delete(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<()> {\n   284→        let project_root = FileSystem::project_root(base_dir, project_id);\n   285→        if !project_root.is_dir() {\n   286→            return Err(AppError::ProjectNotFound {\n   287→                project_id: project_id.to_string(),\n   288→            });\n   289→        }\n   290→\n   291→        let pending_path = FileSystem::pending_delete_path(base_dir, project_id);\n   292→\n   293→        // Clean up any leftover pending-delete from a previous crash\n   294→        if pending_path.exists() {\n   295→            fs::remove_dir_all(&pending_path)?;\n   296→        }\n   297→\n   298→        // Atomic rename to pending-delete location — project becomes\n   299→        // invisible to list/show but data stays on disk.\n   300→        fs::rename(&project_root, &pending_path)?;\n   301→        Ok(())\n   302→    }\n   303→\n   304→    fn commit_delete(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<()> {\n   305→        let pending_path = FileSystem::pending_delete_path(base_dir, project_id);\n   306→        if pending_path.is_dir() {\n   307→            fs::remove_dir_all(&pending_path)?;\n   308→        }\n   309→        Ok(())\n   310→    }\n   311→\n   312→    fn rollback_delete(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<()> {\n   313→        let project_root = FileSystem::project_root(base_dir, project_id);\n   314→        let pending_path = FileSystem::pending_delete_path(base_dir, project_id);\n   315→\n   316→        if !pending_path.is_dir() {\n   317→            return Ok(());\n   318→        }\n   319→\n   320→        fs::rename(&pending_path, &project_root)?;\n   321→        Ok(())\n   322→    }\n   323→\n   324→    fn create_project_atomic(\n   325→        &self,\n   326→        base_dir: &Path,\n   327→        record: &ProjectRecord,\n   328→        prompt_contents: &str,\n   329→        run_snapshot: &RunSnapshot,\n   330→        initial_journal_line: &str,\n   331→        sessions: &SessionStore,\n   332→    ) -> AppResult<()> {\n   333→        let project_root = FileSystem::project_root(base_dir, &record.id);\n   334→\n   335→        // Stage into a temporary directory alongside the final location\n   336→        let staging_name = format!(\".{}.staging.{}\", record.id, std::process::id());\n   337→        let staging_root = project_root\n   338→            .parent()\n   339→            .expect(\"project root has parent\")\n   340→            .join(&staging_name);\n   341→\n   342→        // Clean up any leftover staging dir\n   343→        if staging_root.exists() {\n   344→            fs::remove_dir_all(&staging_root)?;\n   345→        }\n   346→\n   347→        // Create staging directory and all subdirs\n   348→        fs::create_dir_all(&staging_root)?;\n   349→        for subdir in PROJECT_SUBDIRS {\n   350→            fs::create_dir_all(staging_root.join(subdir))?;\n   351→        }\n   352→\n   353→        // Write all canonical files into staging\n   354→        let write_result = (|| -> AppResult<()> {\n   355→            // project.toml\n   356→            let project_toml = toml::to_string_pretty(record)\n   357→                .map_err(|e| AppError::Io(std::io::Error::other(e.to_string())))?;\n   358→            fs::write(staging_root.join(PROJECT_CONFIG_FILE), project_toml)?;\n   359→\n   360→            // prompt.md\n   361→            fs::write(staging_root.join(PROMPT_FILE), prompt_contents)?;\n   362→\n   363→            // run.json\n   364→            let run_json = serde_json::to_string_pretty(run_snapshot)?;\n   365→            fs::write(staging_root.join(RUN_FILE), run_json)?;\n   366→\n   367→            // journal.ndjson (with initial event)\n   368→            let mut journal_content = initial_journal_line.to_owned();\n   369→            journal_content.push('\\n');\n   370→            fs::write(staging_root.join(JOURNAL_FILE), journal_content)?;\n   371→\n   372→            // sessions.json\n   373→            let sessions_json = serde_json::to_string_pretty(sessions)?;\n   374→            fs::write(staging_root.join(SESSIONS_FILE), sessions_json)?;\n   375→\n   376→            Ok(())\n   377→        })();\n   378→\n   379→        if let Err(e) = write_result {\n   380→            // Clean up staging on failure\n   381→            let _ = fs::remove_dir_all(&staging_root);\n   382→            return Err(e);\n   383→        }\n   384→\n   385→        // Atomic rename from staging to final location\n   386→        if let Err(e) = fs::rename(&staging_root, &project_root) {\n   387→            let _ = fs::remove_dir_all(&staging_root);\n   388→            return Err(e.into());\n   389→        }\n   390→\n   391→        Ok(())\n   392→    }\n   393→}\n   394→\n   395→/// Filesystem-backed implementation of `JournalStorePort`.\n   396→pub struct FsJournalStore;\n   397→\n   398→impl JournalStorePort for FsJournalStore {\n   399→    fn read_journal(\n   400→        &self,\n   401→        base_dir: &Path,\n   402→        project_id: &ProjectId,\n   403→    ) -> AppResult<Vec<JournalEvent>> {\n   404→        let path = FileSystem::project_root(base_dir, project_id).join(JOURNAL_FILE);\n   405→        match fs::read_to_string(&path) {\n   406→            Ok(contents) => journal::parse_journal(&contents),\n   407→            Err(e) if e.kind() == std::io::ErrorKind::NotFound => Err(AppError::CorruptRecord {\n   408→                file: format!(\"projects/{}/journal.ndjson\", project_id),\n   409→                details: \"canonical file is missing\".to_owned(),\n   410→            }),\n   411→            Err(e) => Err(e.into()),\n   412→        }\n   413→    }\n   414→\n   415→    fn append_event(&self, base_dir: &Path, project_id: &ProjectId, line: &str) -> AppResult<()> {\n   416→        let path = FileSystem::project_root(base_dir, project_id).join(JOURNAL_FILE);\n   417→        FileSystem::append_line(&path, line)\n   418→    }\n   419→}\n   420→\n   421→/// Filesystem-backed implementation of `ArtifactStorePort`.\n   422→pub struct FsArtifactStore;\n   423→\n   424→impl ArtifactStorePort for FsArtifactStore {\n   425→    fn list_payloads(\n   426→        &self,\n   427→        base_dir: &Path,\n   428→        project_id: &ProjectId,\n   429→    ) -> AppResult<Vec<PayloadRecord>> {\n   430→        let dir = FileSystem::project_root(base_dir, project_id).join(\"history/payloads\");\n   431→        if !dir.is_dir() {\n   432→            return Ok(Vec::new());\n   433→        }\n   434→\n   435→        let mut records = Vec::new();\n   436→        for entry in fs::read_dir(&dir)? {\n   437→            let entry = entry?;\n   438→            let path = entry.path();\n   439→            if path.extension().is_some_and(|ext| ext == \"json\") {\n   440→                let raw = fs::read_to_string(&path)?;\n   441→                let record: PayloadRecord =\n   442→                    serde_json::from_str(&raw).map_err(|e| AppError::CorruptRecord {\n   443→                        file: format!(\n   444→                            \"history/payloads/{}\",\n   445→                            path.file_name().unwrap_or_default().to_string_lossy()\n   446→                        ),\n   447→                        details: e.to_string(),\n   448→                    })?;\n   449→                records.push(record);\n   450→            }\n   451→        }\n   452→\n   453→        records.sort_by_key(|r| r.created_at);\n   454→        Ok(records)\n   455→    }\n   456→\n   457→    fn list_artifacts(\n   458→        &self,\n   459→        base_dir: &Path,\n   460→        project_id: &ProjectId,\n   461→    ) -> AppResult<Vec<ArtifactRecord>> {\n   462→        let dir = FileSystem::project_root(base_dir, project_id).join(\"history/artifacts\");\n   463→        if !dir.is_dir() {\n   464→            return Ok(Vec::new());\n   465→        }\n   466→\n   467→        let mut records = Vec::new();\n   468→        for entry in fs::read_dir(&dir)? {\n   469→            let entry = entry?;\n   470→            let path = entry.path();\n   471→            if path.extension().is_some_and(|ext| ext == \"json\") {\n   472→                let raw = fs::read_to_string(&path)?;\n   473→                let record: ArtifactRecord =\n   474→                    serde_json::from_str(&raw).map_err(|e| AppError::CorruptRecord {\n   475→                        file: format!(\n   476→                            \"history/artifacts/{}\",\n   477→                            path.file_name().unwrap_or_default().to_string_lossy()\n   478→                        ),\n   479→                        details: e.to_string(),\n   480→                    })?;\n   481→                records.push(record);\n   482→            }\n   483→        }\n   484→\n   485→        records.sort_by_key(|r| r.created_at);\n   486→        Ok(records)\n   487→    }\n   488→}\n   489→\n   490→/// Filesystem-backed implementation of `RuntimeLogStorePort`.\n   491→pub struct FsRuntimeLogStore;\n   492→\n   493→impl RuntimeLogStorePort for FsRuntimeLogStore {\n   494→    fn read_runtime_logs(\n   495→        &self,\n   496→        base_dir: &Path,\n   497→        project_id: &ProjectId,\n   498→    ) -> AppResult<Vec<RuntimeLogEntry>> {\n   499→        let dir = FileSystem::project_root(base_dir, project_id).join(\"runtime/logs\");\n   500→        if !dir.is_dir() {\n   501→            return Ok(Vec::new());\n   502→        }\n   503→\n   504→        let mut entries = Vec::new();\n   505→        let mut paths: Vec<_> = fs::read_dir(&dir)?\n   506→            .filter_map(|e| e.ok())\n   507→            .map(|e| e.path())\n   508→            .filter(|p| p.extension().is_some_and(|ext| ext == \"ndjson\"))\n   509→            .collect();\n   510→        paths.sort();\n   511→\n   512→        // Only read the newest/latest log file per spec:\n   513→        // \"run tail --logs appends the newest runtime logs\"\n   514→        if let Some(path) = paths.last() {\n   515→            let contents = fs::read_to_string(path)?;\n   516→            for line in contents.lines() {\n   517→                let trimmed = line.trim();\n   518→                if trimmed.is_empty() {\n   519→                    continue;\n   520→                }\n   521→                if let Ok(entry) = serde_json::from_str::<RuntimeLogEntry>(trimmed) {\n   522→                    entries.push(entry);\n   523→                }\n   524→            }\n   525→        }\n   526→\n   527→        Ok(entries)\n   528→    }\n   529→}\n   530→\n   531→/// Filesystem-backed implementation of `RunSnapshotPort`.\n   532→pub struct FsRunSnapshotStore;\n   533→\n   534→impl RunSnapshotPort for FsRunSnapshotStore {\n   535→    fn read_run_snapshot(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<RunSnapshot> {\n   536→        let path = FileSystem::project_root(base_dir, project_id).join(RUN_FILE);\n   537→        match fs::read_to_string(&path) {\n   538→            Ok(raw) => {\n   539→                let snapshot: RunSnapshot =\n   540→                    serde_json::from_str(&raw).map_err(|e| AppError::CorruptRecord {\n   541→                        file: format!(\"projects/{}/run.json\", project_id),\n   542→                        details: e.to_string(),\n   543→                    })?;\n   544→                // Semantic validation: reject inconsistent status/active_run combinations\n   545→                snapshot\n   546→                    .validate_semantics()\n   547→                    .map_err(|details| AppError::CorruptRecord {\n   548→                        file: format!(\"projects/{}/run.json\", project_id),\n   549→                        details,\n   550→                    })?;\n   551→                Ok(snapshot)\n   552→            }\n   553→            Err(e) if e.kind() == std::io::ErrorKind::NotFound => Err(AppError::CorruptRecord {\n   554→                file: format!(\"projects/{}/run.json\", project_id),\n   555→                details: \"canonical file is missing\".to_owned(),\n   556→            }),\n   557→            Err(e) => Err(e.into()),\n   558→        }\n   559→    }\n   560→}\n   561→\n   562→/// Filesystem-backed implementation of `ActiveProjectPort`.\n   563→pub struct FsActiveProjectStore;\n   564→\n   565→impl ActiveProjectPort for FsActiveProjectStore {\n   566→    fn read_active_project_id(&self, base_dir: &Path) -> AppResult<Option<String>> {\n   567→        FileSystem::read_active_project(&FileSystem::workspace_root_path(base_dir))\n   568→    }\n   569→\n   570→    fn clear_active_project(&self, base_dir: &Path) -> AppResult<()> {\n   571→        let path = FileSystem::workspace_root_path(base_dir).join(ACTIVE_PROJECT_FILE);\n   572→        match fs::remove_file(&path) {\n   573→            Ok(()) => Ok(()),\n   574→            Err(e) if e.kind() == std::io::ErrorKind::NotFound => Ok(()),\n   575→            Err(e) => Err(e.into()),\n   576→        }\n   577→    }\n   578→\n   579→    fn write_active_project(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<()> {\n   580→        FileSystem::write_active_project(\n   581→            &FileSystem::workspace_root_path(base_dir),\n   582→            project_id.as_str(),\n   583→        )\n   584→    }\n   585→}\n   586→\n   587→/// Filesystem-backed implementation of `RawOutputPort`.\n   588→pub struct FsRawOutputStore;\n   589→\n   590→impl RawOutputPort for FsRawOutputStore {\n   591→    fn persist_raw_output(\n   592→        &self,\n   593→        project_root: &Path,\n   594→        invocation_id: &str,\n   595→        contents: &str,\n   596→    ) -> AppResult<RawOutputReference> {\n   597→        let path = project_root\n   598→            .join(\"runtime/backend\")\n   599→            .join(format!(\"{invocation_id}.raw\"));\n   600→        FileSystem::write_atomic(&path, contents)?;\n   601→        Ok(RawOutputReference::Stored(path))\n   602→    }\n   603→}\n   604→\n   605→/// Filesystem-backed implementation of `SessionStorePort`.\n   606→pub struct FsSessionStore;\n   607→\n   608→impl SessionStorePort for FsSessionStore {\n   609→    fn load_sessions(&self, project_root: &Path) -> AppResult<PersistedSessions> {\n   610→        let path = project_root.join(SESSIONS_FILE);\n   611→        match fs::read_to_string(&path) {\n   612→            Ok(raw) => serde_json::from_str(&raw).map_err(|error| AppError::CorruptRecord {\n   613→                file: format!(\"{}/{}\", project_root.display(), SESSIONS_FILE),\n   614→                details: error.to_string(),\n   615→            }),\n   616→            Err(error) if error.kind() == std::io::ErrorKind::NotFound => {\n   617→                Err(AppError::CorruptRecord {\n   618→                    file: format!(\"{}/{}\", project_root.display(), SESSIONS_FILE),\n   619→                    details: \"canonical file is missing\".to_owned(),\n   620→                })\n   621→            }\n   622→            Err(error) => Err(error.into()),\n   623→        }\n   624→    }\n   625→\n   626→    fn save_sessions(&self, project_root: &Path, sessions: &PersistedSessions) -> AppResult<()> {\n   627→        let path = project_root.join(SESSIONS_FILE);\n   628→        let contents = serde_json::to_string_pretty(sessions)?;\n   629→        FileSystem::write_atomic(&path, &contents)\n   630→    }\n   631→}\n   632→"}]},"parent_tool_use_id":null,"session_id":"b9859e69-5579-4e82-ac66-49d19cc80e05","uuid":"61ecbb38-01b4-4232-a8c0-bab7e02486c8","tool_use_result":{"type":"text","file":{"filePath":"/root/new-ralph-burning/ralph-burning-rewrite/src/adapters/fs.rs","content":"use std::env;\nuse std::fs::{self, OpenOptions};\nuse std::io::Write;\nuse std::path::{Path, PathBuf};\nuse std::process::Command;\nuse std::time::{SystemTime, UNIX_EPOCH};\n\nuse crate::contexts::agent_execution::model::RawOutputReference;\nuse crate::contexts::agent_execution::service::RawOutputPort;\nuse crate::contexts::agent_execution::session::{PersistedSessions, SessionStorePort};\nuse crate::contexts::project_run_record::journal;\nuse crate::contexts::project_run_record::model::{\n    ArtifactRecord, JournalEvent, PayloadRecord, ProjectRecord, RunSnapshot, RuntimeLogEntry,\n    SessionStore,\n};\nuse crate::contexts::project_run_record::service::{\n    ActiveProjectPort, ArtifactStorePort, JournalStorePort, ProjectStorePort, RunSnapshotPort,\n    RuntimeLogStorePort,\n};\nuse crate::shared::domain::{ProjectId, WorkspaceConfig};\nuse crate::shared::error::{AppError, AppResult};\n\nconst ACTIVE_PROJECT_FILE: &str = \"active-project\";\nconst WORKSPACE_DIR: &str = \".ralph-burning\";\nconst PROJECTS_DIR: &str = \"projects\";\nconst PROJECT_CONFIG_FILE: &str = \"project.toml\";\nconst RUN_FILE: &str = \"run.json\";\nconst JOURNAL_FILE: &str = \"journal.ndjson\";\nconst SESSIONS_FILE: &str = \"sessions.json\";\nconst PROMPT_FILE: &str = \"prompt.md\";\n\n/// Required subdirectories inside a project.\nconst PROJECT_SUBDIRS: &[&str] = &[\n    \"history/payloads\",\n    \"history/artifacts\",\n    \"runtime/logs\",\n    \"runtime/backend\",\n    \"runtime/temp\",\n    \"amendments\",\n    \"rollback\",\n];\n\npub struct FileSystem;\n\nimpl FileSystem {\n    pub fn create_workspace(\n        workspace_root: &Path,\n        workspace_config: &str,\n        required_directories: &[&str],\n    ) -> AppResult<()> {\n        fs::create_dir_all(workspace_root)?;\n\n        for directory in required_directories {\n            fs::create_dir_all(workspace_root.join(directory))?;\n        }\n\n        Self::write_atomic(&workspace_root.join(\"workspace.toml\"), workspace_config)?;\n        Ok(())\n    }\n\n    pub fn read_to_string(path: &Path) -> AppResult<String> {\n        Ok(fs::read_to_string(path)?)\n    }\n\n    pub fn write_atomic(path: &Path, contents: &str) -> AppResult<()> {\n        let parent = path.parent().ok_or_else(|| {\n            AppError::Io(std::io::Error::new(\n                std::io::ErrorKind::InvalidInput,\n                format!(\"path '{}' has no parent directory\", path.display()),\n            ))\n        })?;\n        fs::create_dir_all(parent)?;\n\n        let timestamp = SystemTime::now()\n            .duration_since(UNIX_EPOCH)\n            .map(|duration| duration.as_nanos())\n            .unwrap_or_default();\n        let temp_path = parent.join(format!(\n            \".{}.{}.{}.tmp\",\n            path.file_name()\n                .and_then(|value| value.to_str())\n                .unwrap_or(\"workspace\"),\n            std::process::id(),\n            timestamp\n        ));\n\n        let mut file = OpenOptions::new()\n            .create_new(true)\n            .write(true)\n            .open(&temp_path)?;\n        file.write_all(contents.as_bytes())?;\n        file.sync_all()?;\n        drop(file);\n\n        if let Err(error) = fs::rename(&temp_path, path) {\n            let _ = fs::remove_file(&temp_path);\n            return Err(error.into());\n        }\n\n        Ok(())\n    }\n\n    pub fn render_workspace_config(config: &WorkspaceConfig) -> AppResult<String> {\n        Ok(toml::to_string_pretty(config)?)\n    }\n\n    pub fn read_active_project(workspace_root: &Path) -> AppResult<Option<String>> {\n        let path = workspace_root.join(ACTIVE_PROJECT_FILE);\n        match fs::read_to_string(path) {\n            Ok(raw) => {\n                let trimmed = raw.trim();\n                if trimmed.is_empty() {\n                    Ok(None)\n                } else {\n                    Ok(Some(trimmed.to_owned()))\n                }\n            }\n            Err(error) if error.kind() == std::io::ErrorKind::NotFound => Ok(None),\n            Err(error) => Err(error.into()),\n        }\n    }\n\n    pub fn write_active_project(workspace_root: &Path, project_id: &str) -> AppResult<()> {\n        Self::write_atomic(&workspace_root.join(ACTIVE_PROJECT_FILE), project_id)\n    }\n\n    pub fn open_editor(path: &Path) -> AppResult<()> {\n        let editor = env::var(\"EDITOR\")\n            .ok()\n            .filter(|value| !value.trim().is_empty())\n            .or_else(|| {\n                env::var(\"VISUAL\")\n                    .ok()\n                    .filter(|value| !value.trim().is_empty())\n            })\n            .unwrap_or_else(|| \"vi\".to_owned());\n\n        let mut parts = editor.split_whitespace();\n        let program = parts.next().ok_or_else(|| AppError::EditorFailed {\n            editor: editor.clone(),\n            details: \": empty editor command\".to_owned(),\n        })?;\n        let status = Command::new(program).args(parts).arg(path).status()?;\n\n        if status.success() {\n            Ok(())\n        } else {\n            let details = match status.code() {\n                Some(code) => format!(\" with exit code {code}\"),\n                None => \" after being terminated by a signal\".to_owned(),\n            };\n            Err(AppError::EditorFailed { editor, details })\n        }\n    }\n\n    /// Compute a simple hash of content for prompt integrity tracking.\n    pub fn prompt_hash(contents: &str) -> String {\n        use std::collections::hash_map::DefaultHasher;\n        use std::hash::{Hash, Hasher};\n        let mut hasher = DefaultHasher::new();\n        contents.hash(&mut hasher);\n        format!(\"{:016x}\", hasher.finish())\n    }\n\n    // ── Helpers for project filesystem layout ──\n\n    fn workspace_root_path(base_dir: &Path) -> PathBuf {\n        base_dir.join(WORKSPACE_DIR)\n    }\n\n    fn project_root(base_dir: &Path, project_id: &ProjectId) -> PathBuf {\n        Self::workspace_root_path(base_dir)\n            .join(PROJECTS_DIR)\n            .join(project_id.as_str())\n    }\n\n    fn pending_delete_path(base_dir: &Path, project_id: &ProjectId) -> PathBuf {\n        Self::workspace_root_path(base_dir)\n            .join(PROJECTS_DIR)\n            .join(format!(\".{}.pending-delete\", project_id))\n    }\n\n    fn append_line(path: &Path, line: &str) -> AppResult<()> {\n        let parent = path.parent().ok_or_else(|| {\n            AppError::Io(std::io::Error::new(\n                std::io::ErrorKind::InvalidInput,\n                format!(\"path '{}' has no parent directory\", path.display()),\n            ))\n        })?;\n        fs::create_dir_all(parent)?;\n\n        let mut file = OpenOptions::new().create(true).append(true).open(path)?;\n        writeln!(file, \"{}\", line)?;\n        file.sync_all()?;\n        Ok(())\n    }\n}\n\n/// Filesystem-backed implementation of `ProjectStorePort`.\npub struct FsProjectStore;\n\nimpl ProjectStorePort for FsProjectStore {\n    fn project_exists(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<bool> {\n        let project_root = FileSystem::project_root(base_dir, project_id);\n        if !project_root.is_dir() {\n            return Ok(false);\n        }\n        if !project_root.join(PROJECT_CONFIG_FILE).is_file() {\n            return Err(AppError::CorruptRecord {\n                file: format!(\"projects/{}/project.toml\", project_id),\n                details: \"project directory exists but canonical project.toml is missing\"\n                    .to_owned(),\n            });\n        }\n        Ok(true)\n    }\n\n    fn read_project_record(\n        &self,\n        base_dir: &Path,\n        project_id: &ProjectId,\n    ) -> AppResult<ProjectRecord> {\n        let project_root = FileSystem::project_root(base_dir, project_id);\n        let path = project_root.join(PROJECT_CONFIG_FILE);\n        let raw = fs::read_to_string(&path).map_err(|e| {\n            if e.kind() == std::io::ErrorKind::NotFound {\n                if project_root.is_dir() {\n                    // Directory exists but project.toml is missing — corruption\n                    AppError::CorruptRecord {\n                        file: format!(\"projects/{}/project.toml\", project_id),\n                        details: \"project directory exists but canonical project.toml is missing\"\n                            .to_owned(),\n                    }\n                } else {\n                    AppError::ProjectNotFound {\n                        project_id: project_id.to_string(),\n                    }\n                }\n            } else {\n                e.into()\n            }\n        })?;\n        toml::from_str(&raw).map_err(|e| AppError::CorruptRecord {\n            file: format!(\"projects/{}/project.toml\", project_id),\n            details: e.to_string(),\n        })\n    }\n\n    fn list_project_ids(&self, base_dir: &Path) -> AppResult<Vec<ProjectId>> {\n        let projects_dir = FileSystem::workspace_root_path(base_dir).join(PROJECTS_DIR);\n        if !projects_dir.is_dir() {\n            return Ok(Vec::new());\n        }\n\n        let mut ids = Vec::new();\n        for entry in fs::read_dir(&projects_dir)? {\n            let entry = entry?;\n            if !entry.file_type()?.is_dir() {\n                continue;\n            }\n            let name = entry.file_name();\n            let name_str = name.to_string_lossy();\n            // Skip hidden directories (staging/trash from transactional operations)\n            if name_str.starts_with('.') {\n                continue;\n            }\n            if let Ok(pid) = ProjectId::new(name_str.as_ref()) {\n                if !entry.path().join(PROJECT_CONFIG_FILE).is_file() {\n                    return Err(AppError::CorruptRecord {\n                        file: format!(\"projects/{}/project.toml\", name_str),\n                        details: \"project directory exists but canonical project.toml is missing\"\n                            .to_owned(),\n                    });\n                }\n                ids.push(pid);\n            }\n        }\n\n        ids.sort_by(|a, b| a.as_str().cmp(b.as_str()));\n        Ok(ids)\n    }\n\n    fn stage_delete(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<()> {\n        let project_root = FileSystem::project_root(base_dir, project_id);\n        if !project_root.is_dir() {\n            return Err(AppError::ProjectNotFound {\n                project_id: project_id.to_string(),\n            });\n        }\n\n        let pending_path = FileSystem::pending_delete_path(base_dir, project_id);\n\n        // Clean up any leftover pending-delete from a previous crash\n        if pending_path.exists() {\n            fs::remove_dir_all(&pending_path)?;\n        }\n\n        // Atomic rename to pending-delete location — project becomes\n        // invisible to list/show but data stays on disk.\n        fs::rename(&project_root, &pending_path)?;\n        Ok(())\n    }\n\n    fn commit_delete(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<()> {\n        let pending_path = FileSystem::pending_delete_path(base_dir, project_id);\n        if pending_path.is_dir() {\n            fs::remove_dir_all(&pending_path)?;\n        }\n        Ok(())\n    }\n\n    fn rollback_delete(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<()> {\n        let project_root = FileSystem::project_root(base_dir, project_id);\n        let pending_path = FileSystem::pending_delete_path(base_dir, project_id);\n\n        if !pending_path.is_dir() {\n            return Ok(());\n        }\n\n        fs::rename(&pending_path, &project_root)?;\n        Ok(())\n    }\n\n    fn create_project_atomic(\n        &self,\n        base_dir: &Path,\n        record: &ProjectRecord,\n        prompt_contents: &str,\n        run_snapshot: &RunSnapshot,\n        initial_journal_line: &str,\n        sessions: &SessionStore,\n    ) -> AppResult<()> {\n        let project_root = FileSystem::project_root(base_dir, &record.id);\n\n        // Stage into a temporary directory alongside the final location\n        let staging_name = format!(\".{}.staging.{}\", record.id, std::process::id());\n        let staging_root = project_root\n            .parent()\n            .expect(\"project root has parent\")\n            .join(&staging_name);\n\n        // Clean up any leftover staging dir\n        if staging_root.exists() {\n            fs::remove_dir_all(&staging_root)?;\n        }\n\n        // Create staging directory and all subdirs\n        fs::create_dir_all(&staging_root)?;\n        for subdir in PROJECT_SUBDIRS {\n            fs::create_dir_all(staging_root.join(subdir))?;\n        }\n\n        // Write all canonical files into staging\n        let write_result = (|| -> AppResult<()> {\n            // project.toml\n            let project_toml = toml::to_string_pretty(record)\n                .map_err(|e| AppError::Io(std::io::Error::other(e.to_string())))?;\n            fs::write(staging_root.join(PROJECT_CONFIG_FILE), project_toml)?;\n\n            // prompt.md\n            fs::write(staging_root.join(PROMPT_FILE), prompt_contents)?;\n\n            // run.json\n            let run_json = serde_json::to_string_pretty(run_snapshot)?;\n            fs::write(staging_root.join(RUN_FILE), run_json)?;\n\n            // journal.ndjson (with initial event)\n            let mut journal_content = initial_journal_line.to_owned();\n            journal_content.push('\\n');\n            fs::write(staging_root.join(JOURNAL_FILE), journal_content)?;\n\n            // sessions.json\n            let sessions_json = serde_json::to_string_pretty(sessions)?;\n            fs::write(staging_root.join(SESSIONS_FILE), sessions_json)?;\n\n            Ok(())\n        })();\n\n        if let Err(e) = write_result {\n            // Clean up staging on failure\n            let _ = fs::remove_dir_all(&staging_root);\n            return Err(e);\n        }\n\n        // Atomic rename from staging to final location\n        if let Err(e) = fs::rename(&staging_root, &project_root) {\n            let _ = fs::remove_dir_all(&staging_root);\n            return Err(e.into());\n        }\n\n        Ok(())\n    }\n}\n\n/// Filesystem-backed implementation of `JournalStorePort`.\npub struct FsJournalStore;\n\nimpl JournalStorePort for FsJournalStore {\n    fn read_journal(\n        &self,\n        base_dir: &Path,\n        project_id: &ProjectId,\n    ) -> AppResult<Vec<JournalEvent>> {\n        let path = FileSystem::project_root(base_dir, project_id).join(JOURNAL_FILE);\n        match fs::read_to_string(&path) {\n            Ok(contents) => journal::parse_journal(&contents),\n            Err(e) if e.kind() == std::io::ErrorKind::NotFound => Err(AppError::CorruptRecord {\n                file: format!(\"projects/{}/journal.ndjson\", project_id),\n                details: \"canonical file is missing\".to_owned(),\n            }),\n            Err(e) => Err(e.into()),\n        }\n    }\n\n    fn append_event(&self, base_dir: &Path, project_id: &ProjectId, line: &str) -> AppResult<()> {\n        let path = FileSystem::project_root(base_dir, project_id).join(JOURNAL_FILE);\n        FileSystem::append_line(&path, line)\n    }\n}\n\n/// Filesystem-backed implementation of `ArtifactStorePort`.\npub struct FsArtifactStore;\n\nimpl ArtifactStorePort for FsArtifactStore {\n    fn list_payloads(\n        &self,\n        base_dir: &Path,\n        project_id: &ProjectId,\n    ) -> AppResult<Vec<PayloadRecord>> {\n        let dir = FileSystem::project_root(base_dir, project_id).join(\"history/payloads\");\n        if !dir.is_dir() {\n            return Ok(Vec::new());\n        }\n\n        let mut records = Vec::new();\n        for entry in fs::read_dir(&dir)? {\n            let entry = entry?;\n            let path = entry.path();\n            if path.extension().is_some_and(|ext| ext == \"json\") {\n                let raw = fs::read_to_string(&path)?;\n                let record: PayloadRecord =\n                    serde_json::from_str(&raw).map_err(|e| AppError::CorruptRecord {\n                        file: format!(\n                            \"history/payloads/{}\",\n                            path.file_name().unwrap_or_default().to_string_lossy()\n                        ),\n                        details: e.to_string(),\n                    })?;\n                records.push(record);\n            }\n        }\n\n        records.sort_by_key(|r| r.created_at);\n        Ok(records)\n    }\n\n    fn list_artifacts(\n        &self,\n        base_dir: &Path,\n        project_id: &ProjectId,\n    ) -> AppResult<Vec<ArtifactRecord>> {\n        let dir = FileSystem::project_root(base_dir, project_id).join(\"history/artifacts\");\n        if !dir.is_dir() {\n            return Ok(Vec::new());\n        }\n\n        let mut records = Vec::new();\n        for entry in fs::read_dir(&dir)? {\n            let entry = entry?;\n            let path = entry.path();\n            if path.extension().is_some_and(|ext| ext == \"json\") {\n                let raw = fs::read_to_string(&path)?;\n                let record: ArtifactRecord =\n                    serde_json::from_str(&raw).map_err(|e| AppError::CorruptRecord {\n                        file: format!(\n                            \"history/artifacts/{}\",\n                            path.file_name().unwrap_or_default().to_string_lossy()\n                        ),\n                        details: e.to_string(),\n                    })?;\n                records.push(record);\n            }\n        }\n\n        records.sort_by_key(|r| r.created_at);\n        Ok(records)\n    }\n}\n\n/// Filesystem-backed implementation of `RuntimeLogStorePort`.\npub struct FsRuntimeLogStore;\n\nimpl RuntimeLogStorePort for FsRuntimeLogStore {\n    fn read_runtime_logs(\n        &self,\n        base_dir: &Path,\n        project_id: &ProjectId,\n    ) -> AppResult<Vec<RuntimeLogEntry>> {\n        let dir = FileSystem::project_root(base_dir, project_id).join(\"runtime/logs\");\n        if !dir.is_dir() {\n            return Ok(Vec::new());\n        }\n\n        let mut entries = Vec::new();\n        let mut paths: Vec<_> = fs::read_dir(&dir)?\n            .filter_map(|e| e.ok())\n            .map(|e| e.path())\n            .filter(|p| p.extension().is_some_and(|ext| ext == \"ndjson\"))\n            .collect();\n        paths.sort();\n\n        // Only read the newest/latest log file per spec:\n        // \"run tail --logs appends the newest runtime logs\"\n        if let Some(path) = paths.last() {\n            let contents = fs::read_to_string(path)?;\n            for line in contents.lines() {\n                let trimmed = line.trim();\n                if trimmed.is_empty() {\n                    continue;\n                }\n                if let Ok(entry) = serde_json::from_str::<RuntimeLogEntry>(trimmed) {\n                    entries.push(entry);\n                }\n            }\n        }\n\n        Ok(entries)\n    }\n}\n\n/// Filesystem-backed implementation of `RunSnapshotPort`.\npub struct FsRunSnapshotStore;\n\nimpl RunSnapshotPort for FsRunSnapshotStore {\n    fn read_run_snapshot(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<RunSnapshot> {\n        let path = FileSystem::project_root(base_dir, project_id).join(RUN_FILE);\n        match fs::read_to_string(&path) {\n            Ok(raw) => {\n                let snapshot: RunSnapshot =\n                    serde_json::from_str(&raw).map_err(|e| AppError::CorruptRecord {\n                        file: format!(\"projects/{}/run.json\", project_id),\n                        details: e.to_string(),\n                    })?;\n                // Semantic validation: reject inconsistent status/active_run combinations\n                snapshot\n                    .validate_semantics()\n                    .map_err(|details| AppError::CorruptRecord {\n                        file: format!(\"projects/{}/run.json\", project_id),\n                        details,\n                    })?;\n                Ok(snapshot)\n            }\n            Err(e) if e.kind() == std::io::ErrorKind::NotFound => Err(AppError::CorruptRecord {\n                file: format!(\"projects/{}/run.json\", project_id),\n                details: \"canonical file is missing\".to_owned(),\n            }),\n            Err(e) => Err(e.into()),\n        }\n    }\n}\n\n/// Filesystem-backed implementation of `ActiveProjectPort`.\npub struct FsActiveProjectStore;\n\nimpl ActiveProjectPort for FsActiveProjectStore {\n    fn read_active_project_id(&self, base_dir: &Path) -> AppResult<Option<String>> {\n        FileSystem::read_active_project(&FileSystem::workspace_root_path(base_dir))\n    }\n\n    fn clear_active_project(&self, base_dir: &Path) -> AppResult<()> {\n        let path = FileSystem::workspace_root_path(base_dir).join(ACTIVE_PROJECT_FILE);\n        match fs::remove_file(&path) {\n            Ok(()) => Ok(()),\n            Err(e) if e.kind() == std::io::ErrorKind::NotFound => Ok(()),\n            Err(e) => Err(e.into()),\n        }\n    }\n\n    fn write_active_project(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<()> {\n        FileSystem::write_active_project(\n            &FileSystem::workspace_root_path(base_dir),\n            project_id.as_str(),\n        )\n    }\n}\n\n/// Filesystem-backed implementation of `RawOutputPort`.\npub struct FsRawOutputStore;\n\nimpl RawOutputPort for FsRawOutputStore {\n    fn persist_raw_output(\n        &self,\n        project_root: &Path,\n        invocation_id: &str,\n        contents: &str,\n    ) -> AppResult<RawOutputReference> {\n        let path = project_root\n            .join(\"runtime/backend\")\n            .join(format!(\"{invocation_id}.raw\"));\n        FileSystem::write_atomic(&path, contents)?;\n        Ok(RawOutputReference::Stored(path))\n    }\n}\n\n/// Filesystem-backed implementation of `SessionStorePort`.\npub struct FsSessionStore;\n\nimpl SessionStorePort for FsSessionStore {\n    fn load_sessions(&self, project_root: &Path) -> AppResult<PersistedSessions> {\n        let path = project_root.join(SESSIONS_FILE);\n        match fs::read_to_string(&path) {\n            Ok(raw) => serde_json::from_str(&raw).map_err(|error| AppError::CorruptRecord {\n                file: format!(\"{}/{}\", project_root.display(), SESSIONS_FILE),\n                details: error.to_string(),\n            }),\n            Err(error) if error.kind() == std::io::ErrorKind::NotFound => {\n                Err(AppError::CorruptRecord {\n                    file: format!(\"{}/{}\", project_root.display(), SESSIONS_FILE),\n                    details: \"canonical file is missing\".to_owned(),\n                })\n            }\n            Err(error) => Err(error.into()),\n        }\n    }\n\n    fn save_sessions(&self, project_root: &Path, sessions: &PersistedSessions) -> AppResult<()> {\n        let path = project_root.join(SESSIONS_FILE);\n        let contents = serde_json::to_string_pretty(sessions)?;\n        FileSystem::write_atomic(&path, &contents)\n    }\n}\n","numLines":632,"startLine":1,"totalLines":632}}}
