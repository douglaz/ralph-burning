per acceptance criteria.\n- `tests/unit/rollback_test.rs` — Domain-level unit tests for rollback validation and state restoration.\n- `tests/unit/adapter_contract_test.rs` — Extend with rollback-point persistence round-trip tests.\n\n## Dependencies\n- Requires: Loop 7 (Retry, Remediation, Resume — provides `RunStatus`, `RollbackPointMeta` model, and resume semantics that rollback interacts with), Loop 4 (Project/Run Record — provides run snapshot and journal infrastructure)\n- Blocks: Roadmap item 12 (Cutover / Conformance Gate — rollback is the last missing runtime command before the CLI surface is complete)\n\n---","stop_reason":"end_turn","session_id":"9efe3b3c-046c-49b6-b72a-68be6f4e5436","total_cost_usd":0.6947109499999999,"usage":{"input_tokens":14,"cache_creation_input_tokens":25968,"cache_read_input_tokens":337986,"output_tokens":4775,"server_tool_use":{"web_search_requests":0,"web_fetch_requests":0},"service_tier":"standard","cache_creation":{"ephemeral_1h_input_tokens":25968,"ephemeral_5m_input_tokens":0},"inference_geo":"","iterations":[],"speed":"standard"},"modelUsage":{"claude-opus-4-6":{"inputTokens":14,"outputTokens":4775,"cacheReadInputTokens":337986,"cacheCreationInputTokens":25968,"webSearchRequests":0,"costUSD":0.45073799999999997,"contextWindow":200000,"maxOutputTokens":32000},"claude-haiku-4-5-20251001":{"inputTokens":55,"outputTokens":6620,"cacheReadInputTokens":1090167,"cacheCreationInputTokens":81441,"webSearchRequests":0,"costUSD":0.24397295,"contextWindow":200000,"maxOutputTokens":32000}},"permission_denials":[],"fast_mode_state":"off","uuid":"cdbc3ceb-853d-41b2-ae8a-323ad258a13f"}
