{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01SovJptdNMNQ6geXWpjNH6Z","type":"tool_result","content":"     1→use clap::{Args, Subcommand};\n     2→\n     3→use crate::adapters::fs::{\n     4→    FsAmendmentQueueStore, FsArtifactStore, FsDaemonStore, FsJournalStore,\n     5→    FsPayloadArtifactWriteStore, FsProjectStore, FsRunSnapshotStore, FsRunSnapshotWriteStore,\n     6→    FsRuntimeLogWriteStore,\n     7→};\n     8→use crate::adapters::worktree::WorktreeAdapter;\n     9→use crate::contexts::automation_runtime::daemon_loop::{DaemonLoop, DaemonLoopConfig};\n    10→use crate::contexts::automation_runtime::lease_service::LeaseService;\n    11→use crate::contexts::automation_runtime::model::TaskStatus;\n    12→use crate::contexts::automation_runtime::task_service::DaemonTaskService;\n    13→use crate::contexts::automation_runtime::DaemonStorePort;\n    14→use crate::contexts::workspace_governance;\n    15→use crate::contexts::workspace_governance::config::EffectiveConfig;\n    16→use crate::shared::error::{AppError, AppResult};\n    17→\n    18→use super::run::build_agent_execution_service;\n    19→\n    20→#[derive(Debug, Args)]\n    21→pub struct DaemonCommand {\n    22→    #[command(subcommand)]\n    23→    pub command: DaemonSubcommand,\n    24→}\n    25→\n    26→#[derive(Debug, Subcommand)]\n    27→pub enum DaemonSubcommand {\n    28→    Start {\n    29→        #[arg(long, default_value_t = 10)]\n    30→        poll_seconds: u64,\n    31→        #[arg(long)]\n    32→        single_iteration: bool,\n    33→    },\n    34→    Status,\n    35→    Abort {\n    36→        task_id: String,\n    37→    },\n    38→    Retry {\n    39→        task_id: String,\n    40→    },\n    41→    Reconcile {\n    42→        #[arg(long)]\n    43→        ttl_seconds: Option<u64>,\n    44→    },\n    45→}\n    46→\n    47→pub async fn handle(command: DaemonCommand) -> AppResult<()> {\n    48→    match command.command {\n    49→        DaemonSubcommand::Start {\n    50→            poll_seconds,\n    51→            single_iteration,\n    52→        } => handle_start(poll_seconds, single_iteration).await,\n    53→        DaemonSubcommand::Status => handle_status().await,\n    54→        DaemonSubcommand::Abort { task_id } => handle_abort(&task_id).await,\n    55→        DaemonSubcommand::Retry { task_id } => handle_retry(&task_id).await,\n    56→        DaemonSubcommand::Reconcile { ttl_seconds } => handle_reconcile(ttl_seconds).await,\n    57→    }\n    58→}\n    59→\n    60→async fn handle_start(poll_seconds: u64, single_iteration: bool) -> AppResult<()> {\n    61→    let current_dir = std::env::current_dir()?;\n    62→    let config = workspace_governance::load_workspace_config(&current_dir)?;\n    63→    workspace_governance::ensure_supported_workspace_version(&config)?;\n    64→    let _ = EffectiveConfig::load(&current_dir)?;\n    65→\n    66→    let agent_service = build_agent_execution_service();\n    67→    let daemon_store = FsDaemonStore;\n    68→    let worktree = WorktreeAdapter;\n    69→    let project_store = FsProjectStore;\n    70→    let run_snapshot_read = FsRunSnapshotStore;\n    71→    let run_snapshot_write = FsRunSnapshotWriteStore;\n    72→    let journal_store = FsJournalStore;\n    73→    let artifact_store = FsArtifactStore;\n    74→    let artifact_write = FsPayloadArtifactWriteStore;\n    75→    let log_write = FsRuntimeLogWriteStore;\n    76→    let amendment_queue = FsAmendmentQueueStore;\n    77→\n    78→    let daemon_loop = DaemonLoop::new(\n    79→        &daemon_store,\n    80→        &worktree,\n    81→        &project_store,\n    82→        &run_snapshot_read,\n    83→        &run_snapshot_write,\n    84→        &journal_store,\n    85→        &artifact_store,\n    86→        &artifact_write,\n    87→        &log_write,\n    88→        &amendment_queue,\n    89→        &agent_service,\n    90→    );\n    91→    let loop_config = DaemonLoopConfig {\n    92→        poll_interval: std::time::Duration::from_secs(poll_seconds),\n    93→        single_iteration,\n    94→        ..DaemonLoopConfig::default()\n    95→    };\n    96→\n    97→    daemon_loop.run(&current_dir, &loop_config).await\n    98→}\n    99→\n   100→async fn handle_status() -> AppResult<()> {\n   101→    let current_dir = std::env::current_dir()?;\n   102→    let config = workspace_governance::load_workspace_config(&current_dir)?;\n   103→    workspace_governance::ensure_supported_workspace_version(&config)?;\n   104→\n   105→    let store = FsDaemonStore;\n   106→    let tasks = DaemonTaskService::list_tasks(&store, &current_dir)?;\n   107→    let leases = store.list_leases(&current_dir)?;\n   108→\n   109→    if tasks.is_empty() {\n   110→        println!(\"No daemon tasks found.\");\n   111→        return Ok(());\n   112→    }\n   113→\n   114→    for task in tasks {\n   115→        let lease = leases.iter().find(|lease| lease.task_id == task.task_id);\n   116→        let lease_id = lease\n   117→            .map(|lease| lease.lease_id.as_str())\n   118→            .or(task.lease_id.as_deref())\n   119→            .unwrap_or(\"-\");\n   120→        let heartbeat = lease\n   121→            .map(|lease| lease.last_heartbeat.to_rfc3339())\n   122→            .unwrap_or_else(|| \"-\".to_owned());\n   123→        println!(\n   124→            \"{}  {}  lease={}  heartbeat={}  issue={}\",\n   125→            task.task_id, task.status, lease_id, heartbeat, task.issue_ref\n   126→        );\n   127→    }\n   128→\n   129→    Ok(())\n   130→}\n   131→\n   132→async fn handle_abort(task_id: &str) -> AppResult<()> {\n   133→    let current_dir = std::env::current_dir()?;\n   134→    let config = workspace_governance::load_workspace_config(&current_dir)?;\n   135→    workspace_governance::ensure_supported_workspace_version(&config)?;\n   136→\n   137→    let store = FsDaemonStore;\n   138→    let worktree = WorktreeAdapter;\n   139→    let task = store.read_task(&current_dir, task_id)?;\n   140→    if task.status.is_terminal() {\n   141→        return Err(AppError::TaskStateTransitionInvalid {\n   142→            task_id: task.task_id,\n   143→            from: task.status.as_str().to_owned(),\n   144→            to: TaskStatus::Aborted.as_str().to_owned(),\n   145→        });\n   146→    }\n   147→\n   148→    let original_status = task.status;\n   149→    DaemonTaskService::mark_aborted(&store, &current_dir, task_id)?;\n   150→\n   151→    if matches!(original_status, TaskStatus::Claimed | TaskStatus::Active) {\n   152→        cleanup_aborted_task(&store, &worktree, &current_dir, task_id, original_status).await?;\n   153→    }\n   154→\n   155→    println!(\"Aborted task {task_id}\");\n   156→    Ok(())\n   157→}\n   158→\n   159→async fn handle_retry(task_id: &str) -> AppResult<()> {\n   160→    let current_dir = std::env::current_dir()?;\n   161→    let config = workspace_governance::load_workspace_config(&current_dir)?;\n   162→    workspace_governance::ensure_supported_workspace_version(&config)?;\n   163→\n   164→    let store = FsDaemonStore;\n   165→    let task = DaemonTaskService::retry_task(&store, &current_dir, task_id)?;\n   166→    println!(\n   167→        \"Retried task {} (attempt_count={})\",\n   168→        task.task_id, task.attempt_count\n   169→    );\n   170→    Ok(())\n   171→}\n   172→\n   173→async fn handle_reconcile(ttl_seconds: Option<u64>) -> AppResult<()> {\n   174→    let current_dir = std::env::current_dir()?;\n   175→    let config = workspace_governance::load_workspace_config(&current_dir)?;\n   176→    workspace_governance::ensure_supported_workspace_version(&config)?;\n   177→\n   178→    let store = FsDaemonStore;\n   179→    let worktree = WorktreeAdapter;\n   180→    let report = LeaseService::reconcile(\n   181→        &store,\n   182→        &worktree,\n   183→        &current_dir,\n   184→        &current_dir,\n   185→        ttl_seconds,\n   186→        chrono::Utc::now(),\n   187→    )?;\n   188→\n   189→    println!(\n   190→        \"reconciled stale_leases={} failed_tasks={} released_leases={}\",\n   191→        report.stale_lease_ids.len(),\n   192→        report.failed_task_ids.len(),\n   193→        report.released_lease_ids.len()\n   194→    );\n   195→    Ok(())\n   196→}\n   197→\n   198→async fn cleanup_aborted_task(\n   199→    store: &dyn DaemonStorePort,\n   200→    worktree: &WorktreeAdapter,\n   201→    base_dir: &std::path::Path,\n   202→    task_id: &str,\n   203→    original_status: TaskStatus,\n   204→) -> AppResult<()> {\n   205→    let grace_deadline = std::time::Instant::now() + std::time::Duration::from_secs(1);\n   206→    let await_daemon_cleanup = original_status == TaskStatus::Active;\n   207→\n   208→    loop {\n   209→        let lease = LeaseService::find_lease_for_task(store, base_dir, task_id)?;\n   210→        let Some(lease) = lease else {\n   211→            let task = store.read_task(base_dir, task_id)?;\n   212→            if task.lease_id.is_some() {\n   213→                DaemonTaskService::clear_lease_reference(store, base_dir, task_id)?;\n   214→            }\n   215→            return Ok(());\n   216→        };\n   217→\n   218→        if await_daemon_cleanup && std::time::Instant::now() < grace_deadline {\n   219→            tokio::time::sleep(std::time::Duration::from_millis(100)).await;\n   220→            continue;\n   221→        }\n   222→\n   223→        let release_result = LeaseService::release(store, worktree, base_dir, base_dir, &lease);\n   224→        let clear_result =\n   225→            DaemonTaskService::clear_lease_reference(store, base_dir, task_id).map(|_| ());\n   226→        return match (release_result, clear_result) {\n   227→            (Ok(()), Ok(())) => Ok(()),\n   228→            (Err(error), Ok(())) => Err(error),\n   229→            (Ok(()), Err(error)) => Err(error),\n   230→            (Err(error), Err(_)) => Err(error),\n   231→        };\n   232→    }\n   233→}\n   234→"}]},"parent_tool_u