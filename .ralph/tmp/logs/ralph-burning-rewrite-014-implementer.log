{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_014zhMitKy1KeeHRwyDqgbf2","type":"tool_result","content":"     1→use std::collections::{HashMap, HashSet};\n     2→use std::sync::atomic::{AtomicU32, Ordering};\n     3→use std::sync::{Arc, Mutex};\n     4→use std::time::Duration;\n     5→\n     6→use chrono::Utc;\n     7→use serde_json::{json, Value};\n     8→\n     9→use crate::contexts::agent_execution::model::{\n    10→    InvocationContract, InvocationEnvelope, InvocationMetadata, InvocationRequest,\n    11→    RawOutputReference, TokenCounts,\n    12→};\n    13→use crate::contexts::agent_execution::service::AgentExecutionPort;\n    14→use crate::shared::domain::{FailureClass, SessionPolicy, StageId};\n    15→use crate::shared::error::{AppError, AppResult};\n    16→\n    17→#[derive(Clone)]\n    18→pub struct StubBackendAdapter {\n    19→    delay: Duration,\n    20→    available: bool,\n    21→    unsupported_stages: HashSet<StageId>,\n    22→    /// Stages that pass preflight but fail during invocation (for testing).\n    23→    fail_invoke_stages: HashSet<StageId>,\n    24→    transient_failure_limits: HashMap<StageId, u32>,\n    25→    transient_failure_counters: HashMap<StageId, Arc<AtomicU32>>,\n    26→    stage_payload_overrides: Arc<Mutex<HashMap<StageId, Vec<Value>>>>,\n    27→    stage_payload_counters: HashMap<StageId, Arc<AtomicU32>>,\n    28→    /// Contract-label-keyed payload overrides for non-stage contracts.\n    29→    label_payload_overrides: Arc<Mutex<HashMap<String, Vec<Value>>>>,\n    30→    label_payload_counters: HashMap<String, Arc<AtomicU32>>,\n    31→    cancelled_invocations: Arc<Mutex<Vec<String>>>,\n    32→}\n    33→\n    34→impl Default for StubBackendAdapter {\n    35→    fn default() -> Self {\n    36→        Self {\n    37→            delay: Duration::from_millis(0),\n    38→            available: true,\n    39→            unsupported_stages: HashSet::new(),\n    40→            fail_invoke_stages: HashSet::new(),\n    41→            transient_failure_limits: HashMap::new(),\n    42→            transient_failure_counters: HashMap::new(),\n    43→            stage_payload_overrides: Arc::new(Mutex::new(HashMap::new())),\n    44→            stage_payload_counters: HashMap::new(),\n    45→            label_payload_overrides: Arc::new(Mutex::new(HashMap::new())),\n    46→            label_payload_counters: HashMap::new(),\n    47→            cancelled_invocations: Arc::new(Mutex::new(Vec::new())),\n    48→        }\n    49→    }\n    50→}\n    51→\n    52→impl StubBackendAdapter {\n    53→    pub fn with_delay(mut self, delay: Duration) -> Self {\n    54→        self.delay = delay;\n    55→        self\n    56→    }\n    57→\n    58→    pub fn unavailable(mut self) -> Self {\n    59→        self.available = false;\n    60→        self\n    61→    }\n    62→\n    63→    pub fn without_stage_support(mut self, stage_id: StageId) -> Self {\n    64→        self.unsupported_stages.insert(stage_id);\n    65→        self\n    66→    }\n    67→\n    68→    /// Configure a stage to pass preflight but fail during invocation.\n    69→    pub fn with_invoke_failure(mut self, stage_id: StageId) -> Self {\n    70→        self.fail_invoke_stages.insert(stage_id);\n    71→        self\n    72→    }\n    73→\n    74→    /// Configure a stage to fail the first N invocations, then succeed.\n    75→    pub fn with_transient_failure(mut self, stage_id: StageId, fail_count: u32) -> Self {\n    76→        self.transient_failure_limits.insert(stage_id, fail_count);\n    77→        self.transient_failure_counters\n    78→            .insert(stage_id, Arc::new(AtomicU32::new(0)));\n    79→        self\n    80→    }\n    81→\n    82→    pub fn with_stage_payload(self, stage_id: StageId, payload: Value) -> Self {\n    83→        self.with_stage_payload_sequence(stage_id, vec![payload])\n    84→    }\n    85→\n    86→    pub fn with_stage_payload_sequence(mut self, stage_id: StageId, payloads: Vec<Value>) -> Self {\n    87→        self.stage_payload_overrides\n    88→            .lock()\n    89→            .expect(\"stage payload override lock poisoned\")\n    90→            .insert(stage_id, payloads);\n    91→        self.stage_payload_counters\n    92→            .insert(stage_id, Arc::new(AtomicU32::new(0)));\n    93→        self\n    94→    }\n    95→\n    96→    /// Configure a contract-label-keyed payload for non-stage invocations (e.g. requirements).\n    97→    pub fn with_label_payload(self, label: impl Into<String>, payload: Value) -> Self {\n    98→        self.with_label_payload_sequence(label, vec![payload])\n    99→    }\n   100→\n   101→    /// Configure a contract-label-keyed payload sequence for non-stage invocations.\n   102→    pub fn with_label_payload_sequence(\n   103→        mut self,\n   104→        label: impl Into<String>,\n   105→        payloads: Vec<Value>,\n   106→    ) -> Self {\n   107→        let label = label.into();\n   108→        self.label_payload_overrides\n   109→            .lock()\n   110→            .expect(\"label payload override lock poisoned\")\n   111→            .insert(label.clone(), payloads);\n   112→        self.label_payload_counters\n   113→            .insert(label, Arc::new(AtomicU32::new(0)));\n   114→        self\n   115→    }\n   116→\n   117→    pub fn cancelled_invocations(&self) -> Vec<String> {\n   118→        self.cancelled_invocations\n   119→            .lock()\n   120→            .expect(\"cancelled invocation lock poisoned\")\n   121→            .clone()\n   122→    }\n   123→\n   124→    fn payload_for_stage(&self, stage_id: StageId) -> Value {\n   125→        let overrides = self\n   126→            .stage_payload_overrides\n   127→            .lock()\n   128→            .expect(\"stage payload override lock poisoned\");\n   129→        let Some(payloads) = overrides.get(&stage_id) else {\n   130→            return canned_payload_for_stage(stage_id);\n   131→        };\n   132→        let Some(counter) = self.stage_payload_counters.get(&stage_id) else {\n   133→            return payloads\n   134→                .last()\n   135→                .cloned()\n   136→                .unwrap_or_else(|| canned_payload_for_stage(stage_id));\n   137→        };\n   138→        let idx = counter.fetch_add(1, Ordering::SeqCst) as usize;\n   139→        payloads\n   140→            .get(idx)\n   141→            .cloned()\n   142→            .or_else(|| payloads.last().cloned())\n   143→            .unwrap_or_else(|| canned_payload_for_stage(stage_id))\n   144→    }\n   145→\n   146→    fn payload_for_label(&self, label: &str) -> Value {\n   147→        let overrides = self\n   148→            .label_payload_overrides\n   149→            .lock()\n   150→            .expect(\"label payload override lock poisoned\");\n   151→        let Some(payloads) = overrides.get(label) else {\n   152→            return canned_requirements_payload(label);\n   153→        };\n   154→        let Some(counter) = self.label_payload_counters.get(label) else {\n   155→            return payloads\n   156→                .last()\n   157→                .cloned()\n   158→                .unwrap_or_else(|| canned_requirements_payload(label));\n   159→        };\n   160→        let idx = counter.fetch_add(1, Ordering::SeqCst) as usize;\n   161→        payloads\n   162→            .get(idx)\n   163→            .cloned()\n   164→            .or_else(|| payloads.last().cloned())\n   165→            .unwrap_or_else(|| canned_requirements_payload(label))\n   166→    }\n   167→\n   168→    fn payload_for_contract(&self, contract: &InvocationContract) -> Value {\n   169→        match contract {\n   170→            InvocationContract::Stage(sc) => self.payload_for_stage(sc.stage_id),\n   171→            InvocationContract::Requirements { label } => self.payload_for_label(label),\n   172→        }\n   173→    }\n   174→}\n   175→\n   176→impl AgentExecutionPort for StubBackendAdapter {\n   177→    async fn check_capability(\n   178→        &self,\n   179→        backend: &crate::shared::domain::ResolvedBackendTarget,\n   180→        contract: &InvocationContract,\n   181→    ) -> AppResult<()> {\n   182→        match contract {\n   183→            InvocationContract::Stage(sc) => {\n   184→                if self.unsupported_stages.contains(&sc.stage_id)\n   185→                    || !backend.supports_stage(sc.stage_id)\n   186→                {\n   187→                    return Err(AppError::CapabilityMismatch {\n   188→                        backend: backend.backend.family.to_string(),\n   189→                        contract_id: sc.stage_id.to_string(),\n   190→                        details: \"stub adapter does not support the requested stage\".to_owned(),\n   191→                    });\n   192→                }\n   193→            }\n   194→            InvocationContract::Requirements { .. } => {\n   195→                // Requirements contracts are always supported by the stub.\n   196→            }\n   197→        }\n   198→\n   199→        Ok(())\n   200→    }\n   201→\n   202→    async fn check_availability(\n   203→        &self,\n   204→        backend: &crate::shared::domain::ResolvedBackendTarget,\n   205→    ) -> AppResult<()> {\n   206→        if self.available {\n   207→            Ok(())\n   208→        } else {\n   209→            Err(AppError::BackendUnavailable {\n   210→                backend: backend.backend.family.to_string(),\n   211→                details: \"stub adapter configured as unavailable\".to_owned(),\n   212→            })\n   213→        }\n   214→    }\n   215→\n   216→    async fn invoke(&self, request: InvocationRequest) -> AppResult<InvocationEnvelope> {\n   217→        let contract_label = request.contract.label();\n   218→\n   219→        if request.cancellation_token.is_cancelled() {\n   220→            return Err(AppError::InvocationCancelled {\n   221→                backend: request.resolved_target.backend.family.to_string(),\n   222→                contract_id: contract_label,\n   223→            });\n   224→        }\n   225→\n   226→        // Transient failure simulation (stage contracts only)\n   227→        if let Some(stage_id) = request.contract.stage_id() {\n   228→            if let Some(limit) = self.transient_failure_limits.get(&stage_id) {\n   229→                let counter = self\n   230→                    .transient_failure_counters\n   231→                    .get(&stage_id)\n   232→                    .expect(\"transient failure counter missing\");\n   233→                let attempt = counter.fetch_add(1, Ordering::SeqCst) + 1;\n   234→                if attempt <= *limit {\n   235→                    return Err(AppError::InvocationFailed {\n   236→                        backend: request.resolved_target.backend.family.to_string(),\n   237→                        contract_id: contract_label,\n   238→                        failure_class: FailureClass::TransportFailure,\n   239→                        details: format!(\n   240→                            \"stub adapter configured to fail invocation {attempt}/{limit} for this stage\"\n   241→                        ),\n   242→                    });\n   243→                }\n   244→            }\n   245→\n   246→            if self.fail_invoke_stages.contains(&stage_id) {\n   247→                return Err(AppError::InvocationFailed {\n   248→                    backend: request.resolved_target.backend.family.to_string(),\n   249→                    contract_id: contract_label,\n   250→                    failure_class: FailureClass::TransportFailure,\n   251→                    details: \"stub adapter configured to fail invocation for this stage\".to_owned(),\n   252→                });\n   253→            }\n   254→        }\n   255→\n   256→        if self.delay > Duration::from_millis(0) {\n   257→            tokio::select! {\n   258→                _ = request.cancellation_token.cancelled() => {\n   259→                    return Err(AppError::InvocationCancelled {\n   260→                        backend: request.resolved_target.backend.family.to_string(),\n   261→                        contract_id: contract_label,\n   262→                    });\n   263→                }\n   264→                _ = tokio::time::sleep(self.delay) => {}\n   265→            }\n   266→        }\n   267→\n   268→        let payload = self.payload_for_contract(&request.contract);\n   269→        let raw_output = serde_json::to_string_pretty(&payload)?;\n   270→        let prompt_token_count = count_tokens(&request.payload.prompt);\n   271→        let completion_token_count = count_tokens(&raw_output);\n   272→        let prompt_tokens = Some(prompt_token_count);\n   273→        let completion_tokens = Some(completion_token_count);\n   274→        let total_tokens = Some(prompt_token_count + completion_token_count);\n   275→\n   276→        let supports_reuse =\n   277→            request.role.allows_session_reuse() && request.resolved_target.supports_session_reuse();\n   278→        let session_reused = supports_reuse\n   279→            && matches!(request.session_policy, SessionPolicy::ReuseIfAllowed)\n   280→            && request.prior_session.is_some();\n   281→        let session_id = if supports_reuse {\n   282→            request\n   283→                .prior_session\n   284→                .as_ref()\n   285→                .map(|session| session.session_id.clone())\n   286→                .filter(|_| session_reused)\n   287→                .or_else(|| Some(format!(\"stub-{}-{}\", request.role.as_str(), contract_label)))\n   288→        } else {\n   289→            None\n   290→        };\n   291→\n   292→        Ok(InvocationEnvelope {\n   293→            raw_output_reference: RawOutputReference::Inline(raw_output),\n   294→            parsed_payload: serde_json::Value::Null,\n   295→            metadata: InvocationMetadata {\n   296→                invocation_id: request.invocation_id,\n   297→                duration: Duration::from_millis(0),\n   298→                token_counts: TokenCounts {\n   299→                    prompt_tokens,\n   300→                    completion_tokens,\n   301→                    total_tokens,\n   302→                },\n   303→                backend_used: request.resolved_target.backend,\n   304→                model_used: request.resolved_target.model,\n   305→                attempt_number: request.attempt_number,\n   306→                session_id,\n   307→                session_reused,\n   308→            },\n   309→            timestamp: Utc::now(),\n   310→        })\n   311→    }\n   312→\n   313→    async fn cancel(&self, invocation_id: &str) -> AppResult<()> {\n   314→        self.cancelled_invocations\n   315→            .lock()\n   316→            .expect(\"cancelled invocation lock poisoned\")\n   317→            .push(invocation_id.to_owned());\n   318→        Ok(())\n   319→    }\n   320→}\n   321→\n   322→fn count_tokens(contents: &str) -> u32 {\n   323→    contents.split_whitespace().count() as u32\n   324→}\n   325→\n   326→fn canned_payload_for_stage(stage_id: StageId) -> serde_json::Value {\n   327→    match stage_id {\n   328→        StageId::PromptReview | StageId::Planning | StageId::DocsPlan | StageId::CiPlan => json!({\n   329→            \"problem_framing\": format!(\"Stub planning output for {}\", stage_id.display_name()),\n   330→            \"assumptions_or_open_questions\": [\n   331→                format!(\"Assumption captured for {}\", stage_id.as_str())\n   332→            ],\n   333→            \"proposed_work\": [\n   334→                {\n   335→                    \"order\": 1,\n   336→                    \"summary\": format!(\"Complete {}\", stage_id.display_name()),\n   337→                    \"details\": \"Deterministic stub work item.\"\n   338→                }\n   339→            ],\n   340→            \"readiness\": {\n   341→                \"ready