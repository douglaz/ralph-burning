],\n   388→            \"acceptance_criteria\": [\"Feature works as specified\"],\n   389→            \"risks_or_open_questions\": [],\n   390→            \"recommended_flow\": \"standard\"\n   391→        })\n   392→    } else if label.contains(\"requirements_review\") {\n   393→        json!({\n   394→            \"outcome\": \"approved\",\n   395→            \"evidence\": [\"Stub review evidence\"],\n   396→            \"findings\": [],\n   397→            \"follow_ups\": []\n   398→        })\n   399→    } else if label.contains(\"project_seed\") {\n   400→        json!({\n   401→            \"project_id\": \"stub-project\",\n   402→            \"project_name\": \"Stub Project\",\n   403→            \"flow\": \"standard\",\n   404→            \"prompt_body\": \"Stub prompt body for the project.\",\n   405→            \"handoff_summary\": \"Stub handoff summary.\",\n   406→            \"follow_ups\": []\n   407→        })\n   408→    } else {\n   409→        json!({\n   410→            \"stub\": true,\n   411→            \"label\": label\n   412→        })\n   413→    }\n   414→}\n   415→"}]},"parent_tool_use_id":"toolu_01Yb9w6C5ywNFBLEy57v2SYo","session_id":"d6d77a57-6575-434e-8636-d856c1e7216a","uuid":"76ba50d2-7547-4a43-9c6d-48b60b17379e"}
