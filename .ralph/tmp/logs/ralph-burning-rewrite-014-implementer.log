{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01LAMf1viGKsoT7WdKbZdjJD","type":"tool_result","content":"     1→use std::path::PathBuf;\n     2→\n     3→use thiserror::Error;\n     4→\n     5→use crate::shared::domain::{FailureClass, StageId};\n     6→\n     7→pub type AppResult<T> = Result<T, AppError>;\n     8→\n     9→#[derive(Debug, Error)]\n    10→pub enum AppError {\n    11→    #[error(\"workspace already initialized at {path}\")]\n    12→    AlreadyInitialized { path: PathBuf },\n    13→    #[error(\n    14→        \"cannot initialize workspace because {path} already exists without a workspace configuration\"\n    15→    )]\n    16→    WorkspaceConflict { path: PathBuf },\n    17→    #[error(\"invalid {field}: must be greater than zero\")]\n    18→    InvalidStageCursorField { field: &'static str },\n    19→    #[error(\"invalid identifier '{value}': identifiers must be non-empty single path segments\")]\n    20→    InvalidIdentifier { value: String },\n    21→    #[error(\n    22→        \"unknown flow preset '{flow_id}'. supported presets: standard, quick_dev, docs_change, ci_improvement\"\n    23→    )]\n    24→    InvalidFlowPreset { flow_id: String },\n    25→    #[error(\"unsupported workspace version {version}; supported version is {supported}\")]\n    26→    UnsupportedWorkspaceVersion { version: u32, supported: u32 },\n    27→    #[error(\n    28→        \"unknown config key '{key}'. supported keys: prompt_review.enabled, default_flow, default_backend, default_model\"\n    29→    )]\n    30→    UnknownConfigKey { key: String },\n    31→    #[error(\"invalid value '{value}' for config key '{key}': {reason}\")]\n    32→    InvalidConfigValue {\n    33→        key: String,\n    34→        value: String,\n    35→        reason: String,\n    36→    },\n    37→    #[error(\"no active project selected; run `ralph-burning project select <id>`\")]\n    38→    NoActiveProject,\n    39→    #[error(\n    40→        \"project '{project_id}' was not found under .ralph-burning/projects/ or is missing project.toml\"\n    41→    )]\n    42→    ProjectNotFound { project_id: String },\n    43→    #[error(\"editor '{editor}' failed{details}\")]\n    44→    EditorFailed { editor: String, details: String },\n    45→    #[error(\"project '{project_id}' already exists\")]\n    46→    DuplicateProject { project_id: String },\n    47→    #[error(\"corrupt record in {file}: {details}\")]\n    48→    CorruptRecord { file: String, details: String },\n    49→    #[error(\"invalid prompt file '{path}': {reason}\")]\n    50→    InvalidPrompt { path: String, reason: String },\n    51→    #[error(\"cannot delete project '{project_id}': it has an active run\")]\n    52→    ActiveRunDelete { project_id: String },\n    53→    #[error(\"journal sequence error: {details}\")]\n    54→    JournalSequence { details: String },\n    55→    #[error(\"cannot start run: {reason}\")]\n    56→    RunStartFailed { reason: String },\n    57→    #[error(\"cannot resume run: {reason}\")]\n    58→    ResumeFailed { reason: String },\n    59→    #[error(\n    60→        \"cannot rollback project '{project_id}' while run status is '{status}'; rollback is only allowed from failed or paused snapshots\"\n    61→    )]\n    62→    RollbackInvalidStatus { project_id: String, status: String },\n    63→    #[error(\n    64→        \"cannot rollback project '{project_id}' to stage '{stage_id}': stage is not part of flow '{flow}'\"\n    65→    )]\n    66→    RollbackStageNotInFlow {\n    67→        project_id: String,\n    68→        stage_id: String,\n    69→        flow: String,\n    70→    },\n    71→    #[error(\n    72→        \"cannot rollback project '{project_id}' to stage '{stage_id}': no persisted rollback point exists\"\n    73→    )]\n    74→    RollbackPointNotFound {\n    75→        project_id: String,\n    76→        stage_id: String,\n    77→    },\n    78→    #[error(\n    79→        \"hard rollback for project '{project_id}' failed after the logical rollback was committed at rollback point '{rollback_id}': {details}\"\n    80→    )]\n    81→    RollbackGitResetFailed {\n    82→        project_id: String,\n    83→        rollback_id: String,\n    84→        details: String,\n    85→    },\n    86→    #[error(\"preflight check failed for stage '{stage_id}': {details}\")]\n    87→    PreflightFailed { stage_id: StageId, details: String },\n    88→    #[error(\"stage commit failed for stage '{stage_id}': {details}\")]\n    89→    StageCommitFailed { stage_id: StageId, details: String },\n    90→    #[error(\"{command} is not yet implemented\")]\n    91→    NotYetImplemented { command: String },\n    92→    #[error(\"backend '{backend}' is unavailable: {details}\")]\n    93→    BackendUnavailable { backend: String, details: String },\n    94→    #[error(\"backend '{backend}' cannot satisfy contract '{contract_id}': {details}\")]\n    95→    CapabilityMismatch {\n    96→        backend: String,\n    97→        contract_id: String,\n    98→        details: String,\n    99→    },\n   100→    #[error(\"backend invocation failed for contract '{contract_id}' via '{backend}': {details}\")]\n   101→    InvocationFailed {\n   102→        backend: String,\n   103→        contract_id: String,\n   104→        failure_class: FailureClass,\n   105→        details: String,\n   106→    },\n   107→    #[error(\n   108→        \"backend invocation timed out for contract '{contract_id}' via '{backend}' after {timeout_ms} ms\"\n   109→    )]\n   110→    InvocationTimeout {\n   111→        backend: String,\n   112→        contract_id: String,\n   113→        timeout_ms: u64,\n   114→    },\n   115→    #[error(\"backend invocation cancelled for contract '{contract_id}' via '{backend}'\")]\n   116→    InvocationCancelled {\n   117→        backend: String,\n   118→        contract_id: String,\n   119→    },\n   120→    #[error(\"invalid requirements state for run '{run_id}': {details}\")]\n   121→    InvalidRequirementsState { run_id: String, details: String },\n   122→    #[error(\"answer validation failed for run '{run_id}': {details}\")]\n   123→    AnswerValidationFailed { run_id: String, details: String },\n   124→    #[error(\"seed persistence failed for run '{run_id}': {details}\")]\n   125→    SeedPersistenceFailed { run_id: String, details: String },\n   126→    #[error(\"remediation exhausted at cycle {cycle}; maximum supported cycles is {max}\")]\n   127→    RemediationExhausted { cycle: u32, max: u32 },\n   128→    #[error(\"amendment queue error: {details}\")]\n   129→    AmendmentQueueError { details: String },\n   130→    #[error(\"completion blocked: {details}\")]\n   131→    CompletionBlocked { details: String },\n   132→    #[error(\"completion guard snapshot commit failed: {details}\")]\n   133→    CompletionGuardSnapshotFailed { details: String },\n   134→    #[error(\"routing resolution failed for '{input}': {details}\")]\n   135→    RoutingResolutionFailed { input: String, details: String },\n   136→    #[error(\"ambiguous routing labels resolved to multiple flows: {labels:?}\")]\n   137→    AmbiguousRouting { labels: Vec<String> },\n   138→    #[error(\"task for issue '{issue_ref}' already exists with non-terminal status\")]\n   139→    DuplicateTaskForIssue { issue_ref: String },\n   140→    #[error(\"project writer lock is already held for '{project_id}'\")]\n   141→    ProjectWriterLockHeld { project_id: String },\n   142→    #[error(\"failed to create worktree for task '{task_id}': {details}\")]\n   143→    WorktreeCreationFailed { task_id: String, details: String },\n   144→    #[error(\"failed to remove worktree for task '{task_id}': {details}\")]\n   145→    WorktreeRemovalFailed { task_id: String, details: String },\n   146→    #[error(\"lease '{lease_id}' is stale\")]\n   147→    LeaseStale { lease_id: String },\n   148→    #[error(\"invalid task state transition for '{task_id}': {from} -> {to}\")]\n   149→    TaskStateTransitionInvalid {\n   150→        task_id: String,\n   151→        from: String,\n   152→        to: String,\n   153→    },\n   154→    #[error(\"rebase conflict for branch '{branch_name}': {details}\")]\n   155→    RebaseConflict {\n   156→        branch_name: String,\n   157→        details: String,\n   158→    },\n   159→    #[error(transparent)]\n   160→    Io(#[from] std::io::Error),\n   161→    #[error(transparent)]\n   162→    TomlDeserialize(#[from] toml::de::Error),\n   163→    #[error(transparent)]\n   164→    TomlSerialize(#[from] toml::ser::Error),\n   165→    #[error(transparent)]\n   166→    TomlEdit(#[from] toml_edit::TomlError),\n   167→    #[error(transparent)]\n   168→    SerdeJson(#[from] serde_json::Error),\n   169→}\n   170→\n   171→/// Errors specific to stage contract evaluation.\n   172→///\n   173→/// Each variant maps to a distinct [`FailureClass`] for retry/terminal policy.\n   174→/// The `stage_id` field is a domain-neutral string identifier, supporting both\n   175→/// workflow stage IDs and requirements stage IDs.\n   176→#[derive(Debug, Error)]\n   177→pub enum ContractError {\n   178→    #[error(\"schema validation failed for stage '{stage_id}': {details}\")]\n   179→    SchemaValidation { stage_id: String, details: String },\n   180→\n   181→    #[error(\"domain validation failed for stage '{stage_id}': {details}\")]\n   182→    DomainValidation { stage_id: String, details: String },\n   183→\n   184→    #[error(\"rendering failed for stage '{stage_id}': {details}\")]\n   185→    RenderError { stage_id: String, details: String },\n   186→\n   187→    #[error(\"non-passing QA/review outcome for stage '{stage_id}': {outcome}\")]\n   188→    QaReviewOutcome { stage_id: String, outcome: String },\n   189→}\n   190→\n   191→impl ContractError {\n   192→    pub fn failure_class(&self) -> FailureClass {\n   193→        match self {\n   194→            Self::SchemaValidation { .. } => FailureClass::SchemaValidationFailure,\n   195→            Self::DomainValidation { .. } | Self::RenderError { .. } => {\n   196→                FailureClass::DomainValidationFailure\n   197→            }\n   198→            Self::QaReviewOutcome { .. } => FailureClass::QaReviewOutcomeFailure,\n   199→        }\n   200→    }\n   201→\n   202→    pub fn stage_id(&self) -> &str {\n   203→        match self {\n   204→            Self::SchemaValidation { stage_id, .. }\n   205→            | Self::DomainValidation { stage_id, .. }\n   206→            | Self::RenderError { stage_id, .. }\n   207→            | Self::QaReviewOutcome { stage_id, .. } => stage_id,\n   208→        }\n   209→    }\n   210→}\n   211→\n   212→impl AppError {\n   213→    pub fn failure_class(&self) -> Option<FailureClass> {\n   214→        match self {\n   215→            Self::BackendUnavailable { .. } => Some(FailureClass::TransportFailure),\n   216→            Self::CapabilityMismatch { .. } => Some(FailureClass::DomainValidationFailure),\n   217→            Self::InvocationFailed { failure_class, .. } => Some(*failure_class),\n   218→            Self::InvocationTimeout { .. } => Some(FailureClass::Timeout),\n   219→            Self::InvocationCancelled { .. } => Some(FailureClass::Cancellation),\n   220→            _ => None,\n   221→        }\n   222→    }\n   223→}\n   224→"}]},"parent_tool_use_id":"toolu_01Yb9w6C5ywNFBLEy57v2SYo","session_id":"d6d77a57-6575-434e-8636-d856c1e7216a","uuid":"4fa86f1d-5c95-48ab-9b1f-80993638d1b8"}
