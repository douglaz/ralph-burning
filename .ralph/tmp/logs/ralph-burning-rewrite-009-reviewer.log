{"type":"item.completed","item":{"id":"item_17","type":"command_execution","command":"/run/current-system/sw/bin/bash -lc \"nl -ba src/cli/run.rs | sed -n '1,280p'\"","aggregated_output":"     1\tuse clap::{Args, Subcommand};\n     2\t\n     3\tuse crate::adapters::fs::{\n     4\t    FsAmendmentQueueStore, FsArtifactStore, FsJournalStore, FsPayloadArtifactWriteStore,\n     5\t    FsProjectStore, FsRawOutputStore, FsRunSnapshotStore, FsRunSnapshotWriteStore,\n     6\t    FsRuntimeLogStore, FsRuntimeLogWriteStore, FsSessionStore,\n     7\t};\n     8\tuse crate::adapters::stub_backend::StubBackendAdapter;\n     9\tuse crate::contexts::agent_execution::service::AgentExecutionService;\n    10\tuse crate::contexts::project_run_record::model::RunStatus;\n    11\tuse crate::contexts::project_run_record::service::{self, ProjectStorePort, RunSnapshotPort};\n    12\tuse crate::contexts::workflow_composition::engine;\n    13\tuse crate::contexts::workspace_governance;\n    14\tuse crate::contexts::workspace_governance::config::EffectiveConfig;\n    15\tuse crate::shared::domain::{FlowPreset, StageId};\n    16\tuse crate::shared::error::{AppError, AppResult};\n    17\t\n    18\t#[derive(Debug, Args)]\n    19\tpub struct RunCommand {\n    20\t    #[command(subcommand)]\n    21\t    pub command: RunSubcommand,\n    22\t}\n    23\t\n    24\t#[derive(Debug, Subcommand)]\n    25\tpub enum RunSubcommand {\n    26\t    Start,\n    27\t    Resume,\n    28\t    Status,\n    29\t    History,\n    30\t    Tail {\n    31\t        #[arg(long)]\n    32\t        logs: bool,\n    33\t    },\n    34\t    Rollback {\n    35\t        #[arg(long)]\n    36\t        to: String,\n    37\t        #[arg(long)]\n    38\t        hard: bool,\n    39\t    },\n    40\t}\n    41\t\n    42\tpub async fn handle(command: RunCommand) -> AppResult<()> {\n    43\t    match command.command {\n    44\t        RunSubcommand::Status => handle_status().await,\n    45\t        RunSubcommand::History => handle_history().await,\n    46\t        RunSubcommand::Tail { logs } => handle_tail(logs).await,\n    47\t        RunSubcommand::Start => handle_start().await,\n    48\t        RunSubcommand::Resume => handle_resume().await,\n    49\t        RunSubcommand::Rollback { .. } => Err(AppError::NotYetImplemented {\n    50\t            command: \"run rollback\".to_owned(),\n    51\t        }),\n    52\t    }\n    53\t}\n    54\t\n    55\tpub fn build_agent_execution_service(\n    56\t) -> AgentExecutionService<StubBackendAdapter, FsRawOutputStore, FsSessionStore> {\n    57\t    let mut adapter = StubBackendAdapter::default();\n    58\t\n    59\t    // Test-only injection seam: environment variables configure the stub backend\n    60\t    // to simulate failure modes that aren't reachable through normal CLI usage.\n    61\t    if std::env::var(\"RALPH_BURNING_TEST_BACKEND_UNAVAILABLE\").is_ok() {\n    62\t        adapter = adapter.unavailable();\n    63\t    }\n    64\t    if let Ok(stage_str) = std::env::var(\"RALPH_BURNING_TEST_FAIL_INVOKE_STAGE\") {\n    65\t        if let Ok(stage_id) = stage_str.parse::<StageId>() {\n    66\t            adapter = adapter.with_invoke_failure(stage_id);\n    67\t        }\n    68\t    }\n    69\t\n    70\t    AgentExecutionService::new(adapter, FsRawOutputStore, FsSessionStore)\n    71\t}\n    72\t\n    73\tasync fn handle_start() -> AppResult<()> {\n    74\t    let current_dir = std::env::current_dir()?;\n    75\t\n    76\t    // Validate workspace version\n    77\t    let config = workspace_governance::load_workspace_config(&current_dir)?;\n    78\t    workspace_governance::ensure_supported_workspace_version(&config)?;\n    79\t\n    80\t    // Resolve active project\n    81\t    let project_id = workspace_governance::resolve_active_project(&current_dir)?;\n    82\t\n    83\t    // Validate canonical project record\n    84\t    let project_store = FsProjectStore;\n    85\t    let project_record = project_store.read_project_record(&current_dir, &project_id)?;\n    86\t\n    87\t    if matches!(project_record.flow, FlowPreset::QuickDev) {\n    88\t        return Err(AppError::UnsupportedFlow {\n    89\t            flow_id: project_record.flow.as_str().to_owned(),\n    90\t        });\n    91\t    }\n    92\t\n    93\t    // Validate run snapshot integrity\n    94\t    let run_snapshot_read = FsRunSnapshotStore;\n    95\t    let run_snapshot = run_snapshot_read.read_run_snapshot(&current_dir, &project_id)?;\n    96\t\n    97\t    // Check preconditions before engine call (fail fast with clear errors)\n    98\t    match run_snapshot.status {\n    99\t        RunStatus::NotStarted => {}\n   100\t        RunStatus::Failed | RunStatus::Paused => {\n   101\t            return Err(AppError::RunStartFailed {\n   102\t                reason: format!(\n   103\t                    \"project snapshot status is '{}'; use `ralph-burning run resume`\",\n   104\t                    run_snapshot.status\n   105\t                ),\n   106\t            });\n   107\t        }\n   108\t        status => {\n   109\t            return Err(AppError::RunStartFailed {\n   110\t                reason: format!(\n   111\t                    \"project snapshot status is '{}'; run start requires 'not_started'\",\n   112\t                    status\n   113\t                ),\n   114\t            });\n   115\t        }\n   116\t    }\n   117\t    if run_snapshot.has_active_run() {\n   118\t        return Err(AppError::RunStartFailed {\n   119\t            reason: \"project already has an active run\".to_owned(),\n   120\t        });\n   121\t    }\n   122\t\n   123\t    let effective_config = EffectiveConfig::load(&current_dir)?;\n   124\t\n   125\t    let agent_service = build_agent_execution_service();\n   126\t    let run_snapshot_write = FsRunSnapshotWriteStore;\n   127\t    let journal_store = FsJournalStore;\n   128\t    let artifact_write = FsPayloadArtifactWriteStore;\n   129\t    let log_write = FsRuntimeLogWriteStore;\n   130\t\n   131\t    println!(\"Starting run for project '{}'...\", project_id);\n   132\t\n   133\t    let amendment_queue = FsAmendmentQueueStore;\n   134\t\n   135\t    engine::execute_run(\n   136\t        &agent_service,\n   137\t        &run_snapshot_read,\n   138\t        &run_snapshot_write,\n   139\t        &journal_store,\n   140\t        &artifact_write,\n   141\t        &log_write,\n   142\t        &amendment_queue,\n   143\t        &current_dir,\n   144\t        &project_id,\n   145\t        project_record.flow,\n   146\t        &effective_config,\n   147\t    )\n   148\t    .await?;\n   149\t\n   150\t    let final_snapshot = run_snapshot_read.read_run_snapshot(&current_dir, &project_id)?;\n   151\t    match final_snapshot.status {\n   152\t        RunStatus::Completed => println!(\"Run completed successfully.\"),\n   153\t        RunStatus::Paused => println!(\"{}\", final_snapshot.status_summary),\n   154\t        status => println!(\"Run finished with status '{}'.\", status),\n   155\t    }\n   156\t    Ok(())\n   157\t}\n   158\t\n   159\tasync fn handle_resume() -> AppResult<()> {\n   160\t    let current_dir = std::env::current_dir()?;\n   161\t\n   162\t    let config = workspace_governance::load_workspace_config(&current_dir)?;\n   163\t    workspace_governance::ensure_supported_workspace_version(&config)?;\n   164\t\n   165\t    let project_id = workspace_governance::resolve_active_project(&current_dir)?;\n   166\t\n   167\t    let project_store = FsProjectStore;\n   168\t    let project_record = project_store.read_project_record(&current_dir, &project_id)?;\n   169\t    if matches!(project_record.flow, FlowPreset::QuickDev) {\n   170\t        return Err(AppError::UnsupportedFlow {\n   171\t            flow_id: project_record.flow.as_str().to_owned(),\n   172\t        });\n   173\t    }\n   174\t\n   175\t    let run_snapshot_read = FsRunSnapshotStore;\n   176\t    let run_snapshot = run_snapshot_read.read_run_snapshot(&current_dir, &project_id)?;\n   177\t    match run_snapshot.status {\n   178\t        RunStatus::Failed | RunStatus::Paused => {}\n   179\t        RunStatus::NotStarted => {\n   180\t            return Err(AppError::ResumeFailed {\n   181\t                reason: \"project has not started a run yet; use `ralph-burning run start`\"\n   182\t                    .to_owned(),\n   183\t            });\n   184\t        }\n   185\t        RunStatus::Running => {\n   186\t            return Err(AppError::ResumeFailed {\n   187\t                reason: \"project already has a running run; `run resume` only works from failed or paused snapshots\".to_owned(),\n   188\t            });\n   189\t        }\n   190\t        RunStatus::Completed => {\n   191\t            return Err(AppError::ResumeFailed {\n   192\t                reason: \"project is already completed; there is nothing to resume\".to_owned(),\n   193\t            });\n   194\t        }\n   195\t    }\n   196\t    if run_snapshot.has_active_run() {\n   197\t        return Err(AppError::ResumeFailed {\n   198\t            reason: \"failed or paused snapshots must not retain an active run\".to_owned(),\n   199\t        });\n   200\t    }\n   201\t\n   202\t    let effective_config = EffectiveConfig::load(&current_dir)?;\n   203\t    let agent_service = build_agent_execution_service();\n   204\t    let run_snapshot_write = FsRunSnapshotWriteStore;\n   205\t    let journal_store = FsJournalStore;\n   206\t    let artifact_write = FsPayloadArtifactWriteStore;\n   207\t    let log_write = FsRuntimeLogWriteStore;\n   208\t\n   209\t    println!(\"Resuming run for project '{}'...\", project_id);\n   210\t\n   211\t    let amendment_queue = FsAmendmentQueueStore;\n   212\t\n   213\t    engine::resume_run(\n   214\t        &agent_service,\n   215\t        &run_snapshot_read,\n   216\t        &run_snapshot_write,\n   217\t        &journal_store,\n   218\t        &FsArtifactStore,\n   219\t        &artifact_write,\n   220\t        &log_write,\n   221\t        &amendment_queue,\n   222\t        &current_dir,\n   223\t        &project_id,\n   224\t        project_record.flow,\n   225\t        &effective_config,\n   226\t    )\n   227\t    .await?;\n   228\t\n   229\t    let final_snapshot = run_snapshot_read.read_run_snapshot(&current_dir, &project_id)?;\n   230\t    match final_snapshot.status {\n   231\t        RunStatus::Completed => println!(\"Run completed successfully.\"),\n   232\t        RunStatus::Paused => println!(\"{}\", final_snapshot.status_summary),\n   233\t        status => println!(\"Run finished with status '{}'.\", status),\n   234\t    }\n   235\t\n   236\t    Ok(())\n   237\t}\n   238\t\n   239\tasync fn handle_status() -> AppResult<()> {\n   240\t    let current_dir = std::env::current_dir()?;\n   241\t\n   242\t    let config = workspace_governance::load_workspace_config(&current_dir)?;\n   243\t    workspace_governance::ensure_supported_workspace_version(&config)?;\n   244\t\n   245\t    let project_id = workspace_governance::resolve_active_project(&current_dir)?;\n   246\t\n   247\t    // Validate canonical project record before proceeding with run queries\n   248\t    let project_store = FsProjectStore;\n   249\t    let _ = project_store.read_project_record(&current_dir, &project_id)?;\n   250\t\n   251\t    let run_store = FsRunSnapshotStore;\n   252\t    let status = service::run_status(&run_store, &current_dir, &project_id)?;\n   253\t\n   254\t    println!(\"Project: {}\", status.project_id);\n   255\t    println!(\"Status: {}\", status.status);\n   256\t    if let Some(ref stage) = status.stage {\n   257\t        println!(\"Stage: {}\", stage);\n   258\t    }\n   259\t    if let Some(cycle) = status.cycle {\n   260\t        println!(\"Cycle: {}\", cycle);\n   261\t    }\n   262\t    if let Some(round) = status.completion_round {\n   263\t        println!(\"Completion round: {}\", round);\n   264\t    }\n   265\t    println!(\"Summary: {}\", status.summary);\n   266\t\n   267\t    Ok(())\n   268\t}\n   269\t\n   270\tasync fn handle_history() -> AppResult<()> {\n   271\t    let current_dir = std::env::current_dir()?;\n   272\t\n   273\t    let config = workspace_governance::load_workspace_config(&current_dir)?;\n   274\t    workspace_governance::ensure_supported_workspace_version(&config)?;\n   275\t\n   276\t    let project_id = workspace_governance::resolve_active_project(&current_dir)?;\n   277\t\n   278\t    // Validate canonical project record before proceeding with run queries\n   279\t    let project_store = FsProjectStore;\n   280\t    let _ = project_store.read_project_record(&current_dir, &project_id)?;\n","exit_code":0,"status":"completed"}}
