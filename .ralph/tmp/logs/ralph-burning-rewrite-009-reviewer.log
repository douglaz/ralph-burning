\t            reason: format!(\n  2061\t                \"failed to reconstruct remediation context for {} cycle {}; payload '{}' is not a validation payload\",\n  2062\t                execution_label, cursor.cycle, payload_id\n  2063\t            ),\n  2064\t        }),\n  2065\t    }\n  2066\t}\n  2067\t\n  2068\tfn stage_plan_for_resume(\n  2069\t    preset: FlowPreset,\n  2070\t    events: &[JournalEvent],\n  2071\t    effective_config: &EffectiveConfig,\n  2072\t) -> AppResult<Vec<StageId>> {\n  2073\t    match preset {\n  2074\t        FlowPreset::Standard => {\n  2075\t            let run_started = events\n  2076\t                .iter()\n  2077\t                .rev()\n  2078\t                .find(|event| {\n  2079\t                    event.event_type\n  2080\t                        == crate::contexts::project_run_record::model::JournalEventType::RunStarted\n  2081\t                })\n  2082\t                .ok_or_else(|| AppError::ResumeFailed {\n  2083\t                    reason: \"run journal does not contain a run_started event\".to_owned(),\n  2084\t                })?;\n  2085\t\n  2086\t            let first_stage = detail_stage_id(run_started, \"first_stage\")?;\n  2087\t            match first_stage {\n  2088\t                StageId::PromptReview => Ok(stage_plan_for_flow(FlowPreset::Standard, true)),\n  2089\t                StageId::Planning => Ok(stage_plan_for_flow(FlowPreset::Standard, false)),\n  2090\t                _ => Ok(stage_plan_for_flow(\n  2091\t                    FlowPreset::Standard,\n  2092\t                    effective_config.prompt_review_enabled(),\n  2093\t                )),\n  2094\t            }\n  2095\t        }\n  2096\t        _ => Ok(stage_plan_for_flow(\n  2097\t            preset,\n  2098\t            effective_config.prompt_review_enabled(),\n  2099\t        )),\n  2100\t    }\n  2101\t}\n  2102\t\n  2103\tfn derive_resume_state(\n  2104\t    events: &[JournalEvent],\n  2105\t    snapshot: &RunSnapshot,\n 