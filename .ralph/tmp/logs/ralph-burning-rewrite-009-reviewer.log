alize_workspace_fixture();\n   299\t    let editor = write_editor_script(\n   300\t        temp_dir.path(),\n   301\t        \"editor-invalid.sh\",\n   302\t        \"#!/bin/sh\\nprintf '%s\\n' 'version = 999' 'created_at = \\\"2026-03-11T17:50:55Z\\\"' > \\\"$1\\\"\\n\",\n   303\t    );\n   304\t\n   305\t    let output = Command::new(binary())\n   306\t        .args([\"config\", \"edit\"])\n   307\t        .env(\"EDITOR\", &editor)\n   308\t        .env_remove(\"VISUAL\")\n   309\t        .current_dir(temp_dir.path())\n   310\t        .output()\n   311\t        .expect(\"run invalid config edit\");\n   312\t\n   313\t    assert!(!output.status.success());\n   314\t    let stderr = String::from_utf8_lossy(&output.stderr);\n   315\t    assert!(stderr.contains(\"workspace.toml is invalid after editing\"));\n   316\t    assert!(stderr.contains(\"unsupported workspace version 999\"));\n   317\t}\n   318\t\n   319\t#[test]\n   320\tfn project_select_sets_active_project_and_rejects_missing_projects() {\n   321\t    let temp_dir = initialize_workspace_fixture();\n   322\t    create_project_fixture(temp_dir.path(), \"alpha\");\n   323\t\n   324\t    let existing = Command::new(binary())\n   325\t        .args([\"project\", \"select\", \"alpha\"])\n   326\t        .current_dir(temp_dir.path())\n   327\t        .output()\n   328\t        .expect(\"run project select\");\n   329\t    assert!(existing.status.success());\n   330\t    assert!(String::from_utf8_lossy(&existing.stdout).contains(\"Selected project alpha\"));\n   331\t    assert_eq!(\n   332\t        \"alpha\",\n   333\t        fs::read_to_string(temp_dir.path().join(\".ralph-burning/active-project\"))\n   334\t            .expect(\"read active project\")\n   335\t    );\n   336\t\n   337\t    let missing = Command::new(binary())\n   338\t        .args([\"project\", \"select\", \"missing\"])\n   339\t        .current_dir(temp_dir.path())\n   340\t        .output()\n   341\t        .expect(\"run missing project select\");\n   342\t    assert!(!missing.status.success());\n   343\t    assert!(String::from_utf8_lossy(&missing.stderr).contains(\"project 'missing' was not found\"));\n   344\t}\n   345\t\n   346\t#[test]\n   347\tfn project_select_rejects_path_like_ids_before_writing_active_project() {\n   348\t    let temp_dir = initialize_workspace_fixture();\n   349\t\n   350\t    let output = Command::new(binary())\n   351\t        .args([\"project\", \"select\", \"../escape\"])\n   352\t        .current_dir(temp_dir.path())\n   353\t        .output()\n   354\t        .expect(\"run path-like project select\");\n   355\t\n   356\t    assert!(!output.status.success());\n   357\t    assert!(String::from_utf8_lossy(&output.stderr).contains(\"invalid identifier\"));\n   358\t    assert!(!temp_dir\n   359\t        .path()\n   360\t        .join(\".ralph-burning/active-project\")\n   361\t        .exists());\n   362\t}\n   363\t\n   364\t// ── Project Create ──\n   365\t\n   366\tfn write_prompt_fixture(base_dir: &std::path::Path) -> std::path::PathBuf {\n   367\t    let prompt_path = base_dir.join(\"test-prompt.md\");\n   368\t    fs::write(&prompt_path, \"# Test Prompt\\nImplement the feature.\\n\").expect(\"write prompt\");\n   369\t    prompt_path\n   370\t}\n   371\t\n   372\t#[test]\n   373\tfn project_create_succeeds_and_writes_all_canonical_files() {\n   374\t    let temp_dir = initialize_workspace_fixture();\n   375\t    let prompt = write_prompt_fixture(temp_dir.path());\n   376\t\n   377\t    let output = Command::new(binary())\n   378\t        .args([\n   379\t            \"project\",\n   380\t            \"create\",\n   381\t            \"--id\",\n   382\t            \"alpha\",\n   383\t            \"--name\",\n   384\t            \"Alpha Project\",\n   385\t            \"--prompt\",\n   386\t            prompt.to_str().unwrap(),\n   387\t            \"--flow\",\n   388\t            \"standard\",\n   389\t        ])\n   390\t        .current_dir(temp_dir.path())\n   391\t        .output()\n   392\t        .expect(\"run project create\");\n   393\t\n   394\t    assert!(\n   395\t        output.status.success(),\n   396\t        \"stderr: {}\",\n   397\t        String::from_utf8_lossy(&output.stderr)\n   398\t    );\n   399\t\n   400\t    let stdout = String::from_utf8_lossy(&output.stdout);\n   401\t    assert!(stdout.contains(\"Created project 'alpha'\"));\n   402\t    assert!(stdout.contains(\"standard\"));\n   403\t\n   404\t    let project_root = temp_dir.path().join(\".ralph-burning/projects/alpha\");\n   405\t    assert!(project_root.join(\"project.toml\").is_file());\n   406\t    assert!(project_root.join(\"prompt.md\").is_file());\n   407\t    assert!(project_root.join(\"run.json\").is_file());\n   408\t    assert!(project_root.join(\"journal.ndjson\").is_file());\n   409\t    assert!(project_root.join(\"sessions.json\").is_file());\n   410\t    assert!(project_root.join(\"history/payloads\").is_dir());\n   411\t    assert!(project_root.join(\"history/artifacts\").is_dir());\n   412\t    assert!(project_root.join(\"runtime/logs\").is_dir());\n   413\t    assert!(project_root.join(\"runtime/backend\").is_dir());\n   414\t    assert!(project_root.join(\"runtime/temp\").is_dir());\n   415\t    assert!(project_root.join(\"amendments\").is_dir());\n   416\t    assert!(project_root.join(\"rollback\").is_dir());\n   417\t}\n   418\t\n   419\t#[test]\n   420\tfn project_create_initializes_journal_with_project_created_event() {\n   421\t    let temp_dir = initialize_workspace_fixture();\n   422\t    let prompt = write_prompt_fixture(temp_dir.path());\n   423\t\n   424\t    let output = Command::new(binary())\n   425\t        .args([\n   426\t            \"project\",\n   427\t            \"create\",\n   428\t            \"--id\",\n   429\t            \"beta\",\n   430\t            \"--name\",\n   431\t            \"Beta\",\n   432\t            \"--prompt\",\n   433\t            prompt.to_str().unwrap(),\n   434\t            \"--flow\",\n   435\t            \"quick_dev\",\n   436\t        ])\n   437\t        .current_dir(temp_dir.path())\n   438\t        .output()\n   439\t        .expect(\"run project create\");\n   440\t    assert!(output.status.success());\n   441\t\n   442\t    let journal = fs::read_to_string(\n   443\t        temp_dir\n   444\t            .path()\n   445\t            .join(\".ralph-burning/projects/beta/journal.ndjson\"),\n   446\t    )\n   447\t    .expect(\"read journal\");\n   448\t\n   449\t    assert!(journal.contains(\"\\\"project_created\\\"\"));\n   450\t    assert!(journal.contains(\"\\\"sequence\\\":1\"));\n   451\t}\n   452\t\n   453\t#[test]\n   454\tfn project_create_run_json_shows_not_started() {\n   455\t    let temp_dir = initialize_workspace_fixture();\n   456\t    let prompt = write_prompt_fixture(temp_dir.path());\n   457\t\n   458\t    Command::new(binary())\n   459\t        .args([\n   460\t            \"project\",\n   461\t            \"create\",\n   462\t            \"--id\",\n   463\t            \"gamma\",\n   464\t            \"--name\",\n   465\t            \"Gamma\",\n   466\t            \"--prompt\",\n   467\t            prompt.to_str().unwrap(),\n   468\t            \"--flow\",\n   469\t            \"standard\",\n   470\t        ])\n   471\t        .current_dir(temp_dir.path())\n   472\t        .output()\n   473\t        .expect(\"run project create\");\n   474\t\n   475\t    let run_json = fs::read_to_string(\n   476\t        temp_dir\n   477\t            .path()\n   478\t            .join(\".ralph-burning/projects/gamma/run.json\"),\n   479\t    )\n   480\t    .expect(\"read run.json\");\n   481\t\n   482\t    assert!(run_json.contains(\"\\\"not_started\\\"\"));\n   483\t    assert!(run_json.contains(\"\\\"active_run\\\": null\"));\n   484\t}\n   485\t\n   486\t#[test]\n   487\tfn project_create_records_canonical_prompt_reference_not_source_path() {\n   488\t    let temp_dir = initialize_workspace_fixture();\n   489\t    // Use a non-standard filename to verify the recorded reference is canonical\n   490\t    let external_prompt = temp_dir.path().join(\"my-external-prompt.md\");\n   491\t    fs::write(&external_prompt, \"# External Prompt\\nContent.\").expect(\"write prompt\");\n   492\t\n   493\t    let output = Command::new(binary())\n   494\t        .args([\n   495\t            \"project\",\n   496\t            \"create\",\n   497\t            \"--id\",\n   498\t            \"reftest\",\n   499\t            \"--name\",\n   500\t            \"Ref Test\",\n   501\t            \"--prompt\",\n   502\t            external_prompt.to_str().unwrap(),\n   503\t            \"--flow\",\n   504\t            \"standard\",\n   505\t        ])\n   506\t        .current_dir(temp_dir.path())\n   507\t        .output()\n   508\t        .expect(\"run project create\");\n   509\t    assert!(output.status.success());\n   510\t\n   511\t    let project_toml = fs::read_to_string(\n   512\t        temp_dir\n   513\t            .path()\n   514\t            .join(\".ralph-burning/projects/reftest/project.toml\"),\n   515\t    )\n   516\t    .expect(\"read project.toml\");\n   517\t\n   518\t    // prompt_reference should be the canonical copied path, not the source path\n   519\t    assert!(\n   520\t        project_toml.contains(\"prompt_reference = \\\"prompt.md\\\"\"),\n   521\t        \"project.toml should record canonical prompt.md, got:\\n{project_toml}\"\n   522\t    );\n   523\t    assert!(\n   524\t        !project_toml.contains(\"my-external-prompt\"),\n   525\t        \"project.toml should not contain the source path\"\n   526\t    );\n   527\t}\n   528\t\n   529\t#[test]\n   530\tfn project_create_fails_on_duplicate_id() {\n   531\t    let temp_dir = initialize_workspace_fixture();\n   532\t    let prompt = write_prompt_fixture(temp_dir.path());\n   533\t\n   534\t    let first = Command::new(binary())\n   535\t        .args([\n   536\t            \"project\",\n   537\t            \"create\",\n   538\t            \"--id\",\n   539\t            \"dup\",\n   540\t            \"--name\",\n   541\t            \"First\",\n   542\t            \"--prompt\",\n   543\t            prompt.to_str().unwrap(),\n   544\t            \"--flow\",\n   545\t            \"standard\",\n   546\t        ])\n   547\t        .current_dir(temp_dir.path())\n   548\t        .output()\n   549\t        .expect(\"first create\");\n   550\t    assert!(first.status.success());\n   551\t\n   552\t    let second = Command::new(binary())\n   553\t        .args([\n   554\t            \"project\",\n   555\t            \"create\",\n   556\t            \"--id\",\n   557\t            \"dup\",\n   558\t            \"--name\",\n   559\t            \"Second\",\n   560\t            \"--prompt\",\n","exit_code":0,"status":"completed"}}
{"type":"item.completed","item":{"id":"item_26","type":"command_execution","command":"/run/current-system/sw/bin/bash -lc \"nl -ba tests/cli.rs | sed -n '1,260p'\"","aggregated_output":"     1\tuse std::fs;\n     2\tuse std::os::unix::fs::PermissionsExt;\n     3\tuse std::process::Command;\n     4\t\n     5\tuse tempfile::tempdir;\n     6\t\n     7\tfn binary() -> &'static str {\n     8\t    env!(\"CARGO_BIN_EXE_ralph-burning\")\n     9\t}\n    10\t\n    11\tfn initialize_workspace_fixture() -> tempfile::TempDir {\n    12\t    let temp_dir = tempdir().expect(\"create temp dir\");\n    13\t    let output = Command::new(binary())\n    14\t        .arg(\"init\")\n    15\t        .current_dir(temp_dir.path())\n    16\t        .output()\n    17\t        .expect(\"run init\");\n    18\t    assert!(output.status.success());\n    19\t    temp_dir\n    20\t}\n    21\t\n    22\tfn create_project_fixture(base_dir: &std::path::Path, project_id: &str) {\n    23\t    let project_root = base_dir.join(\".ralph-burning/projects\").join(project_id);\n    24\t    fs::create_dir_all(&project_root).expect(\"create project directory\");\n    25\t    // Write a complete canonical ProjectRecord so validation passes\n    26\t    let project_toml = format!(\n    27\t        r#\"id = \"{project_id}\"\n    28\tname = \"Fixture {project_id}\"\n    29\tflow = \"standard\"\n    30\tprompt_reference = \"prompt.md\"\n    31\tprompt_hash = \"0000000000000000\"\n    32\tcreated_at = \"2026-03-11T19:00:00Z\"\n    33\tstatus_summary = \"created\"\n    34\t\"#\n    35\t    );\n    36\t    fs::write(project_root.join(\"project.toml\"), project_toml).expect(\"write project\");\n    37\t    // Write required canonical files so run queries don't fail on missing files\n    38\t    fs::write(project_root.join(\"prompt.md\"), \"# Fixture prompt\\n\").expect(\"write prompt\");\n    39\t    fs::write(\n    40\t        project_root.join(\"run.json\"),\n    41\t        r#\"{\"active_run\":null,\"status\":\"not_started\",\"cycle_history\":[],\"completion_rounds\":0,\"rollback_point_meta\":{\"last_rollback_id\":null,\"rollback_count\":0},\"amendment_queue\":{\"pending\":[],\"processed_count\":0},\"status_summary\":\"not started\"}\"#,\n    42\t    ).expect(\"write run.json\");\n    43\t    fs::write(\n    44\t        project_root.join(\"journal.ndjson\"),\n    45\t        format!(\n    46\t            r#\"{{\"sequence\":1,\"timestamp\":\"2026-03-11T19:00:00Z\",\"event_type\":\"project_created\",\"details\":{{\"project_id\":\"{}\",\"flow\":\"standard\"}}}}\"#,\n    47\t            project_id\n    48\t        ),\n    49\t    ).expect(\"write journal\");\n    50\t    fs::write(project_root.join(\"sessions.json\"), r#\"{\"sessions\":[]}\"#).expect(\"write sessions\");\n    51\t    for subdir in &[\n    52\t        \"history/payloads\",\n    53\t        \"history/artifacts\",\n    54\t        \"runtime/logs\",\n    55\t        \"runtime/backend\",\n    56\t        \"runtime/temp\",\n    57\t        \"amendments\",\n    58\t        \"rollback\",\n    59\t    ] {\n    60\t        fs::create_dir_all(project_root.join(subdir)).expect(\"create project subdirectory\");\n    61\t    }\n    62\t}\n    63\t\n    64\tfn write_editor_script(\n    65\t    base_dir: &std::path::Path,\n    66\t    name: &str,\n    67\t    contents: &str,\n    68\t) -> std::path::PathBuf {\n    69\t    let script_path = base_dir.join(name);\n    70\t    fs::write(&script_path, contents).expect(\"write editor script\");\n    71\t    let mut permissions = fs::metadata(&script_path)\n    72\t        .expect(\"script metadata\")\n    73\t        .permissions();\n    74\t    permissions.set_mode(0o755);\n    75\t    fs::set_permissions(&script_path, permissions).expect(\"set script permissions\");\n    76\t    script_path\n    77\t}\n    78\t\n    79\t#[test]\n    80\tfn flow_list_prints_all_presets() {\n    81\t    let output = Command::new(binary())\n    82\t        .args([\"flow\", \"list\"])\n    83\t        .output()\n    84\t        .expect(\"run flow list\");\n    85\t\n    86\t    assert!(output.status.success());\n    87\t\n    88\t    let stdout = String::from_utf8_lossy(&output.stdout);\n    89\t    assert!(stdout.contains(\"standard\"));\n    90\t    assert!(stdout.contains(\"quick_dev\"));\n    91\t    assert!(stdout.contains(\"docs_change\"));\n    92\t    assert!(stdout.contains(\"ci_improvement\"));\n    93\t}\n    94\t\n    95\t#[test]\n    96\tfn flow_show_standard_prints_stage_sequence() {\n    97\t    let output = Command::new(binary())\n    98\t        .args([\"flow\", \"show\", \"standard\"])\n    99\t        .output()\n   100\t        .expect(\"run flow show\");\n   101\t\n   102\t    assert!(output.status.success());\n   103\t\n   104\t    let stdout = String::from_utf8_lossy(&output.stdout);\n   105\t    assert!(stdout.contains(\"Stage count: 8\"));\n   106\t    assert!(stdout.contains(\"1. prompt_review\"));\n   107\t    assert!(stdout.contains(\"8. final_review\"));\n   108\t    assert!(stdout.contains(\"Final review enabled: yes\"));\n   109\t}\n   110\t\n   111\t#[test]\n   112\tfn flow_show_invalid_preset_exits_non_zero_with_clear_error() {\n   113\t    let output = Command::new(binary())\n   114\t        .args([\"flow\", \"show\", \"unknown_flow\"])\n   115\t        .output()\n   116\t        .expect(\"run flow show invalid\");\n   117\t\n   118\t    assert!(!output.status.success());\n   119\t\n   120\t    let stderr = String::from_utf8_lossy(&output.stderr);\n   121\t    assert!(stderr.contains(\"unknown flow preset 'unknown_flow'\"));\n   122\t}\n   123\t\n   124\t#[test]\n   125\tfn init_creates_workspace_layout() {\n   126\t    let temp_dir = tempdir().expect(\"create temp dir\");\n   127\t    let output = Command::new(binary())\n   128\t        .arg(\"init\")\n   129\t        .current_dir(temp_dir.path())\n   130\t        .output()\n   131\t        .expect(\"run init\");\n   132\t\n   133\t    assert!(output.status.success());\n   134\t    assert!(temp_dir\n   135\t        .path()\n   136\t        .join(\".ralph-burning/workspace.toml\")\n   137\t        .is_file());\n   138\t    assert!(temp_dir.path().join(\".ralph-burning/projects\").is_dir());\n   139\t    assert!(temp_dir.path().join(\".ralph-burning/requirements\").is_dir());\n   140\t    assert!(temp_dir.path().join(\".ralph-burning/daemon/tasks\").is_dir());\n   141\t    assert!(temp_dir\n   142\t        .path()\n   143\t        .join(\".ralph-burning/daemon/leases\")\n   144\t        .is_dir());\n   145\t}\n   146\t\n   147\t#[test]\n   148\tfn init_fails_when_workspace_already_exists() {\n   149\t    let temp_dir = tempdir().expect(\"create temp dir\");\n   150\t\n   151\t    let first = Command::new(binary())\n   152\t        .arg(\"init\")\n   153\t        .current_dir(temp_dir.path())\n   154\t        .output()\n   155\t        .expect(\"run first init\");\n   156\t    assert!(first.status.success());\n   157\t\n   158\t    let second = Command::new(binary())\n   159\t        .arg(\"init\")\n   160\t        .current_dir(temp_dir.path())\n   161\t        .output()\n   162\t        .expect(\"run second init\");\n   163\t\n   164\t    assert!(!second.status.success());\n   165\t\n   166\t    let stderr = String::from_utf8_lossy(&second.stderr);\n   167\t    assert!(stderr.contains(\"workspace already initialized\"));\n   168\t}\n   169\t\n   170\t#[test]\n   171\tfn config_show_prints_effective_values_and_sources() {\n   172\t    let temp_dir = initialize_workspace_fixture();\n   173\t\n   174\t    let output = Command::new(binary())\n   175\t        .args([\"config\", \"show\"])\n   176\t        .current_dir(temp_dir.path())\n   177\t        .output()\n   178\t        .expect(\"run config show\");\n   179\t\n   180\t    assert!(output.status.success());\n   181\t\n   182\t    let stdout = String::from_utf8_lossy(&output.stdout);\n   183\t    assert!(stdout.contains(\"[settings]\"));\n   184\t    assert!(stdout.contains(\"prompt_review.enabled = true # source: default\"));\n   185\t    assert!(stdout.contains(\"default_flow = \\\"standard\\\" # source: default\"));\n   186\t    assert!(stdout.contains(\"default_backend = \\\"<unset>\\\" # source: default\"));\n   187\t}\n   188\t\n   189\t#[test]\n   190\tfn config_get_prints_known_values_and_rejects_unknown_keys() {\n   191\t    let temp_dir = initialize_workspace_fixture();\n   192\t\n   193\t    let known = Command::new(binary())\n   194\t        .args([\"config\", \"get\", \"default_flow\"])\n   195\t        .current_dir(temp_dir.path())\n   196\t        .output()\n   197\t        .expect(\"run config get\");\n   198\t    assert!(known.status.success());\n   199\t    assert_eq!(\"standard\\n\", String::from_utf8_lossy(&known.stdout));\n   200\t\n   201\t    let unknown = Command::new(binary())\n   202\t        .args([\"config\", \"get\", \"unknown.key\"])\n   203\t        .current_dir(temp_dir.path())\n   204\t        .output()\n   205\t        .expect(\"run config get invalid\");\n   206\t    assert!(!unknown.status.success());\n   207\t    assert!(String::from_utf8_lossy(&unknown.stderr).contains(\"unknown config key\"));\n   208\t}\n   209\t\n   210\t#[test]\n   211\tfn config_set_updates_valid_keys_and_rejects_invalid_values() {\n   212\t    let temp_dir = initialize_workspace_fixture();\n   213\t\n   214\t    let valid = Command::new(binary())\n   215\t        .args([\"config\", \"set\", \"default_flow\", \"quick_dev\"])\n   216\t        .current_dir(temp_dir.path())\n   217\t        .output()\n   218\t        .expect(\"run config set\");\n   219\t    assert!(valid.status.success());\n   220\t    assert!(String::from_utf8_lossy(&valid.stdout).contains(\"Updated default_flow = quick_dev\"));\n   221\t\n   222\t    let workspace_config =\n   223\t        fs::read_to_string(temp_dir.path().join(\".ralph-burning/workspace.toml\"))\n   224\t            .expect(\"read workspace config\");\n   225\t    assert!(workspace_config.contains(\"default_flow = \\\"quick_dev\\\"\"));\n   226\t\n   227\t    let invalid_value = Command::new(binary())\n   228\t        .args([\"config\", \"set\", \"default_flow\", \"unknown_flow\"])\n   229\t        .current_dir(temp_dir.path())\n   230\t        .output()\n   231\t        .expect(\"run invalid config set\");\n   232\t    assert!(!invalid_value.status.success());\n   233\t    assert!(String::from_utf8_lossy(&invalid_value.stderr).contains(\"invalid value\"));\n   234\t\n   235\t    let invalid_key = Command::new(binary())\n   236\t        .args([\"config\", \"set\", \"unknown.key\", \"value\"])\n   237\t        .current_dir(temp_dir.path())\n   238\t        .output()\n   239\t        .expect(\"run invalid key config set\");\n   240\t    assert!(!invalid_key.status.success());\n   241\t    assert!(String::from_utf8_lossy(&invalid_key.stderr).contains(\"unknown config key\"));\n   242\t}\n   243\t\n   244\t#[test]\n   245\tfn config_edit_revalidates_workspace_file() {\n   246\t    let temp_dir = initialize_workspace_fixture();\n   247\t    let editor = write_editor_script(\n   248\t        temp_dir.path(),\n   249\t        \"editor-valid.sh\",\n   250\t        \"#!/bin/sh\\ncat <<'EOF' > \\\"$1\\\"\\nversion = 1\\ncreated_at = \\\"2026-03-11T17:50:55Z\\\"\\n\\n[settings]\\ndefault_backend = \\\"claude\\\"\\nEOF\\n\",\n   251\t    );\n   252\t\n   253\t    let output = Command::new(binary())\n   254\t        .args([\"config\", \"edit\"])\n   255\t        .env(\"EDITOR\", &editor)\n   256\t        .env_remove(\"VISUAL\")\n   257\t        .current_dir(temp_dir.path())\n   258\t        .output()\n   259\t        .expect(\"run config edit\");\n   260\t\n","exit_code":0,"status":"completed"}}
