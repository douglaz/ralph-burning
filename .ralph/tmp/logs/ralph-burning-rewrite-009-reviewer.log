   stage_id,\n  1285\t                },\n  1286\t                stage_id,\n  1287\t                run_id,\n  1288\t                seq,\n  1289\t                snapshot,\n  1290\t                journal_store,\n  1291\t                run_snapshot_write,\n  1292\t                base_dir,\n  1293\t                project_id,\n  1294\t                origin,\n  1295\t            )\n  1296\t            .await;\n  1297\t        }\n  1298\t\n  1299\t        *seq += 1;\n  1300\t        let stage_entered = journal::stage_entered_event(\n  1301\t            *seq,\n  1302\t            Utc::now(),\n  1303\t            run_id,\n  1304\t            stage_id,\n  1305\t            cursor.cycle,\n  1306\t            cursor.attempt,\n  1307\t        );\n  1308\t        let stage_entered_line = journal::serialize_event(&stage_entered)?;\n  1309\t        if let Err(error) = journal_store.append_event(base_dir, project_id, &stage_entered_line) {\n  1310\t            *seq -= 1;\n  1311\t            return fail_run_result(\n  1312\t                &AppError::StageCommitFailed {\n  1313\t                    stage_id,\n  1314\t                    details: format!(\n  1315\t                        \"failed to persist stage_entered event for {}: {}\",\n  1316\t                        stage_id.as_str(),\n  1317\t                        error\n  1318\t                    ),\n  1319\t                },\n  1320\t                stage_id,\n  1321\t                run_id,\n  1322\t                seq,\n  1323\t                snapshot,\n  1324\t                journal_store,\n  1325\t                run_snapshot_write,\n  1326\t                base_dir,\n  1327\t                project_id,\n  1328\t                origin,\n  1329\t            )\n  1330\t            .await;\n  1331\t        }\n  1332\t\n  1333\t        snapshot.status = RunStatus::Running;\n  1334\t        snapshot.active_run = Some(ActiveRun {\n  1335\t            run_id: run_id.as_str().to_owned(),\n  1336\t            stage_cursor: cursor.clone(),\n  1337\t            started_at: snapshot_started_at(snapshot)?,\n  1338\t        });\n  1339\t        snapshot.status_summary = format!(\"running: {}\", stage_id.display_name());\n  1340\t        if let Err(error) = run_snapshot_write.write_run_snapshot(base_dir, project_id, snapshot) {\n  1341\t            return fail_run_result(\n  1342\t                &AppError::StageCommitFailed {\n  1343\t                    stage_id,\n  1344\t                    details: format!(\n  1345\t                        \"failed to update snapshot for stage {} attempt {}: {}\",\n  1346\t                        stage_id.as_str(),\n  1347\t                        cursor.attempt,\n  1348\t                        error\n  1349\t                    ),\n  1350\t                },\n  1351\t                stage_id,\n  1352\t                run_id,\n  1353\t                seq,\n  1354\t                snapshot,\n  1355\t                journal_store,\n  1356\t                run_snapshot_write,\n  1357\t                base_dir,\n  1358\t                project_id,\n  1359\t                origin,\n  1360\t            )\n  1361\t            .await;\n  1362\t        }\n  1363\t\n  1364\t        let _ = log_write.append_runtime_log(\n  1365\t            base_dir,\n  1366\t            project_id,\n  1367\t            &RuntimeLogEntry {\n  1368\t                timestamp: Utc::now(),\n  1369\t                level: LogLevel::Info,\n  1370\t                source: \"engine\".to_owned(),\n  1371\t                message: format!(\n  1372\t                    \"stage_entered: {} cycle={} attempt={}\",\n  1373\t                    stage_id.as_str(),\n  1374\t                    cursor.cycle,\n  1375\t                    cursor.attempt\n  1376\t                ),\n  1377\t            },\n  1378\t        );\n  1379\t\n  1380\t        let request = InvocationRequest {\n  1381\t            invocation_id: format!(\n  1382\t                \"{}-{}-c{}-a{}\",\n  1383\t                run_id.as_str(),\n  1384\t                stage_id.as_str(),\n  1385\t                cursor.cycle,\n  1386\t                cursor.attempt\n  1387\t            ),\n  1388\t            project_root: project_root.to_path_buf(),\n  1389\t            stage_contract: stage_entry.contract,\n  1390\t            role: stage_entry.role,\n  1391\t            resolved_target: stage_entry.target.clone(),\n  1392\t            payload: InvocationPayload {\n  1393\t                prompt: format!(\"Execute stage: {}\", stage_id.display_name()),\n  1394\t                context: invocation_context(&cursor, execution_context, pending_amendments),\n  1395\t            },\n  1396\t            timeout: Duration::from_secs(300),\n  1397\t            cancellation_token: cancellation_token.clone(),\n  1398\t            session_policy: SessionPolicy::ReuseIfAllowed,\n  1399\t            prior_session: None,\n  1400\t            attempt_number: cursor.attempt,\n  1401\t        };\n  1402\t\n  1403\t        let result = agent_service.invoke(request).await.and_then(|envelope| {\n  1404\t            stage_entry\n  1405\t                .contract\n  1406\t                .evaluate_permissive(&envelope.parsed_payload)\n  1407\t                .map_err(|contract_error| AppError::InvocationFailed {\n  1408\t                    backend: stage_entry.target.backend.family.to_string(),\n  1409\t                    stage_id,\n  1410\t                    failure_class: contract_error.failure_class(),\n  1411\t                    details: contract_error.to_string(),\n  1412\t                })\n  1413\t        });\n  1414\t\n  1415\t        match result {\n  1416\t            Ok(bundle) => return Ok((cursor.clone(), bundle)),\n  1417\t            Err(error) => {\n  1418\t                let Some(failure_class) = error.failure_class() else {\n  1419\t                    return fail_run_result(\n  1420\t                        &error,\n  1421\t                        stage_id,\n  1422\t                        run_id,\n  1423\t                        seq,\n  1424\t                        snapshot,\n  1425\t                        journal_store,\n  1426\t                        run_snapshot_write,\n  1427\t                        base_dir,\n  1428\t                        project_id,\n  1429\t                        origin,\n  1430\t                    )\n  1431\t                    .await;\n  1432\t                };\n  1433\t\n  1434\t                let max_attempts = retry_policy.max_attempts(failure_class);\n  1435\t                let will_retry = retry_policy.is_retryable(failure_class)\n  1436\t                    && cursor.attempt < max_attempts\n  1437\t                    && !matches!(failure_class, FailureClass::Cancellation)\n  1438\t                    && !cancellation_token.is_cancelled();\n  1439\t\n  1440\t                *seq += 1;\n  1441\t                let stage_failed = journal::stage_failed_event(\n  1442\t                    *seq,\n  1443\t                    Utc::now(),\n  1444\t                    run_id,\n  1445\t                    stage_id,\n  1446\t                    cursor.cycle,\n  1447\t                    cursor.attempt,\n  1448\t                    failure_class,\n  1449\t                    &error.to_string(),\n  1450\t                    will_retry,\n  1451\t                );\n  1452\t                let stage_failed_line = journal::serialize_event(&stage_failed)?;\n  1453\t                if let Err(append_error) =\n  1454\t                    journal_store.append_event(base_dir, project_id, &stage_failed_line)\n  1455\t                {\n  1456\t                    *seq -= 1;\n  1457\t                    return fail_run_result(\n  1458\t                        &AppError::StageCommitFailed {\n  1459\t                            stage_id,\n  1460\t                            details: format!(\n  1461\t                                \"failed to persist stage_failed event for {}: {}\",\n  1462\t                                stage_id.as_str(),\n  1463\t                                append_error\n  1464\t                            ),\n  1465\t                        },\n  1466\t                        stage_id,\n  1467\t                        run_id,\n  1468\t                        seq,\n  1469\t                        snapshot,\n  1470\t                        journal_store,\n  1471\t                        run_snapshot_write,\n  1472\t                        base_dir,\n  1473\t                        project_id,\n  1474\t                        origin,\n  1475\t                    )\n  1476\t                    .await;\n  1477\t                }\n  1478\t\n  1479\t                let _ = log_write.append_runtime_log(\n  1480\t                    base_dir,\n  1481\t                    project_id,\n  1482\t                    &RuntimeLogEntry {\n  1483\t                        timestamp: Utc::now(),\n  1484\t                        level: LogLevel::Warn,\n  1485\t                        source: \"engine\".to_owned(),\n  1486\t                        message: format!(\n  1487\t                            \"stage_failed: {} cycle={} attempt={} retry={}\",\n  1488\t                            stage_id.as_str(),\n  1489\t                            cursor.cycle,\n  1490\t                            cursor.attempt,\n  1491\t                            will_retry\n  1492\t                        ),\n  1493\t                    },\n  1494\t                );\n  1495\t\n  1496\t                if will_retry {\n  1497\t                    cursor = cursor.retry();\n  1498\t                    continue;\n  1499\t                }\n  1500\t\n  1501\t                return fail_run_result(\n  1502\t                    &error,\n  1503\t                    stage_id,\n  1504\t                    run_id,\n  1505\t                    seq,\n  1506\t                    snapshot,\n  1507\t                    journal_store,\n  1508\t                    run_snapshot_write,\n  1509\t                    base_dir,\n  1510\t                    project_id,\n  1511\t                    origin,\n  1512\t                )\n  1513\t                .await;\n  1514\t            }\n  1515\t        }\n  1516\t    }\n  1517\t}\n  1518\t\n  1519\t#[allow(clippy::too_many_arguments)]\n  1520\tasync fn persist_stage_success(\n  1521\t    artifact_write: &dyn PayloadArtifactWritePort,\n  1522\t    journal_store: &dyn JournalStorePort,\n  1523\t    run_snapshot_write: &dyn RunSnapshotWritePort,\n  1524\t    log_write: &dyn RuntimeLogWritePort,\n  1525\t    base_dir: &Path,\n  1526\t    project_id: &ProjectId,\n  1527\t    run_id: &RunId,\n  1528\t    seq: &mut u64,\n  1529\t    snapshot: &mut RunSnapshot,\n  1530\t    stage_id: StageId,\n  1531\t    cursor: &StageCursor,\n  1532\t    bundle: &ValidatedBundle,\n  1533\t    origin: ExecutionOrigin,\n  1534\t) -> AppResult<()> {\n  1535\t    let stage_now = Utc::now();\n  1536\t    let payload_id = format!(\n  1537\t        \"{}-{}-c{}-a{}\",\n  1538\t        run_id.as_str(),\n  1539\t        stage_id.as_str(),\n  1540\t        cursor.cycle,\n  1541\t        cursor.attempt\n  1542\t    );\n  1543\t    let artifact_id = format!(\"{}-artifact\", payload_id);\n  1544\t\n  1545\t    let payload_record = PayloadRecord {\n  1546\t        payload_id: payload_id.clone(),\n  1547\t        stage_id,\n  1548\t        cycle: cursor.cycle,\n  1549\t        attempt: cursor.attempt,\n  1550\t        created_at: stage_now,\n  1551\t        payload: serde_json::to_value(&bundle.payload)?,\n  1552\t    };\n  1553\t    let artifact_record = ArtifactRecord {\n  1554\t        artifact_id: artifact_id.clone(),\n  1555\t        payload_id: payload_id.clone(),\n  1556\t        stage_id,\n  1557\t        created_at: stage_now,\n  1558\t        content: bundle.artifact.clone(),\n  1559\t    };\n  1560\t\n  1561\t    if let Err(error) = artifact_write.write_payload_artifact_pair(\n  1562\t        base_dir,\n  1563\t        project_id,\n  1564\t        &payload_record,\n  1565\t        &artifact_record,\n  1566\t    ) {\n  1567\t        let _ = artifact_write.remove_payload_artifact_pair(\n  1568\t            base_dir,\n  1569\t            project_id,\n  1570\t            &payload_id,\n  1571\t            &artifact_id,\n  1572\t        );\n  1573\t        return fail_run(\n  1574\t            &AppError::StageCommitFailed {\n  1575\t                stage_id,\n  1576\t                details: format!(\"payload/artifact persistence failed: {}\", error),\n  1577\t            },\n  1578\t            stage_id,\n  1579\t            run_id,\n  1580\t            seq,\n  1581\t            snapshot,\n  1582\t            journal_store,\n  1583\t            run_snapshot_write,\n  1584\t            base_dir,\n  1585\t            project_id,\n  1586\t            origin,\n  1587\t        )\n  1588\t        .await;\n  1589\t    }\n  1590\t\n  1591\t    *seq += 1;\n  1592\t    let stage_completed = journal::stage_completed_event(\n  1593\t        *seq,\n  1594\t        Utc::now(),\n  1595\t        run_id,\n  1596\t        stage_id,\n  1597\t        cursor.cycle,\n  1598\t        cursor.attempt,\n  1599\t        &payload_id,\n  1600\t        &artifact_id,\n  1601\t    );\n  1602\t    let stage_completed_line = journal::serialize_event(&stage_completed)?;\n  1603\t    if let Err(error) = journal_store.append_event(base_dir, project_id, &stage_completed_line) {\n  1604\t        let _ = artifact_write.remove_payload_artifact_pair(\n  1605\t            base_dir,\n  1606\t            project_id,\n  1607\t            &payload_id,\n  1608\t            &artifact_id,\n  1609\t        );\n  1610\t        *seq -= 1;\n  1611\t        return fail_run(\n  1612\t            &AppError::StageCommitFailed {\n  1613\t                stage_id,\n  1614\t                details: format!(\"journal append failed during stage commit: {}\", error),\n  1615\t            },\n  1616\t            stage_id,\n  1617\t            run_id,\n  1618\t            seq,\n  1619\t            snapshot,\n  1620\t            journal_store,\n  1621\t            run_snapshot_write,\n  1622\t            base_dir,\n  1623\t            project_id,\n  1624\t            origin,\n  1625\t        )\n  1626\t        .await;\n  1627\t    }\n  1628\t\n  1629\t    let _ = log_write.append_runtime_log(\n  1630\t        base_dir,\n  1631\t        project_id,\n  1632\t        &RuntimeLogEntry {\n  1633\t            timestamp: Utc::now(),\n  1634\t            level: LogLevel::Info,\n  1635\t            source: \"engine\".to_owned(),\n  1636\t            message: format!(\"stage_completed: {}\", stage_id.as_str()),\n  1637\t        },\n  1638\t    );\n  1639\t\n  1640\t    Ok(())\n  1641\t}\n  1642\t\n  1643\tfn complete_run(\n  1644\t    snapshot: &mut RunSnapshot,\n  1645\t    run_snapshot_write: &dyn RunSnapshotWritePort,\n  1646\t    journal_store: &dyn JournalStorePort,\n  1647\t    amendment_queue_port: &dyn AmendmentQueuePort,\n  1648\t    base_dir: &Path,\n  1649\t    project_id: &ProjectId,\n  1650\t    run_id: &RunId,\n  1651\t    seq: &mut u64,\n  1652\t) -> AppResult<()> {\n  1653\t    // Completion guard: block completion if pending amendments remain.\n  1654\t    // On CompletionBlocked, persist a resumable (Failed, active_run=None) snapshot\n  1655\t    // so that `run resume` can pick the run back up.\n  1656\t    if let Err(e) = completion_guard(snapshot, amendment_queue_port, base_dir, project_id) {\n  1657\t        if matches!(&e, AppError::CompletionBlocked { .. }) {\n  1658\t            snapshot.status = RunStatus::Failed;\n  1659\t            snapshot.active_run = None;\n  1660\t            snapshot.status_summary = format!(\"blocked: {}\", e);\n  1661\t            run_snapshot_write\n  1662\t                .write_run_snapshot(base_dir, project_id, snapshot)\n  1663\t                .map_err(|write_err| AppError::CompletionGuardSnapshotFailed {\n  1664\t                    details: format!(\n  1665\t                        \"completion guard fired ({}) but resumable snapshot could not be persisted: {}\",\n  1666\t                        e, write_err\n  1667\t                    ),\n  1668\t                })?;\n  1669\t        }\n  1670\t        return Err(e);\n  1671\t    }\n  1672\t\n  1673\t    snapshot.status = RunStatus::Completed;\n  1674\t    snapshot.active_run = None;\n  1675\t    snapshot.completion_rounds = snapshot.completion_rounds.max(1);\n  1676\t    snapshot.status_summary = \"completed\".to_owned();\n  1677\t    run_snapshot_write.write_run_snapshot(base_dir, project_id, snapshot)?;\n  1678\t\n  1679\t    *seq += 1;\n  1680\t    let run_completed =\n  1681\t        journal::run_completed_event(*seq, Utc::now(), run_id, snapshot.completion_rounds);\n  1682\t    let run_completed_line = journal::serialize_event(&run_completed)?;\n  1683\t    journal_store.append_event(base_dir, project_id, &run_completed_line)?;\n  1684\t    Ok(())\n  1685\t}\n  1686\t\n  1687\tfn pause_run(\n  1688\t    snapshot: &mut RunSnapshot,\n  1689\t    run_snapshot_write: &dyn RunSnapshotWritePort,\n  1690\t    base_dir: &Path,\n  1691\t    project_id: &ProjectId,\n  1692\t    summary: String,\n  1693\t) -> AppResult<()> {\n  1694\t    snapshot.status = RunStatus::Paused;\n  1695\t    snapshot.active_run = None;\n  1696\t    snapshot.status_summary = summary;\n  1697\t    run_snapshot_write.write_run_snapshot(base_dir, project_id, snapshot)\n  1698\t}\n  1699\t\n  1700\t/// Record a run failure: persist failed snapshot, then journal event, return error.\n  1701\t#[allow(clippy::too_many_arguments)]\n  1702\tasync fn fail_run(\n  1703\t    err: &AppError,\n  1704\t    stage_id: StageId,\n  1705\t    run_id: &RunId,\n  1706\t    seq: &mut u64,\n  1707\t    snapshot: &mut RunSnapshot,\n  1708\t    journal_store: &dyn JournalStorePort,\n  1709\t    run_snapshot_write: &dyn RunSnapshotWritePort,\n  1710\t    base_dir: &Path,\n  1711\t    project_id: &ProjectId,\n  1712\t    origin: ExecutionOrigin,\n  1713\t) -> AppResult<()> {\n  1714\t    let failure_class = failure_label(err);\n  1715\t    let message = err.to_string();\n  1716\t\n  1717\t    snapshot.status = RunStatus::Failed;\n  1718\t    snapshot.active_run = None;\n  1719\t    snapshot.status_summary = format!(\"failed at {}: {}\", stage_id.display_name(), message);\n  1720\t    run_snapshot_write.write_run_snapshot(base_dir, project_id, snapshot)?;\n  1721\t\n  1722\t    *seq += 1;\n  1723\t    let run_failed =\n  1724\t        journal::run_failed_event(*seq, Utc::now(), run_id, stage_id, &failure_class, &message);\n  1725\t    if let Ok(run_failed_line) = journal::serialize_event(&run_failed) {\n  1726\t        let _ = journal_store.append_event(base_dir, project_id, &run_failed_line);\n  1727\t    }\n  1728\t\n  1729\t    Err(origin.error(format!(\"stage {} failed: {}\", stage_id.as_str(), message)))\n  1730\t}\n  1731\t\n  1732\t#[allow(clippy::too_many_arguments)]\n  1733\tasync fn fail_run_result<T>(\n  1734\t    err: &AppError,\n  1735\t    stage_id: StageId,\n  1736\t    run_id: &RunId,\n  1737\t    seq: &mut u64,\n  1738\t    snapshot: &mut RunSnapshot,\n  1739\t    journal_store: &dyn JournalStorePort,\n  1740\t    run_snapshot_write: &dyn RunSnapshotWritePort,\n  1741\t    base_dir: &Path,\n  1742\t    project_id: &ProjectId,\n  1743\t    origin: ExecutionOrigin,\n  1744\t) -> AppResult<T> {\n  1745\t    fail_run(\n  1746\t        err,\n  1747\t        stage_id,\n  1748\t        run_id,\n  1749\t        seq,\n  1750\t        snapshot,\n  1751\t        journal_store,\n  1752\t        run_snapshot_write,\n  1753\t        base_dir,\n  1754\t        project_id,\n  1755\t        origin,\n  1756\t    )\n  1757\t    .await?;\n  1758\t    unreachable!(\"fail_run always returns an error\")\n  1759\t}\n  1760\t\n  1761\tfn failure_label(error: &AppError) -> String {\n  1762\t    if let Some(failure_class) = error.failure_class() {\n  1763\t        return failure_class.as_str().to_owned();\n  1764\t    }\n  1765\t\n  1766\t    match error {\n  1767\t        AppError::RemediationExhausted { .. } => \"remediation_exhausted\".to_owned(),\n  1768\t        AppError::ResumeFailed { .. } => \"resume_failed\".to_owned(),\n  1769\t        _ => \"unknown\".to_owned(),\n  1770\t    }\n  1771\t}\n  1772\t\n  1773\tfn prompt_review_requires_pause(payload: &StagePayload) -> bool {\n  1774\t    matches!(\n  1775\t        payload,\n  1776\t        StagePayload::Planning(planning) if !planning.readiness.ready\n  1777\t    )\n  1778\t}\n  1779\t\n  1780\tfn validation_outcome(payload: &StagePayload) -> Option<ReviewOutcome> {\n  1781\t    match payload {\n  1782\t        StagePayload::Validation(validation) => Some(validation.outcome),\n  1783\t        _ => None,\n  1784\t    }\n  1785\t}\n  1786\t\n  1787\tfn validation_follow_ups(payload: &StagePayload) -> &[String] {\n  1788\t    match payload {\n  1789\t        StagePayload::Validation(validation) => &validation.follow_up_or_amendments,\n  1790\t        _ => &[],\n  1791\t    }\n  1792\t}\n  1793\t\n  1794\t/// Build typed QueuedAmendment records from follow-up strings.\n  1795\tfn build_queued_amendments(\n  1796\t    follow_ups: &[String],\n  1797\t    source_stage: StageId,\n  1798\t    source_cycle: u32,\n  1799\t    source_completion_round: u32,\n  1800\t    run_id: &RunId,\n  1801\t) -> Vec<QueuedAmendment> {\n  1802\t    let now = Utc::now();\n  1803\t    follow_ups\n  1804\t        .iter()\n  1805\t        .enumerate()\n  1806\t        .map(|(idx, body)| QueuedAmendment {\n  1807\t            amendment_id: format!(\n  1808\t                \"{}-{}-cr{}-amd{}\",\n  1809\t                run_id.as_str(),\n  1810\t                source_stage.as_str(),\n  1811\t                source_completion_round,\n  1812\t                idx + 1\n  1813\t            ),\n  1814\t            source_stage,\n  1815\t            source_cycle,\n  1816\t            source_completion_round,\n  1817\t            body: body.clone(),\n  1818\t            created_at: now,\n  1819\t            batch_sequence: (idx + 1) as u32,\n  1820\t        })\n  1821\t        .collect()\n  1822\t}\n  1823\t\n  1824\t/// Completion guard: blocks run_completed when pending amendments remain.\n  1825\tfn completion_guard(\n  1826\t    snapshot: &RunSnapshot,\n  1827\t    amendment_queue_port: &dyn AmendmentQueuePort,\n  1828\t    base_dir: &Path,\n  1829\t    project_id: &ProjectId,\n  1830\t) -> AppResult<()> {\n  1831\t    // Check snapshot queue.\n  1832\t    if !snapshot.amendment_queue.pending.is_empty() {\n  1833\t        return Err(AppError::CompletionBlocked {\n  1834\t            details: format!(\n  1835\t                \"completion blocked: {} pending amendments remain in snapshot queue\",\n  1836\t                snapshot.amendment_queue.pending.len()\n  1837\t            ),\n  1838\t        });\n  1839\t    }\n  1840\t\n  1841\t    // Check disk.\n  1842\t    if amendment_queue_port.has_pending_amendments(base_dir, project_id)? {\n  1843\t        return Err(AppError::CompletionBlocked {\n  1844\t            details: \"completion blocked: pending amendment files exist on disk\".to_owned(),\n  1845\t        });\n  1846\t    }\n  1847\t\n  1848\t    Ok(())\n  1849\t}\n  1850\t\n  1851\t/// Reconcile amendments from disk into the snapshot during resume.\n  1852\tfn reconcile_amendments_from_disk(\n  1853\t    snapshot: &mut RunSnapshot,\n  1854\t    amendment_queue_port: &dyn AmendmentQueuePort,\n  1855\t    base_dir: &Path,\n  1856\t    project_id: &ProjectId,\n  1857\t) -> AppResult<()> {\n  1858\t    let disk_amendments = amendment_queue_port.list_pending_amendments(base_dir, project_id)?;\n  1859\t    if disk_amendments.is_empty() {\n  1860\t        return Ok(());\n  1861\t    }\n  1862\t\n  1863\t    // Merge disk amendments into snapshot, avoiding duplicates by ID.\n  1864\t    let existing_ids: std::collections::HashSet<String> = snapshot\n  1865\t        .amendment_queue\n  1866\t        .pending\n  1867\t        .iter()\n  1868\t        .map(|a| a.amendment_id.clone())\n  1869\t        .collect();\n  1870\t\n  1871\t    for amendment in disk_amendments {\n  1872\t        if !existing_ids.contains(&amendment.amendment_id) {\n  1873\t            snapshot.amendment_queue.pending.push(amendment);\n  1874\t        }\n  1875\t    }\n  1876\t\n  1877\t    // Sort by (created_at, batch_sequence) for deterministic ordering.\n  1878\t    snapshot.amendment_queue.pending.sort_by(|a, b| {\n  1879\t        a.created_at\n  1880\t            .cmp(&b.created_at)\n  1881\t            .then_with(|| a.batch_sequence.cmp(&b.batch_sequence))\n  1882\t    });\n  1883\t\n  1884\t    Ok(())\n  1885\t}\n  1886\t\n  1887\tfn remediation_context(stage_id: StageId, next_cycle: u32, bundle: &ValidatedBundle) -> Value {\n  1888\t    match &bundle.payload {\n  1889\t        StagePayload::Validation(validation) => {\n  1890\t            remediation_context_from_validation(stage_id, next_cycle, validation)\n  1891\t        }\n  1892\t        _ => json!({}),\n  1893\t    }\n  1894\t}\n  1895\t\n  1896\tfn remediation_context_from_validation(\n  1897\t    stage_id: StageId,\n  1898\t    next_cycle: u32,\n  1899\t    validation: &ValidationPayload,\n  1900\t) -> Value {\n  1901\t    json!({\n  1902\t        \"source_stage\": stage_id.as_str(),\n  1903\t        \"cycle\": next_cycle,\n  1904\t        \"follow_up_or_amendments\": validation.follow_up_or_amendments,\n  1905\t        \"findings_or_gaps\": validation.findings_or_gaps,\n  1906\t    })\n  1907\t}\n  1908\t\n  1909\tfn invocation_context(\n  1910\t    cursor: &StageCursor,\n  1911\t    execution_context: Option<&Value>,\n  1912\t    pending_amendments: Option<&[QueuedAmendment]>,\n  1913\t) -> Value {\n  1914\t    let mut context = json!({\n  1915\t        \"cycle\": cursor.cycle,\n  1916\t        \"attempt\": cursor.attempt,\n  1917\t        \"completion_round\": cursor.completion_round,\n  1918\t    });\n  1919\t\n  1920\t    if let Some(execution_context)