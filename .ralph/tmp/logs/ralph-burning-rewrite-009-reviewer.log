elf remains durable so resume can restart from\n1049:    // The completed first stage remains durable so resume can skip it.\n1502:fn conditionally_approved_payload(follow_ups: &[&str]) -> Value {\n1504:        \"outcome\": \"conditionally_approved\",\n1505:        \"evidence\": [\"conditionally good\"],\n1690:    let cycle_advanced: Vec<_> = events\n1694:    assert_eq!(cycle_advanced.len(), 1);\n1695:    assert_eq!(cycle_advanced[0].details[\"to_cycle\"], 2);\n1750:    let cycle_advanced: Vec<_> = events\n1754:    assert_eq!(cycle_advanced.len(), 2);\n1758:async fn resume_after_cycle_advanced_append_failure_restarts_at_implementation() {\n1763:    let pid = create_standard_project(base_dir, \"resume-remediation-boundary\");\n1786:    //  10 cycle_advanced -> fail here\n1811:    let resume_result = engine::resume_standard_run(\n1825:    assert!(resume_result.is_ok(), \"{resume_result:?}\");\n1838:        \"resume must loop back through implementation for remediation\"\n1841:    let run_resumed = events\n1844:        .expect(\"run_resumed\");\n1845:    assert_eq!(run_resumed.details[\"resume_stage\"], \"implementation\");\n1846:    assert_eq!(run_resumed.details[\"cycle\"], 2);\n1861:async fn resume_from_failed_run_skips_completed_stages() {\n1866:    let pid = create_standard_project(base_dir, \"resume-failed\");\n1887:    let resume_agent_service = build_agent_service();\n1888:    let resume_result = engine::resume_standard_run(\n1889:        &resume_agent_service,\n1902:    assert!(resume_result.is_ok(), \"{resume_result:?}\");\n1914:        \"planning should not rerun on resume\"\n1925:    let run_resumed = events\n1928:        .expect(\"run_resumed\");\n1929:    assert_eq!(run_started.details[\"run_id\"], run_resumed.details[\"run_id\"]);\n1930:    assert_eq!(run_resumed.details[\"resume_stage\"], \"implementation\");\n1934:async fn resume_from_paused_prompt_review_run_continues_from_planning() {\n1939:    let pid = create_standard_project(base_dir, \"resume-paused\");\n1966:    assert!(paused_snapshot.status_summary.contains(\"run resume\"));\n1968:    let resume_agent_service = build_agent_service();\n1969:    let resume_result = engine::resume_standard_run(\n1970:        &resume_agent_service,\n1983:    assert!(resume_result.is_ok(), \"{resume_result:?}\");\n2000:    let run_resumed = events\n2003:        .expect(\"run_resumed\");\n2004:    assert_eq!(run_resumed.details[\"resume_stage\"], \"planning\");\n2113:async fn conditionally_approved_queues_amendments_and_proceeds() {\n2118:    let pid = create_standard_project(base_dir, \"conditional-review\");\n2123:            conditionally_approved_payload(&[\"tighten the acceptance note\", \"add one QA case\"]),\n2147:    // Non-late-stage ConditionallyApproved does not queue amendments (SC-CR-005).\n2150:        \"non-late-stage ConditionallyApproved should not queue amendments\"\n2166:async fn late_stage_conditionally_approved_triggers_completion_round_advancement() {\n2173:    // CompletionPanel returns conditionally_approved on first call, approved on second.\n2180:                    conditionally_approved_payload(&[\"tighten the acceptance note\"]),\n2207:    assert_eq!(snapshot.completion_rounds, 2, \"should be completion round 2\");\n2231:    assert_eq!(round_events.len(), 1, \"should have one completion_round_advanced event\");\n2296:        \"no completion_round_advanced event should exist on rejection\"\n2332:    assert_eq!(snapshot.completion_rounds, 1, \"should complete in round 1\");\n2345:async fn late_stage_request_changes_triggers_completion_round_like_conditional() {\n2385:    assert_eq!(snapshot.completion_rounds, 2);\n2397:async fn cycle_advanced_emitted_when_entering_implementation_from_completion_round() {\n2409:                    conditionally_approved_payload(&[\"minor fix\"]),\n2434:    // Should have completion_round_advanced followed by cycle_advanced.\n2447:        \"cycle_advanced should be emitted when entering implementation from completion round\"\n2457:    // so `run resume` can pick it up.\n2462:    let pid = create_standard_project(base_dir, \"guard-resume\");\n2465:    let amendments_dir = base_dir.join(\".ralph-burning/projects/guard-resume/amendments\");\n2471:        \"source_completion_round\": 1,\n2519:        \"active_run must be None so resume can pick it up\"\n2536:    let resume_result = engine::resume_standard_run(\n2551:        resume_result.is_ok(),\n2552:        \"resume should succeed with orphaned amendments reconciled: {resume_result:?}\"\n2555:    let resumed_snapshot = FsRunSnapshotStore\n2558:    assert_eq!(resumed_snapshot.status, RunStatus::Completed);\n2572:        \"amendment files should be drained after successful resume\"\n2579:async fn final_review_conditionally_approved_triggers_completion_round_advancement() {\n2580:    // When final_review returns conditionally_approved, the engine should queue amendments,\n2593:                    conditionally_approved_payload(&[\"tighten final wording\"]),\n2620:    assert_eq!(snapshot.completion_rounds, 2, \"should advance to completion round 2\");\n2647:    assert_eq!(round_events.len(), 1, \"should have one completion_round_advanced event\");\n2671:async fn final_review_request_changes_triggers_completion_round_advancement() {\n2673:    // completion-round path as conditionally_approved.\n2712:    assert_eq!(snapshot.completion_rounds, 2);\n","exit_code":0,"status":"completed"}}
