ics};\n    37\t\n    38\t/// Compatibility wrapper for the legacy standard-flow helper.\n    39\tpub fn standard_stage_plan(prompt_review_enabled: bool) -> Vec<StageId> {\n    40\t    stage_plan_for_flow(FlowPreset::Standard, prompt_review_enabled)\n    41\t}\n    42\t\n    43\t/// Deterministic stage-to-role mapping per spec.\n    44\tpub fn role_for_stage(stage_id: StageId) -> BackendRole {\n    45\t    BackendRole::for_stage(stage_id)\n    46\t}\n    47\t\n    48\t/// Resolved target per stage for preflight.\n    49\tpub struct StagePlan {\n    50\t    pub stage_id: StageId,\n    51\t    pub role: BackendRole,\n    52\t    pub contract: contracts::StageContract,\n    53\t    pub target: ResolvedBackendTarget,\n    54\t}\n    55\t\n    56\t/// Resolve all stage targets ahead of execution for preflight validation.\n    57\tpub fn resolve_stage_plan(\n    58\t    stages: &[StageId],\n    59\t    resolver: &crate::contexts::agent_execution::service::BackendResolver,\n    60\t    workspace_defaults: Option<&BackendSelectionConfig>,\n    61\t) -> AppResult<Vec<StagePlan>> {\n    62\t    let mut plan = Vec::with_capacity(stages.len());\n    63\t    for &stage_id in stages {\n    64\t        let role = role_for_stage(stage_id);\n    65\t        let contract = contracts::contract_for_stage(stage_id);\n    66\t        let target = resolver.resolve(role, None, None, workspace_defaults)?;\n    67\t        plan.push(StagePlan {\n    68\t            stage_id,\n    69\t            role,\n    70\t            contract,\n    71\t            target,\n    72\t        });\n    73\t    }\n    74\t    Ok(plan)\n    75\t}\n    76\t\n    77\t/// Preflight: check capability and availability for every stage target.\n    78\tpub async fn preflight_check<A: AgentExecutionPort>(\n    79\t    adapter: &A,\n    80\t    plan: &[StagePlan],\n    81\t) -> AppResult<()> {\n    82\t    for entry in plan {\n    83\t        adapter\n    84\t            .check_capability(&entry.target, &entry.contract)\n    85\t            .await\n    86\t            .map_err(|e| AppError::PreflightFailed {\n    87\t                stage_id: entry.stage_id,\n    88\t                details: e.to_string(),\n    89\t            })?;\n    90\t        adapter\n    91\t            .check_availability(&entry.target)\n    92\t            .await\n    93\t            .map_err(|e| AppError::PreflightFailed {\n    94\t                stage_id: entry.stage_id,\n    95\t                details: e.to_string(),\n    96\t            })?;\n    97\t    }\n    98\t    Ok(())\n    99\t}\n   100\t\n   101\t/// Generate a new run ID from a timestamp.\n   102\tfn generate_run_id() -> AppResult<RunId> {\n   103\t    let now = Utc::now();\n   104\t    RunId::new(format!(\"run-{}\", now.format(\"%Y%m%d%H%M%S\")))\n   105\t}\n   106\t\n   107\t#[derive(Debug, Clone, Copy)]\n   108\tenum ExecutionOrigin {\n   109\t    Start,\n   110\t    Resume,\n   111\t}\n   112\t\n   113\timpl ExecutionOrigin {\n   114\t    fn error(self, reason: String) -> AppError {\n   115\t        match self {\n   116\t            Self::Start => AppError::RunStartFailed { reason },\n   117\t            Self::Resume => AppError::ResumeFailed { reason },\n   118\t        }\n   119\t    }\n   120\t}\n   121\t\n   122\t#[derive(Debug, Clone, Copy, PartialEq, Eq)]\n   123\tenum RunOutcome {\n   124\t    Completed,\n   125\t    Paused,\n   126\t}\n   127\t\n   128\t#[derive(Debug)]\n   129\tstruct ResumeState {\n   130\t    run_id: RunId,\n   131\t    started_at: DateTime<Utc>,\n   132\t    stage_index: usize,\n   133\t    cursor: StageCursor,\n   134\t}\n   135\t\n   136\t#[allow(clippy::too_many_arguments)]\n   137\tpub async fn execute_run<A, R, S>(\n   138\t    agent_service: &AgentExecutionService<A, R, S>,\n   139\t    run_snapshot_read: &dyn RunSnapshotPort,\n   140\t    run_snapshot_write: &dyn RunSnapshotWritePort,\n   141\t    journal_store: &dyn JournalStorePort,\n   142\t    artifact_write: &dyn PayloadArtifactWritePort,\n   143\t    log_write: &dyn RuntimeLogWritePort,\n   144\t    amendment_queue_port: &dyn AmendmentQueuePort,\n   145\t    base_dir: &Path,\n   146\t    project_id: &ProjectId,\n   147\t    preset: FlowPreset,\n   148\t    effective_config: &EffectiveConfig,\n   149\t) -> AppResult<()>\n   150\twhere\n   151\t    A: AgentExecutionPort,\n   152\t    R: RawOutputPort,\n   153\t    S: SessionStorePort,\n   154\t{\n   155\t    execute_run_with_retry(\n   156\t        agent_service,\n   157\t        run_snapshot_read,\n   158\t        run_snapshot_write,\n   159\t        journal_store,\n   160\t        artifact_write,\n   161\t        log_write,\n   162\t        amendment_queue_port,\n   163\t        base_dir,\n   164\t        project_id,\n   165\t        preset,\n   166\t        effective_config,\n   167\t        &RetryPolicy::default_policy(),\n   168\t        CancellationToken::new(),\n   169\t    )\n   170\t    .await\n   171\t}\n   172\t\n   173\t#[allow(clippy::too_many_arguments)]\n   174\tpub async fn execute_run_with_retry<A, R, S>(\n   175\t    agent_service: &AgentExecutionService<A, R, S>,\n   176\t    run_snapshot_read: &dyn RunSnapshotPort,\n   177\t    run_snapshot_write: &dyn RunSnapshotWritePort,\n   178\t    journal_store: &dyn JournalStorePort,\n   179\t    artifact_write: &dyn PayloadArtifactWritePort,\n   180\t    log_write: &dyn RuntimeLogWritePort,\n   181\t    amendment_queue_port: &dyn AmendmentQueuePort,\n   182\t    base_dir: &Path,\n   183\t    project_id: &ProjectId,\n   184\t    preset: FlowPreset,\n   185\t    effective_config: &EffectiveConfig,\n   186\t    retry_policy: &RetryPolicy,\n   187\t    cancellation_token: CancellationToken,\n   188\t) -> AppResult<()>\n   189\twhere\n   190\t    A: AgentExecutionPort,\n   191\t    R: RawOutputPort,\n   192\t    S: SessionStorePort,\n   193\t{\n   194\t    let snapshot = run_snapshot_read.read_run_snapshot(base_dir, project_id)?;\n   195\t\n   196\t    match snapshot.status {\n   197\t        RunStatus::NotStarted => {}\n   198\t        RunStatus::Failed | RunStatus::Paused => {\n   199\t            return Err(AppError::RunStartFailed {\n   200\t                reason: format!(\n   201\t                    \"project snapshot status is '{}'; use `ralph-burning run resume`\",\n   202\t                    snapshot.status\n   203\t                ),\n   204\t            });\n   205\t        }\n   206\t        status => {\n   207\t            return Err(AppError::RunStartFailed {\n   208\t                reason: format!(\n   209\t                    \"project snapshot status is '{}'; run start requires 'not_started'\",\n   210\t                    status\n   211\t                ),\n   212\t            });\n   213\t        }\n   214\t    }\n   215\t    if snapshot.has_active_run() {\n   216\t        return Err(AppError::RunStartFailed {\n   217\t            reason: \"project already has an active run\".to_owned(),\n   218\t        });\n   219\t    }\n   220\t\n   221\t    let stage_ids = stage_plan_for_flow(preset, effective_config.prompt_review_enabled());\n   222\t    let semantics = flow_semantics(preset);\n   223\t    let workspace_defaults = BackendSelectionConfig::from_effective_config(effective_config)?;\n   224\t    let stage_plan = resolve_stage_plan(\n   225\t        stage_ids.as_slice(),\n   226\t        agent_service.resolver(),\n   227\t        Some(&workspace_defaults),\n   228\t    )?;\n   229\t    preflight_check(agent_service.adapter(), &stage_plan).await?;\n   230\t\n   231\t    let run_id = generate_run_id()?;\n   232\t    let now = Utc::now();\n   233\t    let events = journal_store.read_journal(base_dir, project_id)?;\n   234\t    let mut seq = journal::last_sequence(&events);\n   235\t    let first_stage = stage_plan[0].stage_id;\n   236\t    let initial_cursor = StageCursor::initial(first_stage);\n   237\t    let mut current_snapshot = RunSnapshot {\n   238\t        active_run: Some(ActiveRun {\n   239\t            run_id: run_id.as_str().to_ow