{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_015kQrWRQpDeX3gMtgx6fXuZ","type":"tool_result","content":"     1→use chrono::{DateTime, Utc};\n     2→use serde::{Deserialize, Serialize};\n     3→\n     4→use crate::shared::domain::{FlowPreset, ProjectId, StageCursor, StageId};\n     5→\n     6→/// Immutable project metadata persisted in `project.toml`.\n     7→#[derive(Debug, Clone, PartialEq, Serialize, Deserialize)]\n     8→pub struct ProjectRecord {\n     9→    pub id: ProjectId,\n    10→    pub name: String,\n    11→    pub flow: FlowPreset,\n    12→    pub prompt_reference: String,\n    13→    pub prompt_hash: String,\n    14→    pub created_at: DateTime<Utc>,\n    15→    pub status_summary: ProjectStatusSummary,\n    16→}\n    17→\n    18→#[derive(Debug, Clone, Copy, PartialEq, Eq, Serialize, Deserialize)]\n    19→#[serde(rename_all = \"snake_case\")]\n    20→pub enum ProjectStatusSummary {\n    21→    Created,\n    22→    Active,\n    23→    Completed,\n    24→    Failed,\n    25→}\n    26→\n    27→/// Canonical run state persisted in `run.json`.\n    28→/// This is the single source of truth for run progression - never inferred from artifacts.\n    29→#[derive(Debug, Clone, PartialEq, Serialize, Deserialize)]\n    30→pub struct RunSnapshot {\n    31→    pub active_run: Option<ActiveRun>,\n    32→    pub status: RunStatus,\n    33→    pub cycle_history: Vec<CycleHistoryEntry>,\n    34→    pub completion_rounds: u32,\n    35→    pub rollback_point_meta: RollbackPointMeta,\n    36→    pub amendment_queue: AmendmentQueueState,\n    37→    pub status_summary: String,\n    38→}\n    39→\n    40→impl RunSnapshot {\n    41→    pub fn initial() -> Self {\n    42→        Self {\n    43→            active_run: None,\n    44→            status: RunStatus::NotStarted,\n    45→            cycle_history: Vec::new(),\n    46→            completion_rounds: 0,\n    47→            rollback_point_meta: RollbackPointMeta::default(),\n    48→            amendment_queue: AmendmentQueueState::default(),\n    49→            status_summary: \"not started\".to_owned(),\n    50→        }\n    51→    }\n    52→\n    53→    pub fn has_active_run(&self) -> bool {\n    54→        self.active_run.is_some()\n    55→    }\n    56→\n    57→    /// Semantic validation of run snapshot consistency.\n    58→    /// Returns `Err` with a description if status and active_run are inconsistent.\n    59→    pub fn validate_semantics(&self) -> Result<(), String> {\n    60→        match (&self.status, &self.active_run) {\n    61→            // Running requires an active run cursor.\n    62→            (RunStatus::Running, None) => Err(\n    63→                \"status is 'running' but active_run is null — inconsistent canonical state\"\n    64→                    .to_owned(),\n    65→            ),\n    66→            (RunStatus::Paused, Some(_)) => Err(\n    67→                \"status is 'paused' but active_run is present — inconsistent canonical state\"\n    68→                    .to_owned(),\n    69→            ),\n    70→            // All non-running states must not retain an active run cursor.\n    71→            (RunStatus::NotStarted, Some(_)) => Err(\n    72→                \"status is 'not_started' but active_run is present — inconsistent canonical state\"\n    73→                    .to_owned(),\n    74→            ),\n    75→            (RunStatus::Completed, Some(_)) => Err(\n    76→                \"status is 'completed' but active_run is present — inconsistent canonical state\"\n    77→                    .to_owned(),\n    78→            ),\n    79→            (RunStatus::Failed, Some(_)) => Err(\n    80→                \"status is 'failed' but active_run is present — inconsistent canonical state\"\n    81→                    .to_owned(),\n    82→            ),\n    83→            // Valid combinations:\n    84→            // NotStarted/Paused/Completed/Failed + None, Running + Some\n    85→            _ => Ok(()),\n    86→        }\n    87→    }\n    88→}\n    89→\n    90→#[derive(Debug, Clone, PartialEq, Serialize, Deserialize)]\n    91→pub struct ActiveRun {\n    92→    pub run_id: String,\n    93→    pub stage_cursor: StageCursor,\n    94→    pub started_at: DateTime<Utc>,\n    95→}\n    96→\n    97→#[derive(Debug, Clone, Copy, PartialEq, Eq, Serialize, Deserialize)]\n    98→#[serde(rename_all = \"snake_case\")]\n    99→pub enum RunStatus {\n   100→    NotStarted,\n   101→    Running,\n   102→    Paused,\n   103→    Completed,\n   104→    Failed,\n   105→}\n   106→\n   107→impl RunStatus {\n   108→    /// Human-readable status string for CLI output.\n   109→    pub fn display_str(self) -> &'static str {\n   110→        match self {\n   111→            Self::NotStarted => \"not started\",\n   112→            Self::Running => \"running\",\n   113→            Self::Paused => \"paused\",\n   114→            Self::Completed => \"completed\",\n   115→            Self::Failed => \"failed\",\n   116→        }\n   117→    }\n   118→}\n   119→\n   120→impl std::fmt::Display for RunStatus {\n   121→    fn fmt(&self, f: &mut std::fmt::Formatter<'_>) -> std::fmt::Result {\n   122→        f.write_str(self.display_str())\n   123→    }\n   124→}\n   125→\n   126→/// A single entry in the cycle history tracking progression through work cycles.\n   127→#[derive(Debug, Clone, PartialEq, Serialize, Deserialize)]\n   128→pub struct CycleHistoryEntry {\n   129→    pub cycle: u32,\n   130→    pub stage_id: StageId,\n   131→    pub started_at: DateTime<Utc>,\n   132→    pub completed_at: Option<DateTime<Utc>>,\n   133→}\n   134→\n   135→/// Rollback-point metadata tracked in the canonical run snapshot.\n   136→#[derive(Debug, Clone, Default, PartialEq, Serialize, Deserialize)]\n   137→pub struct RollbackPointMeta {\n   138→    pub last_rollback_id: Option<String>,\n   139→    pub rollback_count: u32,\n   140→}\n   141→\n   142→/// A typed queued amendment record for durable persistence.\n   143→#[derive(Debug, Clone, PartialEq, Serialize, Deserialize)]\n   144→pub struct QueuedAmendment {\n   145→    pub amendment_id: String,\n   146→    pub source_stage: StageId,\n   147→    pub source_cycle: u32,\n   148→    pub source_completion_round: u32,\n   149→    pub body: String,\n   150→    pub created_at: DateTime<Utc>,\n   151→    /// Stable ordering key within a batch. Amendments created in the same batch\n   152→    /// share a `created_at` timestamp; `batch_sequence` distinguishes their order.\n   153→    #[serde(default)]\n   154→    pub batch_sequence: u32,\n   155→}\n   156→\n   157→/// Amendment queue state tracked in the canonical run snapshot.\n   158→#[derive(Debug, Clone, Default, PartialEq, Serialize, Deserialize)]\n   159→pub struct AmendmentQueueState {\n   160→    pub pending: Vec<QueuedAmendment>,\n   161→    pub processed_count: u32,\n   162→    /// Snapshot-only follow-ups captured from conditional approvals on flows\n   163→    /// that do not use durable completion-round amendments.\n   164→    #[serde(default, skip_serializing_if = \"Vec::is_empty\")]\n   165→    pub recorded_follow_ups: Vec<QueuedAmendment>,\n   166→}\n   167→\n   168→/// A single journal event stored in `journal.ndjson`.\n   169→#[derive(Debug, Clone, PartialEq, Serialize, Deserialize)]\n   170→pub struct JournalEvent {\n   171→    pub sequence: u64,\n   172→    pub timestamp: DateTime<Utc>,\n   173→    pub event_type: JournalEventType,\n   174→    pub details: serde_json::Value,\n   175→}\n   176→\n   177→#[derive(Debug, Clone, PartialEq, Eq, Serialize, Deserialize)]\n   178→#[serde(rename_all = \"snake_case\")]\n   179→pub enum JournalEventType {\n   180→    ProjectCreated,\n   181→    RunStarted,\n   182→    RunResumed,\n   183→    StageEntered,\n   184→    StageFailed,\n   185→    StageCompleted,\n   186→    CycleAdvanced,\n   187→    CompletionRoundAdvanced,\n   188→    RunCompleted,\n   189→    RunFailed,\n   190→    RollbackCreated,\n   191→    AmendmentQueued,\n   192→}\n   193→\n   194→/// A durable history payload record stored in `history/payloads/`.\n   195→#[derive(Debug, Clone, PartialEq, Serialize, Deserialize)]\n   196→pub struct PayloadRecord {\n   197→    pub payload_id: String,\n   198→    pub stage_id: StageId,\n   199→    pub cycle: u32,\n   200→    pub attempt: u32,\n   201→    pub created_at: DateTime<Utc>,\n   202→    pub payload: serde_json::Value,\n   203→}\n   204→\n   205→/// A durable history artifact record stored in `history/artifacts/`.\n   206→#[derive(Debug, Clone, PartialEq, Serialize, Deserialize)]\n   207→pub struct ArtifactRecord {\n   208→    pub artifact_id: String,\n   209→    pub payload_id: String,\n   210→    pub stage_id: StageId,\n   211→    pub created_at: DateTime<Utc>,\n   212→    pub content: String,\n   213→}\n   214→\n   215→/// A runtime log entry stored in `runtime/logs/`.\n   216→#[derive(Debug, Clone, PartialEq, Serialize, Deserialize)]\n   217→pub struct RuntimeLogEntry {\n   218→    pub timestamp: DateTime<Utc>,\n   219→    pub level: LogLevel,\n   220→    pub source: String,\n   221→    pub message: String,\n   222→}\n   223→\n   224→#[derive(Debug, Clone, Copy, PartialEq, Eq, Serialize, Deserialize)]\n   225→#[serde(rename_all = \"snake_case\")]\n   226→pub enum LogLevel {\n   227→    Debug,\n   228→    Info,\n   229→    Warn,\n   230→    Error,\n   231→}\n   232→\n   233→/// Rollback metadata stored in `rollback/`.\n   234→#[derive(Debug, Clone, PartialEq, Serialize, Deserialize)]\n   235→pub struct RollbackPoint {\n   236→    pub rollback_id: String,\n   237→    pub created_at: DateTime<Utc>,\n   238→    pub stage_id: StageId,\n   239→    pub cycle: u32,\n   240→    pub run_snapshot: RunSnapshot,\n   241→}\n   242→\n   243→/// Empty session store for `sessions.json`.\n   244→#[derive(Debug, Clone, PartialEq, Serialize, Deserialize)]\n   245→pub struct SessionStore {\n   246→    pub sessions: Vec<serde_json::Value>,\n   247→}\n   248→\n   249→impl SessionStore {\n   250→    pub fn empty() -> Self {\n   251→        Self {\n   252→            sessions: Vec::new(),\n   253→        }\n   254→    }\n   255→}\n   256→\n   257→/// Summary of a failed stage for run snapshot persistence.\n   258→#[derive(Debug, Clone, PartialEq, Serialize, Deserialize)]\n   259→pub struct FailedStageSummary {\n   260→    pub stage_id: StageId,\n   261→    pub cycle: u32,\n   262→    pub attempt: u32,\n   263→    pub failure_class: String,\n   264→    pub message: String,\n   265→    pub failed_at: DateTime<Utc>,\n   266→}\n   267→\n   268→/// Summary used in `project list` output.\n   269→#[derive(Debug, Clone)]\n   270→pub struct ProjectListEntry {\n   271→    pub id: ProjectId,\n   272→    pub name: String,\n   273→    pub flow: FlowPreset,\n   274→    pub status_summary: ProjectStatusSummary,\n   275→    pub created_at: DateTime<Utc>,\n   276→    pub is_active: bool,\n   277→}\n   278→\n   279→/// Detailed project view used in `project show` output.\n   280→#[derive(Debug, Clone)]\n   281→pub struct ProjectDetail {\n   282→    pub record: ProjectRecord,\n   283→    pub run_snapshot: RunSnapshot,\n   284→    pub journal_event_count: u64,\n   285→    pub rollback_count: usize,\n   286→    pub is_active: bool,\n   287→}\n   288→"}]},"parent_tool_use_id":"toolu_0172JmZWncG6Pf7nVUtxXudN","session_id":"ac8d6a2a-5f6d-4606-9741-7014e6740f51","uuid":"8fac3d1c-e0b0-4c08-9671-01699d60a6d8"}
