{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013FxX6ZL5s7AC2XgJaaC59D","type":"tool_result","content":"     1→#![forbid(unsafe_code)]\n     2→\n     3→//! Structured contracts for requirements stages.\n     4→//!\n     5→//! Follows the same invariant as workflow stage contracts:\n     6→//! 1. Schema validation (JSON → typed payload via serde)\n     7→//! 2. Domain validation (semantic rules)\n     8→//! 3. Rendering (deterministic Markdown artifact)\n     9→//!\n    10→//! Rendered Markdown is never parsed for control flow.\n    11→\n    12→use crate::shared::domain::FlowPreset;\n    13→use crate::shared::error::ContractError;\n    14→\n    15→use super::model::{\n    16→    ProjectSeedPayload, QuestionSetPayload, RequirementsDraftPayload,\n    17→    RequirementsReviewOutcome, RequirementsReviewPayload, RequirementsStageId,\n    18→};\n    19→use super::renderers;\n    20→\n    21→/// A validated requirements contract output.\n    22→#[derive(Debug, Clone, PartialEq, Eq)]\n    23→pub struct RequirementsValidatedBundle {\n    24→    pub payload: RequirementsPayload,\n    25→    pub artifact: String,\n    26→}\n    27→\n    28→/// Typed requirements payload wrapper.\n    29→#[derive(Debug, Clone, PartialEq, Eq)]\n    30→pub enum RequirementsPayload {\n    31→    QuestionSet(QuestionSetPayload),\n    32→    Draft(RequirementsDraftPayload),\n    33→    Review(RequirementsReviewPayload),\n    34→    Seed(ProjectSeedPayload),\n    35→}\n    36→\n    37→/// Requirements contract binding a stage to its validation and rendering.\n    38→#[derive(Debug, Clone, Copy, PartialEq, Eq)]\n    39→pub struct RequirementsContract {\n    40→    pub stage_id: RequirementsStageId,\n    41→}\n    42→\n    43→impl RequirementsContract {\n    44→    pub fn question_set() -> Self {\n    45→        Self {\n    46→            stage_id: RequirementsStageId::QuestionSet,\n    47→        }\n    48→    }\n    49→\n    50→    pub fn draft() -> Self {\n    51→        Self {\n    52→            stage_id: RequirementsStageId::RequirementsDraft,\n    53→        }\n    54→    }\n    55→\n    56→    pub fn review() -> Self {\n    57→        Self {\n    58→            stage_id: RequirementsStageId::RequirementsReview,\n    59→        }\n    60→    }\n    61→\n    62→    pub fn seed() -> Self {\n    63→        Self {\n    64→            stage_id: RequirementsStageId::ProjectSeed,\n    65→        }\n    66→    }\n    67→\n    68→    /// Evaluate a raw JSON value through schema → domain → render.\n    69→    pub fn evaluate(\n    70→        &self,\n    71→        raw_json: &serde_json::Value,\n    72→    ) -> Result<RequirementsValidatedBundle, ContractError> {\n    73→        let payload = self.validate_schema(raw_json)?;\n    74→        self.validate_semantics(&payload)?;\n    75→        let artifact = self.render(&payload);\n    76→        Ok(RequirementsValidatedBundle { payload, artifact })\n    77→    }\n    78→\n    79→    fn validate_schema(\n    80→        &self,"}]},"parent_tool_use_id":"toolu_0172JmZWncG6Pf7nVUtxXudN","session_id":"ac8d6a2a-5f6d-4606-9741-7014e6740f51","uuid":"3827a22b-ab80-428e-b19b-8c084bd98404"}
