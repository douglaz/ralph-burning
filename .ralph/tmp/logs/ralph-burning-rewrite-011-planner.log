andard\",\n   313→            Self::QuickDev => \"quick_dev\",\n   314→            Self::DocsChange => \"docs_change\",\n   315→            Self::CiImprovement => \"ci_improvement\",\n   316→        }\n   317→    }\n   318→\n   319→    pub fn description(self) -> &'static str {\n   320→        match self {\n   321→            Self::Standard => {\n   322→                \"Full delivery flow with planning, implementation, QA, review, and acceptance.\"\n   323→            }\n   324→            Self::QuickDev => \"Fast delivery flow for small code changes with lightweight review.\",\n   325→            Self::DocsChange => {\n   326→                \"Documentation-focused flow for planning, content updates, and validation.\"\n   327→            }\n   328→            Self::CiImprovement => {\n   329→                \"CI improvement flow for automation planning, updates, and validation.\"\n   330→            }\n   331→        }\n   332→    }\n   333→}\n   334→\n   335→impl fmt::Display for FlowPreset {\n   336→    fn fmt(&self, f: &mut fmt::Formatter<'_>) -> fmt::Result {\n   337→        f.write_str(self.as_str())\n   338→    }\n   339→}\n   340→\n   341→impl FromStr for FlowPreset {\n   342→    type Err = AppError;\n   343→\n   344→    fn from_str(value: &str) -> Result<Self, Self::Err> {\n   345→        match value {\n   346→            \"standard\" => Ok(Self::Standard),\n   347→            \"quick_dev\" => Ok(Self::QuickDev),\n   348→            \"docs_change\" => Ok(Self::DocsChange),\n   349→            \"ci_improvement\" => Ok(Self::CiImprovement),\n   350→            _ => Err(AppError::InvalidFlowPreset {\n   351→                flow_id: value.to_owned(),\n   352→            }),\n   353→        }\n   354→    }\n   355→}\n   356→\n   357→#[derive(Debug, Clone, Copy, PartialEq, Eq, Hash, Serialize, Deserialize)]\n   358→#[serde(rename_all = \"snake_case\")]\n   359→pub enum StageId {\n   360→    PromptReview,\n   361→    Planning,\n   362→    Implementation,\n   363→