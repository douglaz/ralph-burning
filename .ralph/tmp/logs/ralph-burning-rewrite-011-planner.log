BackendFamily, model_id: impl Into<String>) -> Self {\n   162→        let model_id = model_id.into();\n   163→        let display_name = format!(\"{} {}\", backend_family.display_name(), model_id);\n   164→        let supports_session_reuse = !matches!(backend_family, BackendFamily::OpenRouter);\n   165→        Self {\n   166→            backend_family,\n   167→            model_id,\n   168→            display_name,\n   169→            capabilities: CapabilityMetadata::for_all_stages(supports_session_reuse, true),\n   170→        }\n   171→    }\n   172→\n   173→    pub fn default_for_backend(backend_family: BackendFamily) -> Self {\n   174→        Self::new(backend_family, backend_family.default_model_id())\n   175→    }\n   176→}\n   177→\n   178→impl fmt::Display for ModelSpec {\n   179→    fn fmt(&self, f: &mut fmt::Formatter<'_>) -> fmt::Result {\n   180→        f.write_str(&self.display_name)\n   181→    }\n   182→}\n   183→\n   184→#[derive(Debug, Clone, PartialEq, Eq, Serialize, Deserialize)]\n   185→pub struct ResolvedBackendTarget {\n   186→    pub backend: BackendSpec,\n   187→    pub model: ModelSpec,\n   188→}\n   189→\n   190→impl ResolvedBackendTarget {\n   191→    pub fn new(backend_family: BackendFamily, model_id: impl Into<String>) -> Self {\n   192→        Self {\n   193→            backend: BackendSpec::from_family(backend_family),\n   194→            model: ModelSpec::new(backend_family, model_id),\n   195→        }\n   196→    }\n   197→\n   198→    pub fn supports_stage(&self, stage_id: StageId) -> bool {\n   199→        self.backend.capabilities.supports_stage(stage_id)\n   200→            && self.model.capabilities.supports_stage(stage_id)\n   201→    }\n   202→\n   203→    pub fn supports_session_reuse(&self) -> bool {\n   204→        self.backend.capabilities.supports_session_reuse\n   205→            && self.model.capabilities.supports_session_reuse\n   206→    }\n   207→}\n   208→\n   209→#[derive(Debug, Clone, Copy, PartialEq, Eq, Hash, Serialize, Deserialize)]\n   210→#[serde(rename_all = \"snake_case\")]\n   211→pub enum BackendRole {\n   212→    Planner,\n   213→    Implementer,\n   214→    Reviewer,\n   215→    QaValidator,\n   216→    CompletionJudge,\n   217→}\n   218→\n   219→impl BackendRole {\n   220→    pub fn as_str(self) -> &'static str {\n   221→        match self {\n   222→            Self::Planner => \"planner\",\n   223→            Self::Implementer => \"implementer\",\n   224→            Self::Reviewer => \"reviewer\",\n   225→            Self::QaValidator => \"qa_validator\",\n   226→            Self::CompletionJudge => \"completion_judge\",\n   227→        }\n   228→    }\n   229→\n   230→    pub fn display_name(self) -> &'static str {\n   231→        match self {\n   232→            Self::Planner => \"Planner\",\n   233→            Self::Implementer => \"Implementer\",\n   234→            Self::Reviewer => \"Reviewer\",\n   235→            Self::QaValidator => \"QA Validator\",\n   236→            Self::CompletionJudge => \"Completion Judge\",\n   237→        }\n   238→    }\n   239→\n   240→    pub fn default_target(self) -> ResolvedBackendTarget {\n   241→        match self {\n   242→            Self::Planner => ResolvedBackendTarget::new(BackendFamily::Claude, \"opus-4.1\"),\n   243→            Self::Implementer => ResolvedBackendTarget::new(BackendFamily::Codex, \"gpt-5-codex\"),\n   244→            Self::Reviewer => ResolvedBackendTarget::new(BackendFamily::Claude, \"sonnet-4.0\"),\n   245→            Self::QaValidator => {\n   246→                ResolvedBackendTarget::new(BackendFamily::OpenRouter, \"openai/gpt-5\")\n   247→            }\n   248→            Self::CompletionJudge => ResolvedBackendTarget::new(BackendFamily::Claude, \"opus-4.1\"),\n   249→        }\n   250→    }\n   251→\n   252→    pub fn allows_session_reuse(self) -> bool {\n   253→        matches!(self, Self::Implementer | Self::Reviewer | Self::QaValidator)\n   254→    }\n   255→\n   256→    pub fn for