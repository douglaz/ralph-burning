{"type":"item.completed","item":{"id":"item_15","type":"command_execution","command":"/run/current-system/sw/bin/bash -lc \"nl -ba ralph-burning-rewrite/src/contexts/project_run_record/queries.rs | sed -n '120,240p'\"","aggregated_output":"   120\t        }\n   121\t    }\n   122\t    // Check orphaned payloads (payload without matching artifact)\n   123\t    for payload in payloads {\n   124\t        if !artifacts.iter().any(|a| a.payload_id == payload.payload_id) {\n   125\t            return Err(crate::shared::error::AppError::CorruptRecord {\n   126\t                file: format!(\"history/payloads/{}\", payload.payload_id),\n   127\t                details: \"payload has no matching artifact\".to_owned(),\n   128\t            });\n   129\t        }\n   130\t    }\n   131\t    Ok(())\n   132\t}\n   133\t\n   134\t/// Apply logical rollback boundaries to an append-only journal.\n   135\t///\n   136\t/// Each `rollback_performed` event rewinds the visible event stream back to the\n   137\t/// referenced durable boundary, then becomes the new branch point for\n   138\t/// subsequent events.\n   139\tpub fn visible_journal_events(events: &[JournalEvent]) -> AppResult<Vec<JournalEvent>> {\n   140\t    let mut visible: Vec<JournalEvent> = Vec::with_capacity(events.len());\n   141\t\n   142\t    for event in events {\n   143\t        if event.event_type == super::model::JournalEventType::RollbackPerformed {\n   144\t            let visible_through_sequence = rollback_boundary_sequence(event)?;\n   145\t            visible.retain(|prior| prior.sequence <= visible_through_sequence);\n   146\t        }\n   147\t        visible.push(event.clone());\n   148\t    }\n   149\t\n   150\t    Ok(visible)\n   151\t}\n   152\t\n   153\t/// Filter payload/artifact history to the records reachable from the visible\n   154\t/// journal branch after applying rollback boundaries.\n   155\tpub fn filter_history_records(\n   156\t    events: &[JournalEvent],\n   157\t    payloads: Vec<PayloadRecord>,\n   158\t    artifacts: Vec<ArtifactRecord>,\n   159\t) -> AppResult<(Vec<PayloadRecord>, Vec<ArtifactRecord>)> {\n   160\t    let mut visible_payload_ids = HashSet::new();\n   161\t    let mut visible_artifact_ids = HashSet::new();\n   162\t\n   163\t    for event in events {\n   164\t        if event.event_type != super::model::JournalEventType::StageCompleted {\n   165\t            continue;\n   166\t        }\n   167\t\n   168\t        visible_payload_ids.insert(detail_string(event, \"payload_id\")?.to_owned());\n   169\t        visible_artifact_ids.insert(detail_string(event, \"artifact_id\")?.to_owned());\n   170\t    }\n   171\t\n   172\t    let mut visible_payloads: Vec<_> = payloads\n   173\t        .into_iter()\n   174\t        .filter(|payload| visible_payload_ids.contains(payload.payload_id.as_str()))\n   175\t        .collect();\n   176\t    let mut visible_artifacts: Vec<_> = artifacts\n   177\t        .into_iter()\n   178\t        .filter(|artifact| {\n   179\t            visible_artifact_ids.contains(artifact.artifact_id.as_str())\n   180\t                && visible_payload_ids.contains(artifact.payload_id.as_str())\n   181\t        })\n   182\t        .collect();\n   183\t\n   184\t    visible_payloads.sort_by_key(|record| record.created_at);\n   185\t    visible_artifacts.sort_by_key(|record| record.created_at);\n   186\t\n   187\t    Ok((visible_payloads, visible_artifacts))\n   188\t}\n   189\t\n   190\tfn rollback_boundary_sequence(event: &JournalEvent) -> AppResult<u64> {\n   191\t    event.details.get(\"visible_through_sequence\").and_then(|value| {\n   192\t        value.as_u64()\n   193\t    }).ok_or_else(|| crate::shared::error::AppError::CorruptRecord {\n   194\t        file: \"journal.ndjson\".to_owned(),\n   195\t        details: format!(\n   196\t            \"rollback_performed event sequence {} is missing 'visible_through_sequence'\",\n   197\t            event.sequence\n   198\t        ),\n   199\t    })\n   200\t}\n   201\t\n   202\tfn detail_string<'a>(event: &'a JournalEvent, key: &str) -> AppResult<&'a str> {\n   203\t    event\n   204\t        .details\n   205\t        .get(key)\n   206\t        .and_then(|value| value.as_str())\n   207\t        .ok_or_else(|| crate::shared::error::AppError::CorruptRecord {\n   208\t            file: \"journal.ndjson\".to_owned(),\n   209\t            details: format!(\n   210\t                \"event sequence {} is missing string field '{}'\",\n   211\t                event.sequence, key\n   212\t            ),\n   213\t        })\n   214\t}\n","exit_code":0,"status":"completed"}}
{"type":"item.completed","item":{"id":"item_16","type":"command_execution","command":"/run/current-system/sw/bin/bash -lc \"nl -ba ralph-burning-rewrite/src/contexts/project_run_record/service.rs | sed -n '90,680p'\"","aggregated_output":"    90\t        project_id: &ProjectId,\n    91\t        snapshot: &RunSnapshot,\n    92\t    ) -> AppResult<()>;\n    93\t}\n    94\t\n    95\t/// Port for durable rollback point persistence.\n    96\tpub trait RollbackPointStorePort {\n    97\t    fn write_rollback_point(\n    98\t        &self,\n    99\t        base_dir: &Path,\n   100\t        project_id: &ProjectId,\n   101\t        rollback_point: &RollbackPoint,\n   102\t    ) -> AppResult<()>;\n   103\t\n   104\t    fn list_rollback_points(\n   105\t        &self,\n   106\t        base_dir: &Path,\n   107\t        project_id: &ProjectId,\n   108\t    ) -> AppResult<Vec<RollbackPoint>>;\n   109\t\n   110\t    fn read_rollback_point_by_stage(\n   111\t        &self,\n   112\t        base_dir: &Path,\n   113\t        project_id: &ProjectId,\n   114\t        stage_id: StageId,\n   115\t    ) -> AppResult<Option<RollbackPoint>>;\n   116\t}\n   117\t\n   118\t/// Port for repository reset operations during hard rollback.\n   119\tpub trait RepositoryResetPort {\n   120\t    fn reset_to_sha(&self, repo_root: &Path, sha: &str) -> AppResult<()>;\n   121\t}\n   122\t\n   123\t/// Port for writing payload and artifact records atomically as a pair.\n   124\tpub trait PayloadArtifactWritePort {\n   125\t    fn write_payload_artifact_pair(\n   126\t        &self,\n   127\t        base_dir: &Path,\n   128\t        project_id: &ProjectId,\n   129\t        payload: &PayloadRecord,\n   130\t        artifact: &ArtifactRecord,\n   131\t    ) -> AppResult<()>;\n   132\t\n   133\t    /// Remove a previously written payload/artifact pair.\n   134\t    /// Used to roll back a stage commit when journal or snapshot persistence\n   135\t    /// fails after the pair was already written.\n   136\t    fn remove_payload_artifact_pair(\n   137\t        &self,\n   138\t        base_dir: &Path,\n   139\t        project_id: &ProjectId,\n   140\t        payload_id: &str,\n   141\t        artifact_id: &str,\n   142\t    ) -> AppResult<()>;\n   143\t}\n   144\t\n   145\t/// Port for appending runtime log entries (best-effort, not durable history).\n   146\tpub trait RuntimeLogWritePort {\n   147\t    fn append_runtime_log(\n   148\t        &self,\n   149\t        base_dir: &Path,\n   150\t        project_id: &ProjectId,\n   151\t        entry: &RuntimeLogEntry,\n   152\t    ) -> AppResult<()>;\n   153\t}\n   154\t\n   155\t/// Port for durable amendment queue persistence under `projects/<id>/amendments/`.\n   156\tpub trait AmendmentQueuePort {\n   157\t    /// Write a single amendment file atomically.\n   158\t    fn write_amendment(\n   159\t        &self,\n   160\t        base_dir: &Path,\n   161\t        project_id: &ProjectId,\n   162\t        amendment: &super::model::QueuedAmendment,\n   163\t    ) -> AppResult<()>;\n   164\t\n   165\t    /// List all pending amendment files from disk.\n   166\t    fn list_pending_amendments(\n   167\t        &self,\n   168\t        base_dir: &Path,\n   169\t        project_id: &ProjectId,\n   170\t    ) -> AppResult<Vec<super::model::QueuedAmendment>>;\n   171\t\n   172\t    /// Remove a single amendment file by ID.\n   173\t    fn remove_amendment(\n   174\t        &self,\n   175\t        base_dir: &Path,\n   176\t        project_id: &ProjectId,\n   177\t        amendment_id: &str,\n   178\t    ) -> AppResult<()>;\n   179\t\n   180\t    /// Remove all pending amendment files. Returns count removed.\n   181\t    fn drain_amendments(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<u32>;\n   182\t\n   183\t    /// Check if any amendment files exist on disk.\n   184\t    fn has_pending_amendments(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<bool>;\n   185\t}\n   186\t\n   187\t/// Port for reading/writing/clearing the active project pointer.\n   188\tpub trait ActiveProjectPort {\n   189\t    fn read_active_project_id(&self, base_dir: &Path) -> AppResult<Option<String>>;\n   190\t    fn clear_active_project(&self, base_dir: &Path) -> AppResult<()>;\n   191\t    fn write_active_project(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<()>;\n   192\t}\n   193\t\n   194\t/// Input for the `project create` use case.\n   195\tpub struct CreateProjectInput {\n   196\t    pub id: ProjectId,\n   197\t    pub name: String,\n   198\t    pub flow: FlowPreset,\n   199\t    pub prompt_path: String,\n   200\t    pub prompt_contents: String,\n   201\t    pub prompt_hash: String,\n   202\t    pub created_at: DateTime<Utc>,\n   203\t}\n   204\t\n   205\t/// Create a new project with all canonical files.\n   206\tpub fn create_project(\n   207\t    store: &dyn ProjectStorePort,\n   208\t    journal_store: &dyn JournalStorePort,\n   209\t    base_dir: &Path,\n   210\t    input: CreateProjectInput,\n   211\t) -> AppResult<ProjectRecord> {\n   212\t    // Check for duplicate project ID\n   213\t    if store.project_exists(base_dir, &input.id)? {\n   214\t        return Err(AppError::DuplicateProject {\n   215\t            project_id: input.id.to_string(),\n   216\t        });\n   217\t    }\n   218\t\n   219\t    let record = ProjectRecord {\n   220\t        id: input.id.clone(),\n   221\t        name: input.name,\n   222\t        flow: input.flow,\n   223\t        prompt_reference: \"prompt.md\".to_owned(),\n   224\t        prompt_hash: input.prompt_hash,\n   225\t        created_at: input.created_at,\n   226\t        status_summary: ProjectStatusSummary::Created,\n   227\t    };\n   228\t\n   229\t    let run_snapshot = RunSnapshot::initial();\n   230\t    let sessions = SessionStore::empty();\n   231\t\n   232\t    // Create the initial journal event\n   233\t    let initial_event = JournalEvent {\n   234\t        sequence: 1,\n   235\t        timestamp: input.created_at,\n   236\t        event_type: JournalEventType::ProjectCreated,\n   237\t        details: serde_json::json!({\n   238\t            \"project_id\": record.id.as_str(),\n   239\t            \"flow\": record.flow.as_str(),\n   240\t        }),\n   241\t    };\n   242\t    let journal_line = journal::serialize_event(&initial_event)?;\n   243\t\n   244\t    // Atomic creation: all files or nothing\n   245\t    store.create_project_atomic(\n   246\t        base_dir,\n   247\t        &record,\n   248\t        &input.prompt_contents,\n   249\t        &run_snapshot,\n   250\t        &journal_line,\n   251\t        &sessions,\n   252\t    )?;\n   253\t\n   254\t    // create_project_atomic writes the journal as part of the atomic init,\n   255\t    // but we don't call journal_store.append_event here because the atomic\n   256\t    // creation already wrote the initial journal line. The journal_store\n   257\t    // parameter is kept for interface consistency and future use.\n   258\t    let _ = journal_store;\n   259\t\n   260\t    Ok(record)\n   261\t}\n   262\t\n   263\t/// List all projects with summary data.\n   264\tpub fn list_projects(\n   265\t    store: &dyn ProjectStorePort,\n   266\t    active_port: &dyn ActiveProjectPort,\n   267\t    base_dir: &Path,\n   268\t) -> AppResult<Vec<ProjectListEntry>> {\n   269\t    let active_id = active_port.read_active_project_id(base_dir)?;\n   270\t    let project_ids = store.list_project_ids(base_dir)?;\n   271\t\n   272\t    let mut entries = Vec::new();\n   273\t    for pid in project_ids {\n   274\t        let record = store.read_project_record(base_dir, &pid)?;\n   275\t        let is_active = active_id.as_deref() == Some(pid.as_str());\n   276\t        entries.push(ProjectListEntry {\n   277\t            id: record.id,\n   278\t            name: record.name,\n   279\t            flow: record.flow,\n   280\t            status_summary: record.status_summary,\n   281\t            created_at: record.created_at,\n   282\t            is_active,\n   283\t        });\n   284\t    }\n   285\t\n   286\t    Ok(entries)\n   287\t}\n   288\t\n   289\t/// Show detailed project information.\n   290\tpub fn show_project(\n   291\t    store: &dyn ProjectStorePort,\n   292\t    run_port: &dyn RunSnapshotPort,\n   293\t    journal_port: &dyn JournalStorePort,\n   294\t    active_port: &dyn ActiveProjectPort,\n   295\t    base_dir: &Path,\n   296\t    project_id: &ProjectId,\n   297\t) -> AppResult<ProjectDetail> {\n   298\t    if !store.project_exists(base_dir, project_id)? {\n   299\t        return Err(AppError::ProjectNotFound {\n   300\t            project_id: project_id.to_string(),\n   301\t        });\n   302\t    }\n   303\t\n   304\t    let record = store.read_project_record(base_dir, project_id)?;\n   305\t    let run_snapshot = run_port.read_run_snapshot(base_dir, project_id)?;\n   306\t    let events = journal_port.read_journal(base_dir, project_id)?;\n   307\t    let journal_event_count = events.len() as u64;\n   308\t    let active_id = active_port.read_active_project_id(base_dir)?;\n   309\t    let is_active = active_id.as_deref() == Some(project_id.as_str());\n   310\t\n   311\t    // Count rollback points from journal events\n   312\t    let rollback_count = events\n   313\t        .iter()\n   314\t        .filter(|e| e.event_type == JournalEventType::RollbackCreated)\n   315\t        .count();\n   316\t\n   317\t    Ok(ProjectDetail {\n   318\t        record,\n   319\t        run_snapshot,\n   320\t        journal_event_count,\n   321\t        rollback_count,\n   322\t        is_active,\n   323\t    })\n   324\t}\n   325\t\n   326\t/// Delete a project. Fails if project has an active run.\n   327\t/// Clears active-project pointer if it pointed to the deleted project.\n   328\t///\n   329\t/// Transactional: if any post-validation step fails, the project remains\n   330\t/// addressable at its canonical path and the active-project pointer is\n   331\t/// unchanged.\n   332\tpub fn delete_project(\n   333\t    store: &dyn ProjectStorePort,\n   334\t    run_port: &dyn RunSnapshotPort,\n   335\t    active_port: &dyn ActiveProjectPort,\n   336\t    base_dir: &Path,\n   337\t    project_id: &ProjectId,\n   338\t) -> AppResult<()> {\n   339\t    if !store.project_exists(base_dir, project_id)? {\n   340\t        return Err(AppError::ProjectNotFound {\n   341\t            project_id: project_id.to_string(),\n   342\t        });\n   343\t    }\n   344\t\n   345\t    // Check for active run\n   346\t    let run_snapshot = run_port.read_run_snapshot(base_dir, project_id)?;\n   347\t    if run_snapshot.has_active_run() {\n   348\t        return Err(AppError::ActiveRunDelete {\n   349\t            project_id: project_id.to_string(),\n   350\t        });\n   351\t    }\n   352\t\n   353\t    // Check if this is the active project (before delete)\n   354\t    let active_id = active_port.read_active_project_id(base_dir)?;\n   355\t    let was_active = active_id.as_deref() == Some(project_id.as_str());\n   356\t\n   357\t    // Phase 1: Stage the delete — project becomes invisible to list/show\n   358\t    // but data remains on disk for rollback.\n   359\t    store.stage_delete(base_dir, project_id)?;\n   360\t\n   361\t    // Phase 2: Clear the active-project pointer if needed.\n   362\t    // If this fails, roll back the staged delete so the project remains\n   363\t    // addressable and the pointer is unchanged.\n   364\t    if was_active {\n   365\t        if let Err(clear_err) = active_port.clear_active_project(base_dir) {\n   366\t            store\n   367\t                .rollback_delete(base_dir, project_id)\n   368\t                .map_err(|restore_err| AppError::CorruptRecord {\n   369\t                    file: format!(\"projects/{}\", project_id),\n   370\t                    details: format!(\n   371\t                        \"delete partially failed: pointer clear error: {}, restore error: {}\",\n   372\t                        clear_err, restore_err\n   373\t                    ),\n   374\t                })?;\n   375\t            return Err(clear_err);\n   376\t        }\n   377\t    }\n   378\t\n   379\t    // Phase 3: Finalize — permanently remove the project data.\n   380\t    // At this point the logical delete has succeeded (project is invisible,\n   381\t    // pointer is cleared). Best-effort cleanup of the staged data.\n   382\t    let _ = store.commit_delete(base_dir, project_id);\n   383\t\n   384\t    Ok(())\n   385\t}\n   386\t\n   387\t/// Get run status for the active project.\n   388\tpub fn run_status(\n   389\t    run_port: &dyn RunSnapshotPort,\n   390\t    base_dir: &Path,\n   391\t    project_id: &ProjectId,\n   392\t) -> AppResult<RunStatusView> {\n   393\t    let snapshot = run_port.read_run_snapshot(base_dir, project_id)?;\n   394\t    Ok(queries::build_status_view(project_id.as_str(), &snapshot))\n   395\t}\n   396\t\n   397\t/// Get run history (durable only, no runtime logs).\n   398\tpub fn run_history(\n   399\t    journal_port: &dyn JournalStorePort,\n   400\t    artifact_port: &dyn ArtifactStorePort,\n   401\t    base_dir: &Path,\n   402\t    project_id: &ProjectId,\n   403\t) -> AppResult<RunHistoryView> {\n   404\t    let events = queries::visible_journal_events(&journal_port.read_journal(base_dir, project_id)?)?;\n   405\t    let (payloads, artifacts) = queries::filter_history_records(\n   406\t        &events,\n   407\t        artifact_port.list_payloads(base_dir, project_id)?,\n   408\t        artifact_port.list_artifacts(base_dir, project_id)?,\n   409\t    )?;\n   410\t\n   411\t    queries::validate_history_consistency(&payloads, &artifacts)?;\n   412\t\n   413\t    Ok(queries::build_history_view(\n   414\t        project_id.as_str(),\n   415\t        events,\n   416\t        payloads,\n   417\t        artifacts,\n   418\t    ))\n   419\t}\n   420\t\n   421\t/// Get run tail: durable history by default, with optional runtime logs.\n   422\tpub fn run_tail(\n   423\t    journal_port: &dyn JournalStorePort,\n   424\t    artifact_port: &dyn ArtifactStorePort,\n   425\t    log_port: &dyn RuntimeLogStorePort,\n   426\t    base_dir: &Path,\n   427\t    project_id: &ProjectId,\n   428\t    include_logs: bool,\n   429\t) -> AppResult<RunTailView> {\n   430\t    let events = queries::visible_journal_events(&journal_port.read_journal(base_dir, project_id)?)?;\n   431\t    let (payloads, artifacts) = queries::filter_history_records(\n   432\t        &events,\n   433\t        artifact_port.list_payloads(base_dir, project_id)?,\n   434\t        artifact_port.list_artifacts(base_dir, project_id)?,\n   435\t    )?;\n   436\t\n   437\t    queries::validate_history_consistency(&payloads, &artifacts)?;\n   438\t\n   439\t    let runtime_logs = if include_logs {\n   440\t        log_port.read_runtime_logs(base_dir, project_id)?\n   441\t    } else {\n   442\t        Vec::new()\n   443\t    };\n   444\t\n   445\t    Ok(queries::build_tail_view(\n   446\t        project_id.as_str(),\n   447\t        events,\n   448\t        payloads,\n   449\t        artifacts,\n   450\t        include_logs,\n   451\t        runtime_logs,\n   452\t    ))\n   453\t}\n   454\t\n   455\t/// List visible rollback points for the current logical history branch.\n   456\tpub fn list_rollback_points(\n   457\t    rollback_store: &dyn RollbackPointStorePort,\n   458\t    journal_port: &dyn JournalStorePort,\n   459\t    base_dir: &Path,\n   460\t    project_id: &ProjectId,\n   461\t) -> AppResult<Vec<RollbackPoint>> {\n   462\t    let events = queries::visible_journal_events(&journal_port.read_journal(base_dir, project_id)?)?;\n   463\t    let visible_ids = visible_rollback_ids(&events);\n   464\t    let mut points = rollback_store\n   465\t        .list_rollback_points(base_dir, project_id)?\n   466\t        .into_iter()\n   467\t        .filter(|point| visible_ids.contains(point.rollback_id.as_str()))\n   468\t        .collect::<Vec<_>>();\n   469\t    points.sort_by_key(|point| point.created_at);\n   470\t    Ok(points)\n   471\t}\n   472\t\n   473\t/// Look up the latest visible rollback point for a stage.\n   474\tpub fn get_rollback_point_for_stage(\n   475\t    rollback_store: &dyn RollbackPointStorePort,\n   476\t    journal_port: &dyn JournalStorePort,\n   477\t    base_dir: &Path,\n   478\t    project_id: &ProjectId,\n   479\t    stage_id: StageId,\n   480\t) -> AppResult<Option<RollbackPoint>> {\n   481\t    let visible_events =\n   482\t        queries::visible_journal_events(&journal_port.read_journal(base_dir, project_id)?)?;\n   483\t    let visible_ids = visible_rollback_ids(&visible_events);\n   484\t\n   485\t    Ok(rollback_store\n   486\t        .list_rollback_points(base_dir, project_id)?\n   487\t        .into_iter()\n   488\t        .filter(|point| point.stage_id == stage_id)\n   489\t        .filter(|point| visible_ids.contains(point.rollback_id.as_str()))\n   490\t        .max_by_key(|point| point.created_at))\n   491\t}\n   492\t\n   493\t/// Perform a logical or hard rollback to a visible checkpoint.\n   494\t#[allow(clippy::too_many_arguments)]\n   495\tpub fn perform_rollback(\n   496\t    run_port: &dyn RunSnapshotPort,\n   497\t    run_write_port: &dyn RunSnapshotWritePort,\n   498\t    journal_port: &dyn JournalStorePort,\n   499\t    rollback_store: &dyn RollbackPointStorePort,\n   500\t    reset_port: Option<&dyn RepositoryResetPort>,\n   501\t    base_dir: &Path,\n   502\t    project_id: &ProjectId,\n   503\t    flow: FlowPreset,\n   504\t    target_stage: StageId,\n   505\t    hard: bool,\n   506\t) -> AppResult<RollbackPoint> {\n   507\t    let current_snapshot = run_port.read_run_snapshot(base_dir, project_id)?;\n   508\t    match current_snapshot.status {\n   509\t        RunStatus::Failed | RunStatus::Paused => {}\n   510\t        status => {\n   511\t            return Err(AppError::RollbackInvalidStatus {\n   512\t                project_id: project_id.to_string(),\n   513\t                status: status.to_string(),\n   514\t            });\n   515\t        }\n   516\t    }\n   517\t\n   518\t    if !flow_stage_membership(flow, target_stage) {\n   519\t        return Err(AppError::RollbackStageNotInFlow {\n   520\t            project_id: project_id.to_string(),\n   521\t            stage_id: target_stage.to_string(),\n   522\t            flow: flow.to_string(),\n   523\t        });\n   524\t    }\n   525\t\n   526\t    let rollback_point = get_rollback_point_for_stage(\n   527\t        rollback_store,\n   528\t        journal_port,\n   529\t        base_dir,\n   530\t        project_id,\n   531\t        target_stage,\n   532\t    )?\n   533\t    .ok_or_else(|| AppError::RollbackPointNotFound {\n   534\t        project_id: project_id.to_string(),\n   535\t        stage_id: target_stage.to_string(),\n   536\t    })?;\n   537\t\n   538\t    let events = journal_port.read_journal(base_dir, project_id)?;\n   539\t    let visible_through_sequence =\n   540\t        rollback_created_sequence_for(&events, rollback_point.rollback_id.as_str())?;\n   541\t\n   542\t    let mut restored_snapshot = rollback_point.run_snapshot.clone();\n   543\t    restored_snapshot.status = RunStatus::Paused;\n   544\t    restored_snapshot.active_run = None;\n   545\t    restored_snapshot.rollback_point_meta.rollback_count =\n   546\t        current_snapshot.rollback_point_meta.rollback_count + 1;\n   547\t    restored_snapshot.rollback_point_meta.last_rollback_id =\n   548\t        Some(rollback_point.rollback_id.clone());\n   549\t    restored_snapshot.status_summary = format!(\n   550\t        \"paused after rollback to {} (cycle {}); run `ralph-burning run resume` to continue\",\n   551\t        rollback_point.stage_id.display_name(),\n   552\t        rollback_point.cycle\n   553\t    );\n   554\t\n   555\t    run_write_port.write_run_snapshot(base_dir, project_id, &restored_snapshot)?;\n   556\t\n   557\t    let sequence = journal::last_sequence(&events) + 1;\n   558\t    let rollback_event = journal::rollback_performed_event(\n   559\t        sequence,\n   560\t        Utc::now(),\n   561\t        rollback_point.rollback_id.as_str(),\n   562\t        rollback_point.stage_id,\n   563\t        rollback_point.cycle,\n   564\t        visible_through_sequence,\n   565\t        hard,\n   566\t        rollback_point.git_sha.as_deref(),\n   567\t        restored_snapshot.rollback_point_meta.rollback_count,\n   568\t    );\n   569\t    let rollback_line = journal::serialize_event(&rollback_event)?;\n   570\t    journal_port.append_event(base_dir, project_id, &rollback_line)?;\n   571\t\n   572\t    if hard {\n   573\t        let git_sha = rollback_point.git_sha.as_deref().ok_or_else(|| {\n   574\t            AppError::RollbackGitResetFailed {\n   575\t                project_id: project_id.to_string(),\n   576\t                rollback_id: rollback_point.rollback_id.clone(),\n   577\t                details: \"rollback point does not record a git commit SHA\".to_owned(),\n   578\t            }\n   579\t        })?;\n   580\t\n   581\t        let reset_port = reset_port.ok_or_else(|| AppError::RollbackGitResetFailed {\n   582\t            project_id: project_id.to_string(),\n   583\t            rollback_id: rollback_point.rollback_id.clone(),\n   584\t            details: \"no repository reset adapter was provided\".to_owned(),\n   585\t        })?;\n   586\t\n   587\t        if let Err(error) = reset_port.reset_to_sha(base_dir, git_sha) {\n   588\t            return Err(AppError::RollbackGitResetFailed {\n   589\t                project_id: project_id.to_string(),\n   590\t                rollback_id: rollback_point.rollback_id.clone(),\n   591\t                details: error.to_string(),\n   592\t            });\n   593\t        }\n   594\t    }\n   595\t\n   596\t    Ok(rollback_point)\n   597\t}\n   598\t\n   599\tfn flow_stage_membership(flow: FlowPreset, stage_id: StageId) -> bool {\n   600\t    workflow_composition::flow_definition(flow)\n   601\t        .stages\n   602\t        .contains(&stage_id)\n   603\t}\n   604\t\n   605\tfn visible_rollback_ids(events: &[JournalEvent]) -> std::collections::HashSet<&str> {\n   606\t    events\n   607\t        .iter()\n   608\t        .filter(|event| event.event_type == JournalEventType::RollbackCreated)\n   609\t        .filter_map(|event| {\n   610\t            event.details.get(\"rollback_id\").and_then(|value| value.as_str())\n   611\t        })\n   612\t        .collect()\n   613\t}\n   614\t\n   615\tfn rollback_created_sequence_for(events: &[JournalEvent], rollback_id: &str) -> AppResult<u64> {\n   616\t    events\n   617\t        .iter()\n   618\t        .find(|event| {\n   619\t            event.event_type == JournalEventType::RollbackCreated\n   620\t                && event\n   621\t                    .details\n   622\t                    .get(\"rollback_id\")\n   623\t                    .and_then(|value| value.as_str())\n   624\t                    == Some(rollback_id)\n   625\t        })\n   626\t        .map(|event| event.sequence)\n   627\t        .ok_or_else(|| AppError::CorruptRecord {\n   628\t            file: \"journal.ndjson\".to_owned(),\n   629\t            details: format!(\n   630\t                \"missing rollback_created event for rollback point '{}'\",\n   631\t                rollback_id\n   632\t            ),\n   633\t        })\n   634\t}\n","exit_code":0,"status":"completed"}}
