ase\")]\n   179\tpub enum JournalEventType {\n   180\t    ProjectCreated,\n   181\t    RunStarted,\n   182\t    RunResumed,\n   183\t    StageEntered,\n   184\t    StageFailed,\n   185\t    StageCompleted,\n   186\t    CycleAdvanced,\n   187\t    CompletionRoundAdvanced,\n   188\t    RunCompleted,\n   189\t    RunFailed,\n   190\t    RollbackCreated,\n   191\t    RollbackPerformed,\n   192\t    AmendmentQueued,\n   193\t}\n   194\t\n   195\t/// A durable history payload record stored in `history/payloads/`.\n   196\t#[derive(Debug, Clone, PartialEq, Serialize, Deserialize)]\n   197\tpub struct PayloadRecord {\n   198\t    pub payload_id: String,\n   199\t    pub stage_id: StageId,\n   200\t    pub cycle: u32,\n   201\t    pub attempt: u32,\n   202\t    pub created_at: DateTime<Utc>,\n   203\t    pub payload: serde_json::Value,\n   204\t}\n   205\t\n   206\t/// A durable history artifact record stored in `history/artifacts/`.\n   207\t#[derive(Debug, Clone, PartialEq, Serialize, Deserialize)]\n   208\tpub struct ArtifactRecord {\n   209\t    pub artifact_id: String,\n   210\t    pub payload_id: String,\n   211\t    pub stage_id: StageId,\n   212\t    pub created_at: DateTime<Utc>,\n   213\t    pub content: String,\n   214\t}\n   215\t\n   216\t/// A runtime log entry stored in `runtime/logs/`.\n   217\t#[derive(Debug, Clone, PartialEq, Serialize, Deserialize)]\n   218\tpub struct RuntimeLogEntry {\n   219\t    pub timestamp: DateTime<Utc>,\n   220\t    pub level: LogLevel,\n","exit_code":0,"status":"completed"}}
