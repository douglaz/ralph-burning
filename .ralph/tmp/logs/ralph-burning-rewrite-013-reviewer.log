70\t    stage_id: StageId,\n  2071\t    run_id: &RunId,\n  2072\t    seq: &mut u64,\n  2073\t    snapshot: &mut RunSnapshot,\n  2074\t    journal_store: &dyn JournalStorePort,\n  2075\t    run_snapshot_write: &dyn RunSnapshotWritePort,\n  2076\t    base_dir: &Path,\n  2077\t    project_id: &ProjectId,\n  2078\t    origin: ExecutionOrigin,\n  2079\t) -> AppResult<T> {\n  2080\t    if snapshot.status == RunStatus::Completed {\n  2081\t        return Err(origin.error(format!(\n  2082\t            \"stage {} checkpoint failed after completion: {}\",\n  2083\t            stage_id.as_str(),\n  2084\t            error\n  2085\t        )));\n  2086\t    }\n  2087\t\n  2088\t    fail_run_result(\n  2089\t        &error,\n  2090\t        stage_id,\n  2091\t        run_id,\n  2092\t        seq,\n  2093\t        snapshot,\n  2094\t        journal_store,\n  2095\t        run_snapshot_write,\n  2096\t        base_dir,\n  2097\t        project_id,\n  2098\t        origin,\n  2099\t    )\n  2100\t    .await\n  2101\t}\n  2102\t\n  2103\tfn failure_label(error: &AppError) -> String {\n  2104\t    if let Some(failure_class) = error.failure_class() {\n  2105\t        return failure_class.as_str().to_owned();\n  2106\t    }\n  2107\t\n  2108\t    match error {\n  2109\t        AppError::RemediationExhausted { .. } => \"remediation_exhausted\".to_owned(),\n  2110\t        AppError::ResumeFailed { .. } => \"resume_failed\".to_owned(),\n  2111\t        _ => \"unknown\".to_owned(),\n  2112\t    }\n  2113\t}\n  2114\t\n  2115\tfn prompt_review_requires_pause(payload: &StagePayload) -> bool {\n  2116\t    matches!(\n  2117\t        payload,\n  2118\t        StagePayload::Planning(planning) if !planning.readiness.ready\n","exit_code":0,"status":"completed"}}
