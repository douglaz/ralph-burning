imestamp: DateTime<Utc>,\n   333\t    rollback_id: &str,\n   334\t    stage_id: StageId,\n   335\t    cycle: u32,\n   336\t    visible_through_sequence: u64,\n   337\t    hard: bool,\n   338\t    git_sha: Option<&str>,\n   339\t    rollback_count: u32,\n   340\t) -> JournalEvent {\n   341\t    let mut details = serde_json::json!({\n   342\t        \"rollback_id\": rollback_id,\n   343\t        \"stage_id\": stage_id.as_str(),\n   344\t        \"cycle\": cycle,\n   345\t        \"visible_through_sequence\": visible_through_sequence,\n   346\t        \"hard\": hard,\n   347\t        \"rollback_count\": rollback_count,\n   348\t    });\n   349\t\n   350\t    if let Some(git_sha) = git_sha {\n   351\t        details[\"git_sha\"] = serde_json::json!(git_sha);\n   352\t    }\n   353\t\n   354\t    JournalEvent {\n   355\t        sequence,\n   356\t        timestamp,\n   357\t        event_type: JournalEventType::RollbackPerformed,\n   358\t        details,\n   359\t    }\n   360\t}\n   361\t\n   362\t/// Build a `run_failed` journal event.\n   363\tpub fn run_failed_event(\n   364\t    sequence: u64,\n   365\t    timestamp: DateTime<Utc>,\n   366\t    run_id: &RunId,\n   367\t    stage_id: StageId,\n   368\t    failure_class: &str,\n   369\t    message: &str,\n   370\t) -> JournalEvent {\n   371\t    JournalEvent {\n   372\t        sequence,\n   373\t        timestamp,\n   374\t        event_type: JournalEventType::RunFailed,\n   375\t        details: serde_json::json!({\n   376\t            \"run_id\": run_id.as_str(),\n   377\t            \"stage_id\": stage_id.as_str(),\n   378\t            \"failure_class\": failure_class,\n   379\t            \"message\": message,\n   380\t        }),\n","exit_code":0,"status":"completed"}}
