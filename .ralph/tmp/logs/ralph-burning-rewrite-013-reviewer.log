d => {\n   547\t            return Err(AppError::ResumeFailed {\n   548\t                reason: \"project is already completed; there is nothing to resume\".to_owned(),\n   549\t            });\n   550\t        }\n   551\t    }\n   552\t    if snapshot.has_active_run() {\n   553\t        return Err(AppError::ResumeFailed {\n   554\t            reason: \"failed or paused snapshots must not retain an active run\".to_owned(),\n   555\t        });\n   556\t    }\n   557\t\n   558\t    let events = journal_store.read_journal(base_dir, project_id)?;\n   559\t    let visible_events = queries::visible_journal_events(&events).map_err(|error| {\n   560\t        AppError::ResumeFailed {\n   561\t            reason: error.to_string(),\n   562\t        }\n   563\t    })?;\n   564\t    let stage_ids = stage_plan_for_resume(preset, &visible_events, effective_config)?;\n   565\t    let semantics = flow_semantics(preset);\n   566\t    let workspace_defaults = BackendSelectionConfig::from_effective_config(effective_config)?;\n   567\t    let stage_plan = resolve_stage_plan(\n   568\t        stage_ids.as_slice(),\n   569\t        agent_service.resolver(),\n   570\t        Some(&workspace_defaults),\n   571\t    )?;\n   572\t    // Reconcile amendments from disk into snapshot before deriving resume state.\n   573\t    reconcile_amendments_from_disk(&mut snapshot, amendment_queue_port, base_dir, project_id)?;\n   574\t\n   575\t    let resume_state = derive_resume_state(&visible_events, &snapshot, &stage_plan, semantics)?;\n   576\t    let execution_context = derive_resume_execution_context(\n   577\t        artifact_store,\n   578\t        base_dir,\n   579\t        project_id,\n   580\t        &resume_state.cursor,\n   581\t        &visible_events,\n   582\t        semantics,\n   583\t    )?;\n   584\t\n   585\t    preflight_check(\n   586\t        agent_service.adapter(),\n   587\t        &stage_plan[resume_state.stage_index..],\n   588\t    )\n   589\t    .await\n   590\t    .map_err(|error| AppError::ResumeFailed {\n   591\t        reason: error.to_string(),\n   592\t    })?;\n   593\t\n   594\t    let mut seq = journal::last_sequence(&events);\n   595\t    snapshot.status = RunStatus::Running;\n   596\t    snapshot.active_run = Some(ActiveRun {\n   597\t        run_id: resume_state.run_id.as_str().to_owned(),\n   598\t        stage_cursor: resume_state.cursor.clone(),\n   599\t        started_at: resume_state.started_at,\n   600\t    });\n   601\t    snapshot.completion_rounds = snapshot\n   602\t        .completion_rounds\n   603\t        .max(resume_state.cursor.completion_round);\n   604\t    snapshot.status_summary = format!(\"running: {}\", resume_state.cursor.stage.display_name());\n   605\t    run_snapshot_write.write_run_snapshot(base_dir, project_id, &snapshot)?;\n   606\t\n   607\t    seq += 1;\n   608\t    let run_resumed = journal::run_resumed_event(\n   609\t        seq,\n   610\t        Utc::now(),\n   611\t        &resume_state.run_id,\n   612\t        resume_state.cursor.stage,\n   613\t        resume_state.cursor.cycle,\n   614\t    );\n   615\t    let run_resumed_line = journal::serialize_event(&run_resumed)?;\n   616\t    if let Err(error) = journal_store.append_event(base_dir, project_id, &run_resumed_line) {\n   617\t        seq -= 1;\n   618\t        return fail_run(\n   619\t            &AppError::ResumeFailed {\n   620\t                reason: format!(\"failed to persist run_resumed event: {}\", error),\n   621\t            },\n   622\t            resume_state.cursor.stage,\n   623\t            &resume_state.run_id,\n   624\t            &mut seq,\n   625\t            &mut snapshot,\n   626\t            journal_store,\n   627\t            run_snapshot_write,\n   628\t            base_dir,\n   629\t            project_id,\n   630\t            ExecutionOrigin::Resume,\n   631\t        )\n   632\t        .await;\n   633\t    }\n   634\t\n   635\t    execute_run_internal(\n   636\t        agent_service,\n   637\t        run_snapshot_write,\n   638\t        journal_store,\n   639\t        artifact_write,\n   640\t        log_write,\n   641\t        amendment_queue_port,\n   642\t        rollback_store,\n   643\t        base_dir,\n   644\t        project_id,\n   645\t        &resume_state.run_id,\n   646\t        &mut seq,\n   647\t        &mut snapshot,\n   648\t        semantics,\n   649\t        &stage_plan,\n   650\t        resume_state.stage_index,\n","exit_code":0,"status":"completed"}}
