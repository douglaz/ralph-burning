del for `run history`: durable history only (journal + payloads + artifacts).\n    42\t/// Runtime logs never appear here.\n    43\t#[derive(Debug, Clone)]\n    44\tpub struct RunHistoryView {\n    45\t    pub project_id: String,\n    46\t    pub events: Vec<JournalEvent>,\n    47\t    pub payloads: Vec<PayloadRecord>,\n    48\t    pub artifacts: Vec<ArtifactRecord>,\n    49\t}\n    50\t\n    51\t/// Read model for `run tail`: durable history by default, with optional runtime logs.\n    52\t#[derive(Debug, Clone)]\n    53\tpub struct RunTailView {\n    54\t    pub project_id: String,\n    55\t    pub events: Vec<JournalEvent>,\n    56\t    pub payloads: Vec<PayloadRecord>,\n    57\t    pub artifacts: Vec<ArtifactRecord>,\n    58\t    pub runtime_logs: Option<Vec<RuntimeLogEntry>>,\n    59\t}\n    60\t\n    61\t/// Build a status view from canonical run state.\n    62\tpub fn build_status_view(project_id: &str, snapshot: &RunSnapshot) -> RunStatusView {\n    63\t    RunStatusView::from_snapshot(project_id, snapshot)\n    64\t}\n    65\t\n    66\t/// Build a history view from durable records only. No runtime logs.\n    67\tpub fn build_history_view(\n    68\t    project_id: &str,\n    69\t    events: Vec<JournalEvent>,\n    70\t    payloads: Vec<PayloadRecord>,\n    71\t    artifacts: Vec<ArtifactRecord>,\n    72\t) -> RunHistoryView {\n    73\t    RunHistoryView {\n    74\t        project_id: project_id.to_owned(),\n    75\t        events,\n    76\t        payloads,\n    77\t        artifacts,\n    78\t    }\n    79\t}\n    80\t\n    81\t/// Build a tail view: durable history always, runtime logs only when requested.\n    82\tpub fn build_tail_view(\n    83\t    project_id: &str,\n    84\t    events: Vec<JournalEvent>,\n    85\t    payloads: Vec<PayloadRecord>,\n    86\t    artifacts: Vec<ArtifactRecord>,\n    87\t    include_logs: bool,\n    88\t    runtime_logs: Vec<RuntimeLogEntry>,\n    89\t) -> RunTailView {\n    90\t    RunTailView {\n    91\t        project_id