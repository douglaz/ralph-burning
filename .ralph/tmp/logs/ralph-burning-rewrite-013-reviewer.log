{"type":"item.completed","item":{"id":"item_29","type":"command_execution","command":"/run/current-system/sw/bin/bash -lc \"nl -ba ralph-burning-rewrite/src/contexts/project_run_record/model.rs | sed -n '1,120p'\"","aggregated_output":"     1\tuse chrono::{DateTime, Utc};\n     2\tuse serde::{Deserialize, Serialize};\n     3\t\n     4\tuse crate::shared::domain::{FlowPreset, ProjectId, StageCursor, StageId};\n     5\t\n     6\t/// Immutable project metadata persisted in `project.toml`.\n     7\t#[derive(Debug, Clone, PartialEq, Serialize, Deserialize)]\n     8\tpub struct ProjectRecord {\n     9\t    pub id: ProjectId,\n    10\t    pub name: String,\n    11\t    pub flow: FlowPreset,\n    12\t    pub prompt_reference: String,\n    13\t    pub prompt_hash: String,\n    14\t    pub created_at: DateTime<Utc>,\n    15\t    pub status_summary: ProjectStatusSummary,\n    16\t}\n    17\t\n    18\t#[derive(Debug, Clone, Copy, PartialEq, Eq, Serialize, Deserialize)]\n    19\t#[serde(rename_all = \"snake_case\")]\n    20\tpub enum ProjectStatusSummary {\n    21\t    Created,\n    22\t    Active,\n    23\t    Completed,\n    24\t    Failed,\n    25\t}\n    26\t\n    27\t/// Canonical run state persisted in `run.json`.\n    28\t/// This is the single source of truth for run progression - never inferred from artifacts.\n    29\t#[derive(Debug, Clone, PartialEq, Serialize, Deserialize)]\n    30\tpub struct RunSnapshot {\n    31\t    pub active_run: Option<ActiveRun>,\n    32\t    pub status: RunStatus,\n    33\t    pub cycle_history: Vec<CycleHistoryEntry>,\n    34\t    pub completion_rounds: u32,\n    35\t    pub rollback_point_meta: RollbackPointMeta,\n    36\t    pub amendment_queue: AmendmentQueueState,\n    37\t    pub status_summary: String,\n    38\t}\n    39\t\n    40\timpl RunSnapshot {\n    41\t    pub fn initial() -> Self {\n    42\t        Self {\n    43\t            active_run: None,\n    44\t            status: RunStatus::NotStarted,\n    45\t            cycle_history: Vec::new(),\n    46\t            completion_rounds: 0,\n    47\t            rollback_point_meta: RollbackPointMeta::default(),\n    48\t            amendment_queue: AmendmentQueueState::default(),\n    49\t            status_summary: \"not started\".to_owned(),\n    50\t        }\n    51\t    }\n    52\t\n    53\t    pub fn has_active_run(&self) -> bool {\n    54\t        self.active_run.is_some()\n    55\t    }\n    56\t\n    57\t    /// Semantic validation of run snapshot consistency.\n    58\t    /// Returns `Err` with a description if status and active_run are inconsistent.\n    59\t    pub fn validate_semantics(&self) -> Result<(), String> {\n    60\t        match (&self.status, &self.active_run) {\n    61\t            // Running requires an active run cursor.\n    62\t            (RunStatus::Running, None) => Err(\n    63\t                \"status is 'running' but active_run is null — inconsistent canonical state\"\n    64\t                    .to_owned(),\n    65\t            ),\n    66\t            (RunStatus::Paused, Some(_)) => Err(\n    67\t                \"status is 'paused' but active_run is present — inconsistent canonical state\"\n    68\t                    .to_owned(),\n    69\t            ),\n    70\t            // All non-running states must not retain an active run cursor.\n    71\t            (RunStatus::NotStarted, Some(_)) => Err(\n    72\t                \"status is 'not_started' but active_run is present — inconsistent canonical state\"\n    73\t                    .to_owned(),\n    74\t            ),\n    75\t            (RunStatus::Completed, Some(_)) => Err(\n    76\t                \"status is 'completed' but active_run is present — inconsistent canonical state\"\n    77\t                    .to_owned(),\n    78\t            ),\n    79\t            (RunStatus::Failed, Some(_)) => Err(\n    80\t                \"status is 'failed' but active_run is present — inconsistent canonical state\"\n    81\t                    .to_owned(),\n    82\t            ),\n    83\t            // Valid combinations:\n    84\t            // NotStarted/Paused/Completed/Failed + None, Running + Some\n    85\t            _ => Ok(()),\n    86\t        }\n    87\t    }\n    88\t}\n    89\t\n    90\t#[derive(Debug, Clone, PartialEq, Serialize, Deserialize)]\n    91\tpub struct ActiveRun {\n    92\t    pub run_id: String,\n    93\t    pub stage_cursor: StageCursor,\n    94\t    pub started_at: DateTime<Utc>,\n    95\t}\n    96\t\n    97\t#[derive(Debug, Clone, Copy, PartialEq, Eq, Serialize, Deserialize)]\n    98\t#[serde(rename_all = \"snake_case\")]\n    99\tpub enum RunStatus {\n   100\t    NotStarted,\n   101\t    Running,\n   102\t    Paused,\n   103\t    Completed,\n   104\t    Failed,\n   105\t}\n   106\t\n   107\timpl RunStatus {\n   108\t    /// Human-readable status string for CLI output.\n   109\t    pub fn display_str(self) -> &'static str {\n   110\t        match self {\n   111\t            Self::NotStarted => \"not started\",\n   112\t            Self::Running => \"running\",\n   113\t            Self::Paused => \"paused\",\n   114\t            Self::Completed => \"completed\",\n   115\t            Self::Failed => \"failed\",\n   116\t        }\n   117\t    }\n   118\t}\n   119\t\n   120\timpl std::fmt::Display for RunStatus {\n","exit_code":0,"status":"completed"}}
