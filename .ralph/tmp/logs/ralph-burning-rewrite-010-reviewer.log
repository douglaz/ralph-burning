       return Err(e);\n   451\t        }\n   452\t\n   453\t        run.latest_review_id = Some(review_payload_id.clone());\n   454\t        run.updated_at = Utc::now();\n   455\t        self.store.write_run(base_dir, &run_id, run)?;\n   456\t\n   457\t        let event = journal_event(\n   458\t            seq,\n   459\t            Utc::now(),\n   460\t            RequirementsJournalEventType::ReviewCompleted,\n   461\t            run,\n   462\t        );\n   463\t        self.store\n   464\t            .append_journal_event(base_dir, &run_id, &event)?;\n   465\t        seq += 1;\n   466\t\n   467\t        // Check review outcome\n   468\t        match review_payload.outcome {\n   469\t            RequirementsReviewOutcome::Approved | RequirementsReviewOutcome::ConditionallyApproved => {\n   470\t                // Continue to seed generation\n   471\t            }\n   472\t            RequirementsReviewOutcome::RequestChanges | RequirementsReviewOutcome::Rejected => {\n   473\t                // Fail the run after review payload/artifact are durably committed\n   474\t                let msg = format!(\n   475\t                    \"review outcome: {} — {}\",\n   476\t                    review_payload.outcome,\n   477\t                    review_payload.findings.join(\"; \")\n   478\t                );\n   479\t                self.fail_run(base_dir, run, seq, &msg).await?;\n   480\t                return Err(AppError::InvalidRequirementsState {\n   481\t                    run_id: run_id.clone(),\n   482\t                    details: msg,\n   483\t                });\n   484\t            }\n   485\t        }\n   486\t\n   487\t        // ── Seed ────────────────────────────────────────────────────────\n   488\t        let follow_ups = if review_payload.outcome == RequirementsReviewOutcome::ConditionallyApproved {\n   489\t            review_payload.follow_ups.clone()\n   490\t        } else {\n   491\t            Vec::new()\n   492\t        };\n   493\t\n   494\t        let seed_prompt = format!(\n   495\t            \"Generate a project seed from the following requirements:\\n\\n{}\\n\\nFollow-ups: {}\",\n   496\t            draft_bundle.artifact,\n   497\t            if follow_ups.is_empty() {\n   498\t                \"none\".to_owned()\n   499\t            } else {\n   500\t                follow_ups.join(\"; \")\n   501\t            }\n   502\t        );\n   503\t\n   504\t        let seed_result = self\n   505\t            .invoke_stage(\n   506\t                &run_root,\n   507\t                RequirementsStageId::ProjectSeed,\n   508\t                BackendRole::Planner,\n   509\t                &seed_prompt,\n   510\t            )\n   511\t            .await;\n   512\t\n   513\t        let seed_bundle = match seed_result {\n   514\t            Ok(b) => b,\n   515\t            Err(e) => {\n   516\t                self.fail_run(base_dir, run, seq, &format!(\"seed generation: {e}\"))\n   517\t                    .await?;\n   518\t                return Err(e);\n   519\t            }\n   520\t        };\n   521\t\n   522\t        let RequirementsPayload::Seed(ref seed_payload) = seed_bundle.payload else {\n   523\t            unreachable!();\n   524\t        };\n   525\t\n   526\t        let seed_payload_id = format!(\"{run_id}-seed-1\");\n   527\t        let seed_artifact_id = format!(\"{run_id}-seed-art-1\");\n   528\t        let seed_json = serde_json::to_value(seed_payload)?;\n   529\t\n   530\t        if let Err(e) = self.persist_payload_artifact_pair(\n   531\t            base_dir,\n   532\t            &run_id,\n   533\t            &seed_payload_id,\n   534\t            &seed_json,\n   535\t            &seed_artifact_id,\n   536\t            &seed_bundle.artifact,\n   537\t        ) {\n   538\t            self.fail_run(base_dir, run, seq, &format!(\"seed persistence: {e}\"))\n   539\t                .await?;\n   540\t            return Err(e);\n   541\t        }\n   542\t\n   543\t        // Write seed files