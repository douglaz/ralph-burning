h-burning/ralph-burning-rewrite/src/adapters/fs.rs:29:const JOURNAL_FILE: &str = \"journal.ndjson\";\n/root/new-ralph-burning/ralph-burning-rewrite/src/adapters/fs.rs:30:const SESSIONS_FILE: &str = \"sessions.json\";\n/root/new-ralph-burning/ralph-burning-rewrite/src/adapters/fs.rs:38:    \"runtime/backend\",\n/root/new-ralph-burning/ralph-burning-rewrite/src/adapters/fs.rs:368:            // journal.ndjson (with initial event)\n/root/new-ralph-burning/ralph-burning-rewrite/src/adapters/fs.rs:373:            // sessions.json\n/root/new-ralph-burning/ralph-burning-rewrite/src/adapters/fs.rs:374:            let sessions_json = serde_json::to_string_pretty(sessions)?;\n/root/new-ralph-burning/ralph-burning-rewrite/src/adapters/fs.rs:375:            fs::write(staging_root.join(SESSIONS_FILE), sessions_json)?;\n/root/new-ralph-burning/ralph-burning-rewrite/src/adapters/fs.rs:409:                file: format!(\"projects/{}/journal.ndjson\", project_id),\n/root/new-ralph-burning/ralph-burning-rewrite/src/adapters/fs.rs:599:            .join(\"runtime/backend\")\n/root/new-ralph-burning/ralph-burning-rewrite/src/adapters/fs.rs:711:    fn remove_payload_artifact_pair(\n/root/new-ralph-burning/ralph-burning-rewrite/src/adapters/fs.rs:887:    \"runtime/backend\",\n/root/new-ralph-burning/ralph-burning-rewrite/src/adapters/fs.rs:893:pub struct FsRequirementsStore;\n/root/new-ralph-burning/ralph-burning-rewrite/src/adapters/fs.rs:896:    fn create_run_dir(&self, base_dir: &Path, run_id: &str) -> AppResult<()> {\n/root/new-ralph-burning/ralph-burning-rewrite/src/adapters/fs.rs:902:        // Agent execution expects sessions.json in the project root (run root).\n/root/new-ralph-burning/ralph-burning-rewrite/src/adapters/fs.rs:961:        let path = requirements_run_root(base_dir, run_id).join(\"journal.ndjson\");\n/root/new-ralph-burning/ralph-burning-rewrite/src/adapters/fs.rs:971:        let path = requirements_run_root(base_dir, run_id).join(\"journal.ndjson\");\n/root/new-ralp