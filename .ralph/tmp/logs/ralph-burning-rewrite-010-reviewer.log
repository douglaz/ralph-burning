.agent_service.invoke(request).await?;\n   803\t\n   804\t        // Validate using requirements contract\n   805\t        let contract = match stage_id {\n   806\t            RequirementsStageId::QuestionSet => RequirementsContract::question_set(),\n   807\t            RequirementsStageId::RequirementsDraft => RequirementsContract::draft(),\n   808\t            RequirementsStageId::RequirementsReview => RequirementsContract::review(),\n   809\t            RequirementsStageId::ProjectSeed => RequirementsContract::seed(),\n   810\t        };\n   811\t\n   812\t        let bundle = contract\n   813\t            .evaluate(&envelope.parsed_payload)\n   814\t            .map_err(|e| AppError::InvalidRequirementsState {\n   815\t                run_id: \"\".to_owned(),\n   816\t                details: format!(\"contract validation failed for {}: {e}\", stage_id),\n   817\t            })?;\n   818\t\n   819\t        Ok(bundle)\n   820\t    }\n   821\t\n   822\t    async fn fail_run(\n   823\t        &self,\n   824\t        base_dir: &Path,\n   825\t        run: &mut RequirementsRun,\n   826\t        seq: u64,\n   827\t        message: &str,\n   828\t    ) -> AppResult<()> {\n   829\t        run.status = RequirementsStatus::Failed;\n   830\t        run.status_summary = format!(\"failed: {message}\");\n   831\t        run.updated_at = Utc::now();\n   832\t        self.store.write_run(base_dir, &run.run_id, run)?;\n   833\t\n   834\t        let event = journal_event(\n   835\t            seq,\n   836\t            Utc::now(),\n   837\t            RequirementsJournalEventType::RunFailed,\n   838\t            run,\n   839\t        );\n   840\t        self.store\n   841\t            .append_journal_event(base_dir, &run.run_id, &event)?;\n   842\t        Ok(())\n   843\t    }\n   844\t\n   845\t    /// Check whether answers have already been durably stored past the question\n   846\t    /// boundary, by consulting both the journal (for AnswersSubmitted events) and\n   847\t    /// the persisted answers.json (for non-empty answer content written before the\n   848\t    /// run/journal transition could complete).\n   849\t    fn answers_already_durably_stored(&self, base_dir: &Path, run_id: &str) -> AppResult<bool> {\n   850\t        // Check journal first — authoritative event source.\n   851\t        let journal = self.store.read_journal(base_dir, run_id)?;\n   852\t        if journal.iter().any(|e| {\n   853\t            e.event_type == RequirementsJournalEventType::AnswersSubmitted\n   854\t        }) {\n   855\t            return Ok(true);\n   856\t        }\n   857\t\n   858\t        // Check answers.json content — covers the case where answers.json was\n   859\t        // durably written but write_run()/journal append failed afterward.\n   860\t        // If answers.json doesn't exist or can't be read, treat as no answers\n   861\t        // stored (same as the initial empty state from create_run_dir).\n   862\t        if let Ok(persisted) = self.store.read_answers_json(base_dir, run_id) {\n   863\t            if !persisted.answers.is_empty() {\n   864\t                return Ok(true);\n   865\t            }\n   866\t        }\n   867\t\n   868\t        Ok(false)\n   869\t    }\n   870\t\n   871\t    fn next_sequence(&self, base_dir: &Path, run_id: &str) -> AppResult<u64> {\n   872\t        let events = self.store.read_journal(base_dir, run_id)?;\n   873\t        Ok(events.last().map_or(0, |e| e.sequence) + 1)\n   874\t    }\n   875\t}\n   876\t\n   877\t// ── Show result ─────────────────────────────────────────────────────────────\n   878\t\n   879\t/// Read model for `requirements show`.\n   880\t#[derive(Debug)]\n   881\tpub struct RequirementsShowResult {\n   882\t    pub run: RequirementsRun,\n   883\t    pub journal_event_count: u64,\n   884\t    pub pending_question_count: Option<u32>,\n   885\t    pub recommended_flow: Option<FlowPreset>,\n   886\t    pub failure_summary: Option<String>,\n   887\t    pub seed_prompt_path: Option<std::path::PathBuf>,\n   888\t}\n   889\t\n   890\t// ── Helpers ─────────────────────────────────────────────────────────────────\n   891\t\n   892\tfn generate_run_id(now: DateTime<Utc>) -> String {\n   893\t    format!(\"req-{}\", now.format(\"%Y%m%d-%H%M%S\"))\n   894\t}\n   895\t\n   896\tfn requirements_run_root(base_dir: &Path, run_id: &str) -> std::path::PathBuf {\n   897\t    base_dir\n   898\t        .join(\".ralph-burning\")\n   899\t        .join(\"requirements\")\n   900\t        .join(run_id)\n   901\t}\n   902\t\n   903\tfn journal_event(\n   904\t    sequence: u64,\n   905\t    timestamp: DateTime<Utc>,\n   906\t    event_type: RequirementsJournalEventType,\n   907\t    run: &RequirementsRun,\n   908\t) -> RequirementsJournalEvent {\n   909\t    RequirementsJournalEvent {\n   910\t        sequence,\n   911\t        timestamp,\n   912\t        event_type,\n   913\t        details: serde_json::json!({\n   914\t            \"run_id\": run.run_id,\n   915\t            \"status\": run.status,\n   916\t            \"status_summary\": run.status_summary,\n   917\t        }),\n   918\t    }\n   919\t}\n   920\t\n   921\tfn generate_answers_template(qs: &QuestionSetPayload) -> String {\n   922\t    let mut out = String::new();\n   923\t    out.push_str(\"# Answers for clarifying questions\\n\");\n   924\t    out.push_str(\"# Fill in answers below each question.\\n\\n\");\n   925\t\n   926\t    for q in &qs.questions {\n   927\t        let required = if q.required { \" (required)\" } else { \"\" };\n   928\t        out.push_str(&format!(\"# {}{}\\n\", q.prompt, required));\n   929\t        if !q.rationale.is_empty() {\n   930\t            out.push_str(&format!(\"# Rationale: {}\\n\", q.rationale));\n   931\t        }\n   932\t        let default_value = q\n   933\t            .suggested_default\n   934\t            .as_deref()\n   935\t            .unwrap_or(\"\");\n   936\t        out.push_str(&format!(\"{} = \\\"{}\\\"\\n\\n\", q.id, default_value));\n   937\t    }\n   938\t\n   939\t    out\n   940\t}\n","exit_code":0,"status":"completed"}}
