{"type":"item.completed","item":{"id":"item_43","type":"command_execution","command":"/run/current-system/sw/bin/bash -lc \"nl -ba /root/new-ralph-burning/ralph-burning-rewrite/src/adapters/fs.rs | sed -n '560,760p'\"","aggregated_output":"   560\t    }\n   561\t}\n   562\t\n   563\t/// Filesystem-backed implementation of `ActiveProjectPort`.\n   564\tpub struct FsActiveProjectStore;\n   565\t\n   566\timpl ActiveProjectPort for FsActiveProjectStore {\n   567\t    fn read_active_project_id(&self, base_dir: &Path) -> AppResult<Option<String>> {\n   568\t        FileSystem::read_active_project(&FileSystem::workspace_root_path(base_dir))\n   569\t    }\n   570\t\n   571\t    fn clear_active_project(&self, base_dir: &Path) -> AppResult<()> {\n   572\t        let path = FileSystem::workspace_root_path(base_dir).join(ACTIVE_PROJECT_FILE);\n   573\t        match fs::remove_file(&path) {\n   574\t            Ok(()) => Ok(()),\n   575\t            Err(e) if e.kind() == std::io::ErrorKind::NotFound => Ok(()),\n   576\t            Err(e) => Err(e.into()),\n   577\t        }\n   578\t    }\n   579\t\n   580\t    fn write_active_project(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<()> {\n   581\t        FileSystem::write_active_project(\n   582\t            &FileSystem::workspace_root_path(base_dir),\n   583\t            project_id.as_str(),\n   584\t        )\n   585\t    }\n   586\t}\n   587\t\n   588\t/// Filesystem-backed implementation of `RawOutputPort`.\n   589\tpub struct FsRawOutputStore;\n   590\t\n   591\timpl RawOutputPort for FsRawOutputStore {\n   592\t    fn persist_raw_output(\n   593\t        &self,\n   594\t        project_root: &Path,\n   595\t        invocation_id: &str,\n   596\t        contents: &str,\n   597\t    ) -> AppResult<RawOutputReference> {\n   598\t        let path = project_root\n   599\t            .join(\"runtime/backend\")\n   600\t            .join(format!(\"{invocation_id}.raw\"));\n   601\t        FileSystem::write_atomic(&path, contents)?;\n   602\t        Ok(RawOutputReference::Stored(path))\n   603\t    }\n   604\t}\n   605\t\n   606\t/// Filesystem-backed implementation of `SessionStorePort`.\n   607\tpub struct FsSessionStore;\n   608\t\n   609\timpl SessionStorePort for FsSessionStore {\n   610\t    fn load_sessions(&self, project_root: &Path) -> AppResult<PersistedSessions> {\n   611\t        let path = project_root.join(SESSIONS_FILE);\n   612\t        match fs::read_to_string(&path) {\n   613\t            Ok(raw) => serde_json::from_str(&raw).map_err(|error| AppError::CorruptRecord {\n   614\t                file: format!(\"{}/{}\", project_root.display(), SESSIONS_FILE),\n   615\t                details: error.to_string(),\n   616\t            }),\n   617\t            Err(error) if error.kind() == std::io::ErrorKind::NotFound => {\n   618\t                Err(AppError::CorruptRecord {\n   619\t                    file: format!(\"{}/{}\", project_root.display(), SESSIONS_FILE),\n   620\t                    details: \"canonical file is missing\".to_owned(),\n   621\t                })\n   622\t            }\n   623\t            Err(error) => Err(error.into()),\n   624\t        }\n   625\t    }\n   626\t\n   627\t    fn save_sessions(&self, project_root: &Path, sessions: &PersistedSessions) -> AppResult<()> {\n   628\t        let path = project_root.join(SESSIONS_FILE);\n   629\t        let contents = serde_json::to_string_pretty(sessions)?;\n   630\t        FileSystem::write_atomic(&path, &contents)\n   631\t    }\n   632\t}\n   633\t\n   634\t/// Filesystem-backed implementation of `RunSnapshotWritePort`.\n   635\tpub struct FsRunSnapshotWriteStore;\n   636\t\n   637\timpl RunSnapshotWritePort for FsRunSnapshotWriteStore {\n   638\t    fn write_run_snapshot(\n   639\t        &self,\n   640\t        base_dir: &Path,\n   641\t        project_id: &ProjectId,\n   642\t        snapshot: &RunSnapshot,\n   643\t    ) -> AppResult<()> {\n   644\t        let path = FileSystem::project_root(base_dir, project_id).join(RUN_FILE);\n   645\t        let contents = serde_json::to_string_pretty(snapshot)?;\n   646\t        FileSystem::write_atomic(&path, &contents)\n   647\t    }\n   648\t}\n   649\t\n   650\t/// Filesystem-backed implementation of `PayloadArtifactWritePort`.\n   651\tpub struct FsPayloadArtifactWriteStore;\n   652\t\n   653\timpl PayloadArtifactWritePort for FsPayloadArtifactWriteStore {\n   654\t    fn write_payload_artifact_pair(\n   655\t        &self,\n   656\t        base_dir: &Path,\n   657\t        project_id: &ProjectId,\n   658\t        payload: &PayloadRecord,\n   659\t        artifact: &ArtifactRecord,\n   660\t    ) -> AppResult<()> {\n   661\t        let project_root = FileSystem::project_root(base_dir, project_id);\n   662\t\n   663\t        let payload_final = project_root\n   664\t            .join(\"history/payloads\")\n   665\t            .join(format!(\"{}.json\", payload.payload_id));\n   666\t        let artifact_final = project_root\n   667\t            .join(\"history/artifacts\")\n   668\t            .join(format!(\"{}.json\", artifact.artifact_id));\n   669\t\n   670\t        // Stage both files under runtime/temp/ first so that no canonical\n   671\t        // history file exists until both writes succeed. This prevents\n   672\t        // orphaned payloads from leaking into durable history on partial failure.\n   673\t        let staging_dir = project_root.join(\"runtime/temp\");\n   674\t        fs::create_dir_all(&staging_dir)?;\n   675\t\n   676\t        let payload_staging = staging_dir.join(format!(\".{}.payload.staging\", payload.payload_id));\n   677\t        let artifact_staging =\n   678\t            staging_dir.join(format!(\".{}.artifact.staging\", artifact.artifact_id));\n   679\t\n   680\t        let payload_json = serde_json::to_string_pretty(payload)?;\n   681\t        let artifact_json = serde_json::to_string_pretty(artifact)?;\n   682\t\n   683\t        // Write payload to staging\n   684\t        FileSystem::write_atomic(&payload_staging, &payload_json)?;\n   685\t\n   686\t        // Write artifact to staging — if this fails, clean up payload staging\n   687\t        if let Err(e) = FileSystem::write_atomic(&artifact_staging, &artifact_json) {\n   688\t            let _ = fs::remove_file(&payload_staging);\n   689\t            return Err(e);\n   690\t        }\n   691\t\n   692\t        // Rename payload staging into canonical location\n   693\t        if let Err(e) = fs::rename(&payload_staging, &payload_final) {\n   694\t            let _ = fs::remove_file(&payload_staging);\n   695\t            let _ = fs::remove_file(&artifact_staging);\n   696\t            return Err(e.into());\n   697\t        }\n   698\t\n   699\t        // Rename artifact staging into canonical location\n   700\t        if let Err(e) = fs::rename(&artifact_staging, &artifact_final) {\n   701\t            // Roll back the payload that was already moved to canonical location\n   702\t            // and remove the orphaned staged artifact file\n   703\t            let _ = fs::remove_file(&payload_final);\n   704\t            let _ = fs::remove_file(&artifact_staging);\n   705\t            return Err(e.into());\n   706\t        }\n   707\t\n   708\t        Ok(())\n   709\t    }\n   710\t\n   711\t    fn remove_payload_artifact_pair(\n   712\t        &self,\n   713\t        base_dir: &Path,\n   714\t        project_id: &ProjectId,\n   715\t        payload_id: &str,\n   716\t        artifact_id: &str,\n   717\t    ) -> AppResult<()> {\n   718\t        let project_root = FileSystem::project_root(base_dir, project_id);\n   719\t\n   720\t        let payload_path = project_root\n   721\t            .join(\"history/payloads\")\n   722\t            .join(format!(\"{}.json\", payload_id));\n   723\t        let artifact_path = project_root\n   724\t            .join(\"history/artifacts\")\n   725\t            .join(format!(\"{}.json\", artifact_id));\n   726\t\n   727\t        // Remove both files, propagating errors so the caller knows about\n   728\t        // leaked durable history. NotFound is not an error (already cleaned up).\n   729\t        let mut errors = Vec::new();\n   730\t        if let Err(e) = fs::remove_file(&artifact_path) {\n   731\t            if e.kind() != std::io::ErrorKind::NotFound {\n   732\t                errors.push(format!(\"artifact {}: {}\", artifact_id, e));\n   733\t            }\n   734\t        }\n   735\t        if let Err(e) = fs::remove_file(&payload_path) {\n   736\t            if e.kind() != std::io::ErrorKind::NotFound {\n   737\t                errors.push(format!(\"payload {}: {}\", payload_id, e));\n   738\t            }\n   739\t        }\n   740\t\n   741\t        if errors.is_empty() {\n   742\t            Ok(())\n   743\t        } else {\n   744\t            Err(AppError::Io(std::io::Error::other(format!(\n   745\t                \"failed to remove payload/artifact pair: {}\",\n   746\t                errors.join(\"; \")\n   747\t            ))))\n   748\t        }\n   749\t    }\n   750\t}\n   751\t\n   752\t/// Filesystem-backed implementation of `AmendmentQueuePort`.\n   753\tpub struct FsAmendmentQueueStore;\n   754\t\n   755\timpl crate::contexts::project_run_record::service::AmendmentQueuePort for FsAmendmentQueueStore {\n   756\t    fn write_amendment(\n   757\t        &self,\n   758\t        base_dir: &Path,\n   759\t        project_id: &ProjectId,\n   760\t        amendment: &crate::contexts::project_run_record::model::QueuedAmendment,\n","exit_code":0,"status":"completed"}}
