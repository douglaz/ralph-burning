st_question_set_id.as_ref().ok_or_else(|| {\n   784\t        AppError::InvalidRequirementsState {\n   785\t            run_id: run_id.to_owned(),\n   786\t            details: \"no question set committed\".to_owned(),\n   787\t        }\n   788\t    })?;\n   789\t\n   790\t    // Build answers from TOML keys\n   791\t    let mut answers = Vec::new();\n   792\t    for (key, value) in &table {\n   793\t        let answer_text = match value.as_str() {\n   794\t            Some(s) => s.to_owned(),\n   795\t            None => value.to_string(),\n   796\t        };\n   797\t        answers.push(AnswerEntry {\n   798\t            question_id: key.clone(),\n   799\t            answer: answer_text,\n   800\t        });\n   801\t    }\n   802\t\n   803\t    // Note: full validation against required question IDs would require\n   804\t    // reading the question set payload. For now we validate non-empty answers.\n   805\t    for entry in &answers {\n   806\t        if entry.answer.trim().is_empty() {\n   807\t            // We just skip empty answers; the required check would need the\n   808\t            // question set payload to determine which are required.\n   809\t        }\n   810\t    }\n   811\t\n   812\t    Ok(PersistedAnswers { answers })\n   813\t}\n   814\t\n   815\tfn build_draft_prompt(idea: &str, answers: &[(String, String)]) -> String {\n   816\t    let mut prompt = format!(\"Draft requirements for the following idea:\\n\\n{idea}\\n\");\n   817\t\n   818\t    if !answers.is_empty() {\n   819\t        prompt.push_str(\"\\nClarifying answers:\\n\");\n   820\t        for (qid, answer) in answers {\n","exit_code":0,"status":"completed"}}
