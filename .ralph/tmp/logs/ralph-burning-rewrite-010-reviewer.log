{"type":"item.completed","item":{"id":"item_30","type":"command_execution","command":"/run/current-system/sw/bin/bash -lc \"nl -ba /root/new-ralph-burning/ralph-burning-rewrite/src/contexts/requirements_drafting/service.rs | sed -n '940,1120p'\"","aggregated_output":"   940\t}\n   941\t\n   942\t/// Validate answers against the committed question set payload.\n   943\t///\n   944\t/// Loads the question set from persisted payloads, rejects unknown answer keys,\n   945\t/// and requires non-empty values for required questions.\n   946\tfn parse_and_validate_answers<Q: RequirementsStorePort>(\n   947\t    answers_raw: &str,\n   948\t    base_dir: &Path,\n   949\t    run_id: &str,\n   950\t    store: &Q,\n   951\t) -> AppResult<PersistedAnswers> {\n   952\t    // Parse TOML\n   953\t    let table: toml::Table = toml::from_str(answers_raw).map_err(|e| {\n   954\t        AppError::AnswerValidationFailed {\n   955\t            run_id: run_id.to_owned(),\n   956\t            details: format!(\"invalid TOML: {e}\"),\n   957\t        }\n   958\t    })?;\n   959\t\n   960\t    // Load the committed question set payload\n   961\t    let run = store.read_run(base_dir, run_id)?;\n   962\t    let qs_id = run.latest_question_set_id.as_ref().ok_or_else(|| {\n   963\t        AppError::InvalidRequirementsState {\n   964\t            run_id: run_id.to_owned(),\n   965\t            details: \"no question set committed\".to_owned(),\n   966\t        }\n   967\t    })?;\n   968\t\n   969\t    let qs_json = store.read_payload(base_dir, run_id, qs_id)?;\n   970\t    let qs: QuestionSetPayload = serde_json::from_value(qs_json).map_err(|e| {\n   971\t        AppError::InvalidRequirementsState {\n   972\t            run_id: run_id.to_owned(),\n   973\t            details: format!(\"corrupt question set payload: {e}\"),\n   974\t        }\n   975\t    })?;\n   976\t\n   977\t    // Build valid question ID set\n   978\t    let valid_ids: HashSet<&str> = qs.questions.iter().map(|q| q.id.as_str()).collect();\n   979\t\n   980\t    // Reject unknown answer keys\n   981\t    for key in table.keys() {\n   982\t        if !valid_ids.contains(key.as_str()) {\n   983\t            return Err(AppError::AnswerValidationFailed {\n   984\t                run_id: run_id.to_owned(),\n   985\t                details: format!(\"unknown question ID: '{key}'\"),\n   986\t            });\n   987\t        }\n   988\t    }\n   989\t\n   990\t    // Require non-empty answers for required questions\n   991\t    for q in &qs.questions {\n   992\t        if q.required {\n   993\t            match table.get(&q.id) {\n   994\t                None => {\n   995\t                    return Err(AppError::AnswerValidationFailed {\n   996\t                        run_id: run_id.to_owned(),\n   997\t                        details: format!(\"required question '{}' has no answer\", q.id),\n   998\t                    });\n   999\t                }\n  1000\t                Some(v) => {\n  1001\t                    let text = v.as_str().unwrap_or(\"\");\n  1002\t                    if text.trim().is_empty() {\n  1003\t                        return Err(AppError::AnswerValidationFailed {\n  1004\t                            run_id: run_id.to_owned(),\n  1005\t                            details: format!(\n  1006\t                                \"required question '{}' has an empty answer\",\n  1007\t                                q.id\n  1008\t                            ),\n  1009\t                        });\n  1010\t                    }\n  1011\t                }\n  1012\t            }\n  1013\t        }\n  1014\t    }\n  1015\t\n  1016\t    // Build answers from TOML keys\n  1017\t    let mut answers = Vec::new();\n  1018\t    for (key, value) in &table {\n  1019\t        let answer_text = match value.as_str() {\n  1020\t            Some(s) => s.to_owned(),\n  1021\t            None => value.to_string(),\n  1022\t        };\n  1023\t        answers.push(AnswerEntry {\n  1024\t            question_id: key.clone(),\n  1025\t            answer: answer_text,\n  1026\t        });\n  1027\t    }\n  1028\t\n  1029\t    Ok(PersistedAnswers { answers })\n  1030\t}\n  1031\t\n  1032\tfn build_draft_prompt(idea: &str, answers: &[(String, String)]) -> String {\n  1033\t    let mut prompt = format!(\"Draft requirements for the following idea:\\n\\n{idea}\\n\");\n  1034\t\n  1035\t    if !answers.is_empty() {\n  1036\t        prompt.push_str(\"\\nClarifying answers:\\n\");\n  1037\t        for (qid, answer) in answers {\n  1038\t            prompt.push_str(&format!(\"- {qid}: {answer}\\n\"));\n  1039\t        }\n  1040\t    }\n  1041\t\n  1042\t    prompt\n  1043\t}\n","exit_code":0,"status":"completed"}}
