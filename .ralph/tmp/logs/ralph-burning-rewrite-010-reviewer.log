{"type":"item.completed","item":{"id":"item_33","type":"command_execution","command":"/run/current-system/sw/bin/bash -lc \"nl -ba /root/new-ralph-burning/ralph-burning-rewrite/src/contexts/agent_execution/model.rs | sed -n '1,220p'\"","aggregated_output":"     1\tuse std::fmt;\n     2\tuse std::path::{Path, PathBuf};\n     3\tuse std::sync::atomic::{AtomicBool, Ordering};\n     4\tuse std::sync::Arc;\n     5\tuse std::time::Duration;\n     6\t\n     7\tuse chrono::{DateTime, Utc};\n     8\tuse serde_json::Value;\n     9\tuse tokio::sync::Notify;\n    10\t\n    11\tuse crate::contexts::agent_execution::session::SessionMetadata;\n    12\tuse crate::contexts::workflow_composition::contracts::StageContract;\n    13\tuse crate::shared::domain::{\n    14\t    BackendRole, BackendSpec, ModelSpec, ResolvedBackendTarget, SessionPolicy, StageId,\n    15\t};\n    16\t\n    17\t#[derive(Clone)]\n    18\tpub struct CancellationToken {\n    19\t    cancelled: Arc<AtomicBool>,\n    20\t    notify: Arc<Notify>,\n    21\t}\n    22\t\n    23\timpl CancellationToken {\n    24\t    pub fn new() -> Self {\n    25\t        Self {\n    26\t            cancelled: Arc::new(AtomicBool::new(false)),\n    27\t            notify: Arc::new(Notify::new()),\n    28\t        }\n    29\t    }\n    30\t\n    31\t    pub fn cancel(&self) {\n    32\t        self.cancelled.store(true, Ordering::SeqCst);\n    33\t        self.notify.notify_waiters();\n    34\t    }\n    35\t\n    36\t    pub fn is_cancelled(&self) -> bool {\n    37\t        self.cancelled.load(Ordering::SeqCst)\n    38\t    }\n    39\t\n    40\t    pub async fn cancelled(&self) {\n    41\t        if self.is_cancelled() {\n    42\t            return;\n    43\t        }\n    44\t\n    45\t        self.notify.notified().await;\n    46\t    }\n    47\t}\n    48\t\n    49\timpl Default for CancellationToken {\n    50\t    fn default() -> Self {\n    51\t        Self::new()\n    52\t    }\n    53\t}\n    54\t\n    55\timpl fmt::Debug for CancellationToken {\n    56\t    fn fmt(&self, f: &mut fmt::Formatter<'_>) -> fmt::Result {\n    57\t        f.debug_struct(\"CancellationToken\")\n    58\t            .field(\"cancelled\", &self.is_cancelled())\n    59\t            .finish()\n    60\t    }\n    61\t}\n    62\t\n    63\t#[derive(Debug, Clone, PartialEq)]\n    64\tpub struct InvocationPayload {\n    65\t    pub prompt: String,\n    66\t    pub context: Value,\n    67\t}\n    68\t\n    69\t// ── Domain-neutral contract identifier ──────────────────────────────────────\n    70\t\n    71\t/// A domain-neutral invocation contract. Wraps either a workflow `StageContract`\n    72\t/// or a requirements-specific contract label. This generalizes agent execution\n    73\t/// away from workflow-only `StageContract` coupling.\n    74\t#[derive(Debug, Clone)]\n    75\tpub enum InvocationContract {\n    76\t    /// Workflow stage contract — validated by agent execution.\n    77\t    Stage(StageContract),\n    78\t    /// Requirements or other domain contract — caller validates after invocation.\n    79\t    Requirements { label: String },\n    80\t}\n    81\t\n    82\timpl InvocationContract {\n    83\t    /// Human-readable label for error messages and logging.\n    84\t    pub fn label(&self) -> String {\n    85\t        match self {\n    86\t            Self::Stage(c) => c.stage_id.as_str().to_owned(),\n    87\t            Self::Requirements { label } => label.clone(),\n    88\t        }\n    89\t    }\n    90\t\n    91\t    /// Returns the `StageId` if this is a workflow stage contract.\n    92\t    pub fn stage_id(&self) -> Option<StageId> {\n    93\t        match self {\n    94\t            Self::Stage(c) => Some(c.stage_id),\n    95\t            Self::Requirements { .. } => None,\n    96\t        }\n    97\t    }\n    98\t\n    99\t    /// Returns the `StageContract` if this is a workflow stage contract.\n   100\t    pub fn stage_contract(&self) -> Option<&StageContract> {\n   101\t        match self {\n   102\t            Self::Stage(c) => Some(c),\n   103\t            Self::Requirements { .. } => None,\n   104\t        }\n   105\t    }\n   106\t}\n   107\t\n   108\t#[derive(Debug, Clone)]\n   109\tpub struct InvocationRequest {\n   110\t    pub invocation_id: String,\n   111\t    pub project_root: PathBuf,\n   112\t    pub contract: InvocationContract,\n   113\t    pub role: BackendRole,\n   114\t    pub resolved_target: ResolvedBackendTarget,\n   115\t    pub payload: InvocationPayload,\n   116\t    pub timeout: Duration,\n   117\t    pub cancellation_token: CancellationToken,\n   118\t    pub session_policy: SessionPolicy,\n   119\t    pub prior_session: Option<SessionMetadata>,\n   120\t    pub attempt_number: u32,\n   121\t}\n   122\t\n   123\t#[derive(Debug, Clone, PartialEq, Eq)]\n   124\tpub struct CapabilityCheck {\n   125\t    pub backend: BackendSpec,\n   126\t    pub model: ModelSpec,\n   127\t    pub contract_id: String,\n   128\t    pub supported: bool,\n   129\t    pub details: Option<String>,\n   130\t}\n   131\t\n   132\timpl CapabilityCheck {\n   133\t    pub fn success(target: &ResolvedBackendTarget, contract: &InvocationContract) -> Self {\n   134\t        Self {\n   135\t            backend: target.backend.clone(),\n   136\t            model: target.model.clone(),\n   137\t            contract_id: contract.label(),\n   138\t            supported: true,\n   139\t            details: None,\n   140\t        }\n   141\t    }\n   142\t\n   143\t    pub fn failure(\n   144\t        target: &ResolvedBackendTarget,\n   145\t        contract: &InvocationContract,\n   146\t        details: impl Into<String>,\n   147\t    ) -> Self {\n   148\t        Self {\n   149\t            backend: target.backend.clone(),\n   150\t            model: target.model.clone(),\n   151\t            contract_id: contract.label(),\n   152\t            supported: false,\n   153\t            details: Some(details.into()),\n   154\t        }\n   155\t    }\n   156\t}\n   157\t\n   158\t#[derive(Debug, Clone, PartialEq, Eq)]\n   159\tpub enum RawOutputReference {\n   160\t    Inline(String),\n   161\t    Stored(PathBuf),\n   162\t}\n   163\t\n   164\timpl RawOutputReference {\n   165\t    pub fn inline_contents(&self) -> Option<&str> {\n   166\t        match self {\n   167\t            Self::Inline(contents) => Some(contents),\n   168\t            Self::Stored(_) => None,\n   169\t        }\n   170\t    }\n   171\t\n   172\t    pub fn stored_path(&self) -> Option<&Path> {\n   173\t        match self {\n   174\t            Self::Inline(_) => None,\n   175\t            Self::Stored(path) => Some(path.as_path()),\n   176\t        }\n   177\t    }\n   178\t}\n   179\t\n   180\t#[derive(Debug, Clone, Default, PartialEq, Eq)]\n   181\tpub struct TokenCounts {\n   182\t    pub prompt_tokens: Option<u32>,\n   183\t    pub completion_tokens: Option<u32>,\n   184\t    pub total_tokens: Option<u32>,\n   185\t}\n   186\t\n   187\t#[derive(Debug, Clone, PartialEq, Eq)]\n   188\tpub struct InvocationMetadata {\n   189\t    pub invocation_id: String,\n   190\t    pub duration: Duration,\n   191\t    pub token_counts: TokenCounts,\n   192\t    pub backend_used: BackendSpec,\n   193\t    pub model_used: ModelSpec,\n   194\t    pub attempt_number: u32,\n   195\t    pub session_id: Option<String>,\n   196\t    pub session_reused: bool,\n   197\t}\n   198\t\n   199\t#[derive(Debug, Clone, PartialEq)]\n   200\tpub struct InvocationEnvelope {\n   201\t    pub raw_output_reference: RawOutputReference,\n   202\t    pub parsed_payload: Value,\n   203\t    pub metadata: InvocationMetadata,\n   204\t    pub timestamp: DateTime<Utc>,\n   205\t}\n","exit_code":0,"status":"completed"}}
