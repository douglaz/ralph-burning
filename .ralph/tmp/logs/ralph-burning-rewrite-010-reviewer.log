m_millis(0),\n    38\t            available: true,\n    39\t            unsupported_stages: HashSet::new(),\n    40\t            fail_invoke_stages: HashSet::new(),\n    41\t            transient_failure_limits: HashMap::new(),\n    42\t            transient_failure_counters: HashMap::new(),\n    43\t            stage_payload_overrides: Arc::new(Mutex::new(HashMap::new())),\n    44\t            stage_payload_counters: HashMap::new(),\n    45\t            label_payload_overrides: Arc::new(Mutex::new(HashMap::new())),\n    46\t            label_payload_counters: HashMap::new(),\n    47\t            cancelled_invocations: Arc::new(Mutex::new(Vec::new())),\n    48\t        }\n    49\t    }\n    50\t}\n    51\t\n    52\timpl StubBackendAdapter {\n    53\t    pub fn with_delay(mut self, delay: Duration) -> Self {\n    54\t        self.delay = delay;\n    55\t        self\n    56\t    }\n    57\t\n    58\t    pub fn unavailable(mut self) -> Self {\n    59\t        self.available = false;\n    60\t        self\n    61\t    }\n    62\t\n    63\t    pub fn without_stage_support(mut self, stage_id: StageId) -> Self {\n    64\t        self.unsupported_stages.insert(stage_id);\n    65\t        self\n    66\t    }\n    67\t\n    68\t    /// Configure a stage to pass preflight but fail during invocation.\n    69\t    pub fn with_invoke_failure(mut self, stage_id: StageId) -> Self {\n    70\t        self.fail_invoke_stages.insert(stage_id);\n    71\t        self\n    72\t    }\n    73\t\n    74\t    /// Configure a stage to fail the first N invocations, then succeed.\n    75\t    pub fn with_transient_failure(mut self, stage_id: StageId, fail_count: u32) -> Self {\n    76\t        self.transient_failure_limits.insert(stage_id, fail_count);\n    77\t        self.transient_failure_counters\n    78\t            .insert(stage_id, Arc::new(AtomicU32::new(0)));\n    79\t        self\n    80\t    }\n    81\t\n    82\t    pub fn with_stage_payload(self, stage_id: StageId, payload: Value) -> Self {\n    83\t        self.with_stage_payload_sequence(stage_id, vec![payload])\n    84\t    }\n    85\t\n    86\t    pub fn with_stage_payload_sequence(mut self, stage_id: StageId, payloads: Vec<Value>) -> Self {\n    87\t        self.stage_payload_overrides\n    88\t            .lock()\n    89\t            .expect(\"stage payload override lock poisoned\")\n    90\t            .insert(stage_id, payloads);\n    91\t        self.stage_payload_counters\n    92\t            .insert(stage_id, Arc::new(AtomicU32::new(0)));\n    93\t        self\n    94\t    }\n    95\t\n    96\t    /// Configure a contract-label-keyed payload for non-stage invocations (e.g. requirements).\n    97\t    pub fn with_label_payload(self, label: impl Into<String>, payload: Value) -> Self {\n    98\t        self.with_label_payload_sequence(label, vec![payload])\n    99\t    }\n   100\t\n   101\t    /// Configure a contract-label-keyed payload sequence for non-stage invocations.\n   102\t    pub fn with_label_payload_sequence(\n   103\t        mut self,\n   104\t        label: impl Into<String>,\n   105\t        payloads: Vec<Value>,\n   106\t    ) -> Self {\n   107\t        let label = label.into();\n   108\t        self.label_payload_overrides\n   109\t            .lock()\n   110\t            .expect(\"label payload override lock poisoned\")\n   111\t            .insert(label.clone(), payloads);\n   112\t        self.label_payload_counters\n   113\t            .insert(label, Arc::new(AtomicU32::new(0)));\n   114\t        self\n   115\t    }\n   116\t\n   117\t    pub fn cancelled_invocations(&self) -> Vec<String> {\n   118\t        self.cancelled_invocations\n   119\t            .lock()\n   120\t            .expect(\"cancelled invocation lock poisoned\")\n   121\t            .clone()\n   122\t    }\n   123\t\n   124\t    fn payload_for_stage(&self, stage_id: StageId) -> Value {\n   125\t        let overrides = self\n   126\t            .stage_payload_overrides\n   127\t            .lock()\n   128\t            .expect(\"stage payload override lock poisoned\");\n   129\t        let Some(payloads) = overrides.get(&stage_id) else {\n   130\t            return canned_payload_for_stage(stage_id);\n   131\t        };\n   132\t        let Some(counter) = self.stage_payload_counters.get(&stage_id) else {\n   133\t            return payloads\n   134\t                .last()\n   135\t                .cloned()\n   136\t                .unwrap_or_else(|| canned_payload_for_stage(stage_id));\n   137\t        };\n   138\t        let idx = counter.fetch_add(1, Ordering::SeqCst) as usize;\n   139\t        payloads\n   140\t            .get(idx)\n   141\t            .cloned()\n   142\t            .or_else(|| payloads.last().cloned())\n   143\t            .unwrap_or_else(|| canned_payload_for_stage(stage_id))\n   144\t    }\n   145\t\n   146\t    fn payload_for_label(&self, label: &str) -> Value {\n   147\t        let overrides = self\n   148\t            .label_payload_overrides\n   149\t            .lock()\n   150\t            .expect(\"label payload override lock poisoned\");\n   151\t        let Some(payloads) = overrides.get(label) else {\n   152\t            return canned_requirements_payload(label);\n   153\t        };\n   154\t        let Some(counter) = self.label_payload_counters.get(label) else {\n   155\t            return payloads\n   156\t                .last()\n   157\t                .cloned()\n   158\t                .unwrap_or_else(|| canned_requirements_payload(label));\n   159\t        };\n   160\t        let idx = counter.fetch_add(1, Ordering::SeqCst) as usize;\n   161\t        payloads\n   162\t            .get(idx)\n   163\t            .cloned()\n   164\t            .or_else(|| payloads.last().cloned())\n   165\t            .unwrap_or_else(|| canned_requirements_payload(label))\n   166\t    }\n   167\t\n   168\t    fn payload_for_contract(&self, contract: &InvocationContract) -> Value {\n   169\t        match contract {\n   170\t            InvocationContract::Stage(sc) => self.payload_for_stage(sc.stage_id),\n   171\t            InvocationContract::Requirements { label } => self.payload_for_label(label),\n   172\t        }\n   173\t    }\n   174\t}\n   175\t\n   176\timpl AgentExecutionPort for StubBackendAdapter {\n   177\t    async fn check_capability(\n   178\t        &self,\n   179\t        backend: &crate::shared::domain::ResolvedBackendTarget,\n   180\t        contract: &InvocationContract,\n   181\t    ) -> AppResult<()> {\n   182\t        match contract {\n   183\t            InvocationContract::Stage(sc) => {\n   184\t                if self.unsupported_stages.contains(&sc.stage_id)\n   185\t                    || !backend.supports_stage(sc.stage_id)\n   186\t                {\n   187\t                    return Err(AppError::CapabilityMismatch {\n   188\t                        backend: backend.backend.family.to_string(),\n   189\t                        contract_id: sc.stage_id.to_string(),\n   190\t                        details: \"stub adapter does not support the requested stage\".to_owned(),\n   191\t                    });\n   192\t                }\n   193\t            }\n   194\t            InvocationContract::Requirements { .. } => {\n   195\t                // Requirements contracts are always supported by the stub.\n   196\t            }\n   197\t        }\n   198\t\n   199\t        Ok(())\n   200\t    }\n   201\t\n   202\t    async fn check_availability(\n   203\t        &self,\n   204\t        backend: &crate::shared::domain::ResolvedBackendTarget,\n   205\t    ) -> AppResult<()> {\n   206\t        if self.available {\n   207\t            Ok(())\n   208\t        } else {\n   209\t            Err(AppError::BackendUnavailable {\n   210\t                backend: backend.backend.family.to_string(),\n   211\t                details: \"stub adapter configured as unavailable\".to_owned(),\n   212\t            })\n   213\t        }\n   214\t    }\n   215\t\n   216\t    async fn invoke(&self, request: InvocationRequest) -> AppResult<InvocationEnvelope> {\n   217\t        let contract_label = request.contract.label();\n   218\t\n   219\t        if request.cancellation_token.is_cancelled() {\n   220\t            return Err(AppError::InvocationCancelled {\n   221\t                backend: request.resolved_target.backend.family.to_string(),\n   222\t                contract_id: contract_label,\n   223\t            });\n   224\t        }\n   225\t\n   226\t        // Transient failure simulation (stage contracts only)\n   227\t        if let Some(stage_id) = request.contract.stage_id() {\n   228\t            if let Some(limit) = self.transient_failure_limits.get(&stage_id) {\n   229\t                let counter = self\n   230\t                    .transient_failure_counters\n   231\t                    .get(&stage_id)\n   232\t                    .expect(\"transient failure counter missing\");\n   233\t                let attempt = counter.fetch_add(1, Ordering::SeqCst) + 1;\n   234\t                if attempt <= *limit {\n   235\t                    return Err(AppError::InvocationFailed {\n   236\t                        backend: request.resolved_target.backend.family.to_string(),\n   237\t                        contract_id: contract_label,\n   238\t                        failure_class: FailureClass::TransportFailure,\n   239\t                        details: format!(\n   240\t                            \"stub adapter configured to fail invocation {attempt}/{limit} for this stage\"\n   241\t                        ),\n   242\t                    });\n   243\t                }\n   244\t            }\n   245\t\n   246\t            if self.fail_invoke_stages.contains(&stage_id) {\n   247\t                return Err(AppError::InvocationFailed {\n   248\t                    backend: request.resolved_target.backend.family.to_string(),\n   249\t                    contract_id: contract_label,\n   250\t                    failure_class: FailureClass::TransportFailure,\n   251\t                    details: \"stub adapter configured to fail invocation for this stage\".to_owned(),\n   252\t                });\n   253\t            }\n   254\t        }\n   255\t\n   256\t        if self.delay > Duration::from_millis(0) {\n   257\t            tokio::select! {\n   258\t                _ = request.cancellation_token.cancelled() => {\n   259\t                    return Err(AppError::InvocationCancelled {\n   260\t                        backend: request.resolved_target.backend.family.to_string(),\n   261\t                        contract_id: contract_label,\n   262\t                    });\n   263\t                }\n   264\t                _ = tokio::time::sleep(self.delay) => {}\n   265\t            }\n   266\t        }\n   267\t\n   268\t        let payload = self.payload_for_contract(&request.contract);\n   269\t        let raw_output = serde_json::to_string_pretty(&payload)?;\n   270\t        let prompt_token_count = count_tokens(&request.payload.prompt);\n   271\t        let completion_token_count = count_tokens(&raw_output);\n   272\t        let prompt_tokens = Some(prompt_token_count);\n   273\t        let completion_tokens = Some(completion_token_count);\n   274\t        let total_tokens = Some(prompt_token_count + completion_token_count);\n   275\t\n   276\t        let supports_reuse =\n   277\t            request.role.allows_session_reuse() && request.resolved_target.supports_session_reuse();\n   278\t        let session_reused = supports_reuse\n   279\t            && matches!(request.session_policy, SessionPolicy::ReuseIfAllowed)\n   280\t            && request.prior_session.is_some();\n   281\t        let session_id = if supports_reuse {\n   282\t            request\n   283\t                .prior_session\n   284\t                .as_ref()\n   285\t                .map(|session| session.session_id.clone())\n   286\t                .filter(|_| session_reused)\n   287\t                .or_else(|| Some(format!(\"stub-{}-{}\", request.role.as_str(), contract_label)))\n   288\t        } else {\n   289\t            None\n   290\t        };\n   291\t\n   292\t        Ok(InvocationEnvelope {\n   293\t            raw_output_reference: RawOutputReference::Inline(raw_output),\n   294\t            parsed_payload: serde_json::Value::Null,\n   295\t            metadata: InvocationMetadata {\n   296\t                invocation_id: request.invocation_id,\n   297\t                duration: Duration::from_millis(0),\n   298\t                token_counts: TokenCounts {\n   299\t                    prompt_tokens,\n   300\t                    completion_tokens,\n   301\t                    total_tokens,\n   302\t                },\n   303\t                backend_used: request.resolved_target.backend,\n   304\t                model_used: request.resolved_target.model,\n   305\t                attempt_number: request.attempt_number,\n   306\t                session_id,\n   307\t                session_reused,\n   308\t            },\n   309\t            timestamp: Utc::now(),\n   310\t        })\n   311\t    }\n   312\t\n   313\t    async fn cancel(&self, invocation_id: &str) -> AppResult<()> {\n   314\t        self.cancelled_invocations\n   315\t            .lock()\n   316\t            .expect(\"cancelled invocation lock poisoned\")\n   317\t            .push(invocation_id.to_owned());\n   318\t        Ok(())\n   319\t    }\n   320\t}\n","exit_code":0,"status":"completed"}}
