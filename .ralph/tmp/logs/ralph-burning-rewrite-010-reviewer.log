rted\",\"cycle_history\":[],\"completion_rounds\":0,\"rollback_point_meta\":{\"last_rollback_id\":null,\"rollback_count\":0},\"amendment_queue\":{\"pending\":[],\"processed_count\":0},\"status_summary\":\"not started\"}\"#,\n    42\t    ).expect(\"write run.json\");\n    43\t    fs::write(\n    44\t        project_root.join(\"journal.ndjson\"),\n    45\t        format!(\n    46\t            r#\"{{\"sequence\":1,\"timestamp\":\"2026-03-11T19:00:00Z\",\"event_type\":\"project_created\",\"details\":{{\"project_id\":\"{}\",\"flow\":\"standard\"}}}}\"#,\n    47\t            project_id\n    48\t        ),\n    49\t    ).expect(\"write journal\");\n    50\t    fs::write(project_root.join(\"sessions.json\"), r#\"{\"sessions\":[]}\"#).expect(\"write sessions\");\n    51\t    for subdir in &[\n    52\t        \"history/payloads\",\n    53\t        \"history/artifacts\",\n    54\t        \"runtime/logs\",\n    55\t        \"runtime/backend\",\n    56\t        \"runtime/temp\",\n    57\t        \"amendments\",\n    58\t        \"rollback\",\n    59\t    ] {\n    60\t        fs::create_dir_all(project_root.join(subdir)).expect(\"create project subdirectory\");\n    61\t    }\n    62\t}\n    63\t\n    64\tfn write_editor_script(\n    65\t    base_dir: &std::path::Path,\n    66\t    name: &str,\n    67\t    contents: &str,\n    68\t) -> std::path::PathBuf {\n    69\t    let script_path = base_dir.join(name);\n    70\t    fs::write(&script_path, contents).expect(\"write editor script\");\n    71\t    let mut permissions = fs::metadata(&script_path)\n    72\t        .expect(\"script metadata\")\n    73\t        .permissions();\n    74\t    permissions.set_mode(0o755);\n    75\t    fs::set_permissions(&script_path, permissions).expect(\"set script permissions\");\n    76\t    script_path\n    77\t}\n    78\t\n    79\t#[test]\n    80\tfn flow_list_prints_all_presets() {\n    81\t    let output = Command::new(binary())\n    82\t        .args([\"flow\", \"list\"])\n    83\t        .output()\n    84\t        .expect(\"run flow list\");\n    85\t\n    86\t    assert!(output.status.success());\n    87\t\n    88\t    let stdout = String::from_utf8_lossy(&output.stdout);\n    89\t    assert!(stdout.contains(\"standard\"));\n    90\t    assert!(stdout.contains(\"quick_dev\"));\n    91\t    assert!(stdout.contains(\"docs_change\"));\n    92\t    assert!(stdout.contains(\"ci_improvement\"));\n    93\t}\n    94\t\n    95\t#[test]\n    96\tfn flow_show_standard_prints_stage_sequence() {\n    97\t    let output = Command::new(binary())\n    98\t        .args([\"flow\", \"show\", \"standard\"])\n    99\t        .output()\n   100\t        .expect(\"run flow show\");\n   101\t\n   102\t    assert!(output.status.success());\n   103\t\n   104\t    let stdout = String::from_utf8_lossy(&output.stdout);\n   105\t    assert!(stdout.contains(\"Stage count: 8\"));\n   106\t    assert!(stdout.contains(\"1. prompt_review\"));\n   107\t    assert!(stdout.contains(\"8. final_review\"));\n   108\t    assert!(stdout.contains(\"Final review enabled: yes\"));\n   109\t}\n   110\t\n   111\t#[test]\n   112\tfn flow_show_invalid_preset_exits_non_zero_with_clear_error() {\n   113\t    let output = Command::new(binary())\n   114\t        .args([\"flow\", \"show\", \"unknown_flow\"])\n   115\t        .output()\n   116\t        .expect(\"run flow show invalid\");\n   117\t\n   118\t    assert!(!output.status.success());\n   119\t\n   120\t    let stderr = String::from_utf8_lossy(&output.stderr);\n","exit_code":0,"status":"completed"}}
