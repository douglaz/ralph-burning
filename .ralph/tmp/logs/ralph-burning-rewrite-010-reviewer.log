run.status = RequirementsStatus::Failed;\n   201\t                run.status_summary = format!(\"failed: question generation: {e}\");\n   202\t                run.updated_at = Utc::now();\n   203\t                self.store.write_run(base_dir, &run_id, &run)?;\n   204\t\n   205\t                let event = journal_event(\n   206\t                    2,\n   207\t                    Utc::now(),\n   208\t                    RequirementsJournalEventType::RunFailed,\n   209\t                    &run,\n   210\t                );\n   211\t                self.store\n   212\t                    .append_journal_event(base_dir, &run_id, &event)?;\n   213\t                return Err(e);\n   214\t            }\n   215\t        }\n   216\t\n   217\t        Ok(run_id)\n   218\t    }\n   219\t\n   220\t    /// Execute `requirements quick --idea \"<text>\"`.\n   221\t    pub async fn quick(&self, base_dir: &Path, idea: &str, now: DateTime<Utc>) -> AppResult<String> {\n   222\t        let run_id = generate_run_id(now);\n   223\t        let mut run = RequirementsRun::new_quick(run_id.clone(), idea.to_owned(), now);\n   224\t\n   225\t        self.store.create_run_dir(base_dir, &run_id)?;\n   226\t        self.store.write_run(base_dir, &run_id, &run)?;\n   227\t\n   228\t        let created_event = journal_event(1, now, RequirementsJournalEventType::RunCreated, &run);\n   229\t        self.store\n   230\t            .append_journal_event(base_dir, &run_id, &created_event)?;\n","exit_code":0,"status":"completed"}}
