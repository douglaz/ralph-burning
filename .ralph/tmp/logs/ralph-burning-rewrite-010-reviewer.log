count: journal.len() as u64,\n   271\t            pending_question_count,\n   272\t            failure_summary,\n   273\t            seed_prompt_path,\n   274\t        })\n   275\t    }\n   276\t\n   277\t    /// Execute `requirements answer <run-id>`.\n   278\t    pub async fn answer(&self, base_dir: &Path, run_id: &str) -> AppResult<()> {\n   279\t        let mut run = self.store.read_run(base_dir, run_id)?;\n   280\t\n   281\t        // Valid only for awaiting_answers or failed runs with a committed question set\n   282\t        match run.status {\n   283\t            RequirementsStatus::AwaitingAnswers => {}\n   284\t            RequirementsStatus::Failed if run.latest_question_set_id.is_some() => {}\n   285\t            _ => {\n   286\t                return Err(AppError::InvalidRequirementsState {\n   287\t                    run_id: run_id.to_owned(),\n   288\t                    details: format!(\n   289\t                        \"cannot answer: run is in '{}' state\",\n   290\t                        run.status\n   291\t                    ),\n   292\t                });\n   293\t            }\n   294\t        }\n   295\t\n   296\t        // Open editor\n   297\t        let answers_path = self.store.answers_toml_path(base_dir, run_id);\n   298\t        FileSystem::open_editor(&answers_path)?;\n   299\t\n   300\t        // Read and validate answers\n   301\t        let answers_raw = self.store.read_answers_toml(base_dir, run_id)?;\n   302\t        let answers = parse_and_validate_answers(&answers_raw, base_dir, run_id, &self.store)?;\n   303\t\n   304\t        // Persist answers.json\n   305\t        self.store\n   306\t            .write_answers_json(base_dir, run_id, &answers)?;\n   307\t\n   308\t        let seq = self.next_sequence(base_dir, run_id)?;\n   309\t        let event = journal_event(\n   310\t            seq,\n   311\t            Utc::now(),\n   312\t            RequirementsJournalEventType::AnswersSubmitted,\n   313\t            &run,\n   314\t        );\n   315\t        self.store\n   316\t            .append_journal_event(base_dir, run_id, &event)?;\n   317\t\n   318\t        // Resume from answers boundary\n   319\t        let answer_entries: Vec<(String, String)> = answers\n   320\t            .answers\n   321\t            .iter()\n   322\t            .map(|a| (a.question_id.clone(), a.answer.clone()))\n   323\t            .collect();\n   324\t\n   325\t        run.question_round += 1;\n   326\t        run.status = RequirementsStatus::Drafting;\n   327\t        run.status_summary = \"drafting: generating requirements from answers\".to_owned();\n   328\t        run.updated_at = Utc::now();\n   329\t        self.store.write_run(base_dir, run_id, &run)?;\n   330\t\n   331\t        let idea = run.idea.clone();\n   332\t        self.continue_after_answers(base_dir, &mut run, &idea, &answer_entries, seq + 1, Utc::now())\n   333\t            .await?;\n   334\t\n   335\t        Ok(())\n   336\t    }\n   337\t\n   338\t    // ── Internal pipeline ───────────────────────────────────────────────\n   339\t\n   340\t    async fn continue_after_answers(\n   341\t        &self,\n   342\t        base_dir: &Path,\n   343\t        run: &mut RequirementsRun,\n   344\t        idea: &str,\n   345\t        answers: &[(String, String)],\n   346\t        start_seq: u64,\n   347\t        _now: DateTime<Utc>,\n   348\t    ) -> AppResult<()> {\n   349\t        let run_id = run.run_id.clone();\n   350\t        let run_root = requirements_run_root(base_dir, &run_id);\n   351\t        let mut seq = start_seq;\n   352\t\n   353\t        // ── Draft ───────────────────────────────────────────────────────\n   354\t        let draft_prompt = build_draft_prompt(idea, answers);\n   355\t        let draft_result = self\n   356\t            .invoke_stage(\n   357\t                &run_root,\n   358\t                RequirementsStageId::RequirementsDraft,\n   359\t                BackendRole::Planner,\n   360\t                &draft_prompt,\n","exit_code":0,"status":"completed"}}
