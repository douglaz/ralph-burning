8\t            \"\\nCreate project:\\n  ralph-burning project create --id {} --name \\\"{}\\\" --flow {} --prompt {}\",\n   589\t            seed_payload.project_id,\n   590\t            seed_payload.project_name,\n   591\t            seed_payload.flow,\n   592\t            seed_path.display()\n   593\t        );\n   594\t\n   595\t        Ok(())\n   596\t    }\n   597\t\n   598\t    async fn invoke_stage(\n   599\t        &self,\n   600\t        run_root: &Path,\n   601\t        stage_id: RequirementsStageId,\n   602\t        role: BackendRole,\n   603\t        prompt: &str,\n   604\t    ) -> AppResult<RequirementsValidatedBundle> {\n   605\t        let contract_label = format!(\"requirements:{}\", stage_id.as_str());\n   606\t        let target = self.agent_service.resolver().resolve(role, None, None, None)?;\n   607\t\n   608\t        let request = InvocationRequest {\n   609\t            invocation_id: format!(\n   610\t                \"req-{}-{}\",\n   611\t                stage_id.as_str(),\n   612\t                Utc::now().format(\"%Y%m%d%H%M%S\")\n   613\t            ),\n   614\t            project_root: run_root.to_path_buf(),\n   615\t            contract: InvocationContract::Requirements {\n   616\t                label: contract_label,\n   617\t            },\n   618\t            role,\n   619\t            resolved_target: target,\n   620\t            payload: InvocationPayload {\n   621\t                prompt: prompt.to_owned(),\n   622\t                context: serde_json::Value::Null,\n   623\t            },\n   624\t            timeout: std::time::Duration::from_secs(300),\n   625\t            cancellation_token: CancellationToken::new(),\n   626\t            session_policy: SessionPolicy::NewSession,\n   627\t            prior_session: None,\n   628\t            attempt_number: 1,\n   629\t        };\n   630\t\n   631\t        let envelope = self.agent_service.invoke(request).await?;\n   632\t\n   633\t        // Validate using requirements contract\n   634\t        let contract = match stage_id {\n   635\t            RequirementsStageId::QuestionSet => RequirementsContract::question_set(),\n   636\t            RequirementsStageId::RequirementsDraft => RequirementsContract::draft(),\n   637\t            RequirementsStageId::RequirementsReview => RequirementsContract::review(),\n   638\t            RequirementsStageId::ProjectSeed => RequirementsContract::seed(),\n   639\t        };\n   640\t\n   641\t        let bundle = contract\n   642\t            .evaluate(&envelope.parsed_payload)\n   643\t            .map_err(|e| AppError::InvalidRequirementsState {\n   644\t                run_id: \"\".to_owned(),\n   645\t                details: format!(\"contract validation failed for {}: {e}\", stage_id),\n   646\t            })?;\n   647\t\n   648\t        Ok(bundle)\n   649\t    }\n   650\t\n   651\t    fn persist_payload_artifact_pair(\n   652\t        &self,\n   653\t        base_dir: &Path,\n   654\t        run_id: &str,\n   655\t        payload_id: &str,\n   656\t        payload: &Value,\n   657\t        artifact_id: &str,\n   658\t        artifact: &str,\n   659\t    ) -> AppResult<()> {\n   660\t        self.store\n   661\t            .write_payload(base_dir, run_id, payload_id, payload)?;\n   662\t        if let Err(e) = self\n   663\t            .store\n   664\t            .write_artifact(base_dir, run_id, artifact_id, artifact)\n   665\t        {\n   666\t            // Rollback: payload was written but artifact failed — this is a\n   667\t            // partial failure. In practice the payload file should be cleaned up,\n   668\t            // but for now we propagate the error.\n   669\t            return Err(e);\n   670\t        }\n   671\t        Ok(())\n   672\t    }\n   673\t\n   674\t    async fn fail_run(\n   675\t        &self,\n   676\t        base_dir: &Path,\n   677\t        run: &mut RequirementsRun,\n   678\t        seq: u64,\n   679\t        message: &str,\n   680\t    ) -> AppResult<()> {\n   681\t        run.status = RequirementsStatus::Failed;\n   682\t        run.status_summary = format!(\"failed: {message}\");\n   683\t        run.updated_at = Utc::now();\n   684\t        self.store.write_run(base_dir, &run.run_id, run)?;\n   685\t\n   686\t        let event = journal_event(\n   687\t            seq,\n   688\t            Utc::now(),\n   689\t            RequirementsJournalEventType::RunFailed,\n   690\t            run,\n   691\t        );\n   692\t        self.store\n   693\t            .append_journal_event(base_dir, &run.run_id, &event)?;\n   694\t        Ok(())\n   695\t    }\n   696\t\n   697\t    fn next_sequence(&self, base_dir: &Path, run_id: &str) -> AppResult<u64> {\n   698\t        let events = self.store.read_journal(base_dir, run_id)?;\n   699\t        Ok(events.last().map_or(0, |e| e.sequence) + 1)\n   700\t    }\n","exit_code":0,"status":"completed"}}
