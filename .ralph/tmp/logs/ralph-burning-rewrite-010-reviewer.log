atch status.code() {\n   150\t                Some(code) => format!(\" with exit code {code}\"),\n   151\t                None => \" after being terminated by a signal\".to_owned(),\n   152\t            };\n   153\t            Err(AppError::EditorFailed { editor, details })\n   154\t        }\n   155\t    }\n   156\t\n   157\t    /// Compute a simple hash of content for prompt integrity tracking.\n   158\t    pub fn prompt_hash(contents: &str) -> String {\n   159\t        use std::collections::hash_map::DefaultHasher;\n   160\t        use std::hash::{Hash, Hasher};\n   161\t        let mut hasher = DefaultHasher::new();\n   162\t        contents.hash(&mut hasher);\n   163\t        format!(\"{:016x}\", hasher.finish())\n   164\t    }\n   165\t\n   166\t    // ── Helpers for project filesystem layout ──\n   167\t\n   168\t    pub(crate) fn workspace_root_path(base_dir: &Path) -> PathBuf {\n   169\t        base_dir.join(WORKSPACE_DIR)\n   170\t    }\n","exit_code":0,"status":"completed"}}
