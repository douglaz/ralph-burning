{"type":"item.completed","item":{"id":"item_26","type":"command_execution","command":"/run/current-system/sw/bin/bash -lc \"nl -ba /root/new-ralph-burning/ralph-burning-rewrite/src/contexts/requirements_drafting/service.rs | sed -n '1,220p'\"","aggregated_output":"     1\t#![forbid(unsafe_code)]\n     2\t\n     3\t//! Requirements drafting service.\n     4\t//!\n     5\t//! Orchestrates `draft`, `quick`, `show`, and `answer` commands, including\n     6\t//! answer-template validation, seed rollback, and failure invariants.\n     7\t\n     8\tuse std::collections::HashSet;\n     9\tuse std::path::Path;\n    10\t\n    11\tuse chrono::{DateTime, Utc};\n    12\tuse serde_json::Value;\n    13\t\n    14\tuse crate::adapters::fs::FileSystem;\n    15\tuse crate::contexts::agent_execution::model::{\n    16\t    CancellationToken, InvocationContract, InvocationPayload, InvocationRequest,\n    17\t};\n    18\tuse crate::contexts::agent_execution::service::{\n    19\t    AgentExecutionPort, AgentExecutionService, BackendSelectionConfig,\n    20\t};\n    21\tuse crate::contexts::agent_execution::session::SessionStorePort;\n    22\tuse crate::contexts::agent_execution::RawOutputPort;\n    23\tuse crate::shared::domain::{BackendRole, FlowPreset, SessionPolicy};\n    24\tuse crate::shared::error::{AppError, AppResult};\n    25\t\n    26\tuse super::contracts::{RequirementsContract, RequirementsPayload};\n    27\tuse super::model::{\n    28\t    AnswerEntry, PersistedAnswers, QuestionSetPayload, RequirementsJournalEvent,\n    29\t    RequirementsJournalEventType, RequirementsReviewOutcome, RequirementsRun,\n    30\t    RequirementsStageId, RequirementsStatus,\n    31\t};\n    32\tuse super::renderers;\n    33\t\n    34\t// ── Port traits ─────────────────────────────────────────────────────────────\n    35\t\n    36\t/// Filesystem operations for requirements runs.\n    37\t#[allow(async_fn_in_trait)]\n    38\tpub trait RequirementsStorePort {\n    39\t    fn create_run_dir(&self, base_dir: &Path, run_id: &str) -> AppResult<()>;\n    40\t    fn write_run(&self, base_dir: &Path, run_id: &str, run: &RequirementsRun) -> AppResult<()>;\n    41\t    fn read_run(&self, base_dir: &Path, run_id: &str) -> AppResult<RequirementsRun>;\n    42\t    fn append_journal_event(\n    43\t        &self,\n    44\t        base_dir: &Path,\n    45\t        run_id: &str,\n    46\t        event: &RequirementsJournalEvent,\n    47\t    ) -> AppResult<()>;\n    48\t    fn read_journal(\n    49\t        &self,\n    50\t        base_dir: &Path,\n    51\t        run_id: &str,\n    52\t    ) -> AppResult<Vec<RequirementsJournalEvent>>;\n    53\t    fn write_payload(\n    54\t        &self,\n    55\t        base_dir: &Path,\n    56\t        run_id: &str,\n    57\t        payload_id: &str,\n    58\t        payload: &Value,\n    59\t    ) -> AppResult<()>;\n    60\t    fn write_artifact(\n    61\t        &self,\n    62\t        base_dir: &Path,\n    63\t        run_id: &str,\n    64\t        artifact_id: &str,\n    65\t        content: &str,\n    66\t    ) -> AppResult<()>;\n    67\t    fn read_payload(\n    68\t        &self,\n    69\t        base_dir: &Path,\n    70\t        run_id: &str,\n    71\t        payload_id: &str,\n    72\t    ) -> AppResult<Value>;\n    73\t    fn write_payload_artifact_pair_atomic(\n    74\t        &self,\n    75\t        base_dir: &Path,\n    76\t        run_id: &str,\n    77\t        payload_id: &str,\n    78\t        payload: &Value,\n    79\t        artifact_id: &str,\n    80\t        artifact: &str,\n    81\t    ) -> AppResult<()>;\n    82\t    fn write_answers_toml(\n    83\t        &self,\n    84\t        base_dir: &Path,\n    85\t        run_id: &str,\n    86\t        template: &str,\n    87\t    ) -> AppResult<()>;\n    88\t    fn read_answers_toml(&self, base_dir: &Path, run_id: &str) -> AppResult<String>;\n    89\t    fn write_answers_json(\n    90\t        &self,\n    91\t        base_dir: &Path,\n    92\t        run_id: &str,\n    93\t        answers: &PersistedAnswers,\n    94\t    ) -> AppResult<()>;\n    95\t    fn read_answers_json(&self, base_dir: &Path, run_id: &str) -> AppResult<PersistedAnswers>;\n    96\t    fn write_seed_pair(\n    97\t        &self,\n    98\t        base_dir: &Path,\n    99\t        run_id: &str,\n   100\t        project_json: &Value,\n   101\t        prompt_md: &str,\n   102\t    ) -> AppResult<()>;\n   103\t    fn remove_seed_pair(&self, base_dir: &Path, run_id: &str) -> AppResult<()>;\n   104\t    fn remove_payload_artifact_pair(\n   105\t        &self,\n   106\t        base_dir: &Path,\n   107\t        run_id: &str,\n   108\t        payload_id: &str,\n   109\t        artifact_id: &str,\n   110\t    ) -> AppResult<()>;\n   111\t    fn answers_toml_path(&self, base_dir: &Path, run_id: &str) -> std::path::PathBuf;\n   112\t    fn seed_prompt_path(&self, base_dir: &Path, run_id: &str) -> std::path::PathBuf;\n   113\t}\n   114\t\n   115\t// ── Service ─────────────────────────────────────────────────────────────────\n   116\t\n   117\tpub struct RequirementsService<A, R, S, Q> {\n   118\t    agent_service: AgentExecutionService<A, R, S>,\n   119\t    store: Q,\n   120\t    workspace_defaults: Option<BackendSelectionConfig>,\n   121\t}\n   122\t\n   123\timpl<A, R, S, Q> RequirementsService<A, R, S, Q> {\n   124\t    pub fn new(agent_service: AgentExecutionService<A, R, S>, store: Q) -> Self {\n   125\t        Self {\n   126\t            agent_service,\n   127\t            store,\n   128\t            workspace_defaults: None,\n   129\t        }\n   130\t    }\n   131\t\n   132\t    pub fn with_workspace_defaults(mut self, defaults: BackendSelectionConfig) -> Self {\n   133\t        self.workspace_defaults = Some(defaults);\n   134\t        self\n   135\t    }\n   136\t}\n   137\t\n   138\timpl<A, R, S, Q> RequirementsService<A, R, S, Q>\n   139\twhere\n   140\t    A: AgentExecutionPort,\n   141\t    R: RawOutputPort,\n   142\t    S: SessionStorePort,\n   143\t    Q: RequirementsStorePort,\n   144\t{\n   145\t    /// Execute `requirements draft --idea \"<text>\"`.\n   146\t    pub async fn draft(&self, base_dir: &Path, idea: &str, now: DateTime<Utc>) -> AppResult<String> {\n   147\t        let run_id = generate_run_id(now);\n   148\t        let mut run = RequirementsRun::new_draft(run_id.clone(), idea.to_owned(), now);\n   149\t\n   150\t        // Create run directory and initial state\n   151\t        self.store.create_run_dir(base_dir, &run_id)?;\n   152\t        self.store.write_run(base_dir, &run_id, &run)?;\n   153\t\n   154\t        let created_event = journal_event(1, now, RequirementsJournalEventType::RunCreated, &run);\n   155\t        self.store\n   156\t            .append_journal_event(base_dir, &run_id, &created_event)?;\n   157\t\n   158\t        // Generate questions\n   159\t        let run_root = requirements_run_root(base_dir, &run_id);\n   160\t        let question_result = self\n   161\t            .invoke_stage(\n   162\t                &run_root,\n   163\t                RequirementsStageId::QuestionSet,\n   164\t                BackendRole::Planner,\n   165\t                &format!(\"Generate clarifying questions for the following idea:\\n\\n{idea}\"),\n   166\t            )\n   167\t            .await;\n   168\t\n   169\t        match question_result {\n   170\t            Ok(bundle) => {\n   171\t                let RequirementsPayload::QuestionSet(ref qs) = bundle.payload else {\n   172\t                    unreachable!(\"QuestionSet contract always returns QuestionSet payload\");\n   173\t                };\n   174\t\n   175\t                let payload_id = format!(\"{run_id}-qs-1\");\n   176\t                let artifact_id = format!(\"{run_id}-qs-art-1\");\n   177\t\n   178\t                // Persist payload and artifact atomically\n   179\t                let payload_json = serde_json::to_value(qs)?;\n   180\t                if let Err(e) = self.store.write_payload_artifact_pair_atomic(\n   181\t                    base_dir,\n   182\t                    &run_id,\n   183\t                    &payload_id,\n   184\t                    &payload_json,\n   185\t                    &artifact_id,\n   186\t                    &bundle.artifact,\n   187\t                ) {\n   188\t                    // State invariant: if payload/artifact pair fails, run must not\n   189\t                    // transition and no partial files remain (handled by atomic write).\n   190\t                    // Durably journal the failure so show() can report it.\n   191\t                    run.status = RequirementsStatus::Failed;\n   192\t                    run.status_summary = format!(\"failed: could not persist question set: {e}\");\n   193\t                    run.updated_at = Utc::now();\n   194\t                    let _ = self.store.write_run(base_dir, &run_id, &run);\n   195\t                    let fail_event = journal_event(\n   196\t                        2,\n   197\t                        Utc::now(),\n   198\t                        RequirementsJournalEventType::RunFailed,\n   199\t                        &run,\n   200\t                    );\n   201\t                    let _ = self.store.append_journal_event(base_dir, &run_id, &fail_event);\n   202\t                    return Err(e);\n   203\t                }\n   204\t\n   205\t                // Record the committed question-set boundary in canonical state and\n   206\t                // journal immediately after the payload/artifact pair succeeds,\n   207\t                // before branching into any downstream path.\n   208\t                run.question_round = 1;\n   209\t                run.latest_question_set_id = Some(payload_id.clone());\n   210\t                run.updated_at = Utc::now();\n   211\t                self.store.write_run(base_dir, &run_id, &run)?;\n   212\t\n   213\t                let qs_event = journal_event(\n   214\t                    2,\n   215\t                    Utc::now(),\n   216\t                    RequirementsJournalEventType::QuestionsGenerated,\n   217\t                    &run,\n   218\t                );\n   219\t                self.store\n   220\t                    .append_journal_event(base_dir, &run_id, &qs_event)?;\n","exit_code":0,"status":"completed"}}
