{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01WgRGSHAnYPPYZo8bVH7q7q","type":"tool_result","content":"     1→use std::env;\n     2→use std::fs::{self, OpenOptions};\n     3→use std::io::Write;\n     4→use std::path::Path;\n     5→use std::process::Command;\n     6→use std::time::{SystemTime, UNIX_EPOCH};\n     7→\n     8→use crate::shared::domain::WorkspaceConfig;\n     9→use crate::shared::error::{AppError, AppResult};\n    10→\n    11→const ACTIVE_PROJECT_FILE: &str = \"active-project\";\n    12→\n    13→pub struct FileSystem;\n    14→\n    15→impl FileSystem {\n    16→    pub fn create_workspace(\n    17→        workspace_root: &Path,\n    18→        workspace_config: &str,\n    19→        required_directories: &[&str],\n    20→    ) -> AppResult<()> {\n    21→        fs::create_dir_all(workspace_root)?;\n    22→\n    23→        for directory in required_directories {\n    24→            fs::create_dir_all(workspace_root.join(directory))?;\n    25→        }\n    26→\n    27→        Self::write_atomic(&workspace_root.join(\"workspace.toml\"), workspace_config)?;\n    28→        Ok(())\n    29→    }\n    30→\n    31→    pub fn read_to_string(path: &Path) -> AppResult<String> {\n    32→        Ok(fs::read_to_string(path)?)\n    33→    }\n    34→\n    35→    pub fn write_atomic(path: &Path, contents: &str) -> AppResult<()> {\n    36→        let parent = path.parent().ok_or_else(|| {\n    37→            AppError::Io(std::io::Error::new(\n    38→                std::io::ErrorKind::InvalidInput,\n    39→                format!(\"path '{}' has no parent directory\", path.display()),\n    40→            ))\n    41→        })?;\n    42→        fs::create_dir_all(parent)?;\n    43→\n    44→        let timestamp = SystemTime::now()\n    45→            .duration_since(UNIX_EPOCH)\n    46→            .map(|duration| duration.as_nanos())\n    47→            .unwrap_or_default();\n    48→        let temp_path = parent.join(format!(\n    49→            \".{}.{}.{}.tmp\",\n    50→            path.file_name()\n    51→                .and_then(|value| value.to_str())\n    52→                .unwrap_or(\"workspace\"),\n    53→            std::process::id(),\n    54→            timestamp\n    55→        ));\n    56→\n    57→        let mut file = OpenOptions::new()\n    58→            .create_new(true)\n    59→            .write(true)\n    60→            .open(&temp_path)?;\n    61→        file.write_all(contents.as_bytes())?;\n    62→        file.sync_all()?;\n    63→        drop(file);\n    64→\n    65→        if let Err(error) = fs::rename(&temp_path, path) {\n    66→            let _ = fs::remove_file(&temp_path);\n    67→            return Err(error.into());\n    68→        }\n    69→\n    70→        Ok(())\n    71→    }\n    72→\n    73→    pub fn render_workspace_config(config: &WorkspaceConfig) -> AppResult<String> {\n    74→        Ok(toml::to_string_pretty(config)?)\n    75→    }\n    76→\n    77→    pub fn read_active_project(workspace_root: &Path) -> AppResult<Option<String>> {\n    78→        let path = workspace_root.join(ACTIVE_PROJECT_FILE);\n    79→        match fs::read_to_string(path) {\n    80→            Ok(raw) => {\n    81→                let trimmed = raw.trim();\n    82→                if trimmed.is_empty() {\n    83→                    Ok(None)\n    84→                } else {\n    85→                    Ok(Some(trimmed.to_owned()))\n    86→                }\n    87→            }\n    88→            Err(error) if error.kind() == std::io::ErrorKind::NotFound => Ok(None),\n    89→            Err(error) => Err(error.into()),\n    90→        }\n    91→    }\n    92→\n    93→    pub fn write_active_project(workspace_root: &Path, project_id: &str) -> AppResult<()> {\n    94→        Self::write_atomic(&workspace_root.join(ACTIVE_PROJECT_FILE), project_id)\n    95→    }\n    96→\n    97→    pub fn open_editor(path: &Path) -> AppResult<()> {\n    98→        let editor = env::var(\"EDITOR\")\n    99→            .ok()\n   100→            .filter(|value| !value.trim().is_empty())\n   101→            .or_else(|| {\n   102→                env::var(\"VISUAL\")\n   103→                    .ok()\n   104→                    .filter(|value| !value.trim().is_empty())\n   105→            })\n   106→            .unwrap_or_else(|| \"vi\".to_owned());\n   107→\n   108→        let mut parts = editor.split_whitespace();\n   109→        let program = parts.next().ok_or_else(|| AppError::EditorFailed {\n   110→            editor: editor.clone(),\n   111→            details: \": empty editor command\".to_owned(),\n   112→        })?;\n   113→        let status = Command::new(program).args(parts).arg(path).status()?;\n   114→\n   115→        if status.success() {\n   116→            Ok(())\n   117→        } else {\n   118→            let details = match status.code() {\n   119→                Some(code) => format!(\" with exit code {code}\"),\n   120→                None => \" after being terminated by a signal\".to_owned(),\n   121→            };\n   122→            Err(AppError::EditorFailed { editor, details })\n   123→        }\n   124→    }\n   125→}\n   126→"}]},"parent_tool_use_id":"toolu_012QdgmdBxgtkt4tovj3QwR9","session_id":"84e4772c-0822-4fc6-b1d7-1c1f7c7f3e3a","uuid":"f1e359c8-ac15-4224-a360-3d51a03937ca"}
