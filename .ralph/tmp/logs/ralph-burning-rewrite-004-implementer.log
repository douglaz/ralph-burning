{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01XeYpWiPnAZhPHwVzQccbzH","type":"tool_result","content":"     1→use std::path::PathBuf;\n     2→\n     3→use thiserror::Error;\n     4→\n     5→use crate::shared::domain::{FailureClass, StageId};\n     6→\n     7→pub type AppResult<T> = Result<T, AppError>;\n     8→\n     9→#[derive(Debug, Error)]\n    10→pub enum AppError {\n    11→    #[error(\"workspace already initialized at {path}\")]\n    12→    AlreadyInitialized { path: PathBuf },\n    13→    #[error(\n    14→        \"cannot initialize workspace because {path} already exists without a workspace configuration\"\n    15→    )]\n    16→    WorkspaceConflict { path: PathBuf },\n    17→    #[error(\"invalid {field}: must be greater than zero\")]\n    18→    InvalidStageCursorField { field: &'static str },\n    19→    #[error(\"invalid identifier '{value}': identifiers must be non-empty single path segments\")]\n    20→    InvalidIdentifier { value: String },\n    21→    #[error(\n    22→        \"unknown flow preset '{flow_id}'. supported presets: standard, quick_dev, docs_change, ci_improvement\"\n    23→    )]\n    24→    InvalidFlowPreset { flow_id: String },\n    25→    #[error(\"unsupported workspace version {version}; supported version is {supported}\")]\n    26→    UnsupportedWorkspaceVersion { version: u32, supported: u32 },\n    27→    #[error(\n    28→        \"unknown config key '{key}'. supported keys: prompt_review.enabled, default_flow, default_backend, default_model\"\n    29→    )]\n    30→    UnknownConfigKey { key: String },\n    31→    #[error(\"invalid value '{value}' for config key '{key}': {reason}\")]\n    32→    InvalidConfigValue {\n    33→        key: String,\n    34→        value: String,\n    35→        reason: String,\n    36→    },\n    37→    #[error(\"no active project selected; run `ralph-burning project select <id>`\")]\n    38→    NoActiveProject,\n    39→    #[error(\n    40→        \"project '{project_id}' was not found under .ralph-burning/projects/ or is missing project.toml\"\n    41→    )]\n    42→    ProjectNotFound { project_id: String },\n    43→    #[error(\"editor '{editor}' failed{details}\")]\n    44→    EditorFailed { editor: String, details: String },\n    45→    #[error(\"{command} is not yet implemented\")]\n    46→    NotYetImplemented { command: String },\n    47→    #[error(transparent)]\n    48→    Io(#[from] std::io::Error),\n    49→    #[error(transparent)]\n    50→    TomlDeserialize(#[from] toml::de::Error),\n    51→    #[error(transparent)]\n    52→    TomlSerialize(#[from] toml::ser::Error),\n    53→    #[error(transparent)]\n    54→    TomlEdit(#[from] toml_edit::TomlError),\n    55→}\n    56→\n    57→/// Errors specific to stage contract evaluation.\n    58→///\n    59→/// Each variant maps to a distinct [`FailureClass`] for retry/terminal policy.\n    60→#[derive(Debug, Error)]\n    61→pub enum ContractError {\n    62→    #[error(\"schema validation failed for stage '{stage_id}': {details}\")]\n    63→    SchemaValidation { stage_id: StageId, details: String },\n    64→\n    65→    #[error(\"domain validation failed for stage '{stage_id}': {details}\")]\n    66→    DomainValidation { stage_id: StageId, details: String },\n    67→\n    68→    #[error(\"rendering failed for stage '{stage_id}': {details}\")]\n    69→    RenderError { stage_id: StageId, details: String },\n    70→\n    71→    #[error(\"non-passing QA/review outcome for stage '{stage_id}': {outcome}\")]\n    72→    QaReviewOutcome { stage_id: StageId, outcome: String },\n    73→}\n    74→\n    75→impl ContractError {\n    76→    pub fn failure_class(&self) -> FailureClass {\n    77→        match self {\n    78→            Self::SchemaValidation { .. } => FailureClass::SchemaValidationFailure,\n    79→            Self::DomainValidation { .. } | Self::RenderError { .. } => {\n    80→                FailureClass::DomainValidationFailure\n    81→            }\n    82→            Self::QaReviewOutcome { .. } => FailureClass::QaReviewOutcomeFailure,\n    83→        }\n    84→    }\n    85→\n    86→    pub fn stage_id(&self) -> StageId {\n    87→        match self {\n    88→            Self::SchemaValidation { stage_id, .. }\n    89→            | Self::DomainValidation { stage_id, .. }\n    90→            | Self::RenderError { stage_id, .. }\n    91→            | Self::QaReviewOutcome { stage_id, .. } => *stage_id,\n    92→        }\n    93→    }\n    94→}\n    95→"}]},"parent_tool_use_id":"toolu_012QdgmdBxgtkt4tovj3QwR9","session_id":"84e4772c-0822-4fc6-b1d7-1c1f7c7f3e3a","uuid":"179c0090-5a27-4e9a-91f5-eed054a9e02f"}
