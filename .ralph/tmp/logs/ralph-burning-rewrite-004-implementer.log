{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01FnNmWkEhb8Tm43hBsXeMVq","type":"tool_result","content":"     1→use std::path::Path;\n     2→\n     3→use chrono::{DateTime, Utc};\n     4→\n     5→use crate::shared::domain::{FlowPreset, ProjectId};\n     6→use crate::shared::error::{AppError, AppResult};\n     7→\n     8→use super::model::{\n     9→    ArtifactRecord, JournalEvent, JournalEventType, PayloadRecord,\n    10→    ProjectDetail, ProjectListEntry, ProjectRecord, ProjectStatusSummary,\n    11→    RunSnapshot, RuntimeLogEntry, SessionStore,\n    12→};\n    13→use super::journal;\n    14→use super::queries::{\n    15→    self, RunHistoryView, RunStatusView, RunTailView,\n    16→};\n    17→\n    18→/// Port for reading and writing project records.\n    19→pub trait ProjectStorePort {\n    20→    fn project_exists(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<bool>;\n    21→    fn read_project_record(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<ProjectRecord>;\n    22→    fn list_project_ids(&self, base_dir: &Path) -> AppResult<Vec<ProjectId>>;\n    23→    fn delete_project(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<()>;\n    24→\n    25→    /// Atomically stage and commit a new project. If any step fails,\n    26→    /// the project must not be visible to list/show.\n    27→    fn create_project_atomic(\n    28→        &self,\n    29→        base_dir: &Path,\n    30→        record: &ProjectRecord,\n    31→        prompt_contents: &str,\n    32→        run_snapshot: &RunSnapshot,\n    33→        initial_journal_line: &str,\n    34→        sessions: &SessionStore,\n    35→    ) -> AppResult<()>;\n    36→}\n    37→\n    38→/// Port for reading and appending journal events.\n    39→pub trait JournalStorePort {\n    40→    fn read_journal(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<Vec<JournalEvent>>;\n    41→    fn append_event(&self, base_dir: &Path, project_id: &ProjectId, line: &str) -> AppResult<()>;\n    42→}\n    43→\n    44→/// Port for reading payload and artifact durable history.\n    45→pub trait ArtifactStorePort {\n    46→    fn list_payloads(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<Vec<PayloadRecord>>;\n    47→    fn list_artifacts(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<Vec<ArtifactRecord>>;\n    48→}\n    49→\n    50→/// Port for reading runtime logs (separate from durable history).\n    51→pub trait RuntimeLogStorePort {\n    52→    fn read_runtime_logs(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<Vec<RuntimeLogEntry>>;\n    53→}\n    54→\n    55→/// Port for reading/writing the run snapshot.\n    56→pub trait RunSnapshotPort {\n    57→    fn read_run_snapshot(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<RunSnapshot>;\n    58→}\n    59→\n    60→/// Port for reading/clearing the active project pointer.\n    61→pub trait ActiveProjectPort {\n    62→    fn read_active_project_id(&self, base_dir: &Path) -> AppResult<Option<String>>;\n    63→    fn clear_active_project(&self, base_dir: &Path) -> AppResult<()>;\n    64→}\n    65→\n    66→/// Input for the `project create` use case.\n    67→pub struct CreateProjectInput {\n    68→    pub id: ProjectId,\n    69→    pub name: String,\n    70→    pub flow: FlowPreset,\n    71→    pub prompt_path: String,\n    72→    pub prompt_contents: String,\n    73→    pub prompt_hash: String,\n    74→    pub created_at: DateTime<Utc>,\n    75→}\n    76→\n    77→/// Create a new project with all canonical files.\n    78→pub fn create_project(\n    79→    store: &dyn ProjectStorePort,\n    80→    journal_store: &dyn JournalStorePort,\n    81→    base_dir: &Path,\n    82→    input: CreateProjectInput,\n    83→) -> AppResult<ProjectRecord> {\n    84→    // Check for duplicate project ID\n    85→    if store.project_exists(base_dir, &input.id)? {\n    86→        return Err(AppError::DuplicateProject {\n    87→            project_id: input.id.to_string(),\n    88→        });\n    89→    }\n    90→\n    91→    let record = ProjectRecord {\n    92→        id: input.id.clone(),\n    93→        name: input.name,\n    94→        flow: input.flow,\n    95→        prompt_reference: input.prompt_path,\n    96→        prompt_hash: input.prompt_hash,\n    97→        created_at: input.created_at,\n    98→        status_summary: ProjectStatusSummary::Created,\n    99→    };\n   100→\n   101→    let run_snapshot = RunSnapshot::initial();\n   102→    let sessions = SessionStore::empty();\n   103→\n   104→    // Create the initial journal event\n   105→    let initial_event = JournalEvent {\n   106→        sequence: 1,\n   107→        timestamp: input.created_at,\n   108→        event_type: JournalEventType::ProjectCreated,\n   109→        details: serde_json::json!({\n   110→            \"project_id\": record.id.as_str(),\n   111→            \"flow\": record.flow.as_str(),\n   112→        }),\n   113→    };\n   114→    let journal_line = journal::serialize_event(&initial_event)?;\n   115→\n   116→    // Atomic creation: all files or nothing\n   117→    store.create_project_atomic(\n   118→        base_dir,\n   119→        &record,\n   120→        &input.prompt_contents,\n   121→        &run_snapshot,\n   122→        &journal_line,\n   123→        &sessions,\n   124→    )?;\n   125→\n   126→    // create_project_atomic writes the journal as part of the atomic init,\n   127→    // but we don't call journal_store.append_event here because the atomic\n   128→    // creation already wrote the initial journal line. The journal_store\n   129→    // parameter is kept for interface consistency and future use.\n   130→    let _ = journal_store;\n   131→\n   132→    Ok(record)\n   133→}\n   134→\n   135→/// List all projects with summary data.\n   136→pub fn list_projects(\n   137→    store: &dyn ProjectStorePort,\n   138→    active_port: &dyn ActiveProjectPort,\n   139→    base_dir: &Path,\n   140→) -> AppResult<Vec<ProjectListEntry>> {\n   141→    let active_id = active_port.read_active_project_id(base_dir)?;\n   142→    let project_ids = store.list_project_ids(base_dir)?;\n   143→\n   144→    let mut entries = Vec::new();\n   145→    for pid in project_ids {\n   146→        let record = store.read_project_record(base_dir, &pid)?;\n   147→        let is_active = active_id.as_deref() == Some(pid.as_str());\n   148→        entries.push(ProjectListEntry {\n   149→            id: record.id,\n   150→            name: record.name,\n   151→            flow: record.flow,\n   152→            status_summary: record.status_summary,\n   153→            created_at: record.created_at,\n   154→            is_active,\n   155→        });\n   156→    }\n   157→\n   158→    Ok(entries)\n   159→}\n   160→\n   161→/// Show detailed project information.\n   162→pub fn show_project(\n   163→    store: &dyn ProjectStorePort,\n   164→    run_port: &dyn RunSnapshotPort,\n   165→    journal_port: &dyn JournalStorePort,\n   166→    active_port: &dyn ActiveProjectPort,\n   167→    base_dir: &Path,\n   168→    project_id: &ProjectId,\n   169→) -> AppResult<ProjectDetail> {\n   170→    if !store.project_exists(base_dir, project_id)? {\n   171→        return Err(AppError::ProjectNotFound {\n   172→            project_id: project_id.to_string(),\n   173→        });\n   174→    }\n   175→\n   176→    let record = store.read_project_record(base_dir, project_id)?;\n   177→    let run_snapshot = run_port.read_run_snapshot(base_dir, project_id)?;\n   178→    let events = journal_port.read_journal(base_dir, project_id)?;\n   179→    let journal_event_count = events.len() as u64;\n   180→    let active_id = active_port.read_active_project_id(base_dir)?;\n   181→    let is_active = active_id.as_deref() == Some(project_id.as_str());\n   182→\n   183→    // Count rollback points from journal events\n   184→    let rollback_count = events\n   185→        .iter()\n   186→        .filter(|e| e.event_type == JournalEventType::RollbackCreated)\n   187→        .count();\n   188→\n   189→    Ok(ProjectDetail {\n   190→        record,\n   191→        run_snapshot,\n   192→        journal_event_count,\n   193→        rollback_count,\n   194→        is_active,\n   195→    })\n   196→}\n   197→\n   198→/// Delete a project. Fails if project has an active run.\n   199→/// Clears active-project pointer if it pointed to the deleted project.\n   200→pub fn delete_project(\n   201→    store: &dyn ProjectStorePort,\n   202→    run_port: &dyn RunSnapshotPort,\n   203→    active_port: &dyn ActiveProjectPort,\n   204→    base_dir: &Path,\n   205→    project_id: &ProjectId,\n   206→) -> AppResult<()> {\n   207→    if !store.project_exists(base_dir, project_id)? {\n   208→        return Err(AppError::ProjectNotFound {\n   209→            project_id: project_id.to_string(),\n   210→        });\n   211→    }\n   212→\n   213→    // Check for active run\n   214→    let run_snapshot = run_port.read_run_snapshot(base_dir, project_id)?;\n   215→    if run_snapshot.has_active_run() {\n   216→        return Err(AppError::ActiveRunDelete {\n   217→            project_id: project_id.to_string(),\n   218→        });\n   219→    }\n   220→\n   221→    // Check if this is the active project (before delete)\n   222→    let active_id = active_port.read_active_project_id(base_dir)?;\n   223→    let was_active = active_id.as_deref() == Some(project_id.as_str());\n   224→\n   225→    // Perform the actual delete\n   226→    store.delete_project(base_dir, project_id)?;\n   227→\n   228→    // Clear active-project pointer only after successful delete\n   229→    if was_active {\n   230→        active_port.clear_active_project(base_dir)?;\n   231→    }\n   232→\n   233→    Ok(())\n   234→}\n   235→\n   236→/// Get run status for the active project.\n   237→pub fn run_status(\n   238→    run_port: &dyn RunSnapshotPort,\n   239→    base_dir: &Path,\n   240→    project_id: &ProjectId,\n   241→) -> AppResult<RunStatusView> {\n   242→    let snapshot = run_port.read_run_snapshot(base_dir, project_id)?;\n   243→    Ok(queries::build_status_view(project_id.as_str(), &snapshot))\n   244→}\n   245→\n   246→/// Get run history (durable only, no runtime logs).\n   247→pub fn run_history(\n   248→    journal_port: &dyn JournalStorePort,\n   249→    artifact_port: &dyn ArtifactStorePort,\n   250→    base_dir: &Path,\n   251→    project_id: &ProjectId,\n   252→) -> AppResult<RunHistoryView> {\n   253→    let events = journal_port.read_journal(base_dir, project_id)?;\n   254→    let payloads = artifact_port.list_payloads(base_dir, project_id)?;\n   255→    let artifacts = artifact_port.list_artifacts(base_dir, project_id)?;\n   256→\n   257→    queries::validate_history_consistency(&payloads, &artifacts)?;\n   258→\n   259→    Ok(queries::build_history_view(\n   260→        project_id.as_str(),\n   261→        events,\n   262→        payloads,\n   263→        artifacts,\n   264→    ))\n   265→}\n   266→\n   267→/// Get run tail: durable history by default, with optional runtime logs.\n   268→pub fn run_tail(\n   269→    journal_port: &dyn JournalStorePort,\n   270→    artifact_port: &dyn ArtifactStorePort,\n   271→    log_port: &dyn RuntimeLogStorePort,\n   272→    base_dir: &Path,\n   273→    project_id: &ProjectId,\n   274→    include_logs: bool,\n   275→) -> AppResult<RunTailView> {\n   276→    let events = journal_port.read_journal(base_dir, project_id)?;\n   277→    let payloads = artifact_port.list_payloads(base_dir, project_id)?;\n   278→    let artifacts = artifact_port.list_artifacts(base_dir, project_id)?;\n   279→\n   280→    queries::validate_history_consistency(&payloads, &artifacts)?;\n   281→\n   282→    let runtime_logs = if include_logs {\n   283→        log_port.read_runtime_logs(base_dir, project_id)?\n   284→    } else {\n   285→        Vec::new()\n   286→    };\n   287→\n   288→    Ok(queries::build_tail_view(\n   289→        project_id.as_str(),\n   290→        events,\n   291→        payloads,\n   292→        artifacts,\n   293→        include_logs,\n   294→        runtime_logs,\n   295→    ))\n   296→}\n   297→"}]},"parent_tool_use_id":null,"session_id":"5eb81d8b-9dcb-415b-a8cb-cb111e8f40b3","uuid":"643451fa-f316-4e41-a90a-e393b479814a","tool_use_result":{"type":"text","file":{"filePath":"/root/new-ralph-burning/ralph-burning-rewrite/src/contexts/project_run_record/service.rs","content":"use std::path::Path;\n\nuse chrono::{DateTime, Utc};\n\nuse crate::shared::domain::{FlowPreset, ProjectId};\nuse crate::shared::error::{AppError, AppResult};\n\nuse super::model::{\n    ArtifactRecord, JournalEvent, JournalEventType, PayloadRecord,\n    ProjectDetail, ProjectListEntry, ProjectRecord, ProjectStatusSummary,\n    RunSnapshot, RuntimeLogEntry, SessionStore,\n};\nuse super::journal;\nuse super::queries::{\n    self, RunHistoryView, RunStatusView, RunTailView,\n};\n\n/// Port for reading and writing project records.\npub trait ProjectStorePort {\n    fn project_exists(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<bool>;\n    fn read_project_record(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<ProjectRecord>;\n    fn list_project_ids(&self, base_dir: &Path) -> AppResult<Vec<ProjectId>>;\n    fn delete_project(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<()>;\n\n    /// Atomically stage and commit a new project. If any step fails,\n    /// the project must not be visible to list/show.\n    fn create_project_atomic(\n        &self,\n        base_dir: &Path,\n        record: &ProjectRecord,\n        prompt_contents: &str,\n        run_snapshot: &RunSnapshot,\n        initial_journal_line: &str,\n        sessions: &SessionStore,\n    ) -> AppResult<()>;\n}\n\n/// Port for reading and appending journal events.\npub trait JournalStorePort {\n    fn read_journal(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<Vec<JournalEvent>>;\n    fn append_event(&self, base_dir: &Path, project_id: &ProjectId, line: &str) -> AppResult<()>;\n}\n\n/// Port for reading payload and artifact durable history.\npub trait ArtifactStorePort {\n    fn list_payloads(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<Vec<PayloadRecord>>;\n    fn list_artifacts(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<Vec<ArtifactRecord>>;\n}\n\n/// Port for reading runtime logs (separate from durable history).\npub trait RuntimeLogStorePort {\n    fn read_runtime_logs(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<Vec<RuntimeLogEntry>>;\n}\n\n/// Port for reading/writing the run snapshot.\npub trait RunSnapshotPort {\n    fn read_run_snapshot(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<RunSnapshot>;\n}\n\n/// Port for reading/clearing the active project pointer.\npub trait ActiveProjectPort {\n    fn read_active_project_id(&self, base_dir: &Path) -> AppResult<Option<String>>;\n    fn clear_active_project(&self, base_dir: &Path) -> AppResult<()>;\n}\n\n/// Input for the `project create` use case.\npub struct CreateProjectInput {\n    pub id: ProjectId,\n    pub name: String,\n    pub flow: FlowPreset,\n    pub prompt_path: String,\n    pub prompt_contents: String,\n    pub prompt_hash: String,\n    pub created_at: DateTime<Utc>,\n}\n\n/// Create a new project with all canonical files.\npub fn create_project(\n    store: &dyn ProjectStorePort,\n    journal_store: &dyn JournalStorePort,\n    base_dir: &Path,\n    input: CreateProjectInput,\n) -> AppResult<ProjectRecord> {\n    // Check for duplicate project ID\n    if store.project_exists(base_dir, &input.id)? {\n        return Err(AppError::DuplicateProject {\n            project_id: input.id.to_string(),\n        });\n    }\n\n    let record = ProjectRecord {\n        id: input.id.clone(),\n        name: input.name,\n        flow: input.flow,\n        prompt_reference: input.prompt_path,\n        prompt_hash: input.prompt_hash,\n        created_at: input.created_at,\n        status_summary: ProjectStatusSummary::Created,\n    };\n\n    let run_snapshot = RunSnapshot::initial();\n    let sessions = SessionStore::empty();\n\n    // Create the initial journal event\n    let initial_event = JournalEvent {\n        sequence: 1,\n        timestamp: input.created_at,\n        event_type: JournalEventType::ProjectCreated,\n        details: serde_json::json!({\n            \"project_id\": record.id.as_str(),\n            \"flow\": record.flow.as_str(),\n        }),\n    };\n    let journal_line = journal::serialize_event(&initial_event)?;\n\n    // Atomic creation: all files or nothing\n    store.create_project_atomic(\n        base_dir,\n        &record,\n        &input.prompt_contents,\n        &run_snapshot,\n        &journal_line,\n        &sessions,\n    )?;\n\n    // create_project_atomic writes the journal as part of the atomic init,\n    // but we don't call journal_store.append_event here because the atomic\n    // creation already wrote the initial journal line. The journal_store\n    // parameter is kept for interface consistency and future use.\n    let _ = journal_store;\n\n    Ok(record)\n}\n\n/// List all projects with summary data.\npub fn list_projects(\n    store: &dyn ProjectStorePort,\n    active_port: &dyn ActiveProjectPort,\n    base_dir: &Path,\n) -> AppResult<Vec<ProjectListEntry>> {\n    let active_id = active_port.read_active_project_id(base_dir)?;\n    let project_ids = store.list_project_ids(base_dir)?;\n\n    let mut entries = Vec::new();\n    for pid in project_ids {\n        let record = store.read_project_record(base_dir, &pid)?;\n        let is_active = active_id.as_deref() == Some(pid.as_str());\n        entries.push(ProjectListEntry {\n            id: record.id,\n            name: record.name,\n            flow: record.flow,\n            status_summary: record.status_summary,\n            created_at: record.created_at,\n            is_active,\n        });\n    }\n\n    Ok(entries)\n}\n\n/// Show detailed project information.\npub fn show_project(\n    store: &dyn ProjectStorePort,\n    run_port: &dyn RunSnapshotPort,\n    journal_port: &dyn JournalStorePort,\n    active_port: &dyn ActiveProjectPort,\n    base_dir: &Path,\n    project_id: &ProjectId,\n) -> AppResult<ProjectDetail> {\n    if !store.project_exists(base_dir, project_id)? {\n        return Err(AppError::ProjectNotFound {\n            project_id: project_id.to_string(),\n        });\n    }\n\n    let record = store.read_project_record(base_dir, project_id)?;\n    let run_snapshot = run_port.read_run_snapshot(base_dir, project_id)?;\n    let events = journal_port.read_journal(base_dir, project_id)?;\n    let journal_event_count = events.len() as u64;\n    let active_id = active_port.read_active_project_id(base_dir)?;\n    let is_active = active_id.as_deref() == Some(project_id.as_str());\n\n    // Count rollback points from journal events\n    let rollback_count = events\n        .iter()\n        .filter(|e| e.event_type == JournalEventType::RollbackCreated)\n        .count();\n\n    Ok(ProjectDetail {\n        record,\n        run_snapshot,\n        journal_event_count,\n        rollback_count,\n        is_active,\n    })\n}\n\n/// Delete a project. Fails if project has an active run.\n/// Clears active-project pointer if it pointed to the deleted project.\npub fn delete_project(\n    store: &dyn ProjectStorePort,\n    run_port: &dyn RunSnapshotPort,\n    active_port: &dyn ActiveProjectPort,\n    base_dir: &Path,\n    project_id: &ProjectId,\n) -> AppResult<()> {\n    if !store.project_exists(base_dir, project_id)? {\n        return Err(AppError::ProjectNotFound {\n            project_id: project_id.to_string(),\n        });\n    }\n\n    // Check for active run\n    let run_snapshot = run_port.read_run_snapshot(base_dir, project_id)?;\n    if run_snapshot.has_active_run() {\n        return Err(AppError::ActiveRunDelete {\n            project_id: project_id.to_string(),\n        });\n    }\n\n    // Check if this is the active project (before delete)\n    let active_id = active_port.read_active_project_id(base_dir)?;\n    let was_active = active_id.as_deref() == Some(project_id.as_str());\n\n    // Perform the actual delete\n    store.delete_project(base_dir, project_id)?;\n\n    // Clear active-project pointer only after successful delete\n    if was_active {\n        active_port.clear_active_project(base_dir)?;\n    }\n\n    Ok(())\n}\n\n/// Get run status for the active project.\npub fn run_status(\n    run_port: &dyn RunSnapshotPort,\n    base_dir: &Path,\n    project_id: &ProjectId,\n) -> AppResult<RunStatusView> {\n    let snapshot = run_port.read_run_snapshot(base_dir, project_id)?;\n    Ok(queries::build_status_view(project_id.as_str(), &snapshot))\n}\n\n/// Get run history (durable only, no runtime logs).\npub fn run_history(\n    journal_port: &dyn JournalStorePort,\n    artifact_port: &dyn ArtifactStorePort,\n    base_dir: &Path,\n    project_id: &ProjectId,\n) -> AppResult<RunHistoryView> {\n    let events = journal_port.read_journal(base_dir, project_id)?;\n    let payloads = artifact_port.list_payloads(base_dir, project_id)?;\n    let artifacts = artifact_port.list_artifacts(base_dir, project_id)?;\n\n    queries::validate_history_consistency(&payloads, &artifacts)?;\n\n    Ok(queries::build_history_view(\n        project_id.as_str(),\n        events,\n        payloads,\n        artifacts,\n    ))\n}\n\n/// Get run tail: durable history by default, with optional runtime logs.\npub fn run_tail(\n    journal_port: &dyn JournalStorePort,\n    artifact_port: &dyn ArtifactStorePort,\n    log_port: &dyn RuntimeLogStorePort,\n    base_dir: &Path,\n    project_id: &ProjectId,\n    include_logs: bool,\n) -> AppResult<RunTailView> {\n    let events = journal_port.read_journal(base_dir, project_id)?;\n    let payloads = artifact_port.list_payloads(base_dir, project_id)?;\n    let artifacts = artifact_port.list_artifacts(base_dir, project_id)?;\n\n    queries::validate_history_consistency(&payloads, &artifacts)?;\n\n    let runtime_logs = if include_logs {\n        log_port.read_runtime_logs(base_dir, project_id)?\n    } else {\n        Vec::new()\n    };\n\n    Ok(queries::build_tail_view(\n        project_id.as_str(),\n        events,\n        payloads,\n        artifacts,\n        include_logs,\n        runtime_logs,\n    ))\n}\n","numLines":297,"startLine":1,"totalLines":297}}}
