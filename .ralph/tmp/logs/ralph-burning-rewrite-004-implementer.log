{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_019uHQVN7msuqHr14ZHc9iD3","type":"tool_result","content":"     1→use std::path::Path;\n     2→\n     3→use chrono::{TimeZone, Utc};\n     4→\n     5→use ralph_burning::contexts::project_run_record::model::*;\n     6→use ralph_burning::contexts::project_run_record::service::*;\n     7→use ralph_burning::shared::domain::{FlowPreset, ProjectId};\n     8→use ralph_burning::shared::error::{AppError, AppResult};\n     9→\n    10→// ── Fake implementations of ports for service-level testing ──\n    11→\n    12→struct FakeProjectStore {\n    13→    existing_ids: Vec<String>,\n    14→}\n    15→\n    16→impl FakeProjectStore {\n    17→    fn empty() -> Self {\n    18→        Self {\n    19→            existing_ids: Vec::new(),\n    20→        }\n    21→    }\n    22→\n    23→    fn with_existing(ids: &[&str]) -> Self {\n    24→        Self {\n    25→            existing_ids: ids.iter().map(|s| s.to_string()).collect(),\n    26→        }\n    27→    }\n    28→}\n    29→\n    30→impl ProjectStorePort for FakeProjectStore {\n    31→    fn project_exists(&self, _base_dir: &Path, project_id: &ProjectId) -> AppResult<bool> {\n    32→        Ok(self.existing_ids.contains(&project_id.to_string()))\n    33→    }\n    34→\n    35→    fn read_project_record(\n    36→        &self,\n    37→        _base_dir: &Path,\n    38→        project_id: &ProjectId,\n    39→    ) -> AppResult<ProjectRecord> {\n    40→        if !self.existing_ids.contains(&project_id.to_string()) {\n    41→            return Err(AppError::ProjectNotFound {\n    42→                project_id: project_id.to_string(),\n    43→            });\n    44→        }\n    45→        Ok(make_project_record(project_id.as_str()))\n    46→    }\n    47→\n    48→    fn list_project_ids(&self, _base_dir: &Path) -> AppResult<Vec<ProjectId>> {\n    49→        self.existing_ids\n    50→            .iter()\n    51→            .map(|id| ProjectId::new(id.as_str()))\n    52→            .collect()\n    53→    }\n    54→\n    55→    fn delete_project(&self, _base_dir: &Path, project_id: &ProjectId) -> AppResult<()> {\n    56→        if !self.existing_ids.contains(&project_id.to_string()) {\n    57→            return Err(AppError::ProjectNotFound {\n    58→                project_id: project_id.to_string(),\n    59→            });\n    60→        }\n    61→        Ok(())\n    62→    }\n    63→\n    64→    fn create_project_atomic(\n    65→        &self,\n    66→        _base_dir: &Path,\n    67→        _record: &ProjectRecord,\n    68→        _prompt_contents: &str,\n    69→        _run_snapshot: &RunSnapshot,\n    70→        _initial_journal_line: &str,\n    71→        _sessions: &SessionStore,\n    72→    ) -> AppResult<()> {\n    73→        Ok(())\n    74→    }\n    75→}\n    76→\n    77→struct FakeJournalStore;\n    78→\n    79→impl JournalStorePort for FakeJournalStore {\n    80→    fn read_journal(\n    81→        &self,\n    82→        _base_dir: &Path,\n    83→        _project_id: &ProjectId,\n    84→    ) -> AppResult<Vec<JournalEvent>> {\n    85→        Ok(vec![make_project_created_event()])\n    86→    }\n    87→\n    88→    fn append_event(\n    89→        &self,\n    90→        _base_dir: &Path,\n    91→        _project_id: &ProjectId,\n    92→        _line: &str,\n    93→    ) -> AppResult<()> {\n    94→        Ok(())\n    95→    }\n    96→}\n    97→\n    98→struct FakeRunSnapshotStore {\n    99→    has_active_run: bool,\n   100→}\n   101→\n   102→impl FakeRunSnapshotStore {\n   103→    fn no_run() -> Self {\n   104→        Self {\n   105→            has_active_run: false,\n   106→        }\n   107→    }\n   108→\n   109→    fn active_run() -> Self {\n   110→        Self {\n   111→            has_active_run: true,\n   112→        }\n   113→    }\n   114→}\n   115→\n   116→impl RunSnapshotPort for FakeRunSnapshotStore {\n   117→    fn read_run_snapshot(\n   118→        &self,\n   119→        _base_dir: &Path,\n   120→        _project_id: &ProjectId,\n   121→    ) -> AppResult<RunSnapshot> {\n   122→        if self.has_active_run {\n   123→            Ok(RunSnapshot {\n   124→                active_run: Some(ActiveRun {\n   125→                    run_id: \"run-1\".to_owned(),\n   126→                    stage_cursor: ralph_burning::shared::domain::StageCursor::initial(\n   127→                        ralph_burning::shared::domain::StageId::Planning,\n   128→                    ),\n   129→                    started_at: test_timestamp(),\n   130→                }),\n   131→                status: RunStatus::Running,\n   132→                status_summary: \"running\".to_owned(),\n   133→            })\n   134→        } else {\n   135→            Ok(RunSnapshot::initial())\n   136→        }\n   137→    }\n   138→}\n   139→\n   140→struct FakeActiveProjectStore {\n   141→    active_id: Option<String>,\n   142→}\n   143→\n   144→impl FakeActiveProjectStore {\n   145→    fn none() -> Self {\n   146→        Self { active_id: None }\n   147→    }\n   148→\n   149→    fn with_active(id: &str) -> Self {\n   150→        Self {\n   151→            active_id: Some(id.to_owned()),\n   152→        }\n   153→    }\n   154→}\n   155→\n   156→impl ActiveProjectPort for FakeActiveProjectStore {\n   157→    fn read_active_project_id(&self, _base_dir: &Path) -> AppResult<Option<String>> {\n   158→        Ok(self.active_id.clone())\n   159→    }\n   160→\n   161→    fn clear_active_project(&self, _base_dir: &Path) -> AppResult<()> {\n   162→        Ok(())\n   163→    }\n   164→}\n   165→\n   166→// ── Helpers ──\n   167→\n   168→fn test_timestamp() -> chrono::DateTime<Utc> {\n   169→    Utc.with_ymd_and_hms(2026, 3, 11, 19, 0, 0)\n   170→        .single()\n   171→        .expect(\"valid timestamp\")\n   172→}\n   173→\n   174→fn make_project_record(id: &str) -> ProjectRecord {\n   175→    ProjectRecord {\n   176→        id: ProjectId::new(id).unwrap(),\n   177→        name: format!(\"Project {id}\"),\n   178→        flow: FlowPreset::Standard,\n   179→        prompt_reference: \"prompt.md\".to_owned(),\n   180→        prompt_hash: \"abc123\".to_owned(),\n   181→        created_at: test_timestamp(),\n   182→        status_summary: ProjectStatusSummary::Created,\n   183→    }\n   184→}\n   185→\n   186→fn make_project_created_event() -> JournalEvent {\n   187→    JournalEvent {\n   188→        sequence: 1,\n   189→        timestamp: test_timestamp(),\n   190→        event_type: JournalEventType::ProjectCreated,\n   191→        details: serde_json::json!({\"project_id\": \"alpha\", \"flow\": \"standard\"}),\n   192→    }\n   193→}\n   194→\n   195→fn dummy_base_dir() -> std::path::PathBuf {\n   196→    std::path::PathBuf::from(\"/tmp/test\")\n   197→}\n   198→\n   199→// ── Domain Tests ──\n   200→\n   201→#[test]\n   202→fn run_snapshot_initial_has_no_active_run() {\n   203→    let snapshot = RunSnapshot::initial();\n   204→    assert!(!snapshot.has_active_run());\n   205→    assert_eq!(snapshot.status, RunStatus::NotStarted);\n   206→}\n   207→\n   208→#[test]\n   209→fn session_store_empty_has_no_sessions() {\n   210→    let store = SessionStore::empty();\n   211→    assert!(store.sessions.is_empty());\n   212→}\n   213→\n   214→#[test]\n   215→fn project_record_flow_is_immutable_after_creation() {\n   216→    let record = make_project_record(\"alpha\");\n   217→    assert_eq!(record.flow, FlowPreset::Standard);\n   218→    // Flow is a plain field with no setter — immutability enforced by\n   219→    // not providing mutation methods on ProjectRecord.\n   220→}\n   221→\n   222→#[test]\n   223→fn journal_event_types_serialize_to_snake_case() {\n   224→    let event = make_project_created_event();\n   225→    let json = serde_json::to_string(&event).expect(\"serialize\");\n   226→    assert!(json.contains(\"\\\"project_created\\\"\"));\n   227→}\n   228→\n   229→// ── Service Tests with Fake Ports ──\n   230→\n   231→#[test]\n   232→fn create_project_succeeds_with_valid_input() {\n   233→    let store = FakeProjectStore::empty();\n   234→    let journal_store = FakeJournalStore;\n   235→    let base_dir = dummy_base_dir();\n   236→\n   237→    let input = CreateProjectInput {\n   238→        id: ProjectId::new(\"alpha\").unwrap(),\n   239→        name: \"Alpha Project\".to_owned(),\n   240→        flow: FlowPreset::Standard,\n   241→        prompt_path: \"prompt.md\".to_owned(),\n   242→        prompt_contents: \"# My prompt\\nDo something.\".to_owned(),\n   243→        prompt_hash: \"hash123\".to_owned(),\n   244→        created_at: test_timestamp(),\n   245→    };\n   246→\n   247→    let result = create_project(&store, &journal_store, &base_dir, input);\n   248→    assert!(result.is_ok());\n   249→\n   250→    let record = result.unwrap();\n   251→    assert_eq!(record.id.as_str(), \"alpha\");\n   252→    assert_eq!(record.flow, FlowPreset::Standard);\n   253→    assert_eq!(record.status_summary, ProjectStatusSummary::Created);\n   254→}\n   255→\n   256→#[test]\n   257→fn create_project_fails_on_duplicate_id() {\n   258→    let store = FakeProjectStore::with_existing(&[\"alpha\"]);\n   259→    let journal_store = FakeJournalStore;\n   260→    let base_dir = dummy_base_dir();\n   261→\n   262→    let input = CreateProjectInput {\n   263→        id: ProjectId::new(\"alpha\").unwrap(),\n   264→        name: \"Alpha Again\".to_owned(),\n   265→        flow: FlowPreset::Standard,\n   266→        prompt_path: \"prompt.md\".to_owned(),\n   267→        prompt_contents: \"content\".to_owned(),\n   268→        prompt_hash: \"hash\".to_owned(),\n   269→        created_at: test_timestamp(),\n   270→    };\n   271→\n   272→    let result = create_project(&store, &journal_store, &base_dir, input);\n   273→    assert!(result.is_err());\n   274→    assert!(matches!(\n   275→        result.unwrap_err(),\n   276→        AppError::DuplicateProject { .. }\n   277→    ));\n   278→}\n   279→\n   280→#[test]\n   281→fn list_projects_returns_entries_with_active_flag() {\n   282→    let store = FakeProjectStore::with_existing(&[\"alpha\", \"beta\"]);\n   283→    let active_store = FakeActiveProjectStore::with_active(\"alpha\");\n   284→    let base_dir = dummy_base_dir();\n   285→\n   286→    let entries = list_projects(&store, &active_store, &base_dir).unwrap();\n   287→    assert_eq!(entries.len(), 2);\n   288→\n   289→    let alpha = entries.iter().find(|e| e.id.as_str() == \"alpha\").unwrap();\n   290→    assert!(alpha.is_active);\n   291→\n   292→    let beta = entries.iter().find(|e| e.id.as_str() == \"beta\").unwrap();\n   293→    assert!(!beta.is_active);\n   294→}\n   295→\n   296→#[test]\n   297→fn list_projects_with_no_active_project() {\n   298→    let store = FakeProjectStore::with_existing(&[\"alpha\"]);\n   299→    let active_store = FakeActiveProjectStore::none();\n   300→    let base_dir = dummy_base_dir();\n   301→\n   302→    let entries = list_projects(&store, &active_store, &base_dir).unwrap();\n   303→    assert_eq!(entries.len(), 1);\n   304→    assert!(!entries[0].is_active);\n   305→}\n   306→\n   307→#[test]\n   308→fn show_project_returns_detail() {\n   309→    let store = FakeProjectStore::with_existing(&[\"alpha\"]);\n   310→    let run_store = FakeRunSnapshotStore::no_run();\n   311→    let journal_store = FakeJournalStore;\n   312→    let active_store = FakeActiveProjectStore::with_active(\"alpha\");\n   313→    let base_dir = dummy_base_dir();\n   314→    let pid = ProjectId::new(\"alpha\").unwrap();\n   315→\n   316→    let detail =\n   317→        show_project(&store, &run_store, &journal_store, &active_store, &base_dir, &pid).unwrap();\n   318→\n   319→    assert_eq!(detail.record.id.as_str(), \"alpha\");\n   320→    assert!(detail.is_active);\n   321→    assert_eq!(detail.journal_event_count, 1);\n   322→    assert!(!detail.run_snapshot.has_active_run());\n   323→}\n   324→\n   325→#[test]\n   326→fn show_project_fails_for_missing_project() {\n   327→    let store = FakeProjectStore::empty();\n   328→    let run_store = FakeRunSnapshotStore::no_run();\n   329→    let journal_store = FakeJournalStore;\n   330→    let active_store = FakeActiveProjectStore::none();\n   331→    let base_dir = dummy_base_dir();\n   332→    let pid = ProjectId::new(\"missing\").unwrap();\n   333→\n   334→    let result =\n   335→        show_project(&store, &run_store, &journal_store, &active_store, &base_dir, &pid);\n   336→    assert!(matches!(\n   337→        result.unwrap_err(),\n   338→        AppError::ProjectNotFound { .. }\n   339→    ));\n   340→}\n   341→\n   342→#[test]\n   343→fn delete_project_succeeds_when_no_active_run() {\n   344→    let store = FakeProjectStore::with_existing(&[\"alpha\"]);\n   345→    let run_store = FakeRunSnapshotStore::no_run();\n   346→    let active_store = FakeActiveProjectStore::none();\n   347→    let base_dir = dummy_base_dir();\n   348→    let pid = ProjectId::new(\"alpha\").unwrap();\n   349→\n   350→    let result = delete_project(&store, &run_store, &active_store, &base_dir, &pid);\n   351→    assert!(result.is_ok());\n   352→}\n   353→\n   354→#[test]\n   355→fn delete_project_fails_with_active_run() {\n   356→    let store = FakeProjectStore::with_existing(&[\"alpha\"]);\n   357→    let run_store = FakeRunSnapshotStore::active_run();\n   358→    let active_store = FakeActiveProjectStore::none();\n   359→    let base_dir = dummy_base_dir();\n   360→    let pid = ProjectId::new(\"alpha\").unwrap();\n   361→\n   362→    let result = delete_project(&store, &run_store, &active_store, &base_dir, &pid);\n   363→    assert!(matches!(\n   364→        result.unwrap_err(),\n   365→        AppError::ActiveRunDelete { .. }\n   366→    ));\n   367→}\n   368→\n   369→#[test]\n   370→fn delete_project_fails_for_missing_project() {\n   371→    let store = FakeProjectStore::empty();\n   372→    let run_store = FakeRunSnapshotStore::no_run();\n   373→    let active_store = FakeActiveProjectStore::none();\n   374→    let base_dir = dummy_base_dir();\n   375→    let pid = ProjectId::new(\"missing\").unwrap();\n   376→\n   377→    let result = delete_project(&store, &run_store, &active_store, &base_dir, &pid);\n   378→    assert!(matches!(\n   379→        result.unwrap_err(),\n   380→        AppError::ProjectNotFound { .. }\n   381→    ));\n   382→}\n   383→\n   384→#[test]\n   385→fn run_status_reports_not_started_when_no_active_run() {\n   386→    let run_store = FakeRunSnapshotStore::no_run();\n   387→    let base_dir = dummy_base_dir();\n   388→    let pid = ProjectId::new(\"alpha\").unwrap();\n   389→\n   390→    let status = run_status(&run_store, &base_dir, &pid).unwrap();\n   391→    assert_eq!(status.status, \"not started\");\n   392→    assert!(status.stage.is_none());\n   393→    assert!(status.cycle.is_none());\n   394→}\n   395→\n   396→#[test]\n   397→fn run_status_reports_running_with_stage_cursor() {\n   398→    let run_store = FakeRunSnapshotStore::active_run();\n   399→    let base_dir = dummy_base_dir();\n   400→    let pid = ProjectId::new(\"alpha\").unwrap();\n   401→\n   402→    let status = run_status(&run_store, &base_dir, &pid).unwrap();\n   403→    assert_eq!(status.status, \"running\");\n   404→    assert_eq!(status.stage, Some(\"planning\".to_owned()));\n   405→    assert_eq!(status.cycle, Some(1));\n   406→}\n   407→"}]},"parent_tool_use_id":"toolu_017r2pi3xTD6qbkY4thKztbt","session_id":"3640e08e-b88d-40cb-b39d-a6d9ec8d8fb8","uuid":"4778281d-8b27-49b0-8708-6fb6a75b1ed9"}
