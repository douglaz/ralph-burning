{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0139dbPXw2jPsDv6D6B9hn8R","type":"tool_result","content":"     1→use std::fs;\n     2→\n     3→use ralph_burning::adapters::fs::FileSystem;\n     4→use ralph_burning::contexts::workspace_governance::{\n     5→    resolve_active_project, set_active_project, WORKSPACE_DIR,\n     6→};\n     7→use ralph_burning::shared::domain::ProjectId;\n     8→use ralph_burning::shared::error::AppError;\n     9→use tempfile::tempdir;\n    10→\n    11→use super::workspace_test::initialize_workspace_fixture;\n    12→\n    13→#[test]\n    14→fn resolve_active_project_fails_when_pointer_is_missing() {\n    15→    let temp_dir = tempdir().expect(\"create temp dir\");\n    16→    initialize_workspace_fixture(temp_dir.path());\n    17→\n    18→    let error = resolve_active_project(temp_dir.path()).expect_err(\"missing active project\");\n    19→\n    20→    assert!(matches!(error, AppError::NoActiveProject));\n    21→}\n    22→\n    23→#[test]\n    24→fn set_active_project_writes_pointer_and_resolves_project() {\n    25→    let temp_dir = tempdir().expect(\"create temp dir\");\n    26→    initialize_workspace_fixture(temp_dir.path());\n    27→    create_project_fixture(temp_dir.path(), \"alpha\");\n    28→\n    29→    let project_id = ProjectId::new(\"alpha\").expect(\"project id\");\n    30→    set_active_project(temp_dir.path(), &project_id).expect(\"set active project\");\n    31→\n    32→    let active_project = FileSystem::read_active_project(&temp_dir.path().join(WORKSPACE_DIR))\n    33→        .expect(\"read active project\");\n    34→    assert_eq!(Some(\"alpha\".to_owned()), active_project);\n    35→\n    36→    let resolved = resolve_active_project(temp_dir.path()).expect(\"resolve active project\");\n    37→    assert_eq!(\"alpha\", resolved.as_str());\n    38→}\n    39→\n    40→#[test]\n    41→fn resolve_active_project_trims_newlines() {\n    42→    let temp_dir = tempdir().expect(\"create temp dir\");\n    43→    initialize_workspace_fixture(temp_dir.path());\n    44→    create_project_fixture(temp_dir.path(), \"alpha\");\n    45→    fs::write(\n    46→        temp_dir.path().join(\".ralph-burning/active-project\"),\n    47→        \"alpha\\n\",\n    48→    )\n    49→    .expect(\"write active project\");\n    50→\n    51→    let resolved = resolve_active_project(temp_dir.path()).expect(\"resolve active project\");\n    52→\n    53→    assert_eq!(\"alpha\", resolved.as_str());\n    54→}\n    55→\n    56→#[test]\n    57→fn set_active_project_rejects_missing_projects() {\n    58→    let temp_dir = tempdir().expect(\"create temp dir\");\n    59→    initialize_workspace_fixture(temp_dir.path());\n    60→    let project_id = ProjectId::new(\"missing\").expect(\"project id\");\n    61→\n    62→    let error = set_active_project(temp_dir.path(), &project_id).expect_err(\"missing project\");\n    63→\n    64→    assert!(matches!(error, AppError::ProjectNotFound { .. }));\n    65→}\n    66→\n    67→#[test]\n    68→fn resolve_active_project_rejects_path_like_pointer_values() {\n    69→    let temp_dir = tempdir().expect(\"create temp dir\");\n    70→    initialize_workspace_fixture(temp_dir.path());\n    71→    fs::write(\n    72→        temp_dir.path().join(\".ralph-burning/active-project\"),\n    73→        \"../escape\\n\",\n    74→    )\n    75→    .expect(\"write active project\");\n    76→\n    77→    let error =\n    78→        resolve_active_project(temp_dir.path()).expect_err(\"path-like active project should fail\");\n    79→\n    80→    assert!(matches!(error, AppError::InvalidIdentifier { .. }));\n    81→}\n    82→\n    83→fn create_project_fixture(base_dir: &std::path::Path, project_id: &str) {\n    84→    let project_root = base_dir.join(\".ralph-burning/projects\").join(project_id);\n    85→    fs::create_dir_all(&project_root).expect(\"create project directory\");\n    86→    fs::write(project_root.join(\"project.toml\"), \"id = \\\"fixture\\\"\\n\").expect(\"write project\");\n    87→}\n    88→"}]},"parent_tool_use_id":"toolu_012QdgmdBxgtkt4tovj3QwR9","session_id":"84e4772c-0822-4fc6-b1d7-1c1f7c7f3e3a","uuid":"8e246270-a41a-4a10-bf56-62a970b726f0"}
