{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_011xk4RzmWFXUiXEX6Tt8NzX","type":"tool_result","content":"     1→use std::env;\n     2→use std::fs::{self, OpenOptions};\n     3→use std::io::Write;\n     4→use std::path::{Path, PathBuf};\n     5→use std::process::Command;\n     6→use std::time::{SystemTime, UNIX_EPOCH};\n     7→\n     8→use crate::contexts::project_run_record::journal;\n     9→use crate::contexts::project_run_record::model::{\n    10→    ArtifactRecord, JournalEvent, PayloadRecord, ProjectRecord, RunSnapshot,\n    11→    RuntimeLogEntry, SessionStore,\n    12→};\n    13→use crate::contexts::project_run_record::service::{\n    14→    ActiveProjectPort, ArtifactStorePort, JournalStorePort, ProjectStorePort,\n    15→    RuntimeLogStorePort, RunSnapshotPort,\n    16→};\n    17→use crate::shared::domain::{ProjectId, WorkspaceConfig};\n    18→use crate::shared::error::{AppError, AppResult};\n    19→\n    20→const ACTIVE_PROJECT_FILE: &str = \"active-project\";\n    21→const WORKSPACE_DIR: &str = \".ralph-burning\";\n    22→const PROJECTS_DIR: &str = \"projects\";\n    23→const PROJECT_CONFIG_FILE: &str = \"project.toml\";\n    24→const RUN_FILE: &str = \"run.json\";\n    25→const JOURNAL_FILE: &str = \"journal.ndjson\";\n    26→const SESSIONS_FILE: &str = \"sessions.json\";\n    27→const PROMPT_FILE: &str = \"prompt.md\";\n    28→\n    29→/// Required subdirectories inside a project.\n    30→const PROJECT_SUBDIRS: &[&str] = &[\n    31→    \"history/payloads\",\n    32→    \"history/artifacts\",\n    33→    \"runtime/logs\",\n    34→    \"runtime/backend\",\n    35→    \"runtime/temp\",\n    36→    \"amendments\",\n    37→    \"rollback\",\n    38→];\n    39→\n    40→pub struct FileSystem;\n    41→\n    42→impl FileSystem {\n    43→    pub fn create_workspace(\n    44→        workspace_root: &Path,\n    45→        workspace_config: &str,\n    46→        required_directories: &[&str],\n    47→    ) -> AppResult<()> {\n    48→        fs::create_dir_all(workspace_root)?;\n    49→\n    50→        for directory in required_directories {\n    51→            fs::create_dir_all(workspace_root.join(directory))?;\n    52→        }\n    53→\n    54→        Self::write_atomic(&workspace_root.join(\"workspace.toml\"), workspace_config)?;\n    55→        Ok(())\n    56→    }\n    57→\n    58→    pub fn read_to_string(path: &Path) -> AppResult<String> {\n    59→        Ok(fs::read_to_string(path)?)\n    60→    }\n    61→\n    62→    pub fn write_atomic(path: &Path, contents: &str) -> AppResult<()> {\n    63→        let parent = path.parent().ok_or_else(|| {\n    64→            AppError::Io(std::io::Error::new(\n    65→                std::io::ErrorKind::InvalidInput,\n    66→                format!(\"path '{}' has no parent directory\", path.display()),\n    67→            ))\n    68→        })?;\n    69→        fs::create_dir_all(parent)?;\n    70→\n    71→        let timestamp = SystemTime::now()\n    72→            .duration_since(UNIX_EPOCH)\n    73→            .map(|duration| duration.as_nanos())\n    74→            .unwrap_or_default();\n    75→        let temp_path = parent.join(format!(\n    76→            \".{}.{}.{}.tmp\",\n    77→            path.file_name()\n    78→                .and_then(|value| value.to_str())\n    79→                .unwrap_or(\"workspace\"),\n    80→            std::process::id(),\n    81→            timestamp\n    82→        ));\n    83→\n    84→        let mut file = OpenOptions::new()\n    85→            .create_new(true)\n    86→            .write(true)\n    87→            .open(&temp_path)?;\n    88→        file.write_all(contents.as_bytes())?;\n    89→        file.sync_all()?;\n    90→        drop(file);\n    91→\n    92→        if let Err(error) = fs::rename(&temp_path, path) {\n    93→            let _ = fs::remove_file(&temp_path);\n    94→            return Err(error.into());\n    95→        }\n    96→\n    97→        Ok(())\n    98→    }\n    99→\n   100→    pub fn render_workspace_config(config: &WorkspaceConfig) -> AppResult<String> {\n   101→        Ok(toml::to_string_pretty(config)?)\n   102→    }\n   103→\n   104→    pub fn read_active_project(workspace_root: &Path) -> AppResult<Option<String>> {\n   105→        let path = workspace_root.join(ACTIVE_PROJECT_FILE);\n   106→        match fs::read_to_string(path) {\n   107→            Ok(raw) => {\n   108→                let trimmed = raw.trim();\n   109→                if trimmed.is_empty() {\n   110→                    Ok(None)\n   111→                } else {\n   112→                    Ok(Some(trimmed.to_owned()))\n   113→                }\n   114→            }\n   115→            Err(error) if error.kind() == std::io::ErrorKind::NotFound => Ok(None),\n   116→            Err(error) => Err(error.into()),\n   117→        }\n   118→    }\n   119→\n   120→    pub fn write_active_project(workspace_root: &Path, project_id: &str) -> AppResult<()> {\n   121→        Self::write_atomic(&workspace_root.join(ACTIVE_PROJECT_FILE), project_id)\n   122→    }\n   123→\n   124→    pub fn open_editor(path: &Path) -> AppResult<()> {\n   125→        let editor = env::var(\"EDITOR\")\n   126→            .ok()\n   127→            .filter(|value| !value.trim().is_empty())\n   128→            .or_else(|| {\n   129→                env::var(\"VISUAL\")\n   130→                    .ok()\n   131→                    .filter(|value| !value.trim().is_empty())\n   132→            })\n   133→            .unwrap_or_else(|| \"vi\".to_owned());\n   134→\n   135→        let mut parts = editor.split_whitespace();\n   136→        let program = parts.next().ok_or_else(|| AppError::EditorFailed {\n   137→            editor: editor.clone(),\n   138→            details: \": empty editor command\".to_owned(),\n   139→        })?;\n   140→        let status = Command::new(program).args(parts).arg(path).status()?;\n   141→\n   142→        if status.success() {\n   143→            Ok(())\n   144→        } else {\n   145→            let details = match status.code() {\n   146→                Some(code) => format!(\" with exit code {code}\"),\n   147→                None => \" after being terminated by a signal\".to_owned(),\n   148→            };\n   149→            Err(AppError::EditorFailed { editor, details })\n   150→        }\n   151→    }\n   152→\n   153→    /// Compute a simple hash of content for prompt integrity tracking.\n   154→    pub fn prompt_hash(contents: &str) -> String {\n   155→        use std::collections::hash_map::DefaultHasher;\n   156→        use std::hash::{Hash, Hasher};\n   157→        let mut hasher = DefaultHasher::new();\n   158→        contents.hash(&mut hasher);\n   159→        format!(\"{:016x}\", hasher.finish())\n   160→    }\n   161→\n   162→    // ── Helpers for project filesystem layout ──\n   163→\n   164→    fn workspace_root_path(base_dir: &Path) -> PathBuf {\n   165→        base_dir.join(WORKSPACE_DIR)\n   166→    }\n   167→\n   168→    fn project_root(base_dir: &Path, project_id: &ProjectId) -> PathBuf {\n   169→        Self::workspace_root_path(base_dir)\n   170→            .join(PROJECTS_DIR)\n   171→            .join(project_id.as_str())\n   172→    }\n   173→\n   174→    fn append_line(path: &Path, line: &str) -> AppResult<()> {\n   175→        let parent = path.parent().ok_or_else(|| {\n   176→            AppError::Io(std::io::Error::new(\n   177→                std::io::ErrorKind::InvalidInput,\n   178→                format!(\"path '{}' has no parent directory\", path.display()),\n   179→            ))\n   180→        })?;\n   181→        fs::create_dir_all(parent)?;\n   182→\n   183→        let mut file = OpenOptions::new()\n   184→            .create(true)\n   185→            .append(true)\n   186→            .open(path)?;\n   187→        writeln!(file, \"{}\", line)?;\n   188→        file.sync_all()?;\n   189→        Ok(())\n   190→    }\n   191→}\n   192→\n   193→/// Filesystem-backed implementation of `ProjectStorePort`.\n   194→pub struct FsProjectStore;\n   195→\n   196→impl ProjectStorePort for FsProjectStore {\n   197→    fn project_exists(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<bool> {\n   198→        let project_root = FileSystem::project_root(base_dir, project_id);\n   199→        if !project_root.is_dir() {\n   200→            return Ok(false);\n   201→        }\n   202→        if !project_root.join(PROJECT_CONFIG_FILE).is_file() {\n   203→            return Err(AppError::CorruptRecord {\n   204→                file: format!(\"projects/{}/project.toml\", project_id),\n   205→                details: \"project directory exists but canonical project.toml is missing\"\n   206→                    .to_owned(),\n   207→            });\n   208→        }\n   209→        Ok(true)\n   210→    }\n   211→\n   212→    fn read_project_record(\n   213→        &self,\n   214→        base_dir: &Path,\n   215→        project_id: &ProjectId,\n   216→    ) -> AppResult<ProjectRecord> {\n   217→        let project_root = FileSystem::project_root(base_dir, project_id);\n   218→        let path = project_root.join(PROJECT_CONFIG_FILE);\n   219→        let raw = fs::read_to_string(&path).map_err(|e| {\n   220→            if e.kind() == std::io::ErrorKind::NotFound {\n   221→                if project_root.is_dir() {\n   222→                    // Directory exists but project.toml is missing — corruption\n   223→                    AppError::CorruptRecord {\n   224→                        file: format!(\"projects/{}/project.toml\", project_id),\n   225→                        details: \"project directory exists but canonical project.toml is missing\"\n   226→                            .to_owned(),\n   227→                    }\n   228→                } else {\n   229→                    AppError::ProjectNotFound {\n   230→                        project_id: project_id.to_string(),\n   231→                    }\n   232→                }\n   233→            } else {\n   234→                e.into()\n   235→            }\n   236→        })?;\n   237→        toml::from_str(&raw).map_err(|e| AppError::CorruptRecord {\n   238→            file: format!(\"projects/{}/project.toml\", project_id),\n   239→            details: e.to_string(),\n   240→        })\n   241→    }\n   242→\n   243→    fn list_project_ids(&self, base_dir: &Path) -> AppResult<Vec<ProjectId>> {\n   244→        let projects_dir = FileSystem::workspace_root_path(base_dir).join(PROJECTS_DIR);\n   245→        if !projects_dir.is_dir() {\n   246→            return Ok(Vec::new());\n   247→        }\n   248→\n   249→        let mut ids = Vec::new();\n   250→        for entry in fs::read_dir(&projects_dir)? {\n   251→            let entry = entry?;\n   252→            if !entry.file_type()?.is_dir() {\n   253→                continue;\n   254→            }\n   255→            let name = entry.file_name();\n   256→            let name_str = name.to_string_lossy();\n   257→            // Skip hidden directories (staging/trash from transactional operations)\n   258→            if name_str.starts_with('.') {\n   259→                continue;\n   260→            }\n   261→            if let Ok(pid) = ProjectId::new(name_str.as_ref()) {\n   262→                if !entry.path().join(PROJECT_CONFIG_FILE).is_file() {\n   263→                    return Err(AppError::CorruptRecord {\n   264→                        file: format!(\"projects/{}/project.toml\", name_str),\n   265→                        details:\n   266→                            \"project directory exists but canonical project.toml is missing\"\n   267→                                .to_owned(),\n   268→                    });\n   269→                }\n   270→                ids.push(pid);\n   271→            }\n   272→        }\n   273→\n   274→        ids.sort_by(|a, b| a.as_str().cmp(b.as_str()));\n   275→        Ok(ids)\n   276→    }\n   277→\n   278→    fn delete_project(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<()> {\n   279→        let project_root = FileSystem::project_root(base_dir, project_id);\n   280→        if !project_root.is_dir() {\n   281→            return Err(AppError::ProjectNotFound {\n   282→                project_id: project_id.to_string(),\n   283→            });\n   284→        }\n   285→\n   286→        // Transactional delete: rename to a trash path first, then remove.\n   287→        // If removal fails, rename back so the project remains addressable.\n   288→        let trash_name = format!(\".{}.deleting.{}\", project_id, std::process::id());\n   289→        let trash_path = project_root\n   290→            .parent()\n   291→            .expect(\"project root has parent\")\n   292→            .join(&trash_name);\n   293→\n   294→        // Phase 1: atomic rename to trash location\n   295→        fs::rename(&project_root, &trash_path)?;\n   296→\n   297→        // Phase 2: remove the trash directory\n   298→        if let Err(remove_err) = fs::remove_dir_all(&trash_path) {\n   299→            // Removal failed — try to restore the project to its original path\n   300→            if let Err(_restore_err) = fs::rename(&trash_path, &project_root) {\n   301→                // Restore also failed; return the original removal error.\n   302→                // The project is stranded at the trash path but not partially deleted.\n   303→            }\n   304→            return Err(remove_err.into());\n   305→        }\n   306→\n   307→        Ok(())\n   308→    }\n   309→\n   310→    fn create_project_atomic(\n   311→        &self,\n   312→        base_dir: &Path,\n   313→        record: &ProjectRecord,\n   314→        prompt_contents: &str,\n   315→        run_snapshot: &RunSnapshot,\n   316→        initial_journal_line: &str,\n   317→        sessions: &SessionStore,\n   318→    ) -> AppResult<()> {\n   319→        let project_root = FileSystem::project_root(base_dir, &record.id);\n   320→\n   321→        // Stage into a temporary directory alongside the final location\n   322→        let staging_name = format!(\".{}.staging.{}\", record.id, std::process::id());\n   323→        let staging_root = project_root\n   324→            .parent()\n   325→            .expect(\"project root has parent\")\n   326→            .join(&staging_name);\n   327→\n   328→        // Clean up any leftover staging dir\n   329→        if staging_root.exists() {\n   330→            fs::remove_dir_all(&staging_root)?;\n   331→        }\n   332→\n   333→        // Create staging directory and all subdirs\n   334→        fs::create_dir_all(&staging_root)?;\n   335→        for subdir in PROJECT_SUBDIRS {\n   336→            fs::create_dir_all(staging_root.join(subdir))?;\n   337→        }\n   338→\n   339→        // Write all canonical files into staging\n   340→        let write_result = (|| -> AppResult<()> {\n   341→            // project.toml\n   342→            let project_toml = toml::to_string_pretty(record).map_err(|e| {\n   343→                AppError::Io(std::io::Error::other(e.to_string()))\n   344→            })?;\n   345→            fs::write(staging_root.join(PROJECT_CONFIG_FILE), project_toml)?;\n   346→\n   347→            // prompt.md\n   348→            fs::write(staging_root.join(PROMPT_FILE), prompt_contents)?;\n   349→\n   350→            // run.json\n   351→            let run_json = serde_json::to_string_pretty(run_snapshot)?;\n   352→            fs::write(staging_root.join(RUN_FILE), run_json)?;\n   353→\n   354→            // journal.ndjson (with initial event)\n   355→            let mut journal_content = initial_journal_line.to_owned();\n   356→            journal_content.push('\\n');\n   357→            fs::write(staging_root.join(JOURNAL_FILE), journal_content)?;\n   358→\n   359→            // sessions.json\n   360→            let sessions_json = serde_json::to_string_pretty(sessions)?;\n   361→            fs::write(staging_root.join(SESSIONS_FILE), sessions_json)?;\n   362→\n   363→            Ok(())\n   364→        })();\n   365→\n   366→        if let Err(e) = write_result {\n   367→            // Clean up staging on failure\n   368→            let _ = fs::remove_dir_all(&staging_root);\n   369→            return Err(e);\n   370→        }\n   371→\n   372→        // Atomic rename from staging to final location\n   373→        if let Err(e) = fs::rename(&staging_root, &project_root) {\n   374→            let _ = fs::remove_dir_all(&staging_root);\n   375→            return Err(e.into());\n   376→        }\n   377→\n   378→        Ok(())\n   379→    }\n   380→}\n   381→\n   382→/// Filesystem-backed implementation of `JournalStorePort`.\n   383→pub struct FsJournalStore;\n   384→\n   385→impl JournalStorePort for FsJournalStore {\n   386→    fn read_journal(\n   387→        &self,\n   388→        base_dir: &Path,\n   389→        project_id: &ProjectId,\n   390→    ) -> AppResult<Vec<JournalEvent>> {\n   391→        let path = FileSystem::project_root(base_dir, project_id).join(JOURNAL_FILE);\n   392→        match fs::read_to_string(&path) {\n   393→            Ok(contents) => journal::parse_journal(&contents),\n   394→            Err(e) if e.kind() == std::io::ErrorKind::NotFound => {\n   395→                Err(AppError::CorruptRecord {\n   396→                    file: format!(\"projects/{}/journal.ndjson\", project_id),\n   397→                    details: \"canonical file is missing\".to_owned(),\n   398→                })\n   399→            }\n   400→            Err(e) => Err(e.into()),\n   401→        }\n   402→    }\n   403→\n   404→    fn append_event(\n   405→        &self,\n   406→        base_dir: &Path,\n   407→        project_id: &ProjectId,\n   408→        line: &str,\n   409→    ) -> AppResult<()> {\n   410→        let path = FileSystem::project_root(base_dir, project_id).join(JOURNAL_FILE);\n   411→        FileSystem::append_line(&path, line)\n   412→    }\n   413→}\n   414→\n   415→/// Filesystem-backed implementation of `ArtifactStorePort`.\n   416→pub struct FsArtifactStore;\n   417→\n   418→impl ArtifactStorePort for FsArtifactStore {\n   419→    fn list_payloads(\n   420→        &self,\n   421→        base_dir: &Path,\n   422→        project_id: &ProjectId,\n   423→    ) -> AppResult<Vec<PayloadRecord>> {\n   424→        let dir = FileSystem::project_root(base_dir, project_id).join(\"history/payloads\");\n   425→        if !dir.is_dir() {\n   426→            return Ok(Vec::new());\n   427→        }\n   428→\n   429→        let mut records = Vec::new();\n   430→        for entry in fs::read_dir(&dir)? {\n   431→            let entry = entry?;\n   432→            let path = entry.path();\n   433→            if path.extension().is_some_and(|ext| ext == \"json\") {\n   434→                let raw = fs::read_to_string(&path)?;\n   435→                let record: PayloadRecord = serde_json::from_str(&raw).map_err(|e| {\n   436→                    AppError::CorruptRecord {\n   437→                        file: format!(\n   438→                            \"history/payloads/{}\",\n   439→                            path.file_name()\n   440→                                .unwrap_or_default()\n   441→                                .to_string_lossy()\n   442→                        ),\n   443→                        details: e.to_string(),\n   444→                    }\n   445→                })?;\n   446→                records.push(record);\n   447→            }\n   448→        }\n   449→\n   450→        records.sort_by_key(|r| r.created_at);\n   451→        Ok(records)\n   452→    }\n   453→\n   454→    fn list_artifacts(\n   455→        &self,\n   456→        base_dir: &Path,\n   457→        project_id: &ProjectId,\n   458→    ) -> AppResult<Vec<ArtifactRecord>> {\n   459→        let dir = FileSystem::project_root(base_dir, project_id).join(\"history/artifacts\");\n   460→        if !dir.is_dir() {\n   461→            return Ok(Vec::new());\n   462→        }\n   463→\n   464→        let mut records = Vec::new();\n   465→        for entry in fs::read_dir(&dir)? {\n   466→            let entry = entry?;\n   467→            let path = entry.path();\n   468→            if path.extension().is_some_and(|ext| ext == \"json\") {\n   469→                let raw = fs::read_to_string(&path)?;\n   470→                let record: ArtifactRecord =\n   471→                    serde_json::from_str(&raw).map_err(|e| AppError::CorruptRecord {\n   472→                        file: format!(\n   473→                            \"history/artifacts/{}\",\n   474→                            path.file_name()\n   475→                                .unwrap_or_default()\n   476→                                .to_string_lossy()\n   477→                        ),\n   478→                        details: e.to_string(),\n   479→                    })?;\n   480→                records.push(record);\n   481→            }\n   482→        }\n   483→\n   484→        records.sort_by_key(|r| r.created_at);\n   485→        Ok(records)\n   486→    }\n   487→}\n   488→\n   489→/// Filesystem-backed implementation of `RuntimeLogStorePort`.\n   490→pub struct FsRuntimeLogStore;\n   491→\n   492→impl RuntimeLogStorePort for FsRuntimeLogStore {\n   493→    fn read_runtime_logs(\n   494→        &self,\n   495→        base_dir: &Path,\n   496→        project_id: &ProjectId,\n   497→    ) -> AppResult<Vec<RuntimeLogEntry>> {\n   498→        let dir = FileSystem::project_root(base_dir, project_id).join(\"runtime/logs\");\n   499→        if !dir.is_dir() {\n   500→            return Ok(Vec::new());\n   501→        }\n   502→\n   503→        let mut entries = Vec::new();\n   504→        let mut paths: Vec<_> = fs::read_dir(&dir)?\n   505→            .filter_map(|e| e.ok())\n   506→            .map(|e| e.path())\n   507→            .filter(|p| p.extension().is_some_and(|ext| ext == \"ndjson\"))\n   508→            .collect();\n   509→        paths.sort();\n   510→\n   511→        for path in paths {\n   512→            let contents = fs::read_to_string(&path)?;\n   513→            for line in contents.lines() {\n   514→                let trimmed = line.trim();\n   515→                if trimmed.is_empty() {\n   516→                    continue;\n   517→                }\n   518→                if let Ok(entry) = serde_json::from_str::<RuntimeLogEntry>(trimmed) {\n   519→                    entries.push(entry);\n   520→                }\n   521→            }\n   522→        }\n   523→\n   524→        Ok(entries)\n   525→    }\n   526→}\n   527→\n   528→/// Filesystem-backed implementation of `RunSnapshotPort`.\n   529→pub struct FsRunSnapshotStore;\n   530→\n   531→impl RunSnapshotPort for FsRunSnapshotStore {\n   532→    fn read_run_snapshot(\n   533→        &self,\n   534→        base_dir: &Path,\n   535→        project_id: &ProjectId,\n   536→    ) -> AppResult<RunSnapshot> {\n   537→        let path = FileSystem::project_root(base_dir, project_id).join(RUN_FILE);\n   538→        match fs::read_to_string(&path) {\n   539→            Ok(raw) => {\n   540→                let snapshot: RunSnapshot =\n   541→                    serde_json::from_str(&raw).map_err(|e| AppError::CorruptRecord {\n   542→                        file: format!(\"projects/{}/run.json\", project_id),\n   543→                        details: e.to_string(),\n   544→                    })?;\n   545→                // Semantic validation: reject inconsistent status/active_run combinations\n   546→                snapshot\n   547→                    .validate_semantics()\n   548→                    .map_err(|details| AppError::CorruptRecord {\n   549→                        file: format!(\"projects/{}/run.json\", project_id),\n   550→                        details,\n   551→                    })?;\n   552→                Ok(snapshot)\n   553→            }\n   554→            Err(e) if e.kind() == std::io::ErrorKind::NotFound => {\n   555→                Err(AppError::CorruptRecord {\n   556→                    file: format!(\"projects/{}/run.json\", project_id),\n   557→                    details: \"canonical file is missing\".to_owned(),\n   558→                })\n   559→            }\n   560→            Err(e) => Err(e.into()),\n   561→        }\n   562→    }\n   563→}\n   564→\n   565→/// Filesystem-backed implementation of `ActiveProjectPort`.\n   566→pub struct FsActiveProjectStore;\n   567→\n   568→impl ActiveProjectPort for FsActiveProjectStore {\n   569→    fn read_active_project_id(&self, base_dir: &Path) -> AppResult<Option<String>> {\n   570→        FileSystem::read_active_project(&FileSystem::workspace_root_path(base_dir))\n   571→    }\n   572→\n   573→    fn clear_active_project(&self, base_dir: &Path) -> AppResult<()> {\n   574→        let path = FileSystem::workspace_root_path(base_dir).join(ACTIVE_PROJECT_FILE);\n   575→        match fs::remove_file(&path) {\n   576→            Ok(()) => Ok(()),\n   577→            Err(e) if e.kind() == std::io::ErrorKind::NotFound => Ok(()),\n   578→            Err(e) => Err(e.into()),\n   579→        }\n   580→    }\n   581→}\n   582→"}]},"parent_tool_use_id":null,"session_id":"5eb81d8b-9dcb-415b-a8cb-cb111e8f40b3","uuid":"e9702fbf-c00c-4171-9c5b-f1c3d7085389","tool_use_result":{"type":"text","file":{"filePath":"/root/new-ralph-burning/ralph-burning-rewrite/src/adapters/fs.rs","content":"use std::env;\nuse std::fs::{self, OpenOptions};\nuse std::io::Write;\nuse std::path::{Path, PathBuf};\nuse std::process::Command;\nuse std::time::{SystemTime, UNIX_EPOCH};\n\nuse crate::contexts::project_run_record::journal;\nuse crate::contexts::project_run_record::model::{\n    ArtifactRecord, JournalEvent, PayloadRecord, ProjectRecord, RunSnapshot,\n    RuntimeLogEntry, SessionStore,\n};\nuse crate::contexts::project_run_record::service::{\n    ActiveProjectPort, ArtifactStorePort, JournalStorePort, ProjectStorePort,\n    RuntimeLogStorePort, RunSnapshotPort,\n};\nuse crate::shared::domain::{ProjectId, WorkspaceConfig};\nuse crate::shared::error::{AppError, AppResult};\n\nconst ACTIVE_PROJECT_FILE: &str = \"active-project\";\nconst WORKSPACE_DIR: &str = \".ralph-burning\";\nconst PROJECTS_DIR: &str = \"projects\";\nconst PROJECT_CONFIG_FILE: &str = \"project.toml\";\nconst RUN_FILE: &str = \"run.json\";\nconst JOURNAL_FILE: &str = \"journal.ndjson\";\nconst SESSIONS_FILE: &str = \"sessions.json\";\nconst PROMPT_FILE: &str = \"prompt.md\";\n\n/// Required subdirectories inside a project.\nconst PROJECT_SUBDIRS: &[&str] = &[\n    \"history/payloads\",\n    \"history/artifacts\",\n    \"runtime/logs\",\n    \"runtime/backend\",\n    \"runtime/temp\",\n    \"amendments\",\n    \"rollback\",\n];\n\npub struct FileSystem;\n\nimpl FileSystem {\n    pub fn create_workspace(\n        workspace_root: &Path,\n        workspace_config: &str,\n        required_directories: &[&str],\n    ) -> AppResult<()> {\n        fs::create_dir_all(workspace_root)?;\n\n        for directory in required_directories {\n            fs::create_dir_all(workspace_root.join(directory))?;\n        }\n\n        Self::write_atomic(&workspace_root.join(\"workspace.toml\"), workspace_config)?;\n        Ok(())\n    }\n\n    pub fn read_to_string(path: &Path) -> AppResult<String> {\n        Ok(fs::read_to_string(path)?)\n    }\n\n    pub fn write_atomic(path: &Path, contents: &str) -> AppResult<()> {\n        let parent = path.parent().ok_or_else(|| {\n            AppError::Io(std::io::Error::new(\n                std::io::ErrorKind::InvalidInput,\n                format!(\"path '{}' has no parent directory\", path.display()),\n            ))\n        })?;\n        fs::create_dir_all(parent)?;\n\n        let timestamp = SystemTime::now()\n            .duration_since(UNIX_EPOCH)\n            .map(|duration| duration.as_nanos())\n            .unwrap_or_default();\n        let temp_path = parent.join(format!(\n            \".{}.{}.{}.tmp\",\n            path.file_name()\n                .and_then(|value| value.to_str())\n                .unwrap_or(\"workspace\"),\n            std::process::id(),\n            timestamp\n        ));\n\n        let mut file = OpenOptions::new()\n            .create_new(true)\n            .write(true)\n            .open(&temp_path)?;\n        file.write_all(contents.as_bytes())?;\n        file.sync_all()?;\n        drop(file);\n\n        if let Err(error) = fs::rename(&temp_path, path) {\n            let _ = fs::remove_file(&temp_path);\n            return Err(error.into());\n        }\n\n        Ok(())\n    }\n\n    pub fn render_workspace_config(config: &WorkspaceConfig) -> AppResult<String> {\n        Ok(toml::to_string_pretty(config)?)\n    }\n\n    pub fn read_active_project(workspace_root: &Path) -> AppResult<Option<String>> {\n        let path = workspace_root.join(ACTIVE_PROJECT_FILE);\n        match fs::read_to_string(path) {\n            Ok(raw) => {\n                let trimmed = raw.trim();\n                if trimmed.is_empty() {\n                    Ok(None)\n                } else {\n                    Ok(Some(trimmed.to_owned()))\n                }\n            }\n            Err(error) if error.kind() == std::io::ErrorKind::NotFound => Ok(None),\n            Err(error) => Err(error.into()),\n        }\n    }\n\n    pub fn write_active_project(workspace_root: &Path, project_id: &str) -> AppResult<()> {\n        Self::write_atomic(&workspace_root.join(ACTIVE_PROJECT_FILE), project_id)\n    }\n\n    pub fn open_editor(path: &Path) -> AppResult<()> {\n        let editor = env::var(\"EDITOR\")\n            .ok()\n            .filter(|value| !value.trim().is_empty())\n            .or_else(|| {\n                env::var(\"VISUAL\")\n                    .ok()\n                    .filter(|value| !value.trim().is_empty())\n            })\n            .unwrap_or_else(|| \"vi\".to_owned());\n\n        let mut parts = editor.split_whitespace();\n        let program = parts.next().ok_or_else(|| AppError::EditorFailed {\n            editor: editor.clone(),\n            details: \": empty editor command\".to_owned(),\n        })?;\n        let status = Command::new(program).args(parts).arg(path).status()?;\n\n        if status.success() {\n            Ok(())\n        } else {\n            let details = match status.code() {\n                Some(code) => format!(\" with exit code {code}\"),\n                None => \" after being terminated by a signal\".to_owned(),\n            };\n            Err(AppError::EditorFailed { editor, details })\n        }\n    }\n\n    /// Compute a simple hash of content for prompt integrity tracking.\n    pub fn prompt_hash(contents: &str) -> String {\n        use std::collections::hash_map::DefaultHasher;\n        use std::hash::{Hash, Hasher};\n        let mut hasher = DefaultHasher::new();\n        contents.hash(&mut hasher);\n        format!(\"{:016x}\", hasher.finish())\n    }\n\n    // ── Helpers for project filesystem layout ──\n\n    fn workspace_root_path(base_dir: &Path) -> PathBuf {\n        base_dir.join(WORKSPACE_DIR)\n    }\n\n    fn project_root(base_dir: &Path, project_id: &ProjectId) -> PathBuf {\n        Self::workspace_root_path(base_dir)\n            .join(PROJECTS_DIR)\n            .join(project_id.as_str())\n    }\n\n    fn append_line(path: &Path, line: &str) -> AppResult<()> {\n        let parent = path.parent().ok_or_else(|| {\n            AppError::Io(std::io::Error::new(\n                std::io::ErrorKind::InvalidInput,\n                format!(\"path '{}' has no parent directory\", path.display()),\n            ))\n        })?;\n        fs::create_dir_all(parent)?;\n\n        let mut file = OpenOptions::new()\n            .create(true)\n            .append(true)\n            .open(path)?;\n        writeln!(file, \"{}\", line)?;\n        file.sync_all()?;\n        Ok(())\n    }\n}\n\n/// Filesystem-backed implementation of `ProjectStorePort`.\npub struct FsProjectStore;\n\nimpl ProjectStorePort for FsProjectStore {\n    fn project_exists(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<bool> {\n        let project_root = FileSystem::project_root(base_dir, project_id);\n        if !project_root.is_dir() {\n            return Ok(false);\n        }\n        if !project_root.join(PROJECT_CONFIG_FILE).is_file() {\n            return Err(AppError::CorruptRecord {\n                file: format!(\"projects/{}/project.toml\", project_id),\n                details: \"project directory exists but canonical project.toml is missing\"\n                    .to_owned(),\n            });\n        }\n        Ok(true)\n    }\n\n    fn read_project_record(\n        &self,\n        base_dir: &Path,\n        project_id: &ProjectId,\n    ) -> AppResult<ProjectRecord> {\n        let project_root = FileSystem::project_root(base_dir, project_id);\n        let path = project_root.join(PROJECT_CONFIG_FILE);\n        let raw = fs::read_to_string(&path).map_err(|e| {\n            if e.kind() == std::io::ErrorKind::NotFound {\n                if project_root.is_dir() {\n                    // Directory exists but project.toml is missing — corruption\n                    AppError::CorruptRecord {\n                        file: format!(\"projects/{}/project.toml\", project_id),\n                        details: \"project directory exists but canonical project.toml is missing\"\n                            .to_owned(),\n                    }\n                } else {\n                    AppError::ProjectNotFound {\n                        project_id: project_id.to_string(),\n                    }\n                }\n            } else {\n                e.into()\n            }\n        })?;\n        toml::from_str(&raw).map_err(|e| AppError::CorruptRecord {\n            file: format!(\"projects/{}/project.toml\", project_id),\n            details: e.to_string(),\n        })\n    }\n\n    fn list_project_ids(&self, base_dir: &Path) -> AppResult<Vec<ProjectId>> {\n        let projects_dir = FileSystem::workspace_root_path(base_dir).join(PROJECTS_DIR);\n        if !projects_dir.is_dir() {\n            return Ok(Vec::new());\n        }\n\n        let mut ids = Vec::new();\n        for entry in fs::read_dir(&projects_dir)? {\n            let entry = entry?;\n            if !entry.file_type()?.is_dir() {\n                continue;\n            }\n            let name = entry.file_name();\n            let name_str = name.to_string_lossy();\n            // Skip hidden directories (staging/trash from transactional operations)\n            if name_str.starts_with('.') {\n                continue;\n            }\n            if let Ok(pid) = ProjectId::new(name_str.as_ref()) {\n                if !entry.path().join(PROJECT_CONFIG_FILE).is_file() {\n                    return Err(AppError::CorruptRecord {\n                        file: format!(\"projects/{}/project.toml\", name_str),\n                        details:\n                            \"project directory exists but canonical project.toml is missing\"\n                                .to_owned(),\n                    });\n                }\n                ids.push(pid);\n            }\n        }\n\n        ids.sort_by(|a, b| a.as_str().cmp(b.as_str()));\n        Ok(ids)\n    }\n\n    fn delete_project(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<()> {\n        let project_root = FileSystem::project_root(base_dir, project_id);\n        if !project_root.is_dir() {\n            return Err(AppError::ProjectNotFound {\n                project_id: project_id.to_string(),\n            });\n        }\n\n        // Transactional delete: rename to a trash path first, then remove.\n        // If removal fails, rename back so the project remains addressable.\n        let trash_name = format!(\".{}.deleting.{}\", project_id, std::process::id());\n        let trash_path = project_root\n            .parent()\n            .expect(\"project root has parent\")\n            .join(&trash_name);\n\n        // Phase 1: atomic rename to trash location\n        fs::rename(&project_root, &trash_path)?;\n\n        // Phase 2: remove the trash directory\n        if let Err(remove_err) = fs::remove_dir_all(&trash_path) {\n            // Removal failed — try to restore the project to its original path\n            if let Err(_restore_err) = fs::rename(&trash_path, &project_root) {\n                // Restore also failed; return the original removal error.\n                // The project is stranded at the trash path but not partially deleted.\n            }\n            return Err(remove_err.into());\n        }\n\n        Ok(())\n    }\n\n    fn create_project_atomic(\n        &self,\n        base_dir: &Path,\n        record: &ProjectRecord,\n        prompt_contents: &str,\n        run_snapshot: &RunSnapshot,\n        initial_journal_line: &str,\n        sessions: &SessionStore,\n    ) -> AppResult<()> {\n        let project_root = FileSystem::project_root(base_dir, &record.id);\n\n        // Stage into a temporary directory alongside the final location\n        let staging_name = format!(\".{}.staging.{}\", record.id, std::process::id());\n        let staging_root = project_root\n            .parent()\n            .expect(\"project root has parent\")\n            .join(&staging_name);\n\n        // Clean up any leftover staging dir\n        if staging_root.exists() {\n            fs::remove_dir_all(&staging_root)?;\n        }\n\n        // Create staging directory and all subdirs\n        fs::create_dir_all(&staging_root)?;\n        for subdir in PROJECT_SUBDIRS {\n            fs::create_dir_all(staging_root.join(subdir))?;\n        }\n\n        // Write all canonical files into staging\n        let write_result = (|| -> AppResult<()> {\n            // project.toml\n            let project_toml = toml::to_string_pretty(record).map_err(|e| {\n                AppError::Io(std::io::Error::other(e.to_string()))\n            })?;\n            fs::write(staging_root.join(PROJECT_CONFIG_FILE), project_toml)?;\n\n            // prompt.md\n            fs::write(staging_root.join(PROMPT_FILE), prompt_contents)?;\n\n            // run.json\n            let run_json = serde_json::to_string_pretty(run_snapshot)?;\n            fs::write(staging_root.join(RUN_FILE), run_json)?;\n\n            // journal.ndjson (with initial event)\n            let mut journal_content = initial_journal_line.to_owned();\n            journal_content.push('\\n');\n            fs::write(staging_root.join(JOURNAL_FILE), journal_content)?;\n\n            // sessions.json\n            let sessions_json = serde_json::to_string_pretty(sessions)?;\n            fs::write(staging_root.join(SESSIONS_FILE), sessions_json)?;\n\n            Ok(())\n        })();\n\n        if let Err(e) = write_result {\n            // Clean up staging on failure\n            let _ = fs::remove_dir_all(&staging_root);\n            return Err(e);\n        }\n\n        // Atomic rename from staging to final location\n        if let Err(e) = fs::rename(&staging_root, &project_root) {\n            let _ = fs::remove_dir_all(&staging_root);\n            return Err(e.into());\n        }\n\n        Ok(())\n    }\n}\n\n/// Filesystem-backed implementation of `JournalStorePort`.\npub struct FsJournalStore;\n\nimpl JournalStorePort for FsJournalStore {\n    fn read_journal(\n        &self,\n        base_dir: &Path,\n        project_id: &ProjectId,\n    ) -> AppResult<Vec<JournalEvent>> {\n        let path = FileSystem::project_root(base_dir, project_id).join(JOURNAL_FILE);\n        match fs::read_to_string(&path) {\n            Ok(contents) => journal::parse_journal(&contents),\n            Err(e) if e.kind() == std::io::ErrorKind::NotFound => {\n                Err(AppError::CorruptRecord {\n                    file: format!(\"projects/{}/journal.ndjson\", project_id),\n                    details: \"canonical file is missing\".to_owned(),\n                })\n            }\n            Err(e) => Err(e.into()),\n        }\n    }\n\n    fn append_event(\n        &self,\n        base_dir: &Path,\n        project_id: &ProjectId,\n        line: &str,\n    ) -> AppResult<()> {\n        let path = FileSystem::project_root(base_dir, project_id).join(JOURNAL_FILE);\n        FileSystem::append_line(&path, line)\n    }\n}\n\n/// Filesystem-backed implementation of `ArtifactStorePort`.\npub struct FsArtifactStore;\n\nimpl ArtifactStorePort for FsArtifactStore {\n    fn list_payloads(\n        &self,\n        base_dir: &Path,\n        project_id: &ProjectId,\n    ) -> AppResult<Vec<PayloadRecord>> {\n        let dir = FileSystem::project_root(base_dir, project_id).join(\"history/payloads\");\n        if !dir.is_dir() {\n            return Ok(Vec::new());\n        }\n\n        let mut records = Vec::new();\n        for entry in fs::read_dir(&dir)? {\n            let entry = entry?;\n            let path = entry.path();\n            if path.extension().is_some_and(|ext| ext == \"json\") {\n                let raw = fs::read_to_string(&path)?;\n                let record: PayloadRecord = serde_json::from_str(&raw).map_err(|e| {\n                    AppError::CorruptRecord {\n                        file: format!(\n                            \"history/payloads/{}\",\n                            path.file_name()\n                                .unwrap_or_default()\n                                .to_string_lossy()\n                        ),\n                        details: e.to_string(),\n                    }\n                })?;\n                records.push(record);\n            }\n        }\n\n        records.sort_by_key(|r| r.created_at);\n        Ok(records)\n    }\n\n    fn list_artifacts(\n        &self,\n        base_dir: &Path,\n        project_id: &ProjectId,\n    ) -> AppResult<Vec<ArtifactRecord>> {\n        let dir = FileSystem::project_root(base_dir, project_id).join(\"history/artifacts\");\n        if !dir.is_dir() {\n            return Ok(Vec::new());\n        }\n\n        let mut records = Vec::new();\n        for entry in fs::read_dir(&dir)? {\n            let entry = entry?;\n            let path = entry.path();\n            if path.extension().is_some_and(|ext| ext == \"json\") {\n                let raw = fs::read_to_string(&path)?;\n                let record: ArtifactRecord =\n                    serde_json::from_str(&raw).map_err(|e| AppError::CorruptRecord {\n                        file: format!(\n                            \"history/artifacts/{}\",\n                            path.file_name()\n                                .unwrap_or_default()\n                                .to_string_lossy()\n                        ),\n                        details: e.to_string(),\n                    })?;\n                records.push(record);\n            }\n        }\n\n        records.sort_by_key(|r| r.created_at);\n        Ok(records)\n    }\n}\n\n/// Filesystem-backed implementation of `RuntimeLogStorePort`.\npub struct FsRuntimeLogStore;\n\nimpl RuntimeLogStorePort for FsRuntimeLogStore {\n    fn read_runtime_logs(\n        &self,\n        base_dir: &Path,\n        project_id: &ProjectId,\n    ) -> AppResult<Vec<RuntimeLogEntry>> {\n        let dir = FileSystem::project_root(base_dir, project_id).join(\"runtime/logs\");\n        if !dir.is_dir() {\n            return Ok(Vec::new());\n        }\n\n        let mut entries = Vec::new();\n        let mut paths: Vec<_> = fs::read_dir(&dir)?\n            .filter_map(|e| e.ok())\n            .map(|e| e.path())\n            .filter(|p| p.extension().is_some_and(|ext| ext == \"ndjson\"))\n            .collect();\n        paths.sort();\n\n        for path in paths {\n            let contents = fs::read_to_string(&path)?;\n            for line in contents.lines() {\n                let trimmed = line.trim();\n                if trimmed.is_empty() {\n                    continue;\n                }\n                if let Ok(entry) = serde_json::from_str::<RuntimeLogEntry>(trimmed) {\n                    entries.push(entry);\n                }\n            }\n        }\n\n        Ok(entries)\n    }\n}\n\n/// Filesystem-backed implementation of `RunSnapshotPort`.\npub struct FsRunSnapshotStore;\n\nimpl RunSnapshotPort for FsRunSnapshotStore {\n    fn read_run_snapshot(\n        &self,\n        base_dir: &Path,\n        project_id: &ProjectId,\n    ) -> AppResult<RunSnapshot> {\n        let path = FileSystem::project_root(base_dir, project_id).join(RUN_FILE);\n        match fs::read_to_string(&path) {\n            Ok(raw) => {\n                let snapshot: RunSnapshot =\n                    serde_json::from_str(&raw).map_err(|e| AppError::CorruptRecord {\n                        file: format!(\"projects/{}/run.json\", project_id),\n                        details: e.to_string(),\n                    })?;\n                // Semantic validation: reject inconsistent status/active_run combinations\n                snapshot\n                    .validate_semantics()\n                    .map_err(|details| AppError::CorruptRecord {\n                        file: format!(\"projects/{}/run.json\", project_id),\n                        details,\n                    })?;\n                Ok(snapshot)\n            }\n            Err(e) if e.kind() == std::io::ErrorKind::NotFound => {\n                Err(AppError::CorruptRecord {\n                    file: format!(\"projects/{}/run.json\", project_id),\n                    details: \"canonical file is missing\".to_owned(),\n                })\n            }\n            Err(e) => Err(e.into()),\n        }\n    }\n}\n\n/// Filesystem-backed implementation of `ActiveProjectPort`.\npub struct FsActiveProjectStore;\n\nimpl ActiveProjectPort for FsActiveProjectStore {\n    fn read_active_project_id(&self, base_dir: &Path) -> AppResult<Option<String>> {\n        FileSystem::read_active_project(&FileSystem::workspace_root_path(base_dir))\n    }\n\n    fn clear_active_project(&self, base_dir: &Path) -> AppResult<()> {\n        let path = FileSystem::workspace_root_path(base_dir).join(ACTIVE_PROJECT_FILE);\n        match fs::remove_file(&path) {\n            Ok(()) => Ok(()),\n            Err(e) if e.kind() == std::io::ErrorKind::NotFound => Ok(()),\n            Err(e) => Err(e.into()),\n        }\n    }\n}\n","numLines":582,"startLine":1,"totalLines":582}}}
