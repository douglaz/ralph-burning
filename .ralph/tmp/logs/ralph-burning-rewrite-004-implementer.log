{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01VC7aTsvAn75ndjsU67WSXi","type":"tool_result","content":"     1→use std::fs;\n     2→use std::os::unix::fs::PermissionsExt;\n     3→use std::process::Command;\n     4→\n     5→use tempfile::tempdir;\n     6→\n     7→fn binary() -> &'static str {\n     8→    env!(\"CARGO_BIN_EXE_ralph-burning\")\n     9→}\n    10→\n    11→fn initialize_workspace_fixture() -> tempfile::TempDir {\n    12→    let temp_dir = tempdir().expect(\"create temp dir\");\n    13→    let output = Command::new(binary())\n    14→        .arg(\"init\")\n    15→        .current_dir(temp_dir.path())\n    16→        .output()\n    17→        .expect(\"run init\");\n    18→    assert!(output.status.success());\n    19→    temp_dir\n    20→}\n    21→\n    22→fn create_project_fixture(base_dir: &std::path::Path, project_id: &str) {\n    23→    let project_root = base_dir.join(\".ralph-burning/projects\").join(project_id);\n    24→    fs::create_dir_all(&project_root).expect(\"create project directory\");\n    25→    fs::write(project_root.join(\"project.toml\"), \"id = \\\"fixture\\\"\\n\").expect(\"write project\");\n    26→}\n    27→\n    28→fn write_editor_script(\n    29→    base_dir: &std::path::Path,\n    30→    name: &str,\n    31→    contents: &str,\n    32→) -> std::path::PathBuf {\n    33→    let script_path = base_dir.join(name);\n    34→    fs::write(&script_path, contents).expect(\"write editor script\");\n    35→    let mut permissions = fs::metadata(&script_path)\n    36→        .expect(\"script metadata\")\n    37→        .permissions();\n    38→    permissions.set_mode(0o755);\n    39→    fs::set_permissions(&script_path, permissions).expect(\"set script permissions\");\n    40→    script_path\n    41→}\n    42→\n    43→#[test]\n    44→fn flow_list_prints_all_presets() {\n    45→    let output = Command::new(binary())\n    46→        .args([\"flow\", \"list\"])\n    47→        .output()\n    48→        .expect(\"run flow list\");\n    49→\n    50→    assert!(output.status.success());\n    51→\n    52→    let stdout = String::from_utf8_lossy(&output.stdout);\n    53→    assert!(stdout.contains(\"standard\"));\n    54→    assert!(stdout.contains(\"quick_dev\"));\n    55→    assert!(stdout.contains(\"docs_change\"));\n    56→    assert!(stdout.contains(\"ci_improvement\"));\n    57→}\n    58→\n    59→#[test]\n    60→fn flow_show_standard_prints_stage_sequence() {\n    61→    let output = Command::new(binary())\n    62→        .args([\"flow\", \"show\", \"standard\"])\n    63→        .output()\n    64→        .expect(\"run flow show\");\n    65→\n    66→    assert!(output.status.success());\n    67→\n    68→    let stdout = String::from_utf8_lossy(&output.stdout);\n    69→    assert!(stdout.contains(\"Stage count: 8\"));\n    70→    assert!(stdout.contains(\"1. prompt_review\"));\n    71→    assert!(stdout.contains(\"8. final_review\"));\n    72→    assert!(stdout.contains(\"Final review enabled: yes\"));\n    73→}\n    74→\n    75→#[test]\n    76→fn flow_show_invalid_preset_exits_non_zero_with_clear_error() {\n    77→    let output = Command::new(binary())\n    78→        .args([\"flow\", \"show\", \"unknown_flow\"])\n    79→        .output()\n    80→        .expect(\"run flow show invalid\");\n    81→\n    82→    assert!(!output.status.success());\n    83→\n    84→    let stderr = String::from_utf8_lossy(&output.stderr);\n    85→    assert!(stderr.contains(\"unknown flow preset 'unknown_flow'\"));\n    86→}\n    87→\n    88→#[test]\n    89→fn init_creates_workspace_layout() {\n    90→    let temp_dir = tempdir().expect(\"create temp dir\");\n    91→    let output = Command::new(binary())\n    92→        .arg(\"init\")\n    93→        .current_dir(temp_dir.path())\n    94→        .output()\n    95→        .expect(\"run init\");\n    96→\n    97→    assert!(output.status.success());\n    98→    assert!(temp_dir\n    99→        .path()\n   100→        .join(\".ralph-burning/workspace.toml\")\n   101→        .is_file());\n   102→    assert!(temp_dir.path().join(\".ralph-burning/projects\").is_dir());\n   103→    assert!(temp_dir.path().join(\".ralph-burning/requirements\").is_dir());\n   104→    assert!(temp_dir.path().join(\".ralph-burning/daemon/tasks\").is_dir());\n   105→    assert!(temp_dir\n   106→        .path()\n   107→        .join(\".ralph-burning/daemon/leases\")\n   108→        .is_dir());\n   109→}\n   110→\n   111→#[test]\n   112→fn init_fails_when_workspace_already_exists() {\n   113→    let temp_dir = tempdir().expect(\"create temp dir\");\n   114→\n   115→    let first = Command::new(binary())\n   116→        .arg(\"init\")\n   117→        .current_dir(temp_dir.path())\n   118→        .output()\n   119→        .expect(\"run first init\");\n   120→    assert!(first.status.success());\n   121→\n   122→    let second = Command::new(binary())\n   123→        .arg(\"init\")\n   124→        .current_dir(temp_dir.path())\n   125→        .output()\n   126→        .expect(\"run second init\");\n   127→\n   128→    assert!(!second.status.success());\n   129→\n   130→    let stderr = String::from_utf8_lossy(&second.stderr);\n   131→    assert!(stderr.contains(\"workspace already initialized\"));\n   132→}\n   133→\n   134→#[test]\n   135→fn config_show_prints_effective_values_and_sources() {\n   136→    let temp_dir = initialize_workspace_fixture();\n   137→\n   138→    let output = Command::new(binary())\n   139→        .args([\"config\", \"show\"])\n   140→        .current_dir(temp_dir.path())\n   141→        .output()\n   142→        .expect(\"run config show\");\n   143→\n   144→    assert!(output.status.success());\n   145→\n   146→    let stdout = String::from_utf8_lossy(&output.stdout);\n   147→    assert!(stdout.contains(\"[settings]\"));\n   148→    assert!(stdout.contains(\"prompt_review.enabled = true # source: default\"));\n   149→    assert!(stdout.contains(\"default_flow = \\\"standard\\\" # source: default\"));\n   150→    assert!(stdout.contains(\"default_backend = \\\"<unset>\\\" # source: default\"));\n   151→}\n   152→\n   153→#[test]\n   154→fn config_get_prints_known_values_and_rejects_unknown_keys() {\n   155→    let temp_dir = initialize_workspace_fixture();\n   156→\n   157→    let known = Command::new(binary())\n   158→        .args([\"config\", \"get\", \"default_flow\"])\n   159→        .current_dir(temp_dir.path())\n   160→        .output()\n   161→        .expect(\"run config get\");\n   162→    assert!(known.status.success());\n   163→    assert_eq!(\"standard\\n\", String::from_utf8_lossy(&known.stdout));\n   164→\n   165→    let unknown = Command::new(binary())\n   166→        .args([\"config\", \"get\", \"unknown.key\"])\n   167→        .current_dir(temp_dir.path())\n   168→        .output()\n   169→        .expect(\"run config get invalid\");\n   170→    assert!(!unknown.status.success());\n   171→    assert!(String::from_utf8_lossy(&unknown.stderr).contains(\"unknown config key\"));\n   172→}\n   173→\n   174→#[test]\n   175→fn config_set_updates_valid_keys_and_rejects_invalid_values() {\n   176→    let temp_dir = initialize_workspace_fixture();\n   177→\n   178→    let valid = Command::new(binary())\n   179→        .args([\"config\", \"set\", \"default_flow\", \"quick_dev\"])\n   180→        .current_dir(temp_dir.path())\n   181→        .output()\n   182→        .expect(\"run config set\");\n   183→    assert!(valid.status.success());\n   184→    assert!(String::from_utf8_lossy(&valid.stdout).contains(\"Updated default_flow = quick_dev\"));\n   185→\n   186→    let workspace_config =\n   187→        fs::read_to_string(temp_dir.path().join(\".ralph-burning/workspace.toml\"))\n   188→            .expect(\"read workspace config\");\n   189→    assert!(workspace_config.contains(\"default_flow = \\\"quick_dev\\\"\"));\n   190→\n   191→    let invalid_value = Command::new(binary())\n   192→        .args([\"config\", \"set\", \"default_flow\", \"unknown_flow\"])\n   193→        .current_dir(temp_dir.path())\n   194→        .output()\n   195→        .expect(\"run invalid config set\");\n   196→    assert!(!invalid_value.status.success());\n   197→    assert!(String::from_utf8_lossy(&invalid_value.stderr).contains(\"invalid value\"));\n   198→\n   199→    let invalid_key = Command::new(binary())\n   200→        .args([\"config\", \"set\", \"unknown.key\", \"value\"])\n   201→        .current_dir(temp_dir.path())\n   202→        .output()\n   203→        .expect(\"run invalid key config set\");\n   204→    assert!(!invalid_key.status.success());\n   205→    assert!(String::from_utf8_lossy(&invalid_key.stderr).contains(\"unknown config key\"));\n   206→}\n   207→\n   208→#[test]\n   209→fn config_edit_revalidates_workspace_file() {\n   210→    let temp_dir = initialize_workspace_fixture();\n   211→    let editor = write_editor_script(\n   212→        temp_dir.path(),\n   213→        \"editor-valid.sh\",\n   214→        \"#!/bin/sh\\ncat <<'EOF' > \\\"$1\\\"\\nversion = 1\\ncreated_at = \\\"2026-03-11T17:50:55Z\\\"\\n\\n[settings]\\ndefault_backend = \\\"claude\\\"\\nEOF\\n\",\n   215→    );\n   216→\n   217→    let output = Command::new(binary())\n   218→        .args([\"config\", \"edit\"])\n   219→        .env(\"EDITOR\", &editor)\n   220→        .env_remove(\"VISUAL\")\n   221→        .current_dir(temp_dir.path())\n   222→        .output()\n   223→        .expect(\"run config edit\");\n   224→\n   225→    assert!(output.status.success());\n   226→    assert!(String::from_utf8_lossy(&output.stdout).contains(\"Validated workspace.toml\"));\n   227→}\n   228→\n   229→#[test]\n   230→fn config_edit_prefers_editor_over_visual() {\n   231→    let temp_dir = initialize_workspace_fixture();\n   232→    let editor = write_editor_script(\n   233→        temp_dir.path(),\n   234→        \"editor-wins.sh\",\n   235→        \"#!/bin/sh\\ncat <<'EOF' > \\\"$1\\\"\\nversion = 1\\ncreated_at = \\\"2026-03-11T17:50:55Z\\\"\\n\\n[settings]\\ndefault_backend = \\\"editor\\\"\\nEOF\\n\",\n   236→    );\n   237→    let visual = write_editor_script(\n   238→        temp_dir.path(),\n   239→        \"visual-loses.sh\",\n   240→        \"#!/bin/sh\\ncat <<'EOF' > \\\"$1\\\"\\nversion = 1\\ncreated_at = \\\"2026-03-11T17:50:55Z\\\"\\n\\n[settings]\\ndefault_backend = \\\"visual\\\"\\nEOF\\n\",\n   241→    );\n   242→\n   243→    let output = Command::new(binary())\n   244→        .args([\"config\", \"edit\"])\n   245→        .env(\"EDITOR\", &editor)\n   246→        .env(\"VISUAL\", &visual)\n   247→        .current_dir(temp_dir.path())\n   248→        .output()\n   249→        .expect(\"run config edit\");\n   250→\n   251→    assert!(output.status.success());\n   252→\n   253→    let workspace_config =\n   254→        fs::read_to_string(temp_dir.path().join(\".ralph-burning/workspace.toml\"))\n   255→            .expect(\"read workspace config\");\n   256→    assert!(workspace_config.contains(\"default_backend = \\\"editor\\\"\"));\n   257→    assert!(!workspace_config.contains(\"default_backend = \\\"visual\\\"\"));\n   258→}\n   259→\n   260→#[test]\n   261→fn config_edit_fails_when_editor_leaves_invalid_file() {\n   262→    let temp_dir = initialize_workspace_fixture();\n   263→    let editor = write_editor_script(\n   264→        temp_dir.path(),\n   265→        \"editor-invalid.sh\",\n   266→        \"#!/bin/sh\\nprintf '%s\\n' 'version = 999' 'created_at = \\\"2026-03-11T17:50:55Z\\\"' > \\\"$1\\\"\\n\",\n   267→    );\n   268→\n   269→    let output = Command::new(binary())\n   270→        .args([\"config\", \"edit\"])\n   271→        .env(\"EDITOR\", &editor)\n   272→        .env_remove(\"VISUAL\")\n   273→        .current_dir(temp_dir.path())\n   274→        .output()\n   275→        .expect(\"run invalid config edit\");\n   276→\n   277→    assert!(!output.status.success());\n   278→    let stderr = String::from_utf8_lossy(&output.stderr);\n   279→    assert!(stderr.contains(\"workspace.toml is invalid after editing\"));\n   280→    assert!(stderr.contains(\"unsupported workspace version 999\"));\n   281→}\n   282→\n   283→#[test]\n   284→fn project_select_sets_active_project_and_rejects_missing_projects() {\n   285→    let temp_dir = initialize_workspace_fixture();\n   286→    create_project_fixture(temp_dir.path(), \"alpha\");\n   287→\n   288→    let existing = Command::new(binary())\n   289→        .args([\"project\", \"select\", \"alpha\"])\n   290→        .current_dir(temp_dir.path())\n   291→        .output()\n   292→        .expect(\"run project select\");\n   293→    assert!(existing.status.success());\n   294→    assert!(String::from_utf8_lossy(&existing.stdout).contains(\"Selected project alpha\"));\n   295→    assert_eq!(\n   296→        \"alpha\",\n   297→        fs::read_to_string(temp_dir.path().join(\".ralph-burning/active-project\"))\n   298→            .expect(\"read active project\")\n   299→    );\n   300→\n   301→    let missing = Command::new(binary())\n   302→        .args([\"project\", \"select\", \"missing\"])\n   303→        .current_dir(temp_dir.path())\n   304→        .output()\n   305→        .expect(\"run missing project select\");\n   306→    assert!(!missing.status.success());\n   307→    assert!(String::from_utf8_lossy(&missing.stderr).contains(\"project 'missing' was not found\"));\n   308→}\n   309→\n   310→#[test]\n   311→fn project_select_rejects_path_like_ids_before_writing_active_project() {\n   312→    let temp_dir = initialize_workspace_fixture();\n   313→\n   314→    let output = Command::new(binary())\n   315→        .args([\"project\", \"select\", \"../escape\"])\n   316→        .current_dir(temp_dir.path())\n   317→        .output()\n   318→        .expect(\"run path-like project select\");\n   319→\n   320→    assert!(!output.status.success());\n   321→    assert!(String::from_utf8_lossy(&output.stderr).contains(\"invalid identifier\"));\n   322→    assert!(!temp_dir\n   323→        .path()\n   324→        .join(\".ralph-burning/active-project\")\n   325→        .exists());\n   326→}\n   327→\n   328→// ── Project Create ──\n   329→\n   330→fn write_prompt_fixture(base_dir: &std::path::Path) -> std::path::PathBuf {\n   331→    let prompt_path = base_dir.join(\"test-prompt.md\");\n   332→    fs::write(&prompt_path, \"# Test Prompt\\nImplement the feature.\\n\").expect(\"write prompt\");\n   333→    prompt_path\n   334→}\n   335→\n   336→#[test]\n   337→fn project_create_succeeds_and_writes_all_canonical_files() {\n   338→    let temp_dir = initialize_workspace_fixture();\n   339→    let prompt = write_prompt_fixture(temp_dir.path());\n   340→\n   341→    let output = Command::new(binary())\n   342→        .args([\n   343→            \"project\", \"create\",\n   344→            \"--id\", \"alpha\",\n   345→            \"--name\", \"Alpha Project\",\n   346→            \"--prompt\", prompt.to_str().unwrap(),\n   347→            \"--flow\", \"standard\",\n   348→        ])\n   349→        .current_dir(temp_dir.path())\n   350→        .output()\n   351→        .expect(\"run project create\");\n   352→\n   353→    assert!(output.status.success(), \"stderr: {}\", String::from_utf8_lossy(&output.stderr));\n   354→\n   355→    let stdout = String::from_utf8_lossy(&output.stdout);\n   356→    assert!(stdout.contains(\"Created project 'alpha'\"));\n   357→    assert!(stdout.contains(\"standard\"));\n   358→\n   359→    let project_root = temp_dir.path().join(\".ralph-burning/projects/alpha\");\n   360→    assert!(project_root.join(\"project.toml\").is_file());\n   361→    assert!(project_root.join(\"prompt.md\").is_file());\n   362→    assert!(project_root.join(\"run.json\").is_file());\n   363→    assert!(project_root.join(\"journal.ndjson\").is_file());\n   364→    assert!(project_root.join(\"sessions.json\").is_file());\n   365→    assert!(project_root.join(\"history/payloads\").is_dir());\n   366→    assert!(project_root.join(\"history/artifacts\").is_dir());\n   367→    assert!(project_root.join(\"runtime/logs\").is_dir());\n   368→    assert!(project_root.join(\"runtime/backend\").is_dir());\n   369→    assert!(project_root.join(\"runtime/temp\").is_dir());\n   370→    assert!(project_root.join(\"amendments\").is_dir());\n   371→    assert!(project_root.join(\"rollback\").is_dir());\n   372→}\n   373→\n   374→#[test]\n   375→fn project_create_initializes_journal_with_project_created_event() {\n   376→    let temp_dir = initialize_workspace_fixture();\n   377→    let prompt = write_prompt_fixture(temp_dir.path());\n   378→\n   379→    let output = Command::new(binary())\n   380→        .args([\n   381→            \"project\", \"create\",\n   382→            \"--id\", \"beta\",\n   383→            \"--name\", \"Beta\",\n   384→            \"--prompt\", prompt.to_str().unwrap(),\n   385→            \"--flow\", \"quick_dev\",\n   386→        ])\n   387→        .current_dir(temp_dir.path())\n   388→        .output()\n   389→        .expect(\"run project create\");\n   390→    assert!(output.status.success());\n   391→\n   392→    let journal = fs::read_to_string(\n   393→        temp_dir.path().join(\".ralph-burning/projects/beta/journal.ndjson\"),\n   394→    )\n   395→    .expect(\"read journal\");\n   396→\n   397→    assert!(journal.contains(\"\\\"project_created\\\"\"));\n   398→    assert!(journal.contains(\"\\\"sequence\\\":1\"));\n   399→}\n   400→\n   401→#[test]\n   402→fn project_create_run_json_shows_not_started() {\n   403→    let temp_dir = initialize_workspace_fixture();\n   404→    let prompt = write_prompt_fixture(temp_dir.path());\n   405→\n   406→    Command::new(binary())\n   407→        .args([\n   408→            \"project\", \"create\",\n   409→            \"--id\", \"gamma\",\n   410→            \"--name\", \"Gamma\",\n   411→            \"--prompt\", prompt.to_str().unwrap(),\n   412→            \"--flow\", \"standard\",\n   413→        ])\n   414→        .current_dir(temp_dir.path())\n   415→        .output()\n   416→        .expect(\"run project create\");\n   417→\n   418→    let run_json = fs::read_to_string(\n   419→        temp_dir.path().join(\".ralph-burning/projects/gamma/run.json\"),\n   420→    )\n   421→    .expect(\"read run.json\");\n   422→\n   423→    assert!(run_json.contains(\"\\\"not_started\\\"\"));\n   424→    assert!(run_json.contains(\"\\\"active_run\\\": null\"));\n   425→}\n   426→\n   427→#[test]\n   428→fn project_create_fails_on_duplicate_id() {\n   429→    let temp_dir = initialize_workspace_fixture();\n   430→    let prompt = write_prompt_fixture(temp_dir.path());\n   431→\n   432→    let first = Command::new(binary())\n   433→        .args([\n   434→            \"project\", \"create\",\n   435→            \"--id\", \"dup\",\n   436→            \"--name\", \"First\",\n   437→            \"--prompt\", prompt.to_str().unwrap(),\n   438→            \"--flow\", \"standard\",\n   439→        ])\n   440→        .current_dir(temp_dir.path())\n   441→        .output()\n   442→        .expect(\"first create\");\n   443→    assert!(first.status.success());\n   444→\n   445→    let second = Command::new(binary())\n   446→        .args([\n   447→            \"project\", \"create\",\n   448→            \"--id\", \"dup\",\n   449→            \"--name\", \"Second\",\n   450→            \"--prompt\", prompt.to_str().unwrap(),\n   451→            \"--flow\", \"standard\",\n   452→        ])\n   453→        .current_dir(temp_dir.path())\n   454→        .output()\n   455→        .expect(\"second create\");\n   456→\n   457→    assert!(!second.status.success());\n   458→    let stderr = String::from_utf8_lossy(&second.stderr);\n   459→    assert!(stderr.contains(\"already exists\"));\n   460→}\n   461→\n   462→#[test]\n   463→fn project_create_fails_on_invalid_flow() {\n   464→    let temp_dir = initialize_workspace_fixture();\n   465→    let prompt = write_prompt_fixture(temp_dir.path());\n   466→\n   467→    let output = Command::new(binary())\n   468→        .args([\n   469→            \"project\", \"create\",\n   470→            \"--id\", \"bad-flow\",\n   471→            \"--name\", \"Bad Flow\",\n   472→            \"--prompt\", prompt.to_str().unwrap(),\n   473→            \"--flow\", \"nonexistent\",\n   474→        ])\n   475→        .current_dir(temp_dir.path())\n   476→        .output()\n   477→        .expect(\"run project create\");\n   478→\n   479→    assert!(!output.status.success());\n   480→    let stderr = String::from_utf8_lossy(&output.stderr);\n   481→    assert!(stderr.contains(\"unknown flow preset\"));\n   482→}\n   483→\n   484→#[test]\n   485→fn project_create_fails_on_missing_prompt() {\n   486→    let temp_dir = initialize_workspace_fixture();\n   487→\n   488→    let output = Command::new(binary())\n   489→        .args([\n   490→            \"project\", \"create\",\n   491→            \"--id\", \"no-prompt\",\n   492→            \"--name\", \"No Prompt\",\n   493→            \"--prompt\", \"/nonexistent/prompt.md\",\n   494→            \"--flow\", \"standard\",\n   495→        ])\n   496→        .current_dir(temp_dir.path())\n   497→        .output()\n   498→        .expect(\"run project create\");\n   499→\n   500→    assert!(!output.status.success());\n   501→    let stderr = String::from_utf8_lossy(&output.stderr);\n   502→    assert!(stderr.contains(\"invalid prompt file\"));\n   503→}\n   504→\n   505→#[test]\n   506→fn project_create_does_not_set_active_project() {\n   507→    let temp_dir = initialize_workspace_fixture();\n   508→    let prompt = write_prompt_fixture(temp_dir.path());\n   509→\n   510→    Command::new(binary())\n   511→        .args([\n   512→            \"project\", \"create\",\n   513→            \"--id\", \"noactive\",\n   514→            \"--name\", \"No Active\",\n   515→            \"--prompt\", prompt.to_str().unwrap(),\n   516→            \"--flow\", \"standard\",\n   517→        ])\n   518→        .current_dir(temp_dir.path())\n   519→        .output()\n   520→        .expect(\"run project create\");\n   521→\n   522→    // active-project should not exist (create does not set it)\n   523→    assert!(!temp_dir\n   524→        .path()\n   525→        .join(\".ralph-burning/active-project\")\n   526→        .exists());\n   527→}\n   528→\n   529→// ── Project List ──\n   530→\n   531→#[test]\n   532→fn project_list_shows_no_projects_when_empty() {\n   533→    let temp_dir = initialize_workspace_fixture();\n   534→\n   535→    let output = Command::new(binary())\n   536→        .args([\"project\", \"list\"])\n   537→        .current_dir(temp_dir.path())\n   538→        .output()\n   539→        .expect(\"run project list\");\n   540→\n   541→    assert!(output.status.success());\n   542→    let stdout = String::from_utf8_lossy(&output.stdout);\n   543→    assert!(stdout.contains(\"No projects found\"));\n   544→}\n   545→\n   546→#[test]\n   547→fn project_list_shows_created_projects_with_active_marker() {\n   548→    let temp_dir = initialize_workspace_fixture();\n   549→    let prompt = write_prompt_fixture(temp_dir.path());\n   550→\n   551→    // Create two projects\n   552→    Command::new(binary())\n   553→        .args([\n   554→            \"project\", \"create\",\n   555→            \"--id\", \"alpha\",\n   556→            \"--name\", \"Alpha\",\n   557→            \"--prompt\", prompt.to_str().unwrap(),\n   558→            \"--flow\", \"standard\",\n   559→        ])\n   560→        .current_dir(temp_dir.path())\n   561→        .output()\n   562→        .expect(\"create alpha\");\n   563→\n   564→    Command::new(binary())\n   565→        .args([\n   566→            \"project\", \"create\",\n   567→            \"--id\", \"beta\",\n   568→            \"--name\", \"Beta\",\n   569→            \"--prompt\", prompt.to_str().unwrap(),\n   570→            \"--flow\", \"quick_dev\",\n   571→        ])\n   572→        .current_dir(temp_dir.path())\n   573→        .output()\n   574→        .expect(\"create beta\");\n   575→\n   576→    // Select alpha as active\n   577→    Command::new(binary())\n   578→        .args([\"project\", \"select\", \"alpha\"])\n   579→        .current_dir(temp_dir.path())\n   580→        .output()\n   581→        .expect(\"select alpha\");\n   582→\n   583→    let output = Command::new(binary())\n   584→        .args([\"project\", \"list\"])\n   585→        .current_dir(temp_dir.path())\n   586→        .output()\n   587→        .expect(\"run project list\");\n   588→\n   589→    assert!(output.status.success());\n   590→    let stdout = String::from_utf8_lossy(&output.stdout);\n   591→    assert!(stdout.contains(\"alpha *\"));\n   592→    assert!(stdout.contains(\"beta\"));\n   593→    assert!(stdout.contains(\"standard\"));\n   594→    assert!(stdout.contains(\"quick_dev\"));\n   595→}\n   596→\n   597→// ── Project Show ──\n   598→\n   599→#[test]\n   600→fn project_show_displays_project_details() {\n   601→    let temp_dir = initialize_workspace_fixture();\n   602→    let prompt = write_prompt_fixture(temp_dir.path());\n   603→\n   604→    Command::new(binary())\n   605→        .args([\n   606→            \"project\", \"create\",\n   607→            \"--id\", \"showme\",\n   608→            \"--name\", \"Show Me\",\n   609→            \"--prompt\", prompt.to_str().unwrap(),\n   610→            \"--flow\", \"docs_change\",\n   611→        ])\n   612→        .current_dir(temp_dir.path())\n   613→        .output()\n   614→        .expect(\"create project\");\n   615→\n   616→    let output = Command::new(binary())\n   617→        .args([\"project\", \"show\", \"showme\"])\n   618→        .current_dir(temp_dir.path())\n   619→        .output()\n   620→        .expect(\"run project show\");\n   621→\n   622→    assert!(output.status.success());\n   623→    let stdout = String::from_utf8_lossy(&output.stdout);\n   624→    assert!(stdout.contains(\"Project: showme\"));\n   625→    assert!(stdout.contains(\"Name: Show Me\"));\n   626→    assert!(stdout.contains(\"Flow: docs_change\"));\n   627→    assert!(stdout.contains(\"Prompt hash:\"));\n   628→    assert!(stdout.contains(\"Run status: not started\"));\n   629→    assert!(stdout.contains(\"Journal events: 1\"));\n   630→}\n   631→\n   632→#[test]\n   633→fn project_show_resolves_active_project_when_no_id_given() {\n   634→    let temp_dir = initialize_workspace_fixture();\n   635→    let prompt = write_prompt_fixture(temp_dir.path());\n   636→\n   637→    Command::new(binary())\n   638→        .args([\n   639→            \"project\", \"create\",\n   640→            \"--id\", \"active-show\",\n   641→            \"--name\", \"Active Show\",\n   642→            \"--prompt\", prompt.to_str().unwrap(),\n   643→            \"--flow\", \"standard\",\n   644→        ])\n   645→        .current_dir(temp_dir.path())\n   646→        .output()\n   647→        .expect(\"create project\");\n   648→\n   649→    Command::new(binary())\n   650→        .args([\"project\", \"select\", \"active-show\"])\n   651→        .current_dir(temp_dir.path())\n   652→        .output()\n   653→        .expect(\"select project\");\n   654→\n   655→    let output = Command::new(binary())\n   656→        .args([\"project\", \"show\"])\n   657→        .current_dir(temp_dir.path())\n   658→        .output()\n   659→        .expect(\"run project show without id\");\n   660→\n   661→    assert!(output.status.success());\n   662→    let stdout = String::from_utf8_lossy(&output.stdout);\n   663→    assert!(stdout.contains(\"Project: active-show (active)\"));\n   664→}\n   665→\n   666→// ── Project Delete ──\n   667→\n   668→#[test]\n   669→fn project_delete_removes_project_directory() {\n   670→    let temp_dir = initialize_workspace_fixture();\n   671→    let prompt = write_prompt_fixture(temp_dir.path());\n   672→\n   673→    Command::new(binary())\n   674→        .args([\n   675→            \"project\", \"create\",\n   676→            \"--id\", \"deleteme\",\n   677→            \"--name\", \"Delete Me\",\n   678→            \"--prompt\", prompt.to_str().unwrap(),\n   679→            \"--flow\", \"standard\",\n   680→        ])\n   681→        .current_dir(temp_dir.path())\n   682→        .output()\n   683→        .expect(\"create project\");\n   684→\n   685→    let output = Command::new(binary())\n   686→        .args([\"project\", \"delete\", \"deleteme\"])\n   687→        .current_dir(temp_dir.path())\n   688→        .output()\n   689→        .expect(\"run project delete\");\n   690→\n   691→    assert!(output.status.success());\n   692→    let stdout = String::from_utf8_lossy(&output.stdout);\n   693→    assert!(stdout.contains(\"Deleted project 'deleteme'\"));\n   694→    assert!(!temp_dir\n   695→        .path()\n   696→        .join(\".ralph-burning/projects/deleteme\")\n   697→        .exists());\n   698→}\n   699→\n   700→#[test]\n   701→fn project_delete_clears_active_project_if_selected() {\n   702→    let temp_dir = initialize_workspace_fixture();\n   703→    let prompt = write_prompt_fixture(temp_dir.path());\n   704→\n   705→    Command::new(binary())\n   706→        .args([\n   707→            \"project\", \"create\",\n   708→            \"--id\", \"active-del\",\n   709→            \"--name\", \"Active Del\",\n   710→            \"--prompt\", prompt.to_str().unwrap(),\n   711→            \"--flow\", \"standard\",\n   712→        ])\n   713→        .current_dir(temp_dir.path())\n   714→        .output()\n   715→        .expect(\"create project\");\n   716→\n   717→    Command::new(binary())\n   718→        .args([\"project\", \"select\", \"active-del\"])\n   719→        .current_dir(temp_dir.path())\n   720→        .output()\n   721→        .expect(\"select project\");\n   722→\n   723→    assert!(temp_dir\n   724→        .path()\n   725→        .join(\".ralph-burning/active-project\")\n   726→        .exists());\n   727→\n   728→    let output = Command::new(binary())\n   729→        .args([\"project\", \"delete\", \"active-del\"])\n   730→        .current_dir(temp_dir.path())\n   731→        .output()\n   732→        .expect(\"run project delete\");\n   733→\n   734→    assert!(output.status.success());\n   735→    assert!(!temp_dir\n   736→        .path()\n   737→        .join(\".ralph-burning/active-project\")\n   738→        .exists());\n   739→}\n   740→\n   741→#[test]\n   742→fn project_delete_fails_for_missing_project() {\n   743→    let temp_dir = initialize_workspace_fixture();\n   744→\n   745→    let output = Command::new(binary())\n   746→        .args([\"project\", \"delete\", \"nonexistent\"])\n   747→        .current_dir(temp_dir.path())\n   748→        .output()\n   749→        .expect(\"run project delete\");\n   750→\n   751→    assert!(!output.status.success());\n   752→    let stderr = String::from_utf8_lossy(&output.stderr);\n   753→    assert!(stderr.contains(\"not found\"));\n   754→}\n   755→\n   756→// ── Run Status ──\n   757→\n   758→#[test]\n   759→fn run_status_shows_not_started_for_new_project() {\n   760→    let temp_dir = initialize_workspace_fixture();\n   761→    let prompt = write_prompt_fixture(temp_dir.path());\n   762→\n   763→    Command::new(binary())\n   764→        .args([\n   765→            \"project\", \"create\",\n   766→            \"--id\", \"status-test\",\n   767→            \"--name\", \"Status Test\",\n   768→            \"--prompt\", prompt.to_str().unwrap(),\n   769→            \"--flow\", \"standard\",\n   770→        ])\n   771→        .current_dir(temp_dir.path())\n   772→        .output()\n   773→        .expect(\"create project\");\n   774→\n   775→    Command::new(binary())\n   776→        .args([\"project\", \"select\", \"status-test\"])\n   777→        .current_dir(temp_dir.path())\n   778→        .output()\n   779→        .expect(\"select project\");\n   780→\n   781→    let output = Command::new(binary())\n   782→        .args([\"run\", \"status\"])\n   783→        .current_dir(temp_dir.path())\n   784→        .output()\n   785→        .expect(\"run status\");\n   786→\n   787→    assert!(output.status.success());\n   788→    let stdout = String::from_utf8_lossy(&output.stdout);\n   789→    assert!(stdout.contains(\"Status: not started\"));\n   790→}\n   791→\n   792→// ── Run History ──\n   793→\n   794→#[test]\n   795→fn run_history_shows_journal_events_for_new_project() {\n   796→    let temp_dir = initialize_workspace_fixture();\n   797→    let prompt = write_prompt_fixture(temp_dir.path());\n   798→\n   799→    Command::new(binary())\n   800→        .args([\n   801→            \"project\", \"create\",\n   802→            \"--id\", \"hist-test\",\n   803→            \"--name\", \"History Test\",\n   804→            \"--prompt\", prompt.to_str().unwrap(),\n   805→            \"--flow\", \"standard\",\n   806→        ])\n   807→        .current_dir(temp_dir.path())\n   808→        .output()\n   809→        .expect(\"create project\");\n   810→\n   811→    Command::new(binary())\n   812→        .args([\"project\", \"select\", \"hist-test\"])\n   813→        .current_dir(temp_dir.path())\n   814→        .output()\n   815→        .expect(\"select project\");\n   816→\n   817→    let output = Command::new(binary())\n   818→        .args([\"run\", \"history\"])\n   819→        .current_dir(temp_dir.path())\n   820→        .output()\n   821→        .expect(\"run history\");\n   822→\n   823→    assert!(output.status.success());\n   824→    let stdout = String::from_utf8_lossy(&output.stdout);\n   825→    assert!(stdout.contains(\"Journal Events\"));\n   826→    assert!(stdout.contains(\"ProjectCreated\"));\n   827→}\n   828→\n   829→// ── Run Tail ──\n   830→\n   831→#[test]\n   832→fn run_tail_shows_durable_history_only_by_default() {\n   833→    let temp_dir = initialize_workspace_fixture();\n   834→    let prompt = write_prompt_fixture(temp_dir.path());\n   835→\n   836→    Command::new(binary())\n   837→        .args([\n   838→            \"project\", \"create\",\n   839→            \"--id\", \"tail-test\",\n   840→            \"--name\", \"Tail Test\",\n   841→            \"--prompt\", prompt.to_str().unwrap(),\n   842→            \"--flow\", \"standard\",\n   843→        ])\n   844→        .current_dir(temp_dir.path())\n   845→        .output()\n   846→        .expect(\"create project\");\n   847→\n   848→    Command::new(binary())\n   849→        .args([\"project\", \"select\", \"tail-test\"])\n   850→        .current_dir(temp_dir.path())\n   851→        .output()\n   852→        .expect(\"select project\");\n   853→\n   854→    let output = Command::new(binary())\n   855→        .args([\"run\", \"tail\"])\n   856→        .current_dir(temp_dir.path())\n   857→        .output()\n   858→        .expect(\"run tail\");\n   859→\n   860→    assert!(output.status.success());\n   861→    let stdout = String::from_utf8_lossy(&output.stdout);\n   862→    assert!(stdout.contains(\"Durable History\"));\n   863→    // No runtime logs section when --logs not passed\n   864→    assert!(!stdout.contains(\"Runtime Logs\"));\n   865→}\n   866→\n   867→#[test]\n   868→fn run_tail_with_logs_includes_runtime_logs_section() {\n   869→    let temp_dir = initialize_workspace_fixture();\n   870→    let prompt = write_prompt_fixture(temp_dir.path());\n   871→\n   872→    Command::new(binary())\n   873→        .args([\n   874→            \"project\", \"create\",\n   875→            \"--id\", \"tail-logs\",\n   876→            \"--name\", \"Tail Logs\",\n   877→            \"--prompt\", prompt.to_str().unwrap(),\n   878→            \"--flow\", \"standard\",\n   879→        ])\n   880→        .current_dir(temp_dir.path())\n   881→        .output()\n   882→        .expect(\"create project\");\n   883→\n   884→    Command::new(binary())\n   885→        .args([\"project\", \"select\", \"tail-logs\"])\n   886→        .current_dir(temp_dir.path())\n   887→        .output()\n   888→        .expect(\"select project\");\n   889→\n   890→    let output = Command::new(binary())\n   891→        .args([\"run\", \"tail\", \"--logs\"])\n   892→        .current_dir(temp_dir.path())\n   893→        .output()\n   894→        .expect(\"run tail --logs\");\n   895→\n   896→    assert!(output.status.success());\n   897→    let stdout = String::from_utf8_lossy(&output.stdout);\n   898→    assert!(stdout.contains(\"Durable History\"));\n   899→    assert!(stdout.contains(\"Runtime Logs\"));\n   900→}\n   901→\n   902→// ── Fail-fast on missing canonical files ──\n   903→\n   904→#[test]\n   905→fn run_status_fails_fast_when_run_json_is_missing() {\n   906→    let temp_dir = initialize_workspace_fixture();\n   907→    let prompt = write_prompt_fixture(temp_dir.path());\n   908→\n   909→    Command::new(binary())\n   910→        .args([\n   911→            \"project\", \"create\",\n   912→            \"--id\", \"broken\",\n   913→            \"--name\", \"Broken\",\n   914→            \"--prompt\", prompt.to_str().unwrap(),\n   915→            \"--flow\", \"standard\",\n   916→        ])\n   917→        .current_dir(temp_dir.path())\n   918→        .output()\n   919→        .expect(\"create project\");\n   920→\n   921→    Command::new(binary())\n   922→        .args([\"project\", \"select\", \"broken\"])\n   923→        .current_dir(temp_dir.path())\n   924→        .output()\n   925→        .expect(\"select project\");\n   926→\n   927→    // Delete run.json to simulate corruption\n   928→    fs::remove_file(\n   929→        temp_dir.path().join(\".ralph-burning/projects/broken/run.json\"),\n   930→    )\n   931→    .expect(\"remove run.json\");\n   932→\n   933→    let output = Command::new(binary())\n   934→        .args([\"run\", \"status\"])\n   935→        .current_dir(temp_dir.path())\n   936→        .output()\n   937→        .expect(\"run status\");\n   938→\n   939→    assert!(!output.status.success());\n   940→    let stderr = String::from_utf8_lossy(&output.stderr);\n   941→    assert!(stderr.contains(\"run.json\"));\n   942→    assert!(stderr.contains(\"missing\"));\n   943→}\n   944→\n   945→#[test]\n   946→fn run_history_fails_fast_when_journal_is_missing() {\n   947→    let temp_dir = initialize_workspace_fixture();\n   948→    let prompt = write_prompt_fixture(temp_dir.path());\n   949→\n   950→    Command::new(binary())\n   951→        .args([\n   952→            \"project\", \"create\",\n   953→            \"--id\", \"nojrnl\",\n   954→            \"--name\", \"No Journal\",\n   955→            \"--prompt\", prompt.to_str().unwrap(),\n   956→            \"--flow\", \"standard\",\n   957→        ])\n   958→        .current_dir(temp_dir.path())\n   959→        .output()\n   960→        .expect(\"create project\");\n   961→\n   962→    Command::new(binary())\n   963→        .args([\"project\", \"select\", \"nojrnl\"])\n   964→        .current_dir(temp_dir.path())\n   965→        .output()\n   966→        .expect(\"select project\");\n   967→\n   968→    // Delete journal.ndjson to simulate corruption\n   969→    fs::remove_file(\n   970→        temp_dir.path().join(\".ralph-burning/projects/nojrnl/journal.ndjson\"),\n   971→    )\n   972→    .expect(\"remove journal\");\n   973→\n   974→    let output = Command::new(binary())\n   975→        .args([\"run\", \"history\"])\n   976→        .current_dir(temp_dir.path())\n   977→        .output()\n   978→        .expect(\"run history\");\n   979→\n   980→    assert!(!output.status.success());\n   981→    let stderr = String::from_utf8_lossy(&output.stderr);\n   982→    assert!(stderr.contains(\"journal.ndjson\"));\n   983→    assert!(stderr.contains(\"missing\"));\n   984→}\n   985→\n   986→#[test]\n   987→fn run_status_fails_fast_when_run_json_is_corrupt() {\n   988→    let temp_dir = initialize_workspace_fixture();\n   989→    let prompt = write_prompt_fixture(temp_dir.path());\n   990→\n   991→    Command::new(binary())\n   992→        .args([\n   993→            \"project\", \"create\",\n   994→            \"--id\", \"corrupt\",\n   995→            \"--name\", \"Corrupt\",\n   996→            \"--prompt\", prompt.to_str().unwrap(),\n   997→            \"--flow\", \"standard\",\n   998→        ])\n   999→        .current_dir(temp_dir.path())\n  1000→        .output()\n  1001→        .expect(\"create project\");\n  1002→\n  1003→    Command::new(binary())\n  1004→        .args([\"project\", \"select\", \"corrupt\"])\n  1005→        .current_dir(temp_dir.path())\n  1006→        .output()\n  1007→        .expect(\"select project\");\n  1008→\n  1009→    // Write corrupt JSON to run.json\n  1010→    fs::write(\n  1011→        temp_dir.path().join(\".ralph-burning/projects/corrupt/run.json\"),\n  1012→        \"{invalid json}\",\n  1013→    )\n  1014→    .expect(\"corrupt run.json\");\n  1015→\n  1016→    let output = Command::new(binary())\n  1017→        .args([\"run\", \"status\"])\n  1018→        .current_dir(temp_dir.path())\n  1019→        .output()\n  1020→        .expect(\"run status\");\n  1021→\n  1022→    assert!(!output.status.success());\n  1023→    let stderr = String::from_utf8_lossy(&output.stderr);\n  1024→    assert!(stderr.contains(\"run.json\"));\n  1025→}\n  1026→\n  1027→// ── Missing project.toml corruption detection ──\n  1028→\n  1029→#[test]\n  1030→fn project_show_fails_fast_when_project_toml_is_missing() {\n  1031→    let temp_dir = initialize_workspace_fixture();\n  1032→    let prompt = write_prompt_fixture(temp_dir.path());\n  1033→\n  1034→    Command::new(binary())\n  1035→        .args([\n  1036→            \"project\", \"create\",\n  1037→            \"--id\", \"corrupt-proj\",\n  1038→            \"--name\", \"Corrupt\",\n  1039→            \"--prompt\", prompt.to_str().unwrap(),\n  1040→            \"--flow\", \"standard\",\n  1041→        ])\n  1042→        .current_dir(temp_dir.path())\n  1043→        .output()\n  1044→        .expect(\"create project\");\n  1045→\n  1046→    // Delete project.toml to simulate corruption\n  1047→    fs::remove_file(\n  1048→        temp_dir.path().join(\".ralph-burning/projects/corrupt-proj/project.toml\"),\n  1049→    )\n  1050→    .expect(\"remove project.toml\");\n  1051→\n  1052→    let output = Command::new(binary())\n  1053→        .args([\"project\", \"show\", \"corrupt-proj\"])\n  1054→        .current_dir(temp_dir.path())\n  1055→        .output()\n  1056→        .expect(\"run project show\");\n  1057→\n  1058→    assert!(!output.status.success());\n  1059→    let stderr = String::from_utf8_lossy(&output.stderr);\n  1060→    assert!(stderr.contains(\"project.toml\"));\n  1061→    assert!(stderr.contains(\"missing\"));\n  1062→}\n  1063→\n  1064→#[test]\n  1065→fn project_list_fails_fast_when_project_toml_is_missing() {\n  1066→    let temp_dir = initialize_workspace_fixture();\n  1067→    let prompt = write_prompt_fixture(temp_dir.path());\n  1068→\n  1069→    Command::new(binary())\n  1070→        .args([\n  1071→            \"project\", \"create\",\n  1072→            \"--id\", \"good-proj\",\n  1073→            \"--name\", \"Good\",\n  1074→            \"--prompt\", prompt.to_str().unwrap(),\n  1075→            \"--flow\", \"standard\",\n  1076→        ])\n  1077→        .current_dir(temp_dir.path())\n  1078→        .output()\n  1079→        .expect(\"create project\");\n  1080→\n  1081→    // Delete project.toml to simulate corruption\n  1082→    fs::remove_file(\n  1083→        temp_dir.path().join(\".ralph-burning/projects/good-proj/project.toml\"),\n  1084→    )\n  1085→    .expect(\"remove project.toml\");\n  1086→\n  1087→    let output = Command::new(binary())\n  1088→        .args([\"project\", \"list\"])\n  1089→        .current_dir(temp_dir.path())\n  1090→        .output()\n  1091→        .expect(\"run project list\");\n  1092→\n  1093→    assert!(!output.status.success());\n  1094→    let stderr = String::from_utf8_lossy(&output.stderr);\n  1095→    assert!(stderr.contains(\"project.toml\"));\n  1096→    assert!(stderr.contains(\"missing\"));\n  1097→}\n  1098→\n  1099→#[test]\n  1100→fn project_delete_fails_fast_when_project_toml_is_missing() {\n  1101→    let temp_dir = initialize_workspace_fixture();\n  1102→\n  1103→    // Create a bare directory without project.toml (simulates corruption)\n  1104→    let corrupt_dir = temp_dir.path().join(\".ralph-burning/projects/bare-proj\");\n  1105→    fs::create_dir_all(&corrupt_dir).expect(\"create bare project dir\");\n  1106→\n  1107→    let output = Command::new(binary())\n  1108→        .args([\"project\", \"delete\", \"bare-proj\"])\n  1109→        .current_dir(temp_dir.path())\n  1110→        .output()\n  1111→        .expect(\"run project delete\");\n  1112→\n  1113→    assert!(!output.status.success());\n  1114→    let stderr = String::from_utf8_lossy(&output.stderr);\n  1115→    assert!(stderr.contains(\"project.toml\"));\n  1116→    assert!(stderr.contains(\"missing\"));\n  1117→}\n  1118→\n  1119→// ── Terminal snapshot status reporting ──\n  1120→\n  1121→#[test]\n  1122→fn run_status_reports_completed_for_terminal_run_snapshot() {\n  1123→    let temp_dir = initialize_workspace_fixture();\n  1124→    let prompt = write_prompt_fixture(temp_dir.path());\n  1125→\n  1126→    Command::new(binary())\n  1127→        .args([\n  1128→            \"project\", \"create\",\n  1129→            \"--id\", \"terminal\",\n  1130→            \"--name\", \"Terminal\",\n  1131→            \"--prompt\", prompt.to_str().unwrap(),\n  1132→            \"--flow\", \"standard\",\n  1133→        ])\n  1134→        .current_dir(temp_dir.path())\n  1135→        .output()\n  1136→        .expect(\"create project\");\n  1137→\n  1138→    Command::new(binary())\n  1139→        .args([\"project\", \"select\", \"terminal\"])\n  1140→        .current_dir(temp_dir.path())\n  1141→        .output()\n  1142→        .expect(\"select project\");\n  1143→\n  1144→    // Write a completed terminal snapshot (no active_run)\n  1145→    let completed_snapshot = r#\"{\n  1146→  \"active_run\": null,\n  1147→  \"status\": \"completed\",\n  1148→  \"cycle_history\": [],\n  1149→  \"completion_rounds\": 3,\n  1150→  \"rollback_point_meta\": { \"last_rollback_id\": null, \"rollback_count\": 0 },\n  1151→  \"amendment_queue\": { \"pending\": [], \"processed_count\": 0 },\n  1152→  \"status_summary\": \"completed after 3 rounds\"\n  1153→}\"#;\n  1154→    fs::write(\n  1155→        temp_dir.path().join(\".ralph-burning/projects/terminal/run.json\"),\n  1156→        completed_snapshot,\n  1157→    )\n  1158→    .expect(\"write completed snapshot\");\n  1159→\n  1160→    let output = Command::new(binary())\n  1161→        .args([\"run\", \"status\"])\n  1162→        .current_dir(temp_dir.path())\n  1163→        .output()\n  1164→        .expect(\"run status\");\n  1165→\n  1166→    assert!(output.status.success());\n  1167→    let stdout = String::from_utf8_lossy(&output.stdout);\n  1168→    assert!(stdout.contains(\"Status: completed\"));\n  1169→    assert!(stdout.contains(\"completed after 3 rounds\"));\n  1170→}\n  1171→\n  1172→#[test]\n  1173→fn run_status_fails_for_semantically_inconsistent_snapshot() {\n  1174→    let temp_dir = initialize_workspace_fixture();\n  1175→    let prompt = write_prompt_fixture(temp_dir.path());\n  1176→\n  1177→    Command::new(binary())\n  1178→        .args([\n  1179→            \"project\", \"create\",\n  1180→            \"--id\", \"inconsist\",\n  1181→            \"--name\", \"Inconsistent\",\n  1182→            \"--prompt\", prompt.to_str().unwrap(),\n  1183→            \"--flow\", \"standard\",\n  1184→        ])\n  1185→        .current_dir(temp_dir.path())\n  1186→        .output()\n  1187→        .expect(\"create project\");\n  1188→\n  1189→    Command::new(binary())\n  1190→        .args([\"project\", \"select\", \"inconsist\"])\n  1191→        .current_dir(temp_dir.path())\n  1192→        .output()\n  1193→        .expect(\"select project\");\n  1194→\n  1195→    // Write a semantically inconsistent snapshot: running with no active_run\n  1196→    let bad_snapshot = r#\"{\n  1197→  \"active_run\": null,\n  1198→  \"status\": \"running\",\n  1199→  \"cycle_history\": [],\n  1200→  \"completion_rounds\": 0,\n  1201→  \"rollback_point_meta\": { \"last_rollback_id\": null, \"rollback_count\": 0 },\n  1202→  \"amendment_queue\": { \"pending\": [], \"processed_count\": 0 },\n  1203→  \"status_summary\": \"running\"\n  1204→}\"#;\n  1205→    fs::write(\n  1206→        temp_dir.path().join(\".ralph-burning/projects/inconsist/run.json\"),\n  1207→        bad_snapshot,\n  1208→    )\n  1209→    .expect(\"write inconsistent snapshot\");\n  1210→\n  1211→    let output = Command::new(binary())\n  1212→        .args([\"run\", \"status\"])\n  1213→        .current_dir(temp_dir.path())\n  1214→        .output()\n  1215→        .expect(\"run status\");\n  1216→\n  1217→    assert!(!output.status.success());\n  1218→    let stderr = String::from_utf8_lossy(&output.stderr);\n  1219→    assert!(stderr.contains(\"run.json\"));\n  1220→    assert!(stderr.contains(\"inconsistent\"));\n  1221→}\n  1222→\n  1223→#[test]\n  1224→fn project_delete_fails_for_semantically_inconsistent_active_run() {\n  1225→    let temp_dir = initialize_workspace_fixture();\n  1226→    let prompt = write_prompt_fixture(temp_dir.path());\n  1227→\n  1228→    Command::new(binary())\n  1229→        .args([\n  1230→            \"project\", \"create\",\n  1231→            \"--id\", \"bad-state\",\n  1232→            \"--name\", \"Bad State\",\n  1233→            \"--prompt\", prompt.to_str().unwrap(),\n  1234→            \"--flow\", \"standard\",\n  1235→        ])\n  1236→        .current_dir(temp_dir.path())\n  1237→        .output()\n  1238→        .expect(\"create project\");\n  1239→\n  1240→    // Write a semantically inconsistent snapshot: paused with no active_run\n  1241→    let bad_snapshot = r#\"{\n  1242→  \"active_run\": null,\n  1243→  \"status\": \"paused\",\n  1244→  \"cycle_history\": [],\n  1245→  \"completion_rounds\": 0,\n  1246→  \"rollback_point_meta\": { \"last_rollback_id\": null, \"rollback_count\": 0 },\n  1247→  \"amendment_queue\": { \"pending\": [], \"processed_count\": 0 },\n  1248→  \"status_summary\": \"paused\"\n  1249→}\"#;\n  1250→    fs::write(\n  1251→        temp_dir.path().join(\".ralph-burning/projects/bad-state/run.json\"),\n  1252→        bad_snapshot,\n  1253→    )\n  1254→    .expect(\"write inconsistent snapshot\");\n  1255→\n  1256→    let output = Command::new(binary())\n  1257→        .args([\"project\", \"delete\", \"bad-state\"])\n  1258→        .current_dir(temp_dir.path())\n  1259→        .output()\n  1260→        .expect(\"run project delete\");\n  1261→\n  1262→    assert!(!output.status.success());\n  1263→    let stderr = String::from_utf8_lossy(&output.stderr);\n  1264→    assert!(stderr.contains(\"run.json\"));\n  1265→    assert!(stderr.contains(\"inconsistent\"));\n  1266→}\n  1267→\n  1268→// ── Run.json schema completeness ──\n  1269→\n  1270→#[test]\n  1271→fn project_create_run_json_contains_all_canonical_fields() {\n  1272→    let temp_dir = initialize_workspace_fixture();\n  1273→    let prompt = write_prompt_fixture(temp_dir.path());\n  1274→\n  1275→    Command::new(binary())\n  1276→        .args([\n  1277→            \"project\", \"create\",\n  1278→            \"--id\", \"schema\",\n  1279→            \"--name\", \"Schema Check\",\n  1280→            \"--prompt\", prompt.to_str().unwrap(),\n  1281→            \"--flow\", \"standard\",\n  1282→        ])\n  1283→        .current_dir(temp_dir.path())\n  1284→        .output()\n  1285→        .expect(\"create project\");\n  1286→\n  1287→    let run_json = fs::read_to_string(\n  1288→        temp_dir.path().join(\".ralph-burning/projects/schema/run.json\"),\n  1289→    )\n  1290→    .expect(\"read run.json\");\n  1291→\n  1292→    assert!(run_json.contains(\"\\\"cycle_history\\\"\"));\n  1293→    assert!(run_json.contains(\"\\\"completion_rounds\\\"\"));\n  1294→    assert!(run_json.contains(\"\\\"rollback_point_meta\\\"\"));\n  1295→    assert!(run_json.contains(\"\\\"amendment_queue\\\"\"));\n  1296→    assert!(run_json.contains(\"\\\"active_run\\\"\"));\n  1297→    assert!(run_json.contains(\"\\\"status\\\"\"));\n  1298→    assert!(run_json.contains(\"\\\"status_summary\\\"\"));\n  1299→}\n  1300→"}]},"parent_tool_use_id":null,"session_id":"5eb81d8b-9dcb-415b-a8cb-cb111e8f40b3","uuid":"2b6ad18c-3529-40a7-8b56-00f31e08b939","tool_use_result":{"type":"text","file":{"filePath":"/root/new-ralph-burning/ralph-burning-rewrite/tests/cli.rs","content":"use std::fs;\nuse std::os::unix::fs::PermissionsExt;\nuse std::process::Command;\n\nuse tempfile::tempdir;\n\nfn binary() -> &'static str {\n    env!(\"CARGO_BIN_EXE_ralph-burning\")\n}\n\nfn initialize_workspace_fixture() -> tempfile::TempDir {\n    let temp_dir = tempdir().expect(\"create temp dir\");\n    let output = Command::new(binary())\n        .arg(\"init\")\n        .current_dir(temp_dir.path())\n        .output()\n        .expect(\"run init\");\n    assert!(output.status.success());\n    temp_dir\n}\n\nfn create_project_fixture(base_dir: &std::path::Path, project_id: &str) {\n    let project_root = base_dir.join(\".ralph-burning/projects\").join(project_id);\n    fs::create_dir_all(&project_root).expect(\"create project directory\");\n    fs::write(project_root.join(\"project.toml\"), \"id = \\\"fixture\\\"\\n\").expect(\"write project\");\n}\n\nfn write_editor_script(\n    base_dir: &std::path::Path,\n    name: &str,\n    contents: &str,\n) -> std::path::PathBuf {\n    let script_path = base_dir.join(name);\n    fs::write(&script_path, contents).expect(\"write editor script\");\n    let mut permissions = fs::metadata(&script_path)\n        .expect(\"script metadata\")\n        .permissions();\n    permissions.set_mode(0o755);\n    fs::set_permissions(&script_path, permissions).expect(\"set script permissions\");\n    script_path\n}\n\n#[test]\nfn flow_list_prints_all_presets() {\n    let output = Command::new(binary())\n        .args([\"flow\", \"list\"])\n        .output()\n        .expect(\"run flow list\");\n\n    assert!(output.status.success());\n\n    let stdout = String::from_utf8_lossy(&output.stdout);\n    assert!(stdout.contains(\"standard\"));\n    assert!(stdout.contains(\"quick_dev\"));\n    assert!(stdout.contains(\"docs_change\"));\n    assert!(stdout.contains(\"ci_improvement\"));\n}\n\n#[test]\nfn flow_show_standard_prints_stage_sequence() {\n    let output = Command::new(binary())\n        .args([\"flow\", \"show\", \"standard\"])\n        .output()\n        .expect(\"run flow show\");\n\n    assert!(output.status.success());\n\n    let stdout = String::from_utf8_lossy(&output.stdout);\n    assert!(stdout.contains(\"Stage count: 8\"));\n    assert!(stdout.contains(\"1. prompt_review\"));\n    assert!(stdout.contains(\"8. final_review\"));\n    assert!(stdout.contains(\"Final review enabled: yes\"));\n}\n\n#[test]\nfn flow_show_invalid_preset_exits_non_zero_with_clear_error() {\n    let output = Command::new(binary())\n        .args([\"flow\", \"show\", \"unknown_flow\"])\n        .output()\n        .expect(\"run flow show invalid\");\n\n    assert!(!output.status.success());\n\n    let stderr = String::from_utf8_lossy(&output.stderr);\n    assert!(stderr.contains(\"unknown flow preset 'unknown_flow'\"));\n}\n\n#[test]\nfn init_creates_workspace_layout() {\n    let temp_dir = tempdir().expect(\"create temp dir\");\n    let output = Command::new(binary())\n        .arg(\"init\")\n        .current_dir(temp_dir.path())\n        .output()\n        .expect(\"run init\");\n\n    assert!(output.status.success());\n    assert!(temp_dir\n        .path()\n        .join(\".ralph-burning/workspace.toml\")\n        .is_file());\n    assert!(temp_dir.path().join(\".ralph-burning/projects\").is_dir());\n    assert!(temp_dir.path().join(\".ralph-burning/requirements\").is_dir());\n    assert!(temp_dir.path().join(\".ralph-burning/daemon/tasks\").is_dir());\n    assert!(temp_dir\n        .path()\n        .join(\".ralph-burning/daemon/leases\")\n        .is_dir());\n}\n\n#[test]\nfn init_fails_when_workspace_already_exists() {\n    let temp_dir = tempdir().expect(\"create temp dir\");\n\n    let first = Command::new(binary())\n        .arg(\"init\")\n        .current_dir(temp_dir.path())\n        .output()\n        .expect(\"run first init\");\n    assert!(first.status.success());\n\n    let second = Command::new(binary())\n        .arg(\"init\")\n        .current_dir(temp_dir.path())\n        .output()\n        .expect(\"run second init\");\n\n    assert!(!second.status.success());\n\n    let stderr = String::from_utf8_lossy(&second.stderr);\n    assert!(stderr.contains(\"workspace already initialized\"));\n}\n\n#[test]\nfn config_show_prints_effective_values_and_sources() {\n    let temp_dir = initialize_workspace_fixture();\n\n    let output = Command::new(binary())\n        .args([\"config\", \"show\"])\n        .current_dir(temp_dir.path())\n        .output()\n        .expect(\"run config show\");\n\n    assert!(output.status.success());\n\n    let stdout = String::from_utf8_lossy(&output.stdout);\n    assert!(stdout.contains(\"[settings]\"));\n    assert!(stdout.contains(\"prompt_review.enabled = true # source: default\"));\n    assert!(stdout.contains(\"default_flow = \\\"standard\\\" # source: default\"));\n    assert!(stdout.contains(\"default_backend = \\\"<unset>\\\" # source: default\"));\n}\n\n#[test]\nfn config_get_prints_known_values_and_rejects_unknown_keys() {\n    let temp_dir = initialize_workspace_fixture();\n\n    let known = Command::new(binary())\n        .args([\"config\", \"get\", \"default_flow\"])\n        .current_dir(temp_dir.path())\n        .output()\n        .expect(\"run config get\");\n    assert!(known.status.success());\n    assert_eq!(\"standard\\n\", String::from_utf8_lossy(&known.stdout));\n\n    let unknown = Command::new(binary())\n        .args([\"config\", \"get\", \"unknown.key\"])\n        .current_dir(temp_dir.path())\n        .output()\n        .expect(\"run config get invalid\");\n    assert!(!unknown.status.success());\n    assert!(String::from_utf8_lossy(&unknown.stderr).contains(\"unknown config key\"));\n}\n\n#[test]\nfn config_set_updates_valid_keys_and_rejects_invalid_values() {\n    let temp_dir = initialize_workspace_fixture();\n\n    let valid = Command::new(binary())\n        .args([\"config\", \"set\", \"default_flow\", \"quick_dev\"])\n        .current_dir(temp_dir.path())\n        .output()\n        .expect(\"run config set\");\n    assert!(valid.status.success());\n    assert!(String::from_utf8_lossy(&valid.stdout).contains(\"Updated default_flow = quick_dev\"));\n\n    let workspace_config =\n        fs::read_to_string(temp_dir.path().join(\".ralph-burning/workspace.toml\"))\n            .expect(\"read workspace config\");\n    assert!(workspace_config.contains(\"default_flow = \\\"quick_dev\\\"\"));\n\n    let invalid_value = Command::new(binary())\n        .args([\"config\", \"set\", \"default_flow\", \"unknown_flow\"])\n        .current_dir(temp_dir.path())\n        .output()\n        .expect(\"run invalid config set\");\n    assert!(!invalid_value.status.success());\n    assert!(String::from_utf8_lossy(&invalid_value.stderr).contains(\"invalid value\"));\n\n    let invalid_key = Command::new(binary())\n        .args([\"config\", \"set\", \"unknown.key\", \"value\"])\n        .current_dir(temp_dir.path())\n        .output()\n        .expect(\"run invalid key config set\");\n    assert!(!invalid_key.status.success());\n    assert!(String::from_utf8_lossy(&invalid_key.stderr).contains(\"unknown config key\"));\n}\n\n#[test]\nfn config_edit_revalidates_workspace_file() {\n    let temp_dir = initialize_workspace_fixture();\n    let editor = write_editor_script(\n        temp_dir.path(),\n        \"editor-valid.sh\",\n        \"#!/bin/sh\\ncat <<'EOF' > \\\"$1\\\"\\nversion = 1\\ncreated_at = \\\"2026-03-11T17:50:55Z\\\"\\n\\n[settings]\\ndefault_backend = \\\"claude\\\"\\nEOF\\n\",\n    );\n\n    let output = Command::new(binary())\n        .args([\"config\", \"edit\"])\n        .env(\"EDITOR\", &editor)\n        .env_remove(\"VISUAL\")\n        .current_dir(temp_dir.path())\n        .output()\n        .expect(\"run config edit\");\n\n    assert!(output.status.success());\n    assert!(String::from_utf8_lossy(&output.stdout).contains(\"Validated workspace.toml\"));\n}\n\n#[test]\nfn config_edit_prefers_editor_over_visual() {\n    let temp_dir = initialize_workspace_fixture();\n    let editor = write_editor_script(\n        temp_dir.path(),\n        \"editor-wins.sh\",\n        \"#!/bin/sh\\ncat <<'EOF' > \\\"$1\\\"\\nversion = 1\\ncreated_at = \\\"2026-03-11T17:50:55Z\\\"\\n\\n[settings]\\ndefault_backend = \\\"editor\\\"\\nEOF\\n\",\n    );\n    let visual = write_editor_script(\n        temp_dir.path(),\n        \"visual-loses.sh\",\n        \"#!/bin/sh\\ncat <<'EOF' > \\\"$1\\\"\\nversion = 1\\ncreated_at = \\\"2026-03-11T17:50:55Z\\\"\\n\\n[settings]\\ndefault_backend = \\\"visual\\\"\\nEOF\\n\",\n    );\n\n    let output = Command::new(binary())\n        .args([\"config\", \"edit\"])\n        .env(\"EDITOR\", &editor)\n        .env(\"VISUAL\", &visual)\n        .current_dir(temp_dir.path())\n        .output()\n        .expect(\"run config edit\");\n\n    assert!(output.status.success());\n\n    let workspace_config =\n        fs::read_to_string(temp_dir.path().join(\".ralph-burning/workspace.toml\"))\n            .expect(\"read workspace config\");\n    assert!(workspace_config.contains(\"default_backend = \\\"editor\\\"\"));\n    assert!(!workspace_config.contains(\"default_backend = \\\"visual\\\"\"));\n}\n\n#[test]\nfn config_edit_fails_when_editor_leaves_invalid_file() {\n    let temp_dir = initialize_workspace_fixture();\n    let editor = write_editor_script(\n        temp_dir.path(),\n        \"editor-invalid.sh\",\n        \"#!/bin/sh\\nprintf '%s\\n' 'version = 999' 'created_at = \\\"2026-03-11T17:50:55Z\\\"' > \\\"$1\\\"\\n\",\n    );\n\n    let output = Command::new(binary())\n        .args([\"config\", \"edit\"])\n        .env(\"EDITOR\", &editor)\n        .env_remove(\"VISUAL\")\n        .current_dir(temp_dir.path())\n        .output()\n        .expect(\"run invalid config edit\");\n\n    assert!(!output.status.success());\n    let stderr = String::from_utf8_lossy(&output.stderr);\n    assert!(stderr.contains(\"workspace.toml is invalid after editing\"));\n    assert!(stderr.contains(\"unsupported workspace version 999\"));\n}\n\n#[test]\nfn project_select_sets_active_project_and_rejects_missing_projects() {\n    let temp_dir = initialize_workspace_fixture();\n    create_project_fixture(temp_dir.path(), \"alpha\");\n\n    let existing = Command::new(binary())\n        .args([\"project\", \"select\", \"alpha\"])\n        .current_dir(temp_dir.path())\n        .output()\n        .expect(\"run project select\");\n    assert!(existing.status.success());\n    assert!(String::from_utf8_lossy(&existing.stdout).contains(\"Selected project alpha\"));\n    assert_eq!(\n        \"alpha\",\n        fs::read_to_string(temp_dir.path().join(\".ralph-burning/active-project\"))\n            .expect(\"read active project\")\n    );\n\n    let missing = Command::new(binary())\n        .args([\"project\", \"select\", \"missing\"])\n        .current_dir(temp_dir.path())\n        .output()\n        .expect(\"run missing project select\");\n    assert!(!missing.status.success());\n    assert!(String::from_utf8_lossy(&missing.stderr).contains(\"project 'missing' was not found\"));\n}\n\n#[test]\nfn project_select_rejects_path_like_ids_before_writing_active_project() {\n    let temp_dir = initialize_workspace_fixture();\n\n    let output = Command::new(binary())\n        .args([\"project\", \"select\", \"../escape\"])\n        .current_dir(temp_dir.path())\n        .output()\n        .expect(\"run path-like project select\");\n\n    assert!(!output.status.success());\n    assert!(String::from_utf8_lossy(&output.stderr).contains(\"invalid identifier\"));\n    assert!(!temp_dir\n        .path()\n        .join(\".ralph-burning/active-project\")\n        .exists());\n}\n\n// ── Project Create ──\n\nfn write_prompt_fixture(base_dir: &std::path::Path) -> std::path::PathBuf {\n    let prompt_path = base_dir.join(\"test-prompt.md\");\n    fs::write(&prompt_path, \"# Test Prompt\\nImplement the feature.\\n\").expect(\"write prompt\");\n    prompt_path\n}\n\n#[test]\nfn project_create_succeeds_and_writes_all_canonical_files() {\n    let temp_dir = initialize_workspace_fixture();\n    let prompt = write_prompt_fixture(temp_dir.path());\n\n    let output = Command::new(binary())\n        .args([\n            \"project\", \"create\",\n            \"--id\", \"alpha\",\n            \"--name\", \"Alpha Project\",\n            \"--prompt\", prompt.to_str().unwrap(),\n            \"--flow\", \"standard\",\n        ])\n        .current_dir(temp_dir.path())\n        .output()\n        .expect(\"run project create\");\n\n    assert!(output.status.success(), \"stderr: {}\", String::from_utf8_lossy(&output.stderr));\n\n    let stdout = String::from_utf8_lossy(&output.stdout);\n    assert!(stdout.contains(\"Created project 'alpha'\"));\n    assert!(stdout.contains(\"standard\"));\n\n    let project_root = temp_dir.path().join(\".ralph-burning/projects/alpha\");\n    assert!(project_root.join(\"project.toml\").is_file());\n    assert!(project_root.join(\"prompt.md\").is_file());\n    assert!(project_root.join(\"run.json\").is_file());\n    assert!(project_root.join(\"journal.ndjson\").is_file());\n    assert!(project_root.join(\"sessions.json\").is_file());\n    assert!(project_root.join(\"history/payloads\").is_dir());\n    assert!(project_root.join(\"history/artifacts\").is_dir());\n    assert!(project_root.join(\"runtime/logs\").is_dir());\n    assert!(project_root.join(\"runtime/backend\").is_dir());\n    assert!(project_root.join(\"runtime/temp\").is_dir());\n    assert!(project_root.join(\"amendments\").is_dir());\n    assert!(project_root.join(\"rollback\").is_dir());\n}\n\n#[test]\nfn project_create_initializes_journal_with_project_created_event() {\n    let temp_dir = initialize_workspace_fixture();\n    let prompt = write_prompt_fixture(temp_dir.path());\n\n    let output = Command::new(binary())\n        .args([\n            \"project\", \"create\",\n            \"--id\", \"beta\",\n            \"--name\", \"Beta\",\n            \"--prompt\", prompt.to_str().unwrap(),\n            \"--flow\", \"quick_dev\",\n        ])\n        .current_dir(temp_dir.path())\n        .output()\n        .expect(\"run project create\");\n    assert!(output.status.success());\n\n    let journal = fs::read_to_string(\n        temp_dir.path().join(\".ralph-burning/projects/beta/journal.ndjson\"),\n    )\n    .expect(\"read journal\");\n\n    assert!(journal.contains(\"\\\"project_created\\\"\"));\n    assert!(journal.contains(\"\\\"sequence\\\":1\"));\n}\n\n#[test]\nfn project_create_run_json_shows_not_started() {\n    let temp_dir = initialize_workspace_fixture();\n    let prompt = write_prompt_fixture(temp_dir.path());\n\n    Command::new(binary())\n        .args([\n            \"project\", \"create\",\n            \"--id\", \"gamma\",\n            \"--name\", \"Gamma\",\n            \"--prompt\", prompt.to_str().unwrap(),\n            \"--flow\", \"standard\",\n        ])\n        .current_dir(temp_dir.path())\n        .output()\n        .expect(\"run project create\");\n\n    let run_json = fs::read_to_string(\n        temp_dir.path().join(\".ralph-burning/projects/gamma/run.json\"),\n    )\n    .expect(\"read run.json\");\n\n    assert!(run_json.contains(\"\\\"not_started\\\"\"));\n    assert!(run_json.contains(\"\\\"active_run\\\": null\"));\n}\n\n#[test]\nfn project_create_fails_on_duplicate_id() {\n    let temp_dir = initialize_workspace_fixture();\n    let prompt = write_prompt_fixture(temp_dir.path());\n\n    let first = Command::new(binary())\n        .args([\n            \"project\", \"create\",\n            \"--id\", \"dup\",\n            \"--name\", \"First\",\n            \"--prompt\", prompt.to_str().unwrap(),\n            \"--flow\", \"standard\",\n        ])\n        .current_dir(temp_dir.path())\n        .output()\n        .expect(\"first create\");\n    assert!(first.status.success());\n\n    let second = Command::new(binary())\n        .args([\n            \"project\", \"create\",\n            \"--id\", \"dup\",\n            \"--name\", \"Second\",\n            \"--prompt\", prompt.to_str().unwrap(),\n            \"--flow\", \"standard\",\n        ])\n        .current_dir(temp_dir.path())\n        .output()\n        .expect(\"second create\");\n\n    assert!(!second.status.success());\n    let stderr = String::from_utf8_lossy(&second.stderr);\n    assert!(stderr.contains(\"already exists\"));\n}\n\n#[test]\nfn project_create_fails_on_invalid_flow() {\n    let temp_dir = initialize_workspace_fixture();\n    let prompt = write_prompt_fixture(temp_dir.path());\n\n    let output = Command::new(binary())\n        .args([\n            \"project\", \"create\",\n            \"--id\", \"bad-flow\",\n            \"--name\", \"Bad Flow\",\n            \"--prompt\", prompt.to_str().unwrap(),\n            \"--flow\", \"nonexistent\",\n        ])\n        .current_dir(temp_dir.path())\n        .output()\n        .expect(\"run project create\");\n\n    assert!(!output.status.success());\n    let stderr = String::from_utf8_lossy(&output.stderr);\n    assert!(stderr.contains(\"unknown flow preset\"));\n}\n\n#[test]\nfn project_create_fails_on_missing_prompt() {\n    let temp_dir = initialize_workspace_fixture();\n\n    let output = Command::new(binary())\n        .args([\n            \"project\", \"create\",\n            \"--id\", \"no-prompt\",\n            \"--name\", \"No Prompt\",\n            \"--prompt\", \"/nonexistent/prompt.md\",\n            \"--flow\", \"standard\",\n        ])\n        .current_dir(temp_dir.path())\n        .output()\n        .expect(\"run project create\");\n\n    assert!(!output.status.success());\n    let stderr = String::from_utf8_lossy(&output.stderr);\n    assert!(stderr.contains(\"invalid prompt file\"));\n}\n\n#[test]\nfn project_create_does_not_set_active_project() {\n    let temp_dir = initialize_workspace_fixture();\n    let prompt = write_prompt_fixture(temp_dir.path());\n\n    Command::new(binary())\n        .args([\n            \"project\", \"create\",\n            \"--id\", \"noactive\",\n            \"--name\", \"No Active\",\n            \"--prompt\", prompt.to_str().unwrap(),\n            \"--flow\", \"standard\",\n        ])\n        .current_dir(temp_dir.path())\n        .output()\n        .expect(\"run project create\");\n\n    // active-project should not exist (create does not set it)\n    assert!(!temp_dir\n        .path()\n        .join(\".ralph-burning/active-project\")\n        .exists());\n}\n\n// ── Project List ──\n\n#[test]\nfn project_list_shows_no_projects_when_empty() {\n    let temp_dir = initialize_workspace_fixture();\n\n    let output = Command::new(binary())\n        .args([\"project\", \"list\"])\n        .current_dir(temp_dir.path())\n        .output()\n        .expect(\"run project list\");\n\n    assert!(output.status.success());\n    let stdout = String::from_utf8_lossy(&output.stdout);\n    assert!(stdout.contains(\"No projects found\"));\n}\n\n#[test]\nfn project_list_shows_created_projects_with_active_marker() {\n    let temp_dir = initialize_workspace_fixture();\n    let prompt = write_prompt_fixture(temp_dir.path());\n\n    // Create two projects\n    Command::new(binary())\n        .args([\n            \"project\", \"create\",\n            \"--id\", \"alpha\",\n            \"--name\", \"Alpha\",\n            \"--prompt\", prompt.to_str().unwrap(),\n            \"--flow\", \"standard\",\n        ])\n        .current_dir(temp_dir.path())\n        .output()\n        .expect(\"create alpha\");\n\n    Command::new(binary())\n        .args([\n            \"project\", \"create\",\n            \"--id\", \"beta\",\n            \"--name\", \"Beta\",\n            \"--prompt\", prompt.to_str().unwrap(),\n            \"--flow\", \"quick_dev\",\n        ])\n        .current_dir(temp_dir.path())\n        .output()\n        .expect(\"create beta\");\n\n    // Select alpha as active\n    Command::new(binary())\n        .args([\"project\", \"select\", \"alpha\"])\n        .current_dir(temp_dir.path())\n        .output()\n        .expect(\"select alpha\");\n\n    let output = Command::new(binary())\n        .args([\"project\", \"list\"])\n        .current_dir(temp_dir.path())\n        .output()\n        .expect(\"run project list\");\n\n    assert!(output.status.success());\n    let stdout = String::from_utf8_lossy(&output.stdout);\n    assert!(stdout.contains(\"alpha *\"));\n    assert!(stdout.contains(\"beta\"));\n    assert!(stdout.contains(\"standard\"));\n    assert!(stdout.contains(\"quick_dev\"));\n}\n\n// ── Project Show ──\n\n#[test]\nfn project_show_displays_project_details() {\n    let temp_dir = initialize_workspace_fixture();\n    let prompt = write_prompt_fixture(temp_dir.path());\n\n    Command::new(binary())\n        .args([\n            \"project\", \"create\",\n            \"--id\", \"showme\",\n            \"--name\", \"Show Me\",\n            \"--prompt\", prompt.to_str().unwrap(),\n            \"--flow\", \"docs_change\",\n        ])\n        .current_dir(temp_dir.path())\n        .output()\n        .expect(\"create project\");\n\n    let output = Command::new(binary())\n        .args([\"project\", \"show\", \"showme\"])\n        .current_dir(temp_dir.path())\n        .output()\n        .expect(\"run project show\");\n\n    assert!(output.status.success());\n    let stdout = String::from_utf8_lossy(&output.stdout);\n    assert!(stdout.contains(\"Project: showme\"));\n    assert!(stdout.contains(\"Name: Show Me\"));\n    assert!(stdout.contains(\"Flow: docs_change\"));\n    assert!(stdout.contains(\"Prompt hash:\"));\n    assert!(stdout.contains(\"Run status: not started\"));\n    assert!(stdout.contains(\"Journal events: 1\"));\n}\n\n#[test]\nfn project_show_resolves_active_project_when_no_id_given() {\n    let temp_dir = initialize_workspace_fixture();\n    let prompt = write_prompt_fixture(temp_dir.path());\n\n    Command::new(binary())\n        .args([\n            \"project\", \"create\",\n            \"--id\", \"active-show\",\n            \"--name\", \"Active Show\",\n            \"--prompt\", prompt.to_str().unwrap(),\n            \"--flow\", \"standard\",\n        ])\n        .current_dir(temp_dir.path())\n        .output()\n        .expect(\"create project\");\n\n    Command::new(binary())\n        .args([\"project\", \"select\", \"active-show\"])\n        .current_dir(temp_dir.path())\n        .output()\n        .expect(\"select project\");\n\n    let output = Command::new(binary())\n        .args([\"project\", \"show\"])\n        .current_dir(temp_dir.path())\n        .output()\n        .expect(\"run project show without id\");\n\n    assert!(output.status.success());\n    let stdout = String::from_utf8_lossy(&output.stdout);\n    assert!(stdout.contains(\"Project: active-show (active)\"));\n}\n\n// ── Project Delete ──\n\n#[test]\nfn project_delete_removes_project_directory() {\n    let temp_dir = initialize_workspace_fixture();\n    let prompt = write_prompt_fixture(temp_dir.path());\n\n    Command::new(binary())\n        .args([\n            \"project\", \"create\",\n            \"--id\", \"deleteme\",\n            \"--name\", \"Delete Me\",\n            \"--prompt\", prompt.to_str().unwrap(),\n            \"--flow\", \"standard\",\n        ])\n        .current_dir(temp_dir.path())\n        .output()\n        .expect(\"create project\");\n\n    let output = Command::new(binary())\n        .args([\"project\", \"delete\", \"deleteme\"])\n        .current_dir(temp_dir.path())\n        .output()\n        .expect(\"run project delete\");\n\n    assert!(output.status.success());\n    let stdout = String::from_utf8_lossy(&output.stdout);\n    assert!(stdout.contains(\"Deleted project 'deleteme'\"));\n    assert!(!temp_dir\n        .path()\n        .join(\".ralph-burning/projects/deleteme\")\n        .exists());\n}\n\n#[test]\nfn project_delete_clears_active_project_if_selected() {\n    let temp_dir = initialize_workspace_fixture();\n    let prompt = write_prompt_fixture(temp_dir.path());\n\n    Command::new(binary())\n        .args([\n            \"project\", \"create\",\n            \"--id\", \"active-del\",\n            \"--name\", \"Active Del\",\n            \"--prompt\", prompt.to_str().unwrap(),\n            \"--flow\", \"standard\",\n        ])\n        .current_dir(temp_dir.path())\n        .output()\n        .expect(\"create project\");\n\n    Command::new(binary())\n        .args([\"project\", \"select\", \"active-del\"])\n        .current_dir(temp_dir.path())\n        .output()\n        .expect(\"select project\");\n\n    assert!(temp_dir\n        .path()\n        .join(\".ralph-burning/active-project\")\n        .exists());\n\n    let output = Command::new(binary())\n        .args([\"project\", \"delete\", \"active-del\"])\n        .current_dir(temp_dir.path())\n        .output()\n        .expect(\"run project delete\");\n\n    assert!(output.status.success());\n    assert!(!temp_dir\n        .path()\n        .join(\".ralph-burning/active-project\")\n        .exists());\n}\n\n#[test]\nfn project_delete_fails_for_missing_project() {\n    let temp_dir = initialize_workspace_fixture();\n\n    let output = Command::new(binary())\n        .args([\"project\", \"delete\", \"nonexistent\"])\n        .current_dir(temp_dir.path())\n        .output()\n        .expect(\"run project delete\");\n\n    assert!(!output.status.success());\n    let stderr = String::from_utf8_lossy(&output.stderr);\n    assert!(stderr.contains(\"not found\"));\n}\n\n// ── Run Status ──\n\n#[test]\nfn run_status_shows_not_started_for_new_project() {\n    let temp_dir = initialize_workspace_fixture();\n    let prompt = write_prompt_fixture(temp_dir.path());\n\n    Command::new(binary())\n        .args([\n            \"project\", \"create\",\n            \"--id\", \"status-test\",\n            \"--name\", \"Status Test\",\n            \"--prompt\", prompt.to_str().unwrap(),\n            \"--flow\", \"standard\",\n        ])\n        .current_dir(temp_dir.path())\n        .output()\n        .expect(\"create project\");\n\n    Command::new(binary())\n        .args([\"project\", \"select\", \"status-test\"])\n        .current_dir(temp_dir.path())\n        .output()\n        .expect(\"select project\");\n\n    let output = Command::new(binary())\n        .args([\"run\", \"status\"])\n        .current_dir(temp_dir.path())\n        .output()\n        .expect(\"run status\");\n\n    assert!(output.status.success());\n    let stdout = String::from_utf8_lossy(&output.stdout);\n    assert!(stdout.contains(\"Status: not started\"));\n}\n\n// ── Run History ──\n\n#[test]\nfn run_history_shows_journal_events_for_new_project() {\n    let temp_dir = initialize_workspace_fixture();\n    let prompt = write_prompt_fixture(temp_dir.path());\n\n    Command::new(binary())\n        .args([\n            \"project\", \"create\",\n            \"--id\", \"hist-test\",\n            \"--name\", \"History Test\",\n            \"--prompt\", prompt.to_str().unwrap(),\n            \"--flow\", \"standard\",\n        ])\n        .current_dir(temp_dir.path())\n        .output()\n        .expect(\"create project\");\n\n    Command::new(binary())\n        .args([\"project\", \"select\", \"hist-test\"])\n        .current_dir(temp_dir.path())\n        .output()\n        .expect(\"select project\");\n\n    let output = Command::new(binary())\n        .args([\"run\", \"history\"])\n        .current_dir(temp_dir.path())\n        .output()\n        .expect(\"run history\");\n\n    assert!(output.status.success());\n    let stdout = String::from_utf8_lossy(&output.stdout);\n    assert!(stdout.contains(\"Journal Events\"));\n    assert!(stdout.contains(\"ProjectCreated\"));\n}\n\n// ── Run Tail ──\n\n#[test]\nfn run_tail_shows_durable_history_only_by_default() {\n    let temp_dir = initialize_workspace_fixture();\n    let prompt = write_prompt_fixture(temp_dir.path());\n\n    Command::new(binary())\n        .args([\n            \"project\", \"create\",\n            \"--id\", \"tail-test\",\n            \"--name\", \"Tail Test\",\n            \"--prompt\", prompt.to_str().unwrap(),\n            \"--flow\", \"standard\",\n        ])\n        .current_dir(temp_dir.path())\n        .output()\n        .expect(\"create project\");\n\n    Command::new(binary())\n        .args([\"project\", \"select\", \"tail-test\"])\n        .current_dir(temp_dir.path())\n        .output()\n        .expect(\"select project\");\n\n    let output = Command::new(binary())\n        .args([\"run\", \"tail\"])\n        .current_dir(temp_dir.path())\n        .output()\n        .expect(\"run tail\");\n\n    assert!(output.status.success());\n    let stdout = String::from_utf8_lossy(&output.stdout);\n    assert!(stdout.contains(\"Durable History\"));\n    // No runtime logs section when --logs not passed\n    assert!(!stdout.contains(\"Runtime Logs\"));\n}\n\n#[test]\nfn run_tail_with_logs_includes_runtime_logs_section() {\n    let temp_dir = initialize_workspace_fixture();\n    let prompt = write_prompt_fixture(temp_dir.path());\n\n    Command::new(binary())\n        .args([\n            \"project\", \"create\",\n            \"--id\", \"tail-logs\",\n            \"--name\", \"Tail Logs\",\n            \"--prompt\", prompt.to_str().unwrap(),\n            \"--flow\", \"standard\",\n        ])\n        .current_dir(temp_dir.path())\n        .output()\n        .expect(\"create project\");\n\n    Command::new(binary())\n        .args([\"project\", \"select\", \"tail-logs\"])\n        .current_dir(temp_dir.path())\n        .output()\n        .expect(\"select project\");\n\n    let output = Command::new(binary())\n        .args([\"run\", \"tail\", \"--logs\"])\n        .current_dir(temp_dir.path())\n        .output()\n        .expect(\"run tail --logs\");\n\n    assert!(output.status.success());\n    let stdout = String::from_utf8_lossy(&output.stdout);\n    assert!(stdout.contains(\"Durable History\"));\n    assert!(stdout.contains(\"Runtime Logs\"));\n}\n\n// ── Fail-fast on missing canonical files ──\n\n#[test]\nfn run_status_fails_fast_when_run_json_is_missing() {\n    let temp_dir = initialize_workspace_fixture();\n    let prompt = write_prompt_fixture(temp_dir.path());\n\n    Command::new(binary())\n        .args([\n            \"project\", \"create\",\n            \"--id\", \"broken\",\n            \"--name\", \"Broken\",\n            \"--prompt\", prompt.to_str().unwrap(),\n            \"--flow\", \"standard\",\n        ])\n        .current_dir(temp_dir.path())\n        .output()\n        .expect(\"create project\");\n\n    Command::new(binary())\n        .args([\"project\", \"select\", \"broken\"])\n        .current_dir(temp_dir.path())\n        .output()\n        .expect(\"select project\");\n\n    // Delete run.json to simulate corruption\n    fs::remove_file(\n        temp_dir.path().join(\".ralph-burning/projects/broken/run.json\"),\n    )\n    .expect(\"remove run.json\");\n\n    let output = Command::new(binary())\n        .args([\"run\", \"status\"])\n        .current_dir(temp_dir.path())\n        .output()\n        .expect(\"run status\");\n\n    assert!(!output.status.success());\n    let stderr = String::from_utf8_lossy(&output.stderr);\n    assert!(stderr.contains(\"run.json\"));\n    assert!(stderr.contains(\"missing\"));\n}\n\n#[test]\nfn run_history_fails_fast_when_journal_is_missing() {\n    let temp_dir = initialize_workspace_fixture();\n    let prompt = write_prompt_fixture(temp_dir.path());\n\n    Command::new(binary())\n        .args([\n            \"project\", \"create\",\n            \"--id\", \"nojrnl\",\n            \"--name\", \"No Journal\",\n            \"--prompt\", prompt.to_str().unwrap(),\n            \"--flow\", \"standard\",\n        ])\n        .current_dir(temp_dir.path())\n        .output()\n        .expect(\"create project\");\n\n    Command::new(binary())\n        .args([\"project\", \"select\", \"nojrnl\"])\n        .current_dir(temp_dir.path())\n        .output()\n        .expect(\"select project\");\n\n    // Delete journal.ndjson to simulate corruption\n    fs::remove_file(\n        temp_dir.path().join(\".ralph-burning/projects/nojrnl/journal.ndjson\"),\n    )\n    .expect(\"remove journal\");\n\n    let output = Command::new(binary())\n        .args([\"run\", \"history\"])\n        .current_dir(temp_dir.path())\n        .output()\n        .expect(\"run history\");\n\n    assert!(!output.status.success());\n    let stderr = String::from_utf8_lossy(&output.stderr);\n    assert!(stderr.contains(\"journal.ndjson\"));\n    assert!(stderr.contains(\"missing\"));\n}\n\n#[test]\nfn run_status_fails_fast_when_run_json_is_corrupt() {\n    let temp_dir = initialize_workspace_fixture();\n    let prompt = write_prompt_fixture(temp_dir.path());\n\n    Command::new(binary())\n        .args([\n            \"project\", \"create\",\n            \"--id\", \"corrupt\",\n            \"--name\", \"Corrupt\",\n            \"--prompt\", prompt.to_str().unwrap(),\n            \"--flow\", \"standard\",\n        ])\n        .current_dir(temp_dir.path())\n        .output()\n        .expect(\"create project\");\n\n    Command::new(binary())\n        .args([\"project\", \"select\", \"corrupt\"])\n        .current_dir(temp_dir.path())\n        .output()\n        .expect(\"select project\");\n\n    // Write corrupt JSON to run.json\n    fs::write(\n        temp_dir.path().join(\".ralph-burning/projects/corrupt/run.json\"),\n        \"{invalid json}\",\n    )\n    .expect(\"corrupt run.json\");\n\n    let output = Command::new(binary())\n        .args([\"run\", \"status\"])\n        .current_dir(temp_dir.path())\n        .output()\n        .expect(\"run status\");\n\n    assert!(!output.status.success());\n    let stderr = String::from_utf8_lossy(&output.stderr);\n    assert!(stderr.contains(\"run.json\"));\n}\n\n// ── Missing project.toml corruption detection ──\n\n#[test]\nfn project_show_fails_fast_when_project_toml_is_missing() {\n    let temp_dir = initialize_workspace_fixture();\n    let prompt = write_prompt_fixture(temp_dir.path());\n\n    Command::new(binary())\n        .args([\n            \"project\", \"create\",\n            \"--id\", \"corrupt-proj\",\n            \"--name\", \"Corrupt\",\n            \"--prompt\", prompt.to_str().unwrap(),\n            \"--flow\", \"standard\",\n        ])\n        .current_dir(temp_dir.path())\n        .output()\n        .expect(\"create project\");\n\n    // Delete project.toml to simulate corruption\n    fs::remove_file(\n        temp_dir.path().join(\".ralph-burning/projects/corrupt-proj/project.toml\"),\n    )\n    .expect(\"remove project.toml\");\n\n    let output = Command::new(binary())\n        .args([\"project\", \"show\", \"corrupt-proj\"])\n        .current_dir(temp_dir.path())\n        .output()\n        .expect(\"run project show\");\n\n    assert!(!output.status.success());\n    let stderr = String::from_utf8_lossy(&output.stderr);\n    assert!(stderr.contains(\"project.toml\"));\n    assert!(stderr.contains(\"missing\"));\n}\n\n#[test]\nfn project_list_fails_fast_when_project_toml_is_missing() {\n    let temp_dir = initialize_workspace_fixture();\n    let prompt = write_prompt_fixture(temp_dir.path());\n\n    Command::new(binary())\n        .args([\n            \"project\", \"create\",\n            \"--id\", \"good-proj\",\n            \"--name\", \"Good\",\n            \"--prompt\", prompt.to_str().unwrap(),\n            \"--flow\", \"standard\",\n        ])\n        .current_dir(temp_dir.path())\n        .output()\n        .expect(\"create project\");\n\n    // Delete project.toml to simulate corruption\n    fs::remove_file(\n        temp_dir.path().join(\".ralph-burning/projects/good-proj/project.toml\"),\n    )\n    .expect(\"remove project.toml\");\n\n    let output = Command::new(binary())\n        .args([\"project\", \"list\"])\n        .current_dir(temp_dir.path())\n        .output()\n        .expect(\"run project list\");\n\n    assert!(!output.status.success());\n    let stderr = String::from_utf8_lossy(&output.stderr);\n    assert!(stderr.contains(\"project.toml\"));\n    assert!(stderr.contains(\"missing\"));\n}\n\n#[test]\nfn project_delete_fails_fast_when_project_toml_is_missing() {\n    let temp_dir = initialize_workspace_fixture();\n\n    // Create a bare directory without project.toml (simulates corruption)\n    let corrupt_dir = temp_dir.path().join(\".ralph-burning/projects/bare-proj\");\n    fs::create_dir_all(&corrupt_dir).expect(\"create bare project dir\");\n\n    let output = Command::new(binary())\n        .args([\"project\", \"delete\", \"bare-proj\"])\n        .current_dir(temp_dir.path())\n        .output()\n        .expect(\"run project delete\");\n\n    assert!(!output.status.success());\n    let stderr = String::from_utf8_lossy(&output.stderr);\n    assert!(stderr.contains(\"project.toml\"));\n    assert!(stderr.contains(\"missing\"));\n}\n\n// ── Terminal snapshot status reporting ──\n\n#[test]\nfn run_status_reports_completed_for_terminal_run_snapshot() {\n    let temp_dir = initialize_workspace_fixture();\n    let prompt = write_prompt_fixture(temp_dir.path());\n\n    Command::new(binary())\n        .args([\n            \"project\", \"create\",\n            \"--id\", \"terminal\",\n            \"--name\", \"Terminal\",\n            \"--prompt\", prompt.to_str().unwrap(),\n            \"--flow\", \"standard\",\n        ])\n        .current_dir(temp_dir.path())\n        .output()\n        .expect(\"create project\");\n\n    Command::new(binary())\n        .args([\"project\", \"select\", \"terminal\"])\n        .current_dir(temp_dir.path())\n        .output()\n        .expect(\"select project\");\n\n    // Write a completed terminal snapshot (no active_run)\n    let completed_snapshot = r#\"{\n  \"active_run\": null,\n  \"status\": \"completed\",\n  \"cycle_history\": [],\n  \"completion_rounds\": 3,\n  \"rollback_point_meta\": { \"last_rollback_id\": null, \"rollback_count\": 0 },\n  \"amendment_queue\": { \"pending\": [], \"processed_count\": 0 },\n  \"status_summary\": \"completed after 3 rounds\"\n}\"#;\n    fs::write(\n        temp_dir.path().join(\".ralph-burning/projects/terminal/run.json\"),\n        completed_snapshot,\n    )\n    .expect(\"write completed snapshot\");\n\n    let output = Command::new(binary())\n        .args([\"run\", \"status\"])\n        .current_dir(temp_dir.path())\n        .output()\n        .expect(\"run status\");\n\n    assert!(output.status.success());\n    let stdout = String::from_utf8_lossy(&output.stdout);\n    assert!(stdout.contains(\"Status: completed\"));\n    assert!(stdout.contains(\"completed after 3 rounds\"));\n}\n\n#[test]\nfn run_status_fails_for_semantically_inconsistent_snapshot() {\n    let temp_dir = initialize_workspace_fixture();\n    let prompt = write_prompt_fixture(temp_dir.path());\n\n    Command::new(binary())\n        .args([\n            \"project\", \"create\",\n            \"--id\", \"inconsist\",\n            \"--name\", \"Inconsistent\",\n            \"--prompt\", prompt.to_str().unwrap(),\n            \"--flow\", \"standard\",\n        ])\n        .current_dir(temp_dir.path())\n        .output()\n        .expect(\"create project\");\n\n    Command::new(binary())\n        .args([\"project\", \"select\", \"inconsist\"])\n        .current_dir(temp_dir.path())\n        .output()\n        .expect(\"select project\");\n\n    // Write a semantically inconsistent snapshot: running with no active_run\n    let bad_snapshot = r#\"{\n  \"active_run\": null,\n  \"status\": \"running\",\n  \"cycle_history\": [],\n  \"completion_rounds\": 0,\n  \"rollback_point_meta\": { \"last_rollback_id\": null, \"rollback_count\": 0 },\n  \"amendment_queue\": { \"pending\": [], \"processed_count\": 0 },\n  \"status_summary\": \"running\"\n}\"#;\n    fs::write(\n        temp_dir.path().join(\".ralph-burning/projects/inconsist/run.json\"),\n        bad_snapshot,\n    )\n    .expect(\"write inconsistent snapshot\");\n\n    let output = Command::new(binary())\n        .args([\"run\", \"status\"])\n        .current_dir(temp_dir.path())\n        .output()\n        .expect(\"run status\");\n\n    assert!(!output.status.success());\n    let stderr = String::from_utf8_lossy(&output.stderr);\n    assert!(stderr.contains(\"run.json\"));\n    assert!(stderr.contains(\"inconsistent\"));\n}\n\n#[test]\nfn project_delete_fails_for_semantically_inconsistent_active_run() {\n    let temp_dir = initialize_workspace_fixture();\n    let prompt = write_prompt_fixture(temp_dir.path());\n\n    Command::new(binary())\n        .args([\n            \"project\", \"create\",\n            \"--id\", \"bad-state\",\n            \"--name\", \"Bad State\",\n            \"--prompt\", prompt.to_str().unwrap(),\n            \"--flow\", \"standard\",\n        ])\n        .current_dir(temp_dir.path())\n        .output()\n        .expect(\"create project\");\n\n    // Write a semantically inconsistent snapshot: paused with no active_run\n    let bad_snapshot = r#\"{\n  \"active_run\": null,\n  \"status\": \"paused\",\n  \"cycle_history\": [],\n  \"completion_rounds\": 0,\n  \"rollback_point_meta\": { \"last_rollback_id\": null, \"rollback_count\": 0 },\n  \"amendment_queue\": { \"pending\": [], \"processed_count\": 0 },\n  \"status_summary\": \"paused\"\n}\"#;\n    fs::write(\n        temp_dir.path().join(\".ralph-burning/projects/bad-state/run.json\"),\n        bad_snapshot,\n    )\n    .expect(\"write inconsistent snapshot\");\n\n    let output = Command::new(binary())\n        .args([\"project\", \"delete\", \"bad-state\"])\n        .current_dir(temp_dir.path())\n        .output()\n        .expect(\"run project delete\");\n\n    assert!(!output.status.success());\n    let stderr = String::from_utf8_lossy(&output.stderr);\n    assert!(stderr.contains(\"run.json\"));\n    assert!(stderr.contains(\"inconsistent\"));\n}\n\n// ── Run.json schema completeness ──\n\n#[test]\nfn project_create_run_json_contains_all_canonical_fields() {\n    let temp_dir = initialize_workspace_fixture();\n    let prompt = write_prompt_fixture(temp_dir.path());\n\n    Command::new(binary())\n        .args([\n            \"project\", \"create\",\n            \"--id\", \"schema\",\n            \"--name\", \"Schema Check\",\n            \"--prompt\", prompt.to_str().unwrap(),\n            \"--flow\", \"standard\",\n        ])\n        .current_dir(temp_dir.path())\n        .output()\n        .expect(\"create project\");\n\n    let run_json = fs::read_to_string(\n        temp_dir.path().join(\".ralph-burning/projects/schema/run.json\"),\n    )\n    .expect(\"read run.json\");\n\n    assert!(run_json.contains(\"\\\"cycle_history\\\"\"));\n    assert!(run_json.contains(\"\\\"completion_rounds\\\"\"));\n    assert!(run_json.contains(\"\\\"rollback_point_meta\\\"\"));\n    assert!(run_json.contains(\"\\\"amendment_queue\\\"\"));\n    assert!(run_json.contains(\"\\\"active_run\\\"\"));\n    assert!(run_json.contains(\"\\\"status\\\"\"));\n    assert!(run_json.contains(\"\\\"status_summary\\\"\"));\n}\n","numLines":1300,"startLine":1,"totalLines":1300}}}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01M1JR6P7kc8qJUZK2YxKNyv","type":"tool_result","content":"     1→Feature: Project Records\n     2→  Canonical project CRUD and immutable flow enforcement.\n     3→\n     4→  # SC-PROJ-001\n     5→  Scenario: Project creation writes all canonical files\n     6→    Given an initialized workspace\n     7→    And a readable prompt file \"prompt.md\"\n     8→    When the user runs \"project create --id alpha --name Alpha --prompt prompt.md --flow standard\"\n     9→    Then the command succeeds\n    10→    And the project directory \"alpha\" contains \"project.toml\", \"prompt.md\", \"run.json\", \"journal.ndjson\", \"sessions.json\"\n    11→    And the project directory \"alpha\" contains subdirectories \"history/payloads\", \"history/artifacts\", \"runtime/logs\", \"runtime/backend\", \"runtime/temp\", \"amendments\", \"rollback\"\n    12→    And \"journal.ndjson\" contains a \"project_created\" event with sequence 1\n    13→    And \"run.json\" shows status \"not_started\" with no active run\n    14→\n    15→  # SC-PROJ-002\n    16→  Scenario: Duplicate project ID is rejected\n    17→    Given an initialized workspace with project \"alpha\"\n    18→    When the user runs \"project create --id alpha --name Again --prompt prompt.md --flow standard\"\n    19→    Then the command fails with error containing \"already exists\"\n    20→    And the existing project \"alpha\" is unchanged\n    21→\n    22→  # SC-PROJ-003\n    23→  Scenario: Flow is immutable after project creation\n    24→    Given an initialized workspace with project \"alpha\" using flow \"standard\"\n    25→    Then \"project.toml\" for \"alpha\" contains flow \"standard\"\n    26→    And there is no CLI or store path to change the flow after creation\n    27→\n    28→  # SC-PROJ-004\n    29→  Scenario: Project list reads canonical records not directory names\n    30→    Given an initialized workspace with projects \"alpha\" and \"beta\"\n    31→    And \"alpha\" is the active project\n    32→    When the user runs \"project list\"\n    33→    Then the output includes \"alpha\" marked as active\n    34→    And the output includes \"beta\" not marked as active\n    35→    And each entry shows flow, status, and name from canonical records\n    36→\n    37→  # SC-PROJ-005\n    38→  Scenario: Project show displays explicit data\n    39→    Given an initialized workspace with project \"alpha\" using flow \"standard\"\n    40→    When the user runs \"project show alpha\"\n    41→    Then the output includes flow \"standard\", prompt hash, created timestamp, run summary, and rollback summary\n    42→\n    43→  # SC-PROJ-006\n    44→  Scenario: Project show resolves active project when no ID given\n    45→    Given an initialized workspace with project \"alpha\" selected as active\n    46→    When the user runs \"project show\"\n    47→    Then the output includes project \"alpha\" marked as active\n    48→\n    49→  # SC-PROJ-007\n    50→  Scenario: Project delete succeeds when no active run\n    51→    Given an initialized workspace with project \"alpha\" and no active run\n    52→    When the user runs \"project delete alpha\"\n    53→    Then the command succeeds\n    54→    And the project directory \"alpha\" no longer exists\n    55→    And \"project list\" does not include \"alpha\"\n    56→\n    57→  # SC-PROJ-008\n    58→  Scenario: Project delete clears active-project pointer if selected\n    59→    Given an initialized workspace with project \"alpha\" selected as active\n    60→    When the user runs \"project delete alpha\"\n    61→    Then the command succeeds\n    62→    And the active-project pointer is cleared\n    63→\n    64→  # SC-PROJ-009\n    65→  Scenario: Project delete fails when project has active run\n    66→    Given an initialized workspace with project \"alpha\" that has an active run\n    67→    When the user runs \"project delete alpha\"\n    68→    Then the command fails with error containing \"active run\"\n    69→    And the project \"alpha\" remains addressable\n    70→\n    71→  # SC-PROJ-010\n    72→  Scenario: Project creation is atomic\n    73→    Given an initialized workspace\n    74→    And a prompt file that will cause journal initialization to fail\n    75→    When the user runs \"project create --id partial --name Partial --prompt bad-prompt.md --flow standard\"\n    76→    Then the command fails\n    77→    And no partial project directory \"partial\" is visible to \"project list\"\n    78→    And the active-project pointer is unchanged\n    79→\n    80→  # SC-PROJ-011\n    81→  Scenario: Project create validates workspace version\n    82→    Given a workspace with unsupported version\n    83→    When the user runs \"project create --id x --name X --prompt prompt.md --flow standard\"\n    84→    Then the command fails with error containing \"unsupported workspace version\"\n    85→\n    86→  # SC-PROJ-012\n    87→  Scenario: Project create validates flow preset\n    88→    Given an initialized workspace\n    89→    When the user runs \"project create --id x --name X --prompt prompt.md --flow unknown\"\n    90→    Then the command fails with error containing \"unknown flow preset\"\n    91→\n    92→  # SC-PROJ-013\n    93→  Scenario: Project create does not implicitly select the project\n    94→    Given an initialized workspace\n    95→    When the user runs \"project create --id alpha --name Alpha --prompt prompt.md --flow standard\"\n    96→    Then the active-project pointer does not exist\n    97→\n    98→  # SC-PROJ-014\n    99→  Scenario: Project delete is transactional\n   100→    Given an initialized workspace with project \"alpha\" and no active run\n   101→    When the filesystem delete partially fails after validation\n   102→    Then the project \"alpha\" remains addressable\n   103→    And the active-project pointer is unchanged\n   104→\n   105→  # SC-PROJ-015\n   106→  Scenario: Run.json contains full ca