  \".{}.{}.{}.tmp\",\n    50→            path.file_name()\n    51→                .and_then(|value| value.to_str())\n    52→                .unwrap_or(\"workspace\"),\n    53→            std::process::id(),\n    54→            timestamp\n    55→        ));\n    56→\n    57→        let mut file = OpenOptions::new()\n    58→            .create_new(true)\n    59→            .write(true)\n    60→            .open(&temp_path)?;\n    61→        file.write_all(contents.as_bytes())?;\n    62→        file.sync_all()?;\n    63→        drop(file);\n    64→\n    65→        if let Err(error) = fs::rename(&temp_path, path) {\n    66→            let _ = fs::remove_file(&temp_path);\n    67→            return Err(error.into());\n    68→        }\n    69→\n    70→        Ok(())\n    71→    }\n    72→\n    73→    pub fn render_workspace_config(config: &WorkspaceConfig) -> AppResult<String> {\n    74→        Ok(toml::to_string_pretty(config)?)\n    75→    }\n    76→\n    77→    pub fn read_active_project(workspace_root: &Path) -> AppResult<Option<String>> {\n    78→        let path = workspace_root.join(ACTIVE_PROJECT_FILE);\n    79→        match fs::read_to_string(path) {\n    80→            Ok(raw) => {\n    81→                let trimmed = raw.trim();\n    82→                if trimmed.is_empty() {\n    83→                    Ok(None)\n    84→                } else {\n    85→                    Ok(Some(trimmed.to_owned()))\n    86→                }\n    87→            }\n    88→            Err(error) if error.kind() == std::io::ErrorKind::NotFound => Ok(None),\n    89→            Err(error) => Err(error.into()),\n    90→        }\n    91→    }\n    92→\n    93→    pub fn write_active_project(workspace_root: &Path, project_id: &str) -> AppResult<()> {\n    94→        Self::write_atomic(&workspace_root.join(ACTIVE_PROJECT_FILE), project_id)\n    95→    }\n    96→\n    97→    pub fn open_editor(path: &Path) -> AppResult<()> {\n    98→        let editor = env::var(\"EDITOR\")\n    99→            .ok()\n   100→            .filter(|value| !value.trim().is_empty())\n   101→            .or_else(|| {\n   102→                env::var(\"VISUAL\")\n   103→                    .ok()\n   104→                    .filter(|value| !value.trim().is_empty())\n   105→            })\n   106→            .unwrap_or_else(|| \"vi\".to_owned());\n   107→\n   108→        let mut parts = editor.split_whitespace();\n   109→        let program = parts.next().ok_or_else(|| AppError::EditorFailed {\n   110→            editor: editor.clone(),\n   111→            details: \": empty editor command\".to_owned(),\n   112→        })?;\n   113→        let status = Command::new(program).args(parts).arg(path).status()?;\n   114→\n   115→        if status.success() {\n   116→            Ok(())\n   117→        } else {\n   118→            let details = match status.code() {\n   119→                Some(code) => format!(\" with exit code {code}\"),\n   120→                None => \" after being terminated by a signal\".to_owned(),\n   121→            };\n   122→            Err(AppError::EditorFailed { editor, details })\n   123→        }\n   124→    }\n   125→}\n   126→"}]},"parent_tool_use_id":null,"session_id":"84e4772c-0822-4fc6-b1d7-1c1f7c7f3e3a","uuid":"bc5364d0-d8f0-4475-812c-bb8e49dd48ed","tool_use_result":{"type":"text","file":{"filePath":"/root/new-ralph-burning/ralph-burning-rewrite/src/adapters/fs.rs","content":"use std::env;\nuse std::fs::{self, OpenOptions};\nuse std::io::Write;\nuse std::path::Path;\nuse std::process::Command;\nuse std::time::{SystemTime, UNIX_EPOCH};\n\nuse crate::shared::domain::WorkspaceConfig;\nuse crate::shared::error::{AppError, AppResult};\n\nconst ACTIVE_PROJECT_FILE: &str = \"active-project\";\n\npub struct FileSystem;\n\nimpl FileSystem {\n    pub fn create_workspace(\n        workspace_root: &Path,\n        workspace_config: &str,\n        required_directories: &[&str],\n    ) -> AppResult<()> {\n        fs::create_dir_all(workspace_root)?;\n\n        for directory in required_directories {\n            fs::create_dir_all(workspace_root.join(directory))?;\n        }\n\n        Self::write_atomic(&workspace_root.join(\"workspace.toml\"), workspace_config)?;\n        Ok(())\n    }\n\n    pub fn read_to_string(path: &Path) -> AppResult<String> {\n        Ok(fs::read_to_string(path)?)\n    }\n\n    pub fn write_atomic(path: &Path, contents: &str) -> AppResult<()> {\n        let parent = path.parent().ok_or_else(|| {\n            AppError::Io(std::io::Error::new(\n                std::io::ErrorKind::InvalidInput,\n                format!(\"path '{}' has no parent directory\", path.display()),\n            ))\n        })?;\n        fs::create_dir_all(parent)?;\n\n        let timestamp = SystemTime::now()\n            .duration_since(UNIX_EPOCH)\n            .map(|duration| duration.as_nanos())\n            .unwrap_or_default();\n        let temp_path = parent.join(format!(\n            \".{}.{}.{}.tmp\",\n            path.file_name()\n                .and_then(|value| value.to_str())\n                .unwrap_or(\"workspace\"),\n            std::process::id(),\n            timestamp\n        ));\n\n        let mut file = OpenOptions::new()\n            .create_new(true)\n            .write(true)\n            .open(&temp_path)?;\n        file.write_all(contents.as_bytes())?;\n        file.sync_all()?;\n        drop(file);\n\n        if let Err(error) = fs::rename(&temp_path, path) {\n            let _ = fs::remove_file(&temp_path);\n            return Err(error.into());\n        }\n\n        Ok(())\n    }\n\n    pub fn render_workspace_config(config: &WorkspaceConfig) -> AppResult<String> {\n        Ok(toml::to_string_pretty(config)?)\n    }\n\n    pub fn read_active_project(workspace_root: &Path) -> AppResult<Option<String>> {\n        let path = workspace_root.join(ACTIVE_PROJECT_FILE);\n        match fs::read_to_string(path) {\n            Ok(raw) => {\n                let trimmed = raw.trim();\n                if trimmed.is_empty() {\n                    Ok(None)\n                } else {\n                    Ok(Some(trimmed.to_owned()))\n                }\n            }\n            Err(error) if error.kind() == std::io::ErrorKind::NotFound => Ok(None),\n            Err(error) => Err(error.into()),\n        }\n    }\n\n    pub fn write_active_project(workspace_root: &Path, project_id: &str) -> AppResult<()> {\n        Self::write_atomic(&workspace_root.join(ACTIVE_PROJECT_FILE), project_id)\n    }\n\n    pub fn open_editor(path: &Path) -> AppResult<()> {\n        let editor = env::var(\"EDITOR\")\n            .ok()\n            .filter(|value| !value.trim().is_empty())\n            .or_else(|| {\n                env::var(\"VISUAL\")\n                    .ok()\n                    .filter(|value| !value.trim().is_empty())\n            })\n            .unwrap_or_else(|| \"vi\".to_owned());\n\n        let mut parts = editor.split_whitespace();\n        let program = parts.next().ok_or_else(|| AppError::EditorFailed {\n            editor: editor.clone(),\n            details: \": empty editor command\".to_owned(),\n        })?;\n        let status = Command::new(program).args(parts).arg(path).status()?;\n\n        if status.success() {\n            Ok(())\n        } else {\n            let details = match status.code() {\n                Some(code) => format!(\" with exit code {code}\"),\n                None => \" after being terminated by a signal\".to_owned(),\n            };\n            Err(AppError::EditorFailed { editor, details })\n        }\n    }\n}\n","numLines":126,"startLine":1,"totalLines":126}}}
