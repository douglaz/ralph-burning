{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01XKAbcXTMZqqcWSjPYw7Zxc","type":"tool_result","content":"     1→#![forbid(unsafe_code)]\n     2→\n     3→use ralph_burning::contexts::workflow_composition::payloads::{\n     4→    ExecutionPayload, ExecutionStep, PlanningPayload, ProposedWorkItem, ReadinessAssessment,\n     5→    ReviewOutcome, StepStatus, ValidationPayload,\n     6→};\n     7→use ralph_burning::contexts::workflow_composition::renderers;\n     8→use ralph_burning::shared::domain::StageId;\n     9→\n    10→// ── Helpers ─────────────────────────────────────────────────────────────────\n    11→\n    12→fn sample_planning_payload() -> PlanningPayload {\n    13→    PlanningPayload {\n    14→        problem_framing: \"We need to add stage contracts.\".to_string(),\n    15→        assumptions_or_open_questions: vec![\"All stages are covered.\".to_string()],\n    16→        proposed_work: vec![ProposedWorkItem {\n    17→            order: 1,\n    18→            summary: \"Define payload types\".to_string(),\n    19→            details: \"Create typed structs per family.\".to_string(),\n    20→        }],\n    21→        readiness: ReadinessAssessment {\n    22→            ready: true,\n    23→            risks: vec![],\n    24→        },\n    25→    }\n    26→}\n    27→\n    28→fn sample_execution_payload() -> ExecutionPayload {\n    29→    ExecutionPayload {\n    30→        change_summary: \"Added the stage contract registry.\".to_string(),\n    31→        steps: vec![\n    32→            ExecutionStep {\n    33→                order: 1,\n    34→                description: \"Created payloads module\".to_string(),\n    35→                status: StepStatus::Completed,\n    36→            },\n    37→            ExecutionStep {\n    38→                order: 2,\n    39→                description: \"Created renderers module\".to_string(),\n    40→                status: StepStatus::Intended,\n    41→            },\n    42→        ],\n    43→        validation_evidence: vec![\"cargo test passes\".to_string()],\n    44→        outstanding_risks: vec![],\n    45→    }\n    46→}\n    47→\n    48→fn sample_validation_payload() -> ValidationPayload {\n    49→    ValidationPayload {\n    50→        outcome: ReviewOutcome::Approved,\n    51→        evidence: vec![\"All tests pass.\".to_string()],\n    52→        findings_or_gaps: vec![],\n    53→        follow_up_or_amendments: vec![],\n    54→    }\n    55→}\n    56→\n    57→// ── Deterministic rendering ─────────────────────────────────────────────────\n    58→\n    59→#[test]\n    60→fn planning_renderer_is_deterministic() {\n    61→    let payload = sample_planning_payload();\n    62→    let a = renderers::render_planning(StageId::Planning, &payload);\n    63→    let b = renderers::render_planning(StageId::Planning, &payload);\n    64→    assert_eq!(a, b, \"repeated renders must be byte-identical\");\n    65→}\n    66→\n    67→#[test]\n    68→fn execution_renderer_is_deterministic() {\n    69→    let payload = sample_execution_payload();\n    70→    let a = renderers::render_execution(StageId::Implementation, &payload);\n    71→    let b = renderers::render_execution(StageId::Implementation, &payload);\n    72→    assert_eq!(a, b, \"repeated renders must be byte-identical\");\n    73→}\n    74→\n    75→#[test]\n    76→fn validation_renderer_is_deterministic() {\n    77→    let payload = sample_validation_payload();\n    78→    let a = renderers::render_validation(StageId::Review, &payload);\n    79→    let b = renderers::render_validation(StageId::Review, &payload);\n    80→    assert_eq!(a, b, \"repeated renders must be byte-identical\");\n    81→}\n    82→\n    83→// ── Planning artifact structure ─────────────────────────────────────────────\n    84→\n    85→#[test]\n    86→fn planning_artifact_contains_expected_sections() {\n    87→    let payload = sample_planning_payload();\n    88→    let artifact = renderers::render_planning(StageId::Planning, &payload);\n    89→\n    90→    assert!(artifact.starts_with(\"# Planning\\n\"));\n    91→    assert!(artifact.contains(\"## Problem Framing\"));\n    92→    assert!(artifact.contains(\"We need to add stage contracts.\"));\n    93→    assert!(artifact.contains(\"## Assumptions and Open Questions\"));\n    94→    assert!(artifact.contains(\"- All stages are covered.\"));\n    95→    assert!(artifact.contains(\"## Proposed Work\"));\n    96→    assert!(artifact.contains(\"1. **Define payload types**\"));\n    97→    assert!(artifact.contains(\"## Readiness\"));\n    98→    assert!(artifact.contains(\"- **Ready:** Yes\"));\n    99→}\n   100→\n   101→#[test]\n   102→fn planning_artifact_uses_stage_display_name() {\n   103→    let payload = sample_planning_payload();\n   104→    let artifact = renderers::render_planning(StageId::PromptReview, &payload);\n   105→    assert!(artifact.starts_with(\"# Prompt Review\\n\"));\n   106→}\n   107→\n   108→#[test]\n   109→fn planning_artifact_shows_empty_assumptions() {\n   110→    let mut payload = sample_planning_payload();\n   111→    payload.assumptions_or_open_questions = vec![];\n   112→    let artifact = renderers::render_planning(StageId::Planning, &payload);\n   113→    assert!(artifact.contains(\"None.\"));\n   114→}\n   115→\n   116→#[test]\n   117→fn planning_artifact_shows_risks() {\n   118→    let mut payload = sample_planning_payload();\n   119→    payload.readiness.risks = vec![\n   120→        \"Tight deadline.\".to_string(),\n   121→        \"API instability.\".to_string(),\n   122→    ];\n   123→    let artifact = renderers::render_planning(StageId::Planning, &payload);\n   124→    assert!(artifact.contains(\"- **Risks:**\"));\n   125→    assert!(artifact.contains(\"  - Tight deadline.\"));\n   126→    assert!(artifact.contains(\"  - API instability.\"));\n   127→}\n   128→\n   129→// ── Execution artifact structure ────────────────────────────────────────────\n   130→\n   131→#[test]\n   132→fn execution_artifact_contains_expected_sections() {\n   133→    let payload = sample_execution_payload();\n   134→    let artifact = renderers::render_execution(StageId::Implementation, &payload);\n   135→\n   136→    assert!(artifact.starts_with(\"# Implementation\\n\"));\n   137→    assert!(artifact.contains(\"## Change Summary\"));\n   138→    assert!(artifact.contains(\"Added the stage contract registry.\"));\n   139→    assert!(artifact.contains(\"## Steps\"));\n   140→    assert!(artifact.contains(\"1. [Completed] Created payloads module\"));\n   141→    assert!(artifact.contains(\"2. [Intended] Created renderers module\"));\n   142→    assert!(artifact.contains(\"## Validation Evidence\"));\n   143→    assert!(artifact.contains(\"- cargo test passes\"));\n   144→    assert!(artifact.contains(\"## Outstanding Risks\"));\n   145→    assert!(artifact.contains(\"None identified.\"));\n   146→}\n   147→\n   148→#[test]\n   149→fn execution_artifact_uses_stage_display_name() {\n   150→    let payload = sample_execution_payload();\n   151→    let artifact = renderers::render_execution(StageId::PlanAndImplement, &payload);\n   152→    assert!(artifact.starts_with(\"# Plan and Implement\\n\"));\n   153→}\n   154→\n   155→// ── Validation artifact structure ───────────────────────────────────────────\n   156→\n   157→#[test]\n   158→fn validation_artifact_contains_expected_sections() {\n   159→    let payload = sample_validation_payload();\n   160→    let artifact = renderers::render_validation(StageId::Review, &payload);\n   161→\n   162→    assert!(artifact.starts_with(\"# Review\\n\"));\n   163→    assert!(artifact.contains(\"## Outcome\"));\n   164→    assert!(artifact.contains(\"**Approved**\"));\n   165→    assert!(artifact.contains(\"## Evidence\"));\n   166→    assert!(artifact.contains(\"- All tests pass.\"));\n   167→    assert!(artifact.contains(\"## Findings and Gaps\"));\n   168→    assert!(artifact.contains(\"None identified.\"));\n   169→    assert!(artifact.contains(\"