{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01NE1v1wkxAz8pyZXqugRiR9","type":"tool_result","content":"     1→use std::fmt;\n     2→use std::str::FromStr;\n     3→\n     4→use chrono::{DateTime, Utc};\n     5→use serde::{Deserialize, Serialize};\n     6→use toml::Table;\n     7→\n     8→use crate::shared::error::{AppError, AppResult};\n     9→\n    10→pub const CURRENT_WORKSPACE_VERSION: u32 = 1;\n    11→\n    12→/// Canonical failure classes for stage contract evaluation and retry semantics.\n    13→#[derive(Debug, Clone, Copy, PartialEq, Eq, Hash, Serialize, Deserialize)]\n    14→#[serde(rename_all = \"snake_case\")]\n    15→pub enum FailureClass {\n    16→    TransportFailure,\n    17→    SchemaValidationFailure,\n    18→    DomainValidationFailure,\n    19→    Timeout,\n    20→    Cancellation,\n    21→    QaReviewOutcomeFailure,\n    22→}\n    23→\n    24→#[derive(Debug, Clone, Copy, PartialEq, Eq, Hash, Serialize, Deserialize)]\n    25→#[serde(rename_all = \"snake_case\")]\n    26→pub enum FlowPreset {\n    27→    Standard,\n    28→    QuickDev,\n    29→    DocsChange,\n    30→    CiImprovement,\n    31→}\n    32→\n    33→impl FlowPreset {\n    34→    pub const ALL: [Self; 4] = [\n    35→        Self::Standard,\n    36→        Self::QuickDev,\n    37→        Self::DocsChange,\n    38→        Self::CiImprovement,\n    39→    ];\n    40→\n    41→    pub fn all() -> &'static [Self] {\n    42→        &Self::ALL\n    43→    }\n    44→\n    45→    pub fn as_str(self) -> &'static str {\n    46→        match self {\n    47→            Self::Standard => \"standard\",\n    48→            Self::QuickDev => \"quick_dev\",\n    49→            Self::DocsChange => \"docs_change\",\n    50→            Self::CiImprovement => \"ci_improvement\",\n    51→        }\n    52→    }\n    53→\n    54→    pub fn description(self) -> &'static str {\n    55→        match self {\n    56→            Self::Standard => {\n    57→                \"Full delivery flow with planning, implementation, QA, review, and acceptance.\"\n    58→            }\n    59→            Self::QuickDev => \"Fast delivery flow for small code changes with lightweight review.\",\n    60→            Self::DocsChange => {\n    61→                \"Documentation-focused flow for planning, content updates, and validation.\"\n    62→            }\n    63→            Self::CiImprovement => {\n    64→                \"CI improvement flow for automation planning, updates, and validation.\"\n    65→            }\n    66→        }\n    67→    }\n    68→}\n    69→\n    70→impl fmt::Display for FlowPreset {\n    71→    fn fmt(&self, f: &mut fmt::Formatter<'_>) -> fmt::Result {\n    72→        f.write_str(self.as_str())\n    73→    }\n    74→}\n    75→\n    76→impl FromStr for FlowPreset {\n    77→    type Err = AppError;\n    78→\n    79→    fn from_str(value: &str) -> Result<Self, Self::Err> {\n    80→        match value {\n    81→            \"standard\" => Ok(Self::Standard),\n    82→            \"quick_dev\" => Ok(Self::QuickDev),\n    83→            \"docs_change\" => Ok(Self::DocsChange),\n    84→            \"ci_improvement\" => Ok(Self::CiImprovement),\n    85→            _ => Err(AppError::InvalidFlowPreset {\n    86→                flow_id: value.to_owned(),\n    87→            }),\n    88→        }\n    89→    }\n    90→}\n    91→\n    92→#[derive(Debug, Clone, Copy, PartialEq, Eq, Hash, Serialize, Deserialize)]\n    93→#[serde(rename_all = \"snake_case\")]\n    94→pub enum StageId {\n    95→    PromptReview,\n    96→    Planning,\n    97→    Implementation,\n    98→    Qa,\n    99→    Review,\n   100→    CompletionPanel,\n   101→    AcceptanceQa,\n   102→    FinalReview,\n   103→    PlanAndImplement,\n   104→    ApplyFixes,\n   105→    DocsPlan,\n   106→    DocsUpdate,\n   107→    DocsValidation,\n   108→    CiPlan,\n   109→    CiUpdate,\n   110→    CiValidation,\n   111→}\n   112→\n   113→impl StageId {\n   114→    pub const ALL: [Self; 16] = [\n   115→        Self::PromptReview,\n   116→        Self::Planning,\n   117→        Self::Implementation,\n   118→        Self::Qa,\n   119→        Self::Review,\n   120→        Self::CompletionPanel,\n   121→        Self::AcceptanceQa,\n   122→        Self::FinalReview,\n   123→        Self::PlanAndImplement,\n   124→        Self::ApplyFixes,\n   125→        Self::DocsPlan,\n   126→        Self::DocsUpdate,\n   127→        Self::DocsValidation,\n   128→        Self::CiPlan,\n   129→        Self::CiUpdate,\n   130→        Self::CiValidation,\n   131→    ];\n   132→\n   133→    pub fn display_name(self) -> &'static str {\n   134→        match self {\n   135→            Self::PromptReview => \"Prompt Review\",\n   136→            Self::Planning => \"Planning\",\n   137→            Self::Implementation => \"Implementation\",\n   138→            Self::Qa => \"QA\",\n   139→            Self::Review => \"Review\",\n   140→            Self::CompletionPanel => \"Completion Panel\",\n   141→            Self::AcceptanceQa => \"Acceptance QA\",\n   142→            Self::FinalReview => \"Final Review\",\n   143→            Self::PlanAndImplement => \"Plan and Implement\",\n   144→            Self::ApplyFixes => \"Apply Fixes\",\n   145→            Self::DocsPlan => \"Docs Plan\",\n   146→            Self::DocsUpdate => \"Docs Update\",\n   147→            Self::DocsValidation => \"Docs Validation\",\n   148→            Self::CiPlan => \"CI Plan\",\n   149→            Self::CiUpdate => \"CI Update\",\n   150→            Self::CiValidation => \"CI Validation\",\n   151→        }\n   152→    }\n   153→\n   154→    pub fn as_str(self) -> &'static str {\n   155→        match self {\n   156→            Self::PromptReview => \"prompt_review\",\n   157→            Self::Planning => \"planning\",\n   158→            Self::Implementation => \"implementation\",\n   159→            Self::Qa => \"qa\",\n   160→            Self::Review => \"review\",\n   161→            Self::CompletionPanel => \"completion_panel\",\n   162→            Self::AcceptanceQa => \"acceptance_qa\",\n   163→            Self::FinalReview => \"final_review\",\n   164→            Self::PlanAndImplement => \"plan_and_implement\",\n   165→            Self::ApplyFixes => \"apply_fixes\",\n   166→            Self::DocsPlan => \"docs_plan\",\n   167→            Self::DocsUpdate => \"docs_update\",\n   168→            Self::DocsValidation => \"docs_validation\",\n   169→            Self::CiPlan => \"ci_plan\",\n   170→            Self::CiUpdate => \"ci_update\",\n   171→            Self::CiValidation => \"ci_validation\",\n   172→        }\n   173→    }\n   174→}\n   175→\n   176→impl fmt::Display for StageId {\n   177→    fn fmt(&self, f: &mut fmt::Formatter<'_>) -> fmt::Result {\n   178→        f.write_str(self.as_str())\n   179→    }\n   180→}\n   181→\n   182→#[derive(Debug, Clone, PartialEq, Eq, Serialize, Deserialize)]\n   183→pub struct StageCursor {\n   184→    pub stage: StageId,\n   185→    pub cycle: u32,\n   186→    pub attempt: u32,\n   187→    pub completion_round: u32,\n   188→}\n   189→\n   190→impl StageCursor {\n   191→    pub fn new(stage: StageId, cycle: u32, attempt: u32, completion_round: u32) -> AppResult<Self> {\n   192→        if cycle == 0 {\n   193→            return Err(AppError::InvalidStageCursorField { field: \"cycle\" });\n   194→        }\n   195→        if attempt == 0 {\n   196→            return Err(AppError::InvalidStageCursorField { field: \"attempt\" });\n   197→        }\n   198→        if completion_round == 0 {\n   199→            return Err(AppError::InvalidStageCursorField {\n   200→                field: \"completion_round\",\n   201→            });\n   202→        }\n   203→\n   204→        Ok(Self {\n   205→            stage,\n   206→            cycle,\n   207→            attempt,\n   208→            completion_round,\n   209→        })\n   210→    }\n   211→\n   212→    pub fn initial(stage: StageId) -> Self {\n   213→        Self {\n   214