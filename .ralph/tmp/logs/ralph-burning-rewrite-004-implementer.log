{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013VgFkkBcarnF1XQ2YESdKZ","type":"tool_result","content":"     1→use std::env;\n     2→use std::fs::{self, OpenOptions};\n     3→use std::io::Write;\n     4→use std::path::{Path, PathBuf};\n     5→use std::process::Command;\n     6→use std::time::{SystemTime, UNIX_EPOCH};\n     7→\n     8→use crate::contexts::project_run_record::journal;\n     9→use crate::contexts::project_run_record::model::{\n    10→    ArtifactRecord, JournalEvent, PayloadRecord, ProjectRecord, RunSnapshot,\n    11→    RuntimeLogEntry, SessionStore,\n    12→};\n    13→use crate::contexts::project_run_record::service::{\n    14→    ActiveProjectPort, ArtifactStorePort, JournalStorePort, ProjectStorePort,\n    15→    RuntimeLogStorePort, RunSnapshotPort,\n    16→};\n    17→use crate::shared::domain::{ProjectId, WorkspaceConfig};\n    18→use crate::shared::error::{AppError, AppResult};\n    19→\n    20→const ACTIVE_PROJECT_FILE: &str = \"active-project\";\n    21→const WORKSPACE_DIR: &str = \".ralph-burning\";\n    22→const PROJECTS_DIR: &str = \"projects\";\n    23→const PROJECT_CONFIG_FILE: &str = \"project.toml\";\n    24→const RUN_FILE: &str = \"run.json\";\n    25→const JOURNAL_FILE: &str = \"journal.ndjson\";\n    26→const SESSIONS_FILE: &str = \"sessions.json\";\n    27→const PROMPT_FILE: &str = \"prompt.md\";\n    28→\n    29→/// Required subdirectories inside a project.\n    30→const PROJECT_SUBDIRS: &[&str] = &[\n    31→    \"history/payloads\",\n    32→    \"history/artifacts\",\n    33→    \"runtime/logs\",\n    34→    \"runtime/backend\",\n    35→    \"runtime/temp\",\n    36→    \"amendments\",\n    37→    \"rollback\",\n    38→];\n    39→\n    40→pub struct FileSystem;\n    41→\n    42→impl FileSystem {\n    43→    pub fn create_workspace(\n    44→        workspace_root: &Path,\n    45→        workspace_config: &str,\n    46→        required_directories: &[&str],\n    47→    ) -> AppResult<()> {\n    48→        fs::create_dir_all(workspace_root)?;\n    49→\n    50→        for directory in required_directories {\n    51→            fs::create_dir_all(workspace_root.join(directory))?;\n    52→        }\n    53→\n    54→        Self::write_atomic(&workspace_root.join(\"workspace.toml\"), workspace_config)?;\n    55→        Ok(())\n    56→    }\n    57→\n    58→    pub fn read_to_string(path: &Path) -> AppResult<String> {\n    59→        Ok(fs::read_to_string(path)?)\n    60→    }\n    61→\n    62→    pub fn write_atomic(path: &Path, contents: &str) -> AppResult<()> {\n    63→        let parent = path.parent().ok_or_else(|| {\n    64→            AppError::Io(std::io::Error::new(\n    65→                std::io::ErrorKind::InvalidInput,\n    66→                format!(\"path '{}' has no parent directory\", path.display()),\n    67→            ))\n    68→        })?;\n    69→        fs::create_dir_all(parent)?;\n    70→\n    71→        let timestamp = SystemTime::now()\n    72→            .duration_since(UNIX_EPOCH)\n    73→            .map(|duration| duration.as_nanos())\n    74→            .unwrap_or_default();\n    75→        let temp_path = parent.join(format!(\n    76→            \".{}.{}.{}.tmp\",\n    77→            path.file_name()\n    78→                .and_then(|value| value.to_str())\n    79→                .unwrap_or(\"workspace\"),\n    80→            std::process::id(),\n    81→            timestamp\n    82→        ));\n    83→\n    84→        let mut file = OpenOptions::new()\n    85→            .create_new(true)\n    86→            .write(true)\n    87→            .open(&temp_path)?;\n    88→        file.write_all(contents.as_bytes())?;\n    89→        file.sync_all()?;\n    90→        drop(file);\n    91→\n    92→        if let Err(error) = fs::rename(&temp_path, path) {\n    93→            let _ = fs::remove_file(&temp_path);\n    94→            return Err(error.into());\n    95→        }\n    96→\n    97→        Ok(())\n    98→    }\n    99→\n   100→    pub fn render_workspace_config(config: &WorkspaceConfig) -> AppResult<String> {\n   101→        Ok(toml::to_string_pretty(config)?)\n   102→    }\n   103→\n   104→    pub fn read_active_project(workspace_root: &Path) -> AppResult<Option<String>> {\n   105→        let path = workspace_root.join(ACTIVE_PROJECT_FILE);\n   106→        match fs::read_to_string(path) {\n   107→            Ok(raw) => {\n   108→                let trimmed = raw.trim();\n   109→                if trimmed.is_empty() {\n   110→                    Ok(None)\n   111→                } else {\n   112→                    Ok(Some(trimmed.to_owned()))\n   113→                }\n   114→            }\n   115→            Err(error) if error.kind() == std::io::ErrorKind::NotFound => Ok(None),\n   116→            Err(error) => Err(error.into()),\n   117→        }\n   118→    }\n   119→\n   120→    pub fn write_active_project(workspace_root: &Path, project_id: &str) -> AppResult<()> {\n   121→        Self::write_atomic(&workspace_root.join(ACTIVE_PROJECT_FILE), project_id)\n   122→    }\n   123→\n   124→    pub fn open_editor(path: &Path) -> AppResult<()> {\n   125→        let editor = env::var(\"EDITOR\")\n   126→            .ok()\n   127→            .filter(|value| !value.trim().is_empty())\n   128→            .or_else(|| {\n   129→                env::var(\"VISUAL\")\n   130→                    .ok()\n   131→                    .filter(|value| !value.trim().is_empty())\n   132→            })\n   133→            .unwrap_or_else(|| \"vi\".to_owned());\n   134→\n   135→        let mut parts = editor.split_whitespace();\n   136→        let program = parts.next().ok_or_else(|| AppError::EditorFailed {\n   137→            editor: editor.clone(),\n   138→            details: \": empty editor command\".to_owned(),\n   139→        })?;\n   140→        let status = Command::new(program).args(parts).arg(path).status()?;\n   141→\n   142→        if status.success() {\n   143→            Ok(())\n   144→        } else {\n   145→            let details = match status.code() {\n   146→                Some(code) => format!(\" with exit code {code}\"),\n   147→                None => \" after being terminated by a signal\".to_owned(),\n   148→            };\n   149→            Err(AppError::EditorFailed { editor, details })\n   150→        }\n   151→    }\n   152→\n   153→    /// Compute a simple hash of content for prompt integrity tracking.\n   154→    pub fn prompt_hash(contents: &str) -> String {\n   155→        use std::collections::hash_map::DefaultHasher;\n   156→        use std::hash::{Hash, Hasher};\n   157→        let mut hasher = DefaultHasher::new();\n   158→        contents.hash(&mut hasher);\n   159→        format!(\"{:016x}\", hasher.finish())\n   160→    }\n   161→\n   162→    // ── Helpers for project filesystem layout ──\n   163→\n   164→    fn workspace_root_path(base_dir: &Path) -> PathBuf {\n   165→        base_dir.join(WORKSPACE_DIR)\n   166→    }\n   167→\n   168→    fn project_root(base_dir: &Path, project_id: &ProjectId) -> PathBuf {\n   169→        Self::workspace_root_path(base_dir)\n   170→            .join(PROJECTS_DIR)\n   171→            .join(project_id.as_str())\n   172→    }\n   173→\n   174→    fn append_line(path: &Path, line: &str) -> AppResult<()> {\n   175→        let parent = path.parent().ok_or_else(|| {\n   176→            AppError::Io(std::io::Error::new(\n   177→                std::io::ErrorKind::InvalidInput,\n   178→                format!(\"path '{}' has no parent directory\", path.display()),\n   179→            ))\n   180→        })?;\n   181→        fs::create_dir_all(parent)?;\n   182→\n   183→        let mut file = OpenOptions::new()\n   184→            .create(true)\n   185→            .append(true)\n   186→            .open(path)?;\n   187→        writeln!(file, \"{}\", line)?;\n   188→        file.sync_all()?;\n   189→        Ok(())\n   190→    }\n   191→}\n   192→\n   193→/// Filesystem-backed implementation of `ProjectStorePort`.\n   194→pub struct FsProjectStore;\n   195→\n   196→impl ProjectStorePort for FsProjectStore {\n   197→    fn project_exists(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<bool> {\n   198→        let project_root = FileSystem::project_root(base_dir, project_id);\n   199→        Ok(project_root.is_dir() && project_root.join(PROJECT_CONFIG_FILE).is_file())\n   200→    }\n   201→\n   202→    fn read_project_record(\n   203→        &self,\n   204→        base_dir: &Path,\n   205→        project_id: &ProjectId,\n   206→    ) -> AppResult<ProjectRecord> {\n   207→        let path = FileSystem::project_root(base_dir, project_id).join(PROJECT_CONFIG_FILE);\n   208→        let raw = fs::read_to_string(&path).map_err(|e| {\n   209→            if e.kind() == std::io::ErrorKind::NotFound {\n   210→                AppError::ProjectNotFound {\n   211→                    project_id: project_id.to_string(),\n   212→                }\n   213→            } else {\n   214→                e.into()\n   215→            }\n   216→        })?;\n   217→        toml::from_str(&raw).map_err(|e| AppError::CorruptRecord {\n   218→            file: format!(\"projects/{}/project.toml\", project_id),\n   219→            details: e.to_string(),\n   220→        })\n   221→    }\n   222→\n   223→    fn list_project_ids(&self, base_dir: &Path) -> AppResult<Vec<ProjectId>> {\n   224→        let projects_dir = FileSystem::workspace_root_path(base_dir).join(PROJECTS_DIR);\n   225→        if !projects_dir.is_dir() {\n   226→            return Ok(Vec::new());\n   227→        }\n   228→\n   229→        let mut ids = Vec::new();\n   230→        for entry in fs::read_dir(&projects_dir)? {\n   231→            let entry = entry?;\n   232→            if !entry.file_type()?.is_dir() {\n   233→                continue;\n   234→            }\n   235→            let name = entry.file_name();\n   236→            let name_str = name.to_string_lossy();\n   237→            // Only include projects that have a valid project.toml\n   238→            if entry.path().join(PROJECT_CONFIG_FILE).is_file() {\n   239→                if let Ok(pid) = ProjectId::new(name_str.as_ref()) {\n   240→                    ids.push(pid);\n   241→                }\n   242→            }\n   243→        }\n   244→\n   245→        ids.sort_by(|a, b| a.as_str().cmp(b.as_str()));\n   246→        Ok(ids)\n   247→    }\n   248→\n   249→    fn delete_project(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<()> {\n   250→        let project_root = FileSystem::project_root(base_dir, project_id);\n   251→        if !project_root.is_dir() {\n   252→            return Err(AppError::ProjectNotFound {\n   253→                project_id: project_id.to_string(),\n   254→            });\n   255→        }\n   256→        fs::remove_dir_all(&project_root)?;\n   257→        Ok(())\n   258→    }\n   259→\n   260→    fn create_project_atomic(\n   261→        &self,\n   262→        base_dir: &Path,\n   263→        record: &ProjectRecord,\n   264→        prompt_contents: &str,\n   265→        run_snapshot: &RunSnapshot,\n   266→        initial_journal_line: &str,\n   267→        sessions: &SessionStore,\n   268→    ) -> AppResult<()> {\n   269→        let project_root = FileSystem::project_root(base_dir, &record.id);\n   270→\n   271→        // Stage into a temporary directory alongside the final location\n   272→        let staging_name = format!(\".{}.staging.{}\", record.id, std::process::id());\n   273→        let staging_root = project_root\n   274→            .parent()\n   275→            .expect(\"project root has parent\")\n   276→            .join(&staging_name);\n   277→\n   278→        // Clean up any leftover staging dir\n   279→        if staging_root.exists() {\n   280→            fs::remove_dir_all(&staging_root)?;\n   281→        }\n   282→\n   283→        // Create staging directory and all subdirs\n   284→        fs::create_dir_all(&staging_root)?;\n   285→        for subdir in PROJECT_SUBDIRS {\n   286→            fs::create_dir_all(staging_root.join(subdir))?;\n   287→        }\n   288→\n   289→        // Write all canonical files into staging\n   290→        let write_result = (|| -> AppResult<()> {\n   291→            // project.toml\n   292→            let project_toml = toml::to_string_pretty(record).map_err(|e| {\n   293→                AppError::Io(std::io::Error::other(e.to_string()))\n   294→            })?;\n   295→            fs::write(staging_root.join(PROJECT_CONFIG_FILE), project_toml)?;\n   296→\n   297→            // prompt.md\n   298→            fs::write(staging_root.join(PROMPT_FILE), prompt_contents)?;\n   299→\n   300→            // run.json\n   301→            let run_json = serde_json::to_string_pretty(run_snapshot)?;\n   302→            fs::write(staging_root.join(RUN_FILE), run_json)?;\n   303→\n   304→            // journal.ndjson (with initial event)\n   305→            let mut journal_content = initial_journal_line.to_owned();\n   306→            journal_content.push('\\n');\n   307→            fs::write(staging_root.join(JOURNAL_FILE), journal_content)?;\n   308→\n   309→            // sessions.json\n   310→            let sessions_json = serde_json::to_string_pretty(sessions)?;\n   311→            fs::write(staging_root.join(SESSIONS_FILE), sessions_json)?;\n   312→\n   313→            Ok(())\n   314→        })();\n   315→\n   316→        if let Err(e) = write_result {\n   317→            // Clean up staging on failure\n   318→            let _ = fs::remove_dir_all(&staging_root);\n   319→            return Err(e);\n   320→        }\n   321→\n   322→        // Atomic rename from staging to final location\n   323→        if let Err(e) = fs::rename(&staging_root, &project_root) {\n   324→            let _ = fs::remove_dir_all(&staging_root);\n   325→            return Err(e.into());\n   326→        }\n   327→\n   328→        Ok(())\n   329→    }\n   330→}\n   331→\n   332→/// Filesystem-backed implementation of `JournalStorePort`.\n   333→pub struct FsJournalStore;\n   334→\n   335→impl JournalStorePort for FsJournalStore {\n   336→    fn read_journal(\n   337→        &self,\n   338→        base_dir: &Path,\n   339→        project_id: &ProjectId,\n   340→    ) -> AppResult<Vec<JournalEvent>> {\n   341→        let path = FileSystem::project_root(base_dir, project_id).join(JOURNAL_FILE);\n   342→        match fs::read_to_string(&path) {\n   343→            Ok(contents) => journal::parse_journal(&contents),\n   344→            Err(e) if e.kind() == std::io::ErrorKind::NotFound => Ok(Vec::new()),\n   345→            Err(e) => Err(e.into()),\n   346→        }\n   347→    }\n   348→\n   349→    fn append_event(\n   350→        &self,\n   351→        base_dir: &Path,\n   352→        project_id: &ProjectId,\n   353→        line: &str,\n   354→    ) -> AppResult<()> {\n   355→        let path = FileSystem::project_root(base_dir, project_id).join(JOURNAL_FILE);\n   356→        FileSystem::append_line(&path, line)\n   357→    }\n   358→}\n   359→\n   360→/// Filesystem-backed implementation of `ArtifactStorePort`.\n   361→pub struct FsArtifactStore;\n   362→\n   363→impl ArtifactStorePort for FsArtifactStore {\n   364→    fn list_payloads(\n   365→        &self,\n   366→        base_dir: &Path,\n   367→        project_id: &ProjectId,\n   368→    ) -> AppResult<Vec<PayloadRecord>> {\n   369→        let dir = FileSystem::project_root(base_dir, project_id).join(\"history/payloads\");\n   370→        if !dir.is_dir() {\n   371→            return Ok(Vec::new());\n   372→        }\n   373→\n   374→        let mut records = Vec::new();\n   375→        for entry in fs::read_dir(&dir)? {\n   376→            let entry = entry?;\n   377→            let path = entry.path();\n   378→            if path.extension().is_some_and(|ext| ext == \"json\") {\n   379→                let raw = fs::read_to_string(&path)?;\n   380→                let record: PayloadRecord = serde_json::from_str(&raw).map_err(|e| {\n   381→                    AppError::CorruptRecord {\n   382→                        file: format!(\n   383→                            \"history/payloads/{}\",\n   384→                            path.file_name()\n   385→                                .unwrap_or_default()\n   386→                                .to_string_lossy()\n   387→                        ),\n   388→                        details: e.to_string(),\n   389→                    }\n   390→                })?;\n   391→                records.push(record);\n   392→            }\n   393→        }\n   394→\n   395→        records.sort_by_key(|r| r.created_at);\n   396→        Ok(records)\n   397→    }\n   398→\n   399→    fn list_artifacts(\n   400→        &self,\n   401→        base_dir: &Path,\n   402→        project_id: &ProjectId,\n   403→    ) -> AppResult<Vec<ArtifactRecord>> {\n   404→        let dir = FileSystem::project_root(base_dir, project_id).join(\"history/artifacts\");\n   405→        if !dir.is_dir() {\n   406→            return Ok(Vec::new());\n   407→        }\n   408→\n   409→        let mut records = Vec::new();\n   410→        for entry in fs::read_dir(&dir)? {\n   411→            let entry = entry?;\n   412→            let path = entry.path();\n   413→            if path.extension().is_some_and(|ext| ext == \"json\") {\n   414→                let raw = fs::read_to_string(&path)?;\n   415→                let record: ArtifactRecord =\n   416→                    serde_json::from_str(&raw).map_err(|e| AppError::CorruptRecord {\n   417→                        file: format!(\n   418→                            \"history/artifacts/{}\",\n   419→                            path.file_name()\n   420→                                .unwrap_or_default()\n   421→                                .to_string_lossy()\n   422→                        ),\n   423→                        details: e.to_string(),\n   424→                    })?;\n   425→                records.push(record);\n   426→            }\n   427→        }\n   428→\n   429→        records.sort_by_key(|r| r.created_at);\n   430→        Ok(records)\n   431→    }\n   432→}\n   433→\n   434→/// Filesystem-backed implementation of `RuntimeLogStorePort`.\n   435→pub struct FsRuntimeLogStore;\n   436→\n   437→impl RuntimeLogStorePort for FsRuntimeLogStore {\n   438→    fn read_runtime_logs(\n   439→        &self,\n   440→        base_dir: &Path,\n   441→        project_id: &ProjectId,\n   442→    ) -> AppResult<Vec<RuntimeLogEntry>> {\n   443→        let dir = FileSystem::project_root(base_dir, project_id).join(\"runtime/logs\");\n   444→        if !dir.is_dir() {\n   445→            return Ok(Vec::new());\n   446→        }\n   447→\n   448→        let mut entries = Vec::new();\n   449→        let mut paths: Vec<_> = fs::read_dir(&dir)?\n   450→            .filter_map(|e| e.ok())\n   451→            .map(|e| e.path())\n   452→            .filter(|p| p.extension().is_some_and(|ext| ext == \"ndjson\"))\n   453→            .collect();\n   454→        paths.sort();\n   455→\n   456→        for path in paths {\n   457→            let contents = fs::read_to_string(&path)?;\n   458→            for line in contents.lines() {\n   459→                let trimmed = line.trim();\n   460→                if trimmed.is_empty() {\n   461→                    continue;\n   462→                }\n   463→                if let Ok(entry) = serde_json::from_str::<RuntimeLogEntry>(trimmed) {\n   464→                    entries.push(entry);\n   465→                }\n   466→            }\n   467→        }\n   468→\n   469→        Ok(entries)\n   470→    }\n   471→}\n   472→\n   473→/// Filesystem-backed implementation of `RunSnapshotPort`.\n   474→pub struct FsRunSnapshotStore;\n   475→\n   476→impl RunSnapshotPort for FsRunSnapshotStore {\n   477→    fn read_run_snapshot(\n   478→        &self,\n   479→        base_dir: &Path,\n   480→        project_id: &ProjectId,\n   481→    ) -> AppResult<RunSnapshot> {\n   482→        let path = FileSystem::project_root(base_dir, project_id).join(RUN_FILE);\n   483→        match fs::read_to_string(&path) {\n   484→            Ok(raw) => serde_json::from_str(&raw).map_err(|e| AppError::CorruptRecord {\n   485→                file: format!(\"projects/{}/run.json\", project_id),\n   486→                details: e.to_string(),\n   487→            }),\n   488→            Err(e) if e.kind() == std::io::ErrorKind::NotFound => Ok(RunSnapshot::initial()),\n   489→            Err(e) => Err(e.into()),\n   490→        }\n   491→    }\n   492→}\n   493→\n   494→/// Filesystem-backed implementation of `ActiveProjectPort`.\n   495→pub struct FsActiveProjectStore;\n   496→\n   497→impl ActiveProjectPort for FsActiveProjectStore {\n   498→    fn read_active_project_id(&self, base_dir: &Path) -> AppResult<Option<String>> {\n   499→        FileSystem::read_active_project(&FileSystem::workspace_root_path(base_dir))\n   500→    }\n   501→\n   502→    fn clear_active_project(&self, base_dir: &Path) -> AppResult<()> {\n   503→        let path = FileSystem::workspace_root_path(base_dir).join(ACTIVE_PROJECT_FILE);\n   504→        match fs::remove_file(&path) {\n   505→            Ok(()) => Ok(()),\n   506→            Err(e) if e.kind() == std::io::ErrorKind::NotFound => Ok(()),\n   507→            Err(e) => Err(e.into()),\n   508→        }\n   509→    }\n   510→}\n   511→"}]},"parent_tool_use_id":null,"session_id":"3640e08e-b88d-40cb-b39d-a6d9ec8d8fb8","uuid":"f67f9bb3-01bc-40ef-926c-9e09ae778128","tool_use_result":{"type":"text","file":{"filePath":"/root/new-ralph-burning/ralph-burning-rewrite/src/adapters/fs.rs","content":"use std::env;\nuse std::fs::{self, OpenOptions};\nuse std::io::Write;\nuse std::path::{Path, PathBuf};\nuse std::process::Command;\nuse std::time::{SystemTime, UNIX_EPOCH};\n\nuse crate::contexts::project_run_record::journal;\nuse crate::contexts::project_run_record::model::{\n    ArtifactRecord, JournalEvent, PayloadRecord, ProjectRecord, RunSnapshot,\n    RuntimeLogEntry, SessionStore,\n};\nuse crate::contexts::project_run_record::service::{\n    ActiveProjectPort, ArtifactStorePort, JournalStorePort, ProjectStorePort,\n    RuntimeLogStorePort, RunSnapshotPort,\n};\nuse crate::shared::domain::{ProjectId, WorkspaceConfig};\nuse crate::shared::error::{AppError, AppResult};\n\nconst ACTIVE_PROJECT_FILE: &str = \"active-project\";\nconst WORKSPACE_DIR: &str = \".ralph-burning\";\nconst PROJECTS_DIR: &str = \"projects\";\nconst PROJECT_CONFIG_FILE: &str = \"project.toml\";\nconst RUN_FILE: &str = \"run.json\";\nconst JOURNAL_FILE: &str = \"journal.ndjson\";\nconst SESSIONS_FILE: &str = \"sessions.json\";\nconst PROMPT_FILE: &str = \"prompt.md\";\n\n/// Required subdirectories inside a project.\nconst PROJECT_SUBDIRS: &[&str] = &[\n    \"history/payloads\",\n    \"history/artifacts\",\n    \"runtime/logs\",\n    \"runtime/backend\",\n    \"runtime/temp\",\n    \"amendments\",\n    \"rollback\",\n];\n\npub struct FileSystem;\n\nimpl FileSystem {\n    pub fn create_workspace(\n        workspace_root: &Path,\n        workspace_config: &str,\n        required_directories: &[&str],\n    ) -> AppResult<()> {\n        fs::create_dir_all(workspace_root)?;\n\n        for directory in required_directories {\n            fs::create_dir_all(workspace_root.join(directory))?;\n        }\n\n        Self::write_atomic(&workspace_root.join(\"workspace.toml\"), workspace_config)?;\n        Ok(())\n    }\n\n    pub fn read_to_string(path: &Path) -> AppResult<String> {\n        Ok(fs::read_to_string(path)?)\n    }\n\n    pub fn write_atomic(path: &Path, contents: &str) -> AppResult<()> {\n        let parent = path.parent().ok_or_else(|| {\n            AppError::Io(std::io::Error::new(\n                std::io::ErrorKind::InvalidInput,\n                format!(\"path '{}' has no parent directory\", path.display()),\n            ))\n        })?;\n        fs::create_dir_all(parent)?;\n\n        let timestamp = SystemTime::now()\n            .duration_since(UNIX_EPOCH)\n            .map(|duration| duration.as_nanos())\n            .unwrap_or_default();\n        let temp_path = parent.join(format!(\n            \".{}.{}.{}.tmp\",\n            path.file_name()\n                .and_then(|value| value.to_str())\n                .unwrap_or(\"workspace\"),\n            std::process::id(),\n            timestamp\n        ));\n\n        let mut file = OpenOptions::new()\n            .create_new(true)\n            .write(true)\n            .open(&temp_path)?;\n        file.write_all(contents.as_bytes())?;\n        file.sync_all()?;\n        drop(file);\n\n        if let Err(error) = fs::rename(&temp_path, path) {\n            let _ = fs::remove_file(&temp_path);\n            return Err(error.into());\n        }\n\n        Ok(())\n    }\n\n    pub fn render_workspace_config(config: &WorkspaceConfig) -> AppResult<String> {\n        Ok(toml::to_string_pretty(config)?)\n    }\n\n    pub fn read_active_project(workspace_root: &Path) -> AppResult<Option<String>> {\n        let path = workspace_root.join(ACTIVE_PROJECT_FILE);\n        match fs::read_to_string(path) {\n            Ok(raw) => {\n                let trimmed = raw.trim();\n                if trimmed.is_empty() {\n                    Ok(None)\n                } else {\n                    Ok(Some(trimmed.to_owned()))\n                }\n            }\n            Err(error) if error.kind() == std::io::ErrorKind::NotFound => Ok(None),\n            Err(error) => Err(error.into()),\n        }\n    }\n\n    pub fn write_active_project(workspace_root: &Path, project_id: &str) -> AppResult<()> {\n        Self::write_atomic(&workspace_root.join(ACTIVE_PROJECT_FILE), project_id)\n    }\n\n    pub fn open_editor(path: &Path) -> AppResult<()> {\n        let editor = env::var(\"EDITOR\")\n            .ok()\n            .filter(|value| !value.trim().is_empty())\n            .or_else(|| {\n                env::var(\"VISUAL\")\n                    .ok()\n                    .filter(|value| !value.trim().is_empty())\n            })\n            .unwrap_or_else(|| \"vi\".to_owned());\n\n        let mut parts = editor.split_whitespace();\n        let program = parts.next().ok_or_else(|| AppError::EditorFailed {\n            editor: editor.clone(),\n            details: \": empty editor command\".to_owned(),\n        })?;\n        let status = Command::new(program).args(parts).arg(path).status()?;\n\n        if status.success() {\n            Ok(())\n        } else {\n            let details = match status.code() {\n                Some(code) => format!(\" with exit code {code}\"),\n                None => \" after being terminated by a signal\".to_owned(),\n            };\n            Err(AppError::EditorFailed { editor, details })\n        }\n    }\n\n    /// Compute a simple hash of content for prompt integrity tracking.\n    pub fn prompt_hash(contents: &str) -> String {\n        use std::collections::hash_map::DefaultHasher;\n        use std::hash::{Hash, Hasher};\n        let mut hasher = DefaultHasher::new();\n        contents.hash(&mut hasher);\n        format!(\"{:016x}\", hasher.finish())\n    }\n\n    // ── Helpers for project filesystem layout ──\n\n    fn workspace_root_path(base_dir: &Path) -> PathBuf {\n        base_dir.join(WORKSPACE_DIR)\n    }\n\n    fn project_root(base_dir: &Path, project_id: &ProjectId) -> PathBuf {\n        Self::workspace_root_path(base_dir)\n            .join(PROJECTS_DIR)\n            .join(project_id.as_str())\n    }\n\n    fn append_line(path: &Path, line: &str) -> AppResult<()> {\n        let parent = path.parent().ok_or_else(|| {\n            AppError::Io(std::io::Error::new(\n                std::io::ErrorKind::InvalidInput,\n                format!(\"path '{}' has no parent directory\", path.display()),\n            ))\n        })?;\n        fs::create_dir_all(parent)?;\n\n        let mut file = OpenOptions::new()\n            .create(true)\n            .append(true)\n            .open(path)?;\n        writeln!(file, \"{}\", line)?;\n        file.sync_all()?;\n        Ok(())\n    }\n}\n\n/// Filesystem-backed implementation of `ProjectStorePort`.\npub struct FsProjectStore;\n\nimpl ProjectStorePort for FsProjectStore {\n    fn project_exists(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<bool> {\n        let project_root = FileSystem::project_root(base_dir, project_id);\n        Ok(project_root.is_dir() && project_root.join(PROJECT_CONFIG_FILE).is_file())\n    }\n\n    fn read_project_record(\n        &self,\n        base_dir: &Path,\n        project_id: &ProjectId,\n    ) -> AppResult<ProjectRecord> {\n        let path = FileSystem::project_root(base_dir, project_id).join(PROJECT_CONFIG_FILE);\n        let raw = fs::read_to_string(&path).map_err(|e| {\n            if e.kind() == std::io::ErrorKind::NotFound {\n                AppError::ProjectNotFound {\n                    project_id: project_id.to_string(),\n                }\n            } else {\n                e.into()\n            }\n        })?;\n        toml::from_str(&raw).map_err(|e| AppError::CorruptRecord {\n            file: format!(\"projects/{}/project.toml\", project_id),\n            details: e.to_string(),\n        })\n    }\n\n    fn list_project_ids(&self, base_dir: &Path) -> AppResult<Vec<ProjectId>> {\n        let projects_dir = FileSystem::workspace_root_path(base_dir).join(PROJECTS_DIR);\n        if !projects_dir.is_dir() {\n            return Ok(Vec::new());\n        }\n\n        let mut ids = Vec::new();\n        for entry in fs::read_dir(&projects_dir)? {\n            let entry = entry?;\n            if !entry.file_type()?.is_dir() {\n                continue;\n            }\n            let name = entry.file_name();\n            let name_str = name.to_string_lossy();\n            // Only include projects that have a valid project.toml\n            if entry.path().join(PROJECT_CONFIG_FILE).is_file() {\n                if let Ok(pid) = ProjectId::new(name_str.as_ref()) {\n                    ids.push(pid);\n                }\n            }\n        }\n\n        ids.sort_by(|a, b| a.as_str().cmp(b.as_str()));\n        Ok(ids)\n    }\n\n    fn delete_project(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<()> {\n        let project_root = FileSystem::project_root(base_dir, project_id);\n        if !project_root.is_dir() {\n            return Err(AppError::ProjectNotFound {\n                project_id: project_id.to_string(),\n            });\n        }\n        fs::remove_dir_all(&project_root)?;\n        Ok(())\n    }\n\n    fn create_project_atomic(\n        &self,\n        base_dir: &Path,\n        record: &ProjectRecord,\n        prompt_contents: &str,\n        run_snapshot: &RunSnapshot,\n        initial_journal_line: &str,\n        sessions: &SessionStore,\n    ) -> AppResult<()> {\n        let project_root = FileSystem::project_root(base_dir, &record.id);\n\n        // Stage into a temporary directory alongside the final location\n        let staging_name = format!(\".{}.staging.{}\", record.id, std::process::id());\n        let staging_root = project_root\n            .parent()\n            .expect(\"project root has parent\")\n            .join(&staging_name);\n\n        // Clean up any leftover staging dir\n        if staging_root.exists() {\n            fs::remove_dir_all(&staging_root)?;\n        }\n\n        // Create staging directory and all subdirs\n        fs::create_dir_all(&staging_root)?;\n        for subdir in PROJECT_SUBDIRS {\n            fs::create_dir_all(staging_root.join(subdir))?;\n        }\n\n        // Write all canonical files into staging\n        let write_result = (|| -> AppResult<()> {\n            // project.toml\n            let project_toml = toml::to_string_pretty(record).map_err(|e| {\n                AppError::Io(std::io::Error::other(e.to_string()))\n            })?;\n            fs::write(staging_root.join(PROJECT_CONFIG_FILE), project_toml)?;\n\n            // prompt.md\n            fs::write(staging_root.join(PROMPT_FILE), prompt_contents)?;\n\n            // run.json\n            let run_json = serde_json::to_string_pretty(run_snapshot)?;\n            fs::write(staging_root.join(RUN_FILE), run_json)?;\n\n            // journal.ndjson (with initial event)\n            let mut journal_content = initial_journal_line.to_owned();\n            journal_content.push('\\n');\n            fs::write(staging_root.join(JOURNAL_FILE), journal_content)?;\n\n            // sessions.json\n            let sessions_json = serde_json::to_string_pretty(sessions)?;\n            fs::write(staging_root.join(SESSIONS_FILE), sessions_json)?;\n\n            Ok(())\n        })();\n\n        if let Err(e) = write_result {\n            // Clean up staging on failure\n            let _ = fs::remove_dir_all(&staging_root);\n            return Err(e);\n        }\n\n        // Atomic rename from staging to final location\n        if let Err(e) = fs::rename(&staging_root, &project_root) {\n            let _ = fs::remove_dir_all(&staging_root);\n            return Err(e.into());\n        }\n\n        Ok(())\n    }\n}\n\n/// Filesystem-backed implementation of `JournalStorePort`.\npub struct FsJournalStore;\n\nimpl JournalStorePort for FsJournalStore {\n    fn read_journal(\n        &self,\n        base_dir: &Path,\n        project_id: &ProjectId,\n    ) -> AppResult<Vec<JournalEvent>> {\n        let path = FileSystem::project_root(base_dir, project_id).join(JOURNAL_FILE);\n        match fs::read_to_string(&path) {\n            Ok(contents) => journal::parse_journal(&contents),\n            Err(e) if e.kind() == std::io::ErrorKind::NotFound => Ok(Vec::new()),\n            Err(e) => Err(e.into()),\n        }\n    }\n\n    fn append_event(\n        &self,\n        base_dir: &Path,\n        project_id: &ProjectId,\n        line: &str,\n    ) -> AppResult<()> {\n        let path = FileSystem::project_root(base_dir, project_id).join(JOURNAL_FILE);\n        FileSystem::append_line(&path, line)\n    }\n}\n\n/// Filesystem-backed implementation of `ArtifactStorePort`.\npub struct FsArtifactStore;\n\nimpl ArtifactStorePort for FsArtifactStore {\n    fn list_payloads(\n        &self,\n        base_dir: &Path,\n        project_id: &ProjectId,\n    ) -> AppResult<Vec<PayloadRecord>> {\n        let dir = FileSystem::project_root(base_dir, project_id).join(\"history/payloads\");\n        if !dir.is_dir() {\n            return Ok(Vec::new());\n        }\n\n        let mut records = Vec::new();\n        for entry in fs::read_dir(&dir)? {\n            let entry = entry?;\n            let path = entry.path();\n            if path.extension().is_some_and(|ext| ext == \"json\") {\n                let raw = fs::read_to_string(&path)?;\n                let record: PayloadRecord = serde_json::from_str(&raw).map_err(|e| {\n                    AppError::CorruptRecord {\n                        file: format!(\n                            \"history/payloads/{}\",\n                            path.file_name()\n                                .unwrap_or_default()\n                                .to_string_lossy()\n                        ),\n                        details: e.to_string(),\n                    }\n                })?;\n                records.push(record);\n            }\n        }\n\n        records.sort_by_key(|r| r.created_at);\n        Ok(records)\n    }\n\n    fn list_artifacts(\n        &self,\n        base_dir: &Path,\n        project_id: &ProjectId,\n    ) -> AppResult<Vec<ArtifactRecord>> {\n        let dir = FileSystem::project_root(base_dir, project_id).join(\"history/artifacts\");\n        if !dir.is_dir() {\n            return Ok(Vec::new());\n        }\n\n        let mut records = Vec::new();\n        for entry in fs::read_dir(&dir)? {\n            let entry = entry?;\n            let path = entry.path();\n            if path.extension().is_some_and(|ext| ext == \"json\") {\n                let raw = fs::read_to_string(&path)?;\n                let record: ArtifactRecord =\n                    serde_json::from_str(&raw).map_err(|e| AppError::CorruptRecord {\n                        file: format!(\n                            \"history/artifacts/{}\",\n                            path.file_name()\n                                .unwrap_or_default()\n                                .to_string_lossy()\n                        ),\n                        details: e.to_string(),\n                    })?;\n                records.push(record);\n            }\n        }\n\n        records.sort_by_key(|r| r.created_at);\n        Ok(records)\n    }\n}\n\n/// Filesystem-backed implementation of `RuntimeLogStorePort`.\npub struct FsRuntimeLogStore;\n\nimpl RuntimeLogStorePort for FsRuntimeLogStore {\n    fn read_runtime_logs(\n        &self,\n        base_dir: &Path,\n        project_id: &ProjectId,\n    ) -> AppResult<Vec<RuntimeLogEntry>> {\n        let dir = FileSystem::project_root(base_dir, project_id).join(\"runtime/logs\");\n        if !dir.is_dir() {\n            return Ok(Vec::new());\n        }\n\n        let mut entries = Vec::new();\n        let mut paths: Vec<_> = fs::read_dir(&dir)?\n            .filter_map(|e| e.ok())\n            .map(|e| e.path())\n            .filter(|p| p.extension().is_some_and(|ext| ext == \"ndjson\"))\n            .collect();\n        paths.sort();\n\n        for path in paths {\n            let contents = fs::read_to_string(&path)?;\n            for line in contents.lines() {\n                let trimmed = line.trim();\n                if trimmed.is_empty() {\n                    continue;\n                }\n                if let Ok(entry) = serde_json::from_str::<RuntimeLogEntry>(trimmed) {\n                    entries.push(entry);\n                }\n            }\n        }\n\n        Ok(entries)\n    }\n}\n\n/// Filesystem-backed implementation of `RunSnapshotPort`.\npub struct FsRunSnapshotStore;\n\nimpl RunSnapshotPort for FsRunSnapshotStore {\n    fn read_run_snapshot(\n        &self,\n        base_dir: &Path,\n        project_id: &ProjectId,\n    ) -> AppResult<RunSnapshot> {\n        let path = FileSystem::project_root(base_dir, project_id).join(RUN_FILE);\n        match fs::read_to_string(&path) {\n            Ok(raw) => serde_json::from_str(&raw).map_err(|e| AppError::CorruptRecord {\n                file: format!(\"projects/{}/run.json\", project_id),\n                details: e.to_string(),\n            }),\n            Err(e) if e.kind() == std::io::ErrorKind::NotFound => Ok(RunSnapshot::initial()),\n            Err(e) => Err(e.into()),\n        }\n    }\n}\n\n/// Filesystem-backed implementation of `ActiveProjectPort`.\npub struct FsActiveProjectStore;\n\nimpl ActiveProjectPort for FsActiveProjectStore {\n    fn read_active_project_id(&self, base_dir: &Path) -> AppResult<Option<String>> {\n        FileSystem::read_active_project(&FileSystem::workspace_root_path(base_dir))\n    }\n\n    fn clear_active_project(&self, base_dir: &Path) -> AppResult<()> {\n        let path = FileSystem::workspace_root_path(base_dir).join(ACTIVE_PROJECT_FILE);\n        match fs::remove_file(&path) {\n            Ok(()) => Ok(()),\n            Err(e) if e.kind() == std::io::ErrorKind::NotFound => Ok(()),\n            Err(e) => Err(e.into()),\n        }\n    }\n}\n","numLines":511,"startLine":1,"totalLines":511}}}
