efault, skip_serializing_if = \"Option::is_none\")]\n    pub enabled: Option<bool>,\n    #[serde(flatten)]\n    pub extra: Table,\n}\n\nimpl PromptReviewSettings {\n    pub fn is_empty(&self) -> bool {\n        self.enabled.is_none() && self.extra.is_empty()\n    }\n}\n","numLines":368,"startLine":1,"totalLines":368}}}
