{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01BJDD71u7yFVXKaCj6SE3Qh","type":"tool_result","content":"     1→#![forbid(unsafe_code)]\n     2→\n     3→//! Stage contract registry and deterministic evaluation pipeline.\n     4→//!\n     5→//! Every stage in every built-in flow preset resolves to exactly one\n     6→//! [`StageContract`]. Contract evaluation enforces a fixed order:\n     7→//!\n     8→//! 1. **Schema validation** — deserialize raw JSON into the typed payload.\n     9→//! 2. **Semantic validation** — apply domain rules to the typed payload.\n    10→//! 3. **Rendering** — produce a deterministic Markdown artifact.\n    11→//!\n    12→//! On schema failure, semantic validation and rendering do not run.\n    13→//! On domain failure, rendering does not run.\n    14→//! On any failure, no success bundle is returned.\n    15→\n    16→use schemars::schema::RootSchema;\n    17→\n    18→use crate::shared::domain::StageId;\n    19→use crate::shared::error::ContractError;\n    20→\n    21→use super::payloads::{ExecutionPayload, PlanningPayload, StagePayload, ValidationPayload};\n    22→use super::renderers;\n    23→\n    24→// ── Contract family ─────────────────────────────────────────────────────────\n    25→\n    26→/// Classifies a stage into one of three payload families.\n    27→#[derive(Debug, Clone, Copy, PartialEq, Eq, Hash)]\n    28→pub enum ContractFamily {\n    29→    /// prompt_review, planning, docs_plan, ci_plan\n    30→    Planning,\n    31→    /// implementation, plan_and_implement, apply_fixes, docs_update, ci_update\n    32→    Execution,\n    33→    /// qa, docs_validation, ci_validation, acceptance_qa, review, final_review,\n    34→    /// completion_panel\n    35→    Validation,\n    36→}\n    37→\n    38→// ── Stage contract ──────────────────────────────────────────────────────────\n    39→\n    40→/// A stage contract binds a [`StageId`] to its payload family, schema,\n    41→/// semantic validation rules, and renderer.\n    42→#[derive(Debug, Clone, Copy, PartialEq, Eq)]\n    43→pub struct StageContract {\n    44→    pub stage_id: StageId,\n    45→    pub family: ContractFamily,\n    46→}\n    47→\n    48→/// Bundle of a validated payload and its rendered Markdown artifact.\n    49→///\n    50→/// Callers receive either a `ValidatedBundle` or an error — never one without\n    51→/// the other. On any failure (schema, domain, or QA/review outcome), no bundle\n    52→/// is returned.\n    53→#[derive(Debug, Clone, PartialEq, Eq)]\n    54→pub struct ValidatedBundle {\n    55→    pub payload: StagePayload,\n    56→    pub artifact: String,\n    57→}\n    58→\n    59→// ── Registry ────────────────────────────────────────────────────────────────\n    60→\n    61→/// Look up the contract for a given stage. Every [`StageId`] variant resolves\n    62→/// to exactly one contract.\n    63→pub fn contract_for_stage(stage_id: StageId) -> StageContract {\n    64→    let family = match stage_id {\n    65→        StageId::PromptReview | StageId::Planning | StageId::DocsPlan | StageId::CiPlan => {\n    66→            ContractFamily::Planning\n    67→        }\n    68→\n    69→        StageId::Implementation\n    70→        | StageId::PlanAndImplement\n    71→        | StageId::ApplyFixes\n    72→        | StageId::DocsUpdate\n    73→        | StageId::CiUpdate => ContractFamily::Execution,\n    74→\n    75→        StageId::Qa\n    76→        | StageId::DocsValidation\n    77→        | StageId::CiValidation\n    78→        | StageId::AcceptanceQa\n    79→        | StageId::Review\n    80→        | StageId::FinalReview\n    81→        | StageId::CompletionPanel => ContractFamily::Validation,\n    82→    };\n    83→\n    84→    StageContract { stage_id, family }\n    85→}\n    86→\n    87→/// Return contracts for all stages, in [`StageId::ALL`] order.\n    88→pub fn all_contracts() -> Vec<StageContract> {\n    89→    StageId::ALL\n    90→        .iter()\n    91→        .map(|&id| contract_for_stage(id))\n    92→        .collect()\n    93→}\n    94→\n    95→// ── Contract implementation ─────────────────────────────────────────────────\n    96→\n    97→impl StageContract {\n    98→    /// Generate the JSON Schema for this contract's payload family.\n    99→    pub fn json_schema(&self) -> RootSchema {\n   100→        match self.family {\n   101→            ContractFamily::Planning => schemars::schema_for!(PlanningPayload),\n   102→            ContractFamily::Execution => schemars::schema_for!(ExecutionPayload),\n   103→            ContractFamily::Validation => schemars::schema_for!(ValidationPayload),\n   104→        }\n   105→    }\n   106→\n   107→    /// Evaluate a raw JSON value through the full contract pipeline.\n   108→    ///\n   109→    /// Schema validation → semantic validation → outcome check → rendering.\n   110→    ///\n   111→    /// Returns [`ValidatedBundle`] on success or a [`ContractError`] on any\n   112→    /// failure. Non-passing QA/review outcomes are errors classified as\n   113→    /// [`FailureClass::QaReviewOutcomeFailure`] — no success bundle is returned.\n   114→    pub fn evaluate(&self, raw_json: &serde_json::Value) -> Result<ValidatedBundle, ContractError> {\n   115→        // Step 1: Schema validation (deserialization into typed payload).\n   116→        let payload = self.validate_schema(raw_json)?;\n   117→\n   118→        // Step 2: Semantic / domain validation.\n   119→        self.validate_semantics(&payload)?;\n   120→\n   121→        // Step 3: Non-passing QA/review outcome check (before rendering).\n   122→        self.check_outcome(&payload)?;\n   123→\n   124→        // Step 4: Deterministic Markdown rendering (only on full success).\n   125→        let artifact = self.render(&payload);\n   126→\n   127→        Ok(ValidatedBundle { payload, artifact })\n   128→    }\n   129→\n   130→    // ── Private helpers ─────────────────────────────────────────────────\n   131→\n   132→    fn validate_schema(&self, raw: &serde_json::Value) -> Result<StagePayload, ContractError> {\n   133→        match self.family {\n   134→            ContractFamily::Planning => {\n   135→                let p: PlanningPayload = serde_json::from_value(raw.clone()).map_err(|e| {\n   136→                    ContractError::SchemaValidation {\n   137→                        stage_id: self.stage_id,\n   138→                        details: e.to_string(),\n   139→                    }\n   140→                })?;\n   141→                Ok(StagePayload::Planning(p))\n   142→            }\n   143→            ContractFamily::Execution => {\n   144→                let p: ExecutionPayload = serde_json::from_value(raw.clone()).map_err(|e| {\n   145→                    ContractError::SchemaValidation {\n   146→                        stage_id: self.stage_id,\n   147→                        details: e.to_string(),\n   148→                    }\n   149→                })?;\n   150→                Ok(StagePayload::Execution(p))\n   151→            }\n   152→            ContractFamily::Validation => {\n   153→                let p: ValidationPayload = serde_json::from_value(raw.clone()).map_err(|e| {\n   154→                    ContractError::SchemaValidation {\n   155→                        stage_id: self.stage_id,\n   156→                        details: e.to_string(),\n   157→                    }\n   158→                })?;\n   159→                Ok(StagePayload::Validation(p))\n   160→            }\n   161→        }\n   162→    }\n   163→\n   164→    fn validate_semantics(&self, payload: &StagePayload) -> Result<(), ContractError> {\n   165→        match payload {\n   166→            StagePayload::Planning(p) => {\n   167→                let mut errors = Vec::new();\n   168→                if p.problem_framing.trim().is_empty() {\n   169→                    errors.push(\"problem_framing must not be empty\".to_string());\n   170→                }\n   171→                if p.proposed_work.is_empty() {\n   172→                    errors.push(\"proposed_work must contain at least one item\".to_string());\n   173→                }\n   174→                for (i, item) in p.proposed_work.iter().enumerate() {\n   175→                    if item.order == 0 {\n   176→                        errors.push(format!(\"proposed_work[{i}].order must be positive\"));\n   177→                    }\n   178→                }\n   179→                if !errors.is_empty() {\n   180→                    return Err(ContractError::DomainValidation {\n   181→                        stage_id: self.stage_id,\n   182→                        details: errors.join(\"; \"),\n   183→                    });\n   184→                }\n   185→            }\n   186→            StagePayload::Execution(p) => {\n   187→                let mut errors = Vec::new();\n   188→                if p.change_summary.trim().is_empty() {\n   189→                    errors.push(\"change_summary must not be empty\".to_string());\n   190→                }\n   191→                if p.steps.is_empty() {\n   192→                    errors.push(\"steps must contain at least one item\".to_string());\n   193→                }\n   194→                for (i, step) in p.steps.iter().enumerate() {\n   195→                    if step.order == 0 {\n   196→                        errors.push(format!(\"steps[{i}].order must be positive\"));\n   197→                    }\n   198→                }\n   199→                if !errors.is_empty() {\n   200→                    return Err(ContractError::DomainValidation {\n   201→                        stage_id: self.stage_id,\n   202→                        details: errors.join(\"; \"),\n   203→                    });\n   204→                }\n   205→            }\n   206→            StagePayload::Validation(p) => {\n   207→                if !p.outcome.is_passing() && p.follow_up_or_amendments.is_empty() {\n   208→                    return Err(ContractError::DomainValidation {\n   209→                        stage_id: self.stage_id,\n   210→                        details: \"follow_up_or_amendments required when outcome is not approved\"\n   211→                            .to_string(),\n   212→                    });\n   213→                }\n   214→            }\n   215→        }\n   216→        Ok(())\n   217→    }\n   218→\n   219→    fn render(&self, payload: &StagePayload) -> String {\n   220→        match payload {\n   221→            StagePayload::Planning(p) => renderers::render_planning(self.stage_id, p),\n   222→            StagePayload::Execution(p) => renderers::render_execution(self.stage_id, p),\n   223→            StagePayload::Validation(p) => renderers::render_validation(self.stage_id, p),\n   224→        }\n   225→    }\n   226→\n   227→    fn check_outcome(&self, payload: &StagePayload) -> Result<(), ContractError> {\n   228→        if let StagePayload::Validation(p) = payload {\n   229→            if !p.outcome.is_passing() {\n   230→                return Err(ContractError::QaReviewOutcome {\n   231→                    stage_id: self.stage_id,\n   232→                    outcome: p.outcome.to_string(),\n   233→                });\n   234→            }\n   235→        }\n   236→        Ok(())\n   237→    }\n   238→}\n   239→"}]},"parent_tool_use_id":"toolu_012QdgmdBxgtkt4tovj3QwR9","session_id":"84e4772c-0822-4fc6-b1d7-1c1f7c7f3e3a","uuid":"0c9cb8d6-b431-470a-80b9-71b5a8633123"}
