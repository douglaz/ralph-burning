n    52→            .collect()\n    53→    }\n    54→\n    55→    fn delete_project(&self, _base_dir: &Path, project_id: &ProjectId) -> AppResult<()> {\n    56→        if !self.existing_ids.contains(&project_id.to_string()) {\n    57→            return Err(AppError::ProjectNotFound {\n    58→                project_id: project_id.to_string(),\n    59→            });\n    60→        }\n    61→        Ok(())\n    62→    }\n    63→\n    64→    fn create_project_atomic(\n    65→        &self,\n    66→        _base_dir: &Path,\n    67→        _record: &ProjectRecord,\n    68→        _prompt_contents: &str,\n    69→        _run_snapshot: &RunSnapshot,\n    70→        _initial_journal_line: &str,\n    71→        _sessions: &SessionStore,\n    72→    ) -> AppResult<()> {\n    73→        Ok(())\n    74→    }\n    75→}\n    76→\n    77→struct FakeJournalStore;\n    78→\n    79→impl JournalStorePort for FakeJournalStore {\n    80→    fn read_journal(\n    81→        &self,\n    82→        _base_dir: &Path,\n    83→        _project_id: &ProjectId,\n    84→    ) -> AppResult<Vec<JournalEvent>> {\n    85→        Ok(vec![make_project_created_event()])\n    86→    }\n    87→\n    88→    fn append_event(\n    89→        &self,\n    90→        _base_dir: &Path,\n    91→        _project_id: &ProjectId,\n    92→        _line: &str,\n    93→    ) -> AppResult<()> {\n    94→        Ok(())\n    95→    }\n    96→}\n    97→\n    98→struct FakeRunSnapshotStore {\n    99→    has_active_run: bool,\n   100→}\n   101→\n   102→impl FakeRunSnapshotStore {\n   103→    fn no_run() -> Self {\n   104→        Self {\n   105→            has_active_run: false,\n   106→        }\n   107→    }\n   108→\n   109→    fn active_run() -> Self {\n   110→        Self {\n   111→            has_active_run: true,\n   112→        }\n   113→    }\n   114→}\n   115→\n   116→impl RunSnapshotPort for FakeRunSnapshotStore {\n   117→    fn read_run_snapshot(\n   118→        &self,\n   119→        _base_dir: &Path,\n   120→        _project_id: &ProjectId,\n   121→    ) -> AppResult<RunSnapshot> {\n   122→        if self.has_active_run {\n   123→            Ok(RunSnapshot {\n   124→                active_run: Some(ActiveRun {\n   125→                    run_id: \"run-1\".to_owned(),\n   126→                    stage_cursor: ralph_burning::shared::domain::StageCursor::initial(\n   127→                        ralph_burning::shared::domain::StageId::Planning,\n   128→                    ),\n   129→                    started_at: test_timestamp(),\n   130→                }),\n   131→                status: RunStatus::Running,\n   132→                cycle_history: Vec::new(),\n   133→                completion_rounds: 0,\n   134→                rollback_point_meta: RollbackPointMeta::default(),\n   135→                amendment_queue: AmendmentQueueState::default(),\n   136→                status_summary: \"running\".to_owned(),\n   137→            })\n   138→        } else {\n   139→            Ok(RunSnapshot::initial())\n   140→        }\n   141→    }\n   142→}\n   143→\n   144→struct FakeActiveProjectStore {\n   145→    active_id: Option<String>,\n   146→}\n   147→\n   148→impl FakeActiveProjectStore {\n   149→    fn none() -> Self {\n   150→        Self { active_id: None }\n   151→    }\n   152→\n   153→    fn with_active(id: &str) -> Self {\n   154→        Self {\n   155→            active_id: Some(id.to_owned()),\n   156→        }\n   157→    }\n   158→}\n   159→\n   160→impl ActiveProjectPort for FakeActiveProjectStore {\n   161→    fn read_active_project_id(&self, _base_dir: &Path) -> AppResult<Option<String>> {\n   162→        Ok(self.active_id.clone())\n   163→    }\n   164→\n   165→    fn clear_active_project(&self, _base_dir: &Path) -> AppResult<()> {\n   166→        Ok(())\n   167→    }\n   168→}\n   169→\n   170→// ── Helpers ──\n   171→\n   172→fn test_timestamp() -> chrono::DateTime<Utc> {\n   173→    Utc.with_ymd_and_hms(2026, 3, 11, 19, 0, 0)\n   174→        .single()\n   175→        .expect(\"valid timestamp\")\n   176→}\n   177→\n   178→fn make_project_record(id: &str) -> ProjectRecord {\n   179→    ProjectRecord {\n   180→        id: ProjectId::new(id).unwrap(),\n   181→        name: format!(\"Project {id}\"),\n   182→        flow: FlowPreset::Standard,\n   183→        prompt_reference: \"prompt.md\".to_owned(),\n   184→        prompt_hash: \"abc123\".to_owned(),\n   185→        created_at: test_timestamp(),\n   186→        status_summary: ProjectStatusSummary::Created,\n   187→    }\n   188→}\n   189→\n   190→fn make_project_created_event() -> JournalEvent {\n   191→    JournalEvent {\n   192→        sequence: 1,\n   193→        timestamp: test_timestamp(),\n   194→        event_type: JournalEventType::ProjectCreated,\n   195→        details: serde_json::json!({\"project_id\": \"alpha\", \"flow\": \"standard\"}),\n   196→    }\n   197→}\n   198→\n   199→fn dummy_base_dir() -> std::path::PathBuf {\n   200→    std::path::PathBuf::from(\"/tmp/test\")\n   201→}\n   202→\n   203→// ── Domain Tests ──\n   204→\n   205→#[test]\n   206→fn run_snapshot_initial_has_no_active_run() {\n   207→    let snapshot = RunSnapshot::initial();\n   208→    assert!(!snapshot.has_active_run());\n   209→    assert_eq!(snapshot.status, RunStatus::NotStarted);\n   210→}\n   211→\n   212→#[test]\n   213→fn session_store_empty_has_no_sessions() {\n   214→    let store = SessionStore::empty();\n   215→    assert!(store.sessions.is_empty());\n   216→}\n   217→\n   218→#[test]\n   219→fn project_record_flow_is_immutable_after_creation() {\n   220→    let record = make_project_record(\"alpha\");\n   221→    assert_eq!(record.flow, FlowPreset::Standard);\n   222→    // Flow is a plain field with no setter — immutability enforced by\n   223→    // not providing mutation methods on ProjectRecord.\n   224→}\n   225→\n   226→#[test]\n   227→fn journal_event_types_serialize_to_snake_case() {\n   228→    let event = make_project_created_event();\n   229→    let json = serde_json::to_string(&event).expect(\"serialize\");\n   230→    assert!(json.contains(\"\\\"project_created\\\"\"));\n   231→}\n   232→\n   233→// ── Service Tests with Fake Ports ──\n   234→\n   235→#[test]\n   236→fn create_project_succeeds_with_valid_input() {\n   237→    let store = FakeProjectStore::empty();\n   238→    let journal_store = FakeJournalStore;\n   239→    let base_dir = dummy_base_dir();\n   240→\n   241→    let input = CreateProjectInput {\n   242→        id: ProjectId::new(\"alpha\").unwrap(),\n   243→        name: \"Alpha Project\".to_owned(),\n   244→        flow: FlowPreset::Standard,\n   245→        prompt_path: \"prompt.md\".to_owned(),\n   246→        prompt_contents: \"# My prompt\\nDo something.\".to_owned(),\n   247→        prompt_hash: \"hash123\".to_owned(),\n   248→        created_at: test_timestamp(),\n   249→    };\n   250→\n   251→    let result = create_project(&store, &journal_store, &base_dir, input);\n   252→    assert!(result.is_ok());\n   253→\n   254→    let record = result.unwrap();\n   255→    assert_eq!(record.id.as_str(), \"alpha\");\n   256→    assert_eq!(record.flow, FlowPreset::Standard);\n   257→    assert_eq!(record.status_summary, ProjectStatusSummary::Created);\n   258→}\n   259→\n   260→#[test]\n   261→fn create_project_fails_on_duplicate_id() {\n   262→    let store = FakeProjectStore::with_existing(&[\"alpha\"]);\n   263→    let journal_store = FakeJournalStore;\n   264→    let base_dir = dummy_base_dir();\n   265→\n   266→    let input = CreateProjectInput {\n   267→        id: ProjectId::new(\"alpha\").unwrap(),\n   268→        name: \"Alpha Again\".to_owned(),\n   269→        flow: FlowPreset::Standard,\n   270→        prompt_path: \"prompt.md\".to_owned(),\n   271→        prompt_contents: \"content\".to_owned(),\n   272→        prompt_hash: \"hash\".to_owned(),\n   273→        created_at: test_timestamp(),\n   274→    };\n   275→\n   276→    let result = create_project(&store, &journal_store, &base_dir, input);\n   277→    assert!(result.is_err());\n   278→    assert!(matches!(\n   279→        result.unwrap_err(),\n   280→        AppError::DuplicateProject { .. }\n   281→    ));\n   282→}\n   283→\n   284→#[test]\n   285→fn list_projects_returns_entries_with_active_flag() {\n   286→    let store = FakeProjectStore::with_existing(&[\"alpha\", \"beta\"]);\n   287→    let active_store = FakeActiveProjectStore::with_active(\"alpha\");\n   288→    let base_dir = dummy_base_dir();\n   289→\n   290→    let entries = list_projects(&store, &active_store, &base_dir).unwrap();\n   291→    assert_eq!(entries.len(), 2);\n   292→\n   293→    let alpha = entries.iter().find(|e| e.id.as_str() == \"alpha\").unwrap();\n   294→    assert!(alpha.is_active);\n   295→\n   296→    let beta = entries.iter().find(|e| e.id.as_str() == \"beta\").unwrap();\n   297→    assert!(!beta.is_active);\n   298→}\n   299→\n   300→#[test]\n   301→fn list_projects_with_no_active_project() {\n   302→    let store = FakeProjectStore::with_existing(&[\"alpha\"]);\n   303→    let active_store = FakeActiveProjectStore::none();\n   304→    let base_dir = dummy_base_dir();\n   305→\n   306→    let entries = list_projects(&store, &active_store, &base_dir).unwrap();\n   307→    assert_eq!(entries.len(), 1);\n   308→    assert!(!entries[0].is_active);\n   309→}\n   310→\n   311→#[test]\n   312→fn show_project_returns_detail() {\n   313→    let store = FakeProjectStore::with_existing(&[\"alpha\"]);\n   314→    let run_store = FakeRunSnapshotStore::no_run();\n   315→    let journal_store = FakeJournalStore;\n   316→    let active_store = FakeActiveProjectStore::with_active(\"alpha\");\n   317→    let base_dir = dummy_base_dir();\n   318→    let pid = ProjectId::new(\"alpha\").unwrap();\n   319→\n   320→    let detail =\n   321→        show_project(&store, &run_store, &journal_store, &active_store, &base_dir, &pid).unwrap();\n   322→\n   323→    assert_eq!(detail.record.id.as_str(), \"alpha\");\n   324→    assert!(detail.is_active);\n   325→    assert_eq!(detail.journal_event_count, 1);\n   326→    assert!(!detail.run_snapshot.has_active_run());\n   327→}\n   328→\n   329→#[test]\n   330→fn show_project_fails_for_missing_project() {\n   331→    let store = FakeProjectStore::empty();\n   332→    let run_store = FakeRunSnapshotStore::no_run();\n   333→    let journal_store = FakeJournalStore;\n   334→    let active_store = FakeActiveProjectStore::none();\n   335→    let base_dir = dummy_base_dir();\n   336→    let pid = ProjectId::new(\"missing\").unwrap();\n   337→\n   338→    let result =\n   339→        show_project(&store, &run_store, &journal_store, &active_store, &base_dir, &pid);\n   340→    assert!(matches!(\n   341→        result.unwrap_err(),\n   342→        AppError::ProjectNotFound { .. }\n   343→    ));\n   344→}\n   345→\n   346→#[test]\n   347→fn delete_project_succeeds_when_no_active_run() {\n   348→    let store = FakeProjectStore::with_existing(&[\"alpha\"]);\n   349→    let run_store = FakeRunSnapshotStore::no_run();\n   350→    let active_store = FakeActiveProjectStore::none();\n   351→    let base_dir = dummy_base_dir();\n   352→    let pid = ProjectId::new(\"alpha\").unwrap();\n   353→\n   354→    let result = delete_project(&store, &run_store, &active_store, &base_dir, &pid);\n   355→    assert!(result.is_ok());\n   356→}\n   357→\n   358→#[test]\n   359→fn delete_project_fails_with_active_run() {\n   360→    let store = FakeProjectStore::with_existing(&[\"alpha\"]);\n   361→    let run_store = FakeRunSnapshotStore::active_run();\n   362→    let active_store = FakeActiveProjectStore::none();\n   363→    let base_dir = dummy_base_dir();\n   364→    let pid = ProjectId::new(\"alpha\").unwrap();\n   365→\n   366→    let result = delete_project(&store, &run_store, &active_store, &base_dir, &pid);\n   367→    assert!(matches!(\n   368→        result.unwrap_err(),\n   369→        AppError::ActiveRunDelete { .. }\n   370→    ));\n   371→}\n   372→\n   373→#[test]\n   374→fn delete_project_fails_for_missing_project() {\n   375→    let store = FakeProjectStore::empty();\n   376→    let run_store = FakeRunSnapshotStore::no_run();\n   377→    let active_store = FakeActiveProjectStore::none();\n   378→    let base_dir = dummy_base_dir();\n   379→    let pid = ProjectId::new(\"missing\").unwrap();\n   380→\n   381→    let result = delete_project(&store, &run_store, &active_store, &base_dir, &pid);\n   382→    assert!(matches!(\n   383→        result.unwrap_err(),\n   384→        AppError::ProjectNotFound { .. }\n   385→    ));\n   386→}\n   387→\n   388→#[test]\n   389→fn run_status_reports_not_started_when_no_active_run() {\n   390→    let run_store = FakeRunSnapshotStore::no_run();\n   391→    let base_dir = dummy_base_dir();\n   392→    let pid = ProjectId::new(\"alpha\").unwrap();\n   393→\n   394→    let status = run_status(&run_store, &base_dir, &pid).unwrap();\n   395→    assert_eq!(status.status, \"not started\");\n   396→    assert!(status.stage.is_none());\n   397→    assert!(status.cycle.is_none());\n   398→}\n   399→\n   400→#[test]\n   401→fn run_status_reports_running_with_stage_cursor() {\n   402→    let run_store = FakeRunSnapshotStore::active_run();\n   403→    let base_dir = dummy_base_dir();\n   404→    let pid = ProjectId::new(\"alpha\").unwrap();\n   405→\n   406→    let status = run_status(&run_store, &base_dir, &pid).unwrap();\n   407→    assert_eq!(status.status, \"running\");\n   408→    assert_eq!(status.stage, Some(\"planning\".to_owned()));\n   409→    assert_eq!(status.cycle, Some(1));\n   410→}\n   411→"}]},"parent_tool_use_id":null,"session_id":"1a3d9a31-afc3-4ac3-baa7-2cce587b25ae","uuid":"70b2f217-9f28-467e-8e0b-6c7c795dac7a","tool_use_result":{"type":"text","file":{"filePath":"/root/new-ralph-burning/ralph-burning-rewrite/tests/unit/project_run_record_test.rs","content":"use std::path::Path;\n\nuse chrono::{TimeZone, Utc};\n\nuse ralph_burning::contexts::project_run_record::model::*;\nuse ralph_burning::contexts::project_run_record::service::*;\nuse ralph_burning::shared::domain::{FlowPreset, ProjectId};\nuse ralph_burning::shared::error::{AppError, AppResult};\n\n// ── Fake implementations of ports for service-level testing ──\n\nstruct FakeProjectStore {\n    existing_ids: Vec<String>,\n}\n\nimpl FakeProjectStore {\n    fn empty() -> Self {\n        Self {\n            existing_ids: Vec::new(),\n        }\n    }\n\n    fn with_existing(ids: &[&str]) -> Self {\n        Self {\n            existing_ids: ids.iter().map(|s| s.to_string()).collect(),\n        }\n    }\n}\n\nimpl ProjectStorePort for FakeProjectStore {\n    fn project_exists(&self, _base_dir: &Path, project_id: &ProjectId) -> AppResult<bool> {\n        Ok(self.existing_ids.contains(&project_id.to_string()))\n    }\n\n    fn read_project_record(\n        &self,\n        _base_dir: &Path,\n        project_id: &ProjectId,\n    ) -> AppResult<ProjectRecord> {\n        if !self.existing_ids.contains(&project_id.to_string()) {\n            return Err(AppError::ProjectNotFound {\n                project_id: project_id.to_string(),\n            });\n        }\n        Ok(make_project_record(project_id.as_str()))\n    }\n\n    fn list_project_ids(&self, _base_dir: &Path) -> AppResult<Vec<ProjectId>> {\n        self.existing_ids\n            .iter()\n            .map(|id| ProjectId::new(id.as_str()))\n            .collect()\n    }\n\n    fn delete_project(&self, _base_dir: &Path, project_id: &ProjectId) -> AppResult<()> {\n        if !self.existing_ids.contains(&project_id.to_string()) {\n            return Err(AppError::ProjectNotFound {\n                project_id: project_id.to_string(),\n            });\n        }\n        Ok(())\n    }\n\n    fn create_project_atomic(\n        &self,\n        _base_dir: &Path,\n        _record: &ProjectRecord,\n        _prompt_contents: &str,\n        _run_snapshot: &RunSnapshot,\n        _initial_journal_line: &str,\n        _sessions: &SessionStore,\n    ) -> AppResult<()> {\n        Ok(())\n    }\n}\n\nstruct FakeJournalStore;\n\nimpl JournalStorePort for FakeJournalStore {\n    fn read_journal(\n        &self,\n        _base_dir: &Path,\n        _project_id: &ProjectId,\n    ) -> AppResult<Vec<JournalEvent>> {\n        Ok(vec![make_project_created_event()])\n    }\n\n    fn append_event(\n        &self,\n        _base_dir: &Path,\n        _project_id: &ProjectId,\n        _line: &str,\n    ) -> AppResult<()> {\n        Ok(())\n    }\n}\n\nstruct FakeRunSnapshotStore {\n    has_active_run: bool,\n}\n\nimpl FakeRunSnapshotStore {\n    fn no_run() -> Self {\n        Self {\n            has_active_run: false,\n        }\n    }\n\n    fn active_run() -> Self {\n        Self {\n            has_active_run: true,\n        }\n    }\n}\n\nimpl RunSnapshotPort for FakeRunSnapshotStore {\n    fn read_run_snapshot(\n        &self,\n        _base_dir: &Path,\n        _project_id: &ProjectId,\n    ) -> AppResult<RunSnapshot> {\n        if self.has_active_run {\n            Ok(RunSnapshot {\n                active_run: Some(ActiveRun {\n                    run_id: \"run-1\".to_owned(),\n                    stage_cursor: ralph_burning::shared::domain::StageCursor::initial(\n                        ralph_burning::shared::domain::StageId::Planning,\n                    ),\n                    started_at: test_timestamp(),\n                }),\n                status: RunStatus::Running,\n                cycle_history: Vec::new(),\n                completion_rounds: 0,\n                rollback_point_meta: RollbackPointMeta::default(),\n                amendment_queue: AmendmentQueueState::default(),\n                status_summary: \"running\".to_owned(),\n            })\n        } else {\n            Ok(RunSnapshot::initial())\n        }\n    }\n}\n\nstruct FakeActiveProjectStore {\n    active_id: Option<String>,\n}\n\nimpl FakeActiveProjectStore {\n    fn none() -> Self {\n        Self { active_id: None }\n    }\n\n    fn with_active(id: &str) -> Self {\n        Self {\n            active_id: Some(id.to_owned()),\n        }\n    }\n}\n\nimpl ActiveProjectPort for FakeActiveProjectStore {\n    fn read_active_project_id(&self, _base_dir: &Path) -> AppResult<Option<String>> {\n        Ok(self.active_id.clone())\n    }\n\n    fn clear_active_project(&self, _base_dir: &Path) -> AppResult<()> {\n        Ok(())\n    }\n}\n\n// ── Helpers ──\n\nfn test_timestamp() -> chrono::DateTime<Utc> {\n    Utc.with_ymd_and_hms(2026, 3, 11, 19, 0, 0)\n        .single()\n        .expect(\"valid timestamp\")\n}\n\nfn make_project_record(id: &str) -> ProjectRecord {\n    ProjectRecord {\n        id: ProjectId::new(id).unwrap(),\n        name: format!(\"Project {id}\"),\n        flow: FlowPreset::Standard,\n        prompt_reference: \"prompt.md\".to_owned(),\n        prompt_hash: \"abc123\".to_owned(),\n        created_at: test_timestamp(),\n        status_summary: ProjectStatusSummary::Created,\n    }\n}\n\nfn make_project_created_event() -> JournalEvent {\n    JournalEvent {\n        sequence: 1,\n        timestamp: test_timestamp(),\n        event_type: JournalEventType::ProjectCreated,\n        details: serde_json::json!({\"project_id\": \"alpha\", \"flow\": \"standard\"}),\n    }\n}\n\nfn dummy_base_dir() -> std::path::PathBuf {\n    std::path::PathBuf::from(\"/tmp/test\")\n}\n\n// ── Domain Tests ──\n\n#[test]\nfn run_snapshot_initial_has_no_active_run() {\n    let snapshot = RunSnapshot::initial();\n    assert!(!snapshot.has_active_run());\n    assert_eq!(snapshot.status, RunStatus::NotStarted);\n}\n\n#[test]\nfn session_store_empty_has_no_sessions() {\n    let store = SessionStore::empty();\n    assert!(store.sessions.is_empty());\n}\n\n#[test]\nfn project_record_flow_is_immutable_after_creation() {\n    let record = make_project_record(\"alpha\");\n    assert_eq!(record.flow, FlowPreset::Standard);\n    // Flow is a plain field with no setter — immutability enforced by\n    // not providing mutation methods on ProjectRecord.\n}\n\n#[test]\nfn journal_event_types_serialize_to_snake_case() {\n    let event = make_project_created_event();\n    let json = serde_json::to_string(&event).expect(\"serialize\");\n    assert!(json.contains(\"\\\"project_created\\\"\"));\n}\n\n// ── Service Tests with Fake Ports ──\n\n#[test]\nfn create_project_succeeds_with_valid_input() {\n    let store = FakeProjectStore::empty();\n    let journal_store = FakeJournalStore;\n    let base_dir = dummy_base_dir();\n\n    let input = CreateProjectInput {\n        id: ProjectId::new(\"alpha\").unwrap(),\n        name: \"Alpha Project\".to_owned(),\n        flow: FlowPreset::Standard,\n        prompt_path: \"prompt.md\".to_owned(),\n        prompt_contents: \"# My prompt\\nDo something.\".to_owned(),\n        prompt_hash: \"hash123\".to_owned(),\n        created_at: test_timestamp(),\n    };\n\n    let result = create_project(&store, &journal_store, &base_dir, input);\n    assert!(result.is_ok());\n\n    let record = result.unwrap();\n    assert_eq!(record.id.as_str(), \"alpha\");\n    assert_eq!(record.flow, FlowPreset::Standard);\n    assert_eq!(record.status_summary, ProjectStatusSummary::Created);\n}\n\n#[test]\nfn create_project_fails_on_duplicate_id() {\n    let store = FakeProjectStore::with_existing(&[\"alpha\"]);\n    let journal_store = FakeJournalStore;\n    let base_dir = dummy_base_dir();\n\n    let input = CreateProjectInput {\n        id: ProjectId::new(\"alpha\").unwrap(),\n        name: \"Alpha Again\".to_owned(),\n        flow: FlowPreset::Standard,\n        prompt_path: \"prompt.md\".to_owned(),\n        prompt_contents: \"content\".to_owned(),\n        prompt_hash: \"hash\".to_owned(),\n        created_at: test_timestamp(),\n    };\n\n    let result = create_project(&store, &journal_store, &base_dir, input);\n    assert!(result.is_err());\n    assert!(matches!(\n        result.unwrap_err(),\n        AppError::DuplicateProject { .. }\n    ));\n}\n\n#[test]\nfn list_projects_returns_entries_with_active_flag() {\n    let store = FakeProjectStore::with_existing(&[\"alpha\", \"beta\"]);\n    let active_store = FakeActiveProjectStore::with_active(\"alpha\");\n    let base_dir = dummy_base_dir();\n\n    let entries = list_projects(&store, &active_store, &base_dir).unwrap();\n    assert_eq!(entries.len(), 2);\n\n    let alpha = entries.iter().find(|e| e.id.as_str() == \"alpha\").unwrap();\n    assert!(alpha.is_active);\n\n    let beta = entries.iter().find(|e| e.id.as_str() == \"beta\").unwrap();\n    assert!(!beta.is_active);\n}\n\n#[test]\nfn list_projects_with_no_active_project() {\n    let store = FakeProjectStore::with_existing(&[\"alpha\"]);\n    let active_store = FakeActiveProjectStore::none();\n    let base_dir = dummy_base_dir();\n\n    let entries = list_projects(&store, &active_store, &base_dir).unwrap();\n    assert_eq!(entries.len(), 1);\n    assert!(!entries[0].is_active);\n}\n\n#[test]\nfn show_project_returns_detail() {\n    let store = FakeProjectStore::with_existing(&[\"alpha\"]);\n    let run_store = FakeRunSnapshotStore::no_run();\n    let journal_store = FakeJournalStore;\n    let active_store = FakeActiveProjectStore::with_active(\"alpha\");\n    let base_dir = dummy_base_dir();\n    let pid = ProjectId::new(\"alpha\").unwrap();\n\n    let detail =\n        show_project(&store, &run_store, &journal_store, &active_store, &base_dir, &pid).unwrap();\n\n    assert_eq!(detail.record.id.as_str(), \"alpha\");\n    assert!(detail.is_active);\n    assert_eq!(detail.journal_event_count, 1);\n    assert!(!detail.run_snapshot.has_active_run());\n}\n\n#[test]\nfn show_project_fails_for_missing_project() {\n    let store = FakeProjectStore::empty();\n    let run_store = FakeRunSnapshotStore::no_run();\n    let journal_store = FakeJournalStore;\n    let active_store = FakeActiveProjectStore::none();\n    let base_dir = dummy_base_dir();\n    let pid = ProjectId::new(\"missing\").unwrap();\n\n    let result =\n        show_project(&store, &run_store, &journal_store, &active_store, &base_dir, &pid);\n    assert!(matches!(\n        result.unwrap_err(),\n        AppError::ProjectNotFound { .. }\n    ));\n}\n\n#[test]\nfn delete_project_succeeds_when_no_active_run() {\n    let store = FakeProjectStore::with_existing(&[\"alpha\"]);\n    let run_store = FakeRunSnapshotStore::no_run();\n    let active_store = FakeActiveProjectStore::none();\n    let base_dir = dummy_base_dir();\n    let pid = ProjectId::new(\"alpha\").unwrap();\n\n    let result = delete_project(&store, &run_store, &active_store, &base_dir, &pid);\n    assert!(result.is_ok());\n}\n\n#[test]\nfn delete_project_fails_with_active_run() {\n    let store = FakeProjectStore::with_existing(&[\"alpha\"]);\n    let run_store = FakeRunSnapshotStore::active_run();\n    let active_store = FakeActiveProjectStore::none();\n    let base_dir = dummy_base_dir();\n    let pid = ProjectId::new(\"alpha\").unwrap();\n\n    let result = delete_project(&store, &run_store, &active_store, &base_dir, &pid);\n    assert!(matches!(\n        result.unwrap_err(),\n        AppError::ActiveRunDelete { .. }\n    ));\n}\n\n#[test]\nfn delete_project_fails_for_missing_project() {\n    let store = FakeProjectStore::empty();\n    let run_store = FakeRunSnapshotStore::no_run();\n    let active_store = FakeActiveProjectStore::none();\n    let base_dir = dummy_base_dir();\n    let pid = ProjectId::new(\"missing\").unwrap();\n\n    let result = delete_project(&store, &run_store, &active_store, &base_dir, &pid);\n    assert!(matches!(\n        result.unwrap_err(),\n        AppError::ProjectNotFound { .. }\n    ));\n}\n\n#[test]\nfn run_status_reports_not_started_when_no_active_run() {\n    let run_store = FakeRunSnapshotStore::no_run();\n    let base_dir = dummy_base_dir();\n    let pid = ProjectId::new(\"alpha\").unwrap();\n\n    let status = run_status(&run_store, &base_dir, &pid).unwrap();\n    assert_eq!(status.status, \"not started\");\n    assert!(status.stage.is_none());\n    assert!(status.cycle.is_none());\n}\n\n#[test]\nfn run_status_reports_running_with_stage_cursor() {\n    let run_store = FakeRunSnapshotStore::active_run();\n    let base_dir = dummy_base_dir();\n    let pid = ProjectId::new(\"alpha\").unwrap();\n\n    let status = run_status(&run_store, &base_dir, &pid).unwrap();\n    assert_eq!(status.status, \"running\");\n    assert_eq!(status.stage, Some(\"planning\".to_owned()));\n    assert_eq!(status.cycle, Some(1));\n}\n","numLines":411,"startLine":1,"totalLines":411}}}
