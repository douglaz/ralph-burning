{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01X4ZSy625zwGZy7cEL8b4qs","type":"tool_result","content":"     1→use chrono::{TimeZone, Utc};\n     2→\n     3→use ralph_burning::contexts::project_run_record::model::*;\n     4→use ralph_burning::contexts::project_run_record::queries;\n     5→use ralph_burning::shared::domain::{StageCursor, StageId};\n     6→use ralph_burning::shared::error::AppError;\n     7→\n     8→fn test_timestamp() -> chrono::DateTime<Utc> {\n     9→    Utc.with_ymd_and_hms(2026, 3, 11, 19, 0, 0)\n    10→        .single()\n    11→        .expect(\"valid timestamp\")\n    12→}\n    13→\n    14→// ── RunStatusView ──\n    15→\n    16→#[test]\n    17→fn status_view_not_started_when_no_active_run() {\n    18→    let snapshot = RunSnapshot::initial();\n    19→    let view = queries::build_status_view(\"alpha\", &snapshot);\n    20→\n    21→    assert_eq!(view.project_id, \"alpha\");\n    22→    assert_eq!(view.status, \"not started\");\n    23→    assert!(view.stage.is_none());\n    24→    assert!(view.cycle.is_none());\n    25→    assert!(view.completion_round.is_none());\n    26→}\n    27→\n    28→#[test]\n    29→fn status_view_reports_running_with_cursor() {\n    30→    let snapshot = RunSnapshot {\n    31→        active_run: Some(ActiveRun {\n    32→            run_id: \"run-1\".to_owned(),\n    33→            stage_cursor: StageCursor::initial(StageId::Planning),\n    34→            started_at: test_timestamp(),\n    35→        }),\n    36→        status: RunStatus::Running,\n    37→        status_summary: \"running at planning\".to_owned(),\n    38→    };\n    39→    let view = queries::build_status_view(\"alpha\", &snapshot);\n    40→\n    41→    assert_eq!(view.status, \"running\");\n    42→    assert_eq!(view.stage, Some(\"planning\".to_owned()));\n    43→    assert_eq!(view.cycle, Some(1));\n    44→    assert_eq!(view.completion_round, Some(1));\n    45→}\n    46→\n    47→// ── RunHistoryView ──\n    48→\n    49→#[test]\n    50→fn history_view_contains_only_durable_records() {\n    51→    let events = vec![JournalEvent {\n    52→        sequence: 1,\n    53→        timestamp: test_timestamp(),\n    54→        event_type: JournalEventType::ProjectCreated,\n    55→        details: serde_json::json!({}),\n    56→    }];\n    57→\n    58→    let view = queries::build_history_view(\"alpha\", events.clone(), vec![], vec![]);\n    59→\n    60→    assert_eq!(view.project_id, \"alpha\");\n    61→    assert_eq!(view.events.len(), 1);\n    62→    assert!(view.payloads.is_empty());\n    63→    assert!(view.artifacts.is_empty());\n    64→}\n    65→\n    66→// ── RunTailView ──\n    67→\n    68→#[test]\n    69→fn tail_view_omits_logs_when_not_requested() {\n    70→    let view = queries::build_tail_view(\"alpha\", vec![], vec![], vec![], false, vec![]);\n    71→    assert!(view.runtime_logs.is_none());\n    72→}\n    73→\n    74→#[test]\n    75→fn tail_view_includes_logs_when_requested() {\n    76→    let logs = vec![RuntimeLogEntry {\n    77→        timestamp: test_timestamp(),\n    78→        level: LogLevel::Info,\n    79→        source: \"agent\".to_owned(),\n    80→        message: \"started\".to_owned(),\n    81→    }];\n    82→\n    83→    let view = queries::build_tail_view(\"alpha\", vec![], vec![], vec![], true, logs);\n    84→    assert!(view.runtime_logs.is_some());\n    85→    assert_eq!(view.runtime_logs.as_ref().unwrap().len(), 1);\n    86→}\n    87→\n    88→#[test]\n    89→fn tail_view_includes_empty_logs_when_requested_but_none_exist() {\n    90→    let view = queries::build_tail_view(\"alpha\", vec![], vec![], vec![], true, vec![]);\n    91→    assert!(view.runtime_logs.is_some());\n    92→    assert!(view.runtime_logs.as_ref().unwrap().is_empty());\n    93→}\n    94→\n    95→// ── History Consistency Validation ──\n    96→\n    97→#[test]\n    98→fn validate_history_consistency_passes_with_matching_records() {\n    99→    let payloads = vec![PayloadRecord {\n   100→        payload_id: \"p1\".to_owned(),\n   101→        stage_id: StageId::Planning,\n   102→        cycle: 1,\n   103→        attempt: 1,\n   104→        created_at: test_timestamp(),\n   105→        payload: serde_json::json!({}),\n   106→    }];\n   107→    let artifacts = vec![ArtifactRecord {\n   108→        artifact_id: \"a1\".to_owned(),\n   109→        payload_id: \"p1\".to_owned(),\n   110→        stage_id: StageId::Planning,\n   111→        created_at: test_timestamp(),\n   112→        content: \"# Planning\".to_owned(),\n   113→    }];\n   114→\n   115→    assert!(queries::validate_history_consistency(&payloads, &artifacts).is_ok());\n   116→}\n   117→\n   118→#[test]\n   119→fn validate_history_consistency_fails_with_orphaned_artifact() {\n   120→    let payloads = vec![];\n   121→    let artifacts = vec![ArtifactRecord {\n   122→        artifact_id: \"a1\".to_owned(),\n   123→        payload_id: \"p-missing\".to_owned(),\n   124→        stage_id: StageId::Planning,\n   125→        created_at: test_timestamp(),\n   126→        content: \"# Planning\".to_owned(),\n   127→    }];\n   128→\n   129→    let result = queries::validate_history_consistency(&payloads, &artifacts);\n   130→    assert!(matches!(\n   131→        result.unwrap_err(),\n   132→        AppError::CorruptRecord { .. }\n   133→    ));\n   134→}\n   135→\n   136→#[test]\n   137→fn validate_history_consistency_passes_with_no_records() {\n   138→    assert!(queries::validate_history_consistency(&[], &[]).is_ok());\n   139→}\n   140→\n   141→// ── Runtime Log Separation ──\n   142→\n   143→#[test]\n   144→fn runtime_logs_never_appear_in_history_view() {\n   145→    // History view has no field for runtime logs - enforced by type system.\n   146→    let view = queries::build_history_view(\"alpha\", vec![], vec![], vec![]);\n   147→    // RunHistoryView has no runtime_logs field, so logs can never leak.\n   148→    assert_eq!(view.project_id, \"alpha\");\n   149→}\n   150→"}]},"parent_tool_use_id":"toolu_017r2pi3xTD6qbkY4thKztbt","session_id":"3640e08e-b88d-40cb-b39d-a6d9ec8d8fb8","uuid":"f0514181-c05c-40ec-b18e-d4aab14c7d6e"}
