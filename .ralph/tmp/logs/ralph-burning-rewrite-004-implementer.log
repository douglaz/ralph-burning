ry`, `run tail`, `project show` (no ID), and missing `project.toml` on `run status`.\n\n## Could Not Address\nNone\n\n## Pending Changes (Pre-Commit)\n- 5 files modified: `workspace_governance/mod.rs`, `cli/run.rs`, `tests/cli.rs`, `tests/conformance/features/run_queries.feature`\n- 162 tests passing (46 CLI + 116 unit), clippy clean\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":116,"cache_read_input_tokens":86924,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":116},"output_tokens":25,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"5eb81d8b-9dcb-415b-a8cb-cb111e8f40b3","uuid":"afc9031a-3b77-4f69-b3d1-1969f0e4a141"}
