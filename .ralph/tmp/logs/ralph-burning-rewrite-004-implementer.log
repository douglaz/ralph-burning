{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01JZRkJw4tsTpe2TrtpDK7nB","type":"tool_result","content":"     1→#![forbid(unsafe_code)]\n     2→\n     3→use std::process::ExitCode;\n     4→\n     5→use clap::Parser;\n     6→use ralph_burning::cli::{self, Cli};\n     7→\n     8→#[tokio::main(flavor = \"multi_thread\")]\n     9→async fn main() -> ExitCode {\n    10→    init_tracing();\n    11→\n    12→    let cli = Cli::parse();\n    13→\n    14→    match cli::run(cli).await {\n    15→        Ok(()) => ExitCode::SUCCESS,\n    16→        Err(error) => {\n    17→            eprintln!(\"{error}\");\n    18→            ExitCode::FAILURE\n    19→        }\n    20→    }\n    21→}\n    22→\n    23→fn init_tracing() {\n    24→    let _ = tracing_subscriber::fmt()\n    25→        .compact()\n    26→        .with_target(false)\n    27→        .without_time()\n    28→        .try_init();\n    29→}\n    30→"}]},"parent_tool_use_id":"toolu_017r2pi3xTD6qbkY4thKztbt","session_id":"3640e08e-b88d-40cb-b39d-a6d9ec8d8fb8","uuid":"7ca7ea49-4eab-4a25-9746-1fdb57fd41cc"}
