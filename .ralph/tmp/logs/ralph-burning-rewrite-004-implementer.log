NotStarted,\n    93→    Running,\n    94→    Paused,\n    95→    Completed,\n    96→    Failed,\n    97→}\n    98→\n    99→impl RunStatus {\n   100→    /// Human-readable status string for CLI output.\n   101→    pub fn display_str(self) -> &'static str {\n   102→        match self {\n   103→            Self::NotStarted => \"not started\",\n   104→            Self::Running => \"running\",\n   105→            Self::Paused => \"paused\",\n   106→            Self::Completed => \"completed\",\n   107→            Self::Failed => \"failed\",\n   108→        }\n   109→    }\n   110→}\n   111→\n   112→/// A single entry in the cycle history tracking progression through work cycles.\n   113→#[derive(Debug, Clone, PartialEq, Serialize, Deserialize)]\n   114→pub struct CycleHistoryEntry {\n   115→    pub cycle: u32,\n   116→    pub stage_id: StageId,\n   117→    pub started_at: DateTime<Utc>,\n   118→    pub completed_at: Option<DateTime<Utc>>,\n   119→}\n   120→\n   121→/// Rollback-point metadata tracked in the canonical run snapshot.\n   122→#[derive(Debug, Clone, Default, PartialEq, Serialize, Deserialize)]\n   123→pub struct RollbackPointMeta {\n   124→    pub last_rollback_id: Option<String>,\n   125→    pub rollback_count: u32,\n   126→}\n   127→\n   128→/// Amendment queue state tracked in the canonical run snapshot.\n   129→#[derive(Debug, Clone, Default, PartialEq, Serialize, Deserialize)]\n   130→pub struct AmendmentQueueState {\n   131→    pub pending: Vec<serde_json::Value>,\n   132→    pub processed_count: u32,\n   133→}\n   134→\n   135→/// A single journal event stored in `journal.ndjson`.\n   136→#[derive(Debug, Clone, PartialEq, Serialize, Deserialize)]\n   137→pub struct JournalEvent {\n   138→    pub sequence: u64,\n   139→    pub timestamp: DateTime<Utc>,\n   140→    pub event_type: JournalEventType,\n   141→    pub details: serde_json::Value,\n   142→}\n   143→\n   144→#[derive(Debug, Clone, PartialEq, Eq, Serialize, Deserialize)]\n   145→#[serde(rename_all = \"snake_case\")]\n   146→pub enum JournalEventType {\n   147→    ProjectCreated,\n   148→    RunStarted,\n   149→    StageEntered,\n   150→    StageCompleted,\n   151→    CycleAdvanced,\n   152→    CompletionRoundAdvanced,\n   153→    RunCompleted,\n   154→    RunFailed,\n   155→    RollbackCreated,\n   156→    AmendmentQueued,\n   157→}\n   158→\n   159→/// A durable history payload record stored in `history/payloads/`.\n   160→#[derive(Debug, Clone, PartialEq, Serialize, Deserialize)]\n   161→pub struct PayloadRecord {\n   162→    pub payload_id: String,\n   163→    pub stage_id: StageId,\n   164→    pub cycle: u32,\n   165→    pub attempt: u32,\n   166→    pub created_at: DateTime<Utc>,\n   167→    pub payload: serde_json::Value,\n   168→}\n   169→\n   170→/// A durable history artifact record stored in `history/artifacts/`.\n   171→#[derive(Debug, Clone, PartialEq, Serialize, Deserialize)]\n   172→pub struct ArtifactRecord {\n   173→    pub artifact_id: String,\n   174→    pub payload_id: String,\n   175→    pub stage_id: StageId,\n   176→    pub created_at: DateTime<Utc>,\n   177→    pub content: String,\n   178→}\n   179→\n   180→/// A runtime log entry stored in `runtime/logs/`.\n   181→#[derive(Debug, Clone, PartialEq, Serialize, Deserialize)]\n   182→pub struct RuntimeLogEntry {\n   183→    pub timestamp: DateTime<Utc>,\n   184→    pub level: LogLevel,\n   185→    pub source: String,\n   186→    pub message: String,\n   187→}\n   188→\n   189→#[derive(Debug, Clone, Copy, PartialEq, Eq, Serialize, Deserialize)]\n   190→#[serde(rename_all = \"snake_case\")]\n   191→pub enum LogLevel {\n   192→    Debug,\n   193→    Info,\n   194→    Warn,\n   195→    Error,\n   196→}\n   197→\n   198→/// Rollback metadata stored in `rollback/`.\n   199→#[derive(Debug, Clone, PartialEq, Serialize, Deserialize)]\n   200→pub struct RollbackPoint {\n   201→    pub rollback_id: String,\n   202→    pub created_at: DateTime<Utc>,\n   203→    pub stage_id: StageId,\n   204→    pub cycle: u32,\n   205→    pub run_snapshot: RunSnapshot,\n   206→}\n   207→\n   208→/// Empty session store for `sessions.json`.\n   209→#[derive(Debug, Clone, PartialEq, Serialize, Deserialize)]\n   210→pub struct SessionStore {\n   211→    pub sessions: Vec<serde_json::Value>,\n   212→}\n   213→\n   214→impl SessionStore {\n   215→    pub fn empty() -> Self {\n   216→        Self {\n   217→            sessions: Vec::new(),\n   218→        }\n   219→    }\n   220→}\n   221→\n   222→/// Summary used in `project list` output.\n   223→#[derive(Debug, Clone)]\n   224→pub struct ProjectListEntry {\n   225→    pub id: ProjectId,\n   226→    pub name: String,\n   227→    pub flow: FlowPreset,\n   228→    pub status_summary: ProjectStatusSummary,\n   229→    pub created_at: DateTime<Utc>,\n   230→    pub is_active: bool,\n   231→}\n   232→\n   233→/// Detailed project view used in `project show` output.\n   234→#[derive(Debug, Clone)]\n   235→pub struct ProjectDetail {\n   236→    pub record: ProjectRecord,\n   237→    pub run_snapshot: RunSnapshot,\n   238→    pub journal_event_count: u64,\n   239→    pub rollback_count: usize,\n   240→    pub is_active: bool,\n   241→}\n   242→"}]},"parent_tool_use_id":null,"session_id":"5eb81d8b-9dcb-415b-a8cb-cb111e8f40b3","uuid":"f30d8e0c-0b62-4d5e-9490-d1f3b151a5bb","tool_use_result":{"type":"text","file":{"filePath":"/root/new-ralph-burning/ralph-burning-rewrite/src/contexts/project_run_record/model.rs","content":"use chrono::{DateTime, Utc};\nuse serde::{Deserialize, Serialize};\n\nuse crate::shared::domain::{FlowPreset, ProjectId, StageCursor, StageId};\n\n/// Immutable project metadata persisted in `project.toml`.\n#[derive(Debug, Clone, PartialEq, Serialize, Deserialize)]\npub struct ProjectRecord {\n    pub id: ProjectId,\n    pub name: String,\n    pub flow: FlowPreset,\n    pub prompt_reference: String,\n    pub prompt_hash: String,\n    pub created_at: DateTime<Utc>,\n    pub status_summary: ProjectStatusSummary,\n}\n\n#[derive(Debug, Clone, Copy, PartialEq, Eq, Serialize, Deserialize)]\n#[serde(rename_all = \"snake_case\")]\npub enum ProjectStatusSummary {\n    Created,\n    Active,\n    Completed,\n    Failed,\n}\n\n/// Canonical run state persisted in `run.json`.\n/// This is the single source of truth for run progression - never inferred from artifacts.\n#[derive(Debug, Clone, PartialEq, Serialize, Deserialize)]\npub struct RunSnapshot {\n    pub active_run: Option<ActiveRun>,\n    pub status: RunStatus,\n    pub cycle_history: Vec<CycleHistoryEntry>,\n    pub completion_rounds: u32,\n    pub rollback_point_meta: RollbackPointMeta,\n    pub amendment_queue: AmendmentQueueState,\n    pub status_summary: String,\n}\n\nimpl RunSnapshot {\n    pub fn initial() -> Self {\n        Self {\n            active_run: None,\n            status: RunStatus::NotStarted,\n            cycle_history: Vec::new(),\n            completion_rounds: 0,\n            rollback_point_meta: RollbackPointMeta::default(),\n            amendment_queue: AmendmentQueueState::default(),\n            status_summary: \"not started\".to_owned(),\n        }\n    }\n\n    pub fn has_active_run(&self) -> bool {\n        self.active_run.is_some()\n    }\n\n    /// Semantic validation of run snapshot consistency.\n    /// Returns `Err` with a description if status and active_run are inconsistent.\n    pub fn validate_semantics(&self) -> Result<(), String> {\n        match (&self.status, &self.active_run) {\n            // Running or Paused requires an active run cursor\n            (RunStatus::Running, None) => Err(\n                \"status is 'running' but active_run is null — inconsistent canonical state\"\n                    .to_owned(),\n            ),\n            (RunStatus::Paused, None) => Err(\n                \"status is 'paused' but active_run is null — inconsistent canonical state\"\n                    .to_owned(),\n            ),\n            // NotStarted must not have an active run cursor\n            (RunStatus::NotStarted, Some(_)) => Err(\n                \"status is 'not_started' but active_run is present — inconsistent canonical state\"\n                    .to_owned(),\n            ),\n            // All other combinations are valid:\n            // NotStarted + None, Running/Paused + Some, Completed/Failed + None/Some\n            _ => Ok(()),\n        }\n    }\n}\n\n#[derive(Debug, Clone, PartialEq, Serialize, Deserialize)]\npub struct ActiveRun {\n    pub run_id: String,\n    pub stage_cursor: StageCursor,\n    pub started_at: DateTime<Utc>,\n}\n\n#[derive(Debug, Clone, Copy, PartialEq, Eq, Serialize, Deserialize)]\n#[serde(rename_all = \"snake_case\")]\npub enum RunStatus {\n    NotStarted,\n    Running,\n    Paused,\n    Completed,\n    Failed,\n}\n\nimpl RunStatus {\n    /// Human-readable status string for CLI output.\n    pub fn display_str(self) -> &'static str {\n        match self {\n            Self::NotStarted => \"not started\",\n            Self::Running => \"running\",\n            Self::Paused => \"paused\",\n            Self::Completed => \"completed\",\n            Self::Failed => \"failed\",\n        }\n    }\n}\n\n/// A single entry in the cycle history tracking progression through work cycles.\n#[derive(Debug, Clone, PartialEq, Serialize, Deserialize)]\npub struct CycleHistoryEntry {\n    pub cycle: u32,\n    pub stage_id: StageId,\n    pub started_at: DateTime<Utc>,\n    pub completed_at: Option<DateTime<Utc>>,\n}\n\n/// Rollback-point metadata tracked in the canonical run snapshot.\n#[derive(Debug, Clone, Default, PartialEq, Serialize, Deserialize)]\npub struct RollbackPointMeta {\n    pub last_rollback_id: Option<String>,\n    pub rollback_count: u32,\n}\n\n/// Amendment queue state tracked in the canonical run snapshot.\n#[derive(Debug, Clone, Default, PartialEq, Serialize, Deserialize)]\npub struct AmendmentQueueState {\n    pub pending: Vec<serde_json::Value>,\n    pub processed_count: u32,\n}\n\n/// A single journal event stored in `journal.ndjson`.\n#[derive(Debug, Clone, PartialEq, Serialize, Deserialize)]\npub struct JournalEvent {\n    pub sequence: u64,\n    pub timestamp: DateTime<Utc>,\n    pub event_type: JournalEventType,\n    pub details: serde_json::Value,\n}\n\n#[derive(Debug, Clone, PartialEq, Eq, Serialize, Deserialize)]\n#[serde(rename_all = \"snake_case\")]\npub enum JournalEventType {\n    ProjectCreated,\n    RunStarted,\n    StageEntered,\n    StageCompleted,\n    CycleAdvanced,\n    CompletionRoundAdvanced,\n    RunCompleted,\n    RunFailed,\n    RollbackCreated,\n    AmendmentQueued,\n}\n\n/// A durable history payload record stored in `history/payloads/`.\n#[derive(Debug, Clone, PartialEq, Serialize, Deserialize)]\npub struct PayloadRecord {\n    pub payload_id: String,\n    pub stage_id: StageId,\n    pub cycle: u32,\n    pub attempt: u32,\n    pub created_at: DateTime<Utc>,\n    pub payload: serde_json::Value,\n}\n\n/// A durable history artifact record stored in `history/artifacts/`.\n#[derive(Debug, Clone, PartialEq, Serialize, Deserialize)]\npub struct ArtifactRecord {\n    pub artifact_id: String,\n    pub payload_id: String,\n    pub stage_id: StageId,\n    pub created_at: DateTime<Utc>,\n    pub content: String,\n}\n\n/// A runtime log entry stored in `runtime/logs/`.\n#[derive(Debug, Clone, PartialEq, Serialize, Deserialize)]\npub struct RuntimeLogEntry {\n    pub timestamp: DateTime<Utc>,\n    pub level: LogLevel,\n    pub source: String,\n    pub message: String,\n}\n\n#[derive(Debug, Clone, Copy, PartialEq, Eq, Serialize, Deserialize)]\n#[serde(rename_all = \"snake_case\")]\npub enum LogLevel {\n    Debug,\n    Info,\n    Warn,\n    Error,\n}\n\n/// Rollback metadata stored in `rollback/`.\n#[derive(Debug, Clone, PartialEq, Serialize, Deserialize)]\npub struct RollbackPoint {\n    pub rollback_id: String,\n    pub created_at: DateTime<Utc>,\n    pub stage_id: StageId,\n    pub cycle: u32,\n    pub run_snapshot: RunSnapshot,\n}\n\n/// Empty session store for `sessions.json`.\n#[derive(Debug, Clone, PartialEq, Serialize, Deserialize)]\npub struct SessionStore {\n    pub sessions: Vec<serde_json::Value>,\n}\n\nimpl SessionStore {\n    pub fn empty() -> Self {\n        Self {\n            sessions: Vec::new(),\n        }\n    }\n}\n\n/// Summary used in `project list` output.\n#[derive(Debug, Clone)]\npub struct ProjectListEntry {\n    pub id: ProjectId,\n    pub name: String,\n    pub flow: FlowPreset,\n    pub status_summary: ProjectStatusSummary,\n    pub created_at: DateTime<Utc>,\n    pub is_active: bool,\n}\n\n/// Detailed project view used in `project show` output.\n#[derive(Debug, Clone)]\npub struct ProjectDetail {\n    pub record: ProjectRecord,\n    pub run_snapshot: RunSnapshot,\n    pub journal_event_count: u64,\n    pub rollback_count: usize,\n    pub is_active: bool,\n}\n","numLines":242,"startLine":1,"totalLines":242}}}
