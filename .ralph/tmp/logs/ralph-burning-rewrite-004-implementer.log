{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0139k7iSfE8bcRktRGhPeR6k","type":"tool_result","content":"     1→use chrono::{DateTime, Utc};\n     2→use serde::{Deserialize, Serialize};\n     3→\n     4→use crate::shared::domain::{FlowPreset, ProjectId, StageCursor, StageId};\n     5→\n     6→/// Immutable project metadata persisted in `project.toml`.\n     7→#[derive(Debug, Clone, PartialEq, Serialize, Deserialize)]\n     8→pub struct ProjectRecord {\n     9→    pub id: ProjectId,\n    10→    pub name: String,\n    11→    pub flow: FlowPreset,\n    12→    pub prompt_reference: String,\n    13→    pub prompt_hash: String,\n    14→    pub created_at: DateTime<Utc>,\n    15→    pub status_summary: ProjectStatusSummary,\n    16→}\n    17→\n    18→#[derive(Debug, Clone, Copy, PartialEq, Eq, Serialize, Deserialize)]\n    19→#[serde(rename_all = \"snake_case\")]\n    20→pub enum ProjectStatusSummary {\n    21→    Created,\n    22→    Active,\n    23→    Completed,\n    24→    Failed,\n    25→}\n    26→\n    27→/// Canonical run state persisted in `run.json`.\n    28→/// This is the single source of truth for run progression - never inferred from artifacts.\n    29→#[derive(Debug, Clone, PartialEq, Serialize, Deserialize)]\n    30→pub struct RunSnapshot {\n    31→    pub active_run: Option<ActiveRun>,\n    32→    pub status: RunStatus,\n    33→    pub status_summary: String,\n    34→}\n    35→\n    36→impl RunSnapshot {\n    37→    pub fn initial() -> Self {\n    38→        Self {\n    39→            active_run: None,\n    40→            status: RunStatus::NotStarted,\n    41→            status_summary: \"not started\".to_owned(),\n    42→        }\n    43→    }\n    44→\n    45→    pub fn has_active_run(&self) -> bool {\n    46→        self.active_run.is_some()\n    47→    }\n    48→}\n    49→\n    50→#[derive(Debug, Clone, PartialEq, Serialize, Deserialize)]\n    51→pub struct ActiveRun {\n    52→    pub run_id: String,\n    53→    pub stage_cursor: StageCursor,\n    54→    pub started_at: DateTime<Utc>,\n    55→}\n    56→\n    57→#[derive(Debug, Clone, Copy, PartialEq, Eq, Serialize, Deserialize)]\n    58→#[serde(rename_all = \"snake_case\")]\n    59→pub enum RunStatus {\n    60→    NotStarted,\n    61→    Running,\n    62→    Paused,\n    63→    Completed,\n    64→    Failed,\n    65→}\n    66→\n    67→/// A single journal event stored in `journal.ndjson`.\n    68→#[derive(Debug, Clone, PartialEq, Serialize, Deserialize)]\n    69→pub struct JournalEvent {\n    70→    pub sequence: u64,\n    71→    pub timestamp: DateTime<Utc>,\n    72→    pub event_type: JournalEventType,\n    73→    pub details: serde_json::Value,\n    74→}\n    75→\n    76→#[derive(Debug, Clone, PartialEq, Eq, Serialize, Deserialize)]\n    77→#[serde(rename_all = \"snake_case\")]\n    78→pub enum JournalEventType {\n    79→    ProjectCreated,\n    80→    RunStarted,\n    81→    StageEntered,\n    82→    StageCompleted,\n    83→    CycleAdvanced,\n    84→    CompletionRoundAdvanced,\n    85→    RunCompleted,\n    86→    RunFailed,\n    87→    RollbackCreated,\n    88→    AmendmentQueued,\n    89→}\n    90→\n    91→/// A durable history payload record stored in `history/payloads/`.\n    92→#[derive(Debug, Clone, PartialEq, Serialize, Deserialize)]\n    93→pub struct PayloadRecord {\n    94→    pub payload_id: String,\n    95→    pub stage_id: StageId,\n    96→    pub cycle: u32,\n    97→    pub attempt: u32,\n    98→    pub created_at: DateTime<Utc>,\n    99→    pub payload: serde_json::Value,\n   100→}\n   101→\n   102→/// A durable history artifact record stored in `history/artifacts/`.\n   103→#[derive(Debug, Clone, PartialEq, Serialize, Deserialize)]\n   104→pub struct ArtifactRecord {\n   105→    pub artifact_id: String,\n   106→    pub payload_id: String,\n   107→    pub stage_id: StageId,\n   108→    pub created_at: DateTime<Utc>,\n   109→    pub content: String,\n   110→}\n   111→\n   112→/// A runtime log entry stored in `runtime/logs/`.\n   113→#[derive(Debug, Clone, PartialEq, Serialize, Deserialize)]\n   114→pub struct RuntimeLogEntry {\n   115→    pub timestamp: DateTime<Utc>,\n   116→    pub level: LogLevel,\n   117→    pub source: String,\n   118→    pub message: String,\n   119→}\n   120→\n   121→#[derive(Debug, Clone, Copy, PartialEq, Eq, Serialize, Deserialize)]\n   122→#[serde(rename_all = \"snake_case\")]\n   123→pub enum LogLevel {\n   124→    Debug,\n   125→    Info,\n   126→    Warn,\n   127→    Error,\n   128→}\n   129→\n   130→/// Rollback metadata stored in `rollback/`.\n   131→#[derive(Debug, Clone, PartialEq, Serialize, Deserialize)]\n   132→pub struct RollbackPoint {\n   133→    pub rollback_id: String,\n   134→    pub created_at: DateTime<Utc>,\n   135→    pub stage_id: StageId,\n   136→    pub cycle: u32,\n   137→    pub run_snapshot: RunSnapshot,\n   138→}\n   139→\n   140→/// Empty session store for `sessions.json`.\n   141→#[derive(Debug, Clone, PartialEq, Serialize, Deserialize)]\n   142→pub struct SessionStore {\n   143→    pub sessions: Vec<serde_json::Value>,\n   144→}\n   145→\n   146→impl SessionStore {\n   147→    pub fn empty() -> Self {\n   148→        Self {\n   149→            sessions: Vec::new(),\n   150→        }\n   151→    }\n   152→}\n   153→\n   154→/// Summary used in `project list` output.\n   155→#[derive(Debug, Clone)]\n   156→pub struct ProjectListEntry {\n   157→    pub id: ProjectId,\n   158→    pub name: String,\n   159→    pub flow: FlowPreset,\n   160→    pub status_summary: ProjectStatusSummary,\n   161→    pub created_at: DateTime<Utc>,\n   162→    pub is_active: bool,\n   163→}\n   164→\n   165→/// Detailed project view used in `project show` output.\n   166→#[derive(Debug, Clone)]\n   167→pub struct ProjectDetail {\n   168→    pub record: ProjectRecord,\n   169→    pub run_snapshot: RunSnapshot,\n   170→    pub journal_event_count: u64,\n   171→    pub rollback_count: usize,\n   172→    pub is_active: bool,\n   173→}\n   174→"}]},"pa