{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01RH6NPEcG5Rn5Aui1HHgKQa","type":"tool_result","content":"     1→use std::path::PathBuf;\n     2→\n     3→use chrono::Utc;\n     4→use clap::{Args, Subcommand};\n     5→\n     6→use crate::adapters::fs::{\n     7→    FsActiveProjectStore, FsJournalStore, FsProjectStore, FsRunSnapshotStore, FileSystem,\n     8→};\n     9→use crate::contexts::project_run_record::model::ProjectStatusSummary;\n    10→use crate::contexts::project_run_record::service::{self, CreateProjectInput};\n    11→use crate::contexts::workspace_governance;\n    12→use crate::shared::domain::{FlowPreset, ProjectId};\n    13→use crate::shared::error::{AppError, AppResult};\n    14→\n    15→#[derive(Debug, Args)]\n    16→pub struct ProjectCommand {\n    17→    #[command(subcommand)]\n    18→    pub command: ProjectSubcommand,\n    19→}\n    20→\n    21→#[derive(Debug, Subcommand)]\n    22→pub enum ProjectSubcommand {\n    23→    Create(ProjectCreateArgs),\n    24→    Select { id: String },\n    25→    List,\n    26→    Show { id: Option<String> },\n    27→    Delete { id: String },\n    28→}\n    29→\n    30→#[derive(Debug, Args)]\n    31→pub struct ProjectCreateArgs {\n    32→    #[arg(long)]\n    33→    pub id: String,\n    34→    #[arg(long)]\n    35→    pub name: String,\n    36→    #[arg(long)]\n    37→    pub prompt: PathBuf,\n    38→    #[arg(long)]\n    39→    pub flow: String,\n    40→}\n    41→\n    42→pub async fn handle(command: ProjectCommand) -> AppResult<()> {\n    43→    match command.command {\n    44→        ProjectSubcommand::Select { id } => {\n    45→            let current_dir = std::env::current_dir()?;\n    46→            let project_id = ProjectId::new(id)?;\n    47→            workspace_governance::set_active_project(&current_dir, &project_id)?;\n    48→            println!(\"Selected project {}\", project_id);\n    49→            Ok(())\n    50→        }\n    51→        ProjectSubcommand::Create(args) => handle_create(args).await,\n    52→        ProjectSubcommand::List => handle_list().await,\n    53→        ProjectSubcommand::Show { id } => handle_show(id).await,\n    54→        ProjectSubcommand::Delete { id } => handle_delete(id).await,\n    55→    }\n    56→}\n    57→\n    58→async fn handle_create(args: ProjectCreateArgs) -> AppResult<()> {\n    59→    let current_dir = std::env::current_dir()?;\n    60→\n    61→    // Validate workspace version\n    62→    let config = workspace_governance::load_workspace_config(&current_dir)?;\n    63→    workspace_governance::ensure_supported_workspace_version(&config)?;\n    64→\n    65→    // Validate project ID\n    66→    let project_id = ProjectId::new(args.id)?;\n    67→\n    68→    // Validate flow preset\n    69→    let flow: FlowPreset = args.flow.parse()?;\n    70→\n    71→    // Validate prompt file is readable\n    72→    let prompt_path = if args.prompt.is_absolute() {\n    73→        args.prompt.clone()\n    74→    } else {\n    75→        current_dir.join(&args.prompt)\n    76→    };\n    77→\n    78→    let prompt_contents = std::fs::read_to_string(&prompt_path).map_err(|e| {\n    79→        AppError::InvalidPrompt {\n    80→            path: args.prompt.display().to_string(),\n    81→            reason: e.to_string(),\n    82→        }\n    83→    })?;\n    84→\n    85→    if prompt_contents.trim().is_empty() {\n    86→        return Err(AppError::InvalidPrompt {\n    87→            path: args.prompt.display().to_string(),\n    88→            reason: \"prompt file is empty\".to_owned(),\n    89→        });\n    90→    }\n    91→\n    92→    let prompt_hash = FileSystem::prompt_hash(&prompt_contents);\n    93→\n    94→    let store = FsProjectStore;\n    95→    let journal_store = FsJournalStore;\n    96→\n    97→    let input = CreateProjectInput {\n    98→        id: project_id,\n    99→        name: args.name,\n   100→        flow,\n   101→        prompt_path: args.prompt.display().to_string(),\n   102→        prompt_contents,\n   103→        prompt_hash,\n   104→        created_at: Utc::now(),\n   105→    };\n   106→\n   107→    let record = service::create_project(&store, &journal_store, &current_dir, input)?;\n   108→\n   109→    println!(\n   110→        \"Created project '{}' with flow '{}'\",\n   111→        record.id, record.flow\n   112→    );\n   113→    Ok(())\n   114→}\n   115→\n   116→async fn handle_list() -> AppResult<()> {\n   117→    let current_dir = std::env::current_dir()?;\n   118→\n   119→    // Validate workspace\n   120→    let config = workspace_governance::load_workspace_config(&current_dir)?;\n   121→    workspace_governance::ensure_supported_workspace_version(&config)?;\n   122→\n   123→    let store = FsProjectStore;\n   124→    let active_store = FsActiveProjectStore;\n   125→\n   126→    let entries = service::list_projects(&store, &active_store, &current_dir)?;\n   127→\n   128→    if entries.is_empty() {\n   129→        println!(\"No projects found.\");\n   130→        return Ok(());\n   131→    }\n   132→\n   133→    for entry in &entries {\n   134→        let active_marker = if entry.is_active { \" *\" } else { \"\" };\n   135→        let status = match entry.status_summary {\n   136→            ProjectStatusSummary::Created => \"created\",\n   137→            ProjectStatusSummary::Active => \"active\",\n   138→            ProjectStatusSummary::Completed => \"completed\",\n   139→            ProjectStatusSummary::Failed => \"failed\",\n   140→        };\n   141→        println!(\n   142→            \"  {}{} ({}) [{}] - {}\",\n   143→            entry.id, active_marker, entry.flow, status, entry.name\n   144→        );\n   145→    }\n   146→\n   147→    Ok(())\n   148→}\n   149→\n   150→async fn handle_show(id: Option<String>) -> AppResult<()> {\n   151→    let current_dir = std::env::current_dir()?;\n   152→\n   153→    // Validate workspace\n   154→    let config = workspace_governance::load_workspace_config(&current_dir)?;\n   155→    workspace_governance::ensure_supported_workspace_version(&config)?;\n   156→\n   157→    // Resolve project ID: explicit or active project\n   158→    let project_id = match id {\n   159→        Some(raw) => ProjectId::new(raw)?,\n   160→        None => workspace_governance::resolve_active_project(&current_dir)?,\n   161→    };\n   162→\n   163→    let store = FsProjectStore;\n   164→    let run_store = FsRunSnapshotStore;\n   165→    let journal_store = FsJournalStore;\n   166→    let active_store = FsActiveProjectStore;\n   167→\n   168→    let detail = service::show_project(\n   169→        &store,\n   170→        &run_store,\n   171→        &journal_store,\n   172→        &active_store,\n   173→        &current_dir,\n   174→        &project_id,\n   175→    )?;\n   176→\n   177→    let active_label = if detail.is_active { \" (active)\" } else { \"\" };\n   178→    println!(\"Project: {}{}\", detail.record.id, active_label);\n   179→    println!(\"Name: {}\", detail.record.name);\n   180→    println!(\"Flow: {}\", detail.record.flow);\n   181→    println!(\"Prompt reference: {}\", detail.record.prompt_reference);\n   182→    println!(\"Prompt hash: {}\", detail.record.prompt_hash);\n   183→    println!(\"Created: {}\", detail.record.created_at);\n   184→    println!(\"Run status: {}\", detail.run_snapshot.status_summary);\n   185→    println!(\"Journal events: {}\", detail.journal_event_count);\n   186→    println!(\"Rollback points: {}\", detail.rollback_count);\n   187→\n   188→    Ok(())\n   189→}\n   190→\n   191→async fn handle_delete(id: String) -> AppResult<()> {\n   192→    let current_dir = std::env::current_dir()?;\n   193→\n   194→    // Validate workspace\n   195→    let config = workspace_governance::load_workspace_config(&current_dir)?;\n   196→    workspace_governance::ensure_supported_workspace_version(&config)?;\n   197→\n   198→    let project_id = ProjectId::new(id)?;\n   199→\n   200→    let store = FsProjectStore;\n   201→    let run_store = FsRunSnapshotStore;\n   202→    let active_store = FsActiveProjectStore;\n   203→\n   204→    service::delete_project(\n   205→        &store,\n   206→        &run_store,\n   207→        &active_store,\n   208→        &current_dir,\n   209→        &project_id,\n   210→    )?;\n   211→\n   212→    println!(\"Deleted project '{}'\", project_id);\n   213→    Ok(())\n   214→}\n   215→"}]},"parent_tool_use_id":null,"session_id":"5eb81d8b-9dcb-415b-a8cb-cb111e8f40b3","uuid":"d9736ce5-ed1b-4262-91f4-6d50b56a8a95","tool_use_result":{"type":"text","file":{"filePath":"/root/new-ralph-burning/ralph-burning-rewrite/src/cli/project.rs","content":"use std::path::PathBuf;\n\nuse chrono::Utc;\nuse clap::{Args, Subcommand};\n\nuse crate::adapters::fs::{\n    FsActiveProjectStore, FsJournalStore, FsProjectStore, FsRunSnapshotStore, FileSystem,\n};\nuse crate::contexts::project_run_record::model::ProjectStatusSummary;\nuse crate::contexts::project_run_record::service::{self, CreateProjectInput};\nuse crate::contexts::workspace_governance;\nuse crate::shared::domain::{FlowPreset, ProjectId};\nuse crate::shared::error::{AppError, AppResult};\n\n#[derive(Debug, Args)]\npub struct ProjectCommand {\n    #[command(subcommand)]\n    pub command: ProjectSubcommand,\n}\n\n#[derive(Debug, Subcommand)]\npub enum ProjectSubcommand {\n    Create(ProjectCreateArgs),\n    Select { id: String },\n    List,\n    Show { id: Option<String> },\n    Delete { id: String },\n}\n\n#[derive(Debug, Args)]\npub struct ProjectCreateArgs {\n    #[arg(long)]\n    pub id: String,\n    #[arg(long)]\n    pub name: String,\n    #[arg(long)]\n    pub prompt: PathBuf,\n    #[arg(long)]\n    pub flow: String,\n}\n\npub async fn handle(command: ProjectCommand) -> AppResult<()> {\n    match command.command {\n        ProjectSubcommand::Select { id } => {\n            let current_dir = std::env::current_dir()?;\n            let project_id = ProjectId::new(id)?;\n            workspace_governance::set_active_project(&current_dir, &project_id)?;\n            println!(\"Selected project {}\", project_id);\n            Ok(())\n        }\n        ProjectSubcommand::Create(args) => handle_create(args).await,\n        ProjectSubcommand::List => handle_list().await,\n        ProjectSubcommand::Show { id } => handle_show(id).await,\n        ProjectSubcommand::Delete { id } => handle_delete(id).await,\n    }\n}\n\nasync fn handle_create(args: ProjectCreateArgs) -> AppResult<()> {\n    let current_dir = std::env::current_dir()?;\n\n    // Validate workspace version\n    let config = workspace_governance::load_workspace_config(&current_dir)?;\n    workspace_governance::ensure_supported_workspace_version(&config)?;\n\n    // Validate project ID\n    let project_id = ProjectId::new(args.id)?;\n\n    // Validate flow preset\n    let flow: FlowPreset = args.flow.parse()?;\n\n    // Validate prompt file is readable\n    let prompt_path = if args.prompt.is_absolute() {\n        args.prompt.clone()\n    } else {\n        current_dir.join(&args.prompt)\n    };\n\n    let prompt_contents = std::fs::read_to_string(&prompt_path).map_err(|e| {\n        AppError::InvalidPrompt {\n            path: args.prompt.display().to_string(),\n            reason: e.to_string(),\n        }\n    })?;\n\n    if prompt_contents.trim().is_empty() {\n        return Err(AppError::InvalidPrompt {\n            path: args.prompt.display().to_string(),\n            reason: \"prompt file is empty\".to_owned(),\n        });\n    }\n\n    let prompt_hash = FileSystem::prompt_hash(&prompt_contents);\n\n    let store = FsProjectStore;\n    let journal_store = FsJournalStore;\n\n    let input = CreateProjectInput {\n        id: project_id,\n        name: args.name,\n        flow,\n        prompt_path: args.prompt.display().to_string(),\n        prompt_contents,\n        prompt_hash,\n        created_at: Utc::now(),\n    };\n\n    let record = service::create_project(&store, &journal_store, &current_dir, input)?;\n\n    println!(\n        \"Created project '{}' with flow '{}'\",\n        record.id, record.flow\n    );\n    Ok(())\n}\n\nasync fn handle_list() -> AppResult<()> {\n    let current_dir = std::env::current_dir()?;\n\n    // Validate workspace\n    let config = workspace_governance::load_workspace_config(&current_dir)?;\n    workspace_governance::ensure_supported_workspace_version(&config)?;\n\n    let store = FsProjectStore;\n    let active_store = FsActiveProjectStore;\n\n    let entries = service::list_projects(&store, &active_store, &current_dir)?;\n\n    if entries.is_empty() {\n        println!(\"No projects found.\");\n        return Ok(());\n    }\n\n    for entry in &entries {\n        let active_marker = if entry.is_active { \" *\" } else { \"\" };\n        let status = match entry.status_summary {\n            ProjectStatusSummary::Created => \"created\",\n            ProjectStatusSummary::Active => \"active\",\n            ProjectStatusSummary::Completed => \"completed\",\n            ProjectStatusSummary::Failed => \"failed\",\n        };\n        println!(\n            \"  {}{} ({}) [{}] - {}\",\n            entry.id, active_marker, entry.flow, status, entry.name\n        );\n    }\n\n    Ok(())\n}\n\nasync fn handle_show(id: Option<String>) -> AppResult<()> {\n    let current_dir = std::env::current_dir()?;\n\n    // Validate workspace\n    let config = workspace_governance::load_workspace_config(&current_dir)?;\n    workspace_governance::ensure_supported_workspace_version(&config)?;\n\n    // Resolve project ID: explicit or active project\n    let project_id = match id {\n        Some(raw) => ProjectId::new(raw)?,\n        None => workspace_governance::resolve_active_project(&current_dir)?,\n    };\n\n    let store = FsProjectStore;\n    let run_store = FsRunSnapshotStore;\n    let journal_store = FsJournalStore;\n    let active_store = FsActiveProjectStore;\n\n    let detail = service::show_project(\n        &store,\n        &run_store,\n        &journal_store,\n        &active_store,\n        &current_dir,\n        &project_id,\n    )?;\n\n    let active_label = if detail.is_active { \" (active)\" } else { \"\" };\n    println!(\"Project: {}{}\", detail.record.id, active_label);\n    println!(\"Name: {}\", detail.record.name);\n    println!(\"Flow: {}\", detail.record.flow);\n    println!(\"Prompt reference: {}\", detail.record.prompt_reference);\n    println!(\"Prompt hash: {}\", detail.record.prompt_hash);\n    println!(\"Created: {}\", detail.record.created_at);\n    println!(\"Run status: {}\", detail.run_snapshot.status_summary);\n    println!(\"Journal events: {}\", detail.journal_event_count);\n    println!(\"Rollback points: {}\", detail.rollback_count);\n\n    Ok(())\n}\n\nasync fn handle_delete(id: String) -> AppResult<()> {\n    let current_dir = std::env::current_dir()?;\n\n    // Validate workspace\n    let config = workspace_governance::load_workspace_config(&current_dir)?;\n    workspace_governance::ensure_supported_workspace_version(&config)?;\n\n    let project_id = ProjectId::new(id)?;\n\n    let store = FsProjectStore;\n    let run_store = FsRunSnapshotStore;\n    let active_store = FsActiveProjectStore;\n\n    service::delete_project(\n        &store,\n        &run_store,\n        &active_store,\n        &current_dir,\n        &project_id,\n    )?;\n\n    println!(\"Deleted project '{}'\", project_id);\n    Ok(())\n}\n","numLines":215,"startLine":1,"totalLines":215}}}
