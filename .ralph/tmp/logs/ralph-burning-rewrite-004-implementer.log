{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01FW4qk1XrN6Qkjy5xnoPaQd","type":"tool_result","content":"     1→pub mod contracts;\n     2→pub mod payloads;\n     3→pub mod renderers;\n     4→\n     5→use crate::shared::domain::{FlowPreset, StageId};\n     6→use crate::shared::error::AppResult;\n     7→\n     8→#[derive(Debug, Clone, Copy, PartialEq, Eq)]\n     9→pub struct ValidationProfile {\n    10→    pub name: &'static str,\n    11→    pub summary: &'static str,\n    12→    pub final_review_enabled: bool,\n    13→}\n    14→\n    15→#[derive(Debug, Clone, Copy, PartialEq, Eq)]\n    16→pub struct FlowDefinition {\n    17→    pub preset: FlowPreset,\n    18→    pub description: &'static str,\n    19→    pub stages: &'static [StageId],\n    20→    pub validation_profile: ValidationProfile,\n    21→}\n    22→\n    23→const STANDARD_STAGES: [StageId; 8] = [\n    24→    StageId::PromptReview,\n    25→    StageId::Planning,\n    26→    StageId::Implementation,\n    27→    StageId::Qa,\n    28→    StageId::Review,\n    29→    StageId::CompletionPanel,\n    30→    StageId::AcceptanceQa,\n    31→    StageId::FinalReview,\n    32→];\n    33→\n    34→const QUICK_DEV_STAGES: [StageId; 4] = [\n    35→    StageId::PlanAndImplement,\n    36→    StageId::Review,\n    37→    StageId::ApplyFixes,\n    38→    StageId::FinalReview,\n    39→];\n    40→\n    41→const DOCS_CHANGE_STAGES: [StageId; 4] = [\n    42→    StageId::DocsPlan,\n    43→    StageId::DocsUpdate,\n    44→    StageId::DocsValidation,\n    45→    StageId::Review,\n    46→];\n    47→\n    48→const CI_IMPROVEMENT_STAGES: [StageId; 4] = [\n    49→    StageId::CiPlan,\n    50→    StageId::CiUpdate,\n    51→    StageId::CiValidation,\n    52→    StageId::Review,\n    53→];\n    54→\n    55→const FLOW_DEFINITIONS: [FlowDefinition; 4] = [\n    56→    FlowDefinition {\n    57→        preset: FlowPreset::Standard,\n    58→        description:\n    59→            \"Full delivery flow with planning, implementation, QA, review, and acceptance.\",\n    60→        stages: &STANDARD_STAGES,\n    61→        validation_profile: ValidationProfile {\n    62→            name: \"standard-default\",\n    63→            summary: \"Full validation suite with completion and acceptance checks.\",\n    64→            final_review_enabled: true,\n    65→        },\n    66→    },\n    67→    FlowDefinition {\n    68→        preset: FlowPreset::QuickDev,\n    69→        description: \"Fast delivery flow for small code changes with lightweight review.\",\n    70→        stages: &QUICK_DEV_STAGES,\n    71→        validation_profile: ValidationProfile {\n    72→            name: \"quick-dev-default\",\n    73→            summary: \"Lightweight panel with final review enabled by default.\",\n    74→            final_review_enabled: true,\n    75→        },\n    76→    },\n    77→    FlowDefinition {\n    78→        preset: FlowPreset::DocsChange,\n    79→        description: \"Documentation-focused flow for planning, content updates, and validation.\",\n    80→        stages: &DOCS_CHANGE_STAGES,\n    81→        validation_profile: ValidationProfile {\n    82→            name: \"docs-default\",\n    83→            summary: \"Documentation validation with final review disabled by default.\",\n    84→            final_review_enabled: false,\n    85→        },\n    86→    },\n    87→    FlowDefinition {\n    88→        preset: FlowPreset::CiImprovement,\n    89→        description: \"CI improvement flow for automation planning, updates, and validation.\",\n    90→        stages: &CI_IMPROVEMENT_STAGES,\n    91→        validation_profile: ValidationProfile {\n    92→            name: \"ci-default\",\n    93→            summary: \"Automation validation with final review disabled by default.\",\n    94→            final_review_enabled: false,\n    95→        },\n    96→    },\n    97→];\n    98→\n    99→pub fn built_in_flows() -> &'static [FlowDefinition] {\n   100→    &FLOW_DEFINITIONS\n   101→}\n   102→\n   103→pub fn flow_definition(preset: FlowPreset) -> &'static FlowDefinition {\n   104→    match preset {\n   105→        FlowPreset::Standard => &FLOW_DEFINITIONS[0],\n   106→        FlowPreset::QuickDev => &FLOW_DEFINITIONS[1],\n   107→        FlowPreset::DocsChange => &FLOW_DEFINITIONS[2],\n   108→        FlowPreset::CiImprovement => &FLOW_DEFINITIONS[3],\n   109→    }\n   110→}\n   111→\n   112→pub fn flow_definition_by_id(flow_id: &str) -> AppResult<&'static FlowDefinition> {\n   113→    let preset = flow_id.parse::<FlowPreset>()?;\n   114→    Ok(flow_definition(preset))\n   115→}\n   116→"}]},"parent_tool_use_id":"toolu_012QdgmdBxgtkt4tovj3QwR9","session_id":"84e4772c-0822-4fc6-b1d7-1c1f7c7f3e3a","uuid":"125cc7b9-b22d-4395-855a-9420fc21cb6f"}
