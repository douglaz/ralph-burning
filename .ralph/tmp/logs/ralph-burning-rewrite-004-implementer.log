45→        .expect(\"valid timestamp\");\n    46→    let mut config = WorkspaceConfig::new(created_at);\n    47→    config.settings = WorkspaceSettings {\n    48→        prompt_review: PromptReviewSettings {\n    49→            enabled: Some(false),\n    50→            extra: toml::map::Map::new(),\n    51→        },\n    52→        default_flow: Some(FlowPreset::QuickDev),\n    53→        default_backend: Some(\"claude\".to_owned()),\n    54→        default_model: Some(\"opus\".to_owned()),\n    55→        extra: toml::map::Map::new(),\n    56→    };\n    57→    FileSystem::write_atomic(\n    58→        &workspace_config_path,\n    59→        &toml::to_string_pretty(&config).expect(\"serialize config\"),\n    60→    )\n    61→    .expect(\"write config\");\n    62→\n    63→    let effective = EffectiveConfig::load(temp_dir.path()).expect(\"load effective config\");\n    64→\n    65→    assert!(!effective.prompt_review_enabled());\n    66→    assert_eq!(FlowPreset::QuickDev, effective.default_flow());\n    67→    assert_eq!(Some(\"claude\"), effective.default_backend());\n    68→    assert_eq!(Some(\"opus\"), effective.default_model());\n    69→    assert!(matches!(\n    70→        effective\n    71→            .get(\"default_model\")\n    72→            .expect(\"default model\")\n    73→            .source,\n    74→        ralph_burning::contexts::workspace_governance::ConfigValueSource::WorkspaceToml\n    75→    ));\n    76→}\n    77→\n    78→#[test]\n    79→fn workspace_config_round_trips_extended_settings() {\n    80→    let created_at = chrono::Utc\n    81→        .with_ymd_and_hms(2026, 3, 11, 17, 50, 55)\n    82→        .single()\n    83→        .expect(\"valid timestamp\");\n    84→    let mut config = WorkspaceConfig::new(created_at);\n    85→    config.settings = WorkspaceSettings {\n    86→        prompt_review: PromptReviewSettings {\n    87→            enabled: Some(false),\n    88→            extra: toml::map::Map::new(),\n    89→        },\n    90→        default_flow: Some(FlowPreset::DocsChange),\n    91→        default_backend: Some(\"openrouter\".to_owned()),\n    92→        default_model: Some(\"gpt-5\".to_owned()),\n    93→        extra: toml::map::Map::new(),\n    94→    };\n    95→\n    96→    let serialized = toml::to_string_pretty(&config).expect(\"serialize config\");\n    97→    let parsed: WorkspaceConfig = toml::from_str(&serialized).expect(\"deserialize config\");\n    98→\n    99→    assert_eq!(config, parsed);\n   100→}"}]},"parent_tool_use_id":"toolu_012QdgmdBxgtkt4tovj3QwR9","session_id":"84e4772c-0822-4fc6-b1d7-1c1f7c7f3e3a","uuid":"ac00320a-e042-460a-8610-6d6d67dc1786"}
