{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01DQAfRpeCiiQFQRXDN4W7H9","type":"tool_result","content":"     1→use chrono::TimeZone;\n     2→use ralph_burning::contexts::workspace_governance::{\n     3→    initialize_workspace, load_workspace_config, REQUIRED_WORKSPACE_DIRECTORIES, WORKSPACE_DIR,\n     4→};\n     5→use ralph_burning::shared::domain::{WorkspaceConfig, CURRENT_WORKSPACE_VERSION};\n     6→use std::path::{Path, PathBuf};\n     7→use tempfile::tempdir;\n     8→\n     9→#[test]\n    10→fn workspace_config_serialization_round_trip() {\n    11→    let created_at = chrono::Utc\n    12→        .with_ymd_and_hms(2026, 3, 11, 17, 50, 55)\n    13→        .single()\n    14→        .expect(\"valid timestamp\");\n    15→    let config = WorkspaceConfig::new(created_at);\n    16→\n    17→    let serialized = toml::to_string_pretty(&config).expect(\"serialize config\");\n    18→    let parsed: WorkspaceConfig = toml::from_str(&serialized).expect(\"deserialize config\");\n    19→\n    20→    assert_eq!(config, parsed);\n    21→    assert_eq!(CURRENT_WORKSPACE_VERSION, parsed.version);\n    22→}\n    23→\n    24→#[test]\n    25→fn initialize_workspace_creates_required_directory_structure_and_config() {\n    26→    let temp_dir = tempdir().expect(\"create temp dir\");\n    27→    let created_at = chrono::Utc\n    28→        .with_ymd_and_hms(2026, 3, 11, 17, 50, 55)\n    29→        .single()\n    30→        .expect(\"valid timestamp\");\n    31→\n    32→    let result = initialize_workspace(temp_dir.path(), created_at).expect(\"initialize workspace\");\n    33→\n    34→    assert_eq!(temp_dir.path().join(WORKSPACE_DIR), result.workspace_root);\n    35→    for required_directory in REQUIRED_WORKSPACE_DIRECTORIES {\n    36→        assert!(result.workspace_root.join(required_directory).is_dir());\n    37→    }\n    38→\n    39→    let config = load_workspace_config(temp_dir.path()).expect(\"load workspace config\");\n    40→    assert_eq!(created_at, config.created_at);\n    41→    assert_eq!(CURRENT_WORKSPACE_VERSION, config.version);\n    42→}\n    43→\n    44→#[test]\n    45→fn initialize_workspace_fails_when_workspace_already_exists() {\n    46→    let temp_dir = tempdir().expect(\"create temp dir\");\n    47→    let created_at = chrono::Utc\n    48→        .with_ymd_and_hms(2026, 3, 11, 17, 50, 55)\n    49→        .single()\n    50→        .expect(\"valid timestamp\");\n    51→\n    52→    initialize_workspace(temp_dir.path(), created_at).expect(\"initial initialization succeeds\");\n    53→    let second_attempt = initialize_workspace(temp_dir.path(), created_at);\n    54→\n    55→    assert!(second_attempt.is_err());\n    56→}\n    57→\n    58→pub(crate) fn initialize_workspace_fixture(base_dir: &Path) -> PathBuf {\n    59→    let created_at = chrono::Utc\n    60→        .with_ymd_and_hms(2026, 3, 11, 17, 50, 55)\n    61→        .single()\n    62→        .expect(\"valid timestamp\");\n    63→    initialize_workspace(base_dir, created_at)\n    64→        .expect(\"initialize workspace\")\n    65→        .workspace_root\n    66→}\n    67→"}]},"parent_tool_use_id":"toolu_012QdgmdBxgtkt4tovj3QwR9","session_id":"84e4772c-0822-4fc6-b1d7-1c1f7c7f3e3a","uuid":"f6d2f013-1f9f-4572-ac04-15c8aecde82e"}
