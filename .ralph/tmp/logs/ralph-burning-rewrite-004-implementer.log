{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Gi8QEhLkgVGfj4UDq2eQEk","type":"tool_result","content":"     1→use chrono::TimeZone;\n     2→use ralph_burning::contexts::workspace_governance::{\n     3→    initialize_workspace, load_workspace_config, REQUIRED_WORKSPACE_DIRECTORIES, WORKSPACE_DIR,\n     4→};\n     5→use ralph_burning::shared::domain::{WorkspaceConfig, CURRENT_WORKSPACE_VERSION};\n     6→use std::path::{Path, PathBuf};\n     7→use tempfile::tempdir;\n     8→\n     9→#[test]\n    10→fn workspace_config_serialization_round_trip() {\n    11→    let created_at = chrono::Utc\n    12→        .with_ymd_and_hms(2026, 3, 11, 17, 50, 55)\n    13→        .single()\n    14→        .expect(\"valid timestamp\");\n    15→    let config = WorkspaceConfig::new(created_at);\n    16→\n    17→    let serialized = toml::to_string_pretty(&config).expect(\"serialize config\");\n    18→    let parsed: WorkspaceConfig = toml::from_str(&serialized).expect(\"deserialize config\");\n    19→\n    20→    assert_eq!(config, parsed);\n    21→    assert_eq!(CURRENT_WORKSPACE_VERSION, parsed.version);\n    22→}\n    23→\n    24→#[test]\n    25→fn initialize_workspace_creates_required_directory_structure_and_config() {\n    26→    let temp_dir = tempdir().expect(\"create temp dir\");\n    27→    let created_at = chrono::Utc\n    28→        .with_ymd_and_hms(2026, 3, 11, 17, 50, 55)\n    29→        .single()\n    30→        .expect(\"valid timestamp\");\n    31→\n    32→    let result = initialize_workspace(temp_dir.path(), created_at).expect(\"initialize workspace\");\n    33→\n    34→    assert_eq!(temp_dir.path().join(WORKSPACE_DIR), result.workspace_root);\n    35→    for required_directory in REQUIRED_WORKSPACE_DIRECTORIES {\n    36→        assert!(result.workspace_root.join(required_directory).is_dir());\n    37→    }\n    38→\n    39→    let config = load_workspace_config(temp_dir.path()).expect(\"load workspace config\");\n    40→    assert_eq!(created_at, config.created_at);\n    41→    assert_eq!(CURRENT_WORKSPACE_VERSION, config.version);\n    42→}\n    43→\n    44→#[test]\n    45→fn initialize_workspace_fails_when_workspace_already_exists() {\n    46→    let temp_dir = tempdir().expect(\"create temp dir\");\n    47→    let created_at = chrono::Utc\n    48→        .with_ymd_and_hms(2026, 3, 11, 17, 50, 55)\n    49→        .single()\n    50→        .expect(\"valid timestamp\");\n    51→\n    52→    initialize_workspace(temp_dir.path(), created_at).expect(\"initial initialization succeeds\");\n    53→    let second_attempt = initialize_workspace(temp_dir.path(), created_at);\n    54→\n    55→    assert!(second_attempt.is_err());\n    56→}\n    57→\n    58→pub(crate) fn initialize_workspace_fixture(base_dir: &Path) -> PathBuf {\n    59→    let created_at = chrono::Utc\n    60→        .with_ymd_and_hms(2026, 3, 11, 17, 50, 55)\n    61→        .single()\n    62→        .expect(\"valid timestamp\");\n    63→    initialize_workspace(base_dir, created_at)\n    64→        .expect(\"initialize workspace\")\n    65→        .workspace_root\n    66→}\n    67→"}]},"parent_tool_use_id":null,"session_id":"84e4772c-0822-4fc6-b1d7-1c1f7c7f3e3a","uuid":"3ea39e30-8096-4b74-8273-a913900c66a1","tool_use_result":{"type":"text","file":{"filePath":"/root/new-ralph-burning/ralph-burning-rewrite/tests/unit/workspace_test.rs","content":"use chrono::TimeZone;\nuse ralph_burning::contexts::workspace_governance::{\n    initialize_workspace, load_workspace_config, REQUIRED_WORKSPACE_DIRECTORIES, WORKSPACE_DIR,\n};\nuse ralph_burning::shared::domain::{WorkspaceConfig, CURRENT_WORKSPACE_VERSION};\nuse std::path::{Path, PathBuf};\nuse tempfile::tempdir;\n\n#[test]\nfn workspace_config_serialization_round_trip() {\n    let created_at = chrono::Utc\n        .with_ymd_and_hms(2026, 3, 11, 17, 50, 55)\n        .single()\n        .expect(\"valid timestamp\");\n    let config = WorkspaceConfig::new(created_at);\n\n    let serialized = toml::to_string_pretty(&config).expect(\"serialize config\");\n    let parsed: WorkspaceConfig = toml::from_str(&serialized).expect(\"deserialize config\");\n\n    assert_eq!(config, parsed);\n    assert_eq!(CURRENT_WORKSPACE_VERSION, parsed.version);\n}\n\n#[test]\nfn initialize_workspace_creates_required_directory_structure_and_config() {\n    let temp_dir = tempdir().expect(\"create temp dir\");\n    let created_at = chrono::Utc\n        .with_ymd_and_hms(2026, 3, 11, 17, 50, 55)\n        .single()\n        .expect(\"valid timestamp\");\n\n    let result = initialize_workspace(temp_dir.path(), created_at).expect(\"initialize workspace\");\n\n    assert_eq!(temp_dir.path().join(WORKSPACE_DIR), result.workspace_root);\n    for required_directory in REQUIRED_WORKSPACE_DIRECTORIES {\n        assert!(result.workspace_root.join(required_directory).is_dir());\n    }\n\n    let config = load_workspace_config(temp_dir.path()).expect(\"load workspace config\");\n    assert_eq!(created_at, config.created_at);\n    assert_eq!(CURRENT_WORKSPACE_VERSION, config.version);\n}\n\n#[test]\nfn initialize_workspace_fails_when_workspace_already_exists() {\n    let temp_dir = tempdir().expect(\"create temp dir\");\n    let created_at = chrono::Utc\n        .with_ymd_and_hms(2026, 3, 11, 17, 50, 55)\n        .single()\n        .expect(\"valid timestamp\");\n\n    initialize_workspace(temp_dir.path(), created_at).expect(\"initial initialization succeeds\");\n    let second_attempt = initialize_workspace(temp_dir.path(), created_at);\n\n    assert!(second_attempt.is_err());\n}\n\npub(crate) fn initialize_workspace_fixture(base_dir: &Path) -> PathBuf {\n    let created_at = chrono::Utc\n        .with_ymd_and_hms(2026, 3, 11, 17, 50, 55)\n        .single()\n        .expect(\"valid timestamp\");\n    initialize_workspace(base_dir, created_at)\n        .expect(\"initialize workspace\")\n        .workspace_root\n}\n","numLines":67,"startLine":1,"totalLines":67}}}
