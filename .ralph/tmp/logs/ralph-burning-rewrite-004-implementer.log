{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01TgCLnjExFdMF9k94KTQnXC","type":"tool_result","content":"     1→pub mod active;\n     2→pub mod discovery;\n     3→pub mod summary;\n     4→\n     5→use std::fs;\n     6→use std::path::{Path, PathBuf};\n     7→\n     8→use serde::Deserialize;\n     9→use tracing::warn;\n    10→\n    11→use crate::config::GlobalConfig;\n    12→use crate::error::RalphError;\n    13→use crate::project::lifecycle::reconstruct_project_state;\n    14→use crate::Result;\n    15→\n    16→use self::summary::{summarize_project, ProjectSummary};\n    17→\n    18→#[derive(Debug, Clone)]\n    19→pub struct Workspace {\n    20→    pub root: PathBuf,\n    21→    pub config: GlobalConfig,\n    22→}\n    23→\n    24→impl Workspace {\n    25→    pub fn discover() -> Result<Self> {\n    26→        let root = discovery::discover_workspace_root(None)?;\n    27→        Self::load(root)\n    28→    }\n    29→\n    30→    /// Discover a workspace by walking up from `start` instead of ambient CWD.\n    31→    pub fn discover_from(start: &Path) -> Result<Self> {\n    32→        let root = discovery::discover_workspace_root(Some(start))?;\n    33→        Self::load(root)\n    34→    }\n    35→\n    36→    pub fn load(root: PathBuf) -> Result<Self> {\n    37→        let config_path = root.join(\"ralph.toml\");\n    38→        let config = GlobalConfig::load(&config_path)?;\n    39→\n    40→        let ws = Self { root, config };\n    41→\n    42→        // One-time migration: seed worktree-local active project from legacy\n    43→        // index.json if the local file doesn't exist yet.\n    44→        ws.migrate_active_project_from_index();\n    45→\n    46→        Ok(ws)\n    47→    }\n    48→\n    49→    /// If the worktree-local active-project file is absent and legacy\n    50→    /// `index.json` contains an `active_project` for an existing project,\n    51→    /// copy it to local storage. Errors are silently ignored.\n    52→    fn migrate_active_project_from_index(&self) {\n    53→        #[derive(Deserialize)]\n    54→        struct LegacyIndexFile {\n    55→            active_project: Option<String>,\n    56→        }\n    57→\n    58→        // Only migrate if no local active project file exists yet.\n    59→        if self.active_project_id().is_some() {\n    60→            return;\n    61→        }\n    62→        // Check if the local file itself exists (even if empty/invalid).\n    63→        let local_path = active::active_project_file_path(&self.root);\n    64→        if local_path.exists() {\n    65→            return;\n    66→        }\n    67→\n    68→        let index_path = self.root.join(\"index.json\");\n    69→        let raw = match fs::read_to_string(&index_path) {\n    70→            Ok(raw) => raw,\n    71→            Err(_) => return,\n    72→        };\n    73→        let legacy = match serde_json::from_str::<LegacyIndexFile>(&raw) {\n    74→            Ok(legacy) => legacy,\n    75→            Err(_) => return,\n    76→        };\n    77→\n    78→        if let Some(legacy_id) = legacy.active_project {\n    79→            if !self.project_exists(&legacy_id) {\n    80→                return;\n    81→            }\n    82→            if active::write_active_project(&self.root, &legacy_id).is_ok() {\n    83→                eprintln!(\n    84→                    \"migrated active project '{}' from index.json to worktree-local storage\",\n    85→                    legacy_id\n    86→                );\n    87→            }\n    88→        }\n    89→    }\n    90→\n    91→    pub fn init(root: &Path) -> Result<Self> {\n    92→        fs::create_dir_all(root.join(\"projects\"))?;\n    93→        fs::create_dir_all(root.join(\"templates\"))?;\n    94→\n    95→        let config = GlobalConfig::default();\n    96→        config.save(&root.join(\"ralph.toml\"))?;\n    97→\n    98→        Ok(Self {\n    99→            root: root.to_path_buf(),\n   100→            config,"}]},"