{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01UKejoy7LYVMnWYmCUF6BmW","type":"tool_result","content":"     1→use crate::shared::error::AppResult;\n     2→\n     3→use super::model::{\n     4→    JournalEvent, PayloadRecord, ArtifactRecord, RuntimeLogEntry, RunSnapshot,\n     5→};\n     6→\n     7→/// Read model for `run status`: canonical state only, no inference from artifacts.\n     8→#[derive(Debug, Clone)]\n     9→pub struct RunStatusView {\n    10→    pub project_id: String,\n    11→    pub status: String,\n    12→    pub stage: Option<String>,\n    13→    pub cycle: Option<u32>,\n    14→    pub completion_round: Option<u32>,\n    15→    pub summary: String,\n    16→}\n    17→\n    18→impl RunStatusView {\n    19→    pub fn from_snapshot(project_id: &str, snapshot: &RunSnapshot) -> Self {\n    20→        match &snapshot.active_run {\n    21→            Some(active) => Self {\n    22→                project_id: project_id.to_owned(),\n    23→                status: format!(\"{:?}\", snapshot.status).to_lowercase(),\n    24→                stage: Some(active.stage_cursor.stage.as_str().to_owned()),\n    25→                cycle: Some(active.stage_cursor.cycle),\n    26→                completion_round: Some(active.stage_cursor.completion_round),\n    27→                summary: snapshot.status_summary.clone(),\n    28→            },\n    29→            None => Self {\n    30→                project_id: project_id.to_owned(),\n    31→                status: \"not started\".to_owned(),\n    32→                stage: None,\n    33→                cycle: None,\n    34→                completion_round: None,\n    35→                summary: snapshot.status_summary.clone(),\n    36→            },\n    37→        }\n    38→    }\n    39→}\n    40→\n    41→/// Read model for `run history`: durable history only (journal + payloads + artifacts).\n    42→/// Runtime logs never appear here.\n    43→#[derive(Debug, Clone)]\n    44→pub struct RunHistoryView {\n    45→    pub project_id: String,\n    46→    pub events: Vec<JournalEvent>,\n    47→    pub payloads: Vec<PayloadRecord>,\n    48→    pub artifacts: Vec<ArtifactRecord>,\n    49→}\n    50→\n    51→/// Read model for `run tail`: durable history by default, with optional runtime logs.\n    52→#[derive(Debug, Clone)]\n    53→pub struct RunTailView {\n    54→    pub project_id: String,\n    55→    pub events: Vec<JournalEvent>,\n    56→    pub payloads: Vec<PayloadRecord>,\n    57→    pub artifacts: Vec<ArtifactRecord>,\n    58→    pub runtime_logs: Option<Vec<RuntimeLogEntry>>,\n    59→}\n    60→\n    61→/// Build a status view from canonical run state.\n    62→pub fn build_status_view(project_id: &str, snapshot: &RunSnapshot) -> RunStatusView {\n    63→    RunStatusView::from_snapshot(project_id, snapshot)\n    64→}\n    65→\n    66→/// Build a history view from durable records only. No runtime logs.\n    67→pub fn build_history_view(\n    68→    project_id: &str,\n    69→    events: Vec<JournalEvent>,\n    70→    payloads: Vec<PayloadRecord>,\n    71→    artifacts: Vec<ArtifactRecord>,\n    72→) -> RunHistoryView {\n    73→    RunHistoryView {\n    74→        project_id: project_id.to_owned(),\n    75→        events,\n    76→        payloads,\n    77→        artifacts,\n    78→    }\n    79→}\n    80→\n    81→/// Build a tail view: durable history always, runtime logs only when requested.\n    82→pub fn build_tail_view(\n    83→    project_id: &str,\n    84→    events: Vec<JournalEvent>,\n    85→    payloads: Vec<PayloadRecord>,\n    86→    artifacts: Vec<ArtifactRecord>,\n    87→    include_logs: bool,\n    88→    runtime_logs: Vec<RuntimeLogEntry>,\n    89→) -> RunTailView {\n    90→    RunTailView {\n    91→        project_id: project_id.to_owned(),\n    92→        events,\n    93→        payloads,\n    94→        artifacts,\n    95→        runtime_logs: if include_logs {\n    96→            Some(runtime_logs)\n    97→        } else {\n    98→            None\n    99→        },\n   100→    }\n   101→}\n   102→\n   103→/// Validate that durable history records are consistent:\n   104→/// every artifact has a matching payload and every payload has a matching artifact.\n   105→/// Payload + artifact are treated as a paired durable-history unit.\n   106→pub fn validate_history_consistency(\n   107→    payloads: &[PayloadRecord],\n   108→    artifacts: &[ArtifactRecord],\n   109→) -> AppResult<()> {\n   110→    // Check orphaned artifacts (artifact without matching payload)\n   111→    for artifact in artifacts {\n   112→        if !payloads.iter().any(|p| p.payload_id == artifact.payload_id) {\n   113→            return Err(crate::shared::error::AppError::CorruptRecord {\n   114→                file: format!(\"history/artifacts/{}\", artifact.artifact_id),\n   115→                details: format!(\n   116→                    \"artifact references payload '{}' which does not exist\",\n   117→                    artifact.payload_id\n   118→                ),\n   119→            });\n   120→        }\n   121→    }\n   122→    // Check orphaned payloads (payload without matching artifact)\n   123→    for payload in payloads {\n   124→        if !artifacts.iter().any(|a| a.payload_id == payload.payload_id) {\n   125→            return Err(crate::shared::error::AppError::CorruptRecord {\n   126→                file: format!(\"history/payloads/{}\", payload.payload_id),\n   127→                details: \"payload has no matching artifact\".to_owned(),\n   128→            });\n   129→        }\n   130→    }\n   131→    Ok(())\n   132→}\n   133→"}]},"parent_tool_use_id":null,"session_id":"1a3d9a31-afc3-4ac3-baa7-2cce587b25ae","uuid":"2eec5557-2ef5-4de5-b925-4adb84a28b93","tool_use_result":{"type":"text","file":{"filePath":"/root/new-ralph-burning/ralph-burning-rewrite/src/contexts/project_run_record/queries.rs","content":"use crate::shared::error::AppResult;\n\nuse super::model::{\n    JournalEvent, PayloadRecord, ArtifactRecord, RuntimeLogEntry, RunSnapshot,\n};\n\n/// Read model for `run status`: canonical state only, no inference from artifacts.\n#[derive(Debug, Clone)]\npub struct RunStatusView {\n    pub project_id: String,\n    pub status: String,\n    pub stage: Option<String>,\n    pub cycle: Option<u32>,\n    pub completion_round: Option<u32>,\n    pub summary: String,\n}\n\nimpl RunStatusView {\n    pub fn from_snapshot(project_id: &str, snapshot: &RunSnapshot) -> Self {\n        match &snapshot.active_run {\n            Some(active) => Self {\n                project_id: project_id.to_owned(),\n                status: format!(\"{:?}\", snapshot.status).to_lowercase(),\n                stage: Some(active.stage_cursor.stage.as_str().to_owned()),\n                cycle: Some(active.stage_cursor.cycle),\n                completion_round: Some(active.stage_cursor.completion_round),\n                summary: snapshot.status_summary.clone(),\n            },\n            None => Self {\n                project_id: project_id.to_owned(),\n                status: \"not started\".to_owned(),\n                stage: None,\n                cycle: None,\n                completion_round: None,\n                summary: snapshot.status_summary.clone(),\n            },\n        }\n    }\n}\n\n/// Read model for `run history`: durable history only (journal + payloads + artifacts).\n/// Runtime logs never appear here.\n#[derive(Debug, Clone)]\npub struct RunHistoryView {\n    pub project_id: String,\n    pub events: Vec<JournalEvent>,\n    pub payloads: Vec<PayloadRecord>,\n    pub artifacts: Vec<ArtifactRecord>,\n}\n\n/// Read model for `run tail`: durable history by default, with optional runtime logs.\n#[derive(Debug, Clone)]\npub struct RunTailView {\n    pub project_id: String,\n    pub events: Vec<JournalEvent>,\n    pub payloads: Vec<PayloadRecord>,\n    pub artifacts: Vec<ArtifactRecord>,\n    pub runtime_logs: Option<Vec<RuntimeLogEntry>>,\n}\n\n/// Build a status view from canonical run state.\npub fn build_status_view(project_id: &str, snapshot: &RunSnapshot) -> RunStatusView {\n    RunStatusView::from_snapshot(project_id, snapshot)\n}\n\n/// Build a history view from durable records only. No runtime logs.\npub fn build_history_view(\n    project_id: &str,\n    events: Vec<JournalEvent>,\n    payloads: Vec<PayloadRecord>,\n    artifacts: Vec<ArtifactRecord>,\n) -> RunHistoryView {\n    RunHistoryView {\n        project_id: project_id.to_owned(),\n        events,\n        payloads,\n        artifacts,\n    }\n}\n\n/// Build a tail view: durable history always, runtime logs only when requested.\npub fn build_tail_view(\n    project_id: &str,\n    events: Vec<JournalEvent>,\n    payloads: Vec<PayloadRecord>,\n    artifacts: Vec<ArtifactRecord>,\n    include_logs: bool,\n    runtime_logs: Vec<RuntimeLogEntry>,\n) -> RunTailView {\n    RunTailView {\n        project_id: project_id.to_owned(),\n        events,\n        payloads,\n        artifacts,\n        runtime_logs: if include_logs {\n            Some(runtime_logs)\n        } else {\n            None\n        },\n    }\n}\n\n/// Validate that durable history records are consistent:\n/// every artifact has a matching payload and every payload has a matching artifact.\n/// Payload + artifact are treated as a paired durable-history unit.\npub fn validate_history_consistency(\n    payloads: &[PayloadRecord],\n    artifacts: &[ArtifactRecord],\n) -> AppResult<()> {\n    // Check orphaned artifacts (artifact without matching payload)\n    for artifact in artifacts {\n        if !payloads.iter().any(|p| p.payload_id == artifact.payload_id) {\n            return Err(crate::shared::error::AppError::CorruptRecord {\n                file: format!(\"history/artifacts/{}\", artifact.artifact_id),\n                details: format!(\n                    \"artifact references payload '{}' which does not exist\",\n                    artifact.payload_id\n                ),\n            });\n        }\n    }\n    // Check orphaned payloads (payload without matching artifact)\n    for payload in payloads {\n        if !artifacts.iter().any(|a| a.payload_id == payload.payload_id) {\n            return Err(crate::shared::error::AppError::CorruptRecord {\n                file: format!(\"history/payloads/{}\", payload.payload_id),\n                details: \"payload has no matching artifact\".to_owned(),\n            });\n        }\n    }\n    Ok(())\n}\n","numLines":133,"startLine":1,"totalLines":133}}}
