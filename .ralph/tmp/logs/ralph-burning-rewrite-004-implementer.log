{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01DFnkwbHgXTMiRCTrPPD8uq","type":"tool_result","content":"     1→use std::fs;\n     2→use std::os::unix::fs::PermissionsExt;\n     3→use std::process::Command;\n     4→\n     5→use tempfile::tempdir;\n     6→\n     7→fn binary() -> &'static str {\n     8→    env!(\"CARGO_BIN_EXE_ralph-burning\")\n     9→}\n    10→\n    11→fn initialize_workspace_fixture() -> tempfile::TempDir {\n    12→    let temp_dir = tempdir().expect(\"create temp dir\");\n    13→    let output = Command::new(binary())\n    14→        .arg(\"init\")\n    15→        .current_dir(temp_dir.path())\n    16→        .output()\n    17→        .expect(\"run init\");\n    18→    assert!(output.status.success());\n    19→    temp_dir\n    20→}\n    21→\n    22→fn create_project_fixture(base_dir: &std::path::Path, project_id: &str) {\n    23→    let project_root = base_dir.join(\".ralph-burning/projects\").join(project_id);\n    24→    fs::create_dir_all(&project_root).expect(\"create project directory\");\n    25→    fs::write(project_root.join(\"project.toml\"), \"id = \\\"fixture\\\"\\n\").expect(\"write project\");\n    26→}\n    27→\n    28→fn write_editor_script(\n    29→    base_dir: &std::path::Path,\n    30→    name: &str,\n    31→    contents: &str,\n    32→) -> std::path::PathBuf {\n    33→    let script_path = base_dir.join(name);\n    34→    fs::write(&script_path, contents).expect(\"write editor script\");\n    35→    let mut permissions = fs::metadata(&script_path)\n    36→        .expect(\"script metadata\")\n    37→        .permissions();\n    38→    permissions.set_mode(0o755);\n    39→    fs::set_permissions(&script_path, permissions).expect(\"set script permissions\");\n    40→    script_path\n    41→}\n    42→\n    43→#[test]\n    44→fn flow_list_prints_all_presets() {\n    45→    let output = Command::new(binary())\n    46→        .args([\"flow\", \"list\"])\n    47→        .output()\n    48→        .expect(\"run flow list\");\n    49→\n    50→    assert!(output.status.success());\n    51→\n    52→    let stdout = String::from_utf8_lossy(&output.stdout);\n    53→    assert!(stdout.contains(\"standard\"));\n    54→    assert!(stdout.contains(\"quick_dev\"));\n    55→    assert!(stdout.contains(\"docs_change\"));\n    56→    assert!(stdout.contains(\"ci_improvement\"));\n    57→}\n    58→\n    59→#[test]\n    60→fn flow_show_standard_prints_stage_sequence() {\n    61→    let output = Command::new(binary())\n    62→        .args([\"flow\", \"show\", \"standard\"])\n    63→        .output()\n    64→        .expect(\"run flow show\");\n    65→\n    66→    assert!(output.status.success());\n    67→\n    68→    let stdout = String::from_utf8_lossy(&output.stdout);\n    69→    assert!(stdout.contains(\"Stage count: 8\"));\n    70→    assert!(stdout.contains(\"1. prompt_review\"));\n    71→    assert!(stdout.contains(\"8. final_review\"));\n    72→    assert!(stdout.contains(\"Final review enabled: yes\"));\n    73→}\n    74→\n    75→#[test]\n    76→fn flow_show_invalid_preset_exits_non_zero_with_clear_error() {\n    77→    let output = Command::new(binary())\n    78→        .args([\"flow\", \"show\", \"unknown_flow\"])\n    79→        .output()\n    80→        .expect(\"run flow show invalid\");\n    81→\n    82→    assert!(!output.status.success());\n    83→\n    84→    let stderr = String::from_utf8_lossy(&output.stderr);\n    85→    assert!(stderr.contains(\"unknown flow preset 'unknown_flow'\"));\n    86→}\n    87→\n    88→#[test]\n    89→fn init_creates_workspace_layout() {\n    90→    let temp_dir = tempdir().expect(\"create temp dir\");\n    91→    let output = Command::new(binary())\n    92→        .arg(\"init\")\n    93→        .current_dir(temp_dir.path())\n    94→        .output()\n    95→        .expect(\"run init\");\n    96→\n    97→    assert!(output.status.success());\n    98→    assert!(temp_dir\n    99→        .path()\n   100→        .join(\".ralph-burning/workspace.toml\")\n   101→        .is_file());\n   102→    assert!(temp_dir.path().join(\".ralph-burning/projects\").is_dir());\n   103→    assert!(temp_dir.path().join(\".ralph-burning/requirements\").is_dir());\n   104→    assert!(temp_dir.path().join(\".ralph-burning/daemon/tasks\").is_dir());\n   105→    assert!(temp_dir\n   106→        .path()\n   107→        .join(\".ralph-burning/daemon/leases\")\n   108→        .is_dir());\n   109→}\n   110→\n   111→#[test]\n   112→fn init_fails_when_workspace_already_exists() {\n   113→    let temp_dir = tempdir().expect(\"create temp dir\");\n   114→\n   115→    let first = Command::new(binary())\n   116→        .arg(\"init\")\n   117→        .current_dir(temp_dir.path())\n   118→        .output()\n   119→        .expect(\"run first init\");\n   120→    assert!(first.status.success());\n   121→\n   122→    let second = Command::new(binary())\n   123→        .arg(\"init\")\n   124→        .current_dir(temp_dir.path())\n   125→        .output()\n   126→        .expect(\"run second init\");\n   127→\n   128→    assert!(!second.status.success());\n   129→\n   130→    let stderr = String::from_utf8_lossy(&second.stderr);\n   131→    assert!(stderr.contains(\"workspace already initialized\"));\n   132→}\n   133→\n   134→#[test]\n   135→fn config_show_prints_effective_values_and_sources() {\n   136→    let temp_dir = initialize_workspace_fixture();\n   137→\n   138→    let output = Command::new(binary())\n   139→        .args([\"config\", \"show\"])\n   140→        .current_dir(temp_dir.path())\n   141→        .output()\n   142→        .expect(\"run config show\");\n   143→\n   144→    assert!(output.status.success());\n   145→\n   146→    let stdout = String::from_utf8_lossy(&output.stdout);\n   147→    assert!(stdout.contains(\"[settings]\"));\n   148→    assert!(stdout.contains(\"prompt_review.enabled = true # source: default\"));\n   149→    assert!(stdout.contains(\"default_flow = \\\"standard\\\" # source: default\"));\n   150→   