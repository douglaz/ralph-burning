w.stage, Some(\"planning\".to_owned()));\n    47→    assert_eq!(view.cycle, Some(1));\n    48→    assert_eq!(view.completion_round, Some(1));\n    49→}\n    50→\n    51→// ── RunHistoryView ──\n    52→\n    53→#[test]\n    54→fn history_view_contains_only_durable_records() {\n    55→    let events = vec![JournalEvent {\n    56→        sequence: 1,\n    57→        timestamp: test_timestamp(),\n    58→        event_type: JournalEventType::ProjectCreated,\n    59→        details: serde_json::json!({}),\n    60→    }];\n    61→\n    62→    let view = queries::build_history_view(\"alpha\", events.clone(), vec![], vec![]);\n    63→\n    64→    assert_eq!(view.project_id, \"alpha\");\n    65→    assert_eq!(view.events.len(), 1);\n    66→    assert!(view.payloads.is_empty());\n    67→    assert!(view.artifacts.is_empty());\n    68→}\n    69→\n    70→// ── RunTailView ──\n    71→\n    72→#[test]\n    73→fn tail_view_omits_logs_when_not_requested() {\n    74→    let view = queries::build_tail_view(\"alpha\", vec![], vec![], vec![], false, vec![]);\n    75→    assert!(view.runtime_logs.is_none());\n    76→}\n    77→\n    78→#[test]\n    79→fn tail_view_includes_logs_when_requested() {\n    80→    let logs = vec![RuntimeLogEntry {\n    81→        timestamp: test_timestamp(),\n    82→        level: LogLevel::Info,\n    83→        source: \"agent\".to_owned(),\n    84→        message: \"started\".to_owned(),\n    85→    }];\n    86→\n    87→    let view = queries::build_tail_view(\"alpha\", vec![], vec![], vec![], true, logs);\n    88→    assert!(view.runtime_logs.is_some());\n    89→    assert_eq!(view.runtime_logs.as_ref().unwrap().len(), 1);\n    90→}\n    91→\n    92→#[test]\n    93→fn tail_view_includes_empty_logs_when_requested_but_none_exist() {\n    94→    let view = queries::build_tail_view(\"alpha\", vec![], vec![], vec![], true, vec![]);\n    95→    assert!(view.runtime_logs.is_some());\n    96→    assert!(view.runtime_logs.as_ref().unwrap().is_empty());\n    97→}\n    98→\n    99→// ── History Consistency Validation ──\n   100→\n   101→#[test]\n   102→fn validate_history_consistency_passes_with_matching_records() {\n   103→    let payloads = vec![PayloadRecord {\n   104→        payload_id: \"p1\".to_owned(),\n   105→        stage_id: StageId::Planning,\n   106→        cycle: 1,\n   107→        attempt: 1,\n   108→        created_at: test_timestamp(),\n   109→        payload: serde_json::json!({}),\n   110→    }];\n   111→    let artifacts = vec![ArtifactRecord {\n   112→        artifact_id: \"a1\".to_owned(),\n   113→        payload_id: \"p1\".to_owned(),\n   114→        stage_id: StageId::Planning,\n   115→        created_at: test_timestamp(),\n   116→        content: \"# Planning\".to_owned(),\n   117→    }];\n   118→\n   119→    assert!(queries::validate_history_consistency(&payloads, &artifacts).is_ok());\n   120→}\n   121→\n   122→#[test]\n   123→fn validate_history_consistency_fails_with_orphaned_artifact() {\n   124→    let payloads = vec![];\n   125→    let artifacts = vec![ArtifactRecord {\n   126→        artifact_id: \"a1\".to_owned(),\n   127→        payload_id: \"p-missing\".to_owned(),\n   128→        stage_id: StageId::Planning,\n   129→        created_at: test_timestamp(),\n   130→        content: \"# Planning\".to_owned(),\n   131→    }];\n   132→\n   133→    let result = queries::validate_history_consistency(&payloads, &artifacts);\n   134→    assert!(matches!(\n   135→        result.unwrap_err(),\n   136→        AppError::CorruptRecord { .. }\n   137→    ));\n   138→}\n   139→\n   140→#[test]\n   141→fn validate_history_consistency_passes_with_no_records() {\n   142→    assert!(queries::validate_history_consistency(&[], &[]).is_ok());\n   143→}\n   144→\n   145→// ── Orphaned Payload Detection ──\n   146→\n   147→#[test]\n   148→fn validate_history_consistency_fails_with_orphaned_payload() {\n   149→    let payloads = vec![PayloadRecord {\n   150→        payload_id: \"p-orphan\".to_owned(),\n   151→        stage_id: StageId::Planning,\n   152→        cycle: 1,\n   153→        attempt: 1,\n   154→        created_at: test_timestamp(),\n   155→        payload: serde_json::json!({}),\n   156→    }];\n   157→    let artifacts = vec![];\n   158→\n   159→    let result = queries::validate_history_consistency(&payloads, &artifacts);\n   160→    assert!(result.is_err());\n   161→    let err = result.unwrap_err();\n   162→    assert!(matches!(err, AppError::CorruptRecord { .. }));\n   163→    match err {\n   164→        AppError::CorruptRecord { details, .. } => {\n   165→            assert!(details.contains(\"no matching artifact\"));\n   166→        }\n   167→        _ => panic!(\"expected CorruptRecord\"),\n   168→    }\n   169→}\n   170→\n   171→// ── RunSnapshot Schema Completeness ──\n   172→\n   173→#[test]\n   174→fn run_snapshot_initial_includes_all_canonical_fields() {\n   175→    let snapshot = RunSnapshot::initial();\n   176→    let json = serde_json::to_string_pretty(&snapshot).expect(\"serialize\");\n   177→\n   178→    // Verify all canonical fields are present in the serialized form\n   179→    assert!(json.contains(\"\\\"active_run\\\"\"));\n   180→    assert!(json.contains(\"\\\"status\\\"\"));\n   181→    assert!(json.contains(\"\\\"cycle_history\\\"\"));\n   182→    assert!(json.contains(\"\\\"completion_rounds\\\"\"));\n   183→    assert!(json.contains(\"\\\"rollback_point_meta\\\"\"));\n   184→    assert!(json.contains(\"\\\"amendment_queue\\\"\"));\n   185→    assert!(json.contains(\"\\\"status_summary\\\"\"));\n   186→}\n   187→\n   188→#[test]\n   189→fn run_snapshot_round_trips_through_json() {\n   190→    let snapshot = RunSnapshot::initial();\n   191→    let json = serde_json::to_string(&snapshot).expect(\"serialize\");\n   192→    let parsed: RunSnapshot = serde_json::from_str(&json).expect(\"deserialize\");\n   193→    assert_eq!(snapshot, parsed);\n   194→}\n   195→\n   196→// ── Runtime Log Separation ──\n   197→\n   198→#[test]\n   199→fn runtime_logs_never_appear_in_history_view() {\n   200→    // History view has no field for runtime logs - enforced by type system.\n   201→    let view = queries::build_history_view(\"alpha\", vec![], vec![], vec![]);\n   202→    // RunHistoryView has no runtime_logs field, so logs can never leak.\n   203→    assert_eq!(view.project_id, \"alpha\");\n   204→}\n   205→"}]},"parent_tool_use_id":null,"session_id":"1a3d9a31-afc3-4ac3-baa7-2cce587b25ae","uuid":"487702e4-0f48-4b77-a1e4-4292a44b6b8e","tool_use_result":{"type":"text","file":{"filePath":"/root/new-ralph-burning/ralph-burning-rewrite/tests/unit/query_test.rs","content":"use chrono::{TimeZone, Utc};\n\nuse ralph_burning::contexts::project_run_record::model::*;\nuse ralph_burning::contexts::project_run_record::queries;\nuse ralph_burning::shared::domain::{StageCursor, StageId};\nuse ralph_burning::shared::error::AppError;\n\nfn test_timestamp() -> chrono::DateTime<Utc> {\n    Utc.with_ymd_and_hms(2026, 3, 11, 19, 0, 0)\n        .single()\n        .expect(\"valid timestamp\")\n}\n\n// ── RunStatusView ──\n\n#[test]\nfn status_view_not_started_when_no_active_run() {\n    let snapshot = RunSnapshot::initial();\n    let view = queries::build_status_view(\"alpha\", &snapshot);\n\n    assert_eq!(view.project_id, \"alpha\");\n    assert_eq!(view.status, \"not started\");\n    assert!(view.stage.is_none());\n    assert!(view.cycle.is_none());\n    assert!(view.completion_round.is_none());\n}\n\n#[test]\nfn status_view_reports_running_with_cursor() {\n    let snapshot = RunSnapshot {\n        active_run: Some(ActiveRun {\n            run_id: \"run-1\".to_owned(),\n            stage_cursor: StageCursor::initial(StageId::Planning),\n            started_at: test_timestamp(),\n        }),\n        status: RunStatus::Running,\n        cycle_history: Vec::new(),\n        completion_rounds: 0,\n        rollback_point_meta: RollbackPointMeta::default(),\n        amendment_queue: AmendmentQueueState::default(),\n        status_summary: \"running at planning\".to_owned(),\n    };\n    let view = queries::build_status_view(\"alpha\", &snapshot);\n\n    assert_eq!(view.status, \"running\");\n    assert_eq!(view.stage, Some(\"planning\".to_owned()));\n    assert_eq!(view.cycle, Some(1));\n    assert_eq!(view.completion_round, Some(1));\n}\n\n// ── RunHistoryView ──\n\n#[test]\nfn history_view_contains_only_durable_records() {\n    let events = vec![JournalEvent {\n        sequence: 1,\n        timestamp: test_timestamp(),\n        event_type: JournalEventType::ProjectCreated,\n        details: serde_json::json!({}),\n    }];\n\n    let view = queries::build_history_view(\"alpha\", events.clone(), vec![], vec![]);\n\n    assert_eq!(view.project_id, \"alpha\");\n    assert_eq!(view.events.len(), 1);\n    assert!(view.payloads.is_empty());\n    assert!(view.artifacts.is_empty());\n}\n\n// ── RunTailView ──\n\n#[test]\nfn tail_view_omits_logs_when_not_requested() {\n    let view = queries::build_tail_view(\"alpha\", vec![], vec![], vec![], false, vec![]);\n    assert!(view.runtime_logs.is_none());\n}\n\n#[test]\nfn tail_view_includes_logs_when_requested() {\n    let logs = vec![RuntimeLogEntry {\n        timestamp: test_timestamp(),\n        level: LogLevel::Info,\n        source: \"agent\".to_owned(),\n        message: \"started\".to_owned(),\n    }];\n\n    let view = queries::build_tail_view(\"alpha\", vec![], vec![], vec![], true, logs);\n    assert!(view.runtime_logs.is_some());\n    assert_eq!(view.runtime_logs.as_ref().unwrap().len(), 1);\n}\n\n#[test]\nfn tail_view_includes_empty_logs_when_requested_but_none_exist() {\n    let view = queries::build_tail_view(\"alpha\", vec![], vec![], vec![], true, vec![]);\n    assert!(view.runtime_logs.is_some());\n    assert!(view.runtime_logs.as_ref().unwrap().is_empty());\n}\n\n// ── History Consistency Validation ──\n\n#[test]\nfn validate_history_consistency_passes_with_matching_records() {\n    let payloads = vec![PayloadRecord {\n        payload_id: \"p1\".to_owned(),\n        stage_id: StageId::Planning,\n        cycle: 1,\n        attempt: 1,\n        created_at: test_timestamp(),\n        payload: serde_json::json!({}),\n    }];\n    let artifacts = vec![ArtifactRecord {\n        artifact_id: \"a1\".to_owned(),\n        payload_id: \"p1\".to_owned(),\n        stage_id: StageId::Planning,\n        created_at: test_timestamp(),\n        content: \"# Planning\".to_owned(),\n    }];\n\n    assert!(queries::validate_history_consistency(&payloads, &artifacts).is_ok());\n}\n\n#[test]\nfn validate_history_consistency_fails_with_orphaned_artifact() {\n    let payloads = vec![];\n    let artifacts = vec![ArtifactRecord {\n        artifact_id: \"a1\".to_owned(),\n        payload_id: \"p-missing\".to_owned(),\n        stage_id: StageId::Planning,\n        created_at: test_timestamp(),\n        content: \"# Planning\".to_owned(),\n    }];\n\n    let result = queries::validate_history_consistency(&payloads, &artifacts);\n    assert!(matches!(\n        result.unwrap_err(),\n        AppError::CorruptRecord { .. }\n    ));\n}\n\n#[test]\nfn validate_history_consistency_passes_with_no_records() {\n    assert!(queries::validate_history_consistency(&[], &[]).is_ok());\n}\n\n// ── Orphaned Payload Detection ──\n\n#[test]\nfn validate_history_consistency_fails_with_orphaned_payload() {\n    let payloads = vec![PayloadRecord {\n        payload_id: \"p-orphan\".to_owned(),\n        stage_id: StageId::Planning,\n        cycle: 1,\n        attempt: 1,\n        created_at: test_timestamp(),\n        payload: serde_json::json!({}),\n    }];\n    let artifacts = vec![];\n\n    let result = queries::validate_history_consistency(&payloads, &artifacts);\n    assert!(result.is_err());\n    let err = result.unwrap_err();\n    assert!(matches!(err, AppError::CorruptRecord { .. }));\n    match err {\n        AppError::CorruptRecord { details, .. } => {\n            assert!(details.contains(\"no matching artifact\"));\n        }\n        _ => panic!(\"expected CorruptRecord\"),\n    }\n}\n\n// ── RunSnapshot Schema Completeness ──\n\n#[test]\nfn run_snapshot_initial_includes_all_canonical_fields() {\n    let snapshot = RunSnapshot::initial();\n    let json = serde_json::to_string_pretty(&snapshot).expect(\"serialize\");\n\n    // Verify all canonical fields are present in the serialized form\n    assert!(json.contains(\"\\\"active_run\\\"\"));\n    assert!(json.contains(\"\\\"status\\\"\"));\n    assert!(json.contains(\"\\\"cycle_history\\\"\"));\n    assert!(json.contains(\"\\\"completion_rounds\\\"\"));\n    assert!(json.contains(\"\\\"rollback_point_meta\\\"\"));\n    assert!(json.contains(\"\\\"amendment_queue\\\"\"));\n    assert!(json.contains(\"\\\"status_summary\\\"\"));\n}\n\n#[test]\nfn run_snapshot_round_trips_through_json() {\n    let snapshot = RunSnapshot::initial();\n    let json = serde_json::to_string(&snapshot).expect(\"serialize\");\n    let parsed: RunSnapshot = serde_json::from_str(&json).expect(\"deserialize\");\n    assert_eq!(snapshot, parsed);\n}\n\n// ── Runtime Log Separation ──\n\n#[test]\nfn runtime_logs_never_appear_in_history_view() {\n    // History view has no field for runtime logs - enforced by type system.\n    let view = queries::build_history_view(\"alpha\", vec![], vec![], vec![]);\n    // RunHistoryView has no runtime_logs field, so logs can never leak.\n    assert_eq!(view.project_id, \"alpha\");\n}\n","numLines":205,"startLine":1,"totalLines":205}}}
