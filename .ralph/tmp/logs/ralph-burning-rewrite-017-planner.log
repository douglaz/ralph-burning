sue_ref\", &input.issue_ref)?;\n    46→\n    47→        let existing_tasks = store.list_tasks(base_dir)?;\n    48→        if existing_tasks\n    49→            .iter()\n    50→            .any(|task| task.issue_ref == issue_ref && !task.is_terminal())\n    51→        {\n    52→            return Err(AppError::DuplicateTaskForIssue { issue_ref });\n    53→        }\n    54→\n    55→        let resolution = routing_engine.resolve_flow(\n    56→            input.routing_command.as_deref(),\n    57→            &input.routing_labels,\n    58→            default_flow,\n    59→        )?;\n    60→\n    61→        let now = Utc::now();\n    62→        let task = DaemonTask {\n    63→            task_id: input.task_id,\n    64→            issue_ref: normalize_required(\"issue_ref\", &input.issue_ref)?,\n    65→            project_id: project_id.to_string(),\n    66→            project_name: input.project_name.filter(|value| !value.trim().is_empty()),\n    67→            prompt: input.prompt.filter(|value| !value.trim().is_empty()),\n    68→            routing_command: input\n    69→                .routing_command\n    70→                .filter(|value| !value.trim().is_empty()),\n    71→            routing_labels: input.routing_labels,\n    72→            resolved_flow: Some(resolution.flow),\n    73→            routing_source: Some(resolution.source),\n    74→            routing_warnings: resolution.warnings.clone(),\n    75→            status: TaskStatus::Pending,\n    76→            created_at: now,\n    77→            updated_at: now,\n    78→            attempt_count: 0,\n    79→            lease_id: None,\n    80→            failure_class: None,\n    81→            failure_message: None,\n    82→            dispatch_mode: input.dispatch_mode,\n    83→            source_revision: input.source_revision,\n    84→            requirements_run_id: None,\n    85→        };\n    86→\n    87→        store.create_task(base_dir, &task)?;\n    88→        Self::append_journal_event(\n    89→            store,\n    90→            base_dir,\n    91→            DaemonJournalEventType::TaskCreated,\n    92→            json!({\n    93→                \"task_id\": task.task_id,\n    94→                \"issue_ref\": task.issue_ref,\n    95→                \"project_id\": task.project_id,\n    96→                \"flow\": resolution.flow,\n    97→                \"routing_source\": resolution.source,\n    98→                \"warnings\": resolution.warnings,\n    99→            }),\n   100→        )?;\n   101→\n   102→        Ok(task)\n   103→    }\n   104→\n   105→    pub fn claim_task(\n   106→        store: &dyn DaemonStorePort,\n   107→        worktree: &dyn WorktreePort,\n   108→        routing_engine: &RoutingEngine,\n   109→        base_dir: &Path,\n   110→        repo_root: &Path,\n   111→        task_id: &str,\n   112→        default_flow: FlowPreset,\n   113→        lease_ttl_seconds: u64,\n   114→    ) -> AppResult<(DaemonTask, WorktreeLease)> {\n   115→        let mut task = store.read_task(base_dir, task_id)?;\n   116→        if task.status != TaskStatus::Pending {\n   117→            return Err(AppError::TaskStateTransitionInvalid {\n   118→                task_id: task.task_id.clone(),\n   119→                from: task.status.as_str().to_owned(),\n   120→                to: TaskStatus::Claimed.as_str().to_owned(),\n   121→            });\n   122→        }\n   123→\n   124→        if task.lease_id.is_some()\n   125→            || store\n   126→                .list_leases(base_dir)?\n   127→                .iter()\n   128→                .any(|lease| lease.task_id == task.task_id)\n   129→        {\n   130→            return Err(AppError::TaskStateTransitionInvalid {\n   131→                task_id: task.task_id.clone(),\n   132→                from: task.status.as_str().to_owned(),\n   133→                to: \"claimed_with_duplicate_lease\".to_owned(),\n   134→            });\n   135→        }\n   136→\n   137→        hydrate_routing(&mut task, routing_engine, default_flow)?;\n   138→        let project_id = ProjectId::new(task.project_id.clone())?;\n   139→        let lease = match LeaseService::acquire(\n   140→            store,\n   141→            worktree,\n   142→            base_dir,\n   143→            repo_root,\n   144→            &task.task_id,\n   145→            &project_id,\n   146→            lease_ttl_seconds,\n   147→        ) {\n   148→            Ok(lease) => lease,\n   149→            Err(AppError::ProjectWriterLockHeld { .. }) => {\n   150→                return Err(AppError::ProjectWriterLockHeld {\n   151→                    project_id: project_id.to_string(),\n   152→                })\n   153→            }\n   154→            Err(error) => {\n   155→                let _ = Self::mark_failed(\n   156→                    store,\n   157→                    base_dir,\n   158→                    &task.task_id,\n   159→                    \"worktree_creation_failed\",\n   160→                    &error.to_string(),\n   161→                );\n   162→                return Err(error);\n   163→            }\n   164→        };\n   165→\n   166→        let now = Utc::now();\n   167→        task.transition_to(TaskStatus::Claimed, now)?;\n   168→        task.attach_lease(lease.lease_id.clone());\n   169→        store.write_task(base_dir, &task).map_err(|error| {\n   170→            let _ = LeaseService::release(store, worktree, base_dir, repo_root, &lease);\n   171→            error\n   172→        })?;\n   173→\n   174→        Self::append_journal_event(\n   175→            store,\n   176→            base_dir,\n   177→            DaemonJournalEventType::LeaseAcquired,\n   178→            json!({\n   179→                \"task_id\": task.task_id,\n   180→                \"lease_id\": lease.lease_id,\n   181→                \"project_id\": project_id,\n   182→                \"worktree_path\": lease.worktree_path,\n   183→                \"branch_name\": lease.branch_name,\n   184→                \"ttl_seconds\": lease.ttl_seconds,\n   185→            }),\n   186→        )?;\n   187→        Self::append_journal_event(\n   188→            store,\n   189→            base_dir,\n   190→            DaemonJournalEventType::TaskClaimed,\n   191→            json!({\n   192→                \"task_id\": task.task_id,\n   193→                \"lease_id\": lease.lease_id,\n   194→                \"project_id\": project_id,\n   195→            }),\n   196→        )?;\n   197→\n   198→        Ok((task, lease))\n   199→    }\n   200→\n   201→    pub fn mark_active(\n   202→        store: &dyn DaemonStorePort,\n   203→        base_dir: &Path,\n   204→        task_id: &str,\n   205→    ) -> AppResult<DaemonTask> {\n   206→        let mut task = store.read_task(base_dir, task_id)?;\n   207→        task.transition_to(TaskStatus::Active, Utc::now())?;\n   208→        store.write_task(base_dir, &task)?;\n   209→        Ok(task)\n   210→    }\n   211→\n   212→    pub fn mark_completed(\n   213→        store: &dyn DaemonStorePort,\n   214→        base_dir: &Path,\n   215→        task_id: &str,\n   216→    ) -> AppResult<DaemonTask> {\n   217→        let mut task = store.read_task(base_dir, task_id)?;\n   218→        task.transition_to(TaskStatus::Completed, Utc::now())?;\n   219→        store.write_task(base_dir, &task)?;\n   220→        Self::append_journal_event(\n   221→            store,\n   222→            base_dir,\n   223→            DaemonJournalEventType::TaskCompleted,\n   224→            json!({ \"task_id\": task.task_id }),\n   225→        )?;\n   226→        Ok(task)\n   227→    }\n   228→\n   229→    pub fn mark_failed(\n   230→        store: &dyn DaemonStorePort,\n   231→        base_dir: &Path,\n   232→        task_id: &str,\n   233→        failure_class: &str,\n   234→        failure_message: &str,\n   235→    ) -> AppResult<DaemonTask> {\n   236→        let mut task = store.read_task(base_dir, task_id)?;\n   237→        task.transition_to(TaskStatus::Failed, Utc::now())?;\n   238→        task.set_failure(failure_class, failure_message);\n   239→        store.write_task(base_dir, &task)?;\n   240→        Self::append_journal_event(\n   241→            store,\n   242→            base_dir,\n   243→            DaemonJournalEventType::TaskFailed,\n   244→            json!({\n   245→                \"task_id\": task.task_id,\n   246→                \"failure_class\": failure_class,\n   247→                \"failure_message\": failure_message,\n   248→            }),\n   249→        )?;\n   250→        Ok(task)\n   251→    }\n   252→\n   253→    pub fn mark_aborted(\n   254→        store: &dyn DaemonStorePort,\n   255→        base_dir: &Path,\n   256→        task_id: &str,\n   257→    ) -> AppResult<DaemonTask> {\n   258→        let mut task = store.read_task(base_dir, task_id)?;\n   259→        if matches!(\n   260→            task.status,\n   261→            TaskStatus::Completed | TaskStatus::Failed | TaskStatus::Aborted\n   262→        ) {\n   263→            return Err(AppError::TaskStateTransitionInvalid {\n   264→                task_id: task.task_id.clone(),\n   265→                from: task.status.as_str().to_owned(),\n   266→                to: TaskStatus::Aborted.as_str().to_owned(),\n   267→            });\n   268→        }\n   269→        task.transition_to(TaskStatus::Aborted, Utc::now())?;\n   270→        store.write_task(base_dir, &task)?;\n   271→        Self::append_journal_event(\n   272→            store,\n   273→            base_dir,\n   274→            DaemonJournalEventType::TaskAborted,\n   275→            json!({ \"task_id\": task.task_id }),\n   276→        )?;\n   277→        Ok(task)\n   278→    }\n   279→\n   280→    pub fn retry_task(\n   281→        store: &dyn DaemonStorePort,\n   282→        base_dir: &Path,\n   283→        task_id: &str,\n   284→    ) -> AppResult<DaemonTask> {\n   285→        let mut task = store.read_task(base_dir, task_id)?;\n   286→        if task.status != TaskStatus::Failed {\n   287→            return Err(AppError::TaskStateTransitionInvalid {\n   288→                task_id: task.task_id.clone(),\n   289→                from: task.status.as_str().to_owned(),\n   290→                to: TaskStatus::Pending.as_str().to_owned(),\n   291→            });\n   292→        }\n   293→\n   294→        task.transition_to(TaskStatus::Pending, Utc::now())?;\n   295→        task.attempt_count += 1;\n   296→        task.clear_failure();\n   297→        task.clear_lease();\n   298→        store.write_task(base_dir, &task)?;\n   299→        Ok(task)\n   300→    }\n   301→\n   302→    pub fn clear_lease_reference(\n   303→        store: &dyn DaemonStorePort,\n   304→        base_dir: &Path,\n   305→        task_id: &str,\n   306→    ) -> AppResult<DaemonTask> {\n   307→        let mut task = store.read_task(base_dir, task_id)?;\n   308→        task.clear_lease();\n   309→        task.updated_at = Utc::now();\n   310→        store.write_task(base_dir, &task)?;\n   311→        Ok(task)\n   312→    }\n   313→\n   314→    /// Create a task from a watched issue, enforcing idempotency by\n   315→    /// `(issue_ref, source_revision)`. If a non-terminal task already exists\n   316→    /// for the same issue_ref and source_revision, the call is a no-op.\n   317→    /// If a prior task for the same issue_ref is terminal and a newer\n   318→    /// source_revision appears, a fresh task may be created.\n   319→    pub fn create_task_from_watched_issue(\n   320→        store: &dyn DaemonStorePort,\n   321→        base_dir: &Path,\n   322→        routing_engine: &RoutingEngine,\n   323→        default_flow: FlowPreset,\n   324→        issue: &WatchedIssueMeta,\n   325→        dispatch_mode: DispatchMode,\n   326→    ) -> AppResult<Option<DaemonTask>> {\n   327→        let issue_ref = normalize_required(\"issue_ref\", &issue.issue_ref)?;\n   328→        let source_revision = normalize_required(\"source_revision\", &issue.source_revision)?;\n   329→\n   330→        let existing_tasks = store.list_tasks(base_dir)?;\n   331→\n   332→        // Check for exact (issue_ref, source_revision) match on non-terminal task\n   333→        for task in &existing_tasks {\n   334→            if task.issue_ref == issue_ref && !task.is_terminal() {\n   335→                if task.source_revision.as_deref() == Some(source_revision.as_str()) {\n   336→                    // Idempotent: same issue + same revision, already tracked\n   337→                    return Ok(None);\n   338→                }\n   339→                // Different source_revision but same issue_ref with non-terminal task\n   340→                return Err(AppError::DuplicateWatchedIssue {\n   341→                    issue_ref,\n   342→                    source_revision,\n   343→                });\n   344→            }\n   345→        }\n   346→\n   347→        // If the routing_command is a requirements command, don't pass it to flow\n   348→        // resolution — requirements commands are orthogonal to flow routing.\n   349→        // Flow precedence still applies via labels and repo default.\n   350→        let flow_routing_cmd = issue.routing_command.as_deref().filter(|cmd| {\n   351→            !super::watcher::is_requirements_command(cmd)\n   352→        });\n   353→        let resolution = routing_engine.resolve_flow(\n   354→            flow_routing_cmd,\n   355→            &issue.labels,\n   356→            default_flow,\n   357→        )?;\n   358→\n   359→        let task_id = format!(\n   360→            \"watch-{}-{}\",\n   361→            issue_ref.replace('/', \"-\").replace('#', \"\"),\n   362→            &source_revision[..source_revision.len().min(8)]\n   363→        );\n   364→        validate_identifier(&task_id)?;\n   365→\n   366→        let now = Utc::now();\n   367→        let task = DaemonTask {\n   368→            task_id,\n   369→            issue_ref: issue_ref.clone(),\n   370→            project_id: format!(\n   371→                \"watched-{}\",\n   372→                issue_ref.replace('/', \"-\").replace('#', \"\")\n   373→            ),\n   374→            project_name: Some(issue.title.clone()),\n   375→            prompt: Some(issue.body.clone()),\n   376→            routing_command: issue.routing_command.clone(),\n   377→            routing_labels: issue.labels.clone(),\n   378→            resolved_flow: Some(resolution.flow),\n   379→            routing_source: Some(resolution.source),\n   380→            routing_warnings: resolution.warnings.clone(),\n   381→            status: TaskStatus::Pending,\n   382→            created_at: now,\n   383→            updated_at: now,\n   384→            attempt_count: 0,\n   385→            lease_id: None,\n   386→            failure_class: None,\n   387→            failure_message: None,\n   388→            dispatch_mode,\n   389→            source_revision: Some(source_revision),\n   390→            requirements_run_id: None,\n   391→        };\n   392→\n   393→        store.create_task(base_dir, &task)?;\n   394→        Self::append_journal_event(\n   395→            store,\n   396→            base_dir,\n   397→            DaemonJournalEventType::WatcherIngestion,\n   398→            json!({\n   399→                \"task_id\": task.task_id,\n   400→                \"issue_ref\": task.issue_ref,\n   401→                \"source_revision\": task.source_revision,\n   402→                \"dispatch_mode\": task.dispatch_mode,\n   403→                \"flow\": resolution.flow,\n   404→            }),\n   405→        )?;\n   406→\n   407→        Ok(Some(task))\n   408→    }\n   409→\n   410→    /// Transition an active task to waiting_for_requirements.\n   411→    /// Releases the lease and writer lock, leaving no external resources held.\n   412→    pub fn mark_waiting_for_requirements(\n   413→        store: &dyn DaemonStorePort,\n   414→        base_dir: &Path,\n   415→        task_id: &str,\n   416→        requirements_run_id: &str,\n   417→    ) -> AppResult<DaemonTask> {\n   418→        let mut task = store.read_task(base_dir, task_id)?;\n   419→        task.transition_to(TaskStatus::WaitingForRequirements, Utc::now())?;\n   420→        task.requirements_run_id = Some(requirements_run_id.to_owned());\n   421→        task.clear_lease();\n   422→        store.write_task(base_dir, &task)?;\n   423→        Self::append_journal_event(\n   424→            store,\n   425→            base_dir,\n   426→            DaemonJournalEventType::RequirementsWaiting,\n   427→            json!({\n   428→                \"task_id\": task.task_id,\n   429→                \"requirements_run_id\": requirements_run_id,\n   430→            }),\n   431→        )?;\n   432→        Ok(task)\n   433→    }\n   434→\n   435→    /// Resume a waiting task back to pending for re-processing by the daemon.\n   436→    pub fn resume_from_waiting(\n   437→        store: &dyn DaemonStorePort,\n   438→        base_dir: &Path,\n   439→        task_id: &str,\n   440→    ) -> AppResult<DaemonTask> {\n   441→        let mut task = store.read_task(base_dir, task_id)?;\n   442→        if task.status != TaskStatus::WaitingForRequirements {\n   443→            return Err(AppError::TaskStateTransitionInvalid {\n   444→                task_id: task.task_id.clone(),\n   445→                from: task.status.as_str().to_owned(),\n   446→                to: TaskStatus::Pending.as_str().to_owned(),\n   447→            });\n   448→        }\n   449→        task.transition_to(TaskStatus::Pending, Utc::now())?;\n   450→        // Switch to workflow dispatch now that requirements are complete\n   451→        task.dispatch_mode = DispatchMode::Workflow;\n   452→        store.write_task(base_dir, &task)?;\n   453→        Self::append_journal_event(\n   454→            store,\n   455→            base_dir,\n   456→            DaemonJournalEventType::RequirementsResumed,\n   457→            json!({\n   458→                \"task_id\": task.task_id,\n   459→                \"requirements_run_id\": task.requirements_run_id,\n   460→            }),\n   461→        )?;\n   462→        Ok(task)\n   463→    }\n   464→\n   465→    pub(crate) fn append_journal_event(\n   466→        store: &dyn DaemonStorePort,\n   467→        base_dir: &Path,\n   468→        event_type: DaemonJournalEventType,\n   469→        details: serde_json::Value,\n   470→    ) -> AppResult<()> {\n   471→        let events = store.read_daemon_journal(base_dir)?;\n   472→        let sequence = events.last().map_or(1, |event| event.sequence + 1);\n   473→        let event = DaemonJournalEvent {\n   474→            sequence,\n   475→            timestamp: Utc::now(),\n   476→            event_type,\n   477→            details,\n   478→        };\n   479→        store.append_daemon_journal_event(base_dir, &event)\n   480→    }\n   481→}\n   482→\n   483→fn hydrate_routing(\n   484→    task: &mut DaemonTask,\n   485→    routing_engine: &RoutingEngine,\n   486→    default_flow: FlowPreset,\n   487→) -> AppResult<()> {\n   488→    if task.resolved_flow.is_some() {\n   489→        return Ok(());\n   490→    }\n   491→\n   492→    let resolution = routing_engine.resolve_flow(\n   493→        task.routing_command.as_deref(),\n   494→        &task.routing_labels,\n   495→        default_flow,\n   496→    )?;\n   497→    task.resolved_flow = Some(resolution.flow);\n   498→    task.routing_source = Some(resolution.source);\n   499→    task.routing_warnings = resolution.warnings;\n   500→    Ok(())\n   501→}\n   502→\n   503→fn validate_identifier(value: &str) -> AppResult<()> {\n   504→    let _ = ProjectId::new(value.to_owned())?;\n   505→    Ok(())\n   506→}\n   507→\n   508→fn normalize_required(field: &'static str, value: &str) -> AppResult<String> {\n   509→    let trimmed = value.trim();\n   510→    if trimmed.is_empty() {\n   511→        return Err(AppError::InvalidConfigValue {\n   512→            key: field.to_owned(),\n   513→            value: value.to_owned(),\n   514→            reason: \"value cannot be empty\".to_owned(),\n   515→        });\n   516→    }\n   517→    Ok(trimmed.to_owned())\n   518→}\n   519→"}]},"parent_tool_use_id":null,"session_id":"4f5afce8-7057-46f6-9d3e-09a7997db51f","uuid":"71d0dd16-b1db-4881-9896-11f39c7a9f87","tool_use_result":{"type":"text","file":{"filePath":"/root/new-ralph-burning/ralph-burning-rewrite/src/contexts/automation_runtime/task_service.rs","content":"use std::path::Path;\n\nuse chrono::Utc;\nuse serde_json::json;\n\nuse crate::contexts::automation_runtime::lease_service::LeaseService;\nuse crate::contexts::automation_runtime::model::{\n    DaemonJournalEvent, DaemonJournalEventType, DaemonTask, DispatchMode, TaskStatus,\n    WatchedIssueMeta, WorktreeLease,\n};\nuse crate::contexts::automation_runtime::routing::RoutingEngine;\nuse crate::contexts::automation_runtime::{DaemonStorePort, WorktreePort};\nuse crate::shared::domain::{FlowPreset, ProjectId};\nuse crate::shared::error::{AppError, AppResult};\n\n#[derive(Debug, Clone, PartialEq, Eq)]\npub struct CreateTaskInput {\n    pub task_id: String,\n    pub issue_ref: String,\n    pub project_id: String,\n    pub project_name: Option<String>,\n    pub prompt: Option<String>,\n    pub routing_command: Option<String>,\n    pub routing_labels: Vec<String>,\n    pub dispatch_mode: DispatchMode,\n    pub source_revision: Option<String>,\n}\n\npub struct DaemonTaskService;\n\nimpl DaemonTaskService {\n    pub fn list_tasks(store: &dyn DaemonStorePort, base_dir: &Path) -> AppResult<Vec<DaemonTask>> {\n        store.list_tasks(base_dir)\n    }\n\n    pub fn create_task(\n        store: &dyn DaemonStorePort,\n        base_dir: &Path,\n        routing_engine: &RoutingEngine,\n        default_flow: FlowPreset,\n        input: CreateTaskInput,\n    ) -> AppResult<DaemonTask> {\n        validate_identifier(&input.task_id)?;\n        let project_id = ProjectId::new(input.project_id.clone())?;\n        let issue_ref = normalize_required(\"issue_ref\", &input.issue_ref)?;\n\n        let existing_tasks = store.list_tasks(base_dir)?;\n        if existing_tasks\n            .iter()\n            .any(|task| task.issue_ref == issue_ref && !task.is_terminal())\n        {\n            return Err(AppError::DuplicateTaskForIssue { issue_ref });\n        }\n\n        let resolution = routing_engine.resolve_flow(\n            input.routing_command.as_deref(),\n            &input.routing_labels,\n            default_flow,\n        )?;\n\n        let now = Utc::now();\n        let task = DaemonTask {\n            task_id: input.task_id,\n            issue_ref: normalize_required(\"issue_ref\", &input.issue_ref)?,\n            project_id: project_id.to_string(),\n            project_name: input.project_name.filter(|value| !value.trim().is_empty()),\n            prompt: input.prompt.filter(|value| !value.trim().is_empty()),\n            routing_command: input\n                .routing_command\n                .filter(|value| !value.trim().is_empty()),\n            routing_labels: input.routing_labels,\n            resolved_flow: Some(resolution.flow),\n            routing_source: Some(resolution.source),\n            routing_warnings: resolution.warnings.clone(),\n            status: TaskStatus::Pending,\n            created_at: now,\n            updated_at: now,\n            attempt_count: 0,\n            lease_id: None,\n            failure_class: None,\n            failure_message: None,\n            dispatch_mode: input.dispatch_mode,\n            source_revision: input.source_revision,\n            requirements_run_id: None,\n        };\n\n        store.create_task(base_dir, &task)?;\n        Self::append_journal_event(\n            store,\n            base_dir,\n            DaemonJournalEventType::TaskCreated,\n            json!({\n                \"task_id\": task.task_id,\n                \"issue_ref\": task.issue_ref,\n                \"project_id\": task.project_id,\n                \"flow\": resolution.flow,\n                \"routing_source\": resolution.source,\n                \"warnings\": resolution.warnings,\n            }),\n        )?;\n\n        Ok(task)\n    }\n\n    pub fn claim_task(\n        store: &dyn DaemonStorePort,\n        worktree: &dyn WorktreePort,\n        routing_engine: &RoutingEngine,\n        base_dir: &Path,\n        repo_root: &Path,\n        task_id: &str,\n        default_flow: FlowPreset,\n        lease_ttl_seconds: u64,\n    ) -> AppResult<(DaemonTask, WorktreeLease)> {\n        let mut task = store.read_task(base_dir, task_id)?;\n        if task.status != TaskStatus::Pending {\n            return Err(AppError::TaskStateTransitionInvalid {\n                task_id: task.task_id.clone(),\n                from: task.status.as_str().to_owned(),\n                to: TaskStatus::Claimed.as_str().to_owned(),\n            });\n        }\n\n        if task.lease_id.is_some()\n            || store\n                .list_leases(base_dir)?\n                .iter()\n                .any(|lease| lease.task_id == task.task_id)\n        {\n            return Err(AppError::TaskStateTransitionInvalid {\n                task_id: task.task_id.clone(),\n                from: task.status.as_str().to_owned(),\n                to: \"claimed_with_duplicate_lease\".to_owned(),\n            });\n        }\n\n        hydrate_routing(&mut task, routing_engine, default_flow)?;\n        let project_id = ProjectId::new(task.project_id.clone())?;\n        let lease = match LeaseService::acquire(\n            store,\n            worktree,\n            base_dir,\n            repo_root,\n            &task.task_id,\n            &project_id,\n            lease_ttl_seconds,\n        ) {\n            Ok(lease) => lease,\n            Err(AppError::ProjectWriterLockHeld { .. }) => {\n                return Err(AppError::ProjectWriterLockHeld {\n                    project_id: project_id.to_string(),\n                })\n            }\n            Err(error) => {\n                let _ = Self::mark_failed(\n                    store,\n                    base_dir,\n                    &task.task_id,\n                    \"worktree_creation_failed\",\n                    &error.to_string(),\n                );\n                return Err(error);\n            }\n        };\n\n        let now = Utc::now();\n        task.transition_to(TaskStatus::Claimed, now)?;\n        task.attach_lease(lease.lease_id.clone());\n        store.write_task(base_dir, &task).map_err(|error| {\n            let _ = LeaseService::release(store, worktree, base_dir, repo_root, &lease);\n            error\n        })?;\n\n        Self::append_journal_event(\n            store,\n            base_dir,\n            DaemonJournalEventType::LeaseAcquired,\n            json!({\n                \"task_id\": task.task_id,\n                \"lease_id\": lease.lease_id,\n                \"project_id\": project_id,\n                \"worktree_path\": lease.worktree_path,\n                \"branch_name\": lease.branch_name,\n                \"ttl_seconds\": lease.ttl_seconds,\n            }),\n        )?;\n        Self::append_journal_event(\n            store,\n            base_dir,\n            DaemonJournalEventType::TaskClaimed,\n            json!({\n                \"task_id\": task.task_id,\n                \"lease_id\": lease.lease_id,\n                \"project_id\": project_id,\n            }),\n        )?;\n\n        Ok((task, lease))\n    }\n\n    pub fn mark_active(\n        store: &dyn DaemonStorePort,\n        base_dir: &Path,\n        task_id: &str,\n    ) -> AppResult<DaemonTask> {\n        let mut task = store.read_task(base_dir, task_id)?;\n        task.transition_to(TaskStatus::Active, Utc::now())?;\n        store.write_task(base_dir, &task)?;\n        Ok(task)\n    }\n\n    pub fn mark_completed(\n        store: &dyn DaemonStorePort,\n        base_dir: &Path,\n        task_id: &str,\n    ) -> AppResult<DaemonTask> {\n        let mut task = store.read_task(base_dir, task_id)?;\n        task.transition_to(TaskStatus::Completed, Utc::now())?;\n        store.write_task(base_dir, &task)?;\n        Self::append_journal_event(\n            store,\n            base_dir,\n            DaemonJournalEventType::TaskCompleted,\n            json!({ \"task_id\": task.task_id }),\n        )?;\n        Ok(task)\n    }\n\n    pub fn mark_failed(\n        store: &dyn DaemonStorePort,\n        base_dir: &Path,\n        task_id: &str,\n        failure_class: &str,\n        failure_message: &str,\n    ) -> AppResult<DaemonTask> {\n        let mut task = store.read_task(base_dir, task_id)?;\n        task.transition_to(TaskStatus::Failed, Utc::now())?;\n        task.set_failure(failure_class, failure_message);\n        store.write_task(base_dir, &task)?;\n        Self::append_journal_event(\n            store,\n            base_dir,\n            DaemonJournalEventType::TaskFailed,\n            json!({\n                \"task_id\": task.task_id,\n                \"failure_class\": failure_class,\n                \"failure_message\": failure_message,\n            }),\n        )?;\n        Ok(task)\n    }\n\n    pub fn mark_aborted(\n        store: &dyn DaemonStorePort,\n        base_dir: &Path,\n        task_id: &str,\n    ) -> AppResult<DaemonTask> {\n        let mut task = store.read_task(base_dir, task_id)?;\n        if matches!(\n            task.status,\n            TaskStatus::Completed | TaskStatus::Failed | TaskStatus::Aborted\n        ) {\n            return Err(AppError::TaskStateTransitionInvalid {\n                task_id: task.task_id.clone(),\n                from: task.status.as_str().to_owned(),\n                to: TaskStatus::Aborted.as_str().to_owned(),\n            });\n        }\n        task.transition_to(TaskStatus::Aborted, Utc::now())?;\n        store.write_task(base_dir, &task)?;\n        Self::append_journal_event(\n            store,\n            base_dir,\n            DaemonJournalEventType::TaskAborted,\n            json!({ \"task_id\": task.task_id }),\n        )?;\n        Ok(task)\n    }\n\n    pub fn retry_task(\n        store: &dyn DaemonStorePort,\n        base_dir: &Path,\n        task_id: &str,\n    ) -> AppResult<DaemonTask> {\n        let mut task = store.read_task(base_dir, task_id)?;\n        if task.status != TaskStatus::Failed {\n            return Err(AppError::TaskStateTransitionInvalid {\n                task_id: task.task_id.clone(),\n                from: task.status.as_str().to_owned(),\n                to: TaskStatus::Pending.as_str().to_owned(),\n            });\n        }\n\n        task.transition_to(TaskStatus::Pending, Utc::now())?;\n        task.attempt_count += 1;\n        task.clear_failure();\n        task.clear_lease();\n        store.write_task(base_dir, &task)?;\n        Ok(task)\n    }\n\n    pub fn clear_lease_reference(\n        store: &dyn DaemonStorePort,\n        base_dir: &Path,\n        task_id: &str,\n    ) -> AppResult<DaemonTask> {\n        let mut task = store.read_task(base_dir, task_id)?;\n        task.clear_lease();\n        task.updated_at = Utc::now();\n        store.write_task(base_dir, &task)?;\n        Ok(task)\n    }\n\n    /// Create a task from a watched issue, enforcing idempotency by\n    /// `(issue_ref, source_revision)`. If a non-terminal task already exists\n    /// for the same issue_ref and source_revision, the call is a no-op.\n    /// If a prior task for the same issue_ref is terminal and a newer\n    /// source_revision appears, a fresh task may be created.\n    pub fn create_task_from_watched_issue(\n        store: &dyn DaemonStorePort,\n        base_dir: &Path,\n        routing_engine: &RoutingEngine,\n        default_flow: FlowPreset,\n        issue: &WatchedIssueMeta,\n        dispatch_mode: DispatchMode,\n    ) -> AppResult<Option<DaemonTask>> {\n        let issue_ref = normalize_required(\"issue_ref\", &issue.issue_ref)?;\n        let source_revision = normalize_required(\"source_revision\", &issue.source_revision)?;\n\n        let existing_tasks = store.list_tasks(base_dir)?;\n\n        // Check for exact (issue_ref, source_revision) match on non-terminal task\n        for task in &existing_tasks {\n            if task.issue_ref == issue_ref && !task.is_terminal() {\n                if task.source_revision.as_deref() == Some(source_revision.as_str()) {\n                    // Idempotent: same issue + same revision, already tracked\n                    return Ok(None);\n                }\n                // Different source_revision but same issue_ref with non-terminal task\n                return Err(AppError::DuplicateWatchedIssue {\n                    issue_ref,\n                    source_revision,\n                });\n            }\n        }\n\n        // If the routing_command is a requirements command, don't pass it to flow\n        // resolution — requirements commands are orthogonal to flow routing.\n        // Flow precedence still applies via labels and repo default.\n        let flow_routing_cmd = issue.routing_command.as_deref().filter(|cmd| {\n            !super::watcher::is_requirements_command(cmd)\n        });\n        let resolution = routing_engine.resolve_flow(\n            flow_routing_cmd,\n            &issue.labels,\n            default_flow,\n        )?;\n\n        let task_id = format!(\n            \"watch-{}-{}\",\n            issue_ref.replace('/', \"-\").replace('#', \"\"),\n            &source_revision[..source_revision.len().min(8)]\n        );\n        validate_identifier(&task_id)?;\n\n        let now = Utc::now();\n        let task = DaemonTask {\n            task_id,\n            issue_ref: issue_ref.clone(),\n            project_id: format!(\n                \"watched-{}\",\n                issue_ref.replace('/', \"-\").replace('#', \"\")\n            ),\n            project_name: Some(issue.title.clone()),\n            prompt: Some(issue.body.clone()),\n            routing_command: issue.routing_command.clone(),\n            routing_labels: issue.labels.clone(),\n            resolved_flow: Some(resolution.flow),\n            routing_source: Some(resolution.source),\n            routing_warnings: resolution.warnings.clone(),\n            status: TaskStatus::Pending,\n            created_at: now,\n            updated_at: now,\n            attempt_count: 0,\n            lease_id: None,\n            failure_class: None,\n            failure_message: None,\n            dispatch_mode,\n            source_revision: Some(source_revision),\n            requirements_run_id: None,\n        };\n\n        store.create_task(base_dir, &task)?;\n        Self::append_journal_event(\n            store,\n            base_dir,\n            DaemonJournalEventType::WatcherIngestion,\n            json!({\n                \"task_id\": task.task_id,\n                \"issue_ref\": task.issue_ref,\n                \"source_revision\": task.source_revision,\n                \"dispatch_mode\": task.dispatch_mode,\n                \"flow\": resolution.flow,\n            }),\n        )?;\n\n        Ok(Some(task))\n    }\n\n    /// Transition an active task to waiting_for_requirements.\n    /// Releases the lease and writer lock, leaving no external resources held.\n    pub fn mark_waiting_for_requirements(\n        store: &dyn DaemonStorePort,\n        base_dir: &Path,\n        task_id: &str,\n        requirements_run_id: &str,\n    ) -> AppResult<DaemonTask> {\n        let mut task = store.read_task(base_dir, task_id)?;\n        task.transition_to(TaskStatus::WaitingForRequirements, Utc::now())?;\n        task.requirements_run_id = Some(requirements_run_id.to_owned());\n        task.clear_lease();\n        store.write_task(base_dir, &task)?;\n        Self::append_journal_event(\n            store,\n            base_dir,\n            DaemonJournalEventType::RequirementsWaiting,\n            json!({\n                \"task_id\": task.task_id,\n                \"requirements_run_id\": requirements_run_id,\n            }),\n        )?;\n        Ok(task)\n    }\n\n    /// Resume a waiting task back to pending for re-processing by the daemon.\n    pub fn resume_from_waiting(\n        store: &dyn DaemonStorePort,\n        base_dir: &Path,\n        task_id: &str,\n    ) -> AppResult<DaemonTask> {\n        let mut task = store.read_task(base_dir, task_id)?;\n        if task.status != TaskStatus::WaitingForRequirements {\n            return Err(AppError::TaskStateTransitionInvalid {\n                task_id: task.task_id.clone(),\n                from: task.status.as_str().to_owned(),\n                to: TaskStatus::Pending.as_str().to_owned(),\n            });\n        }\n        task.transition_to(TaskStatus::Pending, Utc::now())?;\n        // Switch to workflow dispatch now that requirements are complete\n        task.dispatch_mode = DispatchMode::Workflow;\n        store.write_task(base_dir, &task)?;\n        Self::append_journal_event(\n            store,\n            base_dir,\n            DaemonJournalEventType::RequirementsResumed,\n            json!({\n                \"task_id\": task.task_id,\n                \"requirements_run_id\": task.requirements_run_id,\n            }),\n        )?;\n        Ok(task)\n    }\n\n    pub(crate) fn append_journal_event(\n        store: &dyn DaemonStorePort,\n        base_dir: &Path,\n        event_type: DaemonJournalEventType,\n        details: serde_json::Value,\n    ) -> AppResult<()> {\n        let events = store.read_daemon_journal(base_dir)?;\n        let sequence = events.last().map_or(1, |event| event.sequence + 1);\n        let event = DaemonJournalEvent {\n            sequence,\n            timestamp: Utc::now(),\n            event_type,\n            details,\n        };\n        store.append_daemon_journal_event(base_dir, &event)\n    }\n}\n\nfn hydrate_routing(\n    task: &mut DaemonTask,\n    routing_engine: &RoutingEngine,\n    default_flow: FlowPreset,\n) -> AppResult<()> {\n    if task.resolved_flow.is_some() {\n        return Ok(());\n    }\n\n    let resolution = routing_engine.resolve_flow(\n        task.routing_command.as_deref(),\n        &task.routing_labels,\n        default_flow,\n    )?;\n    task.resolved_flow = Some(resolution.flow);\n    task.routing_source = Some(resolution.source);\n    task.routing_warnings = resolution.warnings;\n    Ok(())\n}\n\nfn validate_identifier(value: &str) -> AppResult<()> {\n    let _ = ProjectId::new(value.to_owned())?;\n    Ok(())\n}\n\nfn normalize_required(field: &'static str, value: &str) -> AppResult<String> {\n    let trimmed = value.trim();\n    if trimmed.is_empty() {\n        return Err(AppError::InvalidConfigValue {\n            key: field.to_owned(),\n            value: value.to_owned(),\n            reason: \"value cannot be empty\".to_owned(),\n        });\n    }\n    Ok(trimmed.to_owned())\n}\n","numLines":519,"startLine":1,"totalLines":519}}}
