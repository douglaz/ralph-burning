{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_015df2f5qaxYFzwWN6kqwihn","type":"tool_result","content":"     1→use clap::{Args, Subcommand};\n     2→\n     3→use crate::adapters::fs::{\n     4→    FsAmendmentQueueStore, FsArtifactStore, FsJournalStore, FsPayloadArtifactWriteStore,\n     5→    FsProjectStore, FsRawOutputStore, FsRollbackPointStore, FsRunSnapshotStore,\n     6→    FsRunSnapshotWriteStore, FsRuntimeLogStore, FsRuntimeLogWriteStore, FsSessionStore,\n     7→};\n     8→use crate::adapters::stub_backend::StubBackendAdapter;\n     9→use crate::adapters::worktree::WorktreeAdapter;\n    10→use crate::contexts::agent_execution::service::AgentExecutionService;\n    11→use crate::contexts::project_run_record::model::RunStatus;\n    12→use crate::contexts::project_run_record::service::{self, ProjectStorePort, RunSnapshotPort};\n    13→use crate::contexts::workflow_composition::engine;\n    14→use crate::contexts::workspace_governance;\n    15→use crate::contexts::workspace_governance::config::EffectiveConfig;\n    16→use crate::shared::domain::StageId;\n    17→use crate::shared::error::{AppError, AppResult};\n    18→\n    19→#[derive(Debug, Args)]\n    20→pub struct RunCommand {\n    21→    #[command(subcommand)]\n    22→    pub command: RunSubcommand,\n    23→}\n    24→\n    25→#[derive(Debug, Subcommand)]\n    26→pub enum RunSubcommand {\n    27→    Start,\n    28→    Resume,\n    29→    Status,\n    30→    History,\n    31→    Tail {\n    32→        #[arg(long)]\n    33→        logs: bool,\n    34→    },\n    35→    Rollback {\n    36→        #[arg(long)]\n    37→        to: String,\n    38→        #[arg(long)]\n    39→        hard: bool,\n    40→    },\n    41→}\n    42→\n    43→pub async fn handle(command: RunCommand) -> AppResult<()> {\n    44→    match command.command {\n    45→        RunSubcommand::Status => handle_status().await,\n    46→        RunSubcommand::History => handle_history().await,\n    47→        RunSubcommand::Tail { logs } => handle_tail(logs).await,\n    48→        RunSubcommand::Start => handle_start().await,\n    49→        RunSubcommand::Resume => handle_resume().await,\n    50→        RunSubcommand::Rollback { to, hard } => handle_rollback(to, hard).await,\n    51→    }\n    52→}\n    53→\n    54→pub fn build_agent_execution_service(\n    55→) -> AgentExecutionService<StubBackendAdapter, FsRawOutputStore, FsSessionStore> {\n    56→    let mut adapter = StubBackendAdapter::default();\n    57→\n    58→    // Test-only injection seam: environment variables configure the stub backend\n    59→    // to simulate failure modes that aren't reachable through normal CLI usage.\n    60→    if std::env::var(\"RALPH_BURNING_TEST_BACKEND_UNAVAILABLE\").is_ok() {\n    61→        adapter = adapter.unavailable();\n    62→    }\n    63→    if let Ok(stage_str) = std::env::var(\"RALPH_BURNING_TEST_FAIL_INVOKE_STAGE\") {\n    64→        if let Ok(stage_id) = stage_str.parse::<StageId>() {\n    65→            adapter = adapter.with_invoke_failure(stage_id);\n    66→        }\n    67→    }\n    68→    // Test-only seam: configure a stage to fail the first N invocations, then succeed.\n    69→    // Format: \"stage_id:count\" e.g. \"implementation:1\"\n    70→    if let Ok(spec) = std::env::var(\"RALPH_BURNING_TEST_TRANSIENT_FAILURE\") {\n    71→        if let Some((stage_str, count_str)) = spec.split_once(':') {\n    72→            if let (Ok(stage_id), Ok(count)) = (stage_str.parse::<StageId>(), count_str.parse::<u32>()) {\n    73→                adapter = adapter.with_transient_failure(stage_id, count);\n    74→            }\n    75→        }\n    76→    }\n    77→    // Test-only seam: JSON map from stage-id string to payload JSON.\n    78→    // Values may be a single object or an array of objects (payload sequence).\n    79→    // Example: {\"completion_panel\": {\"outcome\":\"conditionally_approved\",...}}\n    80→    // Example sequence: {\"qa\": [{\"outcome\":\"request_changes\",...}, {\"outcome\":\"approved\",...}]}\n    81→    if let Ok(overrides_json) = std::env::var(\"RALPH_BURNING_TEST_STAGE_OVERRIDES\") {\n    82→        if let Ok(overrides) =\n    83→            serde_json::from_str::<std::collections::HashMap<String, serde_json::Value>>(\n    84→                &overrides_json,\n    85→            )\n    86→        {\n    87→            for (stage_str, payload) in overrides {\n    88→                if let Ok(stage_id) = stage_str.parse::<StageId>() {\n    89→                    if let Some(arr) = payload.as_array() {\n    90→                        adapter = adapter.with_stage_payload_sequence(stage_id, arr.clone());\n    91→                    } else {\n    92→                        adapter = adapter.with_stage_payload(stage_id, payload);\n    93→                    }\n    94→                }\n    95→            }\n    96→        }\n    97→    }\n    98→\n    99→    AgentExecutionService::new(adapter, FsRawOutputStore, FsSessionStore)\n   100→}\n   101→\n   102→async fn handle_start() -> AppResult<()> {\n   103→    let current_dir = std::env::current_dir()?;\n   104→\n   105→    // Validate workspace version\n   106→    let config = workspace_governance::load_workspace_config(&current_dir)?;\n   107→    workspace_governance::ensure_supported_workspace_version(&config)?;\n   108→\n   109→    // Resolve active project\n   110→    let project_id = workspace_governance::resolve_active_project(&current_dir)?;\n   111→\n   112→    // Validate canonical project record\n   113→    let project_store = FsProjectStore;\n   114→    let project_record = project_store.read_project_record(&current_dir, &project_id)?;\n   115→\n   116→    // Validate run snapshot integrity\n   117→    let run_snapshot_read = FsRunSnapshotStore;\n   118→    let run_snapshot = run_snapshot_read.read_run_snapshot(&current_dir, &project_id)?;\n   119→\n   120→    // Check preconditions before engine call (fail fast with clear errors)\n   121→    match run_snapshot.status {\n   122→        RunStatus::NotStarted => {}\n   123→        RunStatus::Failed | RunStatus::Paused => {\n   124→            return Err(AppError::RunStartFailed {\n   125→                reason: format!(\n   126→                    \"project snapshot status is '{}'; use `ralph-burning run resume`\",\n   127→                    run_snapshot.status\n   128→                ),\n   129→            });\n   130→        }\n   131→        status => {\n   132→            return Err(AppError::RunStartFailed {\n   133→                reason: format!(\n   134→                    \"project snapshot status is '{}'; run start requires 'not_started'\",\n   135→                    status\n   136→                ),\n   137→            });\n   138→        }\n   139→    }\n   140→    if run_snapshot.has_active_run() {\n   141→        return Err(AppError::RunStartFailed {\n   142→            reason: \"project already has an active run\".to_owned(),\n   143→        });\n   144→    }\n   145→\n   146→    let effective_config = EffectiveConfig::load(&current_dir)?;\n   147→\n   148→    let agent_service = build_agent_execution_service();\n   149→    let run_snapshot_write = FsRunSnapshotWriteStore;\n   150→    let journal_store = FsJournalStore;\n   151→    let artifact_write = FsPayloadArtifactWriteStore;\n   152→    let log_write = FsRuntimeLogWriteStore;\n   153→\n   154→    println!(\"Starting run for project '{}'...\", project_id);\n   155→\n   156→    let amendment_queue = FsAmendmentQueueStore;\n   157→\n   158→    engine::execute_run(\n   159→        &agent_service,\n   160→        &run_snapshot_read,\n   161→        &run_snapshot_write,\n   162→        &journal_store,\n   163→        &artifact_write,\n   164→        &log_write,\n   165→        &amendment_queue,\n   166→        &current_dir,\n   167→        &project_id,\n   168→        project_record.flow,\n   169→        &effective_config,\n   170→    )\n   171→    .await?;\n   172→\n   173→    let final_snapshot = run_snapshot_read.read_run_snapshot(&current_dir, &project_id)?;\n   174→    match final_snapshot.status {\n   175→        RunStatus::Completed => println!(\"Run completed successfully.\"),\n   176→        RunStatus::Paused => println!(\"{}\", final_snapshot.status_summary),\n   177→        status => println!(\"Run finished with status '{}'.\", status),\n   178→    }\n   179→    Ok(())\n   180→}\n   181→\n   182→async fn handle_resume() -> AppResult<()> {\n   183→    let current_dir = std::env::current_dir()?;\n   184→\n   185→    let config = workspace_governance::load_workspace_config(&current_dir)?;\n   186→    workspace_governance::ensure_supported_workspace_version(&config)?;\n   187→\n   188→    let project_id = workspace_governance::resolve_active_project(&current_dir)?;\n   189→\n   190→    let project_store = FsProjectStore;\n   191→    let project_record = project_store.read_project_record(&current_dir, &project_id)?;\n   192→    let run_snapshot_read = FsRunSnapshotStore;\n   193→    let run_snapshot = run_snapshot_read.read_run_snapshot(&current_dir, &project_id)?;\n   194→    match run_snapshot.status {\n   195→        RunStatus::Failed | RunStatus::Paused => {}\n   196→        RunStatus::NotStarted => {\n   197→            return Err(AppError::ResumeFailed {\n   198→                reason: \"project has not started a run yet; use `ralph-burning run start`\"\n   199→                    .to_owned(),\n   200→            });\n   201→        }\n   202→        RunStatus::Running => {\n   203→            return Err(AppError::ResumeFailed {\n   204→                reason: \"project already has a running run; `run resume` only works from failed or paused snapshots\".to_owned(),\n   205→            });\n   206→        }\n   207→        RunStatus::Completed => {\n   208→            return Err(AppError::ResumeFailed {\n   209→                reason: \"project is already completed; there is nothing to resume\".to_owned(),\n   210→            });\n   211→        }\n   212→    }\n   213→    if run_snapshot.has_active_run() {\n   214→        return Err(AppError::ResumeFailed {\n   215→            reason: \"failed or paused snapshots must not retain an active run\".to_owned(),\n   216→        });\n   217→    }\n   218→\n   219→    let effective_config = EffectiveConfig::load(&current_dir)?;\n   220→    let agent_service = build_agent_execution_service();\n   221→    let run_snapshot_write = FsRunSnapshotWriteStore;\n   222→    let journal_store = FsJournalStore;\n   223→    let artifact_write = FsPayloadArtifactWriteStore;\n   224→    let log_write = FsRuntimeLogWriteStore;\n   225→\n   226→    println!(\"Resuming run for project '{}'...\", project_id);\n   227→\n   228→    let amendment_queue = FsAmendmentQueueStore;\n   229→\n   230→    engine::resume_run(\n   231→        &agent_service,\n   232→        &run_snapshot_read,\n   233→        &run_snapshot_write,\n   234→        &journal_store,\n   235→        &FsArtifactStore,\n   236→        &artifact_write,\n   237→        &log_write,\n   238→        &amendment_queue,\n   239→        &current_dir,\n   240→        &project_id,\n   241→        project_record.flow,\n   242→        &effective_config,\n   243→    )\n   244→    .await?;\n   245→\n   246→    let final_snapshot = run_snapshot_read.read_run_snapshot(&current_dir, &project_id)?;\n   247→    match final_snapshot.status {\n   248→        RunStatus::Completed => println!(\"Run completed successfully.\"),\n   249→        RunStatus::Paused => println!(\"{}\", final_snapshot.status_summary),\n   250→        status => println!(\"Run finished with status '{}'.\", status),\n   251→    }\n   252→\n   253→    Ok(())\n   254→}\n   255→\n   256→async fn handle_status() -> AppResult<()> {\n   257→    let current_dir = std::env::current_dir()?;\n   258→\n   259→    let config = workspace_governance::load_workspace_config(&current_dir)?;\n   260→    workspace_governance::ensure_supported_workspace_version(&config)?;\n   261→\n   262→    let project_id = workspace_governance::resolve_active_project(&current_dir)?;\n   263→\n   264→    // Validate canonical project record before proceeding with run queries\n   265→    let project_store = FsProjectStore;\n   266→    let _ = project_store.read_project_record(&current_dir, &project_id)?;\n   267→\n   268→    let run_store = FsRunSnapshotStore;\n   269→    let status = service::run_status(&run_store, &current_dir, &project_id)?;\n   270→\n   271→    println!(\"Project: {}\", status.project_id);\n   272→    println!(\"Status: {}\", status.status);\n   273→    if let Some(ref stage) = status.stage {\n   274→        println!(\"Stage: {}\", stage);\n   275→    }\n   276→    if let Some(cycle) = status.cycle {\n   277→        println!(\"Cycle: {}\", cycle);\n   278→    }\n   279→    if let Some(round) = status.completion_round {\n   280→        println!(\"Completion round: {}\", round);\n   281→    }\n   282→    println!(\"Summary: {}\", status.summary);\n   283→\n   284→    Ok(())\n   285→}\n   286→\n   287→async fn handle_history() -> AppResult<()> {\n   288→    let current_dir = std::env::current_dir()?;\n   289→\n   290→    let config = workspace_governance::load_workspace_config(&current_dir)?;\n   291→    workspace_governance::ensure_supported_workspace_version(&config)?;\n   292→\n   293→    let project_id = workspace_governance::resolve_active_project(&current_dir)?;\n   294→\n   295→    // Validate canonical project record before proceeding with run queries\n   296→    let project_store = FsProjectStore;\n   297→    let _ = project_store.read_project_record(&current_dir, &project_id)?;\n   298→\n   299→    let journal_store = FsJournalStore;\n   300→    let artifact_store = FsArtifactStore;\n   301→\n   302→    let history = service::run_history(&journal_store, &artifact_store, &current_dir, &project_id)?;\n   303→\n   304→    println!(\"Project: {}\", history.project_id);\n   305→    println!(\"--- Journal Events ---\");\n   306→    for event in &history.events {\n   307→        println!(\n   308→            \"  [{}] {} - {:?}\",\n   309→            event.sequence, event.timestamp, event.event_type\n   310→        );\n   311→    }\n   312→\n   313→    if !history.payloads.is_empty() {\n   314→        println!(\"--- Payloads ---\");\n   315→        for payload in &history.payloads {\n   316→            println!(\n   317→                \"  {} ({}, cycle {}, attempt {})\",\n   318→                payload.payload_id, payload.stage_id, payload.cycle, payload.attempt\n   319→            );\n   320→        }\n   321→    }\n   322→\n   323→    if !history.artifacts.is_empty() {\n   324→        println!(\"--- Artifacts ---\");\n   325→        for artifact in &history.artifacts {\n   326→            println!(\n   327→                \"  {} (payload: {}, stage: {})\",\n   328→                artifact.artifact_id, artifact.payload_id, artifact.stage_id\n   329→            );\n   330→        }\n   331→    }\n   332→\n   333→    Ok(())\n   334→}\n   335→\n   336→async fn handle_tail(include_logs: bool) -> AppResult<()> {\n   337→    let current_dir = std::env::current_dir()?;\n   338→\n   339→    let config = workspace_governance::load_workspace_config(&current_dir)?;\n   340→    workspace_governance::ensure_supported_workspace_version(&config)?;\n   341→\n   342→    let project_id = workspace_governance::resolve_active_project(&current_dir)?;\n   343→\n   344→    // Validate canonical project record before proceeding with run queries\n   345→    let project_store = FsProjectStore;\n   346→    let _ = project_store.read_project_record(&current_dir, &project_id)?;\n   347→\n   348→    let journal_store = FsJournalStore;\n   349→    let artifact_store = FsArtifactStore;\n   350→    let log_store = FsRuntimeLogStore;\n   351→\n   352→    let tail = service::run_tail(\n   353→        &journal_store,\n   354→        &artifact_store,\n   355→        &log_store,\n   356→        &current_dir,\n   357→        &project_id,\n   358→        include_logs,\n   359→    )?;\n   360→\n   361→    println!(\"Project: {}\", tail.project_id);\n   362→    println!(\"--- Durable History ---\");\n   363→    for event in &tail.events {\n   364→        println!(\n   365→            \"  [{}] {} - {:?}\",\n   366→            event.sequence, event.timestamp, event.event_type\n   367→        );\n   368→    }\n   369→\n   370→    if !tail.payloads.is_empty() {\n   371→        println!(\"--- Payloads ---\");\n   372→        for payload in &tail.payloads {\n   373→            println!(\n   374→                \"  {} ({}, cycle {}, attempt {})\",\n   375→                payload.payload_id, payload.stage_id, payload.cycle, payload.attempt\n   376→            );\n   377→        }\n   378→    }\n   379→\n   380→    if !tail.artifacts.is_empty() {\n   381→        println!(\"--- Artifacts ---\");\n   382→        for artifact in &tail.artifacts {\n   383→            println!(\n   384→                \"  {} (payload: {}, stage: {})\",\n   385→                artifact.artifact_id, artifact.payload_id, artifact.stage_id\n   386→            );\n   387→        }\n   388→    }\n   389→\n   390→    if let Some(ref logs) = tail.runtime_logs {\n   391→        println!(\"--- Runtime Logs ---\");\n   392→        if logs.is_empty() {\n   393→            println!(\"  (no runtime logs)\");\n   394→        } else {\n   395→            for log in logs {\n   396→                println!(\n   397→                    \"  [{}] {:?} [{}] {}\",\n   398→                    log.timestamp, log.level, log.source, log.message\n   399→                );\n   400→            }\n   401→        }\n   402→    }\n   403→\n   404→    Ok(())\n   405→}\n   406→\n   407→async fn handle_rollback(target: String, hard: bool) -> AppResult<()> {\n   408→    let current_dir = std::env::current_dir()?;\n   409→\n   410→    let config = workspace_governance::load_workspace_config(&current_dir)?;\n   411→    workspace_governance::ensure_supported_workspace_version(&config)?;\n   412→\n   413→    let project_id = workspace_governance::resolve_active_project(&current_dir)?;\n   414→\n   415→    let project_store = FsProjectStore;\n   416→    let project_record = project_store.read_project_record(&current_dir, &project_id)?;\n   417→\n   418→    let target_stage = match target.parse::<StageId>() {\n   419→        Ok(stage_id) => stage_id,\n   420→        Err(_) => {\n   421→            return Err(AppError::RollbackStageNotInFlow {\n   422→                project_id: project_id.to_string(),\n   423→                stage_id: target,\n   424→                flow: project_record.flow.to_string(),\n   425→            });\n   426→        }\n   427→    };\n   428→\n   429→    let rollback_point = service::perform_rollback(\n   430→        &FsRunSnapshotStore,\n   431→        &FsRunSnapshotWriteStore,\n   432→        &FsJournalStore,\n   433→        &FsRollbackPointStore,\n   434→        Some(&WorktreeAdapter),\n   435→        &current_dir,\n   436→        &project_id,\n   437→        project_record.flow,\n   438→        target_stage,\n   439→        hard,\n   440→    )?;\n   441→\n   442→    println!(\n   443→        \"Rollback complete: project '{}' paused at {} cycle {}.\",\n   444→        project_id, rollback_point.stage_id, rollback_point.cycle\n   445→    );\n   446→    if hard {\n   447→        println!(\"Repository reset to recorded git SHA.\");\n   448→    }\n   449→\n   450→    Ok(())\n   451→}\n   452→"}]},"parent_tool_use_id":null,"session_id":"4f5afce8-7057-46f6-9d3e-09a7997db51f","uuid":"4845299e-4313-4872-a531-23078070200d","tool_use_result":{"type":"text","file":{"filePath":"/root/new-ralph-burning/ralph-burning-rewrite/src/cli/run.rs","content":"use clap::{Args, Subcommand};\n\nuse crate::adapters::fs::{\n    FsAmendmentQueueStore, FsArtifactStore, FsJournalStore, FsPayloadArtifactWriteStore,\n    FsProjectStore, FsRawOutputStore, FsRollbackPointStore, FsRunSnapshotStore,\n    FsRunSnapshotWriteStore, FsRuntimeLogStore, FsRuntimeLogWriteStore, FsSessionStore,\n};\nuse crate::adapters::stub_backend::StubBackendAdapter;\nuse crate::adapters::worktree::WorktreeAdapter;\nuse crate::contexts::agent_execution::service::AgentExecutionService;\nuse crate::contexts::project_run_record::model::RunStatus;\nuse crate::contexts::project_run_record::service::{self, ProjectStorePort, RunSnapshotPort};\nuse crate::contexts::workflow_composition::engine;\nuse crate::contexts::workspace_governance;\nuse crate::contexts::workspace_governance::config::EffectiveConfig;\nuse crate::shared::domain::StageId;\nuse crate::shared::error::{AppError, AppResult};\n\n#[derive(Debug, Args)]\npub struct RunCommand {\n    #[command(subcommand)]\n    pub command: RunSubcommand,\n}\n\n#[derive(Debug, Subcommand)]\npub enum RunSubcommand {\n    Start,\n    Resume,\n    Status,\n    History,\n    Tail {\n        #[arg(long)]\n        logs: bool,\n    },\n    Rollback {\n        #[arg(long)]\n        to: String,\n        #[arg(long)]\n        hard: bool,\n    },\n}\n\npub async fn handle(command: RunCommand) -> AppResult<()> {\n    match command.command {\n        RunSubcommand::Status => handle_status().await,\n        RunSubcommand::History => handle_history().await,\n        RunSubcommand::Tail { logs } => handle_tail(logs).await,\n        RunSubcommand::Start => handle_start().await,\n        RunSubcommand::Resume => handle_resume().await,\n        RunSubcommand::Rollback { to, hard } => handle_rollback(to, hard).await,\n    }\n}\n\npub fn build_agent_execution_service(\n) -> AgentExecutionService<StubBackendAdapter, FsRawOutputStore, FsSessionStore> {\n    let mut adapter = StubBackendAdapter::default();\n\n    // Test-only injection seam: environment variables configure the stub backend\n    // to simulate failure modes that aren't reachable through normal CLI usage.\n    if std::env::var(\"RALPH_BURNING_TEST_BACKEND_UNAVAILABLE\").is_ok() {\n        adapter = adapter.unavailable();\n    }\n    if let Ok(stage_str) = std::env::var(\"RALPH_BURNING_TEST_FAIL_INVOKE_STAGE\") {\n        if let Ok(stage_id) = stage_str.parse::<StageId>() {\n            adapter = adapter.with_invoke_failure(stage_id);\n        }\n    }\n    // Test-only seam: configure a stage to fail the first N invocations, then succeed.\n    // Format: \"stage_id:count\" e.g. \"implementation:1\"\n    if let Ok(spec) = std::env::var(\"RALPH_BURNING_TEST_TRANSIENT_FAILURE\") {\n        if let Some((stage_str, count_str)) = spec.split_once(':') {\n            if let (Ok(stage_id), Ok(count)) = (stage_str.parse::<StageId>(), count_str.parse::<u32>()) {\n                adapter = adapter.with_transient_failure(stage_id, count);\n            }\n        }\n    }\n    // Test-only seam: JSON map from stage-id string to payload JSON.\n    // Values may be a single object or an array of objects (payload sequence).\n    // Example: {\"completion_panel\": {\"outcome\":\"conditionally_approved\",...}}\n    // Example sequence: {\"qa\": [{\"outcome\":\"request_changes\",...}, {\"outcome\":\"approved\",...}]}\n    if let Ok(overrides_json) = std::env::var(\"RALPH_BURNING_TEST_STAGE_OVERRIDES\") {\n        if let Ok(overrides) =\n            serde_json::from_str::<std::collections::HashMap<String, serde_json::Value>>(\n                &overrides_json,\n            )\n        {\n            for (stage_str, payload) in overrides {\n                if let Ok(stage_id) = stage_str.parse::<StageId>() {\n                    if let Some(arr) = payload.as_array() {\n                        adapter = adapter.with_stage_payload_sequence(stage_id, arr.clone());\n                    } else {\n                        adapter = adapter.with_stage_payload(stage_id, payload);\n                    }\n                }\n            }\n        }\n    }\n\n    AgentExecutionService::new(adapter, FsRawOutputStore, FsSessionStore)\n}\n\nasync fn handle_start() -> AppResult<()> {\n    let current_dir = std::env::current_dir()?;\n\n    // Validate workspace version\n    let config = workspace_governance::load_workspace_config(&current_dir)?;\n    workspace_governance::ensure_supported_workspace_version(&config)?;\n\n    // Resolve active project\n    let project_id = workspace_governance::resolve_active_project(&current_dir)?;\n\n    // Validate canonical project record\n    let project_store = FsProjectStore;\n    let project_record = project_store.read_project_record(&current_dir, &project_id)?;\n\n    // Validate run snapshot integrity\n    let run_snapshot_read = FsRunSnapshotStore;\n    let run_snapshot = run_snapshot_read.read_run_snapshot(&current_dir, &project_id)?;\n\n    // Check preconditions before engine call (fail fast with clear errors)\n    match run_snapshot.status {\n        RunStatus::NotStarted => {}\n        RunStatus::Failed | RunStatus::Paused => {\n            return Err(AppError::RunStartFailed {\n                reason: format!(\n                    \"project snapshot status is '{}'; use `ralph-burning run resume`\",\n                    run_snapshot.status\n                ),\n            });\n        }\n        status => {\n            return Err(AppError::RunStartFailed {\n                reason: format!(\n                    \"project snapshot status is '{}'; run start requires 'not_started'\",\n                    status\n                ),\n            });\n        }\n    }\n    if run_snapshot.has_active_run() {\n        return Err(AppError::RunStartFailed {\n            reason: \"project already has an active run\".to_owned(),\n        });\n    }\n\n    let effective_config = EffectiveConfig::load(&current_dir)?;\n\n    let agent_service = build_agent_execution_service();\n    let run_snapshot_write = FsRunSnapshotWriteStore;\n    let journal_store = FsJournalStore;\n    let artifact_write = FsPayloadArtifactWriteStore;\n    let log_write = FsRuntimeLogWriteStore;\n\n    println!(\"Starting run for project '{}'...\", project_id);\n\n    let amendment_queue = FsAmendmentQueueStore;\n\n    engine::execute_run(\n        &agent_service,\n        &run_snapshot_read,\n        &run_snapshot_write,\n        &journal_store,\n        &artifact_write,\n        &log_write,\n        &amendment_queue,\n        &current_dir,\n        &project_id,\n        project_record.flow,\n        &effective_config,\n    )\n    .await?;\n\n    let final_snapshot = run_snapshot_read.read_run_snapshot(&current_dir, &project_id)?;\n    match final_snapshot.status {\n        RunStatus::Completed => println!(\"Run completed successfully.\"),\n        RunStatus::Paused => println!(\"{}\", final_snapshot.status_summary),\n        status => println!(\"Run finished with status '{}'.\", status),\n    }\n    Ok(())\n}\n\nasync fn handle_resume() -> AppResult<()> {\n    let current_dir = std::env::current_dir()?;\n\n    let config = workspace_governance::load_workspace_config(&current_dir)?;\n    workspace_governance::ensure_supported_workspace_version(&config)?;\n\n    let project_id = workspace_governance::resolve_active_project(&current_dir)?;\n\n    let project_store = FsProjectStore;\n    let project_record = project_store.read_project_record(&current_dir, &project_id)?;\n    let run_snapshot_read = FsRunSnapshotStore;\n    let run_snapshot = run_snapshot_read.read_run_snapshot(&current_dir, &project_id)?;\n    match run_snapshot.status {\n        RunStatus::Failed | RunStatus::Paused => {}\n        RunStatus::NotStarted => {\n            return Err(AppError::ResumeFailed {\n                reason: \"project has not started a run yet; use `ralph-burning run start`\"\n                    .to_owned(),\n            });\n        }\n        RunStatus::Running => {\n            return Err(AppError::ResumeFailed {\n                reason: \"project already has a running run; `run resume` only works from failed or paused snapshots\".to_owned(),\n            });\n        }\n        RunStatus::Completed => {\n            return Err(AppError::ResumeFailed {\n                reason: \"project is already completed; there is nothing to resume\".to_owned(),\n            });\n        }\n    }\n    if run_snapshot.has_active_run() {\n        return Err(AppError::ResumeFailed {\n            reason: \"failed or paused snapshots must not retain an active run\".to_owned(),\n        });\n    }\n\n    let effective_config = EffectiveConfig::load(&current_dir)?;\n    let agent_service = build_agent_execution_service();\n    let run_snapshot_write = FsRunSnapshotWriteStore;\n    let journal_store = FsJournalStore;\n    let artifact_write = FsPayloadArtifactWriteStore;\n    let log_write = FsRuntimeLogWriteStore;\n\n    println!(\"Resuming run for project '{}'...\", project_id);\n\n    let amendment_queue = FsAmendmentQueueStore;\n\n    engine::resume_run(\n        &agent_service,\n        &run_snapshot_read,\n        &run_snapshot_write,\n        &journal_store,\n        &FsArtifactStore,\n        &artifact_write,\n        &log_write,\n        &amendment_queue,\n        &current_dir,\n        &project_id,\n        project_record.flow,\n        &effective_config,\n    )\n    .await?;\n\n    let final_snapshot = run_snapshot_read.read_run_snapshot(&current_dir, &project_id)?;\n    match final_snapshot.status {\n        RunStatus::Completed => println!(\"Run completed successfully.\"),\n        RunStatus::Paused => println!(\"{}\", final_snapshot.status_summary),\n        status => println!(\"Run finished with status '{}'.\", status),\n    }\n\n    Ok(())\n}\n\nasync fn handle_status() -> AppResult<()> {\n    let current_dir = std::env::current_dir()?;\n\n    let config = workspace_governance::load_workspace_config(&current_dir)?;\n    workspace_governance::ensure_supported_workspace_version(&config)?;\n\n    let project_id = workspace_governance::resolve_active_project(&current_dir)?;\n\n    // Validate canonical project record before proceeding with run queries\n    let project_store = FsProjectStore;\n    let _ = project_store.read_project_record(&current_dir, &project_id)?;\n\n    let run_store = FsRunSnapshotStore;\n    let status = service::run_status(&run_store, &current_dir, &project_id)?;\n\n    println!(\"Project: {}\", status.project_id);\n    println!(\"Status: {}\", status.status);\n    if let Some(ref stage) = status.stage {\n        println!(\"Stage: {}\", stage);\n    }\n    if let Some(cycle) = status.cycle {\n        println!(\"Cycle: {}\", cycle);\n    }\n    if let Some(round) = status.completion_round {\n        println!(\"Completion round: {}\", round);\n    }\n    println!(\"Summary: {}\", status.summary);\n\n    Ok(())\n}\n\nasync fn handle_history() -> AppResult<()> {\n    let current_dir = std::env::current_dir()?;\n\n    let config = workspace_governance::load_workspace_config(&current_dir)?;\n    workspace_governance::ensure_supported_workspace_version(&config)?;\n\n    let project_id = workspace_governance::resolve_active_project(&current_dir)?;\n\n    // Validate canonical project record before proceeding with run queries\n    let project_store = FsProjectStore;\n    let _ = project_store.read_project_record(&current_dir, &project_id)?;\n\n    let journal_store = FsJournalStore;\n    let artifact_store = FsArtifactStore;\n\n    let history = service::run_history(&journal_store, &artifact_store, &current_dir, &project_id)?;\n\n    println!(\"Project: {}\", history.project_id);\n    println!(\"--- Journal Events ---\");\n    for event in &history.events {\n        println!(\n            \"  [{}] {} - {:?}\",\n            event.sequence, event.timestamp, event.event_type\n        );\n    }\n\n    if !history.payloads.is_empty() {\n        println!(\"--- Payloads ---\");\n        for payload in &history.payloads {\n            println!(\n                \"  {} ({}, cycle {}, attempt {})\",\n                payload.payload_id, payload.stage_id, payload.cycle, payload.attempt\n            );\n        }\n    }\n\n    if !history.artifacts.is_empty() {\n        println!(\"--- Artifacts ---\");\n        for artifact in &history.artifacts {\n            println!(\n                \"  {} (payload: {}, stage: {})\",\n                artifact.artifact_id, artifact.payload_id, artifact.stage_id\n            );\n        }\n    }\n\n    Ok(())\n}\n\nasync fn handle_tail(include_logs: bool) -> AppResult<()> {\n    let current_dir = std::env::current_dir()?;\n\n    let config = workspace_governance::load_workspace_config(&current_dir)?;\n    workspace_governance::ensure_supported_workspace_version(&config)?;\n\n    let project_id = workspace_governance::resolve_active_project(&current_dir)?;\n\n    // Validate canonical project record before proceeding with run queries\n    let project_store = FsProjectStore;\n    let _ = project_store.read_project_record(&current_dir, &project_id)?;\n\n    let journal_store = FsJournalStore;\n    let artifact_store = FsArtifactStore;\n    let log_store = FsRuntimeLogStore;\n\n    let tail = service::run_tail(\n        &journal_store,\n        &artifact_store,\n        &log_store,\n        &current_dir,\n        &project_id,\n        include_logs,\n    )?;\n\n    println!(\"Project: {}\", tail.project_id);\n    println!(\"--- Durable History ---\");\n    for event in &tail.events {\n        println!(\n            \"  [{}] {} - {:?}\",\n            event.sequence, event.timestamp, event.event_type\n        );\n    }\n\n    if !tail.payloads.is_empty() {\n        println!(\"--- Payloads ---\");\n        for payload in &tail.payloads {\n            println!(\n                \"  {} ({}, cycle {}, attempt {})\",\n                payload.payload_id, payload.stage_id, payload.cycle, payload.attempt\n            );\n        }\n    }\n\n    if !tail.artifacts.is_empty() {\n        println!(\"--- Artifacts ---\");\n        for artifact in &tail.artifacts {\n            println!(\n                \"  {} (payload: {}, stage: {})\",\n                artifact.artifact_id, artifact.payload_id, artifact.stage_id\n            );\n        }\n    }\n\n    if let Some(ref logs) = tail.runtime_logs {\n        println!(\"--- Runtime Logs ---\");\n        if logs.is_empty() {\n            println!(\"  (no runtime logs)\");\n        } else {\n            for log in logs {\n                println!(\n                    \"  [{}] {:?} [{}] {}\",\n                    log.timestamp, log.level, log.source, log.message\n                );\n            }\n        }\n    }\n\n    Ok(())\n}\n\nasync fn handle_rollback(target: String, hard: bool) -> AppResult<()> {\n    let current_dir = std::env::current_dir()?;\n\n    let config = workspace_governance::load_workspace_config(&current_dir)?;\n    workspace_governance::ensure_supported_workspace_version(&config)?;\n\n    let project_id = workspace_governance::resolve_active_project(&current_dir)?;\n\n    let project_store = FsProjectStore;\n    let project_record = project_store.read_project_record(&current_dir, &project_id)?;\n\n    let target_stage = match target.parse::<StageId>() {\n        Ok(stage_id) => stage_id,\n        Err(_) => {\n            return Err(AppError::RollbackStageNotInFlow {\n                project_id: project_id.to_string(),\n                stage_id: target,\n                flow: project_record.flow.to_string(),\n            });\n        }\n    };\n\n    let rollback_point = service::perform_rollback(\n        &FsRunSnapshotStore,\n        &FsRunSnapshotWriteStore,\n        &FsJournalStore,\n        &FsRollbackPointStore,\n        Some(&WorktreeAdapter),\n        &current_dir,\n        &project_id,\n        project_record.flow,\n        target_stage,\n        hard,\n    )?;\n\n    println!(\n        \"Rollback complete: project '{}' paused at {} cycle {}.\",\n        project_id, rollback_point.stage_id, rollback_point.cycle\n    );\n    if hard {\n        println!(\"Repository reset to recorded git SHA.\");\n    }\n\n    Ok(())\n}\n","numLines":452,"startLine":1,"totalLines":452}}}
