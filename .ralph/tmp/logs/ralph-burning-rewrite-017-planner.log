{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01EYFnFFi9yXBV7ssryeQ27q","type":"tool_result","content":"     1→use std::path::Path;\n     2→\n     3→use crate::shared::error::{AppError, AppResult};\n     4→\n     5→use super::model::{DispatchMode, WatchedIssueMeta};\n     6→use super::routing::RoutingEngine;\n     7→use crate::shared::domain::FlowPreset;\n     8→\n     9→/// Port trait for watching external issue sources.\n    10→///\n    11→/// Implementations poll an external source (e.g. GitHub issues, files) and\n    12→/// return candidate issues that should be ingested as daemon tasks.\n    13→pub trait IssueWatcherPort {\n    14→    /// Poll the external source and return watched issue candidates.\n    15→    fn poll(&self, base_dir: &Path) -> AppResult<Vec<WatchedIssueMeta>>;\n    16→}\n    17→\n    18→/// Parse a requirements command from issue body or routing command.\n    19→///\n    20→/// Accepts:\n    21→/// - `/rb requirements draft`\n    22→/// - `/rb requirements quick`\n    23→///\n    24→/// Returns `None` if the text does not contain a requirements command,\n    25→/// allowing the caller to default to `DispatchMode::Workflow`.\n    26→///\n    27→/// Returns `Err` for malformed requirements commands (e.g. `/rb requirements`\n    28→/// without a subcommand, unknown subcommands, or extra tokens).\n    29→pub fn parse_requirements_command(text: &str) -> AppResult<Option<DispatchMode>> {\n    30→    for line in text.lines() {\n    31→        let trimmed = line.trim();\n    32→        let tokens: Vec<&str> = trimmed.split_whitespace().collect();\n    33→        if tokens.len() >= 2\n    34→            && matches!(tokens[0], \"/rb\" | \"rb\")\n    35→            && tokens[1] == \"requirements\"\n    36→        {\n    37→            if tokens.len() == 3 {\n    38→                return match tokens[2] {\n    39→                    \"draft\" => Ok(Some(DispatchMode::RequirementsDraft)),\n    40→                    \"quick\" => Ok(Some(DispatchMode::RequirementsQuick)),\n    41→                    other => Err(AppError::WatcherIngestionFailed {\n    42→                        issue_ref: trimmed.to_owned(),\n    43→                        details: format!(\n    44→                            \"unknown requirements subcommand '{}'; expected 'draft' or 'quick'\",\n    45→                            other\n    46→                        ),\n    47→                    }),\n    48→                };\n    49→            }\n    50→            // Malformed: missing subcommand or extra tokens\n    51→            return Err(AppError::WatcherIngestionFailed {\n    52→                issue_ref: trimmed.to_owned(),\n    53→                details: \"malformed requirements command; expected '/rb requirements draft' or '/rb requirements quick'\".to_owned(),\n    54→            });\n    55→        }\n    56→    }\n    57→    Ok(None)\n    58→}\n    59→\n    60→/// Check if a routing command string is a requirements command (not a flow command).\n    61→/// Used to prevent requirements commands from being passed to flow routing.\n    62→pub fn is_requirements_command(text: &str) -> bool {\n    63→    let tokens: Vec<&str> = text.trim().split_whitespace().collect();\n    64→    tokens.len() >= 2\n    65→        && matches!(tokens[0], \"/rb\" | \"rb\")\n    66→        && tokens[1] == \"requirements\"\n    67→}\n    68→\n    69→/// Resolve the dispatch mode for a watched issue.\n    70→///\n    71→/// Checks the routing command first, then the issue body for `/rb requirements ...`.\n    72→/// Falls back to `DispatchMode::Workflow` if no requirements command is found.\n    73→pub fn resolve_dispatch_mode(issue: &WatchedIssueMeta) -> AppResult<DispatchMode> {\n    74→    // Check routing command first\n    75→    if let Some(ref cmd) = issue.routing_command {\n    76→        if let Some(mode) = parse_requirements_command(cmd)? {\n    77→            return Ok(mode);\n    78→        }\n    79→    }\n    80→    // Check issue body\n    81→    if let Some(mode) = parse_requirements_command(&issue.body)? {\n    82→        return Ok(mode);\n    83→    }\n    84→    Ok(DispatchMode::Workflow)\n    85→}\n    86→\n    87→/// Resolve flow from watched issue metadata using the routing engine.\n    88→pub fn resolve_watched_issue_flow(\n    89→    issue: &WatchedIssueMeta,\n    90→    routing_engine: &RoutingEngine,\n    91→    default_flow: FlowPreset,\n    92→) -> AppResult<super::model::RoutingResolution> {\n    93→    routing_engine.resolve_flow(\n    94→        issue.routing_command.as_deref(),\n    95→        &issue.labels,\n    96→        default_flow,\n    97→    )\n    98→}\n    99→"}]},"parent_tool_use_id":"toolu_0145Rc2QGKK9EbsU232znhmJ","session_id":"788958e9-d311-45c0-a75a-a22258565011","uuid":"4d59c7da-b838-433d-b6b4-c44e9e6e342a"}
