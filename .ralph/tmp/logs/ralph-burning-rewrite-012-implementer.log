{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01W6WAHKoRz9qudydAAnePGS","type":"tool_result","content":"     1→use clap::{Args, Subcommand};\n     2→\n     3→use crate::contexts::workflow_composition::{built_in_flows, flow_definition_by_id};\n     4→use crate::shared::error::AppResult;\n     5→\n     6→#[derive(Debug, Args)]\n     7→pub struct FlowCommand {\n     8→    #[command(subcommand)]\n     9→    pub command: FlowSubcommand,\n    10→}\n    11→\n    12→#[derive(Debug, Subcommand)]\n    13→pub enum FlowSubcommand {\n    14→    List,\n    15→    Show { flow_id: String },\n    16→}\n    17→\n    18→pub async fn handle(command: FlowCommand) -> AppResult<()> {\n    19→    match command.command {\n    20→        FlowSubcommand::List => {\n    21→            for definition in built_in_flows() {\n    22→                println!(\"{} - {}\", definition.preset, definition.description);\n    23→            }\n    24→            Ok(())\n    25→        }\n    26→        FlowSubcommand::Show { flow_id } => {\n    27→            let definition = flow_definition_by_id(&flow_id)?;\n    28→            println!(\"Flow: {}\", definition.preset);\n    29→            println!(\"Description: {}\", definition.description);\n    30→            println!(\n    31→                \"Validation profile: {} ({})\",\n    32→                definition.validation_profile.name, definition.validation_profile.summary\n    33→            );\n    34→            println!(\n    35→                \"Final review enabled: {}\",\n    36→                if definition.validation_profile.final_review_enabled {\n    37→                    \"yes\"\n    38→                } else {\n    39→                    \"no\"\n    40→                }\n    41→            );\n    42→            println!(\"Stage count: {}\", definition.stages.len());\n    43→            println!();\n    44→            println!(\"Stages:\");\n    45→            for (index, stage) in definition.stages.iter().enumerate() {\n    46→                println!(\"{}. {}\", index + 1, stage);\n    47→            }\n    48→            Ok(())\n    49→        }\n    50→    }\n    51→}\n    52→"}]},"parent_tool_use_id":"toolu_01GmHc9N8Srjnat2yn1mzYfx","session_id":"216e97eb-aa57-41df-a04f-9831b7c2815e","uuid":"cbff7193-4dad-4702-9b51-53ce5e3b0706"}
