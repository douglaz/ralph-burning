{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01CLsiSs81AteFSGTDk6cEzy","type":"tool_result","content":"     1→use ralph_burning::contexts::workflow_composition::{flow_semantics, stage_plan_for_flow};\n     2→use ralph_burning::shared::domain::{FlowPreset, StageId};\n     3→\n     4→#[test]\n     5→fn standard_flow_semantics_match_spec() {\n     6→    let semantics = flow_semantics(FlowPreset::Standard);\n     7→\n     8→    assert_eq!(semantics.planning_stage, StageId::Planning);\n     9→    assert_eq!(semantics.execution_stage, StageId::Implementation);\n    10→    assert_eq!(\n    11→        semantics.remediation_trigger_stages,\n    12→        &[StageId::Qa, StageId::Review]\n    13→    );\n    14→    assert_eq!(\n    15→        semantics.late_stages,\n    16→        &[\n    17→            StageId::CompletionPanel,\n    18→            StageId::AcceptanceQa,\n    19→            StageId::FinalReview,\n    20→        ]\n    21→    );\n    22→    assert_eq!(semantics.prompt_review_stage, Some(StageId::PromptReview));\n    23→}\n    24→\n    25→#[test]\n    26→fn quick_dev_flow_semantics_are_defined() {\n    27→    let semantics = flow_semantics(FlowPreset::QuickDev);\n    28→\n    29→    assert_eq!(semantics.planning_stage, StageId::PlanAndImplement);\n    30→    assert_eq!(semantics.execution_stage, StageId::ApplyFixes);\n    31→    assert_eq!(semantics.remediation_trigger_stages, &[StageId::Review]);\n    32→    assert_eq!(semantics.late_stages, &[StageId::FinalReview]);\n    33→    assert_eq!(semantics.prompt_review_stage, None);\n    34→}\n    35→\n    36→#[test]\n    37→fn docs_change_flow_semantics_match_spec() {\n    38→    let semantics = flow_semantics(FlowPreset::DocsChange);\n    39→\n    40→    assert_eq!(semantics.planning_stage, StageId::DocsPlan);\n    41→    assert_eq!(semantics.execution_stage, StageId::DocsUpdate);\n    42→    assert_eq!(\n    43→        semantics.remediation_trigger_stages,\n    44→        &[StageId::DocsValidation, StageId::Review]\n    45→    );\n    46→    assert!(semantics.late_stages.is_empty());\n    47→    assert_eq!(semantics.prompt_review_stage, None);\n    48→}\n    49→\n    50→#[test]\n    51→fn ci_improvement_flow_semantics_match_spec() {\n    52→    let semantics = flow_semantics(FlowPreset::CiImprovement);\n    53→\n    54→    assert_eq!(semantics.planning_stage, StageId::CiPlan);\n    55→    assert_eq!(semantics.execution_stage, StageId::CiUpdate);\n    56→    assert_eq!(\n    57→        semantics.remediation_trigger_stages,\n    58→        &[StageId::CiValidation, StageId::Review]\n    59→    );\n    60→    assert!(semantics.late_stages.is_empty());\n    61→    assert_eq!(semantics.prompt_review_stage, None);\n    62→}\n    63→\n    64→#[test]\n    65→fn standard_stage_plan_for_flow_honors_prompt_review_toggle() {\n    66→    assert_eq!(\n    67→        stage_plan_for_flow(FlowPreset::Standard, true),\n    68→        vec![\n    69→            StageId::PromptReview,\n    70→            StageId::Planning,\n    71→            StageId::Implementation,\n    72→            StageId::Qa,\n    73→            StageId::Review,\n    74→            StageId::CompletionPanel,\n    75→            StageId::AcceptanceQa,\n    76→            StageId::FinalReview,\n    77→        ]\n    78→    );\n    79→    assert_eq!(\n    80→        stage_plan_for_flow(FlowPreset::Standard, false),\n    81→        vec![\n    82→            StageId::Planning,\n    83→            StageId::Implementation,\n    84→            StageId::Qa,\n    85→            StageId::Review,\n    86→            StageId::CompletionPanel,\n    87→            StageId::AcceptanceQa,\n    88→            StageId::FinalReview,\n    89→        ]\n    90→    );\n    91→}\n    92→\n    93→#[test]\n    94→fn non_standard_stage_plans_ignore_prompt_review_toggle() {\n    95→    assert_eq!(\n    96→        stage_plan_for_flow(FlowPreset::DocsChange, true),\n    97→        stage_plan_for_flow(FlowPreset::DocsChange, false)\n    98→    );\n    99→    assert_eq!(\n   100→        stage_plan_for_flow(FlowPreset::CiImprovement, true),\n   101→        stage_plan_for_flow(FlowPreset::CiImprovement, false)\n   102→    );\n   103→}\n   104→"}]},"parent_tool_use_id":"toolu_01GmHc9N8Srjnat2yn1mzYfx","session_id":"216e97eb-aa57-41df-a04f-9831b7c2815e","uuid":"96205336-8077-4564-b716-3023fccad6ff"}
