{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Cbrjx8bwNKksCNx2Cn4VVA","type":"tool_result","content":"     1→#![forbid(unsafe_code)]\n     2→\n     3→//! Structured contracts for requirements stages.\n     4→//!\n     5→//! Follows the same invariant as workflow stage contracts:\n     6→//! 1. Schema validation (JSON → typed payload via serde)\n     7→//! 2. Domain validation (semantic rules)\n     8→//! 3. Rendering (deterministic Markdown artifact)\n     9→//!\n    10→//! Rendered Markdown is never parsed for control flow.\n    11→\n    12→use crate::shared::domain::FlowPreset;\n    13→use crate::shared::error::ContractError;\n    14→\n    15→use super::model::{\n    16→    ProjectSeedPayload, QuestionSetPayload, RequirementsDraftPayload, RequirementsReviewOutcome,\n    17→    RequirementsReviewPayload, RequirementsStageId,\n    18→};\n    19→use super::renderers;\n    20→\n    21→/// A validated requirements contract output.\n    22→#[derive(Debug, Clone, PartialEq, Eq)]\n    23→pub struct RequirementsValidatedBundle {\n    24→    pub payload: RequirementsPayload,\n    25→    pub artifact: String,\n    26→}\n    27→\n    28→/// Typed requirements payload wrapper.\n    29→#[derive(Debug, Clone, PartialEq, Eq)]\n    30→pub enum RequirementsPayload {\n    31→    QuestionSet(QuestionSetPayload),\n    32→    Draft(RequirementsDraftPayload),\n    33→    Review(RequirementsReviewPayload),\n    34→    Seed(ProjectSeedPayload),\n    35→}\n    36→\n    37→/// Requirements contract binding a stage to its validation and rendering.\n    38→#[derive(Debug, Clone, Copy, PartialEq, Eq)]\n    39→pub struct RequirementsContract {\n    40→    pub stage_id: RequirementsStageId,\n    41→}\n    42→\n    43→impl RequirementsContract {\n    44→    pub fn question_set() -> Self {\n    45→        Self {\n    46→            stage_id: RequirementsStageId::QuestionSet,\n    47→        }\n    48→    }\n    49→\n    50→    pub fn draft() -> Self {\n    51→        Self {\n    52→            stage_id: RequirementsStageId::RequirementsDraft,\n    53→        }\n    54→    }\n    55→\n    56→    pub fn review() -> Self {\n    57→        Self {\n    58→            stage_id: RequirementsStageId::RequirementsReview,\n    59→        }\n    60→    }\n    61→\n    62→    pub fn seed() -> Self {\n    63→        Self {\n    64→            stage_id: RequirementsStageId::ProjectSeed,\n    65→        }\n    66→    }\n    67→\n    68→    /// Evaluate a raw JSON value through schema → domain → render.\n    69→    pub fn evaluate(\n    70→        &self,\n    71→        raw_json: &serde_json::Value,\n    72→    ) -> Result<RequirementsValidatedBundle, ContractError> {\n    73→        let payload = self.validate_schema(raw_json)?;\n    74→        self.validate_semantics(&payload)?;\n    75→        let artifact = self.render(&payload);\n    76→        Ok(RequirementsValidatedBundle { payload, artifact })\n    77→    }\n    78→\n    79→    fn validate_schema(\n    80→        &self,\n    81→        raw: &serde_json::Value,\n    82→    ) -> Result<RequirementsPayload, ContractError> {\n    83→        match self.stage_id {\n    84→            RequirementsStageId::QuestionSet => {\n    85→                let p: QuestionSetPayload = serde_json::from_value(raw.clone()).map_err(|e| {\n    86→                    ContractError::SchemaValidation {\n    87→                        stage_id: self.stage_id.as_str().to_owned(),\n    88→                        details: format!(\"question_set: {e}\"),\n    89→                    }\n    90→                })?;\n    91→                Ok(RequirementsPayload::QuestionSet(p))\n    92→            }\n    93→            RequirementsStageId::RequirementsDraft => {\n    94→                let p: RequirementsDraftPayload =\n    95→                    serde_json::from_value(raw.clone()).map_err(|e| {\n    96→                        ContractError::SchemaValidation {\n    97→                            stage_id: self.stage_id.as_str().to_owned(),\n    98→                            details: format!(\"requirements_draft: {e}\"),\n    99→                        }\n   100→                    })?;\n   101→                Ok(RequirementsPayload::Draft(p))\n   102→            }\n   103→            RequirementsStageId::RequirementsReview => {\n   104→                let p: RequirementsReviewPayload =\n   105→                    serde_json::from_value(raw.clone()).map_err(|e| {\n   106→                        ContractError::SchemaValidation {\n   107→                            stage_id: self.stage_id.as_str().to_owned(),\n   108→                            details: format!(\"requirements_review: {e}\"),\n   109→                        }\n   110→                    })?;\n   111→                Ok(RequirementsPayload::Review(p))\n   112→            }\n   113→            RequirementsStageId::ProjectSeed => {\n   114→                let p: ProjectSeedPayload = serde_json::from_value(raw.clone()).map_err(|e| {\n   115→                    ContractError::SchemaValidation {\n   116→                        stage_id: self.stage_id.as_str().to_owned(),\n   117→                        details: format!(\"project_seed: {e}\"),\n   118→                    }\n   119→                })?;\n   120→                Ok(RequirementsPayload::Seed(p))\n   121→            }\n   122→        }\n   123→    }\n   124→\n   125→    fn validate_semantics(&self, payload: &RequirementsPayload) -> Result<(), ContractError> {\n   126→        match payload {\n   127→            RequirementsPayload::QuestionSet(p) => {\n   128→                let mut errors = Vec::new();\n   129→                let mut seen_ids = std::collections::HashSet::new();\n   130→                for (i, q) in p.questions.iter().enumerate() {\n   131→                    if q.id.trim().is_empty() {\n   132→                        errors.push(format!(\"questions[{i}].id must not be empty\"));\n   133→                    } else if !q\n   134→                        .id\n   135→                        .chars()\n   136→                        .all(|c| c.is_ascii_alphanumeric() || c == '_' || c == '-')\n   137→                    {\n   138→                        errors.push(format!(\n   139→                            \"questions[{i}].id '{}' contains characters not allowed in TOML bare keys \\\n   140→                             (only ASCII alphanumeric, underscore, and hyphen permitted)\",\n   141→                            q.id\n   142→                        ));\n   143→                    }\n   144→                    if !seen_ids.insert(&q.id) {\n   145→                        errors.push(format!(\"questions[{i}].id '{}' is duplicate\", q.id));\n   146→                    }\n   147→                    if q.prompt.trim().is_empty() {\n   148→                        errors.push(format!(\"questions[{i}].prompt must not be empty\"));\n   149→                    }\n   150→                }\n   151→                if !errors.is_empty() {\n   152→                    return Err(ContractError::DomainValidation {\n   153→                        stage_id: self.stage_id.as_str().to_owned(),\n   154→                        details: format!(\"question_set: {}\", errors.join(\"; \")),\n   155→                    });\n   156→                }\n   157→            }\n   158→            RequirementsPayload::Draft(p) => {\n   159→                let mut errors = Vec::new();\n   160→                if p.problem_summary.trim().is_empty() {\n   161→                    errors.push(\"problem_summary must not be empty\".to_string());\n   162→                }\n   163→                if p.goals.is_empty() {\n   164→                    errors.push(\"goals must contain at least one item\".to_string());\n   165→                }\n   166→                if p.acceptance_criteria.is_empty() {\n   167→                    errors.push(\"acceptance_criteria must contain at least one item\".to_string());\n   168→                }\n   169→                // Validate recommended_flow is a built-in preset\n   170→                let valid_flows = [\n   171→                    FlowPreset::Standard,\n   172→                    FlowPreset::QuickDev,\n   173→                    FlowPreset::DocsChange,\n   174→                    FlowPreset::CiImprovement,\n   175→                ];\n   176→                if !valid_flows.contains(&p.recommended_flow) {\n   177→                    errors.push(\"recommended_flow must be a built-in preset\".to_string());\n   178→                }\n   179→                if !errors.is_empty() {\n   180→                    return Err(ContractError::DomainValidation {\n   181→                        stage_id: self.stage_id.as_str().to_owned(),\n   182→                        details: format!(\"requirements_draft: {}\", errors.join(\"; \")),\n   183→                    });\n   184→                }\n   185→            }\n   186→            RequirementsPayload::Review(p) => {\n   187→                if !p.outcome.allows_completion() && p.findings.is_empty() {\n   188→                    return Err(ContractError::DomainValidation {\n   189→                        stage_id: self.stage_id.as_str().to_owned(),\n   190→                        details: \"requirements_review: findings required for non-approval outcome\"\n   191→                            .to_string(),\n   192→                    });\n   193→                }\n   194→                if p.outcome == RequirementsReviewOutcome::ConditionallyApproved\n   195→                    && p.follow_ups.is_empty()\n   196→                {\n   197→                    return Err(ContractError::DomainValidation {\n   198→                        stage_id: self.stage_id.as_str().to_owned(),\n   199→                        details: \"requirements_review: conditionally_approved requires at least one follow-up\"\n   200→                            .to_string(),\n   201→                    });\n   202→                }\n   203→            }\n   204→            RequirementsPayload::Seed(p) => {\n   205→                let mut errors = Vec::new();\n   206→                if p.project_id.trim().is_empty() {\n   207→                    errors.push(\"project_id must not be empty\".to_string());\n   208→                }\n   209→                if p.project_name.trim().is_empty() {\n   210→                    errors.push(\"project_name must not be empty\".to_string());\n   211→                }\n   212→                if p.prompt_body.trim().is_empty() {\n   213→                    errors.push(\"prompt_body must not be empty\".to_string());\n   214→                }\n   215→                if p.handoff_summary.trim().is_empty() {\n   216→                    errors.push(\"handoff_summary must not be empty\".to_string());\n   217→                }\n   218→                if !errors.is_empty() {\n   219→                    return Err(ContractError::DomainValidation {\n   220→                        stage_id: self.stage_id.as_str().to_owned(),\n   221→                        details: format!(\"project_seed: {}\", errors.join(\"; \")),\n   222→                    });\n   223→                }\n   224→            }\n   225→        }\n   226→        Ok(())\n   227→    }\n   228→\n   229→    fn render(&self, payload: &RequirementsPayload) -> String {\n   230→        match payload {\n   231→            RequirementsPayload::QuestionSet(p) => renderers::render_question_set(p),\n   232→            RequirementsPayload::Draft(p) => renderers::render_requirements_draft(p),\n   233→            RequirementsPayload::Review(p) => renderers::render_requirements_review(p),\n   234→            RequirementsPayload::Seed(p) => renderers::render_project_seed(p),\n   235→        }\n   236→    }\n   237→}\n   238→"}]},"parent_tool_use_id":"toolu_01GmHc9N8Srjnat2yn1mzYfx","session_id":"216e97eb-aa57-41df-a04f-9831b7c2815e","uuid":"5de94b96-6039-43ae-8b23-e5c0c7f7d018"}
