8→\n   419→    pub fn as_str(self) -> &'static str {\n   420→        match self {\n   421→            Self::PromptReview => \"prompt_review\",\n   422→            Self::Planning => \"planning\",\n   423→            Self::Implementation => \"implementation\",\n   424→            Self::Qa => \"qa\",\n   425→            Self::Review => \"review\",\n   426→            Self::CompletionPanel => \"completion_panel\",\n   427→            Self::AcceptanceQa => \"acceptance_qa\",\n   428→            Self::FinalReview => \"final_review\",\n   429→            Self::PlanAndImplement => \"plan_and_implement\",\n   430→            Self::ApplyFixes => \"apply_fixes\",\n   431→            Self::DocsPlan => \"docs_plan\",\n   432→            Self::DocsUpdate => \"docs_update\",\n   433→            Self::DocsValidation => \"docs_validation\",\n   434→            Self::CiPlan => \"ci_plan\",\n   435→            Self::CiUpdate => \"ci_update\",\n   436→            Self::CiValidation => \"ci_validation\",\n   437→        }\n   438→    }\n   439→}\n   440→\n   441→impl fmt::Display for StageId {\n   442→    fn fmt(&self, f: &mut fmt::Formatter<'_>) -> fmt::Result {\n   443→        f.write_str(self.as_str())\n   444→    }\n   445→}\n   446→\n   447→impl FromStr for StageId {\n   448→    type Err = AppError;\n   449→\n   450→    fn from_str(value: &str) -> Result<Self, Self::Err> {\n   451→        match value {\n   452→            \"prompt_review\" => Ok(Self::PromptReview),\n   453→            \"planning\" => Ok(Self::Planning),\n   454→            \"implementation\" => Ok(Self::Implementation),\n   455→            \"qa\" => Ok(Self::Qa),\n   456→            \"review\" => Ok(Self::Review),\n   457→            \"completion_panel\" => Ok(Self::CompletionPanel),\n   458→            \"acceptance_qa\" => Ok(Self::AcceptanceQa),\n   459→            \"final_review\" => Ok(Self::FinalReview),\n   460→            \"plan_and_implement\" => Ok(Self::PlanAndImplement),\n   461→            \"apply_fixes\" => Ok(Self::ApplyFixes),\n   462→            \"docs_plan\" => Ok(Self::DocsPlan),\n   463→            \"docs_update\" => Ok(Self::DocsUpdate),\n   464→            \"docs_validation\" => Ok(Self::DocsValidation),\n   465→            \"ci_plan\" => Ok(Self::CiPlan),\n   466→            \"ci_update\" => Ok(Self::CiUpdate),\n   467→            \"ci_validation\" => Ok(Self::CiValidation),\n   468→            _ => Err(AppError::InvalidConfigValue {\n   469→                key: \"stage_id\".to_owned(),\n   470→                value: value.to_owned(),\n   471→                reason: \"unknown stage identifier\".to_owned(),\n   472→            }),\n   473→        }\n   474→    }\n   475→}\n   476→\n   477→#[derive(Debug, Clone, PartialEq, Eq, Serialize, Deserialize)]\n   478→pub struct StageCursor {\n   479→    pub stage: StageId,\n   480→    pub cycle: u32,\n   481→    pub attempt: u32,\n   482→    pub completion_round: u32,\n   483→}\n   484→\n   485→impl StageCursor {\n   486→    pub fn new(stage: StageId, cycle: u32, attempt: u32, completion_round: u32) -> AppResult<Self> {\n   487→        if cycle == 0 {\n   488→            return Err(AppError::InvalidStageCursorField { field: \"cycle\" });\n   489→        }\n   490→        if attempt == 0 {\n   491→            return Err(AppError::InvalidStageCursorField { field: \"attempt\" });\n   492→        }\n   493→        if completion_round == 0 {\n   494→            return Err(AppError::InvalidStageCursorField {\n   495→                field: \"completion_round\",\n   496→            });\n   497→        }\n   498→\n   499→        Ok(Self {\n   500→            stage,\n   501→            cycle,\n   502→            attempt,\n   503→            completion_round,\n   504→        })\n   505→    }\n   506→\n   507→    pub fn initial(stage: StageId) -> Self {\n   508→        Self {\n   509→            stage,\n   510→            cycle: 1,\n   511→            attempt: 1,\n   512→            completion_round: 1,\n   513→        }\n  