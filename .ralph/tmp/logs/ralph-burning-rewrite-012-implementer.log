{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_018fGFD9rpg36QjGAPE1T3sA","type":"tool_result","content":"     1→use std::fs;\n     2→\n     3→use chrono::TimeZone;\n     4→use ralph_burning::adapters::fs::FileSystem;\n     5→use ralph_burning::contexts::workspace_governance::{\n     6→    EffectiveConfig, DEFAULT_FLOW_PRESET, DEFAULT_PROMPT_REVIEW_ENABLED,\n     7→};\n     8→use ralph_burning::shared::domain::{\n     9→    FlowPreset, PromptReviewSettings, WorkspaceConfig, WorkspaceSettings,\n    10→};\n    11→use ralph_burning::shared::error::AppError;\n    12→use tempfile::tempdir;\n    13→\n    14→use super::workspace_test::initialize_workspace_fixture;\n    15→\n    16→#[test]\n    17→fn effective_config_loads_compiled_defaults() {\n    18→    let temp_dir = tempdir().expect(\"create temp dir\");\n    19→    initialize_workspace_fixture(temp_dir.path());\n    20→\n    21→    let config = EffectiveConfig::load(temp_dir.path()).expect(\"load effective config\");\n    22→\n    23→    assert_eq!(\n    24→        DEFAULT_PROMPT_REVIEW_ENABLED,\n    25→        config.prompt_review_enabled()\n    26→    );\n    27→    assert_eq!(DEFAULT_FLOW_PRESET, config.default_flow());\n    28→    assert_eq!(None, config.default_backend());\n    29→    assert_eq!(None, config.default_model());\n    30→    assert!(matches!(\n    31→        config.get(\"default_flow\").expect(\"default flow\").source,\n    32→        ralph_burning::contexts::workspace_governance::ConfigValueSource::Default\n    33→    ));\n    34→}\n    35→\n    36→#[test]\n    37→fn effective_config_merges_workspace_overrides() {\n    38→    let temp_dir = tempdir().expect(\"create temp dir\");\n    39→    let workspace_root = initialize_workspace_fixture(temp_dir.path());\n    40→    let workspace_config_path = workspace_root.join(\"workspace.toml\");\n    41→\n    42→    let created_at = chrono::Utc\n    43→        .with_ymd_and_hms(2026, 3, 11, 17, 50, 55)\n    44→        .single()\n    45→        .expect(\"valid timestamp\");\n    46→    let mut config = WorkspaceConfig::new(created_at);\n    47→    config.settings = WorkspaceSettings {\n    48→        prompt_review: PromptReviewSettings {\n    49→            enabled: Some(false),\n    50→            extra: toml::map::Map::new(),\n    51→        },\n    52→        default_flow: Some(FlowPreset::QuickDev),\n    53→        default_backend: Some(\"claude\".to_owned()),\n    54→        default_model: Some(\"opus\".to_owned()),\n    55→        extra: toml::map::Map::new(),\n    56→    };\n    57→    FileSystem::write_atomic(\n    58→        &workspace_config_path,\n    59→        &toml::to_string_pretty(&config).expect(\"serialize config\"),\n    60→    )\n    61→    .expect(\"write config\");\n    62→\n    63→    let effective = EffectiveConfig::load(temp_dir.path()).expect(\"load effective config\");\n    64→\n    65→    assert!(!effective.prompt_review_enabled());\n    66→    assert_eq!(FlowPreset::QuickDev, effective.default_flow());\n    67→    assert_eq!(Some(\"claude\"), effective.default_backend());\n    68→    assert_eq!(Some(\"opus\"), effective.default_model());\n    69→    assert!(matches!(\n    70→        effective\n    71→            .get(\"default_model\")\n    72→            .expect(\"default model\")\n    73→            .source,\n    74→        ralph_burning::contexts::workspace_governance::ConfigValueSource::WorkspaceToml\n    75→    ));\n    76→}\n    77→\n    78→#[test]\n    79→fn workspace_config_round_trips_extended_settings() {\n    80→    let created_at = chrono::Utc\n    81→        .with_ymd_and_hms(2026, 3, 11, 17, 50, 55)\n    82→        .single()\n    83→        .expect(\"valid timestamp\");\n    84→    let mut config = WorkspaceConfig::new(created_at);\n    85→    config.settings = WorkspaceSettings {\n    86→        prompt_review: PromptReviewSettings {\n    87→            enabled: Some(false),\n    88→            extra: toml::map::Map::new(),\n    89→        },\n    90→        default_flow: Some(FlowPreset::DocsChange),\n    91→        default_backend: Some(\"openrouter\".to_owned()),\n    92→        default_model: Some(\"gpt-5\".to_owned()),\n    93→        extra: toml::map::Map::new(),\n    94→    };\n    95→\n    96→    let serialized = toml::to_string_pretty(&config).expect(\"serialize config\");\n    97→    let parsed: WorkspaceConfig = toml::from_str(&serialized).expect(\"deserialize config\");\n    98→\n    99→    assert_eq!(config, parsed);\n   100→}\n   101→\n   102→#[test]\n   103→fn config_set_preserves_unknown_settings_keys() {\n   104→    let temp_dir = tempdir().expect(\"create temp dir\");\n   105→    let workspace_root = initialize_workspace_fixture(temp_dir.path());\n   106→    let config_path = workspace_root.join(\"workspace.toml\");\n   107→    let raw = r#\"\n   108→version = 1\n   109→created_at = \"2026-03-11T17:50:55Z\"\n   110→\n   111→[settings]\n   112→default_backend = \"claude\"\n   113→future_toggle = \"enabled\"\n   114→\n   115→[settings.prompt_review]\n   116→enabled = false\n   117→owner = \"ops\"\n   118→\n   119→[settings.routing]\n   120→mode = \"repo_default\"\n   121→\"#;\n   122→    fs::write(&config_path, raw).expect(\"write config\");\n   123→\n   124→    let entry = EffectiveConfig::set(temp_dir.path(), \"default_flow\", \"quick_dev\")\n   125→        .expect(\"update default flow\");\n   126→\n   127→    assert_eq!(\"default_flow\", entry.key);\n   128→    assert_eq!(\"quick_dev\", entry.value.display_value());\n   129→\n   130→    let updated = fs::read_to_string(&config_path).expect(\"read updated config\");\n   131→    assert!(updated.contains(\"future_toggle = \\\"enabled\\\"\"));\n   132→    assert!(updated.contains(\"owner = \\\"ops\\\"\"));\n   133→    assert!(updated.contains(\"[settings.routing]\"));\n   134→}\n   135→\n   136→#[test]\n   137→fn workspace_config_preserves_unknown_keys_through_round_trip() {\n   138→    let raw = r#\"\n   139→version = 1\n   140→created_at = \"2026-03-11T17:50:55Z\"\n   141→\n   142→[settings]\n   143→default_backend = \"claude\"\n   144→future_toggle = \"enabled\"\n   145→\n   146→[settings.prompt_review]\n   147→enabled = true\n   148→owner = \"ops\"\n   149→\n   150→[settings.routing]\n   151→mode = \"repo_default\"\n   152→\"#;\n   153→\n   154→    let parsed: WorkspaceConfig = toml::from_str(raw).expect(\"deserialize config\");\n   155→    let serialized = toml::to_string_pretty(&parsed).expect(\"serialize config\");\n   156→    let reparsed: WorkspaceConfig = toml::from_str(&serialized).expect(\"deserialize config\");\n   157→\n   158→    assert_eq!(\n   159→        Some(&toml::Value::String(\"enabled\".to_owned())),\n   160→        reparsed.settings.extra.get(\"future_toggle\")\n   161→    );\n   162→    assert_eq!(\n   163→        Some(&toml::Value::String(\"ops\".to_owned())),\n   164→        reparsed.settings.prompt_review.extra.get(\"owner\")\n   165→    );\n   166→    assert_eq!(\n   167→        Some(&toml::Value::String(\"repo_default\".to_owned())),\n   168→        reparsed\n   169→            .settings\n   170→            .extra\n   171→            .get(\"routing\")\n   172→            .and_then(|value| value.as_table())\n   173→            .and_then(|table| table.get(\"mode\"))\n   174→    );\n   175→}\n   176→\n   177→#[test]\n   178→fn effective_config_rejects_unknown_keys_and_invalid_values() {\n   179→    let temp_dir = tempdir().expect(\"create temp dir\");\n   180→    initialize_workspace_fixture(temp_dir.path());\n   181→\n   182→    let unknown_key = EffectiveConfig::set(temp_dir.path(), \"unknown.key\", \"value\")\n   183→        .expect_err(\"unknown key should fail\");\n   184→    assert!(matches!(unknown_key, AppError::UnknownConfigKey { .. }));\n   185→\n   186→    let invalid_flow = EffectiveConfig::set(temp_dir.path(), \"default_flow\", \"unknown\")\n   187→        .expect_err(\"invalid flow should fail\");\n   188→    assert!(matches!(invalid_flow, AppError::InvalidConfigValue { .. }));\n   189→\n   190→    let invalid_bool = EffectiveConfig::set(temp_dir.path(), \"prompt_review.enabled\", \"yes\")\n   191→        .expect_err(\"invalid bool should fail\");\n   192→    assert!(matches!(invalid_bool, AppError::InvalidConfigValue { .. }));\n   193→}\n   194→"}]},"parent_tool_use_id":"toolu_01GmHc9N8Srjnat2yn1mzYfx","session_id":"216e97eb-aa57-41df-a04f-9831b7c2815e","uuid":"5364b6bc-054e-4df3-99de-2eacf6e604d2"}
