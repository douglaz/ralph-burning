d}' was not found under .ralph-burning/projects/ or is missing project.toml\"\n    41→    )]\n    42→    ProjectNotFound { project_id: String },\n    43→    #[error(\"editor '{editor}' failed{details}\")]\n    44→    EditorFailed { editor: String, details: String },\n    45→    #[error(\"project '{project_id}' already exists\")]\n    46→    DuplicateProject { project_id: String },\n    47→    #[error(\"corrupt record in {file}: {details}\")]\n    48→    CorruptRecord { file: String, details: String },\n    49→    #[error(\"invalid prompt file '{path}': {reason}\")]\n    50→    InvalidPrompt { path: String, reason: String },\n    51→    #[error(\"cannot delete project '{project_id}': it has an active run\")]\n    52→    ActiveRunDelete { project_id: String },\n    53→    #[error(\"journal sequence error: {details}\")]\n    54→    JournalSequence { details: String },\n    55→    #[error(\"cannot start run: {reason}\")]\n    56→    RunStartFailed { reason: String },\n    57→    #[error(\"cannot resume run: {reason}\")]\n    58→    ResumeFailed { reason: String },\n    59→    #[error(\"flow '{flow_id}' is not yet supported for run execution; 'quick_dev' is deferred to a later loop\")]\n    60→    UnsupportedFlow { flow_id: String },\n    61→    #[error(\"preflight check failed for stage '{stage_id}': {details}\")]\n    62→    PreflightFailed { stage_id: StageId, details: String },\n    63→    #[error(\"stage commit failed for stage '{stage_id}': {details}\")]\n    64→    StageCommitFailed { stage_id: StageId, details: String },\n    65→    #[error(\"{command} is not yet implemented\")]\n    66→    NotYetImplemented { command: String },\n    67→    #[error(\"backend '{backend}' is unavailable: {details}\")]\n    68→    BackendUnavailable { backend: String, details: String },\n    69→    #[error(\"backend '{backend}' cannot satisfy contract '{contract_id}': {details}\")]\n    70→    CapabilityMismatch {\n    71→        backend: String,\n    72→        contract_id: String,\n    73→        details: String,\n    74→    },\n    75→    #[error(\"backend invocation failed for contract '{contract_id}' via '{backend}': {details}\")]\n    76→    InvocationFailed {\n    77→        backend: String,\n    78→        contract_id: String,\n    79→        failure_class: FailureClass,\n    80→        details: String,\n    81→    },\n    82→    #[error(\n    83→        \"backend invocation timed out for contract '{contract_id}' via '{backend}' after {timeout_ms} ms\"\n    84→    )]\n    85→    InvocationTimeout {\n    86→        backend: String,\n    87→        contract_id: String,\n    88→        timeout_ms: u64,\n    89→    },\n    90→    #[error(\"backend invocation cancelled for contract '{contract_id}' via '{backend}'\")]\n    91→    InvocationCancelled {\n    92→        backend: String,\n    93→        contract_id: String,\n    94→    },\n    95→    #[error(\"invalid requirements state for run '{run_id}': {details}\")]\n    96→    InvalidRequirementsState { run_id: String, details: String },\n    97→    #[error(\"answer validation failed for run '{run_id}': {details}\")]\n    98→    AnswerValidationFailed { run_id: String, details: String },\n    99→    #[error(\"seed persistence failed for run '{run_id}': {details}\")]\n   100→    SeedPersistenceFailed { run_id: String, details: String },\n   101→    #[error(\"remediation exhausted at cycle {cycle}; maximum supported cycles is {max}\")]\n   102→    RemediationExhausted { cycle: u32, max: u32 },\n   103→    #[error(\"amendment queue error: {details}\")]\n   104→    AmendmentQueueError { details: String },\n   105→    #[error(\"completion blocked: {details}\")]\n   106→    CompletionBlocked { details: String },\n   107→    #[error(\"completion guard snapshot commit failed: {details}\")]\n   108→    CompletionGuardSnapshotFailed { details: String },\n   109→    #[error(\"routing resolution failed for '{input}': {details}\")]\n   110→    RoutingResolutionFailed { input: String, details: String },\n   111→    #[error(\"ambiguous routing labels resolved to multiple flows: {labels:?}\")]\n   112→    AmbiguousRouting { labels: Vec<String> },\n   113→    #[error(\"task for issue '{issue_ref}' already exists with non-terminal status\")]\n   114→    DuplicateTaskForIssue { issue_ref: String },\n   115→    #[error(\"project writer lock is already held for '{project_id}'\")]\n   116→    ProjectWriterLockHeld { project_id: String },\n   117→    #[error(\"failed to create worktree for task '{task_id}': {details}\")]\n   118→    WorktreeCreationFailed { task_id: String, details: String },\n   119→    #[error(\"failed to remove worktree for task '{task_id}': {details}\")]\n   120→    WorktreeRemovalFailed { task_id: String, details: String },\n   121→    #[error(\"lease '{lease_id}' is stale\")]\n   122→    LeaseStale { lease_id: String },\n   123→    #[error(\"invalid task state transition for '{task_id}': {from} -> {to}\")]\n   124→    TaskStateTransitionInvalid {\n   125→        task_id: String,\n   126→        from: String,\n   127→        to: String,\n   128→    },\n   129→    #[error(\"rebase conflict for branch '{branch_name}': {details}\")]\n   130→    RebaseConflict {\n   131→        branch_name: String,\n   132→        details: String,\n   133→    },\n   134→    #[error(transparent)]\n   135→    Io(#[from] std::io::Error),\n   136→    #[error(transparent)]\n   137→    TomlDeserialize(#[from] toml::de::Error),\n   138→    #[error(transparent)]\n   139→    TomlSerialize(#[from] toml::ser::Error),\n   140→    #[error(transparent)]\n   141→    TomlEdit(#[from] toml_edit::TomlError),\n   142→    #[error(transparent)]\n   143→    SerdeJson(#[from] serde_json::Error),\n   144→}\n   145→\n   146→/// Errors specific to stage contract evaluation.\n   147→///\n   148→/// Each variant maps to a distinct [`FailureClass`] for retry/terminal policy.\n   149→/// The `stage_id` field is a domain-neutral string identifier, supporting both\n   150→/// workflow stage IDs and requirements stage IDs.\n   151→#[derive(Debug, Error)]\n   152→pub enum ContractError {\n   153→    #[error(\"schema validation failed for stage '{stage_id}': {details}\")]\n   154→    SchemaValidation { stage_id: String, details: String },\n   155→\n   156→    #[error(\"domain validation failed for stage '{stage_id}': {details}\")]\n   157→    DomainValidation { stage_id: String, details: String },\n   158→\n   159→    #[error(\"rendering failed for stage '{stage_id}': {details}\")]\n   160→    RenderError { stage_id: String, details: String },\n   161→\n   162→    #[error(\"non-passing QA/review outcome for stage '{stage_id}': {outcome}\")]\n   163→    QaReviewOutcome { stage_id: String, outcome: String },\n   164→}\n   165→\n   166→impl ContractError {\n   167→    pub fn failure_class(&self) -> FailureClass {\n   168→        match self {\n   169→            Self::SchemaValidation { .. } => FailureClass::SchemaValidationFailure,\n   170→            Self::DomainValidation { .. } | Self::RenderError { .. } => {\n   171→                FailureClass::DomainValidationFailure\n   172→            }\n   173→            Self::QaReviewOutcome { .. } => FailureClass::QaReviewOutcomeFailure,\n   174→        }\n   175→    }\n   176→\n   177→    pub fn stage_id(&self) -> &str {\n   178→        match self {\n   179→            Self::SchemaValidation { stage_id, .. }\n   180→            | Self::DomainValidation { stage_id, .. }\n   181→            | Self::RenderError { stage_id, .. }\n   182→            | Self::QaReviewOutcome { stage_id, .. } => stage_id,\n   183→        }\n   184→    }\n   185→}\n   186→\n   187→impl AppError {\n   188→    pub fn failure_class(&self) -> Option<FailureClass> {\n   189→        match self {\n   190→            Self::BackendUnavailable { .. } => Some(FailureClass::TransportFailure),\n   191→            Self::CapabilityMismatch { .. } => Some(FailureClass::DomainValidationFailure),\n   192→            Self::InvocationFailed { failure_class, .. } => Some(*failure_class),\n   193→            Self::InvocationTimeout { .. } => Some(FailureClass::Timeout),\n   194→            Self::InvocationCancelled { .. } => Some(FailureClass::Cancellation),\n   195→            _ => None,\n   196→        }\n   197→    }\n   198→}\n   199→"}]},"parent_tool_use_id":"toolu_01GmHc9N8Srjnat2yn1mzYfx","session_id":"216e97eb-aa57-41df-a04f-9831b7c2815e","uuid":"92783943-676c-4b30-a420-f11b74119a38"}
