{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01G27FQEA4U5k2y9goQa7hfD","type":"tool_result","content":"     1→use ralph_burning::contexts::workflow_composition::{built_in_flows, flow_definition};\n     2→use ralph_burning::shared::domain::{FlowPreset, StageId};\n     3→\n     4→#[test]\n     5→fn built_in_flow_registry_exposes_all_four_presets_in_order() {\n     6→    let presets: Vec<_> = built_in_flows()\n     7→        .iter()\n     8→        .map(|definition| definition.preset)\n     9→        .collect();\n    10→\n    11→    assert_eq!(\n    12→        vec![\n    13→            FlowPreset::Standard,\n    14→            FlowPreset::QuickDev,\n    15→            FlowPreset::DocsChange,\n    16→            FlowPreset::CiImprovement\n    17→        ],\n    18→        presets\n    19→    );\n    20→}\n    21→\n    22→#[test]\n    23→fn standard_flow_stage_order_matches_spec() {\n    24→    assert_eq!(\n    25→        &[\n    26→            StageId::PromptReview,\n    27→            StageId::Planning,\n    28→            StageId::Implementation,\n    29→            StageId::Qa,\n    30→            StageId::Review,\n    31→            StageId::CompletionPanel,\n    32→            StageId::AcceptanceQa,\n    33→            StageId::FinalReview,\n    34→        ],\n    35→        flow_definition(FlowPreset::Standard).stages\n    36→    );\n    37→}\n    38→\n    39→#[test]\n    40→fn quick_dev_flow_stage_order_matches_spec() {\n    41→    assert_eq!(\n    42→        &[\n    43→            StageId::PlanAndImplement,\n    44→            StageId::Review,\n    45→            StageId::ApplyFixes,\n    46→            StageId::FinalReview,\n    47→        ],\n    48→        flow_definition(FlowPreset::QuickDev).stages\n    49→    );\n    50→}\n    51→\n    52→#[test]\n    53→fn docs_change_flow_stage_order_matches_spec() {\n    54→    assert_eq!(\n    55→        &[\n    56→            StageId::DocsPlan,\n    57→            StageId::DocsUpdate,\n    58→            StageId::DocsValidation,\n    59→            StageId::Review,\n    60→        ],\n    61→        flow_definition(FlowPreset::DocsChange).stages\n    62→    );\n    63→}\n    64→\n    65→#[test]\n    66→fn ci_improvement_flow_stage_order_matches_spec() {\n    67→    assert_eq!(\n    68→        &[\n    69→            StageId::CiPlan,\n    70→            StageId::CiUpdate,\n    71→            StageId::CiValidation,\n    72→            StageId::Review,\n    73→        ],\n    74→        flow_definition(FlowPreset::CiImprovement).stages\n    75→    );\n    76→}\n    77→"}]},"parent_tool_use_id":"toolu_01GmHc9N8Srjnat2yn1mzYfx","session_id":"216e97eb-aa57-41df-a04f-9831b7c2815e","uuid":"263fcdc9-7d2c-4f88-b716-92efdcbdd729"}
