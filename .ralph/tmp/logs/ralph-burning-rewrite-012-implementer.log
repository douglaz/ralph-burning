59→const CI_IMPROVEMENT_STAGES: [StageId; 4] = [\n    60→    StageId::CiPlan,\n    61→    StageId::CiUpdate,\n    62→    StageId::CiValidation,\n    63→    StageId::Review,\n    64→];\n    65→\n    66→const STANDARD_REMEDIATION_TRIGGER_STAGES: [StageId; 2] = [StageId::Qa, StageId::Review];\n    67→const STANDARD_LATE_STAGES: [StageId; 3] = [\n    68→    StageId::CompletionPanel,\n    69→    StageId::AcceptanceQa,\n    70→    StageId::FinalReview,\n    71→];\n    72→const QUICK_DEV_REMEDIATION_TRIGGER_STAGES: [StageId; 1] = [StageId::Review];\n    73→const QUICK_DEV_LATE_STAGES: [StageId; 1] = [StageId::FinalReview];\n    74→const DOCS_CHANGE_REMEDIATION_TRIGGER_STAGES: [StageId; 2] =\n    75→    [StageId::DocsValidation, StageId::Review];\n    76→const CI_IMPROVEMENT_REMEDIATION_TRIGGER_STAGES: [StageId; 2] =\n    77→    [StageId::CiValidation, StageId::Review];\n    78→\n    79→const FLOW_DEFINITIONS: [FlowDefinition; 4] = [\n    80→    FlowDefinition {\n    81→        preset: FlowPreset::Standard,\n    82→        description:\n    83→            \"Full delivery flow with planning, implementation, QA, review, and acceptance.\",\n    84→        stages: &STANDARD_STAGES,\n    85→        validation_profile: ValidationProfile {\n    86→            name: \"standard-default\",\n    87→            summary: \"Full validation suite with completion and acceptance checks.\",\n    88→            final_review_enabled: true,\n    89→        },\n    90→    },\n    91→    FlowDefinition {\n    92→        preset: FlowPreset::QuickDev,\n    93→        description: \"Fast delivery flow for small code changes with lightweight review.\",\n    94→        stages: &QUICK_DEV_STAGES,\n    95→        validation_profile: ValidationProfile {\n    96→            name: \"quick-dev-default\",\n    97→            summary: \"Lightweight panel with final review enabled by default.\",\n    98→            final_review_enabled: true,\n    99→        },\n   100→    },\n   101→    FlowDefinition {\n   102→        preset: FlowPreset::DocsChange,\n   103→        description: \"Documentation-focused flow for planning, content updates, and validation.\",\n   104→        stages: &DOCS_CHANGE_STAGES,\n   105→        validation_profile: ValidationProfile {\n   106→            name: \"docs-default\",\n   107→            summary: \"Documentation validation with final review disabled by default.\",\n   108→            final_review_enabled: false,\n   109→        },\n   110→    },\n   111→    FlowDefinition {\n   112→        preset: FlowPreset::CiImprovement,\n   113→        description: \"CI improvement flow for automation planning, updates, and validation.\",\n   114→        stages: &CI_IMPROVEMENT_STAGES,\n   115→        validation_profile: ValidationProfile {\n   116→            name: \"ci-default\",\n   117→            summary: \"Automation validation with final review disabled by default.\",\n   118→            final_review_enabled: false,\n   119→        },\n   120→    },\n   121→];\n   122→\n   123→pub fn built_in_flows() -> &'static [FlowDefinition] {\n   124→    &FLOW_DEFINITIONS\n   125→}\n   126→\n   127→pub fn flow_definition(preset: FlowPreset) -> &'static FlowDefinition {\n   128→    match preset {\n   129→        FlowPreset::Standard => &FLOW_DEFINITIONS[0],\n   130→        FlowPreset::QuickDev => &FLOW_DEFINITIONS[1],\n   131→        FlowPreset::DocsChange => &FLOW_DEFINITIONS[2],\n   132→        FlowPreset::CiImprovement => &FLOW_DEFINITIONS[3],\n   133→    }\n   134→}\n   135→\n   136→pub fn flow_definition_by_id(flow_id: &str) -> AppResult<&'static FlowDefinition> {\n   137→    let preset = flow_id.parse::<FlowPreset>()?;\n   138→    Ok(flow_definition(preset))\n   139→}\n   140→\n   141→pub fn flow_semantics(preset: FlowPreset) -> FlowSemantics {\n   142→    match preset {\n   143→        FlowPreset::Standard => FlowSemantics {\n   144→            planning_stage: StageId::Planning,\n   145→            execution_stage: StageId::Implementation,\n   146→            remediation_trigger_stages: &STANDARD_REMEDIATION_TRIGGER_STAGES,\n   147→            late_stages: &STANDARD_LATE_STAGES,\n   148→            prompt_review_stage: Some(StageId::PromptReview),\n   149→        },\n   150→        FlowPreset::QuickDev => FlowSemantics {\n   151→            planning_stage: StageId::PlanAndImplement,\n   152→            execution_stage: StageId::ApplyFixes,\n   153→            remediation_trigger_stages: &QUICK_DEV_REMEDIATION_TRIGGER_STAGES,\n   154→            late_stages: &QUICK_DEV_LATE_STAGES,\n   155→            prompt_review_stage: None,\n   156→        },\n   157→        FlowPreset::DocsChange => FlowSemantics {\n   158→            planning_stage: StageId::DocsPlan,\n   159→            execution_stage: StageId::DocsUpdate,\n   160→            remediation_trigger_stages: &DOCS_CHANGE_REMEDIATION_TRIGGER_STAGES,\n   161→            late_stages: &[],\n   162→            prompt_review_stage: None,\n   163→        },\n   164→        FlowPreset::CiImprovement => FlowSemantics {\n   165→            planning_stage: StageId::CiPlan,\n   166→            execution_stage: StageId::CiUpdate,\n   167→            remediation_trigger_stages: &CI_IMPROVEMENT_REMEDIATION_TRIGGER_STAGES,\n   168→            late_stages: &[],\n   169→            prompt_review_stage: None,\n   170→        },\n   171→    }\n   172→}\n   173→\n   174→pub fn stage_plan_for_flow(preset: FlowPreset, prompt_review_enabled: bool) -> Vec<StageId> {\n   175→    let flow_def = flow_definition(preset);\n   176→    let semantics = flow_semantics(preset);\n   177→\n   178→    flow_def\n   179→        .stages\n   180→        .iter()\n   181→        .copied()\n   182→        .filter(|stage_id| {\n   183→            prompt_review_enabled || Some(*stage_id) != semantics.prompt_review_stage\n   184→        })\n   185→        .collect()\n   186→}\n   187→"}]},"parent_tool_use_id":"toolu_01GmHc9N8Srjnat2yn1mzYfx","session_id":"216e97eb-aa57-41df-a04f-9831b7c2815e","uuid":"efff32