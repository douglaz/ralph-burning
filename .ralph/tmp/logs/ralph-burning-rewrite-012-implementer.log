oject_id = workspace_governance::resolve_active_project(&current_dir)?;\n   326→\n   327→    // Validate canonical project record before proceeding with run queries\n   328→    let project_store = FsProjectStore;\n   329→    let _ = project_store.read_project_record(&current_dir, &project_id)?;\n   330→\n   331→    let journal_store = FsJournalStore;\n   332→    let artifact_store = FsArtifactStore;\n   333→    let log_store = FsRuntimeLogStore;\n   334→\n   335→    let tail = service::run_tail(\n   336→        &journal_store,\n   337→        &artifact_store,\n   338→        &log_store,\n   339→        &current_dir,\n   340→        &project_id,\n   341→        include_logs,\n   342→    )?;\n   343→\n   344→    println!(\"Project: {}\", tail.project_id);\n   345→    println!(\"--- Durable History ---\");\n   346→    for event in &tail.events {\n   347→        println!(\n   348→            \"  [{}] {} - {:?}\",\n   349→            event.sequence, event.timestamp, event.event_type\n   350→        );\n   351→    }\n   352→\n   353→    if !tail.payloads.is_empty() {\n   354→        println!(\"--- Payloads ---\");\n   355→        for payload in &tail.payloads {\n   356→            println!(\n   357→                \"  {} ({}, cycle {}, attempt {})\",\n   358→                payload.payload_id, payload.stage_id, payload.cycle, payload.attempt\n   359→            );\n   360→        }\n   361→    }\n   362→\n   363→    if !tail.artifacts.is_empty() {\n   364→        println!(\"--- Artifacts ---\");\n   365→        for artifact in &tail.artifacts {\n   366→            println!(\n   367→                \"  {} (payload: {}, stage: {})\",\n   368→                artifact.artifact_id, artifact.payload_id, artifact.stage_id\n   369→            );\n   370→        }\n   371→    }\n   372→\n   373→    if let Some(ref logs) = tail.runtime_logs {\n   374→        println!(\"--- Runtime Logs ---\");\n   375→        if logs.is_empty() {\n   376→            println!(\"  (no runtime logs)\"