{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_019n4cjz1gCXXLB5KVZTEGgF","type":"tool_result","content":"     1→use std::fmt;\n     2→use std::path::Path;\n     3→\n     4→use toml_edit::{value, DocumentMut};\n     5→\n     6→use crate::adapters::fs::FileSystem;\n     7→use crate::shared::domain::{FlowPreset, WorkspaceConfig};\n     8→use crate::shared::error::{AppError, AppResult};\n     9→\n    10→use super::{load_workspace_config, workspace_config_path};\n    11→\n    12→/// Default: enabled.\n    13→pub const DEFAULT_PROMPT_REVIEW_ENABLED: bool = true;\n    14→/// Default: standard.\n    15→pub const DEFAULT_FLOW_PRESET: FlowPreset = FlowPreset::Standard;\n    16→\n    17→#[derive(Debug, Clone, Copy, PartialEq, Eq)]\n    18→pub enum ConfigValueSource {\n    19→    Default,\n    20→    WorkspaceToml,\n    21→}\n    22→\n    23→impl fmt::Display for ConfigValueSource {\n    24→    fn fmt(&self, f: &mut fmt::Formatter<'_>) -> fmt::Result {\n    25→        match self {\n    26→            Self::Default => f.write_str(\"default\"),\n    27→            Self::WorkspaceToml => f.write_str(\"workspace.toml\"),\n    28→        }\n    29→    }\n    30→}\n    31→\n    32→#[derive(Debug, Clone, PartialEq, Eq)]\n    33→pub enum ConfigValue {\n    34→    Bool(bool),\n    35→    FlowPreset(FlowPreset),\n    36→    String(Option<String>),\n    37→}\n    38→\n    39→impl ConfigValue {\n    40→    pub fn display_value(&self) -> String {\n    41→        match self {\n    42→            Self::Bool(value) => value.to_string(),\n    43→            Self::FlowPreset(value) => value.as_str().to_owned(),\n    44→            Self::String(Some(value)) => value.clone(),\n    45→            Self::String(None) => \"<unset>\".to_owned(),\n    46→        }\n    47→    }\n    48→\n    49→    pub fn toml_like_value(&self) -> String {\n    50→        match self {\n    51→            Self::Bool(value) => value.to_string(),\n    52→            Self::FlowPreset(value) => format!(\"\\\"{}\\\"\", value.as_str()),\n    53→            Self::String(Some(value)) => format!(\"\\\"{value}\\\"\"),\n    54→            Self::String(None) => \"\\\"<unset>\\\"\".to_owned(),\n    55→        }\n    56→    }\n    57→}\n    58→\n    59→#[derive(Debug, Clone, PartialEq, Eq)]\n    60→pub struct ConfigEntry {\n    61→    pub key: &'static str,\n    62→    pub value: ConfigValue,\n    63→    pub source: ConfigValueSource,\n    64→}\n    65→\n    66→#[derive(Debug, Clone, PartialEq, Eq)]\n    67→struct ResolvedValue<T> {\n    68→    value: T,\n    69→    source: ConfigValueSource,\n    70→}\n    71→\n    72→#[derive(Debug, Clone, PartialEq, Eq)]\n    73→pub struct EffectiveConfig {\n    74→    prompt_review_enabled: ResolvedValue<bool>,\n    75→    default_flow: ResolvedValue<FlowPreset>,\n    76→    default_backend: ResolvedValue<Option<String>>,\n    77→    default_model: ResolvedValue<Option<String>>,\n    78→}\n    79→\n    80→impl EffectiveConfig {\n    81→    pub fn load(base_dir: &Path) -> AppResult<Self> {\n    82→        let config = load_workspace_config(base_dir)?;\n    83→        Ok(Self::from_workspace_config(&config))\n    84→    }\n    85→\n    86→    pub fn get(&self, key: &str) -> AppResult<ConfigEntry> {\n    87→        let key = ConfigKey::parse(key)?;\n    88→        Ok(self.entry_for(key))\n    89→    }\n    90→\n    91→    pub fn set(base_dir: &Path, key: &str, value: &str) -> AppResult<ConfigEntry> {\n    92→        let key = ConfigKey::parse(key)?;\n    93→        let _ = Self::load(base_dir)?;\n    94→\n    95→        let config_path = workspace_config_path(base_dir);\n    96→        let raw = FileSystem::read_to_string(&config_path)?;\n    97→        let mut document = raw.parse::<DocumentMut>()?;\n    98→        key.apply_to_document(&mut document, value)?;\n    99→        FileSystem::write_atomic(&config_path, &document.to_string())?;\n   100→\n   101→        Self::load(base_dir)?.get(key.as_str())\n   102→    }\n   103→\n   104→    pub fn entries(&self) -> Vec<ConfigEntry> {\n   105→        ConfigKey::ALL\n   106→            .iter()\n   107→            .copied()\n   108→            .map(|key| self.entry_for(key))\n   109→            .collect()\n   110→    }\n   111→\n   112→    /// Default: `true`.\n   113→    pub fn prompt_review_enabled(&self) -> bool {\n   114→        self.prompt_review_enabled.value\n   115→    }\n   116→\n   117→    /// Default: `standard`.\n   118→    pub fn default_flow(&self) -> FlowPreset {\n   119→        self.default_flow.value\n   120→    }\n   121→\n   122→    /// Default: unset.\n   123→    pub fn default_backend(&self) -> Option<&str> {\n   124→        self.default_backend.value.as_deref()\n   125→    }\n   126→\n   127→    /// Default: unset.\n   128→    pub fn default_model(&self) -> Option<&str> {\n   129→        self.default_model.value.as_deref()\n   130→    }\n   131→\n   132→    fn from_workspace_config(config: &WorkspaceConfig) -> Self {\n   133→        let settings = &config.settings;\n   134→        Self {\n   135→            prompt_review_enabled: resolve_value(\n   136→                settings.prompt_review.enabled,\n   137→                DEFAULT_PROMPT_REVIEW_ENABLED,\n   138→            ),\n   139→            default_flow: resolve_value(settings.default_flow, DEFAULT_FLOW_PRESET),\n   140→            default_backend: resolve_optional_value(settings.default_backend.as_ref()),\n   141→            default_model: resolve_optional_value(settings.default_model.as_ref()),\n   142→        }\n   143→    }\n   144→\n   145→    fn entry_for(&self, key: ConfigKey) -> ConfigEntry {\n   146→        match key {\n   147→            ConfigKey::PromptReviewEnabled => ConfigEntry {\n   148→                key: key.as_str(),\n   149→                value: ConfigValue::Bool(self.prompt_review_enabled()),\n   150→                source: self.prompt_review_enabled.source,\n   151→            },\n   152→            ConfigKey::DefaultFlow => ConfigEntry {\n   153→                key: key.as_str(),\n   154→                value: ConfigValue::FlowPreset(self.default_flow()),\n   155→                source: self.default_flow.source,\n   156→            },\n   157→            ConfigKey::DefaultBackend => ConfigEntry {\n   158→                key: key.as_str(),\n   159→                value: ConfigValue::String(self.default_backend.value.clone()),\n   160→                source: self.default_backend.source,\n   161→            },\n   162→            ConfigKey::DefaultModel => ConfigEntry {\n   163→                key: key.as_str(),\n   164→                value: ConfigValue::String(self.default_model.value.clone()),\n   165→                source: self.default_model.source,\n   166→            },\n   167→        }\n   168→    }\n   169→}\n   170→\n   171→fn resolve_value<T: Copy>(value: Option<T>, default: T) -> ResolvedValue<T> {\n   172→    match value {\n   173→        Some(value) => ResolvedValue {\n   174→            value,\n   175→            source: ConfigValueSource::WorkspaceToml,\n   176→        },\n   177→        None => ResolvedValue {\n   178→            value: default,\n   179→            source: ConfigValueSource::Default,\n   180→        },\n   181→    }\n   182→}\n   183→\n   184→fn resolve_optional_value(value: Option<&String>) -> ResolvedValue<Option<String>> {\n   185→    match value {\n   186→        Some(value) => ResolvedValue {\n   187→            value: Some(value.clone()),\n   188→            source: ConfigValueSource::WorkspaceToml,\n   189→        },\n   190→        None => ResolvedValue {\n   191→            value: None,\n   192→            source: ConfigValueSource::Default,\n   193→        },\n   194→    }\n   195→}\n   196→\n   197→#[derive(Debug, Clone, Copy, PartialEq, Eq)]\n   198→enum ConfigKey {\n   199→    PromptReviewEnabled,\n   200→    DefaultFlow,\n   201→    DefaultBackend,\n   202→    DefaultModel,\n   203→}\n   204→\n   205→impl ConfigKey {\n   206→    const ALL: [Self; 4] = [\n   207→        Self::PromptReviewEnabled,\n   208→        Self::DefaultFlow,\n   209→        Self::DefaultBackend,\n   210→        Self::DefaultModel,\n   211→    ];\n   212→\n   213→    fn parse(value: &str) -> AppResult<Self> {\n   214→        match value {\n   215→            \"prompt_review.enabled\" => Ok(Self::PromptReviewEnabled),\n   216→            \"default_flow\" => Ok(Self::DefaultFlow),\n   217→            \"default_backend\" => Ok(Self::DefaultBackend),\n   218→            \"default_model\" => Ok(Self::DefaultModel),\n   219→            _ => Err(AppError::UnknownConfigKey {\n   220→                key: value.to_owned(),\n   221→            }),\n   222→        }\n   223→    }\n   224→\n   225→    fn as_str(self) -> &'static str {\n   226→        match self {\n   227→            Self::PromptReviewEnabled => \"prompt_review.enabled\",\n   228→            Self::DefaultFlow => \"default_flow\",\n   229→            Self::DefaultBackend => \"default_backend\",\n   230→            Self::DefaultModel => \"default_model\",\n   231→        }\n   232→    }\n   233→\n   234→    fn apply_to_document(self, document: &mut DocumentMut, raw_value: &str) -> AppResult<()> {\n   235→        match self {\n   236→            Self::PromptReviewEnabled => {\n   237→                let parsed = parse_bool(self.as_str(), raw_value)?;\n   238→                document[\"settings\"][\"prompt_review\"][\"enabled\"] = value(parsed);\n   239→            }\n   240→            Self::DefaultFlow => {\n   241→                let parsed = parse_flow_preset(self.as_str(), raw_value)?;\n   242→                document[\"settings\"][\"default_flow\"] = value(parsed.as_str());\n   243→            }\n   244→            Self::DefaultBackend => apply_optional_string(document, \"default_backend\", raw_value)?,\n   245→            Self::DefaultModel => apply_optional_string(document, \"default_model\", raw_value)?,\n   246→        }\n   247→\n   248→        Ok(())\n   249→    }\n   250→}\n   251→\n   252→fn parse_bool(key: &str, raw_value: &str) -> AppResult<bool> {\n   253→    match raw_value.trim() {\n   254→        \"true\" => Ok(true),\n   255→        \"false\" => Ok(false),\n   256→        _ => Err(AppError::InvalidConfigValue {\n   257→            key: key.to_owned(),\n   258→            value: raw_value.to_owned(),\n   259→            reason: \"expected `true` or `false`\".to_owned(),\n   260→        }),\n   261→    }\n   262→}\n   263→\n   264→fn parse_flow_preset(key: &str, raw_value: &str) -> AppResult<FlowPreset> {\n   265→    raw_value\n   266→        .trim()\n   267→        .parse::<FlowPreset>()\n   268→        .map_err(|_| AppError::InvalidConfigValue {\n   269→            key: key.to_owned(),\n   270→            value: raw_value.to_owned(),\n   271→            reason: \"expected one of: standard, quick_dev, docs_change, ci_improvement\".to_owned(),\n   272→        })\n   273→}\n   274→\n   275→fn parse_optional_string(key: &str, raw_value: &str) -> AppResult<Option<String>> {\n   276→    let trimmed = raw_value.trim();\n   277→    if trimmed.is_empty() {\n   278→        return Err(AppError::InvalidConfigValue {\n   279→            key: key.to_owned(),\n   280→            value: raw_value.to_owned(),\n   281→            reason: \"expected a non-empty string or one of: unset, none, null\".to_owned(),\n   282→        });\n   283→    }\n   284→\n   285→    if matches!(trimmed, \"unset\" | \"none\" | \"null\") {\n   286→        Ok(None)\n   287→    } else {\n   288→        Ok(Some(trimmed.to_owned()))\n   289→    }\n   290→}\n   291→\n   292→fn apply_optional_string(\n   293→    document: &mut DocumentMut,\n   294→    setting_name: &str,\n   295→    raw_value: &str,\n   296→) -> AppResult<()> {\n   297→    match parse_optional_string(setting_name, raw_value)? {\n   298→        Some(parsed) => {\n   299→            document[\"settings\"][setting_name] = value(parsed);\n   300→        }\n   301→        None => {\n   302→            if let Some(settings) = document\n   303→                .as_table_mut()\n   304→                .get_mut(\"settings\")\n   305→                .and_then(|item| item.as_table_mut())\n   306→            {\n   307→                settings.remove(setting_name);\n   308→            }\n   309→        }\n   310→    }\n   311→\n   312→    Ok(())\n   313→}\n   314→"}]},"parent_tool_use_id":"toolu_01GmHc9N8Srjnat2yn1mzYfx","session_id":"216e97eb-aa57-41df-a04f-9831b7c2815e","uuid":"f7a0d54e-bf05-4c2b-b59a-c79a1bc7bfd6"}
