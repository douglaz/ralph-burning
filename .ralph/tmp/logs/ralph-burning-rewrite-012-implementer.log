{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01PMdHNP1zAS8tLgfA7xfsRg","type":"tool_result","content":"     1→use chrono::{Duration, Utc};\n     2→use tempfile::tempdir;\n     3→\n     4→use ralph_burning::adapters::fs::FsDaemonStore;\n     5→use ralph_burning::adapters::worktree::WorktreeAdapter;\n     6→use ralph_burning::contexts::automation_runtime::model::{DaemonTask, TaskStatus, WorktreeLease};\n     7→use ralph_burning::contexts::automation_runtime::routing::RoutingEngine;\n     8→use ralph_burning::contexts::automation_runtime::task_service::{\n     9→    CreateTaskInput, DaemonTaskService,\n    10→};\n    11→use ralph_burning::contexts::automation_runtime::{DaemonStorePort, WorktreePort};\n    12→use ralph_burning::shared::domain::FlowPreset;\n    13→use ralph_burning::shared::error::AppError;\n    14→\n    15→fn sample_task() -> DaemonTask {\n    16→    let now = Utc::now();\n    17→    DaemonTask {\n    18→        task_id: \"task-1\".to_owned(),\n    19→        issue_ref: \"repo#1\".to_owned(),\n    20→        project_id: \"demo\".to_owned(),\n    21→        project_name: Some(\"Demo\".to_owned()),\n    22→        prompt: Some(\"Prompt\".to_owned()),\n    23→        routing_command: None,\n    24→        routing_labels: vec![],\n    25→        resolved_flow: Some(FlowPreset::Standard),\n    26→        routing_source: None,\n    27→        routing_warnings: vec![],\n    28→        status: TaskStatus::Pending,\n    29→        created_at: now,\n    30→        updated_at: now,\n    31→        attempt_count: 0,\n    32→        lease_id: None,\n    33→        failure_class: None,\n    34→        failure_message: None,\n    35→    }\n    36→}\n    37→\n    38→#[test]\n    39→fn routing_resolution_prefers_command_over_label_and_default() {\n    40→    let engine = RoutingEngine::new();\n    41→    let resolution = engine\n    42→        .resolve_flow(\n    43→            Some(\"/rb flow quick_dev\"),\n    44→            &[String::from(\"rb:flow:docs_change\")],\n    45→            FlowPreset::CiImprovement,\n    46→        )\n    47→        .expect(\"resolve flow\");\n    48→\n    49→    assert_eq!(FlowPreset::QuickDev, resolution.flow);\n    50→}\n    51→\n    52→#[test]\n    53→fn routing_labels_ignore_malformed_values_with_warning() {\n    54→    let engine = RoutingEngine::new();\n    55→    let resolution = engine\n    56→        .resolve_flow(\n    57→            None,\n    58→            &[String::from(\"rb:flow\"), String::from(\"rb:flow:docs_change\")],\n    59→            FlowPreset::Standard,\n    60→        )\n    61→        .expect(\"resolve labels\");\n    62→\n    63→    assert_eq!(FlowPreset::DocsChange, resolution.flow);\n    64→    assert_eq!(1, resolution.warnings.len());\n    65→}\n    66→\n    67→#[test]\n    68→fn conflicting_routing_labels_fail_resolution() {\n    69→    let engine = RoutingEngine::new();\n    70→    let error = engine\n    71→        .resolve_flow(\n    72→            None,\n    73→            &[\n    74→                String::from(\"rb:flow:standard\"),\n    75→                String::from(\"rb:flow:quick_dev\"),\n    76→            ],\n    77→            FlowPreset::Standard,\n    78→        )\n    79→        .expect_err(\"conflicting labels should fail\");\n    80→\n    81→    assert!(matches!(error, AppError::AmbiguousRouting { .. }));\n    82→}\n    83→\n    84→#[test]\n    85→fn task_state_machine_accepts_expected_transitions() {\n    86→    let mut task = sample_task();\n    87→    task.transition_to(TaskStatus::Claimed, Utc::now())\n    88→        .expect(\"pending -> claimed\");\n    89→    task.transition_to(TaskStatus::Active, Utc::now())\n    90→        .expect(\"claimed -> active\");\n    91→    task.transition_to(TaskStatus::Completed, Utc::now())\n    92→        .expect(\"active -> completed\");\n    93→}\n    94→\n    95→#[test]\n    96→fn task_state_machine_rejects_invalid_transition() {\n    97→    let mut task = sample_task();\n    98→    let error = task\n    99→        .transition_to(TaskStatus::Completed, Utc::now())\n   100→        .expect_err(\"pending -> completed should fail\");\n   101→\n   102→    assert!(matches!(error, AppError::TaskStateTransitionInvalid { .. }));\n   103→}\n   104→\n   105→#[test]\n   106→fn lease_ttl_detects_staleness() {\n   107→    let now = Utc::now();\n   108→    let lease = WorktreeLease {\n   109→        lease_id: \"lease-1\".to_owned(),\n   110→        task_id: \"task-1\".to_owned(),\n   111→        project_id: \"demo\".to_owned(),\n   112→        worktree_path: \"/tmp/demo\".into(),\n   113→        branch_name: \"rb/task/task-1\".to_owned(),\n   114→        acquired_at: now,\n   115→        ttl_seconds: 300,\n   116→        last_heartbeat: now,\n   117→    };\n   118→\n   119→    assert!(!lease.is_stale_at(now + Duration::seconds(299)));\n   120→    assert!(lease.is_stale_at(now + Duration::seconds(301)));\n   121→}\n   122→\n   123→#[test]\n   124→fn worktree_path_derivation_is_deterministic() {\n   125→    let adapter = WorktreeAdapter;\n   126→    let temp = tempdir().expect(\"tempdir\");\n   127→    let path = adapter.worktree_path(temp.path(), \"task-99\");\n   128→\n   129→    assert_eq!(temp.path().join(\".ralph-burning/worktrees/task-99\"), path);\n   130→    assert_eq!(\"rb/task/task-99\", adapter.branch_name(\"task-99\"));\n   131→}\n   132→\n   133→#[test]\n   134→fn create_task_rejects_duplicate_active_issue() {\n   135→    let store = FsDaemonStore;\n   136→    let temp = tempdir().expect(\"tempdir\");\n   137→    let routing = RoutingEngine::new();\n   138→\n   139→    DaemonTaskService::create_task(\n   140→        &store,\n   141→        temp.path(),\n   142→        &routing,\n   143→        FlowPreset::Standard,\n   144→        CreateTaskInput {\n   145→            task_id: \"task-1\".to_owned(),\n   146→            issue_ref: \"repo#1\".to_owned(),\n   147→            project_id: \"demo\".to_owned(),\n   148→            project_name: Some(\"Demo\".to_owned()),\n   149→            prompt: Some(\"Prompt\".to_owned()),\n   150→            routing_command: None,\n   151→            routing_labels: vec![],\n   152→        },\n   153→    )\n   154→    .expect(\"create first task\");\n   155→\n   156→    let error = DaemonTaskService::create_task(\n   157→        &store,\n   158→        temp.path(),\n   159→        &routing,\n   160→        FlowPreset::Standard,\n   161→        CreateTaskInput {\n   162→            task_id: \"task-2\".to_owned(),\n   163→            issue_ref: \"repo#1\".to_owned(),\n   164→            project_id: \"demo-2\".to_owned(),\n   165→            project_name: Some(\"Demo Two\".to_owned()),\n   166→            prompt: Some(\"Prompt\".to_owned()),\n   167→            routing_command: None,\n   168→            routing_labels: vec![],\n   169→        },\n   170→    )\n   171→    .expect_err(\"duplicate issue should fail\");\n   172→\n   173→    assert!(matches!(error, AppError::DuplicateTaskForIssue { .. }));\n   174→}\n   175→\n   176→#[test]\n   177→fn retry_resets_failed_task_to_pending_and_increments_attempt_count() {\n   178→    let store = FsDaemonStore;\n   179→    let temp = tempdir().expect(\"tempdir\");\n   180→    let mut task = sample_task();\n   181→    task.status = TaskStatus::Failed;\n   182→    task.set_failure(\"daemon_dispatch_failed\", \"boom\");\n   183→    store.create_task(temp.path(), &task).expect(\"persist task\");\n   184→\n   185→    let retried = DaemonTaskService::retry_task(&store, temp.path(), &task.task_id)\n   186→        .expect(\"retry failed task\");\n   187→\n   188→    assert_eq!(TaskStatus::Pending, retried.status);\n   189→    assert_eq!(1, retried.attempt_count);\n   190→    assert!(retried.failure_class.is_none());\n   191→    assert!(retried.failure_message.is_none());\n   192→}\n   193→"}]},"parent_tool_use_id":"toolu_01GmHc9N8Srjnat2yn1mzYfx","session_id":"216e97eb-aa57-41df-a04f-9831b7c2815e","uuid":"3163d134-27f1-45b9-bf68-dae2e9661ee4"}
