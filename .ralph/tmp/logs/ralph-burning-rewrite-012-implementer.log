(binary())","+        .args([\"run\", \"resume\"])","+        .current_dir(temp_dir.path())","+        .output()","+        .expect(\"run resume\");","     assert!(","-        stderr.contains(\"not yet supported\"),","-        \"should reject quick_dev flow, got: {stderr}\"","+        resume.status.success(),","+        \"run resume failed: {}\",","+        String::from_utf8_lossy(&resume.stderr)","     );","+","+    let run_json = fs::read_to_string(","+        temp_dir","+            .path()","+            .join(\".ralph-burning/projects/qd-resume/run.json\"),","+    )","+    .expect(\"read run.json\");","+    assert!(","+        run_json.contains(\"\\\"completed\\\"\"),","+        \"quick_dev run should be completed after resume, got: {run_json}\"","+    );"," }"," "," #[test]"]}],"userModified":false,"replaceAll":false}}
