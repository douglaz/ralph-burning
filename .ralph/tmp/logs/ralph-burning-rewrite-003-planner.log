{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01CrL7KpBy1hAdm1dqvhnoad","type":"tool_result","content":"     1→use std::path::{Path, PathBuf};\n     2→\n     3→use chrono::{DateTime, Utc};\n     4→\n     5→use crate::adapters::fs::FileSystem;\n     6→use crate::shared::domain::{WorkspaceConfig, CURRENT_WORKSPACE_VERSION};\n     7→use crate::shared::error::{AppError, AppResult};\n     8→\n     9→pub const WORKSPACE_DIR: &str = \".ralph-burning\";\n    10→pub const WORKSPACE_CONFIG_FILE: &str = \"workspace.toml\";\n    11→pub const REQUIRED_WORKSPACE_DIRECTORIES: &[&str] =\n    12→    &[\"projects\", \"requirements\", \"daemon/tasks\", \"daemon/leases\"];\n    13→\n    14→#[derive(Debug, Clone, PartialEq, Eq)]\n    15→pub struct WorkspaceInitialization {\n    16→    pub workspace_root: PathBuf,\n    17→    pub config: WorkspaceConfig,\n    18→}\n    19→\n    20→pub fn initialize_workspace(\n    21→    base_dir: &Path,\n    22→    created_at: DateTime<Utc>,\n    23→) -> AppResult<WorkspaceInitialization> {\n    24→    let workspace_root = base_dir.join(WORKSPACE_DIR);\n    25→    let config_path = workspace_root.join(WORKSPACE_CONFIG_FILE);\n    26→\n    27→    if config_path.exists() {\n    28→        return Err(AppError::AlreadyInitialized {\n    29→            path: workspace_root,\n    30→        });\n    31→    }\n    32→\n    33→    if workspace_root.exists() {\n    34→        return Err(AppError::WorkspaceConflict {\n    35→            path: workspace_root,\n    36→        });\n    37→    }\n    38→\n    39→    let config = WorkspaceConfig::new(created_at);\n    40→    let rendered = FileSystem::render_workspace_config(&config);\n    41→    FileSystem::create_workspace(&workspace_root, &rendered, REQUIRED_WORKSPACE_DIRECTORIES)?;\n    42→\n    43→    Ok(WorkspaceInitialization {\n    44→        workspace_root,\n    45→        config,\n    46→    })\n    47→}\n    48→\n    49→pub fn load_workspace_config(base_dir: &Path) -> AppResult<WorkspaceConfig> {\n    50→    let config_path = base_dir.join(WORKSPACE_DIR).join(WORKSPACE_CONFIG_FILE);\n    51→    let raw = FileSystem::read_to_string(&config_path)?;\n    52→    let config: WorkspaceConfig = toml::from_str(&raw)?;\n    53→    ensure_supported_workspace_version(&config)?;\n    54→    Ok(config)\n    55→}\n    56→\n    57→pub fn ensure_supported_workspace_version(config: &WorkspaceConfig) -> AppResult<()> {\n    58→    if config.version != CURRENT_WORKSPACE_VERSION {\n    59→        return Err(AppError::UnsupportedWorkspaceVersion {\n    60→            version: config.version,\n    61→            supported: CURRENT_WORKSPACE_VERSION,\n    62→        });\n    63→    }\n    64→\n    65→    Ok(())\n    66→}\n    67→"}]},"parent_tool_use_id":null,"session_id":"46f86fe6-16b8-4d7e-86ab-a2a23388603c","uuid":"28817072-b994-4310-a864-bf380369bdcb","tool_use_result":{"type":"text","file":{"filePath":"/root/new-ralph-burning/ralph-burning-rewrite/src/contexts/workspace_governance/mod.rs","content":"use std::path::{Path, PathBuf};\n\nuse chrono::{DateTime, Utc};\n\nuse crate::adapters::fs::FileSystem;\nuse crate::shared::domain::{WorkspaceConfig, CURRENT_WORKSPACE_VERSION};\nuse crate::shared::error::{AppError, AppResult};\n\npub const WORKSPACE_DIR: &str = \".ralph-burning\";\npub const WORKSPACE_CONFIG_FILE: &str = \"workspace.toml\";\npub const REQUIRED_WORKSPACE_DIRECTORIES: &[&str] =\n    &[\"projects\", \"requirements\", \"daemon/tasks\", \"daemon/leases\"];\n\n#[derive(Debug, Clone, PartialEq, Eq)]\npub struct WorkspaceInitialization {\n    pub workspace_root: PathBuf,\n    pub config: WorkspaceConfig,\n}\n\npub fn initialize_workspace(\n    base_dir: &Path,\n    created_at: DateTime<Utc>,\n) -> AppResult<WorkspaceInitialization> {\n    let workspace_root = base_dir.join(WORKSPACE_DIR);\n    let config_path = workspace_root.join(WORKSPACE_CONFIG_FILE);\n\n    if config_path.exists() {\n        return Err(AppError::AlreadyInitialized {\n            path: workspace_root,\n        });\n    }\n\n    if workspace_root.exists() {\n        return Err(AppError::WorkspaceConflict {\n            path: workspace_root,\n        });\n    }\n\n    let config = WorkspaceConfig::new(created_at);\n    let rendered = FileSystem::render_workspace_config(&config);\n    FileSystem::create_workspace(&workspace_root, &rendered, REQUIRED_WORKSPACE_DIRECTORIES)?;\n\n    Ok(WorkspaceInitialization {\n        workspace_root,\n        config,\n    })\n}\n\npub fn load_workspace_config(base_dir: &Path) -> AppResult<WorkspaceConfig> {\n    let config_path = base_dir.join(WORKSPACE_DIR).join(WORKSPACE_CONFIG_FILE);\n    let raw = FileSystem::read_to_string(&config_path)?;\n    let config: WorkspaceConfig = toml::from_str(&raw)?;\n    ensure_supported_workspace_version(&config)?;\n    Ok(config)\n}\n\npub fn ensure_supported_workspace_version(config: &WorkspaceConfig) -> AppResult<()> {\n    if config.version != CURRENT_WORKSPACE_VERSION {\n        return Err(AppError::UnsupportedWorkspaceVersion {\n            version: config.version,\n            supported: CURRENT_WORKSPACE_VERSION,\n        });\n    }\n\n    Ok(())\n}\n","numLines":67,"startLine":1,"totalLines":67}}}
