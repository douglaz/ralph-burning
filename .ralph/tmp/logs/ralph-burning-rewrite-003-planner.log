14→            cycle: 1,\n   215→            attempt: 1,\n   216→            completion_round: 1,\n   217→        }\n   218→    }\n   219→\n   220→    pub fn retry(&self) -> Self {\n   221→        Self {\n   222→            stage: self.stage,\n   223→            cycle: self.cycle,\n   224→            attempt: self.attempt + 1,\n   225→            completion_round: self.completion_round,\n   226→        }\n   227→    }\n   228→\n   229→    pub fn advance_stage(&self, stage: StageId) -> Self {\n   230→        Self {\n   231→            stage,\n   232→            cycle: self.cycle,\n   233→            attempt: 1,\n   234→            completion_round: self.completion_round,\n   235→        }\n   236→    }\n   237→\n   238→    pub fn advance_cycle(&self, stage: StageId) -> Self {\n   239→        Self {\n   240→            stage,\n   241→            cycle: self.cycle + 1,\n   242→            attempt: 1,\n   243→            completion_round: self.completion_round,\n   244→        }\n   245→    }\n   246→\n   247→    pub fn advance_completion_round(&self, stage: StageId) -> Self {\n   248→        Self {\n   249→            stage,\n   250→            cycle: self.cycle,\n   251→            attempt: 1,\n   252→            completion_round: self.completion_round + 1,\n   253→        }\n   254→    }\n   255→}\n   256→\n   257→#[derive(Debug, Clone, PartialEq, Eq, Hash, Serialize, Deserialize)]\n   258→#[serde(transparent)]\n   259→pub struct ProjectId(String);\n   260→\n   261→impl ProjectId {\n   262→    pub fn new(value: impl Into<String>) -> AppResult<Self> {\n   263→        let normalized = value.into().trim().to_owned();\n   264→        if normalized.is_empty() {\n   265→            return Err(AppError::InvalidIdentifier { value: normalized });\n   266→        }\n   267→\n   268→        Ok(Self(normalized))\n   269→    }\n   270→\n   271→    pub fn as_str(&self) -> &str {\n   272→        &self.0\n   273→    }\n   274→}\n   275→\n   276→impl fmt::Display for ProjectId {\n   