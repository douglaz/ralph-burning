      Self::Review => \"review\",\n   108\t            Self::CompletionPanel => \"completion_panel\",\n   109\t            Self::AcceptanceQa => \"acceptance_qa\",\n   110\t            Self::FinalReview => \"final_review\",\n   111\t            Self::PlanAndImplement => \"plan_and_implement\",\n   112\t            Self::ApplyFixes => \"apply_fixes\",\n   113\t            Self::DocsPlan => \"docs_plan\",\n   114\t            Self::DocsUpdate => \"docs_update\",\n   115\t            Self::DocsValidation => \"docs_validation\",\n   116\t            Self::CiPlan => \"ci_plan\",\n   117\t            Self::CiUpdate => \"ci_update\",\n   118\t            Self::CiValidation => \"ci_validation\",\n   119\t        }\n   120\t    }\n   121\t}\n   122\t\n   123\timpl fmt::Display for StageId {\n   124\t    fn fmt(&self, f: &mut fmt::Formatter<'_>) -> fmt::Result {\n   125\t        f.write_str(self.as_str())\n   126\t    }\n   127\t}\n   128\t\n   129\t#[derive(Debug, Clone, PartialEq, Eq, Serialize, Deserialize)]\n   130\tpub struct StageCursor {\n   131\t    pub stage: StageId,\n   132\t    pub cycle: u32,\n   133\t    pub attempt: u32,\n   134\t    pub completion_round: u32,\n   135\t}\n   136\t\n   137\timpl StageCursor {\n   138\t    pub fn new(stage: StageId, cycle: u32, attempt: u32, completion_round: u32) -> AppResult<Self> {\n   139\t        if cycle == 0 {\n   140\t            return Err(AppError::InvalidStageCursorField { field: \"cycle\" });\n   141\t        }\n   142\t        if attempt == 0 {\n   143\t            return Err(AppError::InvalidStageCursorField { field: \"attempt\" });\n   144\t        }\n   145\t        if completion_round == 0 {\n   146\t            return Err(AppError::InvalidStageCursorField {\n   147\t                field: \"completion_round\",\n   148\t            });\n   149\t        }\n   150\t\n   151\t        Ok(Self {\n   152\t            stage,\n   153\t            cycle,\n   154\t            attempt,\n   155\t            completion_round,\n   156\t        })\n   157\t    }\n   158\t\n   159\t    pub fn initial(stage: StageId) -> Self {\n   160\t        Self {\n   161\t            stage,\n   162\t            cycle: 1,\n   163\t            attempt: 1,\n   164\t            completion_round: 1,\n   165\t        }\n   166\t    }\n   167\t\n   168\t    pub fn retry(&self) -> Self {\n   169\t        Self {\n   170\t            stage: self.stage,\n   171\t            cycle: self.cycle,\n   172\t            attempt: self.attempt + 1,\n   173\t            completion_round: self.completion_round,\n   174\t        }\n   175\t    }\n   176\t\n   177\t    pub fn advance_stage(&self, stage: StageId) -> Self {\n   178\t        Self {\n   179\t            stage,\n   180\t            cycle: self.cycle,\n   181\t            attempt: 1,\n   182\t            completion_round: self.completion_round,\n   183\t        }\n   184\t    }\n   185\t\n   186\t    pub fn advance_cycle(&self, stage: StageId) -> Self {\n   187\t        Self {\n   188\t            stage,\n   189\t            cycle: self.cycle + 1,\n   190\t            attempt: 1,\n   191\t            completion_round: self.completion_round,\n   192\t        }\n   193\t    }\n   194\t\n   195\t    pub fn advance_completion_round(&self, stage: StageId) -> Self {\n   196\t        Self {\n   197\t            stage,\n   198\t            cycle: self.cycle,\n   199\t            attempt: 1,\n   200\t            completion_round: self.completion_round + 1,\n   201\t        }\n   202\t    }\n   203\t}\n   204\t\n   205\t#[derive(Debug, Clone, PartialEq, Eq, Hash, Serialize, Deserialize)]\n   206\t#[serde(transparent)]\n   207\tpub struct ProjectId(String);\n   208\t\n   209\timpl ProjectId {\n   210\t    pub fn new(value: impl Into<String>) -> AppResult<Self> {\n   211\t        let normalized = value.into().trim().to_owned();\n   212\t        if normalized.is_empty() {\n   213\t            return Err(AppError::InvalidIdentifier { value: normalized });\n   214\t        }\n   2