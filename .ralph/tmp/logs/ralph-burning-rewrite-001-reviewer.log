dard,\n    54\t        description:\n    55\t            \"Full delivery flow with planning, implementation, QA, review, and acceptance.\",\n    56\t        stages: &STANDARD_STAGES,\n    57\t        validation_profile: ValidationProfile {\n    58\t            name: \"standard-default\",\n    59\t            summary: \"Full validation suite with completion and acceptance checks.\",\n    60\t            final_review_enabled: true,\n    61\t        },\n    62\t    },\n    63\t    FlowDefinition {\n    64\t        preset: FlowPreset::QuickDev,\n    65\t        description: \"Fast delivery flow for small code changes with lightweight review.\",\n    66\t        stages: &QUICK_DEV_STAGES,\n    67\t        validation_profile: ValidationProfile {\n    68\t            name: \"quick-dev-default\",\n    69\t            summary: \"Lightweight panel with final review enabled by default.\",\n    70\t            final_review_enabled: true,\n    71\t        },\n    72\t    },\n    73\t    FlowDefinition {\n    74\t        preset: FlowPreset::DocsChange,\n    75\t        description: \"Documentation-focused flow for planning, content updates, and validation.\",\n    76\t        stages: &DOCS_CHANGE_STAGES,\n    77\t        validation_profile: ValidationProfile {\n    78\t            name: \"docs-default\",\n    79\t            summary: \"Documentation validation with final review disabled by default.\",\n    80\t            final_review_enabled: false,\n    81\t        },\n    82\t    },\n    83\t    FlowDefinition {\n    84\t        preset: FlowPreset::CiImprovement,\n    85\t        description: \"CI improvement flow for automation planning, updates, and validation.\",\n    86\t        stages: &CI_IMPROVEMENT_STAGES,\n    87\t        validation_profile: ValidationProfile {\n    88\t            name: \"ci-default\",\n    89\t            summary: \"Automation validation with final review disabled by default.\",\n    90\t            final_review_enabled: false,\n    91\t        },\n