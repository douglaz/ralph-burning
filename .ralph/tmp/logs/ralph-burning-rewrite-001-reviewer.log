ialization {\n    44\t        workspace_root,\n    45\t        config,\n    46\t    })\n    47\t}\n    48\t\n    49\tpub fn load_workspace_config(base_dir: &Path) -> AppResult<WorkspaceConfig> {\n    50\t    let config_path = base_dir.join(WORKSPACE_DIR).join(WORKSPACE_CONFIG_FILE);\n    51\t    let raw = FileSystem::read_to_string(&config_path)?;\n    52\t    let config: WorkspaceConfig = toml::from_str(&raw)?;\n    53\t    ensure_supported_workspace_version(&config)?;\n    54\t    Ok(config)\n    55\t}\n    56\t\n    57\tpub fn ensure_supported_workspace_version(config: &WorkspaceConfig) -> AppResult<()> {\n    58\t    if config.version != CURRENT_WORKSPACE_VERSION {\n    59\t        return Err(AppError::UnsupportedWorkspaceVersion {\n    60\t            version: config.version,\n    61\t            supported: CURRENT_WORKSPACE_VERSION,\n    62\t        });\n    63\t    }\n    64\t\n    65\t    Ok(())\n    66\t}\n","exit_code":0,"status":"completed"}}
