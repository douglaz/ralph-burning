2→        &self,\n    43→        base_dir: &Path,\n    44→        project_id: &ProjectId,\n    45→        lease_id: &str,\n    46→    ) -> AppResult<()>;\n    47→    fn release_writer_lock(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<()>;\n    48→}\n    49→\n    50→pub trait WorktreePort {\n    51→    fn worktree_path(&self, base_dir: &Path, task_id: &str) -> PathBuf;\n    52→    fn branch_name(&self, task_id: &str) -> String;\n    53→    fn create_worktree(\n    54→        &self,\n    55→        repo_root: &Path,\n    56→        worktree_path: &Path,\n    57→        branch_name: &str,\n    58→        task_id: &str,\n    59→    ) -> AppResult<()>;\n    60→    fn remove_worktree(\n    61→        &self,\n    62→        repo_root: &Path,\n    63→        worktree_path: &Path,\n    64→        task_id: &str,\n    65→    ) -> AppResult<()>;\n    66→    fn rebase_onto_default_branch(\n    67→        &self,\n    68→        repo_root: &Path,\n    69→        worktree_path: &Path,\n    70→        branch_name: &str,\n    71→    ) -> AppResult<()>;\n    72→}\n    73→"}]},"parent_tool_use_id":"toolu_01TEaD8r9ay6pGSRWy6ah8ZA","session_id":"62aed473-a912-4db2-a48b-52d5c598eaf3","uuid":"48507015-ddcf-439e-9965-29c06880a62d"}
