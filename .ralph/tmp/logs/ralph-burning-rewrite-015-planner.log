{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Vre3CFkKWZANz6NvWdoHfW","type":"tool_result","content":"     1→use std::collections::HashSet;\n     2→use std::path::Path;\n     3→\n     4→use crate::shared::error::{AppError, AppResult};\n     5→\n     6→use super::model::{IdSource, ScenarioKind, ScenarioMeta};\n     7→\n     8→/// Compile-time path to the conformance feature directory.\n     9→const FEATURES_DIR: &str = concat!(env!(\"CARGO_MANIFEST_DIR\"), \"/tests/conformance/features\");\n    10→\n    11→/// Returns the path to the conformance features directory.\n    12→pub fn features_dir() -> &'static Path {\n    13→    Path::new(FEATURES_DIR)\n    14→}\n    15→\n    16→/// Discover all conformance scenarios from `.feature` files.\n    17→///\n    18→/// Returns scenarios in deterministic order: feature files sorted by path,\n    19→/// then scenarios in file order.\n    20→///\n    21→/// Respects the `RALPH_BURNING_TEST_FEATURES_DIR` environment variable to\n    22→/// allow tests to point discovery at an isolated feature directory instead\n    23→/// of the checked-in corpus.\n    24→pub fn discover_scenarios() -> AppResult<Vec<ScenarioMeta>> {\n    25→    let dir = match std::env::var(\"RALPH_BURNING_TEST_FEATURES_DIR\") {\n    26→        Ok(override_dir) if !override_dir.is_empty() => {\n    27→            std::path::PathBuf::from(override_dir)\n    28→        }\n    29→        _ => features_dir().to_path_buf(),\n    30→    };\n    31→    discover_scenarios_from(&dir)\n    32→}\n    33→\n    34→/// Discover scenarios from a specific features directory (testable).\n    35→pub fn discover_scenarios_from(dir: &Path) -> AppResult<Vec<ScenarioMeta>> {\n    36→    if !dir.is_dir() {\n    37→        return Err(AppError::ConformanceDiscoveryFailed {\n    38→            details: format!(\"features directory not found: {}\", dir.display()),\n    39→        });\n    40→    }\n    41→\n    42→    let mut feature_files: Vec<_> = std::fs::read_dir(dir)\n    43→        .map_err(|e| AppError::ConformanceDiscoveryFailed {\n    44→            details: format!(\"cannot read features directory: {e}\"),\n    45→        })?\n    46→        .filter_map(|entry| {\n    47→            let entry = entry.ok()?;\n    48→            let path = entry.path();\n    49→            if path.extension().map_or(false, |ext| ext == \"feature\") {\n    50→                Some(path)\n    51→            } else {\n    52→                None\n    53→            }\n    54→        })\n    55→        .collect();\n    56→\n    57→    feature_files.sort();\n    58→\n    59→    let mut all_scenarios = Vec::new();\n    60→\n    61→    for file_path in &feature_files {\n    62→        let content = std::fs::read_to_string(file_path).map_err(|e| {\n    63→            AppError::ConformanceDiscoveryFailed {\n    64→                details: format!(\"cannot read {}: {e}\", file_path.display()),\n    65→            }\n    66→        })?;\n    67→        let file_name = file_path\n    68→            .file_name()\n    69→            .unwrap_or_default()\n    70→            .to_string_lossy()\n    71→            .to_string();\n    72→        let scenarios = parse_feature_file(&content, &file_name)?;\n    73→        all_scenarios.extend(scenarios);\n    74→    }\n    75→\n    76→    if all_scenarios.is_empty() {\n    77→        return Err(AppError::ConformanceDiscoveryFailed {\n    78→            details: \"no scenarios discovered from feature files\".to_owned(),\n    79→        });\n    80→    }\n    81→\n    82→    Ok(all_scenarios)\n    83→}\n    84→\n    85→/// Validate that all discovered scenario IDs are unique and well-formed.\n    86→pub fn validate_ids(scenarios: &[ScenarioMeta]) -> AppResult<()> {\n    87→    let mut seen = HashSet::new();\n    88→\n    89→    for scenario in scenarios {\n    90→        // Validate ID format: non-empty, no whitespace\n    91→        if scenario.id.is_empty() {\n    92→            return Err(AppError::ConformanceParseFailed {\n    93→                file: scenario.source_file.clone(),\n    94→                line: scenario.source_line,\n    95→                details: \"scenario ID is empty\".to_owned(),\n    96→            });\n    97→        }\n    98→\n    99→        if scenario.id.chars().any(|c| c.is_whitespace()) {\n   100→            return Err(AppError::ConformanceParseFailed {"}]},"parent_tool_use_id":"toolu_01TEaD8r9ay6pGSRWy6ah8ZA","session_id":"62aed473-a912-4db2-a48b-52d5c598eaf3","uuid":"35ad4ba6-7ce6-4fd7-b5e3-05c220d366f7"}
