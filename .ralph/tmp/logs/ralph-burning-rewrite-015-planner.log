{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01KcD9kLvevR6hDuXnx2kyw3","type":"tool_result","content":"     1→use std::fmt;\n     2→use std::str::FromStr;\n     3→\n     4→use chrono::{DateTime, Utc};\n     5→use serde::{Deserialize, Serialize};\n     6→use toml::Table;\n     7→\n     8→use crate::shared::error::{AppError, AppResult};\n     9→\n    10→pub const CURRENT_WORKSPACE_VERSION: u32 = 1;\n    11→\n    12→/// Canonical failure classes for stage contract evaluation and retry semantics.\n    13→#[derive(Debug, Clone, Copy, PartialEq, Eq, Hash, Serialize, Deserialize)]\n    14→#[serde(rename_all = \"snake_case\")]\n    15→pub enum FailureClass {\n    16→    TransportFailure,\n    17→    SchemaValidationFailure,\n    18→    DomainValidationFailure,\n    19→    Timeout,\n    20→    Cancellation,\n    21→    QaReviewOutcomeFailure,\n    22→}\n    23→\n    24→impl FailureClass {\n    25→    pub fn as_str(self) -> &'static str {\n    26→        match self {\n    27→            Self::TransportFailure => \"transport_failure\",\n    28→            Self::SchemaValidationFailure => \"schema_validation_failure\",\n    29→            Self::DomainValidationFailure => \"domain_validation_failure\",\n    30→            Self::Timeout => \"timeout\",\n    31→            Self::Cancellation => \"cancellation\",\n    32→            Self::QaReviewOutcomeFailure => \"qa_review_outcome_failure\",\n    33→        }\n    34→    }\n    35→}\n    36→\n    37→impl fmt::Display for FailureClass {\n    38→    fn fmt(&self, f: &mut fmt::Formatter<'_>) -> fmt::Result {\n    39→        f.write_str(self.as_str())\n    40→    }\n    41→}\n    42→\n    43→#[derive(Debug, Clone, Copy, PartialEq, Eq, Hash, Serialize, Deserialize)]\n    44→#[serde(rename_all = \"snake_case\")]\n    45→pub enum BackendFamily {\n    46→    Claude,\n    47→    Codex,\n    48→    OpenRouter,\n    49→    Stub,\n    50→}\n    51→\n    52→impl BackendFamily {\n    53→    pub fn as_str(self) -> &'static str {\n    54→        match self {\n    55→            Self::Claude => \"claude\",\n    56→            Self::Codex => \"codex\",\n    57→            Self::OpenRouter => \"openrouter\",\n    58→            Self::Stub => \"stub\",\n    59→        }\n    60→    }\n    61→\n    62→    pub fn display_name(self) -> &'static str {\n    63→        match self {\n    64→            Self::Claude => \"Claude\",\n    65→            Self::Codex => \"Codex\",\n    66→            Self::OpenRouter => \"OpenRouter\",\n    67→            Self::Stub => \"Stub\",\n    68→        }\n    69→    }\n    70→\n    71→    pub fn default_model_id(self) -> &'static str {\n    72→        match self {\n    73→            Self::Claude => \"opus-4.1\",\n    74→            Self::Codex => \"gpt-5-codex\",\n    75→            Self::OpenRouter => \"openai/gpt-5\",\n    76→            Self::Stub => \"stub-default\",\n    77→        }\n    78→    }\n    79→}\n    80→\n    81→impl fmt::Display for BackendFamily {\n    82→    fn fmt(&self, f: &mut fmt::Formatter<'_>) -> fmt::Result {\n    83→        f.write_str(self.as_str())\n    84→    }\n    85→}\n    86→\n    87→impl FromStr for BackendFamily {\n    88→    type Err = AppError;\n    89→\n    90→    fn from_str(value: &str) -> Result<Self, Self::Err> {\n    91→        match value {\n    92→            \"claude\" => Ok(Self::Claude),\n    93→            \"codex\" => Ok(Self::Codex),\n    94→            \"openrouter\" => Ok(Self::OpenRouter),\n    95→            \"stub\" => Ok(Self::Stub),\n    96→            _ => Err(AppError::InvalidConfigValue {\n    97→                key: \"backend\".to_owned(),\n    98→                value: value.to_owned(),\n    99→                reason: \"expected one of claude, codex, openrouter, stub\".to_owned(),\n   100→            }),\n   101→        }\n   102→    }\n   103→}\n   104→\n   105→#[derive(Debug, Clone, PartialEq, Eq, Serialize, Deserialize)]\n   106→pub struct CapabilityMetadata {\n   107→    pub supports_structured_output: bool,\n   108→    pub supports_session_reuse: bool,\n   109→    pub supports_cancellation: bool,\n   110→    pub supported_stages: Vec<StageId>,\n   111→}\n   112→\n   113→impl CapabilityMetadata {\n   114→    pub fn for_all_stages(supports_session_reuse: bool, supports_cancellation: bool) -> Self {\n   115→        Self {\n   116→            supports_structured_output: true,\n   117→            supports_session_reuse,\n   118→            supports_cancellation,\n   119→            supported_stages: StageId::ALL.to_vec(),\n   120→        }\n   121→    }\n   122→\n   123→    pub fn supports_stage(&self, stage_id: StageId) -> bool {\n   124→        self.supported_stages.contains(&stage_id)\n   125→    }\n   126→}\n   127→\n   128→#[derive(Debug, Clone, PartialEq, Eq, Serialize, Deserialize)]\n   129→pub struct BackendSpec {\n   130→    pub family: BackendFamily,\n   131→    pub display_name: String,\n   132→    pub capabilities: CapabilityMetadata,\n   133→}\n   134→\n   135→impl BackendSpec {\n   136→    pub fn from_family(family: BackendFamily) -> Self {\n   137→        let supports_session_reuse = !matches!(family, BackendFamily::OpenRouter);\n   138→        Self {\n   139→            family,\n   140→            display_name: family.display_name().to_owned(),\n   141→            capabilities: CapabilityMetadata::for_all_stages(supports_session_reuse, true),\n   142→        }\n   143→    }\n   144→}\n   145→\n   146→impl fmt::Display for BackendSpec {\n   147→    fn fmt(&self, f: &mut fmt::Formatter<'_>) -> fmt::Result {\n   148→        f.write_str(&self.display_name)\n   149→    }\n   150→}\n   151→\n   152→#[derive(Debug, Clone, PartialEq, Eq, Serialize, Deserialize)]\n   153→pub struct ModelSpec {\n   154→    pub backend_family: BackendFamily,\n   155→    pub model_id: String,\n   156→    pub display_name: String,\n   157→    pub capabilities: CapabilityMetadata,\n   158→}\n   159→\n   160→impl ModelSpec {\n   161→    pub fn new(backend_family: BackendFamily, model_id: impl Into<String>) -> Self {\n   162→        let model_id = model_id.into();\n   163→        let display_name = format!(\"{} {}\", backend_family.display_name(), model_id);\n   164→        let supports_session_reuse = !matches!(backend_family, BackendFamily::OpenRouter);\n   165→        Self {\n   166→            backend_family,\n   167→            model_id,\n   168→            display_name,\n   169→            capabilities: CapabilityMetadata::for_all_stages(supports_session_reuse, true),\n   170→        }\n   171→    }\n   172→\n   173→    pub fn default_for_backend(backend_family: BackendFamily) -> Self {\n   174→        Self::new(backend_family, backend_family.default_model_id())\n   175→    }\n   176→}\n   177→\n   178→impl fmt::Display for ModelSpec {\n   179→    fn fmt(&self, f: &mut fmt::Formatter<'_>) -> fmt::Result {\n   180→        f.write_str(&self.display_name)\n   181→    }\n   182→}\n   183→\n   184→#[derive(Debug, Clone, PartialEq, Eq, Serialize, Deserialize)]\n   185→pub struct ResolvedBackendTarget {\n   186→    pub backend: BackendSpec,\n   187→    pub model: ModelSpec,\n   188→}\n   189→\n   190→impl ResolvedBackendTarget {\n   191→    pub fn new(backend_family: BackendFamily, model_id: impl Into<String>) -> Self {\n   192→        Self {\n   193→            backend: BackendSpec::from_family(backend_family),\n   194→            model: ModelSpec::new(backend_family, model_id),\n   195→        }\n   196→    }\n   197→\n   198→    pub fn supports_stage(&self, stage_id: StageId) -> bool {\n   199→        self.backend.capabilities.supports_stage(stage_id)\n   200→            && self.model.capabilities.supports_stage(stage_id)"}]},"parent_tool_use_id":"toolu_01TEaD8r9ay6pGSRWy6ah8ZA","session_id":"62aed473-a912-4db2-a48b-52d5c598eaf3","uuid":"5b72b7af-7023-48b4-a13a-c8c749f94cb8"}
