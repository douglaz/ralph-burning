permissions\");\n    81\t    script_path\n    82\t}\n    83\t\n    84\tfn write_daemon_task(base_dir: &std::path::Path, task: &DaemonTask) {\n    85\t    let path = base_dir\n    86\t        .join(\".ralph-burning/daemon/tasks\")\n    87\t        .join(format!(\"{}.json\", task.task_id));\n    88\t    fs::create_dir_all(path.parent().expect(\"task parent\")).expect(\"create task dir\");\n    89\t    fs::write(\n    90\t        path,\n    91\t        serde_json::to_string_pretty(task).expect(\"serialize daemon task\"),\n    92\t    )\n    93\t    .expect(\"write daemon task\");\n    94\t}\n    95\t\n    96\tfn write_worktree_lease(base_dir: &std::path::Path, lease: &WorktreeLease) {\n    97\t    let path = base_dir\n    98\t        .join(\".ralph-burning/daemon/leases\")\n    99\t        .join(format!(\"{}.json\", lease.lease_id));\n   100\t    fs::create_dir_all(path.parent().expect(\"lease parent\")).expect(\"create lease dir\");\n   101\t    fs::write(\n   102\t        path,\n   103\t        serde_json::to_string_pretty(lease).expect(\"serialize daemon lease\"),\n   104\t    )\n   105\t    .expect(\"write daemon lease\");\n   106\t}\n   107\t\n   108\tfn init_git_repo(base_dir: &std::path::Path) {\n   109\t    let init = Command::new(\"git\")\n   110\t        .args([\"init\", \"-b\", \"main\"])\n   111\t        .current_dir(base_dir)\n   112\t        .output()\n   113\t        .expect(\"git init\");\n   114\t    assert!(\n   115\t        init.status.success(),\n   116\t        \"{}\",\n   117\t        String::from_utf8_lossy(&init.stderr)\n   118\t    );\n   119\t\n   120\t    let name = Command::new(\"git\")\n   121\t        .args([\"config\", \"user.name\", \"Test User\"])\n   122\t        .current_dir(base_dir)\n   123\t        .output()\n   124\t        .expect(\"git config user.name\");\n   125\t    assert!(name.status.success());\n   126\t\n   127\t    let email = Command::new(\"git\")\n   128\t        .args([\"config\", \"user.email\", \"test@example.com\"])\n   129\t        .current_dir(base_dir)\n   130\t        .output()\n   131\t        .expect(\"git config user.email\");\n   132\t    assert!(email.status.success());\n   133\t\n   134\t    fs::write(base_dir.join(\"README.md\"), \"# fixture\\n\").expect(\"write readme\");\n   135\t    let add = Command::new(\"git\")\n   136\t        .args([\"add\", \"README.md\"])\n   137\t        .current_dir(base_dir)\n   138\t        .output()\n   139\t        .expect(\"git add\");\n   140\t    assert!(add.status.success());\n   141\t\n   142\t    let commit = Command::new(\"git\")\n   143\t        .args([\"commit\", \"-m\", \"initial\"])\n   144\t        .current_dir(base_dir)\n   145\t        .output()\n   146\t        .expect(\"git commit\");\n   147\t    assert!(\n   148\t        commit.status.success(),\n   149\t        \"{}\",\n   150\t        String::from_utf8_lossy(&commit.stderr)\n   151\t    );\n   152\t}\n   153\t\n   154\t#[test]\n   155\tfn flow_list_prints_all_presets() {\n   156\t    let output = Command::new(binary())\n   157\t        .args([\"flow\", \"list\"])\n   158\t        .output()\n   159\t        .expect(\"run flow list\");\n   160\t\n   161\t    assert!(output.status.success());\n   162\t\n   163\t    let stdout = String::from_utf8_lossy(&output.stdout);\n   164\t    assert!(stdout.contains(\"standard\"));\n   165\t    assert!(stdout.contains(\"quick_dev\"));\n   166\t    assert!(stdout.contains(\"docs_change\"));\n   167\t    assert!(stdout.contains(\"ci_improvement\"));\n   168\t}\n   169\t\n   170\t#[test]\n   171\tfn flow_show_standard_prints_stage_sequence() {\n   172\t    let output = Command::new(binary())\n   173\t        .args([\"flow\", \"show\", \"standard\"])\n   174\t        .output()\n   175\t        .expect(\"run flow show\");\n   176\t\n   177\t    assert!(output.status.success());\n   178\t\n   179\t    let stdout = String::from_utf8_lossy(&output.stdout);\n   180\t    assert!(stdout.contains(\"Stage count: 8\"));\n   181\t    assert!(stdout.contains(\"1. prompt_review\"));\n   182\t    assert!(stdout.contains(\"8. final_review\"));\n   183\t    assert!(stdout.contains(\"Final review enabled: yes\"));\n   184\t}\n   185\t\n   186\t#[test]\n   187\tfn flow_show_invalid_preset_exits_non_zero_with_clear_error() {\n   188\t    let output = Command::new(binary())\n   189\t        .args([\"flow\", \"show\", \"unknown_flow\"])\n   190\t        .output()\n   191\t        .expect(\"run flow show invalid\");\n   192\t\n   193\t    assert!(!output.status.success());\n   194\t\n   195\t    let stderr = String::from_utf8_lossy(&output.stderr);\n   196\t    assert!(stderr.contains(\"unknown flow preset 'unknown_flow'\"));\n   197\t}\n   198\t\n   199\t#[test]\n   200\tfn init_creates_workspace_layout() {\n   201\t    let temp_dir = tempdir().expect(\"create temp dir\");\n   202\t    let output = Command::new(binary())\n   203\t        .arg(\"init\")\n   204\t        .current_dir(temp_dir.path())\n   205\t        .output()\n   206\t        .expect(\"run init\");\n   207\t\n   208\t    assert!(output.status.success());\n   209\t    assert!(temp_dir\n   210\t        .path()\n   211\t        .join(\".ralph-burning/workspace.toml\")\n   212\t        .is_file());\n   213\t    assert!(temp_dir.path().join(\".ralph-burning/projects\").is_dir());\n   214\t    assert!(temp_dir.path().join(\".ralph-burning/requirements\").is_dir());\n   215\t    assert!(temp_dir.path().join(\".ralph-burning/daemon/tasks\").is_dir());\n   216\t    assert!(temp_dir\n   217\t        .path()\n   218\t        .join(\".ralph-burning/daemon/leases\")\n   219\t        .is_dir());\n   220\t}\n   221\t\n   222\t#[test]\n   223\tfn init_fails_when_workspace_already_exists() {\n   224\t    let temp_dir = tempdir().expect(\"create temp dir\");\n   225\t\n   226\t    let first = Command::new(binary())\n   227\t        .arg(\"init\")\n   228\t        .current_dir(temp_dir.path())\n   229\t        .output()\n   230\t        .expect(\"run first init\");\n   231\t    assert!(first.status.success());\n   232\t\n   233\t    let second = Command::new(binary())\n   234\t        .arg(\"init\")\n   235\t        .current_dir(temp_dir.path())\n   236\t        .output()\n   237\t        .expect(\"run second init\");\n   238\t\n   239\t    assert!(!second.status.success());\n   240\t\n   241\t    let stderr = String::from_utf8_lossy(&second.stderr);\n   242\t    assert!(stderr.contains(\"workspace already initialized\"));\n   243\t}\n   244\t\n   245\t#[test]\n   246\tfn config_show_prints_effective_values_and_sources() {\n   247\t    let temp_dir = initialize_workspace_fixture();\n   248\t\n   249\t    let output = Command::new(binary())\n   250\t        .args([\"config\", \"show\"])\n   251\t        .current_dir(temp_dir.path())\n   252\t        .output()\n   253\t        .expect(\"run config show\");\n   254\t\n   255\t    assert!(output.status.success());\n   256\t\n   257\t    let stdout = String::from_utf8_lossy(&output.stdout);\n   258\t    assert!(stdout.contains(\"[settings]\"));\n   259\t    assert!(stdout.contains(\"prompt_review.enabled = true # source: default\"));\n   260\t    assert!(stdout.contains(\"default_flow = \\\"standard\\\" # source: default\"));\n   261\t    assert!(stdout.contains(\"default_backend = \\\"<unset>\\\" # source: default\"));\n   262\t}\n   263\t\n   264\t#[test]\n   265\tfn daemon_status_lists_non_terminal_tasks_first() {\n   266\t    let temp_dir = initialize_workspace_fixture();\n   267\t    let now = Utc::now();\n   268\t\n   269\t    write_daemon_task(\n   270\t        temp_dir.path(),\n   271\t        &DaemonTask {\n   272\t            task_id: \"task-active\".to_owned(),\n   273\t            issue_ref: \"repo#2\".to_owned(),\n   274\t            project_id: \"demo-active\".to_owned(),\n   275\t            project_name: Some(\"Active\".to_owned()),\n   276\t            prompt: Some(\"Prompt\".to_owned()),\n   277\t            routing_command: None,\n   278\t            routing_labels: vec![],\n   279\t            resolved_flow: Some(FlowPreset::Standard),\n   280\t            routing_source: Some(RoutingSource::DefaultFlow),\n   281\t            routing_warnings: vec![],\n   282\t            status: TaskStatus::Active,\n   283\t            created_at: now,\n   284\t            updated_at: now,\n   285\t            attempt_count: 0,\n   286\t            lease_id: Some(\"lease-active\".to_owned()),\n   287\t            failure_class: None,\n   288\t            failure_message: None,\n   289\t        },\n   290\t    );\n   291\t    write_worktree_lease(\n   292\t        temp_dir.path(),\n   293\t        &WorktreeLease {\n   294\t            lease_id: \"lease-active\".to_owned(),\n   295\t            task_id: \"task-active\".to_owned(),\n   296\t            project_id: \"demo-active\".to_owned(),\n   297\t            worktree_path: temp_dir.path().join(\".ralph-burning/worktrees/task-active\"),\n   298\t            branch_name: \"rb/task/task-active\".to_owned(),\n   299\t            acquired_at: now,\n   300\t            ttl_seconds: 300,\n   301\t            last_heartbeat: now,\n   302\t        },\n   303\t    );\n   304\t    write_daemon_task(\n   305\t        temp_dir.path(),\n   306\t        &DaemonTask {\n   307\t            task_id: \"task-completed\".to_owned(),\n   308\t            issue_ref: \"repo#3\".to_owned(),\n   309\t            project_id: \"demo-completed\".to_owned(),\n   310\t            project_name: Some(\"Completed\".to_owned()),\n   311\t            prompt: Some(\"Prompt\".to_owned()),\n   312\t            routing_command: None,\n   313\t            routing_labels: vec![],\n   314\t            resolved_flow: Some(FlowPreset::Standard),\n   315\t            routing_source: Some(RoutingSource::DefaultFlow),\n   316\t            routing_warnings: vec![],\n   317\t            status: TaskStatus::Completed,\n   318\t            created_at: now,\n   319\t            updated_at: now,\n   320\t            attempt_count: 0,\n   321\t            lease_id: None,\n   322\t            failure_class: None,\n   323\t            failure_message: None,\n   324\t        },\n   325\t    );\n   326\t\n   327\t    let output = Command::new(binary())\n   328\t        .args([\"daemon\", \"status\"])\n   329\t        .current_dir(temp_dir.path())\n   330\t        .output()\n   331\t        .expect(\"run daemon status\");\n   332\t    assert!(output.status.success());\n   333\t\n   334\t    let stdout = String::from_utf8_lossy(&output.stdout);\n   335\t    let active_idx = stdout.find(\"task-active\").expect(\"active task\");\n   336\t    let completed_idx = stdout.find(\"task-completed\").expect(\"completed task\");\n   337\t    assert!(active_idx < completed_idx);\n   338\t    assert!(stdout.contains(\"lease=lease-active\"));\n   339\t}\n   340\t\n   341\t#[test]\n   342\tfn daemon_retry_transitions_failed_task_to_pending() {\n   343\t    let temp_dir = initialize_workspace_fixture();\n   344\t    let now = Utc::now();\n   345\t    write_daemon_task(\n   346\t        temp_dir.path(),\n   347\t        &DaemonTask {\n   348\t            task_id: \"task-failed\".to_owned(),\n   349\t            issue_ref: \"repo#4\".to_owned(),\n   350\t            project_id: \"demo-failed\".to_owned(),\n   351\t            project_name: Some(\"Failed\".to_owned()),\n   352\t            prompt: Some(\"Prompt\".to_owned()),\n   353\t            routing_command: None,\n   354\t            routing_labels: vec![],\n   355\t            resolved_flow: Some(FlowPreset::Standard),\n   356\t            routing_source: Some(RoutingSource::DefaultFlow),\n   357\t            routing_warnings: vec![],\n   358\t            status: TaskStatus::Failed,\n   359\t            created_at: now,\n   360\t            updated_at: now,\n   361\t            attempt_count: 0,\n   362\t            lease_id: None,\n   363\t            failure_class: Some(\"daemon_dispatch_failed\".to_owned()),\n   364\t            failure_message: Some(\"boom\".to_owned()),\n   365\t        },\n   366\t    );\n   367\t\n   368\t    let output = Command::new(binary())\n   369\t        .args([\"daemon\", \"retry\", \"task-failed\"])\n   370\t        .current_dir(temp_dir.path())\n   371\t        .output()\n   372\t        .expect(\"run daemon retry\");\n   373\t    assert!(output.status.success());\n   374\t\n   375\t    let task_path = temp_dir\n   376\t        .path()\n   377\t        .join(\".ralph-burning/daemon/tasks/task-failed.json\");\n   378\t    let task: DaemonTask =\n   379\t        serde_json::from_str(&fs::read_to_string(task_path).expect(\"read task\")).expect(\"task\");\n   380\t    assert_eq!(TaskStatus::Pending, task.status);\n   381\t    assert_eq!(1, task.attempt_count);\n   382\t}\n   383\t\n   384\t#[test]\n   385\tfn daemon_abort_claimed_task_releases_lease() {\n   386\t    let temp_dir = initialize_workspace_fixture();\n   387\t    let now = Utc::now();\n   388\t    let missing_worktree = temp_dir.path().join(\".ralph-burning/worktrees/missing\");\n   389\t    write_daemon_task(\n   390\t        temp_dir.path(),\n   391\t        &DaemonTask {\n   392\t            task_id: \"task-claimed\".to_owned(),\n   393\t            issue_ref: \"repo#5\".to_owned(),\n   394\t            project_id: \"demo-claimed\".to_owned(),\n   395\t            project_name: Some(\"Claimed\".to_owned()),\n   396\t            prompt: Some(\"Prompt\".to_owned()),\n   397\t            routing_command: None,\n   398\t            routing_labels: vec![],\n   399\t            resolved_flow: Some(FlowPreset::Standard),\n   400\t            routing_source: Some(RoutingSource::DefaultFlow),\n   401\t            routing_warnings: vec![],\n   402\t            status: TaskStatus::Claimed,\n   403\t            created_at: now,\n   404\t            updated_at: now,\n   405\t            attempt_count: 0,\n   406\t            lease_id: Some(\"lease-claimed\".to_owned()),\n   407\t            failure_class: None,\n   408\t            failure_message: None,\n   409\t        },\n   410\t    );\n   411\t    write_worktree_lease(\n   412\t        temp_dir.path(),\n   413\t        &WorktreeLease {\n   414\t            lease_id: \"lease-claimed\".to_owned(),\n   415\t            task_id: \"task-claimed\".to_owned(),\n   416\t            project_id: \"demo-claimed\".to_owned(),\n   417\t            worktree_path: missing_worktree,\n   418\t            branch_name: \"rb/task/task-claimed\".to_owned(),\n   419\t            acquired_at: now,\n   420\t            ttl_seconds: 300,\n","exit_code":0,"status":"completed"}}
