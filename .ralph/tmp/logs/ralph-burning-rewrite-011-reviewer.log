 if let Some(model_id) = &selection.model_id {\n    90\t            target.model = ModelSpec::new(target.backend.family, model_id.clone());\n    91\t        }\n    92\t    }\n    93\t\n    94\t    fn apply_model_override(target: &mut ResolvedBackendTarget, model_override: ModelSpec) {\n    95\t        if target.backend.family != model_override.backend_family {\n    96\t            target.backend = BackendSpec::from_family(model_override.backend_family);\n    97\t        }\n    98\t        target.model = model_override;\n    99\t    }\n   100\t}\n   101\t\n   102\t#[allow(async_fn_in_trait)]\n   103\tpub trait AgentExecutionPort {\n   104\t    async fn check_capability(\n   105\t        &self,\n   106\t        backend: &ResolvedBackendTarget,\n   107\t        contract: &InvocationContract,\n   108\t    ) -> AppResult<()>;\n   109\t\n   110\t    async fn check_availability(&self, backend: &ResolvedBackendTarget) -> AppResult<()>;\n   111\t\n   112\t    async fn invoke(&self, request: InvocationRequest) -> AppResult<InvocationEnvelope>;\n   113\t\n   114\t    async fn cancel(&self, invocation_id: &str) -> AppResult<()>;\n   115\t}\n   116\t\n   117\tpub trait RawOutputPort {\n   118\t    fn persist_raw_output(\n   119\t        &self,\n   120\t        project_root: &Path,\n   121\t        invocation_id: &str,\n   122\t        contents: &str,\n   123\t    ) -> AppResult<RawOutputReference>;\n   124\t}\n   125\t\n   126\tpub struct AgentExecutionService<A, R, S> {\n   127\t    adapter: A,\n   128\t    raw_output_store: R,\n   129\t    session_manager: SessionManager<S>,\n   130\t    resolver: BackendResolver,\n   131\t}\n   132\t\n   133\timpl<A, R, S> AgentExecutionService<A, R, S> {\n   134\t    pub fn new(adapter: A, raw_output_store: R, session_store: S) -> Self {\n   135\t        Self {\n   136\t            adapter,\n   137\t            raw_output_store,\n   138\t            session_manager: SessionManager::new(session_store),\n   139\t            resolver: BackendResolver::new(),\n   140\t        }\n   141\t    }\n   142\t\n   143\t    pub fn resolver(&self) -> &BackendResolver {\n   144\t        &self.resolver\n   145\t    }\n   146\t\n   147\t    pub fn adapter(&self) -> &A {\n   148\t        &self.adapter\n   149\t    }\n   150\t}\n   151\t\n   152\timpl<A, R, S> AgentExecutionService<A, R, S>\n   153\twhere\n   154\t    A: AgentExecutionPort,\n   155\t    R: RawOutputPort,\n   156\t    S: SessionStorePort,\n   157\t{\n   158\t    pub async fn invoke(&self, request: InvocationRequest) -> AppResult<InvocationEnvelope> {\n   159\t        let _ = CapabilityCheck::success(&request.resolved_target, &request.contract);\n   160\t\n   161\t        self.adapter\n   162\t            .check_capability(&request.resolved_target, &request.contract)\n   163\t            .await\n   164\t            .map_err(|error| map_capability_error(error, &request))?;\n   165\t\n   166\t        self.adapter\n   167\t            .check_availability(&request.resolved_target)\n   168\t            .await\n   169\t            .map_err(|error| map_availability_error(error, &request))?;\n   170\t\n   171\t        let prior_session = self.session_manager.load_reusable_session(\n   172\t            &request.project_root,\n   173\t            request.role,\n   174\t            &request.resolved_target,\n   175\t            request.session_policy,\n   176\t        )?;\n   177\t\n   178\t        let mut request = request;\n   179\t        request.prior_session = prior_session;\n   180\t\n   181\t        if request.cancellation_token.is_cancelled() {\n   182\t            return Err(AppError::InvocationCancelled {\n   183\t                backend: request.resolved_target.backend.family.to_string(),\n   184\t                contract_id: request.contract.label(),\n   185\t            });\n   186\t        }\n   187\t\n   188\t        let started_at = Utc::now();\n   189\t        let started = Instant::now();\n   190\t        let invocation_id = request.invocation_id.clone();\n   191\t        let timeout_ms = request.timeout.as_millis().min(u64::MAX as u128) as u64;\n   192\t\n   193\t        let invoke_future = self.adapter.invoke(request.clone());\n   194\t        tokio::pin!(invoke_future);\n   195\t\n   196\t        let mut envelope = tokio::select! {\n   197\t            _ = request.cancellation_token.cancelled() => {\n   198\t                let _ = self.adapter.cancel(&invocation_id).await;\n   199\t                return Err(AppError::InvocationCancelled {\n   200\t                    backend: request.resolved_target.backend.family.to_string(),\n   201\t                    contract_id: request.contract.label(),\n   202\t                });\n   203\t            }\n   204\t            result = tokio::time::timeout(request.timeout, &mut invoke_future) => {\n   205\t                match result {\n   206\t                    Ok(result) => result.map_err(|error| map_invoke_error(error, &request))?,\n   207\t                    Err(_) => {\n   208\t                        let _ = self.adapter.cancel(&invocation_id).await;\n   209\t                        return Err(AppError::InvocationTimeout {\n   210\t                            backend: request.resolved_target.backend.family.to_string(),\n   211\t                            contract_id: request.contract.label(),\n   212\t                            timeout_ms,\n   213\t                        });\n   214\t                    }\n   215\t                }\n   216\t            }\n   217\t        };\n   218\t\n   219\t        let duration = started.elapsed();\n   220\t        envelope.metadata.duration = duration;\n   221\t        envelope.metadata.attempt_number = request.attempt_number;\n   222\t        envelope.metadata.backend_used = request.resolved_target.backend.clone();\n   223\t        envelope.metadata.model_used = request.resolved_target.model.clone();\n   224\t        envelope.timestamp = Utc::now();\n   225\t\n   226\t        let raw_output = extract_raw_output(&envelope.raw_output_reference)?;\n   227\t        let stored_reference = self.raw_output_store.persist_raw_output(\n   228\t            &request.project_root,\n   229\t            &request.invocation_id,\n   230\t            &raw_output,\n   231\t        )?;\n   232\t\n   233\t        let parsed_payload =\n   234\t            extract_structured_payload(&request, envelope.parsed_payload, &raw_output)?;\n   235\t\n   236\t        // Only validate stage contracts within agent execution;\n   237\t        // requirements contracts are validated by the caller.\n   238\t        if let Some(stage_contract) = request.contract.stage_contract() {\n   239\t            stage_contract\n   240\t                .evaluate_permissive(&parsed_payload)\n   241\t                .map_err(|error| map_contract_error(error, &request))?;\n   242\t        }\n   243\t\n   244\t        envelope.raw_output_reference = stored_reference;\n   245\t        envelope.parsed_payload = parsed_payload;\n   246\t        envelope.timestamp = started_at + duration;\n   247\t\n   248\t        self.session_manager.record_session(\n   249\t            &request.project_root,\n   250\t            request.role,\n   251\t            &request.resolved_target,\n   252\t            envelope.metadata.session_id.as_deref(),\n   253\t            envelope.timestamp,\n   254\t        )?;\n   255\t\n   256\t        Ok(envelope)\n   257\t    }\n   258\t}\n   259\t\n   260\tfn parse_backend_family(key: &str, value: &str) -> AppResult<BackendFamily> {\n   261\t    match value {\n   262\t        \"claude\" => Ok(BackendFamily::Claude),\n   263\t        \"codex\" => Ok(BackendFamily::Codex),\n   264\t        \"openrouter\" => Ok(BackendFamily::OpenRouter),\n   265\t        \"stub\" => Ok(BackendFamily::Stub),\n   266\t        _ => Err(AppError::InvalidConfigValue {\n   267\t            key: key.to_owned(),\n   268\t            value: value.to_owned(),\n   269\t            reason: \"expected one of claude, codex, openrouter, stub\".to_owned(),\n   270\t        }),\n   271\t    }\n   272\t}\n   273\t\n   274\tfn extract_raw_output(raw_output_reference: &RawOutputReference) -> AppResult<String> {\n   275\t    match raw_output_reference {\n   276\t        RawOutputReference::Inline(contents) => Ok(contents.clone()),\n   277\t        RawOutputReference::Stored(path) => std::fs::read_to_string(path).map_err(AppError::from),\n   278\t    }\n   279\t}\n   280\t\n   281\tfn extract_structured_payload(\n   282\t    request: &InvocationRequest,\n   283\t    parsed_payload: Value,\n   284\t    raw_output: &str,\n   285\t) -> AppResult<Value> {\n   286\t    if !parsed_payload.is_null() {\n   287\t        return Ok(parsed_payload);\n   288\t    }\n   289\t\n   290\t    serde_json::from_str(raw_output).map_err(|error| AppError::InvocationFailed {\n   291\t        backend: request.resolved_target.backend.family.to_string(),\n   292\t        contract_id: request.contract.label(),\n   293\t        failure_class: FailureClass::SchemaValidationFailure,\n   294\t        details: error.to_string(),\n   295\t    })\n   296\t}\n   297\t\n   298\tfn map_capability_error(error: AppError, request: &InvocationRequest) -> AppError {\n   299\t    match error {\n   300\t        AppError::CapabilityMismatch { .. } => error,\n   301\t        other => AppError::CapabilityMismatch {\n   302\t            backend: request.resolved_target.backend.family.to_string(),\n   303\t            contract_id: request.contract.label(),\n   304\t            details: other.to_string(),\n   305\t        },\n   306\t    }\n   307\t}\n   308\t\n   309\tfn map_availability_error(error: AppError, request: &InvocationRequest) -> AppError {\n   310\t    match error {\n   311\t        AppError::BackendUnavailable { .. } => error,\n   312\t        other => AppError::BackendUnavailable {\n   313\t            backend: request.resolved_target.backend.family.to_string(),\n   314\t            details: other.to_string(),\n   315\t        },\n   316\t    }\n   317\t}\n   318\t\n   319\tfn map_invoke_error(error: AppError, request: &InvocationRequest) -> AppError {\n   320\t    match error {\n   321\t        AppError::InvocationFailed { .. }\n   322\t        | AppError::InvocationTimeout { .. }\n   323\t        | AppError::InvocationCancelled { .. } => error,\n   324\t        other => AppError::InvocationFailed {\n   325\t            backend: request.resolved_target.backend.family.to_string(),\n   326\t            contract_id: request.contract.label(),\n   327\t            failure_class: FailureClass::TransportFailure,\n   328\t            details: other.to_string(),\n   329\t        },\n   330\t    }\n   331\t}\n   332\t\n   333\tfn map_contract_error(error: ContractError, request: &InvocationRequest) -> AppError {\n   334\t    AppError::InvocationFailed {\n   335\t        backend: request.resolved_target.backend.family.to_string(),\n   336\t        contract_id: request.contract.label(),\n   337\t        failure_class: error.failure_class(),\n   338\t        details: error.to_string(),\n   339\t    }\n   340\t}\n","exit_code":0,"status":"completed"}}
