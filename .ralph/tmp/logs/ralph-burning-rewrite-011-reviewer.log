"])?;\n    48\t        if current.status.success() {\n    49\t            let branch = String::from_utf8_lossy(&current.stdout).trim().to_owned();\n    50\t            if !branch.is_empty() {\n    51\t                return Ok(branch);\n    52\t            }\n    53\t        }\n    54\t\n    55\t        Ok(\"HEAD\".to_owned())\n    56\t    }\n    57\t}\n    58\t\n    59\timpl WorktreePort for WorktreeAdapter {\n    60\t    fn worktree_path(&self, base_dir: &Path, task_id: &str) -> PathBuf {\n    61\t        base_dir\n    62\t            .join(\".ralph-burning\")\n    63\t            .join(\"worktrees\")\n    64\t            .join(task_id)\n    65\t    }\n    66\t\n    67\t    fn branch_name(&self, task_id: &str) -> String {\n    68\t        format!(\"rb/task/{task_id}\")\n    69\t    }\n    70\t\n    71\t    fn create_worktree(\n    72\t        &self,\n    73\t        repo_root: &Path,\n    74\t        worktree_path: &Path,\n    75\t        branch_name: &str,\n    76\t        task_id: &str,\n    77\t    ) -> AppResult<()> {\n    78\t        if let Some(parent) = worktree_path.parent() {\n    79\t            fs::create_dir_all(parent)?;\n    80\t        }\n    81\t\n    82\t        if worktree_path.exists() {\n    83\t            return Err(AppError::WorktreeCreationFailed {\n    84\t                task_id: task_id.to_owned(),\n    85\t                details: format!(\"worktree path '{}' already exists\", worktree_path.display()),\n    86\t            });\n    87\t        }\n    88\t\n    89\t        let base_ref = self.default_branch_ref(repo_root)?;\n    90\t        let output = Self::git(\n    91\t            repo_root,\n    92\t            &[\n    93\t                \"worktree\",\n    94\t                \"add\",\n    95\t                \"-B\",\n    96\t                branch_name,\n    97\t                &worktree_path.to_string_lossy(),\n    98\t                &base_ref,\n    99\t            ],\n   100\t        )?;\n   101\t\n   102\t        if output.status.success() {\n   103\t            return Ok(());\n   104\t        }\n   105\t\n   106\t        Err(AppError::WorktreeCreationFailed {\n   107\t            task_id: task_id.to_owned(),\n   108\t            details: String::from_utf8_lossy(&output.stderr).trim().to_owned(),\n   109\t        })\n   110\t    }\n   111\t\n   112\t    fn remove_worktree(\n   113\t        &self,\n   114\t        repo_root: &Path,\n   115\t        worktree_path: &Path,\n   116\t        task_id: &str,\n   117\t    ) -> AppResult<()> {\n   118\t        if !worktree_path.exists() {\n   119\t            return Ok(());\n   120\t        }\n   121\t\n   122\t        let output = Self::git(\n   123\t            repo_root,\n   124\t            &[\n   125\t                \"worktree\",\n   126\t                \"remove\",\n   127\t                \"--force\",\n   128\t                &worktree_path.to_string_lossy(),\n   129\t            ],\n   130\t        )?;\n   131\t        if !output.status.success() {\n   132\t            return Err(AppError::WorktreeRemovalFailed {\n   133\t                task_id: task_id.to_owned(),\n   134\t                details: String::from_utf8_lossy(&output.stderr).trim().to_owned(),\n   135\t            });\n   136\t        }\n   137\t\n   138\t        if worktree_path.exists() {\n   139\t            fs::remove_dir_all(worktree_path).map_err(|error| AppError::WorktreeRemovalFailed {\n   140\t                task_id: task_id.to_owned(),\n   141\t                details: error.to_string(),\n   142\t            })?;\n   143\t        }\n   144\t\n   145\t        Ok(())\n   146\t    }\n   147\t\n   148\t    fn rebase_onto_default_branch(\n   149\t        &self,\n   150\t        repo_root: &Path,\n   151\t        worktree_path: &Path,\n   152\t        branch_name: &str,\n   153\t    ) -> AppResult<()> {\n   154\t        let upstream = self.default_branch_ref(repo_root)?;\n   155\t        let output = Self::git_in(worktree_path, &[\"rebase\", &upstream])?;\n   156\t     