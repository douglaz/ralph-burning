e_writer_lock(base_dir, project_id, &lease_id)?;\n    46\t\n    47\t        let worktree_path = worktree.worktree_path(base_dir, task_id);\n    48\t        let branch_name = worktree.branch_name(task_id);\n    49\t        if let Err(error) =\n    50\t            worktree.create_worktree(repo_root, &worktree_path, &branch_name, task_id)\n    51\t        {\n    52\t            let _ = store.release_writer_lock(base_dir, project_id);\n    53\t            return Err(error);\n    54\t        }\n    55\t\n    56\t        let now = Utc::now();\n    57\t        let lease = WorktreeLease {\n    58\t            lease_id,\n    59\t            task_id: task_id.to_owned(),\n    60\t            project_id: project_id.to_string(),\n    61\t            worktree_path,\n    62\t            branch_name,\n    63\t            acquired_at: now,\n    64\t            ttl_seconds,\n    65\t            last_heartbeat: now,\n    66\t        };\n    67\t        if let Err(error) = store.write_lease(base_dir, &lease) {\n    68\t            let _ = worktree.remove_worktree(repo_root, &lease.worktree_path, task_id);\n    69\t            let _ = store.release_writer_lock(base_dir, project_id);\n    70\t            return Err(error);\n    71\t        }\n    72\t\n    73\t        Ok(lease)\n    74\t    }\n    75\t\n    76\t    pub fn heartbeat(\n    77\t        store: &dyn DaemonStorePort,\n    78\t        base_dir: &Path,\n    79\t        lease_id: &str,\n    80\t    ) -> AppResult<WorktreeLease> {\n    81\t        let mut lease = store.read_lease(base_dir, lease_id)?;\n    82\t        let now = Utc::now();\n    83\t        if lease.is_stale_at(now) {\n    84\t            return Err(AppError::LeaseStale {\n    85\t                lease_id: lease_id.to_owned(),\n    86\t            });\n    87\t        }\n    88\t        lease.last_heartbeat = now;\n    89\t        store.write_lease(base_dir, &lease)?;\n    90\t        Ok(lease)\n    91\t    }\n    92\t\n    93\t    pub fn release(\n    94\t        store: &dyn DaemonStorePort,\n    95\t        worktree: &dyn WorktreePort,\n    96\t        base_dir: &Path,\n    97\t        repo_root: &Path,\n    98\t        lease: &WorktreeLease,\n    99\t    ) -> AppResult<()> {\n   100\t        let project_id = ProjectId::new(lease.project_id.clone())?;\n   101\t        let remove_error = worktree\n   102\t            .remove_worktree(repo_root, &lease.worktree_path, &lease.task_id)\n   103\t            .err();\n   104\t        store.remove_lease(base_dir, &lease.lease_id)?;\n   105\t        store.release_writer_lock(base_dir, &project_id)?;\n   106\t        DaemonTaskService::append_journal_event(\n   107\t            store,\n   108\t            base_dir,\n   109\t            crate::contexts::automation_runtime::model::DaemonJournalEventType::LeaseReleased,\n   110\t            json!({\n   111\t                \"task_id\": lease.task_id,\n   112\t                \"lease_id\": lease.lease_id,\n   113\t                \"project_id\": lease.project_id,\n   114\t            }),\n   115\t        )?;\n   116\t\n   117\t        if let Some(error) = remove_error {\n   118\t            return Err(error);\n   119\t        }\n   120\t\n   121\t        Ok(())\n   122\t    }\n   123\t\n   124\t    pub fn find_lease_for_task(\n   125\t        store: &dyn DaemonStorePort,\n   126\t        base_dir: &Path,\n   127\t        task_id: &str,\n   128\t    ) -> AppResult<Option<WorktreeLease>> {\n   129\t        Ok(store\n   130\t            .list_leases(base_dir)?\n   131\t            .into_iter()\n   132\t            .find(|lease| lease.task_id == task_id))\n   133\t    }\n   134\t\n   135\t    pub fn reconcile(\n   136\t        store: &dyn DaemonStorePort,\n   137\t        worktree: &dyn WorktreePort,\n   138\t        base_dir: &Path,\n   139\t        repo_root: &Path,\n   140\t        ttl_override_seconds: Option<u64>,\n   141\t        now: DateTime<Utc>,\n   142\t    ) -> AppResult<ReconcileReport> {\n   143\t        let mut report = ReconcileReport::default();\n   144\t        let leases = store.list_leases(base_dir)?;\n   145\t\n   146\t        for lease in leases {\n   147\t            let is_stale = ttl_override_seconds\n   148\t                .map(|ttl| now > lease.last_heartbeat + chrono::Duration::seconds(ttl as i64))\n   149\t                .unwrap_or_else(|| lease.is_stale_at(now));\n   150\t            if !is_stale {\n   151\t                continue;\n   152\t            }\n   153\t\n   154\t            report.stale_lease_ids.push(lease.lease_id.clone());\n   155\t            let task = store.read_task(base_dir, &lease.task_id)?;\n   156\t            if matches!(task.status, TaskStatus::Claimed | TaskStatus::Active) {\n   157\t                DaemonTaskService::mark_failed(\n   158\t                    store,\n   159\t                    base_dir,\n   160\t                    &task.task_id,\n   161\t                    \"reconciliation_timeout\",\n   162\t                    \"stale lease heartbeat exceeded ttl\",\n   163\t                )?;\n   164\t                report.failed_task_ids.push(task.task_id.clone());\n   165\t            }\n   166\t\n   167\t            let _ = Self::release(store, worktree, base_dir, repo_root, &lease);\n   168\t            let _ = DaemonTaskService::clear_lease_reference(store, base_dir, &task.task_id);\n   169\t            report.released_lease_ids.push(lease.lease_id.clone());\n   170\t            report\n   171\t                .removed_worktrees\n   172\t                .push(lease.worktree_path.display().to_string());\n   173\t        }\n   174\t\n   175\t        DaemonTaskService::append_journal_event(\n   176\t            store,\n   177\t            base_dir,\n   178\t            crate::contexts::automation_runtime::model::DaemonJournalEventType::ReconciliationRun,\n   179\t            json!({\n   180\t                \"stale_lease_ids\": report.stale_lease_ids,\n   181\t                \"failed_task_ids\": report.failed_task_ids,\n   182\t       