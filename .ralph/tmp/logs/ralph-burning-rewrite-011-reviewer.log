ange'\n--- task json ---\n{\n  \"task_id\": \"task-mismatch\",\n  \"issue_ref\": \"repo#999\",\n  \"project_id\": \"demo\",\n  \"project_name\": \"Demo\",\n  \"prompt\": \"Prompt\",\n  \"routing_command\": \"/rb flow docs_change\",\n  \"resolved_flow\": \"docs_change\",\n  \"routing_source\": \"command\",\n  \"status\": \"claimed\",\n  \"created_at\": \"2026-03-12T00:00:00Z\",\n  \"updated_at\": \"2026-03-12T23:02:23.028454038Z\",\n  \"attempt_count\": 0,\n  \"lease_id\": \"lease-task-mismatch\"\n}--- leases ---\n.ralph-burning/daemon/leases/lease-task-mismatch.json\n.ralph-burning/daemon/leases/writer-demo.lock\n","exit_code":0,"status":"completed"}}
