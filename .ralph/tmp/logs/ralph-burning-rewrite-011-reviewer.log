lt, skip_serializing_if = \"Option::is_none\")]\n    38\t    pub failure_message: Option<String>,\n    39\t}\n    40\t\n    41\timpl DaemonTask {\n    42\t    pub fn is_terminal(&self) -> bool {\n    43\t        self.status.is_terminal()\n    44\t    }\n    45\t\n    46\t    pub fn transition_to(&mut self, next: TaskStatus, now: DateTime<Utc>) -> AppResult<()> {\n    47\t        if !self.status.can_transition_to(next) {\n    48\t            return Err(AppError::TaskStateTransitionInvalid {\n    49\t                task_id: self.task_id.clone(),\n    50\t                from: self.status.as_str().to_owned(),\n    51\t                to: next.as_str().to_owned(),\n    52\t            });\n    53\t        }\n    54\t\n    55\t        self.status = next;\n    56\t        self.updated_at = now;\n    57\t        Ok(())\n    58\t    }\n    59\t\n    60\t    pub fn attach_lease(&mut self, lease_id: impl Into<String>) {\n    61\t        self.lease_id = Some(lease_id.into());\n    62\t    }\n    63\t\n    64\t    pub fn clear_lease(&mut self) {\n    65\t        self.lease_id = None;\n    66\t    }\n    67\t\n    68\t    pub fn clear_failure(&mut self) {\n    69\t        self.failure_class = None;\n    70\t        self.failure_message = None;\n    71\t    }\n    72\t\n    73\t    pub fn set_failure(\n    74\t        &mut self,\n    75\t        failure_class: impl Into<String>,\n    76\t        failure_message: impl Into<String>,\n    77\t    ) {\n    78\t        self.failure_class = Some(failure_class.into());\n    79\t        self.failure_message = Some(failure_message.into());\n    80\t    }\n    81\t}\n    82\t\n    83\t#[derive(Debug, Clone, Copy, PartialEq, Eq, Serialize, Deserialize)]\n    84\t#[serde(rename_all = \"snake_case\")]\n    85\tpub enum TaskStatus {\n    86\t    Pending,\n    87\t    Claimed,\n    88\t    Active,\n    89\t    Completed,\n    90\t    Failed,\n    91\t    Aborted,\n    92\t}\n    93\t\n    94\timpl TaskStatus {\n    95\t    pub fn as_str(self) -> &'static str {\n    96\t        match self {\n    97\t            Self::Pending => \"pending\",\n    98\t            Self::Claimed => \"claimed\",\n    99\t            Self::Active => \"active\",\n   100\t            Self::Completed => \"completed\",\n   101\t            Self::Failed => \"failed\",\n   102\t            Self::Aborted => \"aborted\",\n   103\t        }\n   104\t    }\n   105\t\n   106\t    pub fn is_terminal(self) -> bool {\n   107\t        matches!(self, Self::Completed | Self::Failed | Self::Aborted)\n   108\t    }\n   109\t\n   110\t    pub fn can_transition_to(self, next: Self) -> bool {\n   111\t        match (self, next) {\n   112\t            (Self::Pending, Self::Claimed | Self::Failed) => true,\n   113\t            (Self::Claimed, Self::Active | Self::Failed | Self::Aborted) => true,\n   114\t            (Self::Active, Self::Completed | Self::Failed | Self::Aborted) => true,\n   115\t            (Self::Failed, Self::Pending) => true,\n   116\t            _ if self == next => true,\n   117\t            _ => false,\n   118\t        }\n   119\t    }\n   120\t}\n   121\t\n   122\timpl std::fmt::Display for TaskStatus {\n   123\t    fn fmt(&self, f: &mut std::fmt::Formatter<'_>) -> std::fmt::Result {\n   124\t        f.write_str(self.as_str())\n   125\t    }\n   126\t}\n   127\t\n   128\t#[derive(Debug, Clone, PartialEq, Eq, Serialize, Deserialize)]\n   129\tpub struct WorktreeLease {\n   130\t    pub lease_id: String,\n   131\t    pub task_id: String,\n   132\t    pub project_id: String,\n   133\t    pub worktree_path: PathBuf,\n   134\t    pub branch_name: String,\n   135\t    pub acquired_at: DateTime<Utc>,\n   136\t    pub ttl_seconds: u64,\n   137\t    pub last_heartbeat: DateTime<Utc>,\n   138\t}\n   139\t\n   140\timpl WorktreeLease {\n   141\t    pub fn heartbeat_deadline(&self) -> DateTime<Utc> {\n   142\t        self.last_heartbeat + Duration::seconds(self.ttl_seconds.min(i64::MAX as u64) as i64)\n   143\t    }\n   144\t\n   145\t    pub fn is_stale_at(&self, now: DateTime<Utc>) -> bool {\n   146\t        now > self.heartbeat_deadline()\n   147\t    }\n   148\t}\n   149\t\n   150\t#[derive(Debug, Clone, Copy, PartialEq, Eq, Serialize, Deserialize)]\n   151\t#[serde(rename_all = \"snake_case\")]\n   152\tpub enum RoutingSource {\n   153\t    Command,\n   154\t    Label,\n   155\t    DefaultFlow,\n   156\t}\n   157\t\n   158\t#[derive(Debug, Clone, PartialEq, Eq, Serialize, Deserialize)]\n   159\tpub struct RoutingResolution {\n   160\t    pub flow: FlowPreset,\n   161\t    pub source: RoutingSource,\n   162\t    #[serde(default, skip_serializing_if = \"Vec::is_empty\")]\n   163\t    pub warnings: Vec<String>,\n   164\t}\n   165\t\n   166\t#[derive(Debug, Clone, PartialEq, Serialize, Deserialize)]\n   167\tpub struct DaemonJournalEvent {\n   168\t    pub sequence: u64,\n   169\t    pub timestamp: DateTime<Utc>,\n   170\t    pub event_type: DaemonJournalEventType,\n   171\t    pub details: serde_json::Value,\n   172\t}\n   173\t\n   174\t#[derive(Debug, Clone, Copy, PartialEq, Eq, Serialize, Deserialize)]\n   175\t#[serde(rename_all = \"snake_case\")]\n   176\tpub enum DaemonJournalEventType {\n   177\t    TaskCreated,\n   178\t    TaskClaimed,\n   179\t    TaskCompleted,\n   180\t    TaskFailed,\n   181\t    TaskAborted,\n   182\t    LeaseAcquired,\n   183\t    LeaseReleased,\n   184\t    ReconciliationRun,\n   185\t}\n","exit_code":0,"status":"completed"}}
