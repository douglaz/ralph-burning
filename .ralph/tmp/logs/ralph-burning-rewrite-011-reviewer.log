 fn writer_lock_path(base_dir: &Path, project_id: &ProjectId) -> PathBuf {\n   947\t        Self::leases_dir(base_dir).join(format!(\"writer-{}.lock\", project_id.as_str()))\n   948\t    }\n   949\t\n   950\t    fn daemon_journal_path(base_dir: &Path) -> PathBuf {\n   951\t        FileSystem::daemon_root(base_dir).join(DAEMON_JOURNAL_FILE)\n   952\t    }\n   953\t\n   954\t    fn read_json_file<T: serde::de::DeserializeOwned>(path: &Path, file: String) -> AppResult<T> {\n   955\t        let raw = fs::read_to_string(path).map_err(|error| {\n   956\t            if error.kind() == std::io::ErrorKind::NotFound {\n   957\t                AppError::CorruptRecord {\n   958\t                    file: file.clone(),\n   959\t                    details: \"canonical file is missing\".to_owned(),\n   960\t                }\n   961\t            } else {\n   962\t                error.into()\n   963\t            }\n   964\t        })?;\n   965\t        serde_json::from_str(&raw).map_err(|error| AppError::CorruptRecord {\n   966\t            file,\n   967\t            details: error.to_string(),\n   968\t        })\n   969\t    }\n   970\t}\n   971\t\n   972\timpl DaemonStorePort for FsDaemonStore {\n   973\t    fn list_tasks(&self, base_dir: &Path) -> AppResult<Vec<DaemonTask>> {\n   974\t        let dir = Self::tasks_dir(base_dir);\n   975\t        if !dir.is_dir() {\n   976\t            return Ok(Vec::new());\n   977\t        }\n   978\t\n   979\t        let mut tasks = Vec::new();\n   980\t        for entry in fs::read_dir(&dir)? {\n   981\t            let entry = entry?;\n   982\t            let path = entry.path();\n   983\t            if !path.extension().is_some_and(|ext| ext == \"json\") {\n   984\t                continue;\n   985\t            }\n   986\t            let file = format!(\n   987\t                \"daemon/tasks/{}\",\n   988\t                path.file_name().unwrap_or_default().to_string_lossy()\n   989\t            );\n   990\t            tasks.push(Self::read_json_file(&path, file)?);\n   991\t        }\n   992\t\n   993\t        tasks.sort_by(|a: &DaemonTask, b: &DaemonTask| {\n   994\t            a.status\n   995\t                .is_terminal()\n   996\t                .cmp(&b.status.is_terminal())\n   997\t                .then_with(|| a.created_at.cmp(&b.created_at))\n   998\t                .then_with(|| a.task_id.cmp(&b.task_id))\n   999\t        });\n  1000\t        Ok(tasks)\n  1001\t    }\n  1002\t\n  1003\t    fn read_task(&self, base_dir: &Path, task_id: &str) -> AppResult<DaemonTask> {\n  1004\t        Self::read_json_file(\n  1005\t            &Self::task_path(base_dir, task_id),\n  1006\t            format!(\"daemon/tasks/{task_id}.json\"),\n  1007\t        )\n  1008\t    }\n  1009\t\n  1010\t    fn create_task(&self, base_dir: &Path, task: &DaemonTask) -> AppResult<()> {\n  1011\t        let contents = serde_json::to_string_pretty(task)?;\n  1012\t        FileSystem::write_create_new(&Self::task_path(base_dir, &task.task_id), &contents)\n  1013\t    }\n  1014\t\n  1015\t    fn write_task(&self, base_dir: &Path, task: &DaemonTask) -> AppResult<()> {\n  1016\t        let contents = serde_json::to_string_pretty(task)?;\n  1017\t        FileSystem::write_atomic(&Self::task_path(base_dir, &task.task_id), &contents)\n  1018\t    }\n  1019\t\n  1020\t    fn list_leases(&self, base_dir: &Path) -> AppResult<Vec<WorktreeLease>> {\n  1021\t        let dir = Self::leases_dir(base_dir);\n  1022\t        if !dir.is_dir() {\n  1023\t            return Ok(Vec::new());\n  1024\t        }\n  1025\t\n  1026\t        let mut leases = Vec::new();\n  1027\t        for entry in fs::read_dir(&dir)? {\n  1028\t            let entry = entry?;\n  1029\t            let path = entry.path();\n  1030\t            if !path.extension().is_some_and(|ext| ext == \"json\") {\n  1031\t                continue;\n  1032\t            }\n  1033\t            let file = format!(\n  1034\t                \"daemon/leases/{}\",\n  1035\t                path.file_name().unwrap_or_default().to_string_lossy()\n  1036\t            );\n  1037\t            leases.push(Self::read_json_file(&path, file)?);\n  1038\t        }\n  1039\t        leases.sort_by_key(|lease: &WorktreeLease| lease.acquired_at);\n  1040\t        Ok(leases)\n  1041\t    }\n  1042\t\n  1043\t    fn read_lease(&self, base_dir: &Path, lease_id: &str) -> AppResult<WorktreeLease> {\n  1044\t        Self::read_json_file(\n  1045\t            &Self::lease_path(base_dir, lease_id),\n  1046\t            format!(\"daemon/leases/{lease_id}.json\"),\n  1047\t        )\n  1048\t    }\n  1049\t\n  1050\t    fn write_lease(&self, base_dir: &Path, lease: &WorktreeLease) -> AppResult<()> {\n  1051\t        let contents = serde_json::to_string_pretty(lease)?;\n  1052\t        FileSystem::write_atomic(&Self::lease_path(base_dir, &lease.lease_id), &contents)\n  1053\t    }\n  1054\t\n  1055\t    fn remove_lease(&self, base_dir: &Path, lease_id: &str) -> AppResult<()> {\n  1056\t        match fs::remove_file(Self::lease_path(base_dir, lease_id)) {\n  1057\t            Ok(()) => Ok(()),\n  1058\t            Err(error) if error.kind() == std::io::ErrorKind::NotFound => Ok(()),\n  1059\t            Err(error) => Err(error.into()),\n  1060\t        }\n  1061\t    }\n  1062\t\n  1063\t    fn read_daemon_journal(&self, base_dir: &Path) -> AppResult<Vec<DaemonJournalEvent>> {\n  1064\t        let path = Self::daemon_journal_path(base_dir);\n  1065\t        match fs::read_to_string(&path) {\n  1066\t            Ok(contents) => {\n  1067\t                let mut events = Vec::new();\n  1068\t                for line in contents.lines() {\n  1069\t                    let trimmed = line.trim();\n  1070\t                    if trimmed.is_empty() {\n  1071\t                        continue;\n  1072\t                    }\n  1073\t                    let event: DaemonJournalEvent =\n  1074\t                        serde_json::from_str(trimmed).map_err(|error| AppError::CorruptRecord {\n  1075\t                            file: \"daemon/journal.ndjson\".to_owned(),\n  1076\t                            details: error.to_string(),\n  1077\t                        })?;\n  1078\t                    events.push(event);\n  1079\t                }\n  1080\t                Ok(events)\n  1081\t            }\n  1082\t            Err(error) if error.kind() == std::io::ErrorKind::NotFound => Ok(Vec::new()),\n  1083\t            Err(error) => Err(error.into()),\n  1084\t        }\n  1085\t    }\n  1086\t\n  1087\t    fn append_daemon_journal_event(\n  1088\t        &self,\n  1089\t        base_dir: &Path,\n  1090\t        event: &DaemonJournalEvent,\n  1091\t    ) -> AppResult<()> {\n  1092\t        let line = serde_json::to_string(event)?;\n  1093\t        FileSystem::append_line(&Self::daemon_journal_path(base_dir), &line)\n  1094\t    }\n  1095\t\n  1096\t    fn acquire_writer_lock(\n  1097\t        &self,\n  1098\t        base_dir: &Path,\n  1099\t        project_id: &ProjectId,\n  1100\t        lease_id: &str,\n  1101\t    ) -> AppResult<()> {\n  1102\t        let path = Self::writer_lock_path(base_dir, project_id);\n  1103\t        match FileSystem::write_create_new(&path, lease_id) {\n  1104\t            Ok(()) => Ok(()),\n  1105\t            Err(AppError::Io(error)) if error.kind() == std::io::ErrorKind::AlreadyExists => {\n  1106\t                Err(AppError::ProjectWriterLockHeld {\n  1107\t                    project_id: project_id.to_string(),\n  1108\t                })\n  1109\t            }\n  1110\t            Err(error) => Err(error),\n  1111\t        }\n  1112\t    }\n  1113\t\n  1114\t    fn release_writer_lock(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<()> {\n  1115\t        match fs::remove_file(Self::writer_lock_path(base_dir, project_id)) {\n  1116\t            Ok(()) => Ok(()),\n  1117\t            Err(error) if error.kind() == std::io::ErrorKind::NotFound => Ok(()),\n  1118\t            Err(error) => Err(error.into()),\n  1119\t        }\n  1120\t    }\n  1121\t}\n  1122\t\n  1123\t// ── Requirements drafting filesystem store ──────────────────────────────────\n  1124\t\n  1125\tuse crate::contexts::requirements_drafting::model::{\n  1126\t    PersistedAnswers, RequirementsJournalEvent, RequirementsRun,\n  1127\t};\n  1128\tuse crate::contexts::requirements_drafting::service::RequirementsStorePort;\n  1129\t\n  1130\tconst REQUIREMENTS_DIR: &str = \"requirements\";\n  1131\t\n  1132\t/// Required subdirectories inside a requirements run.\n  1133\tconst REQUIREMENTS_RUN_SUBDIRS: &[&str] = &[\n  1134\t    \"history/payloads\",\n  1135\t    \"history/artifacts\",\n  1136\t    \"runtime/logs\",\n  1137\t    \"runtime/backend\",\n  1138\t    \"runtime/temp\",\n  1139\t    \"seed\",\n  1140\t];\n  1141\t\n  1142\t/// Filesystem-backed implementation of `RequirementsStorePort`.\n  1143\tpub struct FsRequirementsStore;\n  1144\t\n  1145\timpl RequirementsStorePort for FsRequirementsStore {\n  1146\t    fn create_run_dir(&self, base_dir: &Path, run_id: &str) -> AppResult<()> {\n  1147\t        let run_root = requirements_run_root(base_dir, run_id);\n  1148\t        fs::create_dir_all(&run_root)?;\n  1149\t        for subdir in REQUIREMENTS_RUN_SUBDIRS {\n  1150\t            fs::create_dir_all(run_root.join(subdir))?;\n  1151\t        }\n  1152\t        // Agent execution expects sessions.json in the project root (run root).\n  1153\t        let sessions_path = run_root.join(SESSIONS_FILE);\n  1154\t        if !sessions_path.exists() {\n  1155\t            let empty = serde_json::to_string_pretty(\n  1156\t                &crate::contexts::agent_execution::session::PersistedSessions::empty(),\n  1157\t            )?;\n  1158\t            FileSystem::write_atomic(&sessions_path, &empty)?;\n  1159\t        }\n  1160\t\n","exit_code":0,"status":"completed"}}
