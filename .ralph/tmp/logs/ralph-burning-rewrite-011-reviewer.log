f\", &input.issue_ref)?;\n    43\t\n    44\t        let existing_tasks = store.list_tasks(base_dir)?;\n    45\t        if existing_tasks\n    46\t            .iter()\n    47\t            .any(|task| task.issue_ref == issue_ref && !task.is_terminal())\n    48\t        {\n    49\t            return Err(AppError::DuplicateTaskForIssue { issue_ref });\n    50\t        }\n    51\t\n    52\t        let resolution = routing_engine.resolve_flow(\n    53\t            input.routing_command.as_deref(),\n    54\t            &input.routing_labels,\n    55\t            default_flow,\n    56\t        )?;\n    57\t\n    58\t        let now = Utc::now();\n    59\t        let task = DaemonTask {\n    60\t            task_id: input.task_id,\n    61\t            issue_ref: normalize_required(\"issue_ref\", &input.issue_ref)?,\n    62\t            project_id: project_id.to_string(),\n    63\t            project_name: input.project_name.filter(|value| !value.trim().is_empty()),\n    64\t            prompt: input.prompt.filter(|value| !value.trim().is_empty()),\n    65\t            routing_command: input\n    66\t                .routing_command\n    67\t                .filter(|value| !value.trim().is_empty()),\n    68\t            routing_labels: input.routing_labels,\n    69\t            resolved_flow: Some(resolution.flow),\n    70\t            routing_source: Some(resolution.source),\n    71\t            routing_warnings: resolution.warnings.clone(),\n    72\t            status: TaskStatus::Pending,\n    73\t            created_at: now,\n    74\t            updated_at: now,\n    75\t            attempt_count: 0,\n    76\t            lease_id: None,\n    77\t            failure_class: None,\n    78\t            failure_message: None,\n    79\t        };\n    80\t\n    81\t        store.create_task(base_dir, &task)?;\n    82\t        Self::append_journal_event(\n    83\t            store,\n    84\t            base_dir,\n    85\t            DaemonJournalEventType::TaskCreated,\n    86\t            json!({\n    87\t                \"task_id\": task.task_id,\n    88\t                \"issue_ref\": task.issue_ref,\n    89\t                \"project_id\": task.project_id,\n    90\t                \"flow\": resolution.flow,\n    91\t                \"routing_source\": resolution.source,\n    92\t                \"warnings\": resolution.warnings,\n    93\t            }),\n    94\t        )?;\n    95\t\n    96\t        Ok(task)\n    97\t    }\n    98\t\n    99\t    pub fn claim_task(\n   100\t        store: &dyn DaemonStorePort,\n   101\t        worktree: &dyn WorktreePort,\n   102\t        routing_engine: &RoutingEngine,\n   103\t        base_dir: &Path,\n   104\t        repo_root: &Path,\n   105\t        task_id: &str,\n   106\t        default_flow: FlowPreset,\n   107\t        lease_ttl_seconds: u64,\n   108\t    ) -> AppResult<(DaemonTask, WorktreeLease)> {\n   109\t        let mut task = store.read_task(base_dir, task_id)?;\n   110\t        if task.status != TaskStatus::Pending {\n   111\t            return Err(AppError::TaskStateTransitionInvalid {\n   112\t                task_id: task.task_id.clone(),\n   113\t                from: task.status.as_str().to_owned(),\n   114\t                to: TaskStatus::Claimed.as_str().to_owned(),\n   115\t            });\n   116\t        }\n   117\t\n   118\t        if task.lease_id.is_some()\n   119\t            || store\n   120\t                .list_leases(base_dir)?\n   121\t                .iter()\n   122\t                .any(|lease| lease.task_id == task.task_id)\n   123\t        {\n   124\t            return Err(AppError::TaskStateTransitionInvalid {\n   125\t                task_id: task.task_id.clone(),\n   126\t                from: task.status.as_str().to_owned(),\n   127\t                to: \"claimed_with_duplicate_lease\".to_owned(),\n   128\t            });\n   129\t        }\n   130\t\n   131\t        hydrate_routing(&mut task, routing_engine, default_flow)?;\n   132\t        let project_id = ProjectId::new(task.project_id.clone())?;\n   133\t        let lease = match LeaseService::acquire(\n   134\t            store,\n   135\t            worktree,\n   136\t            base_dir,\n   137\t            repo_root,\n   138\t            &task.task_id,\n   139\t            &project_id,\n   140\t            lease_ttl_seconds,\n   141\t        ) {\n   142\t            Ok(lease) => lease,\n   143\t            Err(AppError::ProjectWriterLockHeld { .. }) => {\n   144\t                return Err(AppError::ProjectWriterLockHeld {\n   145\t                    project_id: project_id.to_string(),\n   146\t                })\n   147\t            }\n   148\t            Err(error) => {\n   149\t                let _ = Self::mark_failed(\n   150\t                    store,\n   151\t                    base_dir,\n   152\t                    &task.task_id,\n   153\t                    \"worktree_creation_failed\",\n   154\t                    &error.to_string(),\n   155\t                );\n   156\t                return Err(error);\n   157\t            }\n   158\t        };\n   159\t\n   160\t        let now = Utc::now();\n   161\t        task.transition_to(TaskStatus::Claimed, now)?;\n   162\t        task.attach_lease(lease.lease_id.clone());\n   163\t        store.write_task(base_dir, &task).map_err(|error| {\n   164\t            let _ = LeaseService::release(store, worktree, base_dir, repo_root, &lease);\n   165\t            error\n   166\t        })?;\n   167\t\n   168\t        Self::append_journal_event(\n   169\t            store,\n   170\t            base_dir,\n   171\t            DaemonJournalEventType::LeaseAcquired,\n   172\t            json!({\n   173\t                \"task_id\": task.task_id,\n   174\t                \"lease_id\": lease.lease_id,\n   175\t                \"project_id\": project_id,\n   176\t                \"worktree_path\": lease.worktree_path,\n   177\t                \"branch_name\": lease.branch_name,\n   178\t                \"ttl_seconds\": lease.ttl_seconds,\n   179\t            }),\n   180\t        )?;\n   181\t        Self::append_journal_event(\n   182\t            store,\n   183\t            base_dir,\n   184\t            DaemonJournalEventType::TaskClaimed,\n   185\t            json!({\n   186\t                \"task_id\": task.task_id,\n   187\t                \"lease_id\": lease.lease_id,\n   188\t                \"project_id\": project_id,\n   189\t            }),\n   190\t        )?;\n   191\t\n   192\t        Ok((task, lease))\n   193\t    }\n   194\t\n   195\t    pub fn mark_active(\n   196\t        store: &dyn DaemonStorePort,\n   197\t        base_dir: &Path,\n   198\t        task_id: &str,\n   199\t    ) -> AppResult<DaemonTask> {\n   200\t        let mut task = store.read_task(base_dir, task_id)?;\n   201\t        task.transition_to(TaskStatus::Active, Utc::now())?;\n   202\t        store.write_task(base_dir, &task)?;\n   203\t        Ok(task)\n   204\t    }\n   205\t\n   206\t    pub fn mark_completed(\n   207\t        store: &dyn DaemonStorePort,\n   208\t        base_dir: &Path,\n   209\t        task_id: &str,\n   210\t    ) -> AppResult<DaemonTask> {\n   211\t        let mut task = store.read_task(base_dir, task_id)?;\n   212\t        task.transition_to(TaskStatus::Completed, Utc::now())?;\n   213\t        store.write_task(base_dir, &task)?;\n   214\t        Self::append_journal_event(\n   215\t            store,\n   216\t            base_dir,\n   217\t            DaemonJournalEventType::TaskCompleted,\n   218\t            json!({ \"task_id\": task.task_id }),\n   219\t        )?;\n   220\t        Ok(task)\n   221\t    }\n   222\t\n   223\t    pub fn mark_failed(\n   224\t        store: &dyn DaemonStorePort,\n   225\t        base_dir: &Path,\n   226\t        task_id: &str,\n   227\t        failure_class: &str,\n   228\t        failure_message: &str,\n   229\t    ) -> AppResult<DaemonTask> {\n   230\t        let mut task = store.read_task(base_dir, task_id)?;\n   231\t        task.transition_to(TaskStatus::Failed, Utc::now())?;\n   232\t        task.set_failure(failure_class, failure_message);\n   233\t        store.write_task(base_dir, &task)?;\n   234\t        Self::append_journal_event(\n   235\t            store,\n   236\t            base_dir,\n   237\t            DaemonJournalEventType::TaskFailed,\n   238\t            json!({\n   239\t                \"task_id\": task.task_id,\n   240\t                \"failure_class\": failure_class,\n   241\t                \"failure_message\": failure_message,\n   242\t            }),\n   243\t        )?;\n   244\t        Ok(task)\n   245\t    }\n   246\t\n   247\t    pub fn mark_aborted(\n   248\t        store: &dyn DaemonStorePort,\n   249\t        base_dir: &Path,\n   250\t        task_id: &str,\n   251\t    ) -> AppResult<DaemonTask> {\n   252\t        let mut task = store.read_task(base_dir, task_id)?;\n   253\t        if matches!(\n   254\t            task.status,\n   255\t            TaskStatus::Completed | TaskStatus::Failed | TaskStatus::Aborted\n   256\t        ) {\n   257\t            return Err(AppError::TaskStateTransitionInvalid {\n   258\t                task_id: task.task_id.clone(),\n   259\t                from: task.status.as_str().to_owned(),\n   260\t                to: TaskStatus::Aborted.as_str().to_owned(),\n   261\t            });\n   262\t        }\n   263\t        task.transition_to(TaskStatus::Aborted, Utc::now())?;\n   264\t        store.write_task(base_dir, &task)?;\n   265\t        Self::append_journal_event(\n   266\t            store,\n   267\t            base_dir,\n   268\t            DaemonJournalEventType::TaskAborted,\n   269\t            json!({ \"task_id\": task.task_id }),\n   270\t        )?;\n   271\t        Ok(task)\n   272\t    }\n   273\t\n   274\t    pub fn retry_task(\n   275\t        store: &dyn DaemonStorePort,\n   276\t        base_dir: &Path,\n   277\t        task_id: &str,\n   278\t    ) -> AppResult<DaemonTask> {\n   279\t        let mut task = store.read_task(base_dir, task_id)?;\n   280\t        if task.status != TaskStatus::Failed {\n   281\t            return Err(AppError::TaskStateTransitionInvalid {\n   282\t                task_id: task.task_id.clone(),\n   283\t                from: task.status.as_str().to_owned(),\n   284\t                to: TaskStatus::Pending.as_str().to_owned(),\n   285\t            });\n   286\t        }\n   287\t\n   288\t        task.transition_to(TaskStatus::Pending, Utc::now())?;\n   289\t        task.attempt_count += 1;\n   290\t        task.clear_failure();\n   291\t        task.clear_lease();\n   292\t        store.write_task(base_dir, &task)?;\n   293\t        Ok(task)\n   294\t    }\n   295\t\n   296\t    pub fn clear_lease_reference(\n   297\t        store: &dyn DaemonStorePort,\n   298\t        base_dir: &Path,\n   299\t        task_id: &str,\n   300\t    ) -> AppResult<DaemonTask> {\n   301\t        let mut task = store.read_task(base_dir, task_id)?;\n   302\t        task.clear_lease();\n   303\t        task.updated_at = Utc::now();\n   304\t        store.write_task(base_dir, &task)?;\n   305\t        Ok(task)\n   306\t    }\n   307\t\n   308\t    pub(crate) fn append_journal_event(\n   309\t        store: &dyn DaemonStorePort,\n   310\t        base_dir: &Path,\n   311\t        event_type: DaemonJournalEventType,\n   312\t        details: serde_json::Value,\n   313\t    ) -> AppResult<()> {\n   314\t        let events = store.read_daemon_journal(base_dir)?;\n   315\t        let sequence = events.last().map_or(1, |event| event.sequence + 1);\n   316\t        let event = DaemonJournalEvent {\n   317\t            sequence,\n   318\t            timestamp: Utc::now(),\n   319\t            event_type,\n   320\t            details,\n   321\t        };\n   322\t        store.append_daemon_journal_event(base_dir, &event)\n   323\t    }\n   324\t}\n   325\t\n   326\tfn hydrate_routing(\n   327\t    task: &mut DaemonTask,\n   328\t    routing_engine: &RoutingEngine,\n   329\t    default_flow: FlowPreset,\n   330\t) -> AppResult<()> {\n   331\t    if task.resolved_flow.is_some() {\n   332\t        return Ok(());\n   333\t    }\n   334\t\n   335\t    let resolution = routing_engine.resolve_flow(\n   336\t        task.routing_command.as_deref(),\n   337\t        &task.routing_labels,\n   338\t        default_flow,\n   339\t    )?;\n   340\t    task.resolved_flow = Some(resolution.flow);\n   341\t    task.routing_source = Some(resolution.source);\n   342\t    task.routing_warnings = resolution.warnings;\n   343\t    Ok(())\n   344\t}\n   345\t\n   346\tfn validate_identifier(value: &str) -> AppResult<()> {\n   347\t    let _ = ProjectId::new(value.to_owned())?;\n   348\t    Ok(())\n   349\t}\n   350\t\n   351\tfn normalize_required(field: &'static str, value: &str) -> AppResult<String> {\n   352\t    let trimmed = value.trim();\n   353\t    if trimmed.is_empty() {\n   354\t        return Err(AppError::InvalidConfigValue {\n   355\t            key: field.to_owned(),\n   356\t            value: value.to_owned(),\n   357\t            reason: \"value cannot be empty\".to_owned(),\n   358\t        });\n   359\t    }\n   360\t    Ok(trimmed.to_owned())\n","exit_code":0,"status":"completed"}}
