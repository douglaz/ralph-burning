 AgentExecutionService<A, R, S>,\n    77\t    ) -> Self {\n    78\t        Self {\n    79\t            store,\n    80\t            worktree,\n    81\t            project_store,\n    82\t            run_snapshot_read,\n    83\t            run_snapshot_write,\n    84\t            journal_store,\n    85\t            artifact_store,\n    86\t            artifact_write,\n    87\t            log_write,\n    88\t            amendment_queue,\n    89\t            agent_service,\n    90\t            routing_engine: RoutingEngine::new(),\n    91\t        }\n    92\t    }\n    93\t}\n    94\t\n    95\timpl<A, R, S> DaemonLoop<'_, A, R, S>\n    96\twhere\n    97\t    A: AgentExecutionPort,\n    98\t    R: RawOutputPort,\n    99\t    S: SessionStorePort,\n   100\t{\n   101\t    pub async fn run(&self, base_dir: &Path, config: &DaemonLoopConfig) -> AppResult<()> {\n   102\t        let shutdown = CancellationToken::new();\n   103\t        let shutdown_watcher = shutdown.clone();\n   104\t        tokio::spawn(async move {\n   105\t            let _ = wait_for_shutdown_signal().await;\n   106\t            shutdown_watcher.cancel();\n   107\t        });\n   108\t\n   109\t        loop {\n   110\t            if shutdown.is_cancelled() {\n   111\t                self.cleanup_active_leases(base_dir)?;\n   112\t                break;\n   113\t            }\n   114\t\n   115\t            let processed = self\n   116\t                .process_cycle(base_dir, config, shutdown.clone())\n   117\t                .await?;\n   118\t            if config.single_iteration {\n   119\t                break;\n   120\t            }\n   121\t\n   122\t            let _ = processed;\n   123\t            tokio::select! {\n   124\t                _ = shutdown.cancelled() => {\n   125\t                    self.cleanup_active_leases(base_dir)?;\n   126\t                    break;\n   127\t                }\n   128\t                _ = tokio::time::sleep(config.poll_interval) => {}\n   129\t            }\n   130\t        }\n   131\t\n   132\t        Ok(())\n   133\t    }\n   134\t\n   135\t    async fn process_cycle(\n   136\t        &self,\n   137\t        base_dir: &Path,\n   138\t        config: &DaemonLoopConfig,\n   139\t        shutdown: CancellationToken,\n   140\t    ) -> AppResult<bool> {\n   141\t        let pending_task = DaemonTaskService::list_tasks(self.store, base_dir)?\n   142\t            .into_iter()\n   143\t            .find(|task| task.status == TaskStatus::Pending);\n   144\t        let Some(task) = pending_task else {\n   145\t            return Ok(false);\n   146\t        };\n   147\t\n   148\t        self.process_task(base_dir, &task, config, shutdown).await?;\n   149\t        Ok(true)\n   150\t    }\n   151\t\n   152\t    async fn process_task(\n   153\t        &self,\n   154\t        base_dir: &Path,\n   155\t        task: &DaemonTask,\n   156\t        config: &DaemonLoopConfig,\n   157\t        shutdown: CancellationToken,\n   158\t    ) -> AppResult<()> {\n   159\t        let effective_config = EffectiveConfig::load(base_dir)?;\n   160\t        let default_flow = effective_config.default_flow();\n   161\t        let repo_root = base_dir;\n   162\t\n   163\t        let (claimed_task, lease) = match DaemonTaskService::claim_task(\n   164\t            self.store,\n   165\t            self.worktree,\n   166\t            &self.routing_engine,\n   167\t            base_dir,\n   168\t            repo_root,\n   169\t            &task.task_id,\n   170\t            default_flow,\n   171\t            config.lease_ttl.as_secs(),\n   172\t        ) {\n   173\t            Ok(value) => value,\n   174\t            Err(AppError::ProjectWriterLockHeld { .. }) => return Ok(()),\n   175\t            Err(error) => return Err(error),\n   176\t        };\n   177\t\n   178\t        println!(\"claimed task {}\", claimed_task.task_id);\n   179\t\n   180\t        if let Err(error) = self.worktree.rebase_onto_default_branch(\n   181\t            repo_root,\n   182\t            &lease.worktree_path,\n   183\t            &lease.branch_name,\n   184\t        ) {\n   185\t            let _ = self.fail_claimed_task(\n   186\t                base_dir,\n   187\t                repo_root,\n   188\t                &claimed_task.task_id,\n   189\t                &lease,\n   190\t                \"rebase_conflict\",\n   191\t                &error.to_string(),\n   192\t            );\n   193\t            println!(\"failed task {}: {}\", claimed_task.task_id, error);\n   194\t            return Ok(());\n   195\t        }\n   196\t\n   197\t        if let Err(error) = self.ensure_project(base_dir, &claimed_task) {\n   198\t            self.handle_post_claim_failure(base_dir, repo_root, &claimed_task, &lease, &error)?;\n   199\t            println!(\"failed task {}: {}\", claimed_task.task_id, error);\n   200\t            return Ok(());\n   201\t        }\n   202\t        let task_on_disk = self.store.read_task(base_dir, &claimed_task.task_id)?;\n   203\t        if task_on_disk.status == TaskStatus::Aborted {\n   204\t            let _ = self.release_task_lease(base_dir, repo_root, &task_on_disk.task_id, &lease);\n   205\t            return Ok(());\n   206\t        }\n   207\t\n   208\t        let active_task =\n   209\t            match DaemonTaskService::mark_active(self.store, base_dir, &claimed_task.task_id) {\n   210\t                Ok(task) => task,\n   211\t                Err(error) => {\n   212\t                    self.handle_post_claim_failure(\n   213\t                        base_dir,\n   214\t                        repo_root,\n   215\t                        &claimed_task,\n   216\t                        &lease,\n   217\t                        &error,\n   218\t                    )?;\n   219\t                    println!(\"failed task {}: {}\", claimed_task.task_id, error);\n   220\t                    return Ok(());\n   221\t                }\n   222\t            };\n   223\t        println!(\"active task {}\", active_task.task_id);\n   224\t\n   225\t        let task_cancel = CancellationToken::new();\n   226\t        let outcome = self\n   227\t            .drive_dispatch(\n   228\t                base_dir,\n   229\t                &active_task,\n   230\t                &lease,\n   231\t                &effective_config,\n   232\t                config,\n   233\t                shutdown,\n   234\t                task_cancel,\n   235\t            )\n   236\t            .await;\n   237\t\n   238\t        let latest_task = self.store.read_task(base_dir, &active_task.task_id)?;\n   239\t        if latest_task.status == TaskStatus::Aborted {\n   240\t            let _ = self.release_task_lease(base_dir, repo_root, &active_task.task_id, &lease);\n   241\t            return Ok(());\n   242\t        }\n   243\t\n   244\t        match outcome {\n   245\t            Ok(()) => {\n   246\t                let _ =\n   247\t                    DaemonTaskService::mark_completed(self.store, base_dir, &active_task.task_id)?;\n   248\t                let _ = self.release_task_lease(base_dir, repo_root, &active_task.task_id, &lease);\n   249\t                println!(\"completed task {}\", active_task.task_id);\n   250\t            }\n   251\t            Err(error) => {\n   252\t                let failure_class = error\n   253\t                    .failure_class()\n   254\t                    .map(|class| class.as_str().to_owned())\n   255\t                    .unwrap_or_else(|| \"daemon_dispatch_failed\".to_owned());\n   256\t                let _ = DaemonTaskService::mark_failed(\n   257\t                    self.store,\n   258\t                    base_dir,\n   259\t                    &active_task.task_id,\n   260\t                    &failure_class,\n   261\t                    &error.to_string(),\n   262\t                )?;\n   263\t                let _ = self.release_task_lease(base_dir, repo_root, &active_task.task_id, &lease);\n   264\t                println!(\"failed task {}: {}\", active_task.task_id, error);\n   265\t            }\n   266\t        }\n   267\t\n   268\t        Ok(())\n   269\t    }\n   270\t\n   271\t    async fn drive_dispatch(\n   272\t        &self,\n   273\t        base_dir: &Path,\n   274\t        task: &DaemonTask,\n   275\t        lease: &crate::contexts::automation_runtime::model::WorktreeLease,\n   276\t        effective_config: &EffectiveConfig,\n   277\t        config: &DaemonLoopConfig,\n   278\t        shutdown: CancellationToken,\n   279\t        task_cancel: CancellationToken,\n   280\t    ) -> AppResult<()> {\n   281\t        let project_id = ProjectId::new(task.project_id.clone())?;\n   282\t        let flow = task\n   283\t            .resolved_flow\n   284\t            .ok_or_else(|| AppError::RoutingResolutionFailed {\n   285\t                input: task.task_id.clone(),\n   286\t                details: \"task has no resolved flow\".to_owned(),\n   287\t            })?;\n   288\t\n   289\t        let run_snapshot = self\n   290\t            .run_snapshot_read\n   291\t            .read_run_snapshot(base_dir, &project_id)?;\n   292\t        let dispatch_future = self.dispatch_in_worktree(\n   293\t            base_dir,\n   294\t            &project_id,\n   295\t            flow,\n   296\t            run_snapshot.status,\n   297\t            effective_config,\n   298\t            &lease.worktree_path,\n   299\t            task_cancel.clone(),\n   300\t        );\n   301\t        tokio::pin!(dispatch_future);\n   302\t\n   303\t        let heartbeat_interval = config.heartbeat_interval.max(Duration::from_secs(1));\n   304\t        let mut heartbeat = tokio::time::interval(heartbeat_interval);\n   305\t        let mut abort_poll = tokio::time::interval(Duration::from_millis(250));\n   306\t\n   307\t        loop {\n   308\t            tokio::select! {\n   309\t                result = &mut dispatch_future => break result,\n   310\t                _ = heartbeat.tick() => {\n   311\t                    let _ = LeaseService::heartbeat(self.store, base_dir, &lease.lease_id);\n   312\t                }\n   313\t                _ = abort_poll.tick() => {\n   314\t                    let current = self.store.read_task(base_dir, &task.task_id)?;\n   315\t                    if current.status == TaskStatus::Aborted {\n   316\t                        task_cancel.cancel();\n   317\t                    }\n   318\t                }\n   319\t                _ = shutdown.cancelled() => {\n   320\t                    let _ = DaemonTaskService::mark_aborted(self.store, base_dir, &task.task_id);\n   321\t                    task_cancel.cancel();\n   322\t                }\n   323\t            }\n   324\t        }\n   325\t    }\n   326\t\n   327\t    async fn dispatch_in_worktree(\n   328\t        &self,\n   329\t        base_dir: &Path,\n   330\t        project_id: &ProjectId,\n   331\t        flow: FlowPreset,\n   332\t        run_status: RunStatus,\n   333\t        effective_config: &EffectiveConfig,\n   334\t        worktree_path: &Path,\n   335\t        cancellation_token: CancellationToken,\n   336\t    ) -> AppResult<()> {\n   337\t        let original_dir = std::env::current_dir()?;\n   338\t        std::env::set_current_dir(worktree_path)?;\n   339\t\n   340\t        let result = match run_status {\n   341\t            RunStatus::NotStarted => {\n   342\t                engine::execute_run_with_retry(\n   343\t                    self.agent_service,\n   344\t                    self.run_snapshot_read,\n   345\t                    self.run_snapshot_write,\n   346\t                    self.journal_store,\n   347\t                    self.artifact_write,\n   348\t                    self.log_write,\n   349\t                    self.amendment_queue,\n   350\t                    base_dir,\n   351\t                    project_id,\n   352\t                    flow,\n   353\t                    effective_config,\n   354\t                    &RetryPolicy::default_policy(),\n   355\t                    cancellation_token,\n   356\t                )\n   357\t                .await\n   358\t            }\n   359\t            RunStatus::Failed | RunStatus::Paused => {\n   360\t                engine::resume_run_with_retry(\n","exit_code":0,"status":"completed"}}
