immed.is_empty() {\n    47\t            return Err(AppError::RoutingResolutionFailed {\n    48\t                input: command.to_owned(),\n    49\t                details: \"routing command cannot be empty\".to_owned(),\n    50\t            });\n    51\t        }\n    52\t\n    53\t        if let Ok(flow) = trimmed.parse::<FlowPreset>() {\n    54\t            return Ok(flow);\n    55\t        }\n    56\t\n    57\t        let tokens: Vec<_> = trimmed.split_whitespace().collect();\n    58\t        if tokens.len() == 3 && matches!(tokens[0], \"/rb\" | \"rb\") && tokens[1] == \"flow\" {\n    59\t            return tokens[2].parse::<FlowPreset>().map_err(|_| {\n    60\t                AppError::RoutingResolutionFailed {\n    61\t                    input: trimmed.to_owned(),\n    62\t                    details: format!(\"unknown flow preset '{}'\", tokens[2]),\n    63\t                }\n    64\t            });\n    65\t        }\n    66\t\n    67\t        Err(AppError::RoutingResolutionFailed {\n    68\t            input: trimmed.to_owned(),\n    69\t            details: \"expected `<preset>` or `/rb flow <preset>`\".to_owned(),\n    70\t        })\n    71\t    }\n    72\t\n    73\t    pub fn parse_labels(&self, labels: &[String]) -> AppResult<(Vec<FlowPreset>, Vec<String>)> {\n    74\t        let mut flows = Vec::new();\n    75\t        let mut warnings = Vec::new();\n    76\t\n    77\t        for label in labels {\n    78\t            let trimmed = label.trim();\n    79\t            if trimmed.is_empty() {\n    80\t                continue;\n    81\t            }\n    82\t\n    83\t            if trimmed.starts_with(\"rb:flow:\") {\n    84\t                let preset = trimmed.trim_start_matches(\"rb:flow:\");\n    85\t                if preset.is_empty() {\n    86\t                    warnings.push(format!(\"ignored malformed routing label '{trimmed}'\"));\n    87\t                    continue;\n    88\t                }\n    89\t\n    90\t                let flow = preset.parse::<FlowPreset>().map_err(|_| {\n    91\t                    AppError::RoutingResolutionFailed {\n    92\t                        input: trimmed.to_owned(),\n    93\t                        details: format!(\"unknown flow preset '{preset}'\"),\n    94\t                    }\n    95\t                })?;\n    96\t                flows.push(flow);\n    97\t                continue;\n    98\t            }\n    99\t\n   100\t            if trimmed.starts_with(\"rb:flow\") {\n   101\t                warnings.push(format!(\"ignored malformed routing label '{trimmed}'\"));\n   102\t            }\n   103\t        }\n   104\t\n   105\t        flows.sort_by_key(|flow| flow.as_str());\n   106\t        flows.dedup();\n   107\t\n   108\t        if flows.len() > 1 {\n   109\t            return Err(AppError::AmbiguousRouting {\n   110\t                labels: flows\n   111\t                    .into_iter()\n   112\t                    .map(|flow| flow.as_str().to_owned())\n   113\t                    .collect(),\n   114\t            });\n   115\t        }\n   116\t\n   117\t        Ok((flows, warnings))\n   118\t    }\n   119\t}\n","exit_code":0,"status":"completed"}}
