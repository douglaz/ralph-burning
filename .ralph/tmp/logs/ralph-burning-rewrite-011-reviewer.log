DaemonCommand) -> AppResult<()> {\n    48\t    match command.command {\n    49\t        DaemonSubcommand::Start {\n    50\t            poll_seconds,\n    51\t            single_iteration,\n    52\t        } => handle_start(poll_seconds, single_iteration).await,\n    53\t        DaemonSubcommand::Status => handle_status().await,\n    54\t        DaemonSubcommand::Abort { task_id } => handle_abort(&task_id).await,\n    55\t        DaemonSubcommand::Retry { task_id } => handle_retry(&task_id).await,\n    56\t        DaemonSubcommand::Reconcile { ttl_seconds } => handle_reconcile(ttl_seconds).await,\n    57\t    }\n    58\t}\n    59\t\n    60\tasync fn handle_start(poll_seconds: u64, single_iteration: bool) -> AppResult<()> {\n    61\t    let current_dir = std::env::current_dir()?;\n    62\t    let config = workspace_governance::load_workspace_config(&current_dir)?;\n    63\t    workspace_governance::ensure_supported_workspace_version(&config)?;\n    64\t    let _ = EffectiveConfig::load(&current_dir)?;\n    65\t\n    66\t    let agent_service = build_agent_execution_service();\n    67\t    let daemon_store = FsDaemonStore;\n    68\t    let worktree = WorktreeAdapter;\n    69\t    let project_store = FsProjectStore;\n    70\t    let run_snapshot_read = FsRunSnapshotStore;\n    71\t    let run_snapshot_write = FsRunSnapshotWriteStore;\n    72\t    let journal_store = FsJournalStore;\n    73\t    let artifact_store = FsArtifactStore;\n    74\t    let artifact_write = FsPayloadArtifactWriteStore;\n    75\t    let log_write = FsRuntimeLogWriteStore;\n    76\t    let amendment_queue = FsAmendmentQueueStore;\n    77\t\n    78\t    let daemon_loop = DaemonLoop::new(\n    79\t        &daemon_store,\n    80\t        &worktree,\n    81\t        &project_store,\n    82\t        &run_snapshot_read,\n    83\t        &run_snapshot_write,\n    84\t        &journal_store,\n    85\t        &artifact_store,\n    86\t        &artifact_write,\n    87\t        &log_write,\n    88\t        &amendment_queue,\n    89\t        &agent_service,\n    90\t    );\n    91\t    let loop_config = DaemonLoopConfig {\n    92\t        poll_interval: std::time::Duration::from_secs(poll_seconds),\n    93\t        single_iteration,\n    94\t        ..DaemonLoopConfig::default()\n    95\t    };\n    96\t\n    97\t    daemon_loop.run(&current_dir, &loop_config).await\n    98\t}\n    99\t\n   100\tasync fn handle_status() -> AppResult<()> {\n   101\t    let current_dir = std::env::current_dir()?;\n   102\t    let config = workspace_governance::load_workspace_config(&current_dir)?;\n   103\t    workspace_governance::ensure_supported_workspace_version(&config)?;\n   104\t\n   105\t    let store = FsDaemonStore;\n   106\t    let tasks = DaemonTaskService::list_tasks(&store, &current_dir)?;\n   107\t    let leases = store.list_leases(&current_dir)?;\n   108\t\n   109\t    if tasks.is_empty() {\n   110\t        println!(\"No daemon tasks found.\");\n   111\t        return Ok(());\n   112\t    }\n   113\t\n   114\t    for task in tasks {\n   115\t        let lease = leases.iter().find(|lease| lease.task_id == task.task_id);\n   116\t        let lease_id = lease\n   117\t            .map(|lease| lease.lease_id.as_str())\n   118\t            .or(task.lease_id.as_deref())\n   119\t            .unwrap_or(\"-\");\n   120\t        let heartbeat = lease\n   121\t            .map(|lease| lease.last_heartbeat.to_rfc3339())\n   122\t            .unwrap_or_else(|| \"-\".to_owned());\n   123\t        println!(\n   124\t            \"{}  {}  lease={}  heartbeat={}  issue={}\",\n   125\t            task.task_id, task.status, lease_id, heartbeat, task.issue_ref\n   126\t        );\n   127\t    }\n   128\t\n   129\t    Ok(())\n   130\t}\n   131\t\n   132\tasync fn handle_abort(task_id: &str) -> AppResult<()> {\n   133\t    let current_dir = std::env::current_dir()?;\n   134\t    let config = workspace_governance::load_workspace_config(&current_dir)?;\n   135\t    workspace_governance::ensure_supported_workspace_version(&config)?;\n   136\t\n   137\t    let store = FsDaemonStore;\n   138\t    let worktree = WorktreeAdapter;\n   139\t    let task = store.read_task(&current_dir, task_id)?;\n   140\t    if task.status.is_terminal() {\n   141\t        return Err(AppError::TaskStateTransitionInvalid {\n   142\t            task_id: task.task_id,\n   143\t            from: task.status.as_str().to_owned(),\n   144\t            to: TaskStatus::Aborted.as_str().to_owned(),\n   145\t        });\n   146\t    }\n   147\t\n   148\t    let original_status = task.status;\n   149\t    DaemonTaskService::mark_aborted(&store, &current_dir, task_id)?;\n   150\t\n   151\t    if matches!(original_status, TaskStatus::Claimed | TaskStatus::Active) {\n   152\t        cleanup_aborted_task(&store, &worktree, &current_dir, task_id, original_status).await?;\n   153\t    }\n   154\t\n   155\t    println!(\"Aborted task {task_id}\");\n   156\t    Ok(())\n   157\t}\n   158\t\n   159\tasync fn handle_retry(task_id: &str) -> AppResult<()> {\n   160\t    let current_dir = std::env::current_dir()?;\n   161\t    let config = workspace_governance::load_workspace_config(&current_dir)?;\n   162\t    workspace_governance::ensure_supported_workspace_version(&config)?;\n   163\t\n   164\t    let store = FsDaemonStore;\n   165\t    let task = DaemonTaskService::retry_task(&store, &current_dir, task_id)?;\n   166\t    println!(\n   167\t        \"Retried task {} (attempt_count={})\",\n   168\t        task.task_id, task.attempt_count\n   169\t    );\n   170\t    Ok(())\n   171\t}\n   172\t\n   173\tasync fn handle_reconcile(ttl_seconds: Option<u64>) -> AppResult<()> {\n   174\t    let current_dir = std::env::current_dir()?;\n   175\t    let config = workspace_governance::load_workspace_config(&current_dir)?;\n   176\t    workspace_governance::ensure_supported_workspace_version(&config)?;\n   177\t\n   178\t    let store = FsDaemonStore;\n   179\t    let worktree = WorktreeAdapter;\n   180\t    let report = LeaseService::reconcile(\n   181\t        &store,\n   182\t        &worktree,\n   183\t        &current_dir,\n   184\t        &current_dir,\n   185\t        ttl_seconds,\n   186\t        chrono::Utc::now(),\n   187\t    )?;\n   188\t\n   189\t    println!(\n   190\t        \"reconciled stale_leases={} failed_tasks={} released_leases={}\",\n   191\t        report.stale_lease_ids.len(),\n   192\t        report.failed_task_ids.len(),\n   193\t        report.released_lease_ids.len()\n   194\t    );\n   195\t    Ok(())\n   196\t}\n   197\t\n   198\tasync fn cleanup_aborted_task(\n   199\t    store: &dyn DaemonStorePort,\n   200\t    worktree: &WorktreeAdapter,\n   201\t    base_dir: &std::path::Path,\n   202\t    task_id: &str,\n   203\t    original_status: TaskStatus,\n   204\t) -> AppResult<()> {\n   205\t    let grace_deadline = std::time::Instant::now() + std::time::Duration::from_secs(1);\n   206\t    let await_daemon_cleanup = original_status == TaskStatus::Active;\n   207\t\n   208\t    loop {\n   209\t        let lease = LeaseService::find_lease_for_task(store, base_dir, task_id)?;\n   210\t        let Some(lease) = lease else {\n   211\t            let task = store.read_task(base_dir, task_id)?;\n   212\t            if task.lease_id.is_some() {\n   213\t                DaemonTaskService::clear_lease_reference(store, base_dir, task_id)?;\n   214\t            }\n   215\t            return Ok(());\n   216\t        };\n   217\t\n   218\t        if await_daemon_cleanup && std::time::Instant::now() < grace_deadline {\n   219\t            tokio::time::sleep(std::time::Duration::from_millis(100)).await;\n   220\t            continue;\n   221\t        }\n   222\t\n   223\t        let release_result = LeaseService::release(store, worktree, base_dir, base_dir, &lease);\n   224\t        let clear_result =\n   225\t            DaemonTaskService::clear_lease_reference(store, base_dir, task_id).map(|_| ());\n   226\t        return match (release_result, clear_result) {\