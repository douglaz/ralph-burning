{}\", task.issue_ref));\n   440\t        let input = CreateProjectInput {\n   441\t            id: project_id,\n   442\t            name,\n   443\t            flow,\n   444\t            prompt_path: \"daemon\".to_owned(),\n   445\t            prompt_contents: prompt_contents.clone(),\n   446\t            prompt_hash: FileSystem::prompt_hash(&prompt_contents),\n   447\t            created_at: Utc::now(),\n   448\t        };\n   449\t        create_project(self.project_store, self.journal_store, base_dir, input)?;\n   450\t        Ok(())\n   451\t    }\n   452\t\n   453\t    fn cleanup_active_leases(&self, base_dir: &Path) -> AppResult<()> {\n   454\t        let leases = self.store.list_leases(base_dir)?;\n   455\t        for lease in leases {\n   456\t            let _ = DaemonTaskService::mark_aborted(self.store, base_dir, &lease.task_id);\n   457\t            let _ = self.release_task_lease(base_dir, base_dir, &lease.task_id, &lease);\n   458\t        }\n   459\t        Ok(())\n   460\t    }\n   461\t\n   462\t    fn handle_post_claim_failure(\n   463\t        &self,\n   464\t        base_dir: &Path,\n   465\t        repo_root: &Path,\n   466\t        task: &DaemonTask,\n   467\t        lease: &crate::contexts::automation_runtime::model::WorktreeLease,\n   468\t        error: &AppError,\n   469\t    ) -> AppResult<()> {\n   470\t        let latest_task = self.store.read_task(base_dir, &task.task_id)?;\n   471\t        if latest_task.status == TaskStatus::Aborted {\n   472\t            return self.release_task_lease(base_dir, repo_root, &task.task_id, lease);\n   473\t        }\n   474\t\n   475\t        let failure_class = error\n   476\t            .failure_class()\n   477\t            .map(|class| class.as_str().to_owned())\n   478\t            .unwrap_or_else(|| \"daemon_dispatch_failed\".to_owned());\n   479\t        self.fail_claimed_task(\n   480\t            base_dir,\n   481\t            repo_root,\n   482\t            &task.task_id,\n   483\t            lease,\n   484\t            &failure_class,\n   485\t            &error.to_string(),\n   486\t        )\n   487\t    }\n   488\t\n   489\t    fn fail_claimed_task(\n   490\t        &self,\n   491\t        base_dir: &Path,\n   492\t        repo_root: &Path,\n   493\t        task_id: &str,\n   494\t        lease: &crate::contexts::automation_runtime::model::WorktreeLease,\n   495\t        failure_class: &str,\n   496\t        failure_message: &str,\n   497\t    ) -> AppResult<()> {\n   498\t        let mark_result = DaemonTaskService::mark_failed(\n   499\t            self.store,\n   500\t            base_dir,\n   501\t            task_id,\n   502\t            failure_class,\n   503\t            failure_message,\n   504\t        )\n   505\t        .map(|_| ());\n   506\t        let cleanup_result = self.release_task_lease(base_dir, repo_root, task_id, lease);\n   507\t\n   508\t        match (mark_result, cleanup_result) {\n   509\t            (Ok(()), Ok(())) => Ok(()),\n   510\t            (Err(error), Ok(())) => Err(error),\n   511\t            (Ok(()), Err(error)) => Err(error),\n   512\t            (Err(error), Err(_)) => Err(error),\n   513\t        }\n   514\t    }\n   515\t\n   516\t    fn release_task_lease(\n   517\t        &self,\n   518\t        base_dir: &Path,\n   519\t        repo_root: &Path,\n   520\t        task_id: &str,\n   521\t        lease: &crate::contexts::automation_runtime::model::WorktreeLease,\n   522\t    ) -> AppResult<()> {\n   523\t        let release_result =\n   524\t            LeaseService::release(self.store, self.worktree, base_dir, repo_root, lease);\n   525\t        let clear_result =\n   526\t            DaemonTaskService::clear_lease_reference(self.store, base_dir, task_id).map(|_| ());\n   527\t\n   528\t        match (release_result, clear_result) {\n   529\t            (Ok(()), Ok(())) => Ok(()),\n   530\t            (Err(error), Ok(())) => Err(error),\n   531\t            (Ok(()), Err(error)) => Err(error),\n   532\t            (Err(error), Err(_)) => Err(error),\n   533\t        }\n   534\t    }\n   535\t}\n   536\t\n   537\tasync fn wait_for_shutdown_signal() -> AppResult<()> {\n   538\t    #[cfg(unix)]\n   539\t    {\n   540\t        let mut sigterm =\n   541\t            tokio::signal::unix::signal(tokio::signal::unix::SignalKind::terminate())?;\n   542\t        tokio::select! {\n   543\t            _ = tokio::signal::ctrl_c() => Ok(()),\n   544\t            _ = sigterm.recv() => Ok(()),\n   545\t        }\n   546\t    }\n   547\t\n   548\t    #[cfg(not(unix))]\n   549\t    {\n   550\t        tokio::signal::ctrl_c().await.map_err(AppError::from)\n   551\t    }\n   552\t}\n","exit_code":0,"status":"completed"}}
