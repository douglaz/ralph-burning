s_cancelled())\n    59→            .finish()\n    60→    }\n    61→}\n    62→\n    63→#[derive(Debug, Clone, PartialEq)]\n    64→pub struct InvocationPayload {\n    65→    pub prompt: String,\n    66→    pub context: Value,\n    67→}\n    68→\n    69→#[derive(Debug, Clone)]\n    70→pub struct InvocationRequest {\n    71→    pub invocation_id: String,\n    72→    pub project_root: PathBuf,\n    73→    pub stage_contract: StageContract,\n    74→    pub role: BackendRole,\n    75→    pub resolved_target: ResolvedBackendTarget,\n    76→    pub payload: InvocationPayload,\n    77→    pub timeout: Duration,\n    78→    pub cancellation_token: CancellationToken,\n    79→    pub session_policy: SessionPolicy,\n    80→    pub prior_session: Option<SessionMetadata>,\n    81→    pub attempt_number: u32,\n    82→}\n    83→\n    84→#[derive(Debug, Clone, PartialEq, Eq)]\n    85→pub struct CapabilityCheck {\n    86→    pub backend: BackendSpec,\n    87→    pub model: ModelSpec,\n    88→    pub stage_id: crate::shared::domain::StageId,\n    89→    pub supported: bool,\n    90→    pub details: Option<String>,\n    91→}\n    92→\n    93→impl CapabilityCheck {\n    94→    pub fn success(target: &ResolvedBackendTarget, stage_contract: StageContract) -> Self {\n    95→        Self {\n    96→            backend: target.backend.clone(),\n    97→            model: target.model.clone(),\n    98→            stage_id: stage_contract.stage_id,\n    99→            supported: true,\n   100→            details: None,\n   101→        }\n   102→    }\n   103→\n   104→    pub fn failure(\n   105→        target: &ResolvedBackendTarget,\n   106→        stage_contract: StageContract,\n   107→        details: impl Into<String>,\n   108→    ) -> Self {\n   109→        Self {\n   110→            backend: target.backend.clone(),\n   111→            model: target.model.clone(),\n   112→            stage_id: stage_contract.stage_id,\n   113→            supported: false,\n   114→            details: Some(details.into()),\n   115→        }\n   116→    }\n   117→}\n   118→\n   119→#[derive(Debug, Clone, PartialEq, Eq)]\n   120→pub enum RawOutputReference {\n   121→    Inline(String),\n   122→    Stored(PathBuf),\n   123→}\n   124→\n   125→impl RawOutputReference {\n   126→    pub fn inline_contents(&self) -> Option<&str> {\n   127→        match self {\n   128→            Self::Inline(contents) => Some(contents),\n   129→            Self::Stored(_) => None,\n   130→        }\n   131→    }\n   132→\n   133→    pub fn stored_path(&self) -> Option<&Path> {\n   134→        match self {\n   135→            Self::Inline(_) => None,\n   136→            Self::Stored(path) => Some(path.as_path()),\n   137→        }\n   138→    }\n   139→}\n   140→\n   141→#[derive(Debug, Clone, Default, PartialEq, Eq)]\n   142→pub struct TokenCounts {\n   143→    pub prompt_tokens: Option<u32>,\n   144→    pub completion_tokens: Option<u32>,\n   145→    pub total_tokens: Option<u32>,\n   146→}\n   147→\n   148→#[derive(Debug, Clone, PartialEq, Eq)]\n   149→pub struct InvocationMetadata {\n   150→    pub invocation_id: String,\n   151→    pub duration: Duration,\n   152→    pub token_counts: TokenCounts,\n   153→    pub backend_used: BackendSpec,\n   154→    pub model_used: ModelSpec,\n   155→    pub attempt_number: u32,\n   156→    pub session_id: Option<String>,\n   157→    pub session_reused: bool,\n   158→}\n   159→\n   160→#[derive(Debug, Clone, PartialEq)]\n   161→pub struct InvocationEnvelope {\n   162→    pub raw_output_reference: RawOutputReference,\n   163→    pub parsed_payload: Value,\n   164→    pub metadata: InvocationMetadata,\n   165→    pub timestamp: DateTime<Utc>,\n   166→}\n   167→"}]},"parent_tool_use_id":"toolu_01B1RfMwbw1gwGPfFG4aoZxB","session_id":"36dfa1de-6185-4dcd-ac73-de5f18bf85fd","uuid":"54f31be3-42c4-453c-87e0-4fe3a22f7556"}
