rompt_review_enabled: bool) -> Vec<StageId> {\n    40→    stage_plan_for_flow(FlowPreset::Standard, prompt_review_enabled)\n    41→}\n    42→\n    43→/// Deterministic stage-to-role mapping per spec.\n    44→pub fn role_for_stage(stage_id: StageId) -> BackendRole {\n    45→    BackendRole::for_stage(stage_id)\n    46→}\n    47→\n    48→/// Resolved target per stage for preflight.\n    49→pub struct StagePlan {\n    50→    pub stage_id: StageId,\n    51→    pub role: BackendRole,\n    52→    pub contract: contracts::StageContract,\n    53→    pub target: ResolvedBackendTarget,\n    54→}\n    55→\n    56→/// Resolve all stage targets ahead of execution for preflight validation.\n    57→pub fn resolve_stage_plan(\n    58→    stages: &[StageId],\n    59→    resolver: &crate::contexts::agent_execution::service::BackendResolver,\n    60→    workspace_defaults: Option<&BackendSelectionConfig>,\n    61→) -> AppResult<Vec<StagePlan>> {\n    62→    let mut plan = Vec::with_capacity(stages.len());\n    63→    for &stage_id in stages {\n    64→        let role = role_for_stage(stage_id);\n    65→        let contract = contracts::contract_for_stage(stage_id);\n    66→        let target = resolver.resolve(role, None, None, workspace_defaults)?;\n    67→        plan.push(StagePlan {\n    68→            stage_id,\n    69→            role,\n    70→            contract,\n    71→            target,\n    72→        });\n    73→    }\n    74→    Ok(plan)\n    75→}\n    76→\n    77→/// Preflight: check capability and availability for every stage target.\n    78→pub async fn preflight_check<A: AgentExecutionPort>(\n    79→    adapter: &A,\n    80→    plan: &[StagePlan],\n    81→) -> AppResult<()> {\n    82→    for entry in plan {\n    83→        adapter\n    84→            .check_capability(&entry.target, &entry.contract)\n    85→            .await\n    86→            .map_err(|e| AppError::PreflightFailed {\n    87→                stage_id: entry.stage_id,\n    88→                details: e.to_string(),\n    89→            })?;\n    90→        adapter\n    91→            .check_availability(&entry.target)\n    92→            .await\n    93→            .map_err(|e| AppError::PreflightFailed {\n    94→                stage_id: entry.stage_id,\n    95→                details: e.to_string(),\n    96→            })?;\n    97→    }\n    98→    Ok(())\n    99→}\n   100→\n   101→/// Generate a new run ID from a timestamp.\n   102→fn generate_run_id() -> AppResult<RunId> {\n   103→    let now = Utc::now();\n   104→    RunId::new(format!(\"run-{}\", now.format(\"%Y%m%d%H%M%S\")))\n   105→}\n   106→\n   107→#[derive(Debug, Clone, Copy)]\n   108→enum ExecutionOrigin {\n   109→    Start,\n   110→    Resume,\n   111→}\n   112→\n   113→impl ExecutionOrigin {\n   114→    fn error(self, reason: String) -> AppError {\n   115→        match self {\n   116→            Self::Start => AppError::RunStartFailed { reason },\n   117→            Self::Resume => AppError::ResumeFailed { reason },\n   118→        }\n   119→    }\n   120→}\n   121→\n   122→#[derive(Debug, Clone, Copy, PartialEq, Eq)]\n   123→enum RunOutcome {\n   124→    Completed,\n   125→    Paused,\n   126→}\n   127→\n   128→#[derive(Debug)]\n   129→struct ResumeState {\n   130→    run_id: RunId,\n   131→    started_at: DateTime<Utc>,\n   132→    stage_index: usize,\n   133→    cursor: StageCursor,\n   134→}\n   135→\n   136→#[allow(clippy::too_many_arguments)]\n   137→pub async fn execute_run<A, R, S>(\n   138→    agent_service: &AgentExecutionService<A, R, S>,\n   139→    run_snapshot_read: &dyn RunSnapshotPort,\n   140→    run_snapshot_write: &dyn RunSnapshotWritePort,\n   141→    journal_store: &dyn JournalStorePort,\n   142→    artifact_write: &dyn PayloadArtifactWritePort,\n   143→    log_write: &dyn RuntimeLogWritePort,\n   144→    amendment_queue_port: &dyn AmendmentQueuePort,\n   145→    base_dir: &Path,\n   146→    project_id: &ProjectId,\n   147→    preset: FlowPreset,\n   148→    effective_config: &EffectiveConfig,\n   149→) -> AppResult<()>\n   150→where"}]},"parent_tool_use_id":"toolu_01B1RfMwbw1gwGPfFG4aoZxB","session_id":"36dfa1de-6185-4dcd-ac73-de5f18bf85fd","uuid":"eed8d643-6bc9-4334-be6b-3c46b8f6f838"}
