{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01BtfYetc7LQdPYFCs2FxACa","type":"tool_result","content":"     1→use std::fs;\n     2→use std::time::Duration;\n     3→\n     4→use chrono::{TimeZone, Utc};\n     5→use serde_json::{json, Value};\n     6→use tempfile::tempdir;\n     7→\n     8→use ralph_burning::adapters::fs::{FsRawOutputStore, FsSessionStore};\n     9→use ralph_burning::adapters::stub_backend::StubBackendAdapter;\n    10→use ralph_burning::contexts::agent_execution::model::{\n    11→    CancellationToken, InvocationContract, InvocationEnvelope, InvocationMetadata,\n    12→    InvocationPayload, InvocationRequest, RawOutputReference, TokenCounts,\n    13→};\n    14→use ralph_burning::contexts::agent_execution::service::{\n    15→    AgentExecutionPort, AgentExecutionService, BackendResolver, BackendSelectionConfig,\n    16→};\n    17→use ralph_burning::contexts::agent_execution::session::{PersistedSessions, SessionMetadata};\n    18→use ralph_burning::contexts::workflow_composition::contracts::contract_for_stage;\n    19→use ralph_burning::shared::domain::{\n    20→    BackendFamily, BackendRole, FailureClass, ModelSpec, ResolvedBackendTarget, SessionPolicy,\n    21→    StageId,\n    22→};\n    23→use ralph_burning::shared::error::{AppError, AppResult};\n    24→\n    25→fn project_root_fixture(root: &std::path::Path) -> std::path::PathBuf {\n    26→    let project_root = root.join(\"project-alpha\");\n    27→    fs::create_dir_all(project_root.join(\"runtime/backend\")).expect(\"create runtime/backend\");\n    28→    let sessions = serde_json::to_string_pretty(&PersistedSessions::empty())\n    29→        .expect(\"serialize empty sessions\");\n    30→    fs::write(project_root.join(\"sessions.json\"), sessions).expect(\"write sessions.json\");\n    31→    project_root\n    32→}\n    33→\n    34→#[allow(clippy::too_many_arguments)]\n    35→fn request_fixture(\n    36→    project_root: &std::path::Path,\n    37→    invocation_id: &str,\n    38→    stage_id: StageId,\n    39→    role: BackendRole,\n    40→    resolved_target: ResolvedBackendTarget,\n    41→    timeout: Duration,\n    42→    session_policy: SessionPolicy,\n    43→    cancellation_token: CancellationToken,\n    44→) -> InvocationRequest {\n    45→    InvocationRequest {\n    46→        invocation_id: invocation_id.to_owned(),\n    47→        project_root: project_root.to_path_buf(),\n    48→        contract: InvocationContract::Stage(contract_for_stage(stage_id)),\n    49→        role,\n    50→        resolved_target,\n    51→        payload: InvocationPayload {\n    52→            prompt: format!(\"Produce structured output for {}\", stage_id.as_str()),\n    53→            context: json!({\"stage\": stage_id.as_str()}),\n    54→        },\n    55→        timeout,\n    56→        cancellation_token,\n    57→        session_policy,\n    58→        prior_session: None,\n    59→        attempt_number: 1,\n    60→    }\n    61→}\n    62→\n    63→fn metadata_for_request(request: &InvocationRequest) -> InvocationMetadata {\n    64→    InvocationMetadata {\n    65→        invocation_id: request.invocation_id.clone(),\n    66→        duration: Duration::from_millis(0),\n    67→        token_counts: TokenCounts::default(),\n    68→        backend_used: request.resolved_target.backend.clone(),\n    69→        model_used: request.resolved_target.model.clone(),\n    70→        attempt_number: request.attempt_number,\n    71→        session_id: None,\n    72→        session_reused: false,\n    73→    }\n    74→}\n    75→\n    76→struct MalformedOutputAdapter;\n    77→\n    78→impl AgentExecutionPort for MalformedOutputAdapter {\n    79→    async fn check_capability(\n    80→        &self,\n    81→        _backend: &ResolvedBackendTarget,\n    82→        _contract: &InvocationContract,\n    83→    ) -> AppResult<()> {\n    84→        Ok(())\n    85→    }\n    86→\n    87→    async fn check_availability(&self, _backend: &ResolvedBackendTarget) -> AppResult<()> {\n    88→        Ok(())\n    89→    }\n    90→\n    91→    async fn invoke(&self, request: InvocationRequest) -> AppResult<InvocationEnvelope> {\n    92→        Ok(InvocationEnvelope {\n    93→            raw_output_reference: RawOutputReference::Inline(\"not-json\".to_owned()),\n    94→            parsed_payload: Value::Null,\n    95→            metadata: metadata_for_request(&request),\n    96→            timestamp: Utc::now(),\n    97→        })\n    98→    }\n    99→\n   100→    async fn cancel(&self, _invocation_id: &str) -> AppResult<()> {\n   101→        Ok(())\n   102→    }\n   103→}\n   104→\n   105→struct DomainInvalidAdapter;\n   106→\n   107→impl AgentExecutionPort for DomainInvalidAdapter {\n   108→    async fn check_capability(\n   109→        &self,\n   110→        _backend: &ResolvedBackendTarget,\n   111→        _contract: &InvocationContract,\n   112→    ) -> AppResult<()> {\n   113→        Ok(())\n   114→    }\n   115→\n   116→    async fn check_availability(&self, _backend: &ResolvedBackendTarget) -> AppResult<()> {\n   117→        Ok(())\n   118→    }\n   119→\n   120→    async fn invoke(&self, request: InvocationRequest) -> AppResult<InvocationEnvelope> {\n   121→        let raw = json!({\n   122→            \"problem_framing\": \"   \",\n   123→            \"assumptions_or_open_questions\": [],\n   124→            \"proposed_work\": [],\n   125→            \"readiness\": {\"ready\": false, \"risks\": []}\n   126→        });\n   127→\n   128→        Ok(InvocationEnvelope {\n   129→            raw_output_reference: RawOutputReference::Inline(\n   130→                serde_json::to_string_pretty(&raw).expect(\"serialize raw\"),\n   131→            ),\n   132→            parsed_payload: Value::Null,\n   133→            metadata: metadata_for_request(&request),\n   134→            timestamp: Utc::now(),\n   135→        })\n   136→    }\n   137→\n   138→    async fn cancel(&self, _invocation_id: &str) -> AppResult<()> {\n   139→        Ok(())\n   140→    }\n   141→}\n   142→\n   143→struct TransportErrorAdapter;\n   144→\n   145→impl AgentExecutionPort for TransportErrorAdapter {\n   146→    async fn check_capability(\n   147→        &self,\n   148→        _backend: &ResolvedBackendTarget,\n   149→        _contract: &InvocationContract,\n   150→    ) -> AppResult<()> {\n   151→        Ok(())\n   152→    }\n   153→\n   154→    async fn check_availability(&self, _backend: &ResolvedBackendTarget) -> AppResult<()> {\n   155→        Ok(())\n   156→    }\n   157→\n   158→    async fn invoke(&self, _request: InvocationRequest) -> AppResult<InvocationEnvelope> {\n   159→        Err(std::io::Error::other(\"transport failed\").into())\n   160→    }\n   161→\n   162→    async fn cancel(&self, _invocation_id: &str) -> AppResult<()> {\n   163→        Ok(())\n   164→    }\n   165→}\n   166→\n   167→#[test]\n   168→fn backend_resolver_honors_precedence_chain() {\n   169→    let resolver = BackendResolver::new();\n   170→    let workspace = BackendSelectionConfig {\n   171→        backend_family: Some(BackendFamily::OpenRouter),\n   172→        model_id: Some(\"workspace-model\".to_owned()),\n   173→    };\n   174→    let project = BackendSelectionConfig {\n   175→        backend_family: Some(BackendFamily::Codex),\n   176→        model_id: Some(\"project-model\".to_owned()),\n   177→    };\n   178→    let explicit = ModelSpec::new(BackendFamily::Claude, \"explicit-model\");\n   179→\n   180→    let resolved = resolver\n   181→        .resolve(\n   182→            BackendRole::Reviewer,\n   183→            Some(explicit.clone()),\n   184→            Some(&project),\n   185→            Some(&workspace),\n   186→        )\n   187→        .expect(\"resolve target\");\n   188→\n   189→    assert_eq!(resolved.backend.family, BackendFamily::Claude);\n   190→    assert_eq!(resolved.model.backend_family, BackendFamily::Claude);\n   191→    assert_eq!(resolved.model.model_id, explicit.model_id);\n   192→}\n   193→\n   194→#[tokio::test(flavor = \"multi_thread\")]\n   195→async fn service_constructs_envelope_and_persists_raw_output() {\n   196→    let temp_dir = tempdir().expect(\"create temp dir\");\n   197→    let project_root = project_root_fixture(temp_dir.path());\n   198→\n   199→    let adapter = StubBackendAdapter::default();\n   200→    let service = AgentExecutionService::new(adapter, FsRawOutputStore, FsSessionStore);\n   201→    let request = request_fixture(\n   202→        &project_root,\n   203→        \"invoke-1\",\n   204→        StageId::Planning,\n   205→        BackendRole::Planner,\n   206→        BackendRole::Planner.default_target(),\n   207→        Duration::from_secs(1),\n   208→        SessionPolicy::NewSession,\n   209→        CancellationToken::new(),\n   210→    );\n   211→\n   212→    let envelope = service.invoke(request).await.expect(\"invoke service\");\n   213→    let stored_path = envelope\n   214→        .raw_output_reference\n   215→        .stored_path()\n   216→        .expect(\"stored path\");\n   217→\n   218→    assert!(stored_path.exists());\n   219→    assert!(stored_path.ends_with(\"runtime/backend/invoke-1.raw\"));\n   220→    assert_eq!(envelope.parsed_payload[\"readiness\"][\"ready\"], json!(true));\n   221→    assert_eq!(envelope.metadata.attempt_number, 1);\n   222→    assert_eq!(envelope.metadata.backend_used.family, BackendFamily::Claude);\n   223→    assert_eq!(envelope.metadata.model_used.model_id, \"opus-4.1\");\n   224→    assert!(envelope.metadata.token_counts.total_tokens.is_some());\n   225→}\n   226→\n   227→#[tokio::test(flavor = \"multi_thread\")]\n   228→async fn service_returns_capability_mismatch_when_backend_cannot_support_stage() {\n   229→    let temp_dir = tempdir().expect(\"create temp dir\");\n   230→    let project_root = project_root_fixture(temp_dir.path());\n   231→    let adapter = StubBackendAdapter::default().without_stage_support(StageId::Planning);\n   232→    let service = AgentExecutionService::new(adapter, FsRawOutputStore, FsSessionStore);\n   233→    let request = request_fixture(\n   234→        &project_root,\n   235→        \"invoke-capability\",\n   236→        StageId::Planning,\n   237→        BackendRole::Planner,\n   238→        BackendRole::Planner.default_target(),\n   239→        Duration::from_secs(1),\n   240→        SessionPolicy::NewSession,\n   241→        CancellationToken::new(),\n   242→    );\n   243→\n   244→    let error = service\n   245→        .invoke(request)\n   246→        .await\n   247→        .expect_err(\"capability mismatch\");\n   248→\n   249→    assert!(matches!(error, AppError::CapabilityMismatch { .. }));\n   250→    assert_eq!(\n   251→        error.failure_class(),\n   252→        Some(FailureClass::DomainValidationFailure)\n   253→    );\n   254→}\n   255→\n   256→#[tokio::test(flavor = \"multi_thread\")]\n   257→async fn service_returns_backend_unavailable_as_transport_failure() {\n   258→    let temp_dir = tempdir().expect(\"create temp dir\");\n   259→    let project_root = project_root_fixture(temp_dir.path());\n   260→    let adapter = StubBackendAdapter::default().unavailable();\n   261→    let service = AgentExecutionService::new(adapter, FsRawOutputStore, FsSessionStore);\n   262→    let request = request_fixture(\n   263→        &project_root,\n   264→        \"invoke-unavailable\",\n   265→        StageId::Planning,\n   266→        BackendRole::Planner,\n   267→        BackendRole::Planner.default_target(),\n   268→        Duration::from_secs(1),\n   269→        SessionPolicy::NewSession,\n   270→        CancellationToken::new(),\n   271→    );\n   272→\n   273→    let error = service\n   274→        .invoke(request)\n   275→        .await\n   276→        .expect_err(\"backend unavailable\");\n   277→\n   278→    assert!(matches!(error, AppError::BackendUnavailable { .. }));\n   279→    assert_eq!(error.failure_class(), Some(FailureClass::TransportFailure));\n   280→}\n   281→\n   282→#[tokio::test(flavor = \"multi_thread\")]\n   283→async fn service_times_out_and_requests_backend_cancellation() {\n   284→    let temp_dir = tempdir().expect(\"create temp dir\");\n   285→    let project_root = project_root_fixture(temp_dir.path());\n   286→    let adapter = StubBackendAdapter::default().with_delay(Duration::from_millis(100));\n   287→    let adapter_handle = adapter.clone();\n   288→    let service = AgentExecutionService::new(adapter, FsRawOutputStore, FsSessionStore);\n   289→    let request = request_fixture(\n   290→        &project_root,\n   291→        \"invoke-timeout\",\n   292→        StageId::Planning,\n   293→        BackendRole::Planner,\n   294→        BackendRole::Planner.default_target(),\n   295→        Duration::from_millis(10),\n   296→        SessionPolicy::NewSession,\n   297→        CancellationToken::new(),\n   298→    );\n   299→\n   300→    let error = service.invoke(request).await.expect_err(\"timeout\");\n   301→\n   302→    assert!(matches!(error, AppError::InvocationTimeout { .. }));\n   303→    assert_eq!(error.failure_class(), Some(FailureClass::Timeout));\n   304→    assert_eq!(\n   305→        adapter_handle.cancelled_invocations(),\n   306→        vec![\"invoke-timeout\".to_owned()]\n   307→    );\n   308→}\n   309→\n   310→#[tokio::test(flavor = \"multi_thread\")]\n   311→async fn service_propagates_cancellation_without_retry() {\n   312→    let temp_dir = tempdir().expect(\"create temp dir\");\n   313→    let project_root = project_root_fixture(temp_dir.path());\n   314→    let adapter = StubBackendAdapter::default().with_delay(Duration::from_millis(100));\n   315→    let service = AgentExecutionService::new(adapter, FsRawOutputStore, FsSessionStore);\n   316→    let cancellation_token = CancellationToken::new();\n   317→    let cancel_handle = cancellation_token.clone();\n   318→    let request = request_fixture(\n   319→        &project_root,\n   320→        \"invoke-cancel\",\n   321→        StageId::Planning,\n   322→        BackendRole::Planner,\n   323→        BackendRole::Planner.default_target(),\n   324→        Duration::from_secs(1),\n   325→        SessionPolicy::NewSession,\n   326→        cancellation_token,\n   327→    );\n   328→\n   329→    tokio::spawn(async move {\n   330→        tokio::time::sleep(Duration::from_millis(10)).await;\n   331→        cancel_handle.cancel();\n   332→    });\n   333→\n   334→    let error = service\n   335→        .invoke(request)\n   336→        .await\n   337→        .expect_err(\"cancelled invocation\");\n   338→\n   339→    assert!(matches!(error, AppError::InvocationCancelled { .. }));\n   340→    assert_eq!(error.failure_class(), Some(FailureClass::Cancellation));\n   341→}\n   342→\n   343→#[tokio::test(flavor = \"multi_thread\")]\n   344→async fn service_maps_transport_failures_from_invoke() {\n   345→    let temp_dir = tempdir().expect(\"create temp dir\");\n   346→    let project_root = project_root_fixture(temp_dir.path());\n   347→    let service =\n   348→        AgentExecutionService::new(TransportErrorAdapter, FsRawOutputStore, FsSessionStore);\n   349→    let request = request_fixture(\n   350→        &project_root,\n   351→        \"invoke-transport\",\n   352→        StageId::Planning,\n   353→        BackendRole::Planner,\n   354→        BackendRole::Planner.default_target(),\n   355→        Duration::from_secs(1),\n   356→        SessionPolicy::NewSession,\n   357→        CancellationToken::new(),\n   358→    );\n   359→\n   360→    let error = service\n   361→        .invoke(request)\n   362→        .await\n   363→        .expect_err(\"transport failure\");\n   364→\n   365→    assert!(matches!(error, AppError::InvocationFailed { .. }));\n   366→    assert_eq!(error.failure_class(), Some(FailureClass::TransportFailure));\n   367→}\n   368→\n   369→#[tokio::test(flavor = \"multi_thread\")]\n   370→async fn service_maps_schema_failures_and_still_persists_raw_output() {\n   371→    let temp_dir = tempdir().expect(\"create temp dir\");\n   372→    let project_root = project_root_fixture(temp_dir.path());\n   373→    let service =\n   374→        AgentExecutionService::new(MalformedOutputAdapter, FsRawOutputStore, FsSessionStore);\n   375→    let request = request_fixture(\n   376→        &project_root,\n   377→        \"invoke-schema\",\n   378→        StageId::Planning,\n   379→        BackendRole::Planner,\n   380→        BackendRole::Planner.default_target(),\n   381→        Duration::from_secs(1),\n   382→        SessionPolicy::NewSession,\n   383→        CancellationToken::new(),\n   384→    );\n   385→\n   386→    let error = service.invoke(request).await.expect_err(\"schema failure\");\n   387→\n   388→    assert!(matches!(error, AppError::InvocationFailed { .. }));\n   389→    assert_eq!(\n   390→        error.failure_class(),\n   391→        Some(FailureClass::SchemaValidationFailure)\n   392→    );\n   393→\n   394→    let raw_output = fs::read_to_string(project_root.join(\"runtime/backend/invoke-schema.raw\"))\n   395→        .expect(\"read stored raw output\");\n   396→    assert_eq!(raw_output, \"not-json\");\n   397→}\n   398→\n   399→#[tokio::test(flavor = \"multi_thread\")]\n   400→async fn service_maps_domain_validation_failures() {\n   401→    let temp_dir = tempdir().expect(\"create temp dir\");\n   402→    let project_root = project_root_fixture(temp_dir.path());\n   403→    let service =\n   404→        AgentExecutionService::new(DomainInvalidAdapter, FsRawOutputStore, FsSessionStore);\n   405→    let request = request_fixture(\n   406→        &project_root,\n   407→        \"invoke-domain\",\n   408→        StageId::Planning,\n   409→        BackendRole::Planner,\n   410→        BackendRole::Planner.default_target(),\n   411→        Duration::from_secs(1),\n   412→        SessionPolicy::NewSession,\n   413→        CancellationToken::new(),\n   414→    );\n   415→\n   416→    let error = service.invoke(request).await.expect_err(\"domain failure\");\n   417→\n   418→    assert!(matches!(error, AppError::InvocationFailed { .. }));\n   419→    assert_eq!(\n   420→        error.failure_class(),\n   421→        Some(FailureClass::DomainValidationFailure)\n   422→    );\n   423→}\n   424→\n   425→#[tokio::test(flavor = \"multi_thread\")]\n   426→async fn service_reuses_supported_sessions_and_persists_updated_metadata() {\n   427→    let temp_dir = tempdir().expect(\"create temp dir\");\n   428→    let project_root = project_root_fixture(temp_dir.path());\n   429→    let timestamp = Utc\n   430→        .with_ymd_and_hms(2026, 3, 11, 21, 0, 0)\n   431→        .single()\n   432→        .expect(\"valid timestamp\");\n   433→    let sessions = PersistedSessions {\n   434→        sessions: vec![SessionMetadata {\n   435→            role: BackendRole::Implementer,\n   436→            backend_family: BackendFamily::Codex,\n   437→            model_id: \"gpt-5-codex\".to_owned(),\n   438→            session_id: \"existing-session\".to_owned(),\n   439→            created_at: timestamp,\n   440→            last_used_at: timestamp,\n   441→            invocation_count: 1,\n   442→        }],\n   443→    };\n   444→    fs::write(\n   445→        project_root.join(\"sessions.json\"),\n   446→        serde_json::to_string_pretty(&sessions).expect(\"serialize sessions\"),\n   447→    )\n   448→    .expect(\"write sessions\");\n   449→\n   450→    let service = AgentExecutionService::new(\n   451→        StubBackendAdapter::default(),\n   452→        FsRawOutputStore,\n   453→        FsSessionStore,\n   454→    );\n   455→    let request = request_fixture(\n   456→        &project_root,\n   457→        \"invoke-session-reuse\",\n   458→        StageId::Implementation,\n   459→        BackendRole::Implementer,\n   460→        BackendRole::Implementer.default_target(),\n   461→        Duration::from_secs(1),\n   462→        SessionPolicy::ReuseIfAllowed,\n   463→        CancellationToken::new(),\n   464→    );\n   465→\n   466→    let envelope = service\n   467→        .invoke(request)\n   468→        .await\n   469→        .expect(\"invoke with session reuse\");\n   470→\n   471→    assert!(envelope.metadata.session_reused);\n   472→    assert_eq!(\n   473→        envelope.metadata.session_id.as_deref(),\n   474→        Some(\"existing-session\")\n   475→    );\n   476→\n   477→    let persisted: PersistedSessions = serde_json::from_str(\n   478→        &fs::read_to_string(project_root.join(\"sessions.json\")).expect(\"read sessions.json\"),\n   479→    )\n   480→    .expect(\"deserialize sessions\");\n   481→    assert_eq!(persisted.sessions.len(), 1);\n   482→    assert_eq!(persisted.sessions[0].invocation_count, 2);\n   483→    assert_eq!(persisted.sessions[0].session_id, \"existing-session\");\n   484→}\n   485→\n   486→#[tokio::test(flavor = \"multi_thread\")]\n   487→async fn service_does_not_reuse_sessions_for_roles_that_disallow_it() {\n   488→    let temp_dir = tempdir().expect(\"create temp dir\");\n   489→    let project_root = project_root_fixture(temp_dir.path());\n   490→    let timestamp = Utc\n   491→        .with_ymd_and_hms(2026, 3, 11, 21, 0, 0)\n   492→        .single()\n   493→        .expect(\"valid timestamp\");\n   494→    let sessions = PersistedSessions {\n   495→        sessions: vec![SessionMetadata {\n   496→            role: BackendRole::Planner,\n   497→            backend_family: BackendFamily::Claude,\n   498→            model_id: \"opus-4.1\".to_owned(),\n   499→            session_id: \"planner-session\".to_owned(),\n   500→            created_at: timestamp,\n   501→            last_used_at: timestamp,\n   502→            invocation_count: 1,\n   503→        }],\n   504→    };\n   505→    fs::write(\n   506→        project_root.join(\"sessions.json\"),\n   507→        serde_json::to_string_pretty(&sessions).expect(\"serialize sessions\"),\n   508→    )\n   509→    .expect(\"write sessions\");\n   510→\n   511→    let service = AgentExecutionService::new(\n   512→        StubBackendAdapter::default(),\n   513→        FsRawOutputStore,\n   514→        FsSessionStore,\n   515→    );\n   516→    let request = request_fixture(\n   517→        &project_root,\n   518→        \"invoke-no-session-reuse\",\n   519→        StageId::Planning,\n   520→        BackendRole::Planner,\n   521→        BackendRole::Planner.default_target(),\n   522→        Duration::from_secs(1),\n   523→        SessionPolicy::ReuseIfAllowed,\n   524→        CancellationToken::new(),\n   525→    );\n   526→\n   527→    let envelope = service.invoke(request).await.expect(\"invoke without reuse\");\n   528→\n   529→    assert!(!envelope.metadata.session_reused);\n   530→    assert_eq!(\n   531→        envelope.metadata.session_id.as_deref(),\n   532→        None,\n   533→        \"planner sessions must not be reused\"\n   534→    );\n   535→\n   536→    let persisted: PersistedSessions = serde_json::from_str(\n   537→        &fs::read_to_string(project_root.join(\"sessions.json\")).expect(\"read sessions.json\"),\n   538→    )\n   539→    .expect(\"deserialize sessions\");\n   540→    assert_eq!(persisted.sessions.len(), 1);\n   541→    assert_eq!(persisted.sessions[0].session_id, \"planner-session\");\n   542→    assert_eq!(persisted.sessions[0].invocation_count, 1);\n   543→}\n   544→"}]},"parent_tool_use_id":"toolu_01PaXyQz2ihAyjCvhHfcUYoy","session_id":"36dfa1de-6185-4dcd-ac73-de5f18bf85fd","uuid":"ce8e3008-a80c-42ad-bf33-43c10befd4fb"}
