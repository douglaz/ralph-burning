{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_014ErCKsVQ3Q2njtetZdVNdy","type":"tool_result","content":"     1→#![forbid(unsafe_code)]\n     2→\n     3→//! Stage contract registry and deterministic evaluation pipeline.\n     4→//!\n     5→//! Every stage in every built-in flow preset resolves to exactly one\n     6→//! [`StageContract`]. Contract evaluation enforces a fixed order:\n     7→//!\n     8→//! 1. **Schema validation** — deserialize raw JSON into the typed payload.\n     9→//! 2. **Semantic validation** — apply domain rules to the typed payload.\n    10→//! 3. **Rendering** — produce a deterministic Markdown artifact.\n    11→//!\n    12→//! On schema failure, semantic validation and rendering do not run.\n    13→//! On domain failure, rendering does not run.\n    14→//! On any failure, no success bundle is returned.\n    15→\n    16→use schemars::schema::RootSchema;\n    17→\n    18→use crate::shared::domain::StageId;\n    19→use crate::shared::error::ContractError;\n    20→\n    21→use super::payloads::{ExecutionPayload, PlanningPayload, StagePayload, ValidationPayload};\n    22→use super::renderers;\n    23→\n    24→// ── Contract family ─────────────────────────────────────────────────────────\n    25→\n    26→/// Classifies a stage into one of three payload families.\n    27→#[derive(Debug, Clone, Copy, PartialEq, Eq, Hash)]\n    28→pub enum ContractFamily {\n    29→    /// prompt_review, planning, docs_plan, ci_plan\n    30→    Planning,\n    31→    /// implementation, plan_and_implement, apply_fixes, docs_update, ci_update\n    32→    Execution,\n    33→    /// qa, docs_validation, ci_validation, acceptance_qa, review, final_review,\n    34→    /// completion_panel\n    35→    Validation,\n    36→}\n    37→\n    38→// ── Stage contract ──────────────────────────────────────────────────────────\n    39→\n    40→/// A stage contract binds a [`StageId`] to its payload family, schema,\n    41→/// semantic validation rules, and renderer.\n    42→#[derive(Debug, Clone, Copy, PartialEq, Eq)]\n    43→pub struct StageContract {\n    44→    pub stage_id: StageId,\n    45→    pub family: ContractFamily,\n    46→}\n    47→\n    48→/// Bundle of a validated payload and its rendered Markdown artifact.\n    49→///\n    50→/// Callers receive either a `ValidatedBundle` or an error — never one without\n    51→/// the other. Schema and domain failures still prevent bundle creation. Review\n    52→/// outcomes are enforced separately by [`StageContract::evaluate`], while\n    53→/// [`StageContract::evaluate_permissive`] may return a bundle for non-passing\n    54→/// validation payloads so the engine can persist them before remediation.\n    55→#[derive(Debug, Clone, PartialEq, Eq)]\n    56→pub struct ValidatedBundle {\n    57→    pub payload: StagePayload,\n    58→    pub artifact: String,\n    59→}\n    60→\n    61→// ── Registry ────────────────────────────────────────────────────────────────\n    62→\n    63→/// Look up the contract for a given stage. Every [`StageId`] variant resolves\n    64→/// to exactly one contract.\n    65→pub fn contract_for_stage(stage_id: StageId) -> StageContract {\n    66→    let family = match stage_id {\n    67→        StageId::PromptReview | StageId::Planning | StageId::DocsPlan | StageId::CiPlan => {\n    68→            ContractFamily::Planning\n    69→        }\n    70→\n    71→        StageId::Implementation\n    72→        | StageId::PlanAndImplement\n    73→        | StageId::ApplyFixes\n    74→        | StageId::DocsUpdate\n    75→        | StageId::CiUpdate => ContractFamily::Execution,\n    76→\n    77→        StageId::Qa\n    78→        | StageId::DocsValidation\n    79→        | StageId::CiValidation\n    80→        | StageId::AcceptanceQa\n    81→        | StageId::Review\n    82→        | StageId::FinalReview\n    83→        | StageId::CompletionPanel => ContractFamily::Validation,\n    84→    };\n    85→\n    86→    StageContract { stage_id, family }\n    87→}\n    88→\n    89→/// Return contracts for all stages, in [`StageId::ALL`] order.\n    90→pub fn all_contracts() -> Vec<StageContract> {\n    91→    StageId::ALL\n    92→        .iter()\n    93→        .map(|&id| contract_for_stage(id))\n    94→        .collect()\n    95→}\n    96→\n    97→// ── Contract implementation ─────────────────────────────────────────────────\n    98→\n    99→impl StageContract {\n   100→    /// Generate the JSON Schema for this contract's payload family.\n   101→    pub fn json_schema(&self) -> RootSchema {\n   102→        match self.family {\n   103→            ContractFamily::Planning => schemars::schema_for!(PlanningPayload),\n   104→            ContractFamily::Execution => schemars::schema_for!(ExecutionPayload),\n   105→            ContractFamily::Validation => schemars::schema_for!(ValidationPayload),\n   106→        }\n   107→    }\n   108→\n   109→    /// Evaluate a raw JSON value through the full contract pipeline.\n   110→    ///\n   111→    /// Schema validation → semantic validation → outcome check → rendering.\n   112→    ///\n   113→    /// Returns [`ValidatedBundle`] on success or a [`ContractError`] on any\n   114→    /// failure. Non-passing QA/review outcomes are still errors here and are\n   115→    /// classified as [`FailureClass::QaReviewOutcomeFailure`].\n   116→    pub fn evaluate(&self, raw_json: &serde_json::Value) -> Result<ValidatedBundle, ContractError> {\n   117→        let bundle = self.evaluate_permissive(raw_json)?;\n   118→\n   119→        self.check_outcome(&bundle.payload)?;\n   120→\n   121→        Ok(bundle)\n   122→    }\n   123→\n   124→    /// Evaluate a raw JSON value without enforcing passing review outcomes.\n   125→    ///\n   126→    /// Schema validation → semantic validation → rendering.\n   127→    ///\n   128→    /// This is used by the engine so it can durably persist non-passing\n   129→    /// validation payloads before applying remediation or terminal semantics.\n   130→    pub fn evaluate_permissive(\n   131→        &self,\n   132→        raw_json: &serde_json::Value,\n   133→    ) -> Result<ValidatedBundle, ContractError> {\n   134→        // Step 1: Schema validation (deserialization into typed payload).\n   135→        let payload = self.validate_schema(raw_json)?;\n   136→\n   137→        // Step 2: Semantic / domain validation.\n   138→        self.validate_semantics(&payload)?;\n   139→\n   140→        // Step 3: Deterministic Markdown rendering (without outcome enforcement).\n   141→        let artifact = self.render(&payload);\n   142→\n   143→        Ok(ValidatedBundle { payload, artifact })\n   144→    }\n   145→\n   146→    // ── Private helpers ─────────────────────────────────────────────────\n   147→\n   148→    fn validate_schema(&self, raw: &serde_json::Value) -> Result<StagePayload, ContractError> {\n   149→        match self.family {\n   150→            ContractFamily::Planning => {\n   151→                let p: PlanningPayload = serde_json::from_value(raw.clone()).map_err(|e| {\n   152→                    ContractError::SchemaValidation {\n   153→                        stage_id: self.stage_id,\n   154→                        details: e.to_string(),\n   155→                    }\n   156→                })?;\n   157→                Ok(StagePayload::Planning(p))\n   158→            }\n   159→            ContractFamily::Execution => {\n   160→                let p: ExecutionPayload = serde_json::from_value(raw.clone()).map_err(|e| {\n   161→                    ContractError::SchemaValidation {\n   162→                        stage_id: self.stage_id,\n   163→                        details: e.to_string(),\n   164→                    }\n   165→                })?;\n   166→                Ok(StagePayload::Execution(p))\n   167→            }\n   168→            ContractFamily::Validation => {\n   169→                let p: ValidationPayload = serde_json::from_value(raw.clone()).map_err(|e| {\n   170→                    ContractError::SchemaValidation {\n   171→                        stage_id: self.stage_id,\n   172→                        details: e.to_string(),\n   173→                    }\n   174→                })?;\n   175→                Ok(StagePayload::Validation(p))\n   176→            }\n   177→        }\n   178→    }\n   179→\n   180→    fn validate_semantics(&self, payload: &StagePayload) -> Result<(), ContractError> {\n   181→        match payload {\n   182→            StagePayload::Planning(p) => {\n   183→                let mut errors = Vec::new();\n   184→                if p.problem_framing.trim().is_empty() {\n   185→                    errors.push(\"problem_framing must not be empty\".to_string());\n   186→                }\n   187→                if p.proposed_work.is_empty() {\n   188→                    errors.push(\"proposed_work must contain at least one item\".to_string());\n   189→                }\n   190→                for (i, item) in p.proposed_work.iter().enumerate() {\n   191→                    if item.order == 0 {\n   192→                        errors.push(format!(\"proposed_work[{i}].order must be positive\"));\n   193→                    }\n   194→                }\n   195→                if !errors.is_empty() {\n   196→                    return Err(ContractError::DomainValidation {\n   197→                        stage_id: self.stage_id,\n   198→                        details: errors.join(\"; \"),\n   199→                    });\n   200→                }\n   201→            }\n   202→            StagePayload::Execution(p) => {\n   203→                let mut errors = Vec::new();\n   204→                if p.change_summary.trim().is_empty() {\n   205→                    errors.push(\"change_summary must not be empty\".to_string());\n   206→                }\n   207→                if p.steps.is_empty() {\n   208→                    errors.push(\"steps must contain at least one item\".to_string());\n   209→                }\n   210→                for (i, step) in p.steps.iter().enumerate() {\n   211→                    if step.order == 0 {\n   212→                        errors.push(format!(\"steps[{i}].order must be positive\"));\n   213→                    }\n   214→                }\n   215→                if !errors.is_empty() {\n   216→                    return Err(ContractError::DomainValidation {\n   217→                        stage_id: self.stage_id,\n   218→                        details: errors.join(\"; \"),\n   219→                    });\n   220→                }\n   221→            }\n   222→            StagePayload::Validation(p) => {\n   223→                if !p.outcome.is_passing() && p.follow_up_or_amendments.is_empty() {\n   224→                    return Err(ContractError::DomainValidation {\n   225→                        stage_id: self.stage_id,\n   226→                        details: \"follow_up_or_amendments required when outcome is not approved\"\n   227→                            .to_string(),\n   228→                    });\n   229→                }\n   230→            }\n   231→        }\n   232→        Ok(())\n   233→    }\n   234→\n   235→    fn render(&self, payload: &StagePayload) -> String {\n   236→        match payload {\n   237→            StagePayload::Planning(p) => renderers::render_planning(self.stage_id, p),\n   238→            StagePayload::Execution(p) => renderers::render_execution(self.stage_id, p),\n   239→            StagePayload::Validation(p) => renderers::render_validation(self.stage_id, p),\n   240→        }\n   241→    }\n   242→\n   243→    fn check_outcome(&self, payload: &StagePayload) -> Result<(), ContractError> {\n   244→        if let StagePayload::Validation(p) = payload {\n   245→            if !p.outcome.is_passing() {\n   246→                return Err(ContractError::QaReviewOutcome {\n   247→                    stage_id: self.stage_id,\n   248→                    outcome: p.outcome.to_string(),\n   249→                });\n   250→            }\n   251→        }\n   252→        Ok(())\n   253→    }\n   254→}\n   255→"}]},"parent_tool_use_id":null,"session_id":"36dfa1de-6185-4dcd-ac73-de5f18bf85fd","uuid":"835fb4c6-6c3a-4a0c-86de-0c08bc202439","tool_use_result":{"type":"text","file":{"filePath":"/root/new-ralph-burning/ralph-burning-rewrite/src/contexts/workflow_composition/contracts.rs","content":"#![forbid(unsafe_code)]\n\n//! Stage contract registry and deterministic evaluation pipeline.\n//!\n//! Every stage in every built-in flow preset resolves to exactly one\n//! [`StageContract`]. Contract evaluation enforces a fixed order:\n//!\n//! 1. **Schema validation** — deserialize raw JSON into the typed payload.\n//! 2. **Semantic validation** — apply domain rules to the typed payload.\n//! 3. **Rendering** — produce a deterministic Markdown artifact.\n//!\n//! On schema failure, semantic validation and rendering do not run.\n//! On domain failure, rendering does not run.\n//! On any failure, no success bundle is returned.\n\nuse schemars::schema::RootSchema;\n\nuse crate::shared::domain::StageId;\nuse crate::shared::error::ContractError;\n\nuse super::payloads::{ExecutionPayload, PlanningPayload, StagePayload, ValidationPayload};\nuse super::renderers;\n\n// ── Contract family ─────────────────────────────────────────────────────────\n\n/// Classifies a stage into one of three payload families.\n#[derive(Debug, Clone, Copy, PartialEq, Eq, Hash)]\npub enum ContractFamily {\n    /// prompt_review, planning, docs_plan, ci_plan\n    Planning,\n    /// implementation, plan_and_implement, apply_fixes, docs_update, ci_update\n    Execution,\n    /// qa, docs_validation, ci_validation, acceptance_qa, review, final_review,\n    /// completion_panel\n    Validation,\n}\n\n// ── Stage contract ──────────────────────────────────────────────────────────\n\n/// A stage contract binds a [`StageId`] to its payload family, schema,\n/// semantic validation rules, and renderer.\n#[derive(Debug, Clone, Copy, PartialEq, Eq)]\npub struct StageContract {\n    pub stage_id: StageId,\n    pub family: ContractFamily,\n}\n\n/// Bundle of a validated payload and its rendered Markdown artifact.\n///\n/// Callers receive either a `ValidatedBundle` or an error — never one without\n/// the other. Schema and domain failures still prevent bundle creation. Review\n/// outcomes are enforced separately by [`StageContract::evaluate`], while\n/// [`StageContract::evaluate_permissive`] may return a bundle for non-passing\n/// validation payloads so the engine can persist them before remediation.\n#[derive(Debug, Clone, PartialEq, Eq)]\npub struct ValidatedBundle {\n    pub payload: StagePayload,\n    pub artifact: String,\n}\n\n// ── Registry ────────────────────────────────────────────────────────────────\n\n/// Look up the contract for a given stage. Every [`StageId`] variant resolves\n/// to exactly one contract.\npub fn contract_for_stage(stage_id: StageId) -> StageContract {\n    let family = match stage_id {\n        StageId::PromptReview | StageId::Planning | StageId::DocsPlan | StageId::CiPlan => {\n            ContractFamily::Planning\n        }\n\n        StageId::Implementation\n        | StageId::PlanAndImplement\n        | StageId::ApplyFixes\n        | StageId::DocsUpdate\n        | StageId::CiUpdate => ContractFamily::Execution,\n\n        StageId::Qa\n        | StageId::DocsValidation\n        | StageId::CiValidation\n        | StageId::AcceptanceQa\n        | StageId::Review\n        | StageId::FinalReview\n        | StageId::CompletionPanel => ContractFamily::Validation,\n    };\n\n    StageContract { stage_id, family }\n}\n\n/// Return contracts for all stages, in [`StageId::ALL`] order.\npub fn all_contracts() -> Vec<StageContract> {\n    StageId::ALL\n        .iter()\n        .map(|&id| contract_for_stage(id))\n        .collect()\n}\n\n// ── Contract implementation ─────────────────────────────────────────────────\n\nimpl StageContract {\n    /// Generate the JSON Schema for this contract's payload family.\n    pub fn json_schema(&self) -> RootSchema {\n        match self.family {\n            ContractFamily::Planning => schemars::schema_for!(PlanningPayload),\n            ContractFamily::Execution => schemars::schema_for!(ExecutionPayload),\n            ContractFamily::Validation => schemars::schema_for!(ValidationPayload),\n        }\n    }\n\n    /// Evaluate a raw JSON value through the full contract pipeline.\n    ///\n    /// Schema validation → semantic validation → outcome check → rendering.\n    ///\n    /// Returns [`ValidatedBundle`] on success or a [`ContractError`] on any\n    /// failure. Non-passing QA/review outcomes are still errors here and are\n    /// classified as [`FailureClass::QaReviewOutcomeFailure`].\n    pub fn evaluate(&self, raw_json: &serde_json::Value) -> Result<ValidatedBundle, ContractError> {\n        let bundle = self.evaluate_permissive(raw_json)?;\n\n        self.check_outcome(&bundle.payload)?;\n\n        Ok(bundle)\n    }\n\n    /// Evaluate a raw JSON value without enforcing passing review outcomes.\n    ///\n    /// Schema validation → semantic validation → rendering.\n    ///\n    /// This is used by the engine so it can durably persist non-passing\n    /// validation payloads before applying remediation or terminal semantics.\n    pub fn evaluate_permissive(\n        &self,\n        raw_json: &serde_json::Value,\n    ) -> Result<ValidatedBundle, ContractError> {\n        // Step 1: Schema validation (deserialization into typed payload).\n        let payload = self.validate_schema(raw_json)?;\n\n        // Step 2: Semantic / domain validation.\n        self.validate_semantics(&payload)?;\n\n        // Step 3: Deterministic Markdown rendering (without outcome enforcement).\n        let artifact = self.render(&payload);\n\n        Ok(ValidatedBundle { payload, artifact })\n    }\n\n    // ── Private helpers ─────────────────────────────────────────────────\n\n    fn validate_schema(&self, raw: &serde_json::Value) -> Result<StagePayload, ContractError> {\n        match self.family {\n            ContractFamily::Planning => {\n                let p: PlanningPayload = serde_json::from_value(raw.clone()).map_err(|e| {\n                    ContractError::SchemaValidation {\n                        stage_id: self.stage_id,\n                        details: e.to_string(),\n                    }\n                })?;\n                Ok(StagePayload::Planning(p))\n            }\n            ContractFamily::Execution => {\n                let p: ExecutionPayload = serde_json::from_value(raw.clone()).map_err(|e| {\n                    ContractError::SchemaValidation {\n                        stage_id: self.stage_id,\n                        details: e.to_string(),\n                    }\n                })?;\n                Ok(StagePayload::Execution(p))\n            }\n            ContractFamily::Validation => {\n                let p: ValidationPayload = serde_json::from_value(raw.clone()).map_err(|e| {\n                    ContractError::SchemaValidation {\n                        stage_id: self.stage_id,\n                        details: e.to_string(),\n                    }\n                })?;\n                Ok(StagePayload::Validation(p))\n            }\n        }\n    }\n\n    fn validate_semantics(&self, payload: &StagePayload) -> Result<(), ContractError> {\n        match payload {\n            StagePayload::Planning(p) => {\n                let mut errors = Vec::new();\n                if p.problem_framing.trim().is_empty() {\n                    errors.push(\"problem_framing must not be empty\".to_string());\n                }\n                if p.proposed_work.is_empty() {\n                    errors.push(\"proposed_work must contain at least one item\".to_string());\n                }\n                for (i, item) in p.proposed_work.iter().enumerate() {\n                    if item.order == 0 {\n                        errors.push(format!(\"proposed_work[{i}].order must be positive\"));\n                    }\n                }\n                if !errors.is_empty() {\n                    return Err(ContractError::DomainValidation {\n                        stage_id: self.stage_id,\n                        details: errors.join(\"; \"),\n                    });\n                }\n            }\n            StagePayload::Execution(p) => {\n                let mut errors = Vec::new();\n                if p.change_summary.trim().is_empty() {\n                    errors.push(\"change_summary must not be empty\".to_string());\n                }\n                if p.steps.is_empty() {\n                    errors.push(\"steps must contain at least one item\".to_string());\n                }\n                for (i, step) in p.steps.iter().enumerate() {\n                    if step.order == 0 {\n                        errors.push(format!(\"steps[{i}].order must be positive\"));\n                    }\n                }\n                if !errors.is_empty() {\n                    return Err(ContractError::DomainValidation {\n                        stage_id: self.stage_id,\n                        details: errors.join(\"; \"),\n                    });\n                }\n            }\n            StagePayload::Validation(p) => {\n                if !p.outcome.is_passing() && p.follow_up_or_amendments.is_empty() {\n                    return Err(ContractError::DomainValidation {\n                        stage_id: self.stage_id,\n                        details: \"follow_up_or_amendments required when outcome is not approved\"\n                            .to_string(),\n                    });\n                }\n            }\n        }\n        Ok(())\n    }\n\n    fn render(&self, payload: &StagePayload) -> String {\n        match payload {\n            StagePayload::Planning(p) => renderers::render_planning(self.stage_id, p),\n            StagePayload::Execution(p) => renderers::render_execution(self.stage_id, p),\n            StagePayload::Validation(p) => renderers::render_validation(self.stage_id, p),\n        }\n    }\n\n    fn check_outcome(&self, payload: &StagePayload) -> Result<(), ContractError> {\n        if let StagePayload::Validation(p) = payload {\n            if !p.outcome.is_passing() {\n                return Err(ContractError::QaReviewOutcome {\n                    stage_id: self.stage_id,\n                    outcome: p.outcome.to_string(),\n                });\n            }\n        }\n        Ok(())\n    }\n}\n","numLines":255,"startLine":1,"totalLines":255}}}
