{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01NToEU9SbaSNBJ3rSQ1MZca","type":"tool_result","content":"     1→#![forbid(unsafe_code)]\n     2→\n     3→//! Requirements drafting service.\n     4→//!\n     5→//! Orchestrates `draft`, `quick`, `show`, and `answer` commands, including\n     6→//! answer-template validation, seed rollback, and failure invariants.\n     7→\n     8→use std::path::Path;\n     9→\n    10→use chrono::{DateTime, Utc};\n    11→use serde_json::Value;\n    12→\n    13→use crate::adapters::fs::FileSystem;\n    14→use crate::contexts::agent_execution::model::{\n    15→    CancellationToken, InvocationContract, InvocationPayload, InvocationRequest,\n    16→};\n    17→use crate::contexts::agent_execution::service::{AgentExecutionPort, AgentExecutionService};\n    18→use crate::contexts::agent_execution::session::SessionStorePort;\n    19→use crate::contexts::agent_execution::RawOutputPort;\n    20→use crate::shared::domain::{BackendRole, SessionPolicy};\n    21→use crate::shared::error::{AppError, AppResult};\n    22→\n    23→use super::contracts::{RequirementsContract, RequirementsPayload, RequirementsValidatedBundle};\n    24→use super::model::{\n    25→    AnswerEntry, PersistedAnswers, QuestionSetPayload, RequirementsJournalEvent,\n    26→    RequirementsJournalEventType, RequirementsReviewOutcome, RequirementsRun,\n    27→    RequirementsStageId, RequirementsStatus,\n    28→};\n    29→\n    30→// ── Port traits ─────────────────────────────────────────────────────────────\n    31→\n    32→/// Filesystem operations for requirements runs.\n    33→#[allow(async_fn_in_trait)]\n    34→pub trait RequirementsStorePort {\n    35→    fn create_run_dir(&self, base_dir: &Path, run_id: &str) -> AppResult<()>;\n    36→    fn write_run(&self, base_dir: &Path, run_id: &str, run: &RequirementsRun) -> AppResult<()>;\n    37→    fn read_run(&self, base_dir: &Path, run_id: &str) -> AppResult<RequirementsRun>;\n    38→    fn append_journal_event(\n    39→        &self,\n    40→        base_dir: &Path,\n    41→        run_id: &str,\n    42→        event: &RequirementsJournalEvent,\n    43→    ) -> AppResult<()>;\n    44→    fn read_journal(\n    45→        &self,\n    46→        base_dir: &Path,\n    47→        run_id: &str,\n    48→    ) -> AppResult<Vec<RequirementsJournalEvent>>;\n    49→    fn write_payload(\n    50→        &self,\n    51→        base_dir: &Path,\n    52→        run_id: &str,\n    53→        payload_id: &str,\n    54→        payload: &Value,\n    55→    ) -> AppResult<()>;\n    56→    fn write_artifact(\n    57→        &self,\n    58→        base_dir: &Path,\n    59→        run_id: &str,\n    60→        artifact_id: &str,\n    61→        content: &str,\n    62→    ) -> AppResult<()>;\n    63→    fn write_answers_toml(\n    64→        &self,\n    65→        base_dir: &Path,\n    66→        run_id: &str,\n    67→        template: &str,\n    68→    ) -> AppResult<()>;\n    69→    fn read_answers_toml(&self, base_dir: &Path, run_id: &str) -> AppResult<String>;\n    70→    fn write_answers_json(\n    71→        &self,\n    72→        base_dir: &Path,\n    73→        run_id: &str,\n    74→        answers: &PersistedAnswers,\n    75→    ) -> AppResult<()>;\n    76→    fn write_seed_pair(\n    77→        &self,\n    78→        base_dir: &Path,\n    79→        run_id: &str,\n    80→        project_json: &Value,\n    81→        prompt_md: &str,\n    82→    ) -> AppResult<()>;\n    83→    fn remove_seed_pair(&self, base_dir: &Path, run_id: &str) -> AppResult<()>;\n    84→    fn answers_toml_path(&self, base_dir: &Path, run_id: &str) -> std::path::PathBuf;\n    85→    fn seed_prompt_path(&self, base_dir: &Path, run_id: &str) -> std::path::PathBuf;\n    86→}\n    87→\n    88→// ── Service ─────────────────────────────────────────────────────────────────\n    89→\n    90→pub struct RequirementsService<A, R, S, Q> {\n    91→    agent_service: AgentExecutionService<A, R, S>,\n    92→    store: Q,\n    93→}\n    94→\n    95→impl<A, R, S, Q> RequirementsService<A, R, S, Q> {\n    96→    pub fn new(agent_service: AgentExecutionService<A, R, S>, store: Q) -> Self {\n    97→        Self {\n    98→            agent_service,\n    99→            store,\n   100→        }\n   101→    }\n   102→}\n   103→\n   104→impl<A, R, S, Q> RequirementsService<A, R, S, Q>\n   105→where\n   106→    A: AgentExecutionPort,\n   107→    R: RawOutputPort,\n   108→    S: SessionStorePort,\n   109→    Q: RequirementsStorePort,\n   110→{\n   111→    /// Execute `requirements draft --idea \"<text>\"`.\n   112→    pub async fn draft(&self, base_dir: &Path, idea: &str, now: DateTime<Utc>) -> AppResult<String> {\n   113→        let run_id = generate_run_id(now);\n   114→        let mut run = RequirementsRun::new_draft(run_id.clone(), idea.to_owned(), now);\n   115→\n   116→        // Create run directory and initial state\n   117→        self.store.create_run_dir(base_dir, &run_id)?;\n   118→        self.store.write_run(base_dir, &run_id, &run)?;\n   119→\n   120→        let created_event = journal_event(1, now, RequirementsJournalEventType::RunCreated, &run);\n   121→        self.store\n   122→            .append_journal_event(base_dir, &run_id, &created_event)?;\n   123→\n   124→        // Generate questions\n   125→        let run_root = requirements_run_root(base_dir, &run_id);\n   126→        let question_result = self\n   127→            .invoke_stage(\n   128→                &run_root,\n   129→                RequirementsStageId::QuestionSet,\n   130→                BackendRole::Planner,\n   131→                &format!(\"Generate clarifying questions for the following idea:\\n\\n{idea}\"),\n   132→            )\n   133→            .await;\n   134→\n   135→        match question_result {\n   136→            Ok(bundle) => {\n   137→                let RequirementsPayload::QuestionSet(ref qs) = bundle.payload else {\n   138→                    unreachable!(\"QuestionSet contract always returns QuestionSet payload\");\n   139→                };\n   140→\n   141→                let payload_id = format!(\"{run_id}-qs-1\");\n   142→                let artifact_id = format!(\"{run_id}-qs-art-1\");\n   143→\n   144→                // Persist payload and artifact atomically\n   145→                let payload_json = serde_json::to_value(qs)?;\n   146→                if let Err(e) = self.persist_payload_artifact_pair(\n   147→                    base_dir,\n   148→                    &run_id,\n   149→                    &payload_id,\n   150→                    &payload_json,\n   151→                    &artifact_id,\n   152→                    &bundle.artifact,\n   153→                ) {\n   154→                    // State invariant: if payload/artifact pair fails, run must not transition\n   155→                    run.status = RequirementsStatus::Failed;\n   156→                    run.status_summary = format!(\"failed: could not persist question set: {e}\");\n   157→                    run.updated_at = Utc::now();\n   158→                    let _ = self.store.write_run(base_dir, &run_id, &run);\n   159→                    return Err(e);\n   160→                }\n   161→\n   162→                if qs.questions.is_empty() {\n   163→                    // No questions needed — continue directly\n   164→                    self.continue_after_answers(base_dir, &mut run, idea, &[], 2, now)\n   165→                        .await?;\n   166→                } else {\n   167→                    // Generate answers.toml template\n   168→                    let template = generate_answers_template(qs);\n   169→                    self.store\n   170→                        .write_answers_toml(base_dir, &run_id, &template)?;\n   171→\n   172→                    run.question_round = 1;\n   173→                    run.latest_question_set_id = Some(payload_id.clone());\n   174→                    run.status = RequirementsStatus::AwaitingAnswers;\n   175→                    run.status_summary = format!(\n   176→                        \"awaiting answers: {} question(s), round 1\",\n   177→                        qs.questions.len()\n   178→                    );\n   179→                    run.updated_at = Utc::now();\n   180→                    self.store.write_run(base_dir, &run_id, &run)?;\n   181→\n   182→                    let event = journal_event(\n   183→                        2,\n   184→                        Utc::now(),\n   185→                        RequirementsJournalEventType::QuestionsGenerated,\n   186→                        &run,\n   187→                    );\n   188→                    self.store\n   189→                        .append_journal_event(base_dir, &run_id, &event)?;\n   190→\n   191→                    let answers_path = self.store.answers_toml_path(base_dir, &run_id);\n   192→                    println!(\n   193→                        \"Questions generated. Edit answers at:\\n  {}\\n\\nThen run:\\n  ralph-burning requirements answer {}\",\n   194→                        answers_path.display(),\n   195→                        run_id\n   196→                    );\n   197→                }\n   198→            }\n   199→            Err(e) => {\n   200→                run.status = RequirementsStatus::Failed;\n   201→                run.status_summary = format!(\"failed: question generation: {e}\");\n   202→                run.updated_at = Utc::now();\n   203→                self.store.write_run(base_dir, &run_id, &run)?;\n   204→\n   205→                let event = journal_event(\n   206→                    2,\n   207→                    Utc::now(),\n   208→                    RequirementsJournalEventType::RunFailed,\n   209→                    &run,\n   210→                );\n   211→                self.store\n   212→                    .append_journal_event(base_dir, &run_id, &event)?;\n   213→                return Err(e);\n   214→            }\n   215→        }\n   216→\n   217→        Ok(run_id)\n   218→    }\n   219→\n   220→    /// Execute `requirements quick --idea \"<text>\"`.\n   221→    pub async fn quick(&self, base_dir: &Path, idea: &str, now: DateTime<Utc>) -> AppResult<String> {\n   222→        let run_id = generate_run_id(now);\n   223→        let mut run = RequirementsRun::new_quick(run_id.clone(), idea.to_owned(), now);\n   224→\n   225→        self.store.create_run_dir(base_dir, &run_id)?;\n   226→        self.store.write_run(base_dir, &run_id, &run)?;\n   227→\n   228→        let created_event = journal_event(1, now, RequirementsJournalEventType::RunCreated, &run);\n   229→        self.store\n   230→            .append_journal_event(base_dir, &run_id, &created_event)?;\n   231→\n   232→        // Skip question generation entirely — go straight to draft\n   233→        self.continue_after_answers(base_dir, &mut run, idea, &[], 2, now)\n   234→            .await?;\n   235→\n   236→        Ok(run_id)\n   237→    }\n   238→\n   239→    /// Execute `requirements show <run-id>`.\n   240→    pub fn show(&self, base_dir: &Path, run_id: &str) -> AppResult<RequirementsShowResult> {\n   241→        let run = self.store.read_run(base_dir, run_id)?;\n   242→        let journal = self.store.read_journal(base_dir, run_id)?;\n   243→\n   244→        let pending_question_count = if run.status == RequirementsStatus::AwaitingAnswers {\n   245→            // Count required questions from latest question set\n   246→            if let Some(ref _qs_id) = run.latest_question_set_id {\n   247→                // We derive count from the run state, not by scanning artifacts\n   248→                Some(run.question_round)\n   249→            } else {\n   250→                None\n   251→            }\n   252→        } else {\n   253→            None\n   254→        };\n   255→\n   256→        let failure_summary = if run.status == RequirementsStatus::Failed {\n   257→            Some(run.status_summary.clone())\n   258→        } else {\n   259→            None\n   260→        };\n   261→\n   262→        let seed_prompt_path = if run.status == RequirementsStatus::Completed {\n   263→            Some(self.store.seed_prompt_path(base_dir, run_id))\n   264→        } else {\n   265→            None\n   266→        };\n   267→\n   268→        Ok(RequirementsShowResult {\n   269→            run,\n   270→            journal_event_count: journal.len() as u64,\n   271→            pending_question_count,\n   272→            failure_summary,\n   273→            seed_prompt_path,\n   274→        })\n   275→    }\n   276→\n   277→    /// Execute `requirements answer <run-id>`.\n   278→    pub async fn answer(&self, base_dir: &Path, run_id: &str) -> AppResult<()> {\n   279→        let mut run = self.store.read_run(base_dir, run_id)?;\n   280→\n   281→        // Valid only for awaiting_answers or failed runs with a committed question set\n   282→        match run.status {\n   283→            RequirementsStatus::AwaitingAnswers => {}\n   284→            RequirementsStatus::Failed if run.latest_question_set_id.is_some() => {}\n   285→            _ => {\n   286→                return Err(AppError::InvalidRequirementsState {\n   287→                    run_id: run_id.to_owned(),\n   288→                    details: format!(\n   289→                        \"cannot answer: run is in '{}' state\",\n   290→                        run.status\n   291→                    ),\n   292→                });\n   293→            }\n   294→        }\n   295→\n   296→        // Open editor\n   297→        let answers_path = self.store.answers_toml_path(base_dir, run_id);\n   298→        FileSystem::open_editor(&answers_path)?;\n   299→\n   300→        // Read and validate answers\n   301→        let answers_raw = self.store.read_answers_toml(base_dir, run_id)?;\n   302→        let answers = parse_and_validate_answers(&answers_raw, base_dir, run_id, &self.store)?;\n   303→\n   304→        // Persist answers.json\n   305→        self.store\n   306→            .write_answers_json(base_dir, run_id, &answers)?;\n   307→\n   308→        let seq = self.next_sequence(base_dir, run_id)?;\n   309→        let event = journal_event(\n   310→            seq,\n   311→            Utc::now(),\n   312→            RequirementsJournalEventType::AnswersSubmitted,\n   313→            &run,\n   314→        );\n   315→        self.store\n   316→            .append_journal_event(base_dir, run_id, &event)?;\n   317→\n   318→        // Resume from answers boundary\n   319→        let answer_entries: Vec<(String, String)> = answers\n   320→            .answers\n   321→            .iter()\n   322→            .map(|a| (a.question_id.clone(), a.answer.clone()))\n   323→            .collect();\n   324→\n   325→        run.question_round += 1;\n   326→        run.status = RequirementsStatus::Drafting;\n   327→        run.status_summary = \"drafting: generating requirements from answers\".to_owned();\n   328→        run.updated_at = Utc::now();\n   329→        self.store.write_run(base_dir, run_id, &run)?;\n   330→\n   331→        let idea = run.idea.clone();\n   332→        self.continue_after_answers(base_dir, &mut run, &idea, &answer_entries, seq + 1, Utc::now())\n   333→            .await?;\n   334→\n   335→        Ok(())\n   336→    }\n   337→\n   338→    // ── Internal pipeline ───────────────────────────────────────────────\n   339→\n   340→    async fn continue_after_answers(\n   341→        &self,\n   342→        base_dir: &Path,\n   343→        run: &mut RequirementsRun,\n   344→        idea: &str,\n   345→        answers: &[(String, String)],\n   346→        start_seq: u64,\n   347→        _now: DateTime<Utc>,\n   348→    ) -> AppResult<()> {\n   349→        let run_id = run.run_id.clone();\n   350→        let run_root = requirements_run_root(base_dir, &run_id);\n   351→        let mut seq = start_seq;\n   352→\n   353→        // ── Draft ───────────────────────────────────────────────────────\n   354→        let draft_prompt = build_draft_prompt(idea, answers);\n   355→        let draft_result = self\n   356→            .invoke_stage(\n   357→                &run_root,\n   358→                RequirementsStageId::RequirementsDraft,\n   359→                BackendRole::Planner,\n   360→                &draft_prompt,\n   361→            )\n   362→            .await;\n   363→\n   364→        let draft_bundle = match draft_result {\n   365→            Ok(b) => b,\n   366→            Err(e) => {\n   367→                self.fail_run(base_dir, run, seq, &format!(\"draft generation: {e}\"))\n   368→                    .await?;\n   369→                return Err(e);\n   370→            }\n   371→        };\n   372→\n   373→        let RequirementsPayload::Draft(ref draft_payload) = draft_bundle.payload else {\n   374→            unreachable!();\n   375→        };\n   376→\n   377→        let draft_payload_id = format!(\"{run_id}-draft-1\");\n   378→        let draft_artifact_id = format!(\"{run_id}-draft-art-1\");\n   379→        let draft_json = serde_json::to_value(draft_payload)?;\n   380→\n   381→        if let Err(e) = self.persist_payload_artifact_pair(\n   382→            base_dir,\n   383→            &run_id,\n   384→            &draft_payload_id,\n   385→            &draft_json,\n   386→            &draft_artifact_id,\n   387→            &draft_bundle.artifact,\n   388→        ) {\n   389→            self.fail_run(base_dir, run, seq, &format!(\"draft persistence: {e}\"))\n   390→                .await?;\n   391→            return Err(e);\n   392→        }\n   393→\n   394→        run.latest_draft_id = Some(draft_payload_id.clone());\n   395→        run.status_summary = \"drafting: reviewing requirements\".to_owned();\n   396→        run.updated_at = Utc::now();\n   397→        self.store.write_run(base_dir, &run_id, run)?;\n   398→\n   399→        let event = journal_event(\n   400→            seq,\n   401→            Utc::now(),\n   402→            RequirementsJournalEventType::DraftGenerated,\n   403→            run,\n   404→        );\n   405→        self.store\n   406→            .append_journal_event(base_dir, &run_id, &event)?;\n   407→        seq += 1;\n   408→\n   409→        // ── Review ──────────────────────────────────────────────────────\n   410→        let review_prompt = format!(\n   411→            \"Review the following requirements draft:\\n\\n{}\",\n   412→            draft_bundle.artifact\n   413→        );\n   414→        let review_result = self\n   415→            .invoke_stage(\n   416→                &run_root,\n   417→                RequirementsStageId::RequirementsReview,\n   418→                BackendRole::Reviewer,\n   419→                &review_prompt,\n   420→            )\n   421→            .await;\n   422→\n   423→        let review_bundle = match review_result {\n   424→            Ok(b) => b,\n   425→            Err(e) => {\n   426→                self.fail_run(base_dir, run, seq, &format!(\"review: {e}\"))\n   427→                    .await?;\n   428→                return Err(e);\n   429→            }\n   430→        };\n   431→\n   432→        let RequirementsPayload::Review(ref review_payload) = review_bundle.payload else {\n   433→            unreachable!();\n   434→        };\n   435→\n   436→        let review_payload_id = format!(\"{run_id}-review-1\");\n   437→        let review_artifact_id = format!(\"{run_id}-review-art-1\");\n   438→        let review_json = serde_json::to_value(review_payload)?;\n   439→\n   440→        if let Err(e) = self.persist_payload_artifact_pair(\n   441→            base_dir,\n   442→            &run_id,\n   443→            &review_payload_id,\n   444→            &review_json,\n   445→            &review_artifact_id,\n   446→            &review_bundle.artifact,\n   447→        ) {\n   448→            self.fail_run(base_dir, run, seq, &format!(\"review persistence: {e}\"))\n   449→                .await?;\n   450→            return Err(e);\n   451→        }\n   452→\n   453→        run.latest_review_id = Some(review_payload_id.clone());\n   454→        run.updated_at = Utc::now();\n   455→        self.store.write_run(base_dir, &run_id, run)?;\n   456→\n   457→        let event = journal_event(\n   458→            seq,\n   459→            Utc::now(),\n   460→            RequirementsJournalEventType::ReviewCompleted,\n   461→            run,\n   462→        );\n   463→        self.store\n   464→            .append_journal_event(base_dir, &run_id, &event)?;\n   465→        seq += 1;\n   466→\n   467→        // Check review outcome\n   468→        match review_payload.outcome {\n   469→            RequirementsReviewOutcome::Approved | RequirementsReviewOutcome::ConditionallyApproved => {\n   470→                // Continue to seed generation\n   471→            }\n   472→            RequirementsReviewOutcome::RequestChanges | RequirementsReviewOutcome::Rejected => {\n   473→                // Fail the run after review payload/artifact are durably committed\n   474→                let msg = format!(\n   475→                    \"review outcome: {} — {}\",\n   476→                    review_payload.outcome,\n   477→                    review_payload.findings.join(\"; \")\n   478→                );\n   479→                self.fail_run(base_dir, run, seq, &msg).await?;\n   480→                return Err(AppError::InvalidRequirementsState {\n   481→                    run_id: run_id.clone(),\n   482→                    details: msg,\n   483→                });\n   484→            }\n   485→        }\n   486→\n   487→        // ── Seed ────────────────────────────────────────────────────────\n   488→        let follow_ups = if review_payload.outcome == RequirementsReviewOutcome::ConditionallyApproved {\n   489→            review_payload.follow_ups.clone()\n   490→        } else {\n   491→            Vec::new()\n   492→        };\n   493→\n   494→        let seed_prompt = format!(\n   495→            \"Generate a project seed from the following requirements:\\n\\n{}\\n\\nFollow-ups: {}\",\n   496→            draft_bundle.artifact,\n   497→            if follow_ups.is_empty() {\n   498→                \"none\".to_owned()\n   499→            } else {\n   500→                follow_ups.join(\"; \")\n   501→            }\n   502→        );\n   503→\n   504→        let seed_result = self\n   505→            .invoke_stage(\n   506→                &run_root,\n   507→                RequirementsStageId::ProjectSeed,\n   508→                BackendRole::Planner,\n   509→                &seed_prompt,\n   510→            )\n   511→            .await;\n   512→\n   513→        let seed_bundle = match seed_result {\n   514→            Ok(b) => b,\n   515→            Err(e) => {\n   516→                self.fail_run(base_dir, run, seq, &format!(\"seed generation: {e}\"))\n   517→                    .await?;\n   518→                return Err(e);\n   519→            }\n   520→        };\n   521→\n   522→        let RequirementsPayload::Seed(ref seed_payload) = seed_bundle.payload else {\n   523→            unreachable!();\n   524→        };\n   525→\n   526→        let seed_payload_id = format!(\"{run_id}-seed-1\");\n   527→        let seed_artifact_id = format!(\"{run_id}-seed-art-1\");\n   528→        let seed_json = serde_json::to_value(seed_payload)?;\n   529→\n   530→        if let Err(e) = self.persist_payload_artifact_pair(\n   531→            base_dir,\n   532→            &run_id,\n   533→            &seed_payload_id,\n   534→            &seed_json,\n   535→            &seed_artifact_id,\n   536→            &seed_bundle.artifact,\n   537→        ) {\n   538→            self.fail_run(base_dir, run, seq, &format!(\"seed persistence: {e}\"))\n   539→                .await?;\n   540→            return Err(e);\n   541→        }\n   542→\n   543→        // Write seed files atomically\n   544→        let project_json = serde_json::to_value(seed_payload)?;\n   545→        if let Err(e) = self\n   546→            .store\n   547→            .write_seed_pair(base_dir, &run_id, &project_json, &seed_payload.prompt_body)\n   548→        {\n   549→            // Rollback: remove both seed outputs, keep draft/review\n   550→            let _ = self.store.remove_seed_pair(base_dir, &run_id);\n   551→            self.fail_run(base_dir, run, seq, &format!(\"seed file write: {e}\"))\n   552→                .await?;\n   553→            return Err(AppError::SeedPersistenceFailed {\n   554→                run_id: run_id.clone(),\n   555→                details: e.to_string(),\n   556→            });\n   557→        }\n   558→\n   559→        run.latest_seed_id = Some(seed_payload_id.clone());\n   560→        run.status = RequirementsStatus::Completed;\n   561→        run.status_summary = \"completed\".to_owned();\n   562→        run.updated_at = Utc::now();\n   563→        self.store.write_run(base_dir, &run_id, run)?;\n   564→\n   565→        let event = journal_event(\n   566→            seq,\n   567→            Utc::now(),\n   568→            RequirementsJournalEventType::SeedGenerated,\n   569→            run,\n   570→        );\n   571→        self.store\n   572→            .append_journal_event(base_dir, &run_id, &event)?;\n   573→        seq += 1;\n   574→\n   575→        let event = journal_event(\n   576→            seq,\n   577→            Utc::now(),\n   578→            RequirementsJournalEventType::RunCompleted,\n   579→            run,\n   580→        );\n   581→        self.store\n   582→            .append_journal_event(base_dir, &run_id, &event)?;\n   583→\n   584→        let seed_path = self.store.seed_prompt_path(base_dir, &run_id);\n   585→        println!(\"Requirements completed. Seed files at:\");\n   586→        println!(\"  {}\", seed_path.display());\n   587→        println!(\n   588→            \"\\nCreate project:\\n  ralph-burning project create --id {} --name \\\"{}\\\" --flow {} --prompt {}\",\n   589→            seed_payload.project_id,\n   590→            seed_payload.project_name,\n   591→            seed_payload.flow,\n   592→            seed_path.display()\n   593→        );\n   594→\n   595→        Ok(())\n   596→    }\n   597→\n   598→    async fn invoke_stage(\n   599→        &self,\n   600→        run_root: &Path,\n   601→        stage_id: RequirementsStageId,\n   602→        role: BackendRole,\n   603→        prompt: &str,\n   604→    ) -> AppResult<RequirementsValidatedBundle> {\n   605→        let contract_label = format!(\"requirements:{}\", stage_id.as_str());\n   606→        let target = self.agent_service.resolver().resolve(role, None, None, None)?;\n   607→\n   608→        let request = InvocationRequest {\n   609→            invocation_id: format!(\n   610→                \"req-{}-{}\",\n   611→                stage_id.as_str(),\n   612→                Utc::now().format(\"%Y%m%d%H%M%S\")\n   613→            ),\n   614→            project_root: run_root.to_path_buf(),\n   615→            contract: InvocationContract::Requirements {\n   616→                label: contract_label,\n   617→            },\n   618→            role,\n   619→            resolved_target: target,\n   620→            payload: InvocationPayload {\n   621→                prompt: prompt.to_owned(),\n   622→                context: serde_json::Value::Null,\n   623→            },\n   624→            timeout: std::time::Duration::from_secs(300),\n   625→            cancellation_token: CancellationToken::new(),\n   626→            session_policy: SessionPolicy::NewSession,\n   627→            prior_session: None,\n   628→            attempt_number: 1,\n   629→        };\n   630→\n   631→        let envelope = self.agent_service.invoke(request).await?;\n   632→\n   633→        // Validate using requirements contract\n   634→        let contract = match stage_id {\n   635→            RequirementsStageId::QuestionSet => RequirementsContract::question_set(),\n   636→            RequirementsStageId::RequirementsDraft => RequirementsContract::draft(),\n   637→            RequirementsStageId::RequirementsReview => RequirementsContract::review(),\n   638→            RequirementsStageId::ProjectSeed => RequirementsContract::seed(),\n   639→        };\n   640→\n   641→        let bundle = contract\n   642→            .evaluate(&envelope.parsed_payload)\n   643→            .map_err(|e| AppError::InvalidRequirementsState {\n   644→                run_id: \"\".to_owned(),\n   645→                details: format!(\"contract validation failed for {}: {e}\", stage_id),\n   646→            })?;\n   647→\n   648→        Ok(bundle)\n   649→    }\n   650→\n   651→    fn persist_payload_artifact_pair(\n   652→        &self,\n   653→        base_dir: &Path,\n   654→        run_id: &str,\n   655→        payload_id: &str,\n   656→        payload: &Value,\n   657→        artifact_id: &str,\n   658→        artifact: &str,\n   659→    ) -> AppResult<()> {\n   660→        self.store\n   661→            .write_payload(base_dir, run_id, payload_id, payload)?;\n   662→        if let Err(e) = self\n   663→            .store\n   664→            .write_artifact(base_dir, run_id, artifact_id, artifact)\n   665→        {\n   666→            // Rollback: payload was written but artifact failed — this is a\n   667→            // partial failure. In practice the payload file should be cleaned up,\n   668→            // but for now we propagate the error.\n   669→            return Err(e);\n   670→        }\n   671→        Ok(())\n   672→    }\n   673→\n   674→    async fn fail_run(\n   675→        &self,\n   676→        base_dir: &Path,\n   677→        run: &mut RequirementsRun,\n   678→        seq: u64,\n   679→        message: &str,\n   680→    ) -> AppResult<()> {\n   681→        run.status = RequirementsStatus::Failed;\n   682→        run.status_summary = format!(\"failed: {message}\");\n   683→        run.updated_at = Utc::now();\n   684→        self.store.write_run(base_dir, &run.run_id, run)?;\n   685→\n   686→        let event = journal_event(\n   687→            seq,\n   688→            Utc::now(),\n   689→            RequirementsJournalEventType::RunFailed,\n   690→            run,\n   691→        );\n   692→        self.store\n   693→            .append_journal_event(base_dir, &run.run_id, &event)?;\n   694→        Ok(())\n   695→    }\n   696→\n   697→    fn next_sequence(&self, base_dir: &Path, run_id: &str) -> AppResult<u64> {\n   698→        let events = self.store.read_journal(base_dir, run_id)?;\n   699→        Ok(events.last().map_or(0, |e| e.sequence) + 1)\n   700→    }\n   701→}\n   702→\n   703→// ── Show result ─────────────────────────────────────────────────────────────\n   704→\n   705→/// Read model for `requirements show`.\n   706→#[derive(Debug)]\n   707→pub struct RequirementsShowResult {\n   708→    pub run: RequirementsRun,\n   709→    pub journal_event_count: u64,\n   710→    pub pending_question_count: Option<u32>,\n   711→    pub failure_summary: Option<String>,\n   712→    pub seed_prompt_path: Option<std::path::PathBuf>,\n   713→}\n   714→\n   715→// ── Helpers ─────────────────────────────────────────────────────────────────\n   716→\n   717→fn generate_run_id(now: DateTime<Utc>) -> String {\n   718→    format!(\"req-{}\", now.format(\"%Y%m%d-%H%M%S\"))\n   719→}\n   720→\n   721→fn requirements_run_root(base_dir: &Path, run_id: &str) -> std::path::PathBuf {\n   722→    base_dir\n   723→        .join(\".ralph-burning\")\n   724→        .join(\"requirements\")\n   725→        .join(run_id)\n   726→}\n   727→\n   728→fn journal_event(\n   729→    sequence: u64,\n   730→    timestamp: DateTime<Utc>,\n   731→    event_type: RequirementsJournalEventType,\n   732→    run: &RequirementsRun,\n   733→) -> RequirementsJournalEvent {\n   734→    RequirementsJournalEvent {\n   735→        sequence,\n   736→        timestamp,\n   737→        event_type,\n   738→        details: serde_json::json!({\n   739→            \"run_id\": run.run_id,\n   740→            \"status\": run.status,\n   741→            \"status_summary\": run.status_summary,\n   742→        }),\n   743→    }\n   744→}\n   745→\n   746→fn generate_answers_template(qs: &QuestionSetPayload) -> String {\n   747→    let mut out = String::new();\n   748→    out.push_str(\"# Answers for clarifying questions\\n\");\n   749→    out.push_str(\"# Fill in answers below each question.\\n\\n\");\n   750→\n   751→    for q in &qs.questions {\n   752→        let required = if q.required { \" (required)\" } else { \"\" };\n   753→        out.push_str(&format!(\"# {}{}\\n\", q.prompt, required));\n   754→        if !q.rationale.is_empty() {\n   755→            out.push_str(&format!(\"# Rationale: {}\\n\", q.rationale));\n   756→        }\n   757→        let default_value = q\n   758→            .suggested_default\n   759→            .as_deref()\n   760→            .unwrap_or(\"\");\n   761→        out.push_str(&format!(\"{} = \\\"{}\\\"\\n\\n\", q.id, default_value));\n   762→    }\n   763→\n   764→    out\n   765→}\n   766→\n   767→fn parse_and_validate_answers<Q: RequirementsStorePort>(\n   768→    answers_raw: &str,\n   769→    base_dir: &Path,\n   770→    run_id: &str,\n   771→    store: &Q,\n   772→) -> AppResult<PersistedAnswers> {\n   773→    // Parse TOML\n   774→    let table: toml::Table = toml::from_str(answers_raw).map_err(|e| {\n   775→        AppError::AnswerValidationFailed {\n   776→            run_id: run_id.to_owned(),\n   777→            details: format!(\"invalid TOML: {e}\"),\n   778→        }\n   779→    })?;\n   780→\n   781→    // Read the question set to get required question IDs\n   782→    let run = store.read_run(base_dir, run_id)?;\n   783→    let _qs_id = run.latest_question_set_id.as_ref().ok_or_else(|| {\n   784→        AppError::InvalidRequirementsState {\n   785→            run_id: run_id.to_owned(),\n   786→            details: \"no question set committed\".to_owned(),\n   787→        }\n   788→    })?;\n   789→\n   790→    // Build answers from TOML keys\n   791→    let mut answers = Vec::new();\n   792→    for (key, value) in &table {\n   793→        let answer_text = match value.as_str() {\n   794→            Some(s) => s.to_owned(),\n   795→            None => value.to_string(),\n   796→        };\n   797→        answers.push(AnswerEntry {\n   798→            question_id: key.clone(),\n   799→            answer: answer_text,\n   800→        });\n   801→    }\n   802→\n   803→    // Note: full validation against required question IDs would require\n   804→    // reading the question set payload. For now we validate non-empty answers.\n   805→    for entry in &answers {\n   806→        if entry.answer.trim().is_empty() {\n   807→            // We just skip empty answers; the required check would need the\n   808→            // question set payload to determine which are required.\n   809→        }\n   810→    }\n   811→\n   812→    Ok(PersistedAnswers { answers })\n   813→}\n   814→\n   815→fn build_draft_prompt(idea: &str, answers: &[(String, String)]) -> String {\n   816→    let mut prompt = format!(\"Draft requirements for the following idea:\\n\\n{idea}\\n\");\n   817→\n   818→    if !answers.is_empty() {\n   819→        prompt.push_str(\"\\nClarifying answers:\\n\");\n   820→        for (qid, answer) in answers {\n   821→            prompt.push_str(&format!(\"- {qid}: {answer}\\n\"));\n   822→        }\n   823→    }\n   824→\n   825→    prompt\n   826→}\n   827→"}]},"parent_tool_use_id":"toolu_01PaXyQz2ihAyjCvhHfcUYoy","session_id":"36dfa1de-6185-4dcd-ac73-de5f18bf85fd","uuid":"cacf98b7-bb70-4454-adf6-4b3e09aeb2d3"}
