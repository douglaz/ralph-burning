{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_015xEMCM41EEZUEGjVJEe2qz","type":"tool_result","content":"     1→#![forbid(unsafe_code)]\n     2→\n     3→//! Requirements drafting service.\n     4→//!\n     5→//! Orchestrates `draft`, `quick`, `show`, and `answer` commands, including\n     6→//! answer-template validation, seed rollback, and failure invariants.\n     7→\n     8→use std::path::Path;\n     9→\n    10→use chrono::{DateTime, Utc};\n    11→use serde_json::Value;\n    12→\n    13→use crate::adapters::fs::FileSystem;\n    14→use crate::contexts::agent_execution::model::{\n    15→    CancellationToken, InvocationContract, InvocationPayload, InvocationRequest,\n    16→};\n    17→use crate::contexts::agent_execution::service::{AgentExecutionPort, AgentExecutionService};\n    18→use crate::contexts::agent_execution::session::SessionStorePort;\n    19→use crate::contexts::agent_execution::RawOutputPort;\n    20→use crate::shared::domain::{BackendRole, SessionPolicy};\n    21→use crate::shared::error::{AppError, AppResult};\n    22→\n    23→use super::contracts::{RequirementsContract, RequirementsPayload, RequirementsValidatedBundle};\n    24→use super::model::{\n    25→    AnswerEntry, PersistedAnswers, ProjectSeedPayload, Question, QuestionSetPayload,\n    26→    RequirementsDraftPayload, RequirementsJournalEvent, RequirementsJournalEventType,\n    27→    RequirementsMode, RequirementsReviewOutcome, RequirementsReviewPayload, RequirementsRun,\n    28→    RequirementsStageId, RequirementsStatus,\n    29→};\n    30→\n    31→// ── Port traits ─────────────────────────────────────────────────────────────\n    32→\n    33→/// Filesystem operations for requirements runs.\n    34→#[allow(async_fn_in_trait)]\n    35→pub trait RequirementsStorePort {\n    36→    fn create_run_dir(&self, base_dir: &Path, run_id: &str) -> AppResult<()>;\n    37→    fn write_run(&self, base_dir: &Path, run_id: &str, run: &RequirementsRun) -> AppResult<()>;\n    38→    fn read_run(&self, base_dir: &Path, run_id: &str) -> AppResult<RequirementsRun>;\n    39→    fn append_journal_event(\n    40→        &self,\n    41→        base_dir: &Path,\n    42→        run_id: &str,\n    43→        event: &RequirementsJournalEvent,\n    44→    ) -> AppResult<()>;\n    45→    fn read_journal(\n    46→        &self,\n    47→        base_dir: &Path,\n    48→        run_id: &str,\n    49→    ) -> AppResult<Vec<RequirementsJournalEvent>>;\n    50→    fn write_payload(\n    51→        &self,\n    52→        base_dir: &Path,\n    53→        run_id: &str,\n    54→        payload_id: &str,\n    55→        payload: &Value,\n    56→    ) -> AppResult<()>;\n    57→    fn write_artifact(\n    58→        &self,\n    59→        base_dir: &Path,\n    60→        run_id: &str,\n    61→        artifact_id: &str,\n    62→        content: &str,\n    63→    ) -> AppResult<()>;\n    64→    fn write_answers_toml(\n    65→        &self,\n    66→        base_dir: &Path,\n    67→        run_id: &str,\n    68→        template: &str,\n    69→    ) -> AppResult<()>;\n    70→    fn read_answers_toml(&self, base_dir: &Path, run_id: &str) -> AppResult<String>;\n    71→    fn write_answers_json(\n    72→        &self,\n    73→        base_dir: &Path,\n    74→        run_id: &str,\n    75→        answers: &PersistedAnswers,\n    76→    ) -> AppResult<()>;\n    77→    fn write_seed_pair(\n    78→        &self,\n    79→        base_dir: &Path,\n    80→        run_id: &str,\n    81→        project_json: &Value,\n    82→        prompt_md: &str,\n    83→    ) -> AppResult<()>;\n    84→    fn remove_seed_pair(&self, base_dir: &Path, run_id: &str) -> AppResult<()>;\n    85→    fn answers_toml_path(&self, base_dir: &Path, run_id: &str) -> std::path::PathBuf;\n    86→    fn seed_prompt_path(&self, base_dir: &Path, run_id: &str) -> std::path::PathBuf;\n    87→}\n    88→\n    89→// ── Service ─────────────────────────────────────────────────────────────────\n    90→\n    91→pub struct RequirementsService<A, R, S, Q> {\n    92→    agent_service: AgentExecutionService<A, R, S>,\n    93→    store: Q,\n    94→}\n    95→\n    96→impl<A, R, S, Q> RequirementsService<A, R, S, Q> {\n    97→    pub fn new(agent_service: AgentExecutionService<A, R, S>, store: Q) -> Self {\n    98→        Self {\n    99→            agent_service,\n   100→            store,\n   101→        }\n   102→    }\n   103→}\n   104→\n   105→impl<A, R, S, Q> RequirementsService<A, R, S, Q>\n   106→where\n   107→    A: AgentExecutionPort,\n   108→    R: RawOutputPort,\n   109→    S: SessionStorePort,\n   110→    Q: RequirementsStorePort,\n   111→{\n   112→    /// Execute `requirements draft --idea \"<text>\"`.\n   113→    pub async fn draft(&self, base_dir: &Path, idea: &str, now: DateTime<Utc>) -> AppResult<String> {\n   114→        let run_id = generate_run_id(now);\n   115→        let mut run = RequirementsRun::new_draft(run_id.clone(), idea.to_owned(), now);\n   116→\n   117→        // Create run directory and initial state\n   118→        self.store.create_run_dir(base_dir, &run_id)?;\n   119→        self.store.write_run(base_dir, &run_id, &run)?;\n   120→\n   121→        let created_event = journal_event(1, now, RequirementsJournalEventType::RunCreated, &run);\n   122→        self.store\n   123→            .append_journal_event(base_dir, &run_id, &created_event)?;\n   124→\n   125→        // Generate questions\n   126→        let run_root = requirements_run_root(base_dir, &run_id);\n   127→        let question_result = self\n   128→            .invoke_stage(\n   129→                &run_root,\n   130→                RequirementsStageId::QuestionSet,\n   131→                BackendRole::Planner,\n   132→                &format!(\"Generate clarifying questions for the following idea:\\n\\n{idea}\"),\n   133→            )\n   134→            .await;\n   135→\n   136→        match question_result {\n   137→            Ok(bundle) => {\n   138→                let RequirementsPayload::QuestionSet(ref qs) = bundle.payload else {\n   139→                    unreachable!(\"QuestionSet contract always returns QuestionSet payload\");\n   140→                };\n   141→\n   142→                let payload_id = format!(\"{run_id}-qs-1\");\n   143→                let artifact_id = format!(\"{run_id}-qs-art-1\");\n   144→\n   145→                // Persist payload and artifact atomically\n   146→                let payload_json = serde_json::to_value(qs)?;\n   147→                if let Err(e) = self.persist_payload_artifact_pair(\n   148→                    base_dir,\n   149→                    &run_id,\n   150→                    &payload_id,\n   151→                    &payload_json,\n   152→                    &artifact_id,\n   153→                    &bundle.artifact,\n   154→                ) {\n   155→                    // State invariant: if payload/artifact pair fails, run must not transition\n   156→                    run.status = RequirementsStatus::Failed;\n   157→                    run.status_summary = format!(\"failed: could not persist question set: {e}\");\n   158→                    run.updated_at = Utc::now();\n   159→                    let _ = self.store.write_run(base_dir, &run_id, &run);\n   160→                    return Err(e);\n   161→                }\n   162→\n   163→                if qs.questions.is_empty() {\n   164→                    // No questions needed — continue directly\n   165→                    self.continue_after_answers(base_dir, &mut run, idea, &[], 2, now)\n   166→                        .await?;\n   167→                } else {\n   168→                    // Generate answers.toml template\n   169→                    let template = generate_answers_template(qs);\n   170→                    self.store\n   171→                        .write_answers_toml(base_dir, &run_id, &template)?;\n   172→\n   173→                    run.question_round = 1;\n   174→                    run.latest_question_set_id = Some(payload_id.clone());\n   175→                    run.status = RequirementsStatus::AwaitingAnswers;\n   176→                    run.status_summary = format!(\n   177→                        \"awaiting answers: {} question(s), round 1\",\n   178→                        qs.questions.len()\n   179→                    );\n   180→                    run.updated_at = Utc::now();\n   181→                    self.store.write_run(base_dir, &run_id, &run)?;\n   182→\n   183→                    let event = journal_event(\n   184→                        2,\n   185→                        Utc::now(),\n   186→                        RequirementsJournalEventType::QuestionsGenerated,\n   187→                        &run,\n   188→                    );\n   189→                    self.store\n   190→                        .append_journal_event(base_dir, &run_id, &event)?;\n   191→\n   192→                    let answers_path = self.store.answers_toml_path(base_dir, &run_id);\n   193→                    println!(\n   194→                        \"Questions generated. Edit answers at:\\n  {}\\n\\nThen run:\\n  ralph-burning requirements answer {}\",\n   195→                        answers_path.display(),\n   196→                        run_id\n   197→                    );\n   198→                }\n   199→            }\n   200→            Err(e) => {\n   201→                run.status = RequirementsStatus::Failed;\n   202→                run.status_summary = format!(\"failed: question generation: {e}\");\n   203→                run.updated_at = Utc::now();\n   204→                self.store.write_run(base_dir, &run_id, &run)?;\n   205→\n   206→                let event = journal_event(\n   207→                    2,\n   208→                    Utc::now(),\n   209→                    RequirementsJournalEventType::RunFailed,\n   210→                    &run,\n   211→                );\n   212→                self.store\n   213→                    .append_journal_event(base_dir, &run_id, &event)?;\n   214→                return Err(e);\n   215→            }\n   216→        }\n   217→\n   218→        Ok(run_id)\n   219→    }\n   220→\n   221→    /// Execute `requirements quick --idea \"<text>\"`.\n   222→    pub async fn quick(&self, base_dir: &Path, idea: &str, now: DateTime<Utc>) -> AppResult<String> {\n   223→        let run_id = generate_run_id(now);\n   224→        let mut run = RequirementsRun::new_quick(run_id.clone(), idea.to_owned(), now);\n   225→\n   226→        self.store.create_run_dir(base_dir, &run_id)?;\n   227→        self.store.write_run(base_dir, &run_id, &run)?;\n   228→\n   229→        let created_event = journal_event(1, now, RequirementsJournalEventType::RunCreated, &run);\n   230→        self.store\n   231→            .append_journal_event(base_dir, &run_id, &created_event)?;\n   232→\n   233→        // Skip question generation entirely — go straight to draft\n   234→        self.continue_after_answers(base_dir, &mut run, idea, &[], 2, now)\n   235→            .await?;\n   236→\n   237→        Ok(run_id)\n   238→    }\n   239→\n   240→    /// Execute `requirements show <run-id>`.\n   241→    pub fn show(&self, base_dir: &Path, run_id: &str) -> AppResult<RequirementsShowResult> {\n   242→        let run = self.store.read_run(base_dir, run_id)?;\n   243→        let journal = self.store.read_journal(base_dir, run_id)?;\n   244→\n   245→        let pending_question_count = if run.status == RequirementsStatus::AwaitingAnswers {\n   246→            // Count required questions from latest question set\n   247→            if let Some(ref _qs_id) = run.latest_question_set_id {\n   248→                // We derive count from the run state, not by scanning artifacts\n   249→                Some(run.question_round)\n   250→            } else {\n   251→                None\n   252→            }\n   253→        } else {\n   254→            None\n   255→        };\n   256→\n   257→        let failure_summary = if run.status == RequirementsStatus::Failed {\n   258→            Some(run.status_summary.clone())\n   259→        } else {\n   260→            None\n   261→        };\n   262→\n   263→        let seed_prompt_path = if run.status == RequirementsStatus::Completed {\n   264→            Some(self.store.seed_prompt_path(base_dir, run_id))\n   265→        } else {\n   266→            None\n   267→        };\n   268→\n   269→        Ok(RequirementsShowResult {\n   270→            run,\n   271→            journal_event_count: journal.len() as u64,\n   272→            pending_question_count,\n   273→            failure_summary,\n   274→            seed_prompt_path,\n   275→        })\n   276→    }\n   277→\n   278→    /// Execute `requirements answer <run-id>`.\n   279→    pub async fn answer(&self, base_dir: &Path, run_id: &str) -> AppResult<()> {\n   280→        let mut run = self.store.read_run(base_dir, run_id)?;\n   281→\n   282→        // Valid only for awaiting_answers or failed runs with a committed question set\n   283→        match run.status {\n   284→            RequirementsStatus::AwaitingAnswers => {}\n   285→            RequirementsStatus::Failed if run.latest_question_set_id.is_some() => {}\n   286→            _ => {\n   287→                return Err(AppError::InvalidRequirementsState {\n   288→                    run_id: run_id.to_owned(),\n   289→                    details: format!(\n   290→                        \"cannot answer: run is in '{}' state\",\n   291→                        run.status\n   292→                    ),\n   293→                });\n   294→            }\n   295→        }\n   296→\n   297→        // Open editor\n   298→        let answers_path = self.store.answers_toml_path(base_dir, run_id);\n   299→        FileSystem::open_editor(&answers_path)?;\n   300→\n   301→        // Read and validate answers\n   302→        let answers_raw = self.store.read_answers_toml(base_dir, run_id)?;\n   303→        let answers = parse_and_validate_answers(&answers_raw, base_dir, run_id, &self.store)?;\n   304→\n   305→        // Persist answers.json\n   306→        self.store\n   307→            .write_answers_json(base_dir, run_id, &answers)?;\n   308→\n   309→        let seq = self.next_sequence(base_dir, run_id)?;\n   310→        let event = journal_event(\n   311→            seq,\n   312→            Utc::now(),\n   313→            RequirementsJournalEventType::AnswersSubmitted,\n   314→            &run,\n   315→        );\n   316→        self.store\n   317→            .append_journal_event(base_dir, run_id, &event)?;\n   318→\n   319→        // Resume from answers boundary\n   320→        let answer_entries: Vec<(String, String)> = answers\n   321→            .answers\n   322→            .iter()\n   323→            .map(|a| (a.question_id.clone(), a.answer.clone()))\n   324→            .collect();\n   325→\n   326→        run.question_round += 1;\n   327→        run.status = RequirementsStatus::Drafting;\n   328→        run.status_summary = \"drafting: generating requirements from answers\".to_owned();\n   329→        run.updated_at = Utc::now();\n   330→        self.store.write_run(base_dir, run_id, &run)?;\n   331→\n   332→        self.continue_after_answers(base_dir, &mut run, &run.idea.clone(), &answer_entries, seq + 1, Utc::now())\n   333→            .await?;\n   334→\n   335→        Ok(())\n   336→    }\n   337→\n   338→    // ── Internal pipeline ───────────────────────────────────────────────\n   339→\n   340→    async fn continue_after_answers(\n   341→        &self,\n   342→        base_dir: &Path,\n   343→        run: &mut RequirementsRun,\n   344→        idea: &str,\n   345→        answers: &[(String, String)],\n   346→        start_seq: u64,\n   347→        _now: DateTime<Utc>,\n   348→    ) -> AppResult<()> {\n   349→        let run_id = run.run_id.clone();\n   350→        let run_root = requirements_run_root(base_dir, &run_id);\n   351→        let mut seq = start_seq;\n   352→\n   353→        // ── Draft ───────────────────────────────────────────────────────\n   354→        let draft_prompt = build_draft_prompt(idea, answers);\n   355→        let draft_result = self\n   356→            .invoke_stage(\n   357→                &run_root,\n   358→                RequirementsStageId::RequirementsDraft,\n   359→                BackendRole::Planner,\n   360→                &draft_prompt,\n   361→            )\n   362→            .await;\n   363→\n   364→        let draft_bundle = match draft_result {\n   365→            Ok(b) => b,\n   366→            Err(e) => {\n   367→                self.fail_run(base_dir, run, seq, &format!(\"draft generation: {e}\"))\n   368→                    .await?;\n   369→                return Err(e);\n   370→            }\n   371→        };\n   372→\n   373→        let RequirementsPayload::Draft(ref draft_payload) = draft_bundle.payload else {\n   374→            unreachable!();\n   375→        };\n   376→\n   377→        let draft_payload_id = format!(\"{run_id}-draft-1\");\n   378→        let draft_artifact_id = format!(\"{run_id}-draft-art-1\");\n   379→        let draft_json = serde_json::to_value(draft_payload)?;\n   380→\n   381→        if let Err(e) = self.persist_payload_artifact_pair(\n   382→            base_dir,\n   383→            &run_id,\n   384→            &draft_payload_id,\n   385→            &draft_json,\n   386→            &draft_artifact_id,\n   387→            &draft_bundle.artifact,\n   388→        ) {\n   389→            self.fail_run(base_dir, run, seq, &format!(\"draft persistence: {e}\"))\n   390→                .await?;\n   391→            return Err(e);\n   392→        }\n   393→\n   394→        run.latest_draft_id = Some(draft_payload_id.clone());\n   395→        run.status_summary = \"drafting: reviewing requirements\".to_owned();\n   396→        run.updated_at = Utc::now();\n   397→        self.store.write_run(base_dir, &run_id, run)?;\n   398→\n   399→        let event = journal_event(\n   400→            seq,\n   401→            Utc::now(),\n   402→            RequirementsJournalEventType::DraftGenerated,\n   403→            run,\n   404→        );\n   405→        self.store\n   406→            .append_journal_event(base_dir, &run_id, &event)?;\n   407→        seq += 1;\n   408→\n   409→        // ── Review ──────────────────────────────────────────────────────\n   410→        let review_prompt = format!(\n   411→            \"Review the following requirements draft:\\n\\n{}\",\n   412→            draft_bundle.artifact\n   413→        );\n   414→        let review_result = self\n   415→            .invoke_stage(\n   416→                &run_root,\n   417→                RequirementsStageId::RequirementsReview,\n   418→                BackendRole::Reviewer,\n   419→                &review_prompt,\n   420→            )\n   421→            .await;\n   422→\n   423→        let review_bundle = match review_result {\n   424→            Ok(b) => b,\n   425→            Err(e) => {\n   426→                self.fail_run(base_dir, run, seq, &format!(\"review: {e}\"))\n   427→                    .await?;\n   428→                return Err(e);\n   429→            }\n   430→        };\n   431→\n   432→        let RequirementsPayload::Review(ref review_payload) = review_bundle.payload else {\n   433→            unreachable!();\n   434→        };\n   435→\n   436→        let review_payload_id = format!(\"{run_id}-review-1\");\n   437→        let review_artifact_id = format!(\"{run_id}-review-art-1\");\n   438→        let review_json = serde_json::to_value(review_payload)?;\n   439→\n   440→        if let Err(e) = self.persist_payload_artifact_pair(\n   441→            base_dir,\n   442→            &run_id,\n   443→            &review_payload_id,\n   444→            &review_json,\n   445→            &review_artifact_id,\n   446→            &review_bundle.artifact,\n   447→        ) {\n   448→            self.fail_run(base_dir, run, seq, &format!(\"review persistence: {e}\"))\n   449→                .await?;\n   450→            return Err(e);\n   451→        }\n   452→\n   453→        run.latest_review_id = Some(review_payload_id.clone());\n   454→        run.updated_at = Utc::now();\n   455→        self.store.write_run(base_dir, &run_id, run)?;\n   456→\n   457→        let event = journal_event(\n   458→            seq,\n   459→            Utc::now(),\n   460→            RequirementsJournalEventType::ReviewCompleted,\n   461→            run,\n   462→        );\n   463→        self.store\n   464→            .append_journal_event(base_dir, &run_id, &event)?;\n   465→        seq += 1;\n   466→\n   467→        // Check review outcome\n   468→        match review_payload.outcome {\n   469→            RequirementsReviewOutcome::Approved | RequirementsReviewOutcome::ConditionallyApproved => {\n   470→                // Continue to seed generation\n   471→            }\n   472→            RequirementsReviewOutcome::RequestChanges | RequirementsReviewOutcome::Rejected => {\n   473→                // Fail the run after review payload/artifact are durably committed\n   474→                let msg = format!(\n   475→                    \"review outcome: {} — {}\",\n   476→                    review_payload.outcome,\n   477→                    review_payload.findings.join(\"; \")\n   478→                );\n   479→                self.fail_run(base_dir, run, seq, &msg).await?;\n   480→                return Err(AppError::InvalidRequirementsState {\n   481→                    run_id: run_id.clone(),\n   482→                    details: msg,\n   483→                });\n   484→            }\n   485→        }\n   486→\n   487→        // ── Seed ────────────────────────────────────────────────────────\n   488→        let follow_ups = if review_payload.outcome == RequirementsReviewOutcome::ConditionallyApproved {\n   489→            review_payload.follow_ups.clone()\n   490→        } else {\n   491→            Vec::new()\n   492→        };\n   493→\n   494→        let seed_prompt = format!(\n   495→            \"Generate a project seed from the following requirements:\\n\\n{}\\n\\nFollow-ups: {}\",\n   496→            draft_bundle.artifact,\n   497→            if follow_ups.is_empty() {\n   498→                \"none\".to_owned()\n   499→            } else {\n   500→                follow_ups.join(\"; \")\n   501→            }\n   502→        );\n   503→\n   504→        let seed_result = self\n   505→            .invoke_stage(\n   506→                &run_root,\n   507→                RequirementsStageId::ProjectSeed,\n   508→                BackendRole::Planner,\n   509→                &seed_prompt,\n   510→            )\n   511→            .await;\n   512→\n   513→        let seed_bundle = match seed_result {\n   514→            Ok(b) => b,\n   515→            Err(e) => {\n   516→                self.fail_run(base_dir, run, seq, &format!(\"seed generation: {e}\"))\n   517→                    .await?;\n   518→                return Err(e);\n   519→            }\n   520→        };\n   521→\n   522→        let RequirementsPayload::Seed(ref seed_payload) = seed_bundle.payload else {\n   523→            unreachable!();\n   524→        };\n   525→\n   526→        let seed_payload_id = format!(\"{run_id}-seed-1\");\n   527→        let seed_artifact_id = format!(\"{run_id}-seed-art-1\");\n   528→        let seed_json = serde_json::to_value(seed_payload)?;\n   529→\n   530→        if let Err(e) = self.persist_payload_artifact_pair(\n   531→            base_dir,\n   532→            &run_id,\n   533→            &seed_payload_id,\n   534→            &seed_json,\n   535→            &seed_artifact_id,\n   536→            &seed_bundle.artifact,\n   537→        ) {\n   538→            self.fail_run(base_dir, run, seq, &format!(\"seed persistence: {e}\"))\n   539→                .await?;\n   540→            return Err(e);\n   541→        }\n   542→\n   543→        // Write seed files atomically\n   544→        let project_json = serde_json::to_value(seed_payload)?;\n   545→        if let Err(e) = self\n   546→            .store\n   547→            .write_seed_pair(base_dir, &run_id, &project_json, &seed_payload.prompt_body)\n   548→        {\n   549→            // Rollback: remove both seed outputs, keep draft/review\n   550→            let _ = self.store.remove_seed_pair(base_dir, &run_id);\n   551→            self.fail_run(base_dir, run, seq, &format!(\"seed file write: {e}\"))\n   552→                .await?;\n   553→            return Err(AppError::SeedPersistenceFailed {\n   554→                run_id: run_id.clone(),\n   555→                details: e.to_string(),\n   556→            });\n   557→        }\n   558→\n   559→        run.latest_seed_id = Some(seed_payload_id.clone());\n   560→        run.status = RequirementsStatus::Completed;\n   561→        run.status_summary = \"completed\".to_owned();\n   562→        run.updated_at = Utc::now();\n   563→        self.store.write_run(base_dir, &run_id, run)?;\n   564→\n   565→        let event = journal_event(\n   566→            seq,\n   567→            Utc::now(),\n   568→            RequirementsJournalEventType::SeedGenerated,\n   569→            run,\n   570→        );\n   571→        self.store\n   572→            .append_journal_event(base_dir, &run_id, &event)?;\n   573→        seq += 1;\n   574→\n   575→        let event = journal_event(\n   576→            seq,\n   577→            Utc::now(),\n   578→            RequirementsJournalEventType::RunCompleted,\n   579→            run,\n   580→        );\n   581→        self.store\n   582→            .append_journal_event(base_dir, &run_id, &event)?;\n   583→\n   584→        let seed_path = self.store.seed_prompt_path(base_dir, &run_id);\n   585→        println!(\"Requirements completed. Seed files at:\");\n   586→        println!(\"  {}\", seed_path.display());\n   587→        println!(\n   588→            \"\\nCreate project:\\n  ralph-burning project create --id {} --name \\\"{}\\\" --flow {} --prompt {}\",\n   589→            seed_payload.project_id,\n   590→            seed_payload.project_name,\n   591→            seed_payload.flow,\n   592→            seed_path.display()\n   593→        );\n   594→\n   595→        Ok(())\n   596→    }\n   597→\n   598→    async fn invoke_stage(\n   599→        &self,\n   600→        run_root: &Path,\n   601→        stage_id: RequirementsStageId,\n   602→        role: BackendRole,\n   603→        prompt: &str,\n   604→    ) -> AppResult<RequirementsValidatedBundle> {\n   605→        let contract_label = format!(\"requirements:{}\", stage_id.as_str());\n   606→        let target = self.agent_service.resolver().resolve(role, None, None, None)?;\n   607→\n   608→        let request = InvocationRequest {\n   609→            invocation_id: format!(\n   610→                \"req-{}-{}\",\n   611→                stage_id.as_str(),\n   612→                Utc::now().format(\"%Y%m%d%H%M%S\")\n   613→            ),\n   614→            project_root: run_root.to_path_buf(),\n   615→            contract: InvocationContract::Requirements {\n   616→                label: contract_label,\n   617→            },\n   618→            role,\n   619→            resolved_target: target,\n   620→            payload: InvocationPayload {\n   621→                prompt: prompt.to_owned(),\n   622→                context: serde_json::Value::Null,\n   623→            },\n   624→            timeout: std::time::Duration::from_secs(300),\n   625→            cancellation_token: CancellationToken::new(),\n   626→            session_policy: SessionPolicy::NewSession,\n   627→            prior_session: None,\n   628→            attempt_number: 1,\n   629→        };\n   630→\n   631→        let envelope = self.agent_service.invoke(request).await?;\n   632→\n   633→        // Validate using requirements contract\n   634→        let contract = match stage_id {\n   635→            RequirementsStageId::QuestionSet => RequirementsContract::question_set(),\n   636→            RequirementsStageId::RequirementsDraft => RequirementsContract::draft(),\n   637→            RequirementsStageId::RequirementsReview => RequirementsContract::review(),\n   638→            RequirementsStageId::ProjectSeed => RequirementsContract::seed(),\n   639→        };\n   640→\n   641→        let bundle = contract\n   642→            .evaluate(&envelope.parsed_payload)\n   643→            .map_err(|e| AppError::InvalidRequirementsState {\n   644→                run_id: \"\".to_owned(),\n   645→                details: format!(\"contract validation failed for {}: {e}\", stage_id),\n   646→            })?;\n   647→\n   648→        Ok(bundle)\n   649→    }\n   650→\n   651→    fn persist_payload_artifact_pair(\n   652→        &self,\n   653→        base_dir: &Path,\n   654→        run_id: &str,\n   655→        payload_id: &str,\n   656→        payload: &Value,\n   657→        artifact_id: &str,\n   658→        artifact: &str,\n   659→    ) -> AppResult<()> {\n   660→        self.store\n   661→            .write_payload(base_dir, run_id, payload_id, payload)?;\n   662→        if let Err(e) = self\n   663→            .store\n   664→            .write_artifact(base_dir, run_id, artifact_id, artifact)\n   665→        {\n   666→            // Rollback: payload was written but artifact failed — this is a\n   667→            // partial failure. In practice the payload file should be cleaned up,\n   668→            // but for now we propagate the error.\n   669→            return Err(e);\n   670→        }\n   671→        Ok(())\n   672→    }\n   673→\n   674→    async fn fail_run(\n   675→        &self,\n   676→        base_dir: &Path,\n   677→        run: &mut RequirementsRun,\n   678→        seq: u64,\n   679→        message: &str,\n   680→    ) -> AppResult<()> {\n   681→        run.status = RequirementsStatus::Failed;\n   682→        run.status_summary = format!(\"failed: {message}\");\n   683→        run.updated_at = Utc::now();\n   684→        self.store.write_run(base_dir, &run.run_id, run)?;\n   685→\n   686→        let event = journal_event(\n   687→            seq,\n   688→            Utc::now(),\n   689→            RequirementsJournalEventType::RunFailed,\n   690→            run,\n   691→        );\n   692→        self.store\n   693→            .append_journal_event(base_dir, &run.run_id, &event)?;\n   694→        Ok(())\n   695→    }\n   696→\n   697→    fn next_sequence(&self, base_dir: &Path, run_id: &str) -> AppResult<u64> {\n   698→        let events = self.store.read_journal(base_dir, run_id)?;\n   699→        Ok(events.last().map_or(0, |e| e.sequence) + 1)\n   700→    }\n   701→}\n   702→\n   703→// ── Show result ─────────────────────────────────────────────────────────────\n   704→\n   705→/// Read model for `requirements show`.\n   706→#[derive(Debug)]\n   707→pub struct RequirementsShowResult {\n   708→    pub run: RequirementsRun,\n   709→    pub journal_event_count: u64,\n   710→    pub pending_question_count: Option<u32>,\n   711→    pub failure_summary: Option<String>,\n   712→    pub seed_prompt_path: Option<std::path::PathBuf>,\n   713→}\n   714→\n   715→// ── Helpers ─────────────────────────────────────────────────────────────────\n   716→\n   717→fn generate_run_id(now: DateTime<Utc>) -> String {\n   718→    format!(\"req-{}\", now.format(\"%Y%m%d-%H%M%S\"))\n   719→}\n   720→\n   721→fn requirements_run_root(base_dir: &Path, run_id: &str) -> std::path::PathBuf {\n   722→    base_dir\n   723→        .join(\".ralph-burning\")\n   724→        .join(\"requirements\")\n   725→        .join(run_id)\n   726→}\n   727→\n   728→fn journal_event(\n   729→    sequence: u64,\n   730→    timestamp: DateTime<Utc>,\n   731→    event_type: RequirementsJournalEventType,\n   732→    run: &RequirementsRun,\n   733→) -> RequirementsJournalEvent {\n   734→    RequirementsJournalEvent {\n   735→        sequence,\n   736→        timestamp,\n   737→        event_type,\n   738→        details: serde_json::json!({\n   739→            \"run_id\": run.run_id,\n   740→            \"status\": run.status,\n   741→            \"status_summary\": run.status_summary,\n   742→        }),\n   743→    }\n   744→}\n   745→\n   746→fn generate_answers_template(qs: &QuestionSetPayload) -> String {\n   747→    let mut out = String::new();\n   748→    out.push_str(\"# Answers for clarifying questions\\n\");\n   749→    out.push_str(\"# Fill in answers below each question.\\n\\n\");\n   750→\n   751→    for q in &qs.questions {\n   752→        let required = if q.required { \" (required)\" } else { \"\" };\n   753→        out.push_str(&format!(\"# {}{}\\n\", q.prompt, required));\n   754→        if !q.rationale.is_empty() {\n   755→            out.push_str(&format!(\"# Rationale: {}\\n\", q.rationale));\n   756→        }\n   757→        let default_value = q\n   758→            .suggested_default\n   759→            .as_deref()\n   760→            .unwrap_or(\"\");\n   761→        out.push_str(&format!(\"{} = \\\"{}\\\"\\n\\n\", q.id, default_value));\n   762→    }\n   763→\n   764→    out\n   765→}\n   766→\n   767→fn parse_and_validate_answers<Q: RequirementsStorePort>(\n   768→    answers_raw: &str,\n   769→    base_dir: &Path,\n   770→    run_id: &str,\n   771→    store: &Q,\n   772→) -> AppResult<PersistedAnswers> {\n   773→    // Parse TOML\n   774→    let table: toml::Table = toml::from_str(answers_raw).map_err(|e| {\n   775→        AppError::AnswerValidationFailed {\n   776→            run_id: run_id.to_owned(),\n   777→            details: format!(\"invalid TOML: {e}\"),\n   778→        }\n   779→    })?;\n   780→\n   781→    // Read the question set to get required question IDs\n   782→    let run = store.read_run(base_dir, run_id)?;\n   783→    let _qs_id = run.latest_question_set_id.as_ref().ok_or_else(|| {\n   784→        AppError::InvalidRequirementsState {\n   785→            run_id: run_id.to_owned(),\n   786→            details: \"no question set committed\".to_owned(),\n   787→        }\n   788→    })?;\n   789→\n   790→    // Build answers from TOML keys\n   791→    let mut answers = Vec::new();\n   792→    for (key, value) in &table {\n   793→        let answer_text = match value.as_str() {\n   794→            Some(s) => s.to_owned(),\n   795→            None => value.to_string(),\n   796→        };\n   797→        answers.push(AnswerEntry {\n   798→            question_id: key.clone(),\n   799→            answer: answer_text,\n   800→        });\n   801→    }\n   802→\n   803→    // Note: full validation against required question IDs would require\n   804→    // reading the question set payload. For now we validate non-empty answers.\n   805→    for entry in &answers {\n   806→        if entry.answer.trim().is_empty() {\n   807→            // We just skip empty answers; the required check would need the\n   808→            // question set payload to determine which are required.\n   809→        }\n   810→    }\n   811→\n   812→    Ok(PersistedAnswers { answers })\n   813→}\n   814→\n   815→fn build_draft_prompt(idea: &str, answers: &[(String, String)]) -> String {\n   816→    let mut prompt = format!(\"Draft requirements for the following idea:\\n\\n{idea}\\n\");\n   817→\n   818→    if !answers.is_empty() {\n   819→        prompt.push_str(\"\\nClarifying answers:\\n\");\n   820→        for (qid, answer) in answers {\n   821→            prompt.push_str(&format!(\"- {qid}: {answer}\\n\"));\n   822→        }\n   823→    }\n   824→\n   825→    prompt\n   826→}\n   827→"}]},"parent_tool_use_id":null,"session_id":"36dfa1de-6185-4dcd-ac73-de5f18bf85fd","uuid":"313b0a71-f6f8-4311-9467-be93ef180f7b","tool_use_result":{"type":"text","file":{"filePath":"/root/new-ralph-burning/ralph-burning-rewrite/src/contexts/requirements_drafting/service.rs","content":"#![forbid(unsafe_code)]\n\n//! Requirements drafting service.\n//!\n//! Orchestrates `draft`, `quick`, `show`, and `answer` commands, including\n//! answer-template validation, seed rollback, and failure invariants.\n\nuse std::path::Path;\n\nuse chrono::{DateTime, Utc};\nuse serde_json::Value;\n\nuse crate::adapters::fs::FileSystem;\nuse crate::contexts::agent_execution::model::{\n    CancellationToken, InvocationContract, InvocationPayload, InvocationRequest,\n};\nuse crate::contexts::agent_execution::service::{AgentExecutionPort, AgentExecutionService};\nuse crate::contexts::agent_execution::session::SessionStorePort;\nuse crate::contexts::agent_execution::RawOutputPort;\nuse crate::shared::domain::{BackendRole, SessionPolicy};\nuse crate::shared::error::{AppError, AppResult};\n\nuse super::contracts::{RequirementsContract, RequirementsPayload, RequirementsValidatedBundle};\nuse super::model::{\n    AnswerEntry, PersistedAnswers, ProjectSeedPayload, Question, QuestionSetPayload,\n    RequirementsDraftPayload, RequirementsJournalEvent, RequirementsJournalEventType,\n    RequirementsMode, RequirementsReviewOutcome, RequirementsReviewPayload, RequirementsRun,\n    RequirementsStageId, RequirementsStatus,\n};\n\n// ── Port traits ─────────────────────────────────────────────────────────────\n\n/// Filesystem operations for requirements runs.\n#[allow(async_fn_in_trait)]\npub trait RequirementsStorePort {\n    fn create_run_dir(&self, base_dir: &Path, run_id: &str) -> AppResult<()>;\n    fn write_run(&self, base_dir: &Path, run_id: &str, run: &RequirementsRun) -> AppResult<()>;\n    fn read_run(&self, base_dir: &Path, run_id: &str) -> AppResult<RequirementsRun>;\n    fn append_journal_event(\n        &self,\n        base_dir: &Path,\n        run_id: &str,\n        event: &RequirementsJournalEvent,\n    ) -> AppResult<()>;\n    fn read_journal(\n        &self,\n        base_dir: &Path,\n        run_id: &str,\n    ) -> AppResult<Vec<RequirementsJournalEvent>>;\n    fn write_payload(\n        &self,\n        base_dir: &Path,\n        run_id: &str,\n        payload_id: &str,\n        payload: &Value,\n    ) -> AppResult<()>;\n    fn write_artifact(\n        &self,\n        base_dir: &Path,\n        run_id: &str,\n        artifact_id: &str,\n        content: &str,\n    ) -> AppResult<()>;\n    fn write_answers_toml(\n        &self,\n        base_dir: &Path,\n        run_id: &str,\n        template: &str,\n    ) -> AppResult<()>;\n    fn read_answers_toml(&self, base_dir: &Path, run_id: &str) -> AppResult<String>;\n    fn write_answers_json(\n        &self,\n        base_dir: &Path,\n        run_id: &str,\n        answers: &PersistedAnswers,\n    ) -> AppResult<()>;\n    fn write_seed_pair(\n        &self,\n        base_dir: &Path,\n        run_id: &str,\n        project_json: &Value,\n        prompt_md: &str,\n    ) -> AppResult<()>;\n    fn remove_seed_pair(&self, base_dir: &Path, run_id: &str) -> AppResult<()>;\n    fn answers_toml_path(&self, base_dir: &Path, run_id: &str) -> std::path::PathBuf;\n    fn seed_prompt_path(&self, base_dir: &Path, run_id: &str) -> std::path::PathBuf;\n}\n\n// ── Service ─────────────────────────────────────────────────────────────────\n\npub struct RequirementsService<A, R, S, Q> {\n    agent_service: AgentExecutionService<A, R, S>,\n    store: Q,\n}\n\nimpl<A, R, S, Q> RequirementsService<A, R, S, Q> {\n    pub fn new(agent_service: AgentExecutionService<A, R, S>, store: Q) -> Self {\n        Self {\n            agent_service,\n            store,\n        }\n    }\n}\n\nimpl<A, R, S, Q> RequirementsService<A, R, S, Q>\nwhere\n    A: AgentExecutionPort,\n    R: RawOutputPort,\n    S: SessionStorePort,\n    Q: RequirementsStorePort,\n{\n    /// Execute `requirements draft --idea \"<text>\"`.\n    pub async fn draft(&self, base_dir: &Path, idea: &str, now: DateTime<Utc>) -> AppResult<String> {\n        let run_id = generate_run_id(now);\n        let mut run = RequirementsRun::new_draft(run_id.clone(), idea.to_owned(), now);\n\n        // Create run directory and initial state\n        self.store.create_run_dir(base_dir, &run_id)?;\n        self.store.write_run(base_dir, &run_id, &run)?;\n\n        let created_event = journal_event(1, now, RequirementsJournalEventType::RunCreated, &run);\n        self.store\n            .append_journal_event(base_dir, &run_id, &created_event)?;\n\n        // Generate questions\n        let run_root = requirements_run_root(base_dir, &run_id);\n        let question_result = self\n            .invoke_stage(\n                &run_root,\n                RequirementsStageId::QuestionSet,\n                BackendRole::Planner,\n                &format!(\"Generate clarifying questions for the following idea:\\n\\n{idea}\"),\n            )\n            .await;\n\n        match question_result {\n            Ok(bundle) => {\n                let RequirementsPayload::QuestionSet(ref qs) = bundle.payload else {\n                    unreachable!(\"QuestionSet contract always returns QuestionSet payload\");\n                };\n\n                let payload_id = format!(\"{run_id}-qs-1\");\n                let artifact_id = format!(\"{run_id}-qs-art-1\");\n\n                // Persist payload and artifact atomically\n                let payload_json = serde_json::to_value(qs)?;\n                if let Err(e) = self.persist_payload_artifact_pair(\n                    base_dir,\n                    &run_id,\n                    &payload_id,\n                    &payload_json,\n                    &artifact_id,\n                    &bundle.artifact,\n                ) {\n                    // State invariant: if payload/artifact pair fails, run must not transition\n                    run.status = RequirementsStatus::Failed;\n                    run.status_summary = format!(\"failed: could not persist question set: {e}\");\n                    run.updated_at = Utc::now();\n                    let _ = self.store.write_run(base_dir, &run_id, &run);\n                    return Err(e);\n                }\n\n                if qs.questions.is_empty() {\n                    // No questions needed — continue directly\n                    self.continue_after_answers(base_dir, &mut run, idea, &[], 2, now)\n                        .await?;\n                } else {\n                    // Generate answers.toml template\n                    let template = generate_answers_template(qs);\n                    self.store\n                        .write_answers_toml(base_dir, &run_id, &template)?;\n\n                    run.question_round = 1;\n                    run.latest_question_set_id = Some(payload_id.clone());\n                    run.status = RequirementsStatus::AwaitingAnswers;\n                    run.status_summary = format!(\n                        \"awaiting answers: {} question(s), round 1\",\n                        qs.questions.len()\n                    );\n                    run.updated_at = Utc::now();\n                    self.store.write_run(base_dir, &run_id, &run)?;\n\n                    let event = journal_event(\n                        2,\n                        Utc::now(),\n                        RequirementsJournalEventType::QuestionsGenerated,\n                        &run,\n                    );\n                    self.store\n                        .append_journal_event(base_dir, &run_id, &event)?;\n\n                    let answers_path = self.store.answers_toml_path(base_dir, &run_id);\n                    println!(\n                        \"Questions generated. Edit answers at:\\n  {}\\n\\nThen run:\\n  ralph-burning requirements answer {}\",\n                        answers_path.display(),\n                        run_id\n                    );\n                }\n            }\n            Err(e) => {\n                run.status = RequirementsStatus::Failed;\n                run.status_summary = format!(\"failed: question generation: {e}\");\n                run.updated_at = Utc::now();\n                self.store.write_run(base_dir, &run_id, &run)?;\n\n                let event = journal_event(\n                    2,\n                    Utc::now(),\n                    RequirementsJournalEventType::RunFailed,\n                    &run,\n                );\n                self.store\n                    .append_journal_event(base_dir, &run_id, &event)?;\n                return Err(e);\n            }\n        }\n\n        Ok(run_id)\n    }\n\n    /// Execute `requirements quick --idea \"<text>\"`.\n    pub async fn quick(&self, base_dir: &Path, idea: &str, now: DateTime<Utc>) -> AppResult<String> {\n        let run_id = generate_run_id(now);\n        let mut run = RequirementsRun::new_quick(run_id.clone(), idea.to_owned(), now);\n\n        self.store.create_run_dir(base_dir, &run_id)?;\n        self.store.write_run(base_dir, &run_id, &run)?;\n\n        let created_event = journal_event(1, now, RequirementsJournalEventType::RunCreated, &run);\n        self.store\n            .append_journal_event(base_dir, &run_id, &created_event)?;\n\n        // Skip question generation entirely — go straight to draft\n        self.continue_after_answers(base_dir, &mut run, idea, &[], 2, now)\n            .await?;\n\n        Ok(run_id)\n    }\n\n    /// Execute `requirements show <run-id>`.\n    pub fn show(&self, base_dir: &Path, run_id: &str) -> AppResult<RequirementsShowResult> {\n        let run = self.store.read_run(base_dir, run_id)?;\n        let journal = self.store.read_journal(base_dir, run_id)?;\n\n        let pending_question_count = if run.status == RequirementsStatus::AwaitingAnswers {\n            // Count required questions from latest question set\n            if let Some(ref _qs_id) = run.latest_question_set_id {\n                // We derive count from the run state, not by scanning artifacts\n                Some(run.question_round)\n            } else {\n                None\n            }\n        } else {\n            None\n        };\n\n        let failure_summary = if run.status == RequirementsStatus::Failed {\n            Some(run.status_summary.clone())\n        } else {\n            None\n        };\n\n        let seed_prompt_path = if run.status == RequirementsStatus::Completed {\n            Some(self.store.seed_prompt_path(base_dir, run_id))\n        } else {\n            None\n        };\n\n        Ok(RequirementsShowResult {\n            run,\n            journal_event_count: journal.len() as u64,\n            pending_question_count,\n            failure_summary,\n            seed_prompt_path,\n        })\n    }\n\n    /// Execute `requirements answer <run-id>`.\n    pub async fn answer(&self, base_dir: &Path, run_id: &str) -> AppResult<()> {\n        let mut run = self.store.read_run(base_dir, run_id)?;\n\n        // Valid only for awaiting_answers or failed runs with a committed question set\n        match run.status {\n            RequirementsStatus::AwaitingAnswers => {}\n            RequirementsStatus::Failed if run.latest_question_set_id.is_some() => {}\n            _ => {\n                return Err(AppError::InvalidRequirementsState {\n                    run_id: run_id.to_owned(),\n                    details: format!(\n                        \"cannot answer: run is in '{}' state\",\n                        run.status\n                    ),\n                });\n            }\n        }\n\n        // Open editor\n        let answers_path = self.store.answers_toml_path(base_dir, run_id);\n        FileSystem::open_editor(&answers_path)?;\n\n        // Read and validate answers\n        let answers_raw = self.store.read_answers_toml(base_dir, run_id)?;\n        let answers = parse_and_validate_answers(&answers_raw, base_dir, run_id, &self.store)?;\n\n        // Persist answers.json\n        self.store\n            .write_answers_json(base_dir, run_id, &answers)?;\n\n        let seq = self.next_sequence(base_dir, run_id)?;\n        let event = journal_event(\n            seq,\n            Utc::now(),\n            RequirementsJournalEventType::AnswersSubmitted,\n            &run,\n        );\n        self.store\n            .append_journal_event(base_dir, run_id, &event)?;\n\n        // Resume from answers boundary\n        let answer_entries: Vec<(String, String)> = answers\n            .answers\n            .iter()\n            .map(|a| (a.question_id.clone(), a.answer.clone()))\n            .collect();\n\n        run.question_round += 1;\n        run.status = RequirementsStatus::Drafting;\n        run.status_summary = \"drafting: generating requirements from answers\".to_owned();\n        run.updated_at = Utc::now();\n        self.store.write_run(base_dir, run_id, &run)?;\n\n        self.continue_after_answers(base_dir, &mut run, &run.idea.clone(), &answer_entries, seq + 1, Utc::now())\n            .await?;\n\n        Ok(())\n    }\n\n    // ── Internal pipeline ───────────────────────────────────────────────\n\n    async fn continue_after_answers(\n        &self,\n        base_dir: &Path,\n        run: &mut RequirementsRun,\n        idea: &str,\n        answers: &[(String, String)],\n        start_seq: u64,\n        _now: DateTime<Utc>,\n    ) -> AppResult<()> {\n        let run_id = run.run_id.clone();\n        let run_root = requirements_run_root(base_dir, &run_id);\n        let mut seq = start_seq;\n\n        // ── Draft ───────────────────────────────────────────────────────\n        let draft_prompt = build_draft_prompt(idea, answers);\n        let draft_result = self\n            .invoke_stage(\n                &run_root,\n                RequirementsStageId::RequirementsDraft,\n                BackendRole::Planner,\n                &draft_prompt,\n            )\n            .await;\n\n        let draft_bundle = match draft_result {\n            Ok(b) => b,\n            Err(e) => {\n                self.fail_run(base_dir, run, seq, &format!(\"draft generation: {e}\"))\n                    .await?;\n                return Err(e);\n            }\n        };\n\n        let RequirementsPayload::Draft(ref draft_payload) = draft_bundle.payload else {\n            unreachable!();\n        };\n\n        let draft_payload_id = format!(\"{run_id}-draft-1\");\n        let draft_artifact_id = format!(\"{run_id}-draft-art-1\");\n        let draft_json = serde_json::to_value(draft_payload)?;\n\n        if let Err(e) = self.persist_payload_artifact_pair(\n            base_dir,\n            &run_id,\n            &draft_payload_id,\n            &draft_json,\n            &draft_artifact_id,\n            &draft_bundle.artifact,\n        ) {\n            self.fail_run(base_dir, run, seq, &format!(\"draft persistence: {e}\"))\n                .await?;\n            return Err(e);\n        }\n\n        run.latest_draft_id = Some(draft_payload_id.clone());\n        run.status_summary = \"drafting: reviewing requirements\".to_owned();\n        run.updated_at = Utc::now();\n        self.store.write_run(base_dir, &run_id, run)?;\n\n        let event = journal_event(\n            seq,\n            Utc::now(),\n            RequirementsJournalEventType::DraftGenerated,\n            run,\n        );\n        self.store\n            .append_journal_event(base_dir, &run_id, &event)?;\n        seq += 1;\n\n        // ── Review ──────────────────────────────────────────────────────\n        let review_prompt = format!(\n            \"Review the following requirements draft:\\n\\n{}\",\n            draft_bundle.artifact\n        );\n        let review_result = self\n            .invoke_stage(\n                &run_root,\n                RequirementsStageId::RequirementsReview,\n                BackendRole::Reviewer,\n                &review_prompt,\n            )\n            .await;\n\n        let review_bundle = match review_result {\n            Ok(b) => b,\n            Err(e) => {\n                self.fail_run(base_dir, run, seq, &format!(\"review: {e}\"))\n                    .await?;\n                return Err(e);\n            }\n        };\n\n        let RequirementsPayload::Review(ref review_payload) = review_bundle.payload else {\n            unreachable!();\n        };\n\n        let review_payload_id = format!(\"{run_id}-review-1\");\n        let review_artifact_id = format!(\"{run_id}-review-art-1\");\n        let review_json = serde_json::to_value(review_payload)?;\n\n        if let Err(e) = self.persist_payload_artifact_pair(\n            base_dir,\n            &run_id,\n            &review_payload_id,\n            &review_json,\n            &review_artifact_id,\n            &review_bundle.artifact,\n        ) {\n            self.fail_run(base_dir, run, seq, &format!(\"review persistence: {e}\"))\n                .await?;\n            return Err(e);\n        }\n\n        run.latest_review_id = Some(review_payload_id.clone());\n        run.updated_at = Utc::now();\n        self.store.write_run(base_dir, &run_id, run)?;\n\n        let event = journal_event(\n            seq,\n            Utc::now(),\n            RequirementsJournalEventType::ReviewCompleted,\n            run,\n        );\n        self.store\n            .append_journal_event(base_dir, &run_id, &event)?;\n        seq += 1;\n\n        // Check review outcome\n        match review_payload.outcome {\n            RequirementsReviewOutcome::Approved | RequirementsReviewOutcome::ConditionallyApproved => {\n                // Continue to seed generation\n            }\n            RequirementsReviewOutcome::RequestChanges | RequirementsReviewOutcome::Rejected => {\n                // Fail the run after review payload/artifact are durably committed\n                let msg = format!(\n                    \"review outcome: {} — {}\",\n                    review_payload.outcome,\n                    review_payload.findings.join(\"; \")\n                );\n                self.fail_run(base_dir, run, seq, &msg).await?;\n                return Err(AppError::InvalidRequirementsState {\n                    run_id: run_id.clone(),\n                    details: msg,\n                });\n            }\n        }\n\n        // ── Seed ────────────────────────────────────────────────────────\n        let follow_ups = if review_payload.outcome == RequirementsReviewOutcome::ConditionallyApproved {\n            review_payload.follow_ups.clone()\n        } else {\n            Vec::new()\n        };\n\n        let seed_prompt = format!(\n            \"Generate a project seed from the following requirements:\\n\\n{}\\n\\nFollow-ups: {}\",\n            draft_bundle.artifact,\n            if follow_ups.is_empty() {\n                \"none\".to_owned()\n            } else {\n                follow_ups.join(\"; \")\n            }\n        );\n\n        let seed_result = self\n            .invoke_stage(\n                &run_root,\n                RequirementsStageId::ProjectSeed,\n                BackendRole::Planner,\n                &seed_prompt,\n            )\n            .await;\n\n        let seed_bundle = match seed_result {\n            Ok(b) => b,\n            Err(e) => {\n                self.fail_run(base_dir, run, seq, &format!(\"seed generation: {e}\"))\n                    .await?;\n                return Err(e);\n            }\n        };\n\n        let RequirementsPayload::Seed(ref seed_payload) = seed_bundle.payload else {\n            unreachable!();\n        };\n\n        let seed_payload_id = format!(\"{run_id}-seed-1\");\n        let seed_artifact_id = format!(\"{run_id}-seed-art-1\");\n        let seed_json = serde_json::to_value(seed_payload)?;\n\n        if let Err(e) = self.persist_payload_artifact_pair(\n            base_dir,\n            &run_id,\n            &seed_payload_id,\n            &seed_json,\n            &seed_artifact_id,\n            &seed_bundle.artifact,\n        ) {\n            self.fail_run(base_dir, run, seq, &format!(\"seed persistence: {e}\"))\n                .await?;\n            return Err(e);\n        }\n\n        // Write seed files atomically\n        let project_json = serde_json::to_value(seed_payload)?;\n        if let Err(e) = self\n            .store\n            .write_seed_pair(base_dir, &run_id, &project_json, &seed_payload.prompt_body)\n        {\n            // Rollback: remove both seed outputs, keep draft/review\n            let _ = self.store.remove_seed_pair(base_dir, &run_id);\n            self.fail_run(base_dir, run, seq, &format!(\"seed file write: {e}\"))\n                .await?;\n            return Err(AppError::SeedPersistenceFailed {\n                run_id: run_id.clone(),\n                details: e.to_string(),\n            });\n        }\n\n        run.latest_seed_id = Some(seed_payload_id.clone());\n        run.status = RequirementsStatus::Completed;\n        run.status_summary = \"completed\".to_owned();\n        run.updated_at = Utc::now();\n        self.store.write_run(base_dir, &run_id, run)?;\n\n        let event = journal_event(\n            seq,\n            Utc::now(),\n            RequirementsJournalEventType::SeedGenerated,\n            run,\n        );\n        self.store\n            .append_journal_event(base_dir, &run_id, &event)?;\n        seq += 1;\n\n        let event = journal_event(\n            seq,\n            Utc::now(),\n            RequirementsJournalEventType::RunCompleted,\n            run,\n        );\n        self.store\n            .append_journal_event(base_dir, &run_id, &event)?;\n\n        let seed_path = self.store.seed_prompt_path(base_dir, &run_id);\n        println!(\"Requirements completed. Seed files at:\");\n        println!(\"  {}\", seed_path.display());\n        println!(\n            \"\\nCreate project:\\n  ralph-burning project create --id {} --name \\\"{}\\\" --flow {} --prompt {}\",\n            seed_payload.project_id,\n            seed_payload.project_name,\n            seed_payload.flow,\n            seed_path.display()\n        );\n\n        Ok(())\n    }\n\n    async fn invoke_stage(\n        &self,\n        run_root: &Path,\n        stage_id: RequirementsStageId,\n        role: BackendRole,\n        prompt: &str,\n    ) -> AppResult<RequirementsValidatedBundle> {\n        let contract_label = format!(\"requirements:{}\", stage_id.as_str());\n        let target = self.agent_service.resolver().resolve(role, None, None, None)?;\n\n        let request = InvocationRequest {\n            invocation_id: format!(\n                \"req-{}-{}\",\n                stage_id.as_str(),\n                Utc::now().format(\"%Y%m%d%H%M%S\")\n            ),\n            project_root: run_root.to_path_buf(),\n            contract: InvocationContract::Requirements {\n                label: contract_label,\n            },\n            role,\n            resolved_target: target,\n            payload: InvocationPayload {\n                prompt: prompt.to_owned(),\n                context: serde_json::Value::Null,\n            },\n            timeout: std::time::Duration::from_secs(300),\n            cancellation_token: CancellationToken::new(),\n            session_policy: SessionPolicy::NewSession,\n            prior_session: None,\n            attempt_number: 1,\n        };\n\n        let envelope = self.agent_service.invoke(request).await?;\n\n        // Validate using requirements contract\n        let contract = match stage_id {\n            RequirementsStageId::QuestionSet => RequirementsContract::question_set(),\n            RequirementsStageId::RequirementsDraft => RequirementsContract::draft(),\n            RequirementsStageId::RequirementsReview => RequirementsContract::review(),\n            RequirementsStageId::ProjectSeed => RequirementsContract::seed(),\n        };\n\n        let bundle = contract\n            .evaluate(&envelope.parsed_payload)\n            .map_err(|e| AppError::InvalidRequirementsState {\n                run_id: \"\".to_owned(),\n                details: format!(\"contract validation failed for {}: {e}\", stage_id),\n            })?;\n\n        Ok(bundle)\n    }\n\n    fn persist_payload_artifact_pair(\n        &self,\n        base_dir: &Path,\n        run_id: &str,\n        payload_id: &str,\n        payload: &Value,\n        artifact_id: &str,\n        artifact: &str,\n    ) -> AppResult<()> {\n        self.store\n            .write_payload(base_dir, run_id, payload_id, payload)?;\n        if let Err(e) = self\n            .store\n            .write_artifact(base_dir, run_id, artifact_id, artifact)\n        {\n            // Rollback: payload was written but artifact failed — this is a\n            // partial failure. In practice the payload file should be cleaned up,\n            // but for now we propagate the error.\n            return Err(e);\n        }\n        Ok(())\n    }\n\n    async fn fail_run(\n        &self,\n        base_dir: &Path,\n        run: &mut RequirementsRun,\n        seq: u64,\n        message: &str,\n    ) -> AppResult<()> {\n        run.status = RequirementsStatus::Failed;\n        run.status_summary = format!(\"failed: {message}\");\n        run.updated_at = Utc::now();\n        self.store.write_run(base_dir, &run.run_id, run)?;\n\n        let event = journal_event(\n            seq,\n            Utc::now(),\n            RequirementsJournalEventType::RunFailed,\n            run,\n        );\n        self.store\n            .append_journal_event(base_dir, &run.run_id, &event)?;\n        Ok(())\n    }\n\n    fn next_sequence(&self, base_dir: &Path, run_id: &str) -> AppResult<u64> {\n        let events = self.store.read_journal(base_dir, run_id)?;\n        Ok(events.last().map_or(0, |e| e.sequence) + 1)\n    }\n}\n\n// ── Show result ─────────────────────────────────────────────────────────────\n\n/// Read model for `requirements show`.\n#[derive(Debug)]\npub struct RequirementsShowResult {\n    pub run: RequirementsRun,\n    pub journal_event_count: u64,\n    pub pending_question_count: Option<u32>,\n    pub failure_summary: Option<String>,\n    pub seed_prompt_path: Option<std::path::PathBuf>,\n}\n\n// ── Helpers ─────────────────────────────────────────────────────────────────\n\nfn generate_run_id(now: DateTime<Utc>) -> String {\n    format!(\"req-{}\", now.format(\"%Y%m%d-%H%M%S\"))\n}\n\nfn requirements_run_root(base_dir: &Path, run_id: &str) -> std::path::PathBuf {\n    base_dir\n        .join(\".ralph-burning\")\n        .join(\"requirements\")\n        .join(run_id)\n}\n\nfn journal_event(\n    sequence: u64,\n    timestamp: DateTime<Utc>,\n    event_type: RequirementsJournalEventType,\n    run: &RequirementsRun,\n) -> RequirementsJournalEvent {\n    RequirementsJournalEvent {\n        sequence,\n        timestamp,\n        event_type,\n        details: serde_json::json!({\n            \"run_id\": run.run_id,\n            \"status\": run.status,\n            \"status_summary\": run.status_summary,\n        }),\n    }\n}\n\nfn generate_answers_template(qs: &QuestionSetPayload) -> String {\n    let mut out = String::new();\n    out.push_str(\"# Answers for clarifying questions\\n\");\n    out.push_str(\"# Fill in answers below each question.\\n\\n\");\n\n    for q in &qs.questions {\n        let required = if q.required { \" (required)\" } else { \"\" };\n        out.push_str(&format!(\"# {}{}\\n\", q.prompt, required));\n        if !q.rationale.is_empty() {\n            out.push_str(&format!(\"# Rationale: {}\\n\", q.rationale));\n        }\n        let default_value = q\n            .suggested_default\n            .as_deref()\n            .unwrap_or(\"\");\n        out.push_str(&format!(\"{} = \\\"{}\\\"\\n\\n\", q.id, default_value));\n    }\n\n    out\n}\n\nfn parse_and_validate_answers<Q: RequirementsStorePort>(\n    answers_raw: &str,\n    base_dir: &Path,\n    run_id: &str,\n    store: &Q,\n) -> AppResult<PersistedAnswers> {\n    // Parse TOML\n    let table: toml::Table = toml::from_str(answers_raw).map_err(|e| {\n        AppError::AnswerValidationFailed {\n            run_id: run_id.to_owned(),\n            details: format!(\"invalid TOML: {e}\"),\n        }\n    })?;\n\n    // Read the question set to get required question IDs\n    let run = store.read_run(base_dir, run_id)?;\n    let _qs_id = run.latest_question_set_id.as_ref().ok_or_else(|| {\n        AppError::InvalidRequirementsState {\n            run_id: run_id.to_owned(),\n            details: \"no question set committed\".to_owned(),\n        }\n    })?;\n\n    // Build answers from TOML keys\n    let mut answers = Vec::new();\n    for (key, value) in &table {\n        let answer_text = match value.as_str() {\n            Some(s) => s.to_owned(),\n            None => value.to_string(),\n        };\n        answers.push(AnswerEntry {\n            question_id: key.clone(),\n            answer: answer_text,\n        });\n    }\n\n    // Note: full validation against required question IDs would require\n    // reading the question set payload. For now we validate non-empty answers.\n    for entry in &answers {\n        if entry.answer.trim().is_empty() {\n            // We just skip empty answers; the required check would need the\n            // question set payload to determine which are required.\n        }\n    }\n\n    Ok(PersistedAnswers { answers })\n}\n\nfn build_draft_prompt(idea: &str, answers: &[(String, String)]) -> String {\n    let mut prompt = format!(\"Draft requirements for the following idea:\\n\\n{idea}\\n\");\n\n    if !answers.is_empty() {\n        prompt.push_str(\"\\nClarifying answers:\\n\");\n        for (qid, answer) in answers {\n            prompt.push_str(&format!(\"- {qid}: {answer}\\n\"));\n        }\n    }\n\n    prompt\n}\n","numLines":827,"startLine":1,"totalLines":827}}}
