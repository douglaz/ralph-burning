t_execution_port_for_all_stage_contracts() {\n    39→    let adapter = StubBackendAdapter::default();\n    40→\n    41→    for stage_id in StageId::ALL {\n    42→        let request = request_fixture(stage_id);\n    43→        adapter\n    44→            .check_capability(&request.resolved_target, &request.stage_contract)\n    45→            .await\n    46→            .expect(\"capability check\");\n    47→        adapter\n    48→            .check_availability(&request.resolved_target)\n    49→            .await\n    50→            .expect(\"availability check\");\n    51→\n    52→        let envelope = adapter.invoke(request.clone()).await.expect(\"invoke stub\");\n    53→        let raw = envelope\n    54→            .raw_output_reference\n    55→            .inline_contents()\n    56→            .expect(\"inline raw output\");\n    57→        let parsed: Value = serde_json::from_str(raw).expect(\"parse canned JSON\");\n    58→\n    59→        request\n    60→            .stage_contract\n    61→            .evaluate(&parsed)\n    62→            .expect(\"stage contract must accept stub payload\");\n    63→    }\n    64→}\n    65→\n    66→#[tokio::test(flavor = \"multi_thread\")]\n    67→async fn stub_backend_reports_capability_failure_for_disabled_stage() {\n    68→    let adapter = StubBackendAdapter::default().without_stage_support(StageId::Planning);\n    69→    let request = request_fixture(StageId::Planning);\n    70→\n    71→    let error = adapter\n    72→        .check_capability(&request.resolved_target, &request.stage_contract)\n    73→        .await\n    74→        .expect_err(\"capability failure\");\n    75→\n    76→    assert!(matches!(error, AppError::CapabilityMismatch { .. }));\n    77→}\n    78→\n    79→#[tokio::test(flavor = \"multi_thread\")]\n    80→async fn stub_backend_reuses_prior_session_when_role_and_backend_allow_it() {\n    81→    let adapter = StubBackendAdapter::default();\n    82→    let timestamp = Utc\n    83→        .with_ymd_and_hms(2026, 3, 11, 21, 0, 0)\n    84→        .single()\n    85→        .expect(\"valid timestamp\");\n    86→    let mut request = request_fixture(StageId::Implementation);\n    87→    request.session_policy = SessionPolicy::ReuseIfAllowed;\n    88→    request.prior_session = Some(SessionMetadata {\n    89→        role: BackendRole::Implementer,\n    90→        backend_family: BackendFamily::Codex,\n    91→        model_id: \"gpt-5-codex\".to_owned(),\n    92→        session_id: \"existing-session\".to_owned(),\n    93→        created_at: timestamp,\n    94→        last_used_at: timestamp,\n    95→        invocation_count: 1,\n    96→    });\n    97→\n    98→    let envelope = adapter\n    99→        .invoke(request)\n   100→        .await\n   101→        .expect(\"invoke with session reuse\");\n   102→\n   103→    assert!(envelope.metadata.session_reused);\n   104→    assert_eq!(\n   105→        envelope.metadata.session_id.as_deref(),\n   106→        Some(\"existing-session\")\n   107→    );\n   108→}\n   109→\n   110→#[tokio::test(flavor = \"multi_thread\")]\n   111→async fn stub_backend_cancel_is_callable() {\n   112→    let adapter = StubBackendAdapter::default();\n   113→    adapter.cancel(\"stub-cancel\").await.expect(\"cancel stub\");\n   114→    assert_eq!(\n   115→        adapter.cancelled_invocations(),\n   116→        vec![\"stub-cancel\".to_owned()]\n   117→    );\n   118→}\n   119→\n   120→#[tokio::test(flavor = \"multi_thread\")]\n   121→async fn stub_backend_transient_failure_succeeds_after_fail_count() {\n   122→    let adapter = StubBackendAdapter::default().with_transient_failure(StageId::Implementation, 1);\n   123→    let request = request_fixture(StageId::Implementation);\n   124→\n   125→    let first = adapter\n   126→        .invoke(request.clone())\n   127→        .await\n   128→        .expect_err(\"first failure\");\n   129→    assert!(matches!(first, AppError::InvocationFailed { .. }));\n   130→\n   131→    let second = adapter.invoke(request).await.expect(\"second success\");\n   132→    let raw = second\n   133→        .raw_output_reference\n   134→        .inline_contents()\n   135→        .expect(\"inline raw output\");\n   136→    let parsed: Value = serde_json::from_str(raw).expect(\"parse canned JSON\");\n   137→    assert_eq!(\n   138→        parsed[\"change_summary\"].as_str(),\n   139→        Some(\"Stub execution output for Implementation\")\n   140→    );\n   141→}\n   142→"}]},"parent_tool_use_id":null,"session_id":"36dfa1de-6185-4dcd-ac73-de5f18bf85fd","uuid":"a61f2b5e-8526-48c8-af10-d19795c47f34","tool_use_result":{"type":"text","file":{"filePath":"/root/new-ralph-burning/ralph-burning-rewrite/tests/unit/stub_backend_test.rs","content":"use std::time::Duration;\n\nuse chrono::{TimeZone, Utc};\nuse serde_json::Value;\nuse tempfile::tempdir;\n\nuse ralph_burning::adapters::stub_backend::StubBackendAdapter;\nuse ralph_burning::contexts::agent_execution::model::{\n    CancellationToken, InvocationPayload, InvocationRequest,\n};\nuse ralph_burning::contexts::agent_execution::service::AgentExecutionPort;\nuse ralph_burning::contexts::agent_execution::session::SessionMetadata;\nuse ralph_burning::contexts::workflow_composition::contracts::contract_for_stage;\nuse ralph_burning::shared::domain::{BackendFamily, BackendRole, SessionPolicy, StageId};\nuse ralph_burning::shared::error::AppError;\n\nfn request_fixture(stage_id: StageId) -> InvocationRequest {\n    let temp_dir = tempdir().expect(\"create temp dir\");\n    InvocationRequest {\n        invocation_id: format!(\"stub-{}\", stage_id.as_str()),\n        project_root: temp_dir.path().to_path_buf(),\n        stage_contract: contract_for_stage(stage_id),\n        role: BackendRole::for_stage(stage_id),\n        resolved_target: BackendRole::for_stage(stage_id).default_target(),\n        payload: InvocationPayload {\n            prompt: format!(\"Stub prompt for {}\", stage_id.as_str()),\n            context: serde_json::json!({\"stage\": stage_id.as_str()}),\n        },\n        timeout: Duration::from_secs(1),\n        cancellation_token: CancellationToken::new(),\n        session_policy: SessionPolicy::NewSession,\n        prior_session: None,\n        attempt_number: 1,\n    }\n}\n\n#[tokio::test(flavor = \"multi_thread\")]\nasync fn stub_backend_satisfies_agent_execution_port_for_all_stage_contracts() {\n    let adapter = StubBackendAdapter::default();\n\n    for stage_id in StageId::ALL {\n        let request = request_fixture(stage_id);\n        adapter\n            .check_capability(&request.resolved_target, &request.stage_contract)\n            .await\n            .expect(\"capability check\");\n        adapter\n            .check_availability(&request.resolved_target)\n            .await\n            .expect(\"availability check\");\n\n        let envelope = adapter.invoke(request.clone()).await.expect(\"invoke stub\");\n        let raw = envelope\n            .raw_output_reference\n            .inline_contents()\n            .expect(\"inline raw output\");\n        let parsed: Value = serde_json::from_str(raw).expect(\"parse canned JSON\");\n\n        request\n            .stage_contract\n            .evaluate(&parsed)\n            .expect(\"stage contract must accept stub payload\");\n    }\n}\n\n#[tokio::test(flavor = \"multi_thread\")]\nasync fn stub_backend_reports_capability_failure_for_disabled_stage() {\n    let adapter = StubBackendAdapter::default().without_stage_support(StageId::Planning);\n    let request = request_fixture(StageId::Planning);\n\n    let error = adapter\n        .check_capability(&request.resolved_target, &request.stage_contract)\n        .await\n        .expect_err(\"capability failure\");\n\n    assert!(matches!(error, AppError::CapabilityMismatch { .. }));\n}\n\n#[tokio::test(flavor = \"multi_thread\")]\nasync fn stub_backend_reuses_prior_session_when_role_and_backend_allow_it() {\n    let adapter = StubBackendAdapter::default();\n    let timestamp = Utc\n        .with_ymd_and_hms(2026, 3, 11, 21, 0, 0)\n        .single()\n        .expect(\"valid timestamp\");\n    let mut request = request_fixture(StageId::Implementation);\n    request.session_policy = SessionPolicy::ReuseIfAllowed;\n    request.prior_session = Some(SessionMetadata {\n        role: BackendRole::Implementer,\n        backend_family: BackendFamily::Codex,\n        model_id: \"gpt-5-codex\".to_owned(),\n        session_id: \"existing-session\".to_owned(),\n        created_at: timestamp,\n        last_used_at: timestamp,\n        invocation_count: 1,\n    });\n\n    let envelope = adapter\n        .invoke(request)\n        .await\n        .expect(\"invoke with session reuse\");\n\n    assert!(envelope.metadata.session_reused);\n    assert_eq!(\n        envelope.metadata.session_id.as_deref(),\n        Some(\"existing-session\")\n    );\n}\n\n#[tokio::test(flavor = \"multi_thread\")]\nasync fn stub_backend_cancel_is_callable() {\n    let adapter = StubBackendAdapter::default();\n    adapter.cancel(\"stub-cancel\").await.expect(\"cancel stub\");\n    assert_eq!(\n        adapter.cancelled_invocations(),\n        vec![\"stub-cancel\".to_owned()]\n    );\n}\n\n#[tokio::test(flavor = \"multi_thread\")]\nasync fn stub_backend_transient_failure_succeeds_after_fail_count() {\n    let adapter = StubBackendAdapter::default().with_transient_failure(StageId::Implementation, 1);\n    let request = request_fixture(StageId::Implementation);\n\n    let first = adapter\n        .invoke(request.clone())\n        .await\n        .expect_err(\"first failure\");\n    assert!(matches!(first, AppError::InvocationFailed { .. }));\n\n    let second = adapter.invoke(request).await.expect(\"second success\");\n    let raw = second\n        .raw_output_reference\n        .inline_contents()\n        .expect(\"inline raw output\");\n    let parsed: Value = serde_json::from_str(raw).expect(\"parse canned JSON\");\n    assert_eq!(\n        parsed[\"change_summary\"].as_str(),\n        Some