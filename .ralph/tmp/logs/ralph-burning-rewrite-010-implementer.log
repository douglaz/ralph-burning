mily, model_id.clone());\n    92→        }\n    93→    }\n    94→\n    95→    fn apply_model_override(target: &mut ResolvedBackendTarget, model_override: ModelSpec) {\n    96→        if target.backend.family != model_override.backend_family {\n    97→            target.backend = BackendSpec::from_family(model_override.backend_family);\n    98→        }\n    99→        target.model = model_override;\n   100→    }\n   101→}\n   102→\n   103→#[allow(async_fn_in_trait)]\n   104→pub trait AgentExecutionPort {\n   105→    async fn check_capability(\n   106→        &self,\n   107→        backend: &ResolvedBackendTarget,\n   108→        stage_contract: &StageContract,\n   109→    ) -> AppResult<()>;\n   110→\n   111→    async fn check_availability(&self, backend: &ResolvedBackendTarget) -> AppResult<()>;\n   112→\n   113→    async fn invoke(&self, request: InvocationRequest) -> AppResult<InvocationEnvelope>;\n   114→\n   115→    async fn cancel(&self, invocation_id: &str) -> AppResult<()>;\n   116→}\n   117→\n   118→pub trait RawOutputPort {\n   119→    fn persist_raw_output(\n   120→        &self,\n   121→        project_root: &Path,\n   122→        invocation_id: &str,\n   123→        contents: &str,\n   124→    ) -> AppResult<RawOutputReference>;\n   125→}\n   126→\n   127→pub struct AgentExecutionService<A, R, S> {\n   128→    adapter: A,\n   129→    raw_output_store: R,\n   130→    session_manager: SessionManager<S>,\n   131→    resolver: BackendResolver,\n   132→}\n   133→\n   134→impl<A, R, S> AgentExecutionService<A, R, S> {\n   135→    pub fn new(adapter: A, raw_output_store: R, session_store: S) -> Self {\n   136→        Self {\n   137→            adapter,\n   138→            raw_output_store,\n   139→            session_manager: SessionManager::new(session_store),\n   140→            resolver: BackendResolver::new(),\n   141→        }\n   142→    }\n   143→\n   144→    pub fn resolver(&self) -> &BackendResolver {\n   145→        &self.resolver\n   146→    }\n   147→\n   148→    pub fn adapter(&self) -> &A {\n   149→        &self.adapter\n   150→    }\n   151→}\n   152→\n   153→impl<A, R, S> AgentExecutionService<A, R, S>\n   154→where\n   155→    A: AgentExecutionPort,\n   156→    R: RawOutputPort,\n   157→    S: SessionStorePort,\n   158→{\n   159→    pub async fn invoke(&self, request: InvocationRequest) -> AppResult<InvocationEnvelope> {\n   160→        let _ = CapabilityCheck::success(&request.resolved_target, request.stage_contract);\n   161→\n   162→        self.adapter\n   163→            .check_capability(&request.resolved_target, &request.stage_contract)\n   164→            .await\n   165→            .map_err(|error| map_capability_error(error, &request))?;\n   166→\n   167→        self.adapter\n   168→            .check_availability(&request.resolved_target)\n   169→            .await\n   170→            .map_err(|error| map_availability_error(error, &request))?;\n   171→\n   172→        let prior_session = self.session_manager.load_reusable_session(\n   173→            &request.project_root,\n   174→            request.role,\n   175→            &request.resolved_target,\n   176→            request.session_policy,\n   177→        )?;\n   178→\n   179→        let mut request = request;\n   180→        request.prior_session = prior_session;\n   181→\n   182→        if request.cancellation_token.is_cancelled() {\n   183→            return Err(AppError::InvocationCancelled {\n   184→                backend: request.resolved_target.backend.family.to_string(),\n   185→                stage_id: request.stage_contract.stage_id,\n   186→            });\n   187→        }\n   188→\n   189→        let started_at = Utc::now();\n   190→        let started = Instant::now();\n   191→        let invocation_id = request.invocation_id.clone();\n   192→        let timeout_ms = request.timeout.as_millis().min(u64::MAX as u128) as u64;\n   193→\n   194→        let invoke_future = self.adapter.invoke(request.clone());\n   195→        tokio::pin!(invoke_future);\n   196→\n   197→        let mut envelope = tokio::select! {\n   198→            _ = request.cancellation_token.cancelled() => {\n   199→                let _ = self.adapter.cancel(&invocation_id).await;\n   200→                return Err(AppError::InvocationCancelled {\n   201→                    backend: request.resolved_target.backend.family.to_string(),\n   202→                    stage_id: request.stage_contract.stage_id,\n   203→                });\n   204→            }\n   205→            result = tokio::time::timeout(request.timeout, &mut invoke_future) => {\n   206→                match result {\n   207→                    Ok(result) => result.map_err(|error| map_invoke_error(error, &request))?,\n   208→                    Err(_) => {\n   209→                        let _ = self.adapter.cancel(&invocation_id).await;\n   210→                        return Err(AppError::InvocationTimeout {\n   211→                            backend: request.resolved_target.backend.family.to_string(),\n   212→                            stage_id: request.stage_contract.stage_id,\n   213→                            timeout_ms,\n   214→                        });\n   215→                    }\n   216→                }\n   217→            }\n   218→        };\n   219→\n   220→        let duration = started.elapsed();\n   221→        envelope.metadata.duration = duration;\n   222→        envelope.metadata.attempt_number = request.attempt_number;\n   223→        envelope.metadata.backend_used = request.resolved_target.backend.clone();\n   224→        envelope.metadata.model_used = request.resolved_target.model.clone();\n   225→        envelope.timestamp = Utc::now();\n   226→\n   227→        let raw_output = extract_raw_output(&envelope.raw_output_reference)?;\n   228→        let stored_reference = self.raw_output_store.persist_raw_output(\n   229→            &request.project_root,\n   230→            &request.invocation_id,\n   231→            &raw_output,\n   232→        )?;\n   233→\n   234→        let parsed_payload =\n   235→            extract_structured_payload(&request, envelope.parsed_payload, &raw_output)?;\n   236→\n   237→        request\n   238→            .stage_contract\n   239→            .evaluate_permissive(&parsed_payload)\n   240→            .map_err(|error| map_contract_error(error, &request))?;\n   241→\n   242→        envelope.raw_output_reference = stored_reference;\n   243→        envelope.parsed_payload = parsed_payload;\n   244→        envelope.timestamp = started_at + duration;\n   245→\n   246→        self.session_manager.record_session(\n   247→            &request.project_root,\n   248→            request.role,\n   249→            &request.resolved_target,\n   250→            envelope.metadata.session_id.as_deref(),\n   251→            envelope.timestamp,\n   252→        )?;\n   253→\n   254→        Ok(envelope)\n   255→    }\n   256→}\n   257→\n   258→fn parse_backend_family(key: &str, value: &str) -> AppResult<BackendFamily> {\n   259→    match value {\n   260→        \"claude\" => Ok(BackendFamily::Claude),\n   261→        \"codex\" => Ok(BackendFamily::Codex),\n   262→        \"openrouter\" => Ok(BackendFamily::OpenRouter),\n   263→        \"stub\" => Ok(BackendFamily::Stub),\n   264→        _ => Err(AppError::InvalidConfigValue {\n   265→            key: key.to_owned(),\n   266→            value: value.to_owned(),\n   267→            reason: \"expected one of claude, codex, openrouter, stub\".to_owned(),\n   268→        }),\n   269→    }\n   270→}\n   271→\n   272→fn extract_raw_output(raw_output_reference: &RawOutputReference) -> AppResult<String> {\n   273→    match raw_output_reference {\n   274→        RawOutputReference::Inline(contents) => Ok(contents.clone()),\n   275→        RawOutputReference::Stored(path) => std::fs::read_to_string(path).map_err(AppError::from),\n   276→    }\n   277→}\n   278→\n   279→fn extract_structured_payload(\n   280→    request: &InvocationRequest,\n   281→    parsed_payload: Value,\n   282→    raw_output: &str,\n   283→) -> AppResult<Value> {\n   284→    if !parsed_payload.is_null() {\n   285→        return Ok(parsed_payload);\n   286→    }\n   287→\n   288→    serde_json::from_str(raw_output).map_err(|error| AppError::InvocationFailed {\n   289→        backend: request.resolved_target.backend.family.to_string(),\n   290→        stage_id: request.stage_contract.stage_id,\n   291→        failure_class: FailureClass::SchemaValidationFailure,\n   292→        details: error.to_string(),\n   293→    })\n   294→}\n   295→\n   296→fn map_capability_error(error: AppError, request: &InvocationRequest) -> AppError {\n   297→    match error {\n   298→        AppError::CapabilityMismatch { .. } => error,\n   299→        other => AppError::CapabilityMismatch {\n   300→            backend: request.resolved_target.backend.family.to_string(),\n   301→            stage_id: request.stage_contract.stage_id,\n   302→            details: other.to_string(),\n   303→        },\n   304→    }\n   305→}\n   306→\n   307→fn map_availability_error(error: AppError, request: &InvocationRequest) -> AppError {\n   308→    match error {\n   309→        AppError::BackendUnavailable { .. } => error,\n   310→        other => AppError::BackendUnavailable {\n   311→            backend: request.resolved_target.backend.family.to_string(),\n   312→            details: other.to_string(),\n   313→        },\n   314→    }\n   315→}\n   316→\n   317→fn map_invoke_error(error: AppError, request: &InvocationRequest) -> AppError {\n   318→    match error {\n   319→        AppError::InvocationFailed { .. }\n   320→        | AppError::InvocationTimeout { .. }\n   321→        | AppError::InvocationCancelled { .. } => error,\n   322→        other => AppError::InvocationFailed {\n   323→            backend: request.resolved_target.backend.family.to_string(),\n   324→            stage_id: request.stage_contract.stage_id,\n   325→            failure_class: FailureClass::TransportFailure,\n   326→            details: other.to_string(),\n   327→        },\n   328→    }\n   329→}\n   330→\n   331→fn map_contract_error(error: ContractError, request: &InvocationRequest) -> AppError {\n   332→    AppError::InvocationFailed {\n   333→        backend: request.resolved_target.backend.family.to_string(),\n   334→        stage_id: request.stage_contract.stage_id,\n   335→        failure_class: error.failure_class(),\n   336→        details: error.to_string(),\n   337→    }\n   338→}\n   339→"}]},"parent_tool_use_id":null,"session_id":"36dfa1de-6185-4dcd-ac73-de5f18bf85fd","uuid":"ef5dd23e-eafd-4cd2-a472-c026b8494c9b","tool_use_result":{"type":"text","file":{"filePath":"/root/new-ralph-burning/ralph-burning-rewrite/src/contexts/agent_execution/service.rs","content":"use std::path::Path;\nuse std::time::Instant;\n\nuse chrono::Utc;\nuse serde_json::Value;\n\nuse crate::contexts::agent_execution::model::{\n    CapabilityCheck, InvocationEnvelope, InvocationRequest, RawOutputReference,\n};\nuse crate::contexts::agent_execution::session::{SessionManager, SessionStorePort};\nuse crate::contexts::workflow_composition::contracts::StageContract;\nuse crate::contexts::workspace_governance::EffectiveConfig;\nuse crate::shared::domain::{\n    BackendFamily, BackendRole, BackendSpec, FailureClass, ModelSpec, ResolvedBackendTarget,\n};\nuse crate::shared::error::{AppError, AppResult, ContractError};\n\n#[derive(Debug, Clone, Default, PartialEq, Eq)]\npub struct BackendSelectionConfig {\n    pub backend_family: Option<BackendFamily>,\n    pub model_id: Option<String>,\n}\n\nimpl BackendSelectionConfig {\n    pub fn from_effective_config(config: &EffectiveConfig) -> AppResult<Self> {\n        Ok(Self {\n            backend_family: config\n                .default_backend()\n                .map(|value| parse_backend_family(\"default_backend\", value))\n                .transpose()?,\n            model_id: config.default_model().map(|value| value.to_owned()),\n        })\n    }\n}\n\n#[derive(Debug, Clone, Default)]\npub struct BackendResolver;\n\nimpl BackendResolver {\n    pub fn new() -> Self {\n        Self\n    }\n\n    pub fn resolve(\n        &self,\n        role: BackendRole,\n        explicit_model_override: Option<ModelSpec>,\n        project_config: Option<&BackendSelectionConfig>,\n        workspace_defaults: Option<&BackendSelectionConfig>,\n    ) -> AppResult<ResolvedBackendTarget> {\n        let mut target = role.default_target();\n\n        if let Some(workspace_defaults) = workspace_defaults {\n            Self::apply_selection(&mut target, workspace_defaults);\n        }\n        if let Some(project_config) = project_config {\n            Self::apply_selection(&mut target, project_config);\n        }\n        if let Some(model_override) = explicit_model_override {\n            Self::apply_model_override(&mut target, model_override);\n        }\n\n        Ok(target)\n    }\n\n    pub fn resolve_from_effective_config(\n        &self,\n        role: BackendRole,\n        explicit_model_override: Option<ModelSpec>,\n        project_config: Option<&BackendSelectionConfig>,\n        effective_config: &EffectiveConfig,\n    ) -> AppResult<ResolvedBackendTarget> {\n        let workspace_defaults = BackendSelectionConfig::from_effective_config(effective_config)?;\n        self.resolve(\n            role,\n            explicit_model_override,\n            project_config,\n            Some(&workspace_defaults),\n        )\n    }\n\n    fn apply_selection(target: &mut ResolvedBackendTarget, selection: &BackendSelectionConfig) {\n        if let Some(backend_family) = selection.backend_family {\n            target.backend = BackendSpec::from_family(backend_family);\n            if target.model.backend_family != backend_family {\n                target.model = ModelSpec::default_for_backend(backend_family);\n            }\n        }\n\n        if let Some(model_id) = &selection.model_id {\n            target.model = ModelSpec::new(target.backend.family, model_id.clone());\n        }\n    }\n\n    fn apply_model_override(target: &mut ResolvedBackendTarget, model_override: ModelSpec) {\n        if target.backend.family != model_override.backend_family {\n            target.backend = BackendSpec::from_family(model_override.backend_family);\n        }\n        target.model = model_override;\n    }\n}\n\n#[allow(async_fn_in_trait)]\npub trait AgentExecutionPort {\n    async fn check_capability(\n        &self,\n        backend: &ResolvedBackendTarget,\n        stage_contract: &StageContract,\n    ) -> AppResult<()>;\n\n    async fn check_availability(&self, backend: &ResolvedBackendTarget) -> AppResult<()>;\n\n    async fn invoke(&self, request: InvocationRequest) -> AppResult<InvocationEnvelope>;\n\n    async fn cancel(&self, invocation_id: &str) -> AppResult<()>;\n}\n\npub trait RawOutputPort {\n    fn persist_raw_output(\n        &self,\n        project_root: &Path,\n        invocation_id: &str,\n        contents: &str,\n    ) -> AppResult<RawOutputReference>;\n}\n\npub struct AgentExecutionService<A, R, S> {\n    adapter: A,\n    raw_output_store: R,\n    session_manager: SessionManager<S>,\n    resolver: BackendResolver,\n}\n\nimpl<A, R, S> AgentExecutionService<A, R, S> {\n    pub fn new(adapter: A, raw_output_store: R, session_store: S) -> Self {\n        Self {\n            adapter,\n            raw_output_store,\n            session_manager: SessionManager::new(session_store),\n            resolver: BackendResolver::new(),\n        }\n    }\n\n    pub fn resolver(&self) -> &BackendResolver {\n        &self.resolver\n    }\n\n    pub fn adapter(&self) -> &A {\n        &self.adapter\n    }\n}\n\nimpl<A, R, S> AgentExecutionService<A, R, S>\nwhere\n    A: AgentExecutionPort,\n    R: RawOutputPort,\n    S: SessionStorePort,\n{\n    pub async fn invoke(&self, request: InvocationRequest) -> AppResult<InvocationEnvelope> {\n        let _ = CapabilityCheck::success(&request.resolved_target, request.stage_contract);\n\n        self.adapter\n            .check_capability(&request.resolved_target, &request.stage_contract)\n            .await\n            .map_err(|error| map_capability_error(error, &request))?;\n\n        self.adapter\n            .check_availability(&request.resolved_target)\n            .await\n            .map_err(|error| map_availability_error(error, &request))?;\n\n        let prior_session = self.session_manager.load_reusable_session(\n            &request.project_root,\n            request.role,\n            &request.resolved_target,\n            request.session_policy,\n        )?;\n\n        let mut request = request;\n        request.prior_session = prior_session;\n\n        if request.cancellation_token.is_cancelled() {\n            return Err(AppError::InvocationCancelled {\n                backend: request.resolved_target.backend.family.to_string(),\n                stage_id: request.stage_contract.stage_id,\n            });\n        }\n\n        let started_at = Utc::now();\n        let started = Instant::now();\n        let invocation_id = request.invocation_id.clone();\n        let timeout_ms = request.timeout.as_millis().min(u64::MAX as u128) as u64;\n\n        let invoke_future = self.adapter.invoke(request.clone());\n        tokio::pin!(invoke_future);\n\n        let mut envelope = tokio::select! {\n            _ = request.cancellation_token.cancelled() => {\n                let _ = self.adapter.cancel(&invocation_id).await;\n                return Err(AppError::InvocationCancelled {\n                    backend: request.resolved_target.backend.family.to_string(),\n                    stage_id: request.stage_contract.stage_id,\n                });\n            }\n            result = tokio::time::timeout(request.timeout, &mut invoke_future) => {\n                match result {\n                    Ok(result) => result.map_err(|error| map_invoke_error(error, &request))?,\n                    Err(_) => {\n                        let _ = self.adapter.cancel(&invocation_id).await;\n                        return Err(AppError::InvocationTimeout {\n                            backend: request.resolved_target.backend.family.to_string(),\n                            stage_id: request.stage_contract.stage_id,\n                            timeout_ms,\n                        });\n                    }\n                }\n            }\n        };\n\n        let duration = started.elapsed();\n        envelope.metadata.duration = duration;\n        envelope.metadata.attempt_number = request.attempt_number;\n        envelope.metadata.backend_used = request.resolved_target.backend.clone();\n        envelope.metadata.model_used = request.resolved_target.model.clone();\n        envelope.timestamp = Utc::now();\n\n        let raw_output = extract_raw_output(&envelope.raw_output_reference)?;\n        let stored_reference = self.raw_output_store.persist_raw_output(\n            &request.project_root,\n            &request.invocation_id,\n            &raw_output,\n        )?;\n\n        let parsed_payload =\n            extract_structured_payload(&request, envelope.parsed_payload, &raw_output)?;\n\n        request\n            .stage_contract\n            .evaluate_permissive(&parsed_payload)\n            .map_err(|error| map_contract_error(error, &request))?;\n\n        envelope.raw_output_reference = stored_reference;\n        envelope.parsed_payload = parsed_payload;\n        envelope.timestamp = started_at + duration;\n\n        self.session_manager.record_session(\n            &request.project_root,\n            request.role,\n            &request.resolved_target,\n            envelope.metadata.session_id.as_deref(),\n            envelope.timestamp,\n        )?;\n\n        Ok(envelope)\n    }\n}\n\nfn parse_backend_family(key: &str, value: &str) -> AppResult<BackendFamily> {\n    match value {\n        \"claude\" => Ok(BackendFamily::Claude),\n        \"codex\" => Ok(BackendFamily::Codex),\n        \"openrouter\" => Ok(BackendFamily::OpenRouter),\n        \"stub\" => Ok(BackendFamily::Stub),\n        _ => Err(AppError::InvalidConfigValue {\n            key: key.to_owned(),\n            value: value.to_owned(),\n            reason: \"expected one of claude, codex, openrouter, stub\".to_owned(),\n        }),\n    }\n}\n\nfn extract_raw_output(raw_output_reference: &RawOutputReference) -> AppResult<String> {\n    match raw_output_reference {\n        RawOutputReference::Inline(contents) => Ok(contents.clone()),\n        RawOutputReference::Stored(path) => std::fs::read_to_string(path).map_err(AppError::from),\n    }\n}\n\nfn extract_structured_payload(\n    request: &InvocationRequest,\n    parsed_payload: Value,\n    raw_output: &str,\n) -> AppResult<Value> {\n    if !parsed_payload.is_null() {\n        return Ok(parsed_payload);\n    }\n\n    serde_json::from_str(raw_output).map_err(|error| AppError::InvocationFailed {\n        backend: request.resolved_target.backend.family.to_string(),\n        stage_id: request.stage_contract.stage_id,\n        failure_class: FailureClass::SchemaValidationFailure,\n        details: error.to_string(),\n    })\n}\n\nfn map_capability_error(error: AppError, request: &InvocationRequest) -> AppError {\n    match error {\n        AppError::CapabilityMismatch { .. } => error,\n        other => AppError::CapabilityMismatch {\n            backend: request.resolved_target.backend.family.to_string(),\n            stage_id: request.stage_contract.stage_id,\n            details: other.to_string(),\n        },\n    }\n}\n\nfn map_availability_error(error: AppError, request: &InvocationRequest) -> AppError {\n    match error {\n        AppError::BackendUnavailable { .. } => error,\n        other => AppError::BackendUnavailable {\n            backend: request.resolved_target.backend.family.to_string(),\n            details: other.to_string(),\n        },\n    }\n}\n\nfn map_invoke_error(error: AppError, request: &InvocationRequest) -> AppError {\n    match error {\n        AppError::InvocationFailed { .. }\n        | AppError::InvocationTimeout { .. }\n        | AppError::InvocationCancelled { .. } => error,\n        other => AppError::InvocationFailed {\n            backend: request.resolved_target.backend.family.to_string(),\n            stage_id: request.stage_contract.stage_id,\n            failure_class: FailureClass::TransportFailure,\n            details: other.to_string(),\n        },\n    }\n}\n\nfn map_contract_error(error: ContractError, request: &InvocationRequest) -> AppError {\n    AppError::InvocationFailed {\n        backend: request.resolved_target.backend.family.to_string(),\n        stage_id: request.stage_contract.stage_id,\n        failure_class: error.failure_class(),\n        details: error.to_string(),\n    }\n}\n","numLines":339,"startLine":1,"totalLines":339}}}
