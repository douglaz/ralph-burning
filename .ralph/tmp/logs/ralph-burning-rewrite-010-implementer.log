ved.model.backend_family, BackendFamily::Claude);\n   191→    assert_eq!(resolved.model.model_id, explicit.model_id);\n   192→}\n   193→\n   194→#[tokio::test(flavor = \"multi_thread\")]\n   195→async fn service_constructs_envelope_and_persists_raw_output() {\n   196→    let temp_dir = tempdir().expect(\"create temp dir\");\n   197→    let project_root = project_root_fixture(temp_dir.path());\n   198→\n   199→    let adapter = StubBackendAdapter::default();\n   200→    let service = AgentExecutionService::new(adapter, FsRawOutputStore, FsSessionStore);\n   201→    let request = request_fixture(\n   202→        &project_root,\n   203→        \"invoke-1\",\n   204→        StageId::Planning,\n   205→        BackendRole::Planner,\n   206→        BackendRole::Planner.default_target(),\n   207→        Duration::from_secs(1),\n   208→        SessionPolicy::NewSession,\n   209→        CancellationToken::new(),\n   210→    );\n   211→\n   212→    let envelope = service.invoke(request).await.expect(\"invoke service\");\n   213→    let stored_path = envelope\n   214→        .raw_output_reference\n   215→        .stored_path()\n   216→        .expect(\"stored path\");\n   217→\n   218→    assert!(stored_path.exists());\n   219→    assert!(stored_path.ends_with(\"runtime/backend/invoke-1.raw\"));\n   220→    assert_eq!(envelope.parsed_payload[\"readiness\"][\"ready\"], json!(true));\n   221→    assert_eq!(envelope.metadata.attempt_number, 1);\n   222→    assert_eq!(envelope.metadata.backend_used.family, BackendFamily::Claude);\n   223→    assert_eq!(envelope.metadata.model_used.model_id, \"opus-4.1\");\n   224→    assert!(envelope.metadata.token_counts.total_tokens.is_some());\n   225→}\n   226→\n   227→#[tokio::test(flavor = \"multi_thread\")]\n   228→async fn service_returns_capability_mismatch_when_backend_cannot_support_stage() {\n   229→    let temp_dir = tempdir().expect(\"create temp dir\");\n   230→    let project_root = project_root_fixture(temp_dir.path());\n   231→    let adapter = StubBackendAdapter::default().without_stage_support(StageId::Planning);\n   232→    let service = AgentExecutionService::new(adapter, FsRawOutputStore, FsSessionStore);\n   233→    let request = request_fixture(\n   234→        &project_root,\n   235→        \"invoke-capability\",\n   236→        StageId::Planning,\n   237→        BackendRole::Planner,\n   238→        BackendRole::Planner.default_target(),\n   239→        Duration::from_secs(1),\n   240→        SessionPolicy::NewSession,\n   241→        CancellationToken::new(),\n   242→    );\n   243→\n   244→    let error = service\n   245→        .invoke(request)\n   246→        .await\n   247→        .expect_err(\"capability mismatch\");\n   248→\n   249→    assert!(matches!(error, AppError::CapabilityMismatch { .. }));\n   250→    assert_eq!(\n   251→        error.failure_class(),\n   252→        Some(FailureClass::DomainValidationFailure)\n   253→    );\n   254→}\n   255→\n   256→#[tokio::test(flavor = \"multi_thread\")]\n   257→async fn service_returns_backend_unavailable_as_transport_failure() {\n   258→    let temp_dir = tempdir().expect(\"create temp dir\");\n   259→    let project_root = project_root_fixture(temp_dir.path());\n   260→    let adapter = StubBackendAdapter::default().unavailable();\n   261→    let service = AgentExecutionService::new(adapter, FsRawOutputStore, FsSessionStore);\n   262→    let request = request_fixture(\n   263→        &project_root,\n   264→        \"invoke-unavailable\",\n   265→        StageId::Planning,\n   266→        BackendRole::Planner,\n   267→        BackendRole::Planner.default_target(),\n   268→        Duration::from_secs(1),\n   269→        SessionPolicy::NewSession,\n   270→        CancellationToken::new(),\n   271→    );\n   272→\n   273→    let error = service\n   274→        .invoke(request)\n   275→        .await\n   276→        .expect_err(\"backend unavailable\");\n   277→\n   278→    assert!(matches!(error, AppError::BackendUnavailable { .. }));\n   279→    assert_eq!(error.failure_class(), Some(FailureClass::TransportFailure));\n   280→}\n   281→\n   282→#[tokio::test(flavor = \"multi_thread\")]\n   283→async fn service_times_out_and_requests_backend_cancellation() {\n   284→    let temp_dir = tempdir().expect(\"create temp dir\");\n   285→    let project_root = project_root_fixture(temp_dir.path());\n   286→    let adapter = StubBackendAdapter::default().with_delay(Duration::from_millis(100));\n   287→    let adapter_handle = adapter.clone();\n   288→    let service = AgentExecutionService::new(adapter, FsRawOutputStore, FsSessionStore);\n   289→    let request = request_fixture(\n   290→        &project_root,\n   291→        \"invoke-timeout\",\n   292→        StageId::Planning,\n   293→        BackendRole::Planner,\n   294→        BackendRole::Planner.default_target(),\n   295→        Duration::from_millis(10),\n   296→        SessionPolicy::NewSession,\n   297→        CancellationToken::new(),\n   298→    );\n   299→\n   300→    let error = service.invoke(request).await.expect_err(\"timeout\");\n   301→\n   302→    assert!(matches!(error, AppError::InvocationTimeout { .. }));\n   303→    assert_eq!(error.failure_class(), Some(FailureClass::Timeout));\n   304→    assert_eq!(\n   305→        adapter_handle.cancelled_invocations(),\n   306→        vec![\"invoke-timeout\".to_owned()]\n   307→    );\n   308→}\n   309→\n   310→#[tokio::test(flavor = \"multi_thread\")]\n   311→async fn service_propagates_cancellation_without_retry() {\n   312→    let temp_dir = tempdir().expect(\"create temp dir\");\n   313→    let project_root = project_root_fixture(temp_dir.path());\n   314→    let adapter = StubBackendAdapter::default().with_delay(Duration::from_millis(100));\n   315→    let service = AgentExecutionService::new(adapter, FsRawOutputStore, FsSessionStore);\n   316→    let cancellation_token = CancellationToken::new();\n   317→    let cancel_handle = cancellation_token.clone();\n   318→    let request =