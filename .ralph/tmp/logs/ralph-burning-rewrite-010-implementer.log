{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01VfoW5m9LwLxhUKw6HB8gF4","type":"tool_result","content":"     1→use std::time::Duration;\n     2→\n     3→use chrono::{TimeZone, Utc};\n     4→use serde_json::Value;\n     5→use tempfile::tempdir;\n     6→\n     7→use ralph_burning::adapters::stub_backend::StubBackendAdapter;\n     8→use ralph_burning::contexts::agent_execution::model::{\n     9→    CancellationToken, InvocationContract, InvocationPayload, InvocationRequest,\n    10→};\n    11→use ralph_burning::contexts::agent_execution::service::AgentExecutionPort;\n    12→use ralph_burning::contexts::agent_execution::session::SessionMetadata;\n    13→use ralph_burning::contexts::workflow_composition::contracts::contract_for_stage;\n    14→use ralph_burning::shared::domain::{BackendFamily, BackendRole, SessionPolicy, StageId};\n    15→use ralph_burning::shared::error::AppError;\n    16→\n    17→fn request_fixture(stage_id: StageId) -> InvocationRequest {\n    18→    let temp_dir = tempdir().expect(\"create temp dir\");\n    19→    InvocationRequest {\n    20→        invocation_id: format!(\"stub-{}\", stage_id.as_str()),\n    21→        project_root: temp_dir.path().to_path_buf(),\n    22→        contract: InvocationContract::Stage(contract_for_stage(stage_id)),\n    23→        role: BackendRole::for_stage(stage_id),\n    24→        resolved_target: BackendRole::for_stage(stage_id).default_target(),\n    25→        payload: InvocationPayload {\n    26→            prompt: format!(\"Stub prompt for {}\", stage_id.as_str()),\n    27→            context: serde_json::json!({\"stage\": stage_id.as_str()}),\n    28→        },\n    29→        timeout: Duration::from_secs(1),\n    30→        cancellation_token: CancellationToken::new(),\n    31→        session_policy: SessionPolicy::NewSession,\n    32→        prior_session: None,\n    33→        attempt_number: 1,\n    34→    }\n    35→}\n    36→\n    37→#[tokio::test(flavor = \"multi_thread\")]\n    38→async fn stub_backend_satisfies_agent_execution_port_for_all_stage_contracts() {\n    39→    let adapter = StubBackendAdapter::default();\n    40→\n    41→    for stage_id in StageId::ALL {\n    42→        let request = request_fixture(stage_id);\n    43→        adapter\n    44→            .check_capability(&request.resolved_target, &request.contract)\n    45→            .await\n    46→            .expect(\"capability check\");\n    47→        adapter\n    48→            .check_availability(&request.resolved_target)\n    49→            .await\n    50→            .expect(\"availability check\");\n    51→\n    52→        let envelope = adapter.invoke(request.clone()).await.expect(\"invoke stub\");\n    53→        let raw = envelope\n    54→            .raw_output_reference\n    55→            .inline_contents()\n    56→            .expect(\"inline raw output\");\n    57→        let parsed: Value = serde_json::from_str(raw).expect(\"parse canned JSON\");\n    58→\n    59→        request\n    60→            .contract\n    61→            .stage_contract()\n    62→            .expect(\"stage contract\")\n    63→            .evaluate(&parsed)\n    64→            .expect(\"stage contract must accept stub payload\");\n    65→    }\n    66→}\n    67→\n    68→#[tokio::test(flavor = \"multi_thread\")]\n    69→async fn stub_backend_reports_capability_failure_for_disabled_stage() {\n    70→    let adapter = StubBackendAdapter::default().without_stage_support(StageId::Planning);\n    71→    let request = request_fixture(StageId::Planning);\n    72→\n    73→    let error = adapter\n    74→        .check_capability(&request.resolved_target, &request.contract)\n    75→        .await\n    76→        .expect_err(\"capability failure\");\n    77→\n    78→    assert!(matches!(error, AppError::CapabilityMismatch { .. }));\n    79→}\n    80→\n    81→#[tokio::test(flavor = \"multi_thread\")]\n    82→async fn stub_backend_reuses_prior_session_when_role_and_backend_allow_it() {\n    83→    let adapter = StubBackendAdapter::default();\n    84→    let timestamp = Utc\n    85→        .with_ymd_and_hms(2026, 3, 11, 21, 0, 0)\n    86→        .single()\n    87→        .expect(\"valid timestamp\");\n    88→    let mut request = request_fixture(StageId::Implementation);\n    89→    request.session_policy = SessionPolicy::ReuseIfAllowed;\n    90→    request.prior_session = Some(SessionMetadata {\n    91→        role: BackendRole::Implementer,\n    92→        backend_family: BackendFamily::Codex,\n    93→        model_id: \"gpt-5-codex\".to_owned(),\n    94→        session_id: \"existing-session\".to_owned(),\n    95→        created_at: timestamp,\n    96→        last_used_at: timestamp,\n    97→        invocation_count: 1,\n    98→    });\n    99→\n   100→    let envelope = adapter\n   101→        .invoke(request)\n   102→        .await\n   103→        .expect(\"invoke with session reuse\");\n   104→\n   105→    assert!(envelope.metadata.session_reused);\n   106→    assert_eq!(\n   107→        envelope.metadata.session_id.as_deref(),\n   108→        Some(\"existing-session\")\n   109→    );\n   110→}\n   111→\n   112→#[tokio::test(flavor = \"multi_thread\")]\n   113→async fn stub_backend_cancel_is_callable() {\n   114→    let adapter = StubBackendAdapter::default();\n   115→    adapter.cancel(\"stub-cancel\").await.expect(\"cancel stub\");\n   116→    assert_eq!(\n   117→        adapter.cancelled_invocations(),\n   118→        vec![\"stub-cancel\".to_owned()]\n   119→    );\n   120→}\n   121→\n   122→#[tokio::test(flavor = \"multi_thread\")]\n   123→async fn stub_backend_transient_failure_succeeds_after_fail_count() {\n   124→    let adapter = StubBackendAdapter::default().with_transient_failure(StageId::Implementation, 1);\n   125→    let request = request_fixture(StageId::Implementation);\n   126→\n   127→    let first = adapter\n   128→        .invoke(request.clone())\n   129→        .await\n   130→        .expect_err(\"first failure\");\n   131→    assert!(matches!(first, AppError::InvocationFailed { .. }));\n   132→\n   133→    let second = adapter.invoke(request).await.expect(\"second success\");\n   134→    let raw = second\n   135→        .raw_output_reference\n   136→        .inline_contents()\n   137→        .expect(\"inline raw output\");\n   138→    let parsed: Value = serde_json::from_str(raw).expect(\"parse canned JSON\");\n   139→    assert_eq!(\n   140→        parsed[\"change_summary\"].as_str(),\n   141→        Some(\"Stub execution output for Implementation\")\n   142→    );\n   143→}\n   144→"}]},"parent_tool_use_id":"toolu_01PaXyQz2ihAyjCvhHfcUYoy","session_id":"36dfa1de-6185-4dcd-ac73-de5f18bf85fd","uuid":"eed340d3-7236-4657-b1b8-5d76d4c55fa8"}
