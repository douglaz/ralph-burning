{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Juar7f3yqdaXemuvkLdH8U","type":"tool_result","content":"     1→pub mod config;\n     2→\n     3→use std::path::{Path, PathBuf};\n     4→\n     5→use chrono::{DateTime, Utc};\n     6→\n     7→use crate::adapters::fs::FileSystem;\n     8→use crate::shared::domain::{ProjectId, WorkspaceConfig, CURRENT_WORKSPACE_VERSION};\n     9→use crate::shared::error::{AppError, AppResult};\n    10→\n    11→pub use config::{\n    12→    ConfigEntry, ConfigValue, ConfigValueSource, EffectiveConfig, DEFAULT_FLOW_PRESET,\n    13→    DEFAULT_PROMPT_REVIEW_ENABLED,\n    14→};\n    15→\n    16→pub const WORKSPACE_DIR: &str = \".ralph-burning\";\n    17→pub const WORKSPACE_CONFIG_FILE: &str = \"workspace.toml\";\n    18→pub const ACTIVE_PROJECT_FILE: &str = \"active-project\";\n    19→pub const PROJECTS_DIR: &str = \"projects\";\n    20→pub const PROJECT_CONFIG_FILE: &str = \"project.toml\";\n    21→pub const REQUIRED_WORKSPACE_DIRECTORIES: &[&str] =\n    22→    &[\"projects\", \"requirements\", \"daemon/tasks\", \"daemon/leases\"];\n    23→\n    24→#[derive(Debug, Clone, PartialEq)]\n    25→pub struct WorkspaceInitialization {\n    26→    pub workspace_root: PathBuf,\n    27→    pub config: WorkspaceConfig,\n    28→}\n    29→\n    30→pub fn initialize_workspace(\n    31→    base_dir: &Path,\n    32→    created_at: DateTime<Utc>,\n    33→) -> AppResult<WorkspaceInitialization> {\n    34→    let workspace_root = workspace_root(base_dir);\n    35→    let config_path = workspace_root.join(WORKSPACE_CONFIG_FILE);\n    36→\n    37→    if config_path.exists() {\n    38→        return Err(AppError::AlreadyInitialized {\n    39→            path: workspace_root,\n    40→        });\n    41→    }\n    42→\n    43→    if workspace_root.exists() {\n    44→        return Err(AppError::WorkspaceConflict {\n    45→            path: workspace_root,\n    46→        });\n    47→    }\n    48→\n    49→    let config = WorkspaceConfig::new(created_at);\n    50→    let rendered = FileSystem::render_workspace_config(&config)?;\n    51→    FileSystem::create_workspace(&workspace_root, &rendered, REQUIRED_WORKSPACE_DIRECTORIES)?;\n    52→\n    53→    Ok(WorkspaceInitialization {\n    54→        workspace_root,\n    55→        config,\n    56→    })\n    57→}\n    58→\n    59→pub fn load_workspace_config(base_dir: &Path) -> AppResult<WorkspaceConfig> {\n    60→    let raw = FileSystem::read_to_string(&workspace_config_path(base_dir))?;\n    61→    parse_workspace_config(&raw)\n    62→}\n    63→\n    64→pub fn ensure_supported_workspace_version(config: &WorkspaceConfig) -> AppResult<()> {\n    65→    if config.version != CURRENT_WORKSPACE_VERSION {\n    66→        return Err(AppError::UnsupportedWorkspaceVersion {\n    67→            version: config.version,\n    68→            supported: CURRENT_WORKSPACE_VERSION,\n    69→        });\n    70→    }\n    71→\n    72→    Ok(())\n    73→}\n    74→\n    75→pub fn resolve_active_project(base_dir: &Path) -> AppResult<ProjectId> {\n    76→    let _ = EffectiveConfig::load(base_dir)?;\n    77→    let active_project = FileSystem::read_active_project(&workspace_root(base_dir))?\n    78→        .ok_or(AppError::NoActiveProject)?;\n    79→    let project_id = ProjectId::new(active_project)?;\n    80→    validate_project_exists(base_dir, &project_id)?;\n    81→    Ok(project_id)\n    82→}\n    83→\n    84→pub fn set_active_project(base_dir: &Path, project_id: &ProjectId) -> AppResult<()> {\n    85→    let _ = EffectiveConfig::load(base_dir)?;\n    86→    validate_project_exists(base_dir, project_id)?;\n    87→    FileSystem::write_active_project(&workspace_root(base_dir), project_id.as_str())\n    88→}\n    89→\n    90→pub(crate) fn parse_workspace_config(raw: &str) -> AppResult<WorkspaceConfig> {\n    91→    let config: WorkspaceConfig = toml::from_str(raw)?;\n    92→    ensure_supported_workspace_version(&config)?;\n    93→    Ok(config)\n    94→}\n    95→\n    96→pub(crate) fn workspace_root(base_dir: &Path) -> PathBuf {\n    97→    base_dir.join(WORKSPACE_DIR)\n    98→}\n    99→\n   100→pub(crate) fn workspace_config_path(base_dir: &Path) -> PathBuf {\n   101→    workspace_root(base_dir).join(WORKSPACE_CONFIG_FILE)\n   102→}\n   103→\n   104→fn validate_project_exists(base_dir: &Path, project_id: &ProjectId) -> AppResult<()> {\n   105→    let project_root = workspace_root(base_dir)\n   106→        .join(PROJECTS_DIR)\n   107→        .join(project_id.as_str());\n   108→    if !project_root.is_dir() {\n   109→        return Err(AppError::ProjectNotFound {\n   110→            project_id: project_id.to_string(),\n   111→        });\n   112→    }\n   113→    let config_path = project_root.join(PROJECT_CONFIG_FILE);\n   114→    if !config_path.is_file() {\n   115→        return Err(AppError::CorruptRecord {\n   116→            file: format!(\"projects/{}/project.toml\", project_id),\n   117→            details: \"project directory exists but canonical project.toml is missing\".to_owned(),\n   118→        });\n   119→    }\n   120→    // Deserialize as the canonical ProjectRecord to validate both TOML syntax\n   121→    // and structural completeness. This catches corruption early so that\n   122→    // commands resolving the active project fail fast instead of silently\n   123→    // operating on corrupt canonical state (e.g. missing required fields).\n   124→    let raw = std::fs::read_to_string(&config_path).map_err(|e| AppError::CorruptRecord {\n   125→        file: format!(\"projects/{}/project.toml\", project_id),\n   126→        details: format!(\"cannot read project.toml: {}\", e),\n   127→    })?;\n   128→    let _: crate::contexts::project_run_record::model::ProjectRecord = toml::from_str(&raw)\n   129→        .map_err(|e| AppError::CorruptRecord {\n   130→            file: format!(\"projects/{}/project.toml\", project_id),\n   131→            details: format!(\"project.toml has invalid canonical structure: {}\", e),\n   132→        })?;\n   133→    Ok(())\n   134→}\n   135→"}]},"parent_tool_use_id":"toolu_01B1RfMwbw1gwGPfFG4aoZxB","session_id":"36dfa1de-6185-4dcd-ac73-de5f18bf85fd","uuid":"d1859f77-e6eb-4592-90f1-150bcab6b618"}
