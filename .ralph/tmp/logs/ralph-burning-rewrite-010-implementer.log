{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01JmfZ643c8XpyyrxpVXqDSG","type":"tool_result","content":"   375→\n   376→/// Deterministic canned payloads for requirements contracts.\n   377→fn canned_requirements_payload(label: &str) -> serde_json::Value {\n   378→    if label.contains(\"question_set\") {\n   379→        json!({\n   380→            \"questions\": []\n   381→        })\n   382→    } else if label.contains(\"requirements_draft\") {\n   383→        json!({\n   384→            \"problem_summary\": \"Stub requirements draft\",\n   385→            \"goals\": [\"Deliver the feature\"],\n   386→            \"non_goals\": [],\n   387→            \"constraints\": [],\n   388→            \"acceptance_criteria\": [\"Feature works as specified\"],\n   389→            \"risks_or_open_questions\": [],\n   390→            \"recommended_flow\": \"standard\"\n   391→        })\n   392→    } else if label.contains(\"requirements_review\") {\n   393→        json!({\n   394→            \"outcome\": \"approved\",\n   395→            \"evidence\": [\"Stub review evidence\"],\n   396→            \"findings\": [],\n   397→            \"follow_ups\": []\n   398→        })\n   399→    } else if label.contains(\"project_seed\") {\n   400→        json!({\n   401→            \"project_id\": \"stub-project\",\n   402→            \"project_name\": \"Stub Project\",\n   403→            \"flow\": \"standard\",\n   404→            \"prompt_body\": \"Stub prompt body for the project.\",\n   405→            \"handoff_summary\": \"Stub handoff summary.\",\n   406→            \"follow_ups\": []\n   407→        })\n   408→    } else {\n   409→        json!({\n   410→            \"stub\": true,\n   411→            \"label\": label\n   412→        })\n   413→    }\n   414→}\n   415→"}]},"parent_tool_use_id":null,"session_id":"36dfa1de-6185-4dcd-ac73-de5f18bf85fd","uuid":"e300990c-f4eb-4747-b285-ecfcee511bde","tool_use_result":{"type":"text","file":{"filePath":"/root/new-ralph-burning/ralph-burning-rewrite/src/adapters/stub_backend.rs","content":"\n/// Deterministic canned payloads for requirements contracts.\nfn canned_requirements_payload(label: &str) -> serde_json::Value {\n    if label.contains(\"question_set\") {\n        json!({\n            \"questions\": []\n        })\n    } else if label.contains(\"requirements_draft\") {\n        json!({\n            \"problem_summary\": \"Stub requirements draft\",\n            \"goals\": [\"Deliver the feature\"],\n            \"non_goals\": [],\n            \"constraints\": [],\n            \"acceptance_criteria\": [\"Feature works as specified\"],\n            \"risks_or_open_questions\": [],\n            \"recommended_flow\": \"standard\"\n        })\n    } else if label.contains(\"requirements_review\") {\n        json!({\n            \"outcome\": \"approved\",\n            \"evidence\": [\"Stub review evidence\"],\n            \"findings\": [],\n            \"follow_ups\": []\n        })\n    } else if label.contains(\"project_seed\") {\n        json!({\n            \"project_id\": \"stub-project\",\n            \"project_name\": \"Stub Project\",\n            \"flow\": \"standard\",\n            \"prompt_body\": \"Stub prompt body for the project.\",\n            \"handoff_summary\": \"Stub handoff summary.\",\n            \"follow_ups\": []\n        })\n    } else {\n        json!({\n            \"stub\": true,\n            \"label\": label\n        })\n    }\n}\n","numLines":41,"startLine":375,"totalLines":415}}}
