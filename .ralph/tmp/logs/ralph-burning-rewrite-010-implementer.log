{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01R1sWbTFjzWk389We6vmeF1","type":"tool_result","content":"     1→use std::collections::{HashMap, HashSet};\n     2→use std::sync::atomic::{AtomicU32, Ordering};\n     3→use std::sync::{Arc, Mutex};\n     4→use std::time::Duration;\n     5→\n     6→use chrono::Utc;\n     7→use serde_json::{json, Value};\n     8→\n     9→use crate::contexts::agent_execution::model::{\n    10→    InvocationEnvelope, InvocationMetadata, InvocationRequest, RawOutputReference, TokenCounts,\n    11→};\n    12→use crate::contexts::agent_execution::service::AgentExecutionPort;\n    13→use crate::shared::domain::{FailureClass, SessionPolicy, StageId};\n    14→use crate::shared::error::{AppError, AppResult};\n    15→\n    16→#[derive(Clone)]\n    17→pub struct StubBackendAdapter {\n    18→    delay: Duration,\n    19→    available: bool,\n    20→    unsupported_stages: HashSet<StageId>,\n    21→    /// Stages that pass preflight but fail during invocation (for testing).\n    22→    fail_invoke_stages: HashSet<StageId>,\n    23→    transient_failure_limits: HashMap<StageId, u32>,\n    24→    transient_failure_counters: HashMap<StageId, Arc<AtomicU32>>,\n    25→    stage_payload_overrides: Arc<Mutex<HashMap<StageId, Vec<Value>>>>,\n    26→    stage_payload_counters: HashMap<StageId, Arc<AtomicU32>>,\n    27→    cancelled_invocations: Arc<Mutex<Vec<String>>>,\n    28→}\n    29→\n    30→impl Default for StubBackendAdapter {\n    31→    fn default() -> Self {\n    32→        Self {\n    33→            delay: Duration::from_millis(0),\n    34→            available: true,\n    35→            unsupported_stages: HashSet::new(),\n    36→            fail_invoke_stages: HashSet::new(),\n    37→            transient_failure_limits: HashMap::new(),\n    38→            transient_failure_counters: HashMap::new(),\n    39→            stage_payload_overrides: Arc::new(Mutex::new(HashMap::new())),\n    40→            stage_payload_counters: HashMap::new(),\n    41→            cancelled_invocations: Arc::new(Mutex::new(Vec::new())),\n    42→        }\n    43→    }\n    44→}\n    45→\n    46→impl StubBackendAdapter {\n    47→    pub fn with_delay(mut self, delay: Duration) -> Self {\n    48→        self.delay = delay;\n    49→        self\n    50→    }\n    51→\n    52→    pub fn unavailable(mut self) -> Self {\n    53→        self.available = false;\n    54→        self\n    55→    }\n    56→\n    57→    pub fn without_stage_support(mut self, stage_id: StageId) -> Self {\n    58→        self.unsupported_stages.insert(stage_id);\n    59→        self\n    60→    }\n    61→\n    62→    /// Configure a stage to pass preflight but fail during invocation.\n    63→    pub fn with_invoke_failure(mut self, stage_id: StageId) -> Self {\n    64→        self.fail_invoke_stages.insert(stage_id);\n    65→        self\n    66→    }\n    67→\n    68→    /// Configure a stage to fail the first N invocations, then succeed.\n    69→    pub fn with_transient_failure(mut self, stage_id: StageId, fail_count: u32) -> Self {\n    70→        self.transient_failure_limits.insert(stage_id, fail_count);\n    71→        self.transient_failure_counters\n    72→            .insert(stage_id, Arc::new(AtomicU32::new(0)));\n    73→        self\n    74→    }\n    75→\n    76→    pub fn with_stage_payload(self, stage_id: StageId, payload: Value) -> Self {\n    77→        self.with_stage_payload_sequence(stage_id, vec![payload])\n    78→    }\n    79→\n    80→    pub fn with_stage_payload_sequence(mut self, stage_id: StageId, payloads: Vec<Value>) -> Self {\n    81→        self.stage_payload_overrides\n    82→            .lock()\n    83→            .expect(\"stage payload override lock poisoned\")\n    84→            .insert(stage_id, payloads);\n    85→        self.stage_payload_counters\n    86→            .insert(stage_id, Arc::new(AtomicU32::new(0)));\n    87→        self\n    88→    }\n    89→\n    90→    pub fn cancelled_invocations(&self) -> Vec<String> {\n    91→        self.cancelled_invocations\n    92→            .lock()\n    93→            .expect(\"cancelled invocation lock poisoned\")\n    94→            .clone()\n    95→    }\n    96→\n    97→    fn payload_for_stage(&self, stage_id: StageId) -> Value {\n    98→        let overrides = self\n    99→            .stage_payload_overrides\n   100→            .lock()\n   101→            .expect(\"stage payload override lock poisoned\");\n   102→        let Some(payloads) = overrides.get(&stage_id) else {\n   103→            return canned_payload_for_stage(stage_id);\n   104→        };\n   105→        let Some(counter) = self.stage_payload_counters.get(&stage_id) else {\n   106→            return payloads\n   107→                .last()\n   108→                .cloned()\n   109→                .unwrap_or_else(|| canned_payload_for_stage(stage_id));\n   110→        };\n   111→        let idx = counter.fetch_add(1, Ordering::SeqCst) as usize;\n   112→        payloads\n   113→            .get(idx)\n   114→            .cloned()\n   115→            .or_else(|| payloads.last().cloned())\n   116→            .unwrap_or_else(|| canned_payload_for_stage(stage_id))\n   117→    }\n   118→}\n   119→\n   120→impl AgentExecutionPort for StubBackendAdapter {\n   121→    async fn check_capability(\n   122→        &self,\n   123→        backend: &crate::shared::domain::ResolvedBackendTarget,\n   124→        stage_contract: &crate::contexts::workflow_composition::contracts::StageContract,\n   125→    ) -> AppResult<()> {\n   126→        if self.unsupported_stages.contains(&stage_contract.stage_id)\n   127→            || !backend.supports_stage(stage_contract.stage_id)\n   128→        {\n   129→            return Err(AppError::CapabilityMismatch {\n   130→                backend: backend.backend.family.to_string(),\n   131→                stage_id: stage_contract.stage_id,\n   132→                details: \"stub adapter does not support the requested stage\".to_owned(),\n   133→            });\n   134→        }\n   135→\n   136→        Ok(())\n   137→    }\n   138→\n   139→    async fn check_availability(\n   140→        &self,\n   141→        backend: &crate::shared::domain::ResolvedBackendTarget,\n   142→    ) -> AppResult<()> {\n   143→        if self.available {\n   144→            Ok(())\n   145→        } else {\n   146→            Err(AppError::BackendUnavailable {\n   147→                backend: backend.backend.family.to_string(),\n   148→                details: \"stub adapter configured as unavailable\".to_owned(),\n   149→            })\n   150→        }\n   151→    }\n   152→\n   153→    async fn invoke(&self, request: InvocationRequest) -> AppResult<InvocationEnvelope> {\n   154→        if request.cancellation_token.is_cancelled() {\n   155→            return Err(AppError::InvocationCancelled {\n   156→                backend: request.resolved_target.backend.family.to_string(),\n   157→                stage_id: request.stage_contract.stage_id,\n   158→            });\n   159→        }\n   160→\n   161→        if let Some(limit) = self\n   162→            .transient_failure_limits\n   163→            .get(&request.stage_contract.stage_id)\n   164→        {\n   165→            let counter = self\n   166→                .transient_failure_counters\n   167→                .get(&request.stage_contract.stage_id)\n   168→                .expect(\"transient failure counter missing\");\n   169→            let attempt = counter.fetch_add(1, Ordering::SeqCst) + 1;\n   170→            if attempt <= *limit {\n   171→                return Err(AppError::InvocationFailed {\n   172→                    backend: request.resolved_target.backend.family.to_string(),\n   173→                    stage_id: request.stage_contract.stage_id,\n   174→                    failure_class: FailureClass::TransportFailure,\n   175→                    details: format!(\n   176→                        \"stub adapter configured to fail invocation {attempt}/{limit} for this stage\"\n   177→                    ),\n   178→                });\n   179→            }\n   180→        }\n   181→\n   182→        if self\n   183→            .fail_invoke_stages\n   184→            .contains(&request.stage_contract.stage_id)\n   185→        {\n   186→            return Err(AppError::InvocationFailed {\n   187→                backend: request.resolved_target.backend.family.to_string(),\n   188→                stage_id: request.stage_contract.stage_id,\n   189→                failure_class: FailureClass::TransportFailure,\n   190→                details: \"stub adapter configured to fail invocation for this stage\".to_owned(),\n   191→            });\n   192→        }\n   193→\n   194→        if self.delay > Duration::from_millis(0) {\n   195→            tokio::select! {\n   196→                _ = request.cancellation_token.cancelled() => {\n   197→                    return Err(AppError::InvocationCancelled {\n   198→                        backend: request.resolved_target.backend.family.to_string(),\n   199→                        stage_id: request.stage_contract.stage_id,\n   200→                    });\n   201→                }\n   202→                _ = tokio::time::sleep(self.delay) => {}\n   203→            }\n   204→        }\n   205→\n   206→        let payload = self.payload_for_stage(request.stage_contract.stage_id);\n   207→        let raw_output = serde_json::to_string_pretty(&payload)?;\n   208→        let prompt_token_count = count_tokens(&request.payload.prompt);\n   209→        let completion_token_count = count_tokens(&raw_output);\n   210→        let prompt_tokens = Some(prompt_token_count);\n   211→        let completion_tokens = Some(completion_token_count);\n   212→        let total_tokens = Some(prompt_token_count + completion_token_count);\n   213→\n   214→        let supports_reuse =\n   215→            request.role.allows_session_reuse() && request.resolved_target.supports_session_reuse();\n   216→        let session_reused = supports_reuse\n   217→            && matches!(request.session_policy, SessionPolicy::ReuseIfAllowed)\n   218→            && request.prior_session.is_some();\n   219→        let session_id = if supports_reuse {\n   220→            request\n   221→                .prior_session\n   222→                .as_ref()\n   223→                .map(|session| session.session_id.clone())\n   224→                .filter(|_| session_reused)\n   225→                .or_else(|| {\n   226→                    Some(format!(\n   227→                        \"stub-{}-{}\",\n   228→                        request.role.as_str(),\n   229→                        request.stage_contract.stage_id.as_str()\n   230→                    ))\n   231→                })\n   232→        } else {\n   233→            None\n   234→        };\n   235→\n   236→        Ok(InvocationEnvelope {\n   237→            raw_output_reference: RawOutputReference::Inline(raw_output),\n   238→            parsed_payload: serde_json::Value::Null,\n   239→            metadata: InvocationMetadata {\n   240→                invocation_id: request.invocation_id,\n   241→                duration: Duration::from_millis(0),\n   242→                token_counts: TokenCounts {\n   243→                    prompt_tokens,\n   244→                    completion_tokens,\n   245→                    total_tokens,\n   246→                },\n   247→                backend_used: request.resolved_target.backend,\n   248→                model_used: request.resolved_target.model,\n   249→                attempt_number: request.attempt_number,\n   250→                session_id,\n   251→                session_reused,\n   252→            },\n   253→            timestamp: Utc::now(),\n   254→        })\n   255→    }\n   256→\n   257→    async fn cancel(&self, invocation_id: &str) -> AppResult<()> {\n   258→        self.cancelled_invocations\n   259→            .lock()\n   260→            .expect(\"cancelled invocation lock poisoned\")\n   261→            .push(invocation_id.to_owned());\n   262→        Ok(())\n   263→    }\n   264→}\n   265→\n   266→fn count_tokens(contents: &str) -> u32 {\n   267→    contents.split_whitespace().count() as u32\n   268→}\n   269→\n   270→fn canned_payload_for_stage(stage_id: StageId) -> serde_json::Value {\n   271→    match stage_id {\n   272→        StageId::PromptReview | StageId::Planning | StageId::DocsPlan | StageId::CiPlan => json!({\n   273→            \"problem_framing\": format!(\"Stub planning output for {}\", stage_id.display_name()),\n   274→            \"assumptions_or_open_questions\": [\n   275→                format!(\"Assumption captured for {}\", stage_id.as_str())\n   276→            ],\n   277→            \"proposed_work\": [\n   278→                {\n   279→                    \"order\": 1,\n   280→                    \"summary\": format!(\"Complete {}\", stage_id.display_name()),\n   281→                    \"details\": \"Deterministic stub work item.\"\n   282→                }\n   283→            ],\n   284→            \"readiness\": {\n   285→                \"ready\": true,\n   286→                \"risks\": []\n   287→            }\n   288→        }),\n   289→        StageId::Implementation\n   290→        | StageId::PlanAndImplement\n   291→        | StageId::ApplyFixes\n   292→        | StageId::DocsUpdate\n   293→        | StageId::CiUpdate => json!({\n   294→            \"change_summary\": format!(\"Stub execution output for {}\", stage_id.display_name()),\n   295→            \"steps\": [\n   296→                {\n   297→                    \"order\": 1,\n   298→                    \"description\": format!(\"Execute {}\", stage_id.as_str()),\n   299→                    \"status\": \"completed\"\n   300→                }\n   301→            ],\n   302→            \"validation_evidence\": [\"stub adapter deterministic evidence\"],\n   303→            \"outstanding_risks\": []\n   304→        }),\n   305→        StageId::Qa\n   306→        | StageId::Review\n   307→        | StageId::CompletionPanel\n   308→        | StageId::AcceptanceQa\n   309→        | StageId::FinalReview\n   310→        | StageId::DocsValidation\n   311→        | StageId::CiValidation => json!({\n   312→            \"outcome\": \"approved\",\n   313→            \"evidence\": [format!(\"Stub validation output for {}\", stage_id.display_name())],\n   314→            \"findings_or_gaps\": [],\n   315→            \"follow_up_or_amendments\": []\n   316→        }),\n   317→    }\n   318→}\n   319→"}]},"parent_tool_use_id":null,"session_id":"36dfa1de-6185-4dcd-ac73-de5f18bf85fd","uuid":"60db8674-702f-4c0f-b7b3-fab3a74ec0d0","tool_use_result":{"type":"text","file":{"filePath":"/root/new-ralph-burning/ralph-burning-rewrite/src/adapters/stub_backend.rs","content":"use std::collections::{HashMap, HashSet};\nuse std::sync::atomic::{AtomicU32, Ordering};\nuse std::sync::{Arc, Mutex};\nuse std::time::Duration;\n\nuse chrono::Utc;\nuse serde_json::{json, Value};\n\nuse crate::contexts::agent_execution::model::{\n    InvocationEnvelope, InvocationMetadata, InvocationRequest, RawOutputReference, TokenCounts,\n};\nuse crate::contexts::agent_execution::service::AgentExecutionPort;\nuse crate::shared::domain::{FailureClass, SessionPolicy, StageId};\nuse crate::shared::error::{AppError, AppResult};\n\n#[derive(Clone)]\npub struct StubBackendAdapter {\n    delay: Duration,\n    available: bool,\n    unsupported_stages: HashSet<StageId>,\n    /// Stages that pass preflight but fail during invocation (for testing).\n    fail_invoke_stages: HashSet<StageId>,\n    transient_failure_limits: HashMap<StageId, u32>,\n    transient_failure_counters: HashMap<StageId, Arc<AtomicU32>>,\n    stage_payload_overrides: Arc<Mutex<HashMap<StageId, Vec<Value>>>>,\n    stage_payload_counters: HashMap<StageId, Arc<AtomicU32>>,\n    cancelled_invocations: Arc<Mutex<Vec<String>>>,\n}\n\nimpl Default for StubBackendAdapter {\n    fn default() -> Self {\n        Self {\n            delay: Duration::from_millis(0),\n            available: true,\n            unsupported_stages: HashSet::new(),\n            fail_invoke_stages: HashSet::new(),\n            transient_failure_limits: HashMap::new(),\n            transient_failure_counters: HashMap::new(),\n            stage_payload_overrides: Arc::new(Mutex::new(HashMap::new())),\n            stage_payload_counters: HashMap::new(),\n            cancelled_invocations: Arc::new(Mutex::new(Vec::new())),\n        }\n    }\n}\n\nimpl StubBackendAdapter {\n    pub fn with_delay(mut self, delay: Duration) -> Self {\n        self.delay = delay;\n        self\n    }\n\n    pub fn unavailable(mut self) -> Self {\n        self.available = false;\n        self\n    }\n\n    pub fn without_stage_support(mut self, stage_id: StageId) -> Self {\n        self.unsupported_stages.insert(stage_id);\n        self\n    }\n\n    /// Configure a stage to pass preflight but fail during invocation.\n    pub fn with_invoke_failure(mut self, stage_id: StageId) -> Self {\n        self.fail_invoke_stages.insert(stage_id);\n        self\n    }\n\n    /// Configure a stage to fail the first N invocations, then succeed.\n    pub fn with_transient_failure(mut self, stage_id: StageId, fail_count: u32) -> Self {\n        self.transient_failure_limits.insert(stage_id, fail_count);\n        self.transient_failure_counters\n            .insert(stage_id, Arc::new(AtomicU32::new(0)));\n        self\n    }\n\n    pub fn with_stage_payload(self, stage_id: StageId, payload: Value) -> Self {\n        self.with_stage_payload_sequence(stage_id, vec![payload])\n    }\n\n    pub fn with_stage_payload_sequence(mut self, stage_id: StageId, payloads: Vec<Value>) -> Self {\n        self.stage_payload_overrides\n            .lock()\n            .expect(\"stage payload override lock poisoned\")\n            .insert(stage_id, payloads);\n        self.stage_payload_counters\n            .insert(stage_id, Arc::new(AtomicU32::new(0)));\n        self\n    }\n\n    pub fn cancelled_invocations(&self) -> Vec<String> {\n        self.cancelled_invocations\n            .lock()\n            .expect(\"cancelled invocation lock poisoned\")\n            .clone()\n    }\n\n    fn payload_for_stage(&self, stage_id: StageId) -> Value {\n        let overrides = self\n            .stage_payload_overrides\n            .lock()\n            .expect(\"stage payload override lock poisoned\");\n        let Some(payloads) = overrides.get(&stage_id) else {\n            return canned_payload_for_stage(stage_id);\n        };\n        let Some(counter) = self.stage_payload_counters.get(&stage_id) else {\n            return payloads\n                .last()\n                .cloned()\n                .unwrap_or_else(|| canned_payload_for_stage(stage_id));\n        };\n        let idx = counter.fetch_add(1, Ordering::SeqCst) as usize;\n        payloads\n            .get(idx)\n            .cloned()\n            .or_else(|| payloads.last().cloned())\n            .unwrap_or_else(|| canned_payload_for_stage(stage_id))\n    }\n}\n\nimpl AgentExecutionPort for StubBackendAdapter {\n    async fn check_capability(\n        &self,\n        backend: &crate::shared::domain::ResolvedBackendTarget,\n        stage_contract: &crate::contexts::workflow_composition::contracts::StageContract,\n    ) -> AppResult<()> {\n        if self.unsupported_stages.contains(&stage_contract.stage_id)\n            || !backend.supports_stage(stage_contract.stage_id)\n        {\n            return Err(AppError::CapabilityMismatch {\n                backend: backend.backend.family.to_string(),\n                stage_id: stage_contract.stage_id,\n                details: \"stub adapter does not support the requested stage\".to_owned(),\n            });\n        }\n\n        Ok(())\n    }\n\n    async fn check_availability(\n        &self,\n        backend: &crate::shared::domain::ResolvedBackendTarget,\n    ) -> AppResult<()> {\n        if self.available {\n            Ok(())\n        } else {\n            Err(AppError::BackendUnavailable {\n                backend: backend.backend.family.to_string(),\n                details: \"stub adapter configured as unavailable\".to_owned(),\n            })\n        }\n    }\n\n    async fn invoke(&self, request: InvocationRequest) -> AppResult<InvocationEnvelope> {\n        if request.cancellation_token.is_cancelled() {\n            return Err(AppError::InvocationCancelled {\n                backend: request.resolved_target.backend.family.to_string(),\n                stage_id: request.stage_contract.stage_id,\n            });\n        }\n\n        if let Some(limit) = self\n            .transient_failure_limits\n            .get(&request.stage_contract.stage_id)\n        {\n            let counter = self\n                .transient_failure_counters\n                .get(&request.stage_contract.stage_id)\n                .expect(\"transient failure counter missing\");\n            let attempt = counter.fetch_add(1, Ordering::SeqCst) + 1;\n            if attempt <= *limit {\n                return Err(AppError::InvocationFailed {\n                    backend: request.resolved_target.backend.family.to_string(),\n                    stage_id: request.stage_contract.stage_id,\n                    failure_class: FailureClass::TransportFailure,\n                    details: format!(\n                        \"stub adapter configured to fail invocation {attempt}/{limit} for this stage\"\n                    ),\n                });\n            }\n        }\n\n        if self\n            .fail_invoke_stages\n            .contains(&request.stage_contract.stage_id)\n        {\n            return Err(AppError::InvocationFailed {\n                backend: request.resolved_target.backend.family.to_string(),\n                stage_id: request.stage_contract.stage_id,\n                failure_class: FailureClass::TransportFailure,\n                details: \"stub adapter configured to fail invocation for this stage\".to_owned(),\n            });\n        }\n\n        if self.delay > Duration::from_millis(0) {\n            tokio::select! {\n                _ = request.cancellation_token.cancelled() => {\n                    return Err(AppError::InvocationCancelled {\n                        backend: request.resolved_target.backend.family.to_string(),\n                        stage_id: request.stage_contract.stage_id,\n                    });\n                }\n                _ = tokio::time::sleep(self.delay) => {}\n            }\n        }\n\n        let payload = self.payload_for_stage(request.stage_contract.stage_id);\n        let raw_output = serde_json::to_string_pretty(&payload)?;\n        let prompt_token_count = count_tokens(&request.payload.prompt);\n        let completion_token_count = count_tokens(&raw_output);\n        let prompt_tokens = Some(prompt_token_count);\n        let completion_tokens = Some(completion_token_count);\n        let total_tokens = Some(prompt_token_count + completion_token_count);\n\n        let supports_reuse =\n            request.role.allows_session_reuse() && request.resolved_target.supports_session_reuse();\n        let session_reused = supports_reuse\n            && matches!(request.session_policy, SessionPolicy::ReuseIfAllowed)\n            && request.prior_session.is_some();\n        let session_id = if supports_reuse {\n            request\n                .prior_session\n                .as_ref()\n                .map(|session| session.session_id.clone())\n                .filter(|_| session_reused)\n                .or_else(|| {\n                    Some(format!(\n                        \"stub-{}-{}\",\n                        request.role.as_str(),\n                        request.stage_contract.stage_id.as_str()\n                    ))\n                })\n        } else {\n            None\n        };\n\n        Ok(InvocationEnvelope {\n            raw_output_reference: RawOutputReference::Inline(raw_output),\n            parsed_payload: serde_json::Value::Null,\n            metadata: InvocationMetadata {\n                invocation_id: request.invocation_id,\n                duration: Duration::from_millis(0),\n                token_counts: TokenCounts {\n                    prompt_tokens,\n                    completion_tokens,\n                    total_tokens,\n                },\n                backend_used: request.resolved_target.backend,\n                model_used: request.resolved_target.model,\n                attempt_number: request.attempt_number,\n                session_id,\n                session_reused,\n            },\n            timestamp: Utc::now(),\n        })\n    }\n\n    async fn cancel(&self, invocation_id: &str) -> AppResult<()> {\n        self.cancelled_invocations\n            .lock()\n            .expect(\"cancelled invocation lock poisoned\")\n            .push(invocation_id.to_owned());\n        Ok(())\n    }\n}\n\nfn count_tokens(contents: &str) -> u32 {\n    contents.split_whitespace().count() as u32\n}\n\nfn canned_payload_for_stage(stage_id: StageId) -> serde_json::Value {\n    match stage_id {\n        StageId::PromptReview | StageId::Planning | StageId::DocsPlan | StageId::CiPlan => json!({\n            \"problem_framing\": format!(\"Stub planning output for {}\", stage_id.display_name()),\n            \"assumptions_or_open_questions\": [\n                format!(\"Assumption captured for {}\", stage_id.as_str())\n            ],\n            \"proposed_work\": [\n                {\n                    \"order\": 1,\n                    \"summary\": format!(\"Complete {}\", stage_id.display_name()),\n                    \"details\": \"Deterministic stub work item.\"\n                }\n            ],\n            \"readiness\": {\n                \"ready\": true,\n                \"risks\": []\n            }\n        }),\n        StageId::Implementation\n        | StageId::PlanAndImplement\n        | StageId::ApplyFixes\n        | StageId::DocsUpdate\n        | StageId::CiUpdate => json!({\n            \"change_summary\": format!(\"Stub execution output for {}\", stage_id.display_name()),\n            \"steps\": [\n                {\n                    \"order\": 1,\n                    \"description\": format!(\"Execute {}\", stage_id.as_str()),\n                    \"status\": \"completed\"\n                }\n            ],\n            \"validation_evidence\": [\"stub adapter deterministic evidence\"],\n            \"outstanding_risks\": []\n        }),\n        StageId::Qa\n        | StageId::Review\n        | StageId::CompletionPanel\n        | StageId::AcceptanceQa\n        | StageId::FinalReview\n        | StageId::DocsValidation\n        | StageId::CiValidation => json!({\n            \"outcome\": \"approved\",\n            \"evidence\": [format!(\"Stub validation output for {}\", stage_id.display_name())],\n            \"findings_or_gaps\": [],\n            \"follow_up_or_amendments\": []\n        }),\n    }\n}\n","numLines":319,"startLine":1,"totalLines":319}}}
