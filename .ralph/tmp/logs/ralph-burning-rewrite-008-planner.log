{"type":"item.completed","item":{"id":"item_50","type":"command_execution","command":"/run/current-system/sw/bin/bash -lc \"sed -n '1,220p' ralph-burning-rewrite/src/contexts/project_run_record/service.rs\"","aggregated_output":"use std::path::Path;\n\nuse chrono::{DateTime, Utc};\n\nuse crate::shared::domain::{FlowPreset, ProjectId};\nuse crate::shared::error::{AppError, AppResult};\n\nuse super::journal;\nuse super::model::{\n    ArtifactRecord, JournalEvent, JournalEventType, PayloadRecord, ProjectDetail, ProjectListEntry,\n    ProjectRecord, ProjectStatusSummary, RunSnapshot, RuntimeLogEntry, SessionStore,\n};\nuse super::queries::{self, RunHistoryView, RunStatusView, RunTailView};\n\n/// Port for reading and writing project records.\npub trait ProjectStorePort {\n    fn project_exists(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<bool>;\n    fn read_project_record(\n        &self,\n        base_dir: &Path,\n        project_id: &ProjectId,\n    ) -> AppResult<ProjectRecord>;\n    fn list_project_ids(&self, base_dir: &Path) -> AppResult<Vec<ProjectId>>;\n\n    /// Stage a project for deletion: makes it invisible to list/show but\n    /// keeps data on disk for potential rollback.\n    fn stage_delete(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<()>;\n\n    /// Finalize a staged delete: permanently removes the project data.\n    fn commit_delete(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<()>;\n\n    /// Roll back a staged delete: restores the project to its canonical path.\n    fn rollback_delete(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<()>;\n\n    /// Atomically stage and commit a new project. If any step fails,\n    /// the project must not be visible to list/show.\n    fn create_project_atomic(\n        &self,\n        base_dir: &Path,\n        record: &ProjectRecord,\n        prompt_contents: &str,\n        run_snapshot: &RunSnapshot,\n        initial_journal_line: &str,\n        sessions: &SessionStore,\n    ) -> AppResult<()>;\n}\n\n/// Port for reading and appending journal events.\npub trait JournalStorePort {\n    fn read_journal(&self, base_dir: &Path, project_id: &ProjectId)\n        -> AppResult<Vec<JournalEvent>>;\n    fn append_event(&self, base_dir: &Path, project_id: &ProjectId, line: &str) -> AppResult<()>;\n}\n\n/// Port for reading payload and artifact durable history.\npub trait ArtifactStorePort {\n    fn list_payloads(\n        &self,\n        base_dir: &Path,\n        project_id: &ProjectId,\n    ) -> AppResult<Vec<PayloadRecord>>;\n    fn list_artifacts(\n        &self,\n        base_dir: &Path,\n        project_id: &ProjectId,\n    ) -> AppResult<Vec<ArtifactRecord>>;\n}\n\n/// Port for reading runtime logs (separate from durable history).\npub trait RuntimeLogStorePort {\n    fn read_runtime_logs(\n        &self,\n        base_dir: &Path,\n        project_id: &ProjectId,\n    ) -> AppResult<Vec<RuntimeLogEntry>>;\n}\n\n/// Port for reading/writing the run snapshot.\npub trait RunSnapshotPort {\n    fn read_run_snapshot(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<RunSnapshot>;\n}\n\n/// Port for writing the run snapshot atomically.\npub trait RunSnapshotWritePort {\n    fn write_run_snapshot(\n        &self,\n        base_dir: &Path,\n        project_id: &ProjectId,\n        snapshot: &RunSnapshot,\n    ) -> AppResult<()>;\n}\n\n/// Port for writing payload and artifact records atomically as a pair.\npub trait PayloadArtifactWritePort {\n    fn write_payload_artifact_pair(\n        &self,\n        base_dir: &Path,\n        project_id: &ProjectId,\n        payload: &PayloadRecord,\n        artifact: &ArtifactRecord,\n    ) -> AppResult<()>;\n\n    /// Remove a previously written payload/artifact pair.\n    /// Used to roll back a stage commit when journal or snapshot persistence\n    /// fails after the pair was already written.\n    fn remove_payload_artifact_pair(\n        &self,\n        base_dir: &Path,\n        project_id: &ProjectId,\n        payload_id: &str,\n        artifact_id: &str,\n    ) -> AppResult<()>;\n}\n\n/// Port for appending runtime log entries (best-effort, not durable history).\npub trait RuntimeLogWritePort {\n    fn append_runtime_log(\n        &self,\n        base_dir: &Path,\n        project_id: &ProjectId,\n        entry: &RuntimeLogEntry,\n    ) -> AppResult<()>;\n}\n\n/// Port for reading/writing/clearing the active project pointer.\npub trait ActiveProjectPort {\n    fn read_active_project_id(&self, base_dir: &Path) -> AppResult<Option<String>>;\n    fn clear_active_project(&self, base_dir: &Path) -> AppResult<()>;\n    fn write_active_project(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<()>;\n}\n\n/// Input for the `project create` use case.\npub struct CreateProjectInput {\n    pub id: ProjectId,\n    pub name: String,\n    pub flow: FlowPreset,\n    pub prompt_path: String,\n    pub prompt_contents: String,\n    pub prompt_hash: String,\n    pub created_at: DateTime<Utc>,\n}\n\n/// Create a new project with all canonical files.\npub fn create_project(\n    store: &dyn ProjectStorePort,\n    journal_store: &dyn JournalStorePort,\n    base_dir: &Path,\n    input: CreateProjectInput,\n) -> AppResult<ProjectRecord> {\n    // Check for duplicate project ID\n    if store.project_exists(base_dir, &input.id)? {\n        return Err(AppError::DuplicateProject {\n            project_id: input.id.to_string(),\n        });\n    }\n\n    let record = ProjectRecord {\n        id: input.id.clone(),\n        name: input.name,\n        flow: input.flow,\n        prompt_reference: \"prompt.md\".to_owned(),\n        prompt_hash: input.prompt_hash,\n        created_at: input.created_at,\n        status_summary: ProjectStatusSummary::Created,\n    };\n\n    let run_snapshot = RunSnapshot::initial();\n    let sessions = SessionStore::empty();\n\n    // Create the initial journal event\n    let initial_event = JournalEvent {\n        sequence: 1,\n        timestamp: input.created_at,\n        event_type: JournalEventType::ProjectCreated,\n        details: serde_json::json!({\n            \"project_id\": record.id.as_str(),\n            \"flow\": record.flow.as_str(),\n        }),\n    };\n    let journal_line = journal::serialize_event(&initial_event)?;\n\n    // Atomic creation: all files or nothing\n    store.create_project_atomic(\n        base_dir,\n        &record,\n        &input.prompt_contents,\n        &run_snapshot,\n        &journal_line,\n        &sessions,\n    )?;\n\n    // create_project_atomic writes the journal as part of the atomic init,\n    // but we don't call journal_store.append_event here because the atomic\n    // creation already wrote the initial journal line. The journal_store\n    // parameter is kept for interface consistency and future use.\n    let _ = journal_store;\n\n    Ok(record)\n}\n\n/// List all projects with summary data.\npub fn list_projects(\n    store: &dyn ProjectStorePort,\n    active_port: &dyn ActiveProjectPort,\n    base_dir: &Path,\n) -> AppResult<Vec<ProjectListEntry>> {\n    let active_id = active_port.read_active_project_id(base_dir)?;\n    let project_ids = store.list_project_ids(base_dir)?;\n\n    let mut entries = Vec::new();\n    for pid in project_ids {\n        let record = store.read_project_record(base_dir, &pid)?;\n        let is_active = active_id.as_deref() == Some(pid.as_str());\n        entries.push(ProjectListEntry {\n            id: record.id,\n            name: record.name,\n            flow: record.flow,\n            status_summary: record.status_summary,\n            created_at: record.created_at,\n            is_active,\n","exit_code":0,"status":"completed"}}
{"type":"item.completed","item":{"id":"item_51","type":"agent_message","text":"# Feature: Completion Rounds, Late-Stage Acceptance, and Durable Amendments\n\n## Description\nApproved loop artifacts `001` through `007` and checkpoint history through `4b10f4e` show the rewrite has completed the roadmap through retry, remediation, pause/resume, and failure-class handling. The next missing slice is roadmap step 8. The current standard-flow engine already executes `completion_panel`, `acceptance_qa`, and `final_review`, but it still treats them as generic validation stages: `completion_rounds` never advances beyond `1`, `StageCursor::advance_completion_round` and `JournalEventType::CompletionRoundAdvanced` are unused, `AmendmentQueued` and `processed_count` are unused, `projects/<id>/amendments/` is only scaffolding, and a run can currently complete while `amendment_queue.pending` is non-empty. This feature should add the real late-stage state machine for the standard preset: completion-round advancement, durable amendment queue persistence/application, and stage-specific continue-vs-complete behavior for `completion_panel`, `acceptance_qa`, and `final_review`, without re-implementing loops 1-7 or enabling non-standard flows yet.\n\n## Acceptance Criteria\n- [ ] Loop-7 behavior remains unchanged for `qa` and `review`: their `RequestChanges` remediation path still advances work cycles directly back to `implementation`, and the new logic applies only to `completion_panel`, `acceptance_qa`, and `final_review`.\n- [ ] Late-stage transition rules are explicit and stage-specific: `completion_panel` `Approved` advances to `acceptance_qa`; `acceptance_qa` `Approved` advances to `final_review` when the flow definition enables final review and otherwise completes the run; `final_review` `Approved` completes the run; `Rejected` at any late stage fails the run terminally with `QaReviewOutcomeFailure`.\n- [ ] `ConditionallyApproved` or `RequestChanges` at any late stage does not silently proceed and does not terminally fail; after the late-stage payload/artifact pair is durably committed, the engine queues every `follow_up_or_amendments` item as a durable amendment, emits `amendment_queued` journal events, emits one `completion_round_advanced` journal event, and moves the cursor to `planning` for the next completion round.\n- [ ] On a `completion_round_advanced` transition, `StageCursor.completion_round` increments, `attempt` resets to `1`, the next stage becomes `planning`, and `cycle` stays unchanged at that boundary. `run.json.completion_rounds` tracks the highest round reached and remains monotonic independently of `cycle_history`.\n- [ ] When the next completion round successfully leaves `planning` and re-enters `implementation`, the engine emits `cycle_advanced`, increments the work-cycle number, and records the new cycle in `cycle_history`. Completion-round continuation must therefore advance completion round first and work cycle only when new implementation work actually begins.\n- [ ] Queued amendments are persisted under `projects/<id>/amendments/` using atomic writes and a typed canonical record that includes at least amendment id, source stage, source cycle, source completion round, body, and created timestamp. `run.json` stores the same queue in structured form; raw `serde_json::Value` placeholders are no longer the canonical queue model in this slice.\n- [ ] Pending queued amendments are injected into the next `planning` invocation in deterministic order. They are marked processed and removed from pending on-disk state only after the `planning` stage commit succeeds; planning invocation failure or planning commit failure must leave them pending and reusable on `run resume`.\n- [ ] `JournalEventType::CompletionRoundAdvanced` and `JournalEventType::AmendmentQueued` have concrete builders and are emitted in canonical order after the source late-stage commit. Public `run history`/`run tail` output includes those events without ever treating amendment files or runtime logs as durable history artifacts.\n- [ ] `run_completed` may be persisted only when both the structured amendment queue and the `amendments/` directory contain no pending items. A late-stage conditional approval must never allow a completed snapshot with leftover queued amendments.\n- [ ] `run resume` reconstructs pending amendments and the current completion round from canonical state and resumes from the first incomplete durable stage without duplicating already-processed amendments or losing queued ones.\n- [ ] Failure invariant: if amendment persistence fails before any `amendment_queued` event is committed, no queue entry becomes visible in `run.json` and no `completion_round_advanced` event is written.\n- [ ] Failure invariant: if some amendment files and `amendment_queued` events are durable but snapshot or cursor advancement fails afterward, those amendments remain pending and discoverable for resume; the run must end in a non-completed state with `active_run == null`.\n- [ ] Failure invariant: if completion is otherwise ready but pending amendments are detected during terminalization, completion is blocked and the run remains resumable; that guard must not delete, drain, or silently mark any pending amendment as processed.\n- [ ] Conformance and unit coverage are added for: completion-panel-driven continuation into round 2, acceptance-QA-driven continuation, final-review-driven continuation, terminal rejection at late stages, successful completion after a second round, resume with pending late-stage amendments, and the completion guard that blocks success while amendments remain queued.\n- [ ] `quick_dev`, `docs_change`, and `ci_improvement` remain unsupported in `run start` after this slice; this feature hardens only the standard-flow late-stage semantics.\n\n## Files to Modify/Create\n- `ralph-burning-rewrite/src/contexts/workflow_composition/engine.rs` - add late-stage transition table, completion-round advancement, planning restart, amendment injection/drain, and completion guard\n- `ralph-burning-rewrite/src/contexts/workflow_composition/mod.rs` - route acceptance/final-review behavior through flow-definition metadata instead of generic hard-coded assumptions\n- `ralph-burning-rewrite/src/shared/domain.rs` - make cursor round/cycle transitions explicit for late-stage restart boundaries\n- `ralph-burning-rewrite/src/contexts/project_run_record/model.rs` - add typed queued-amendment records and finalize journal event enum usage for completion-round/amendment events\n- `ralph-burning-rewrite/src/contexts/project_run_record/journal.rs` - add builders for `completion_round_advanced` and `amendment_queued`\n- `ralph-burning-rewrite/src/contexts/project_run_record/service.rs` - add ports/use-cases for reading, writing, draining, and reconciling durable amendment queue state\n- `ralph-burning-rewrite/src/adapters/fs.rs` - implement filesystem-backed amendment queue persistence under `projects/<id>/amendments/`\n- `ralph-burning-rewrite/src/shared/error.rs` - add explicit amendment-queue and completion-guard error variants\n- `ralph-burning-rewrite/tests/unit/workflow_engine_test.rs` - cover completion-round restarts, queue drain/apply behavior, and late-stage failure invariants\n- `ralph-burning-rewrite/tests/unit/journal_test.rs` - cover new journal event builders and ordering expectations\n- `ralph-burning-rewrite/tests/unit/adapter_contract_test.rs` - cover atomic amendment queue persistence and non-lossy failure behavior\n- `ralph-burning-rewrite/tests/cli.rs` - extend CLI-level assertions for round advancement, resume, and blocked completion\n- `ralph-burning-rewrite/tests/conformance/features/run_completion_rounds.feature` - add public scenarios for completion rounds, late-stage amendments, and blocked completion\n\n## Dependencies\n- Requires: Loop 7 (Retry, Remediation, Resume, and Failure Class Semantics)\n- Blocks: Non-standard preset execution on the shared engine (`quick_dev`, `docs_change`, `ci_improvement`)\n\n---"}}
