{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0135zok7FHC7Kcir2KZVFcpG","type":"tool_result","content":"     1→use std::path::Path;\n     2→\n     3→use chrono::{DateTime, Utc};\n     4→\n     5→use crate::shared::domain::{FlowPreset, ProjectId};\n     6→use crate::shared::error::{AppError, AppResult};\n     7→\n     8→use super::model::{\n     9→    ArtifactRecord, JournalEvent, JournalEventType, PayloadRecord,\n    10→    ProjectDetail, ProjectListEntry, ProjectRecord, ProjectStatusSummary,\n    11→    RunSnapshot, RuntimeLogEntry, SessionStore,\n    12→};\n    13→use super::journal;\n    14→use super::queries::{\n    15→    self, RunHistoryView, RunStatusView, RunTailView,\n    16→};\n    17→\n    18→/// Port for reading and writing project records.\n    19→pub trait ProjectStorePort {\n    20→    fn project_exists(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<bool>;\n    21→    fn read_project_record(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<ProjectRecord>;\n    22→    fn list_project_ids(&self, base_dir: &Path) -> AppResult<Vec<ProjectId>>;\n    23→\n    24→    /// Stage a project for deletion: makes it invisible to list/show but\n    25→    /// keeps data on disk for potential rollback.\n    26→    fn stage_delete(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<()>;\n    27→\n    28→    /// Finalize a staged delete: permanently removes the project data.\n    29→    fn commit_delete(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<()>;\n    30→\n    31→    /// Roll back a staged delete: restores the project to its canonical path.\n    32→    fn rollback_delete(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<()>;\n    33→\n    34→    /// Atomically stage and commit a new project. If any step fails,\n    35→    /// the project must not be visible to list/show.\n    36→    fn create_project_atomic(\n    37→        &self,\n    38→        base_dir: &Path,\n    39→        record: &ProjectRecord,\n    40→        prompt_contents: &str,\n    41→        run_snapshot: &RunSnapshot,\n    42→        initial_journal_line: &str,\n    43→        sessions: &SessionStore,\n    44→    ) -> AppResult<()>;\n    45→}\n    46→\n    47→/// Port for reading and appending journal events.\n    48→pub trait JournalStorePort {\n    49→    fn read_journal(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<Vec<JournalEvent>>;\n    50→    fn append_event(&self, base_dir: &Path, project_id: &ProjectId, line: &str) -> AppResult<()>;\n    51→}\n    52→\n    53→/// Port for reading payload and artifact durable history.\n    54→pub trait ArtifactStorePort {\n    55→    fn list_payloads(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<Vec<PayloadRecord>>;\n    56→    fn list_artifacts(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<Vec<ArtifactRecord>>;\n    57→}\n    58→\n    59→/// Port for reading runtime logs (separate from durable history).\n    60→pub trait RuntimeLogStorePort {\n    61→    fn read_runtime_logs(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<Vec<RuntimeLogEntry>>;\n    62→}\n    63→\n    64→/// Port for reading/writing the run snapshot.\n    65→pub trait RunSnapshotPort {\n    66→    fn read_run_snapshot(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<RunSnapshot>;\n    67→}\n    68→\n    69→/// Port for reading/writing/clearing the active project pointer.\n    70→pub trait ActiveProjectPort {\n    71→    fn read_active_project_id(&self, base_dir: &Path) -> AppResult<Option<String>>;\n    72→    fn clear_active_project(&self, base_dir: &Path) -> AppResult<()>;\n    73→    fn write_active_project(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<()>;\n    74→}\n    75→\n    76→/// Input for the `project create` use case.\n    77→pub struct CreateProjectInput {\n    78→    pub id: ProjectId,\n    79→    pub name: String,\n    80→    pub flow: FlowPreset,\n    81→    pub prompt_path: String,\n    82→    pub prompt_contents: String,\n    83→    pub prompt_hash: String,\n    84→    pub created_at: DateTime<Utc>,\n    85→}\n    86→\n    87→/// Create a new project with all canonical files.\n    88→pub fn create_project(\n    89→    store: &dyn ProjectStorePort,\n    90→    journal_store: &dyn JournalStorePort,\n    91→    base_dir: &Path,\n    92→    input: CreateProjectInput,\n    93→) -> AppResult<ProjectRecord> {\n    94→    // Check for duplicate project ID\n    95→    if store.project_exists(base_dir, &input.id)? {\n    96→        return Err(AppError::DuplicateProject {\n    97→            project_id: input.id.to_string(),\n    98→        });\n    99→    }\n   100→\n   101→    let record = ProjectRecord {\n   102→        id: input.id.clone(),\n   103→        name: input.name,\n   104→        flow: input.flow,\n   105→        prompt_reference: \"prompt.md\".to_owned(),\n   106→        prompt_hash: input.prompt_hash,\n   107→        created_at: input.created_at,\n   108→        status_summary: ProjectStatusSummary::Created,\n   109→    };\n   110→\n   111→    let run_snapshot = RunSnapshot::initial();\n   112→    let sessions = SessionStore::empty();\n   113→\n   114→    // Create the initial journal event\n   115→    let initial_event = JournalEvent {\n   116→        sequence: 1,\n   117→        timestamp: input.created_at,\n   118→        event_type: JournalEventType::ProjectCreated,\n   119→        details: serde_json::json!({\n   120→            \"project_id\": record.id.as_str(),\n   121→            \"flow\": record.flow.as_str(),\n   122→        }),\n   123→    };\n   124→    let journal_line = journal::serialize_event(&initial_event)?;\n   125→\n   126→    // Atomic creation: all files or nothing\n   127→    store.create_project_atomic(\n   128→        base_dir,\n   129→        &record,\n   130→        &input.prompt_contents,\n   131→        &run_snapshot,\n   132→        &journal_line,\n   133→        &sessions,\n   134→    )?;\n   135→\n   136→    // create_project_atomic writes the journal as part of the atomic init,\n   137→    // but we don't call journal_store.append_event here because the atomic\n   138→    // creation already wrote the initial journal line. The journal_store\n   139→    // parameter is kept for interface consistency and future use.\n   140→    let _ = journal_store;\n   141→\n   142→    Ok(record)\n   143→}\n   144→\n   145→/// List all projects with summary data.\n   146→pub fn list_projects(\n   147→    store: &dyn ProjectStorePort,\n   148→    active_port: &dyn ActiveProjectPort,\n   149→    base_dir: &Path,\n   150→) -> AppResult<Vec<ProjectListEntry>> {"}]},"parent_tool_use_id":"toolu_015umV9Ff8rGC1wuGDkBQWvr","session_id":"68f65612-956d-4383-9b3f-2ff2c684a050","uuid":"e125a914-e1a5-4f13-9d18-ac4a8f0bfab9"}
