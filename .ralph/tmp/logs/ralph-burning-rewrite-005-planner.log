fs::create_dir_all(workspace_root)?;\n    49→\n    50→        for directory in required_directories {\n    51→            fs::create_dir_all(workspace_root.join(directory))?;\n    52→        }\n    53→\n    54→        Self::write_atomic(&workspace_root.join(\"workspace.toml\"), workspace_config)?;\n    55→        Ok(())\n    56→    }\n    57→\n    58→    pub fn read_to_string(path: &Path) -> AppResult<String> {\n    59→        Ok(fs::read_to_string(path)?)\n    60→    }\n    61→\n    62→    pub fn write_atomic(path: &Path, contents: &str) -> AppResult<()> {\n    63→        let parent = path.parent().ok_or_else(|| {\n    64→            AppError::Io(std::io::Error::new(\n    65→                std::io::ErrorKind::InvalidInput,\n    66→                format!(\"path '{}' has no parent directory\", path.display()),\n    67→            ))\n    68→        })?;\n    69→        fs::create_dir_all(parent)?;\n    70→\n    71→        let timestamp = SystemTime::now()\n    72→            .duration_since(UNIX_EPOCH)\n    73→            .map(|duration| duration.as_nanos())\n    74→            .unwrap_or_default();\n    75→        let temp_path = parent.join(format!(\n    76→            \".{}.{}.{}.tmp\",\n    77→            path.file_name()\n    78→                .and_then(|value| value.to_str())\n    79→                .unwrap_or(\"workspace\"),\n    80→            std::process::id(),\n    81→            timestamp\n    82→        ));\n    83→\n    84→        let mut file = OpenOptions::new()\n    85→            .create_new(true)\n    86→            .write(true)\n    87→            .open(&temp_path)?;\n    88→        file.write_all(contents.as_bytes())?;\n    89→        file.sync_all()?;\n    90→        drop(file);\n    91→\n    92→        if let Err(error) = fs::rename(&temp_path, path) {\n    93→            let _ = fs::remove_file(&temp_path);\n    94→            return Err(error.into());\n    95→        }\n    96→\n    97→        Ok(())\n    98→    }\n    99→\n   100→    pub fn render_workspace_config(config: &WorkspaceConfig) -> AppResult<String> {\n   101→        Ok(toml::to_string_pretty(config)?)\n   102→    }\n   103→\n   104→    pub fn read_active_project(workspace_root: &Path) -> AppResult<Option<String>> {\n   105→        let path = workspace_root.join(ACTIVE_PROJECT_FILE);\n   106→        match fs::read_to_string(path) {\n   107→            Ok(raw) => {\n   108→                let trimmed = raw.trim();\n   109→                if trimmed.is_empty() {\n   110→                    Ok(None)\n   111→                } else {\n   112→                    Ok(Some(trimmed.to_owned()))\n   113→                }\n   114→            }\n   115→            Err(error) if error.kind() == std::io::ErrorKind::NotFound => Ok(None),\n   116→            Err(error) => Err(error.into()),\n   117→        }\n   118→    }\n   119→\n   120→    pub fn write_active_project(workspace_root: &Path, project_id: &str) -> AppResult<()> {\n   121→        Self::write_atomic(&workspace_root.join(ACTIVE_PROJECT_FILE), project_id)\n   122→    }\n   123→\n   124→    pub fn open_editor(path: &Path) -> AppResult<()> {\n   125→        let editor = env::var(\"EDITOR\")\n   126→            .ok()\n   127→            .filter(|value| !value.trim().is_empty())\n   128→            .or_else(|| {\n   129→                env::var(\"VISUAL\")\n   130→                    .ok()\n   131→                    .filter(|value| !value.trim().is_empty())\n   132→            })\n   133→            .unwrap_or_else(|| \"vi\".to_owned());\n   134→\n   135→        let mut parts = editor.split_whitespace();\n   136→        let program = parts.next().ok_or_else(|| AppError::EditorFailed {\n   137→            editor: editor.clone(),\n   138→            details: \": empty editor command\".to_owned(),\n   139→        })?;\n   140→        let status = Command::new(program).args(parts).arg(path).status()?;\n   141→\n   142→        if status.success() {\n   143→            Ok(())\n   144→        } else {\n   145→            let details = match status.code() {\n   146→                Some(code) => format!(\" with exit code {code}\"),\n   147→                None => \" after being terminated by a signal\".to_owned(),\n   148→            };\n   149→            Err(AppError::EditorFailed { editor, details })\n   150→        }\n   151→    }\n   152→\n   153→    /// Compute a simple hash of content for prompt integrity tracking.\n   154→    pub fn prompt_hash(contents: &str) -> String {\n   155→        use std::collections::hash_map::DefaultHasher;\n   156→        use std::hash::{Hash, Hasher};\n   157→        let mut hasher = DefaultHasher::new();\n   158→        contents.hash(&mut hasher);\n   159→        format!(\"{:016x}\", hasher.finish())\n   160→    }\n   161→\n   162→    // ── Helpers for project filesystem layout ──\n   163→\n   164→    fn workspace_root_path(base_dir: &Path) -> PathBuf {\n   165→        base_dir.join(WORKSPACE_DIR)\n   166→    }\n   167→\n   168→    fn project_root(base_dir: &Path, project_id: &ProjectId) -> PathBuf {\n   169→        Self::workspace_root_path(base_dir)\n   170→            .join(PROJECTS_DIR)\n   171→            .join(project_id.as_str())\n   172→    }\n   173→\n   174→    fn pending_delete_path(base_dir: &Path, project_id: &ProjectId) -> PathBuf {\n   175→        Self::workspace_root_path(base_dir)\n   176→            .join(PROJECTS_DIR)\n   177→            .join(format!(\".{}.pending-delete\", project_id))\n   178→    }\n   179→\n   180→    fn append_line(path: &Path, line: &str) -> AppResult<()> {\n   181→        let parent = path.parent().ok_or_else(|| {\n   182→            AppError::Io(std::io::Error::new(\n   183→                std::io::ErrorKind::InvalidInput,\n   184→                format!(\"path '{}' has no parent directory\", path.display()),\n   185→            ))\n   186→        })?;\n   187→        fs::create_dir_all(parent)?;\n   188→\n   189→        let mut file = OpenOptions::new()\n   190→            .create(true)\n   191→            .append(true)\n   192→            .open(path)?;\n   193→        writeln!(file, \"{}\", line)?;\n   194→        file.sync_all()?;\n   195→        Ok(())\n   196→    }\n   197→}\n   198→\n   199→/// Filesystem-backed implementation of `ProjectStorePort`.\n   200→pub struct FsProjectStore;\n   201→\n   202→impl ProjectStorePort for FsProjectStore {\n   203→    fn project_exists(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<bool> {\n   204→        let project_root = FileSystem::project_root(base_dir, project_id);\n   205→        if !project_root.is_dir() {\n   206→            return Ok(false);\n   207→        }\n   208→        if !project_root.join(PROJECT_CONFIG_FILE).is_file() {\n   209→            return Err(AppError::CorruptRecord {\n   210→                file: format!(\"projects/{}/project.toml\", project_id),\n   211→                details: \"project directory exists but canonical project.toml is missing\"\n   212→                    .to_owned(),\n   213→            });\n   214→        }\n   215→        Ok(true)\n   216→    }\n   217→\n   218→    fn read_project_record(\n   219→        &self,\n   220→        base_dir: &Path,\n   221→        project_id: &ProjectId,\n   222→    ) -> AppResult<ProjectRecord> {\n   223→        let project_root = FileSystem::project_root(base_dir, project_id);\n   224→        let path = project_root.join(PROJECT_CONFIG_FILE);\n   225→        let raw = fs::read_to_string(&path).map_err(|e| {\n   226→            if e.kind() == std::io::ErrorKind::NotFound {\n   227→                if project_root.is_dir() {\n   228→                    // Directory exists but project.toml is missing — corruption\n   229→                    AppError::CorruptRecord {\n   230→                        file: format!(\"projects/{}/project.toml\", project_id),\n   231→                        details: \"project directory exists but canonical project.toml is missing\"\n   232→                            .to_owned(),\n   233→                    }\n   234→                } else {\n   235→                    AppError::ProjectNotFound {\n   236→                        project_id: project_id.to_string(),\n   237→                    }\n   238→                }\n   239→            } else {\n   240→                e.into()\n   241→            }\n   242→        })?;\n   243→        toml::from_str(&raw).map_err(|e| AppError::CorruptRecord {\n   244→            file: format!(\"projects/{}/project.toml\", project_id),\n   245→            details: e.to_string(),\n   246→        })\n   247→    }\n   248→\n   249→    fn list_project_ids(&self, base_dir: &Path) -> AppResult<Vec<ProjectId>> {\n   250→        let projects_dir = FileSystem::workspace_root_path(base_dir).join(PROJECTS_DIR);\n   251→        if !projects_dir.is_dir() {\n   252→            return Ok(Vec::new());\n   253→        }\n   254→\n   255→        let mut ids = Vec::new();\n   256→        for entry in fs::read_dir(&projects_dir)? {\n   257→            let entry = entry?;\n   258→            if !entry.file_type()?.is_dir() {\n   259→                continue;\n   260→            }\n   261→            let name = entry.file_name();\n   262→            let name_str = name.to_string_lossy();\n   263→            // Skip hidden directories (staging/trash from transactional operations)\n   264→            if name_str.starts_with('.') {\n   265→                continue;\n   266→            }\n   267→            if let Ok(pid) = ProjectId::new(name_str.as_ref()) {\n   268→                if !entry.path().join(PROJECT_CONFIG_FILE).is_file() {\n   269→                    return Err(AppError::CorruptRecord {\n   270→                        file: format!(\"projects/{}/project.toml\", name_str),\n   271→                        details:\n   272→                            \"project directory exists but canonical project.toml is missing\"\n   273→                                .to_owned(),\n   274→                    });\n   275→                }\n   276→                ids.push(pid);\n   277→            }\n   278→        }\n   279→\n   280→        ids.sort_by(|a, b| a.as_str().cmp(b.as_str()));\n   281→        Ok(ids)\n   282→    }\n   283→\n   284→    fn stage_delete(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<()> {\n   285→        let project_root = FileSystem::project_root(base_dir, project_id);\n   286→        if !project_root.is_dir() {\n   287→            return Err(AppError::ProjectNotFound {\n   288→                project_id: project_id.to_string(),\n   289→            });\n   290→        }\n   291→\n   292→        let pending_path = FileSystem::pending_delete_path(base_dir, project_id);\n   293→\n   294→        // Clean up any leftover pending-delete from a previous crash\n   295→        if pending_path.exists() {\n   296→            fs::remove_dir_all(&pending_path)?;\n   297→        }\n   298→\n   299→        // Atomic rename to pending-delete location — project becomes\n   300→        // invisible to list/show but data stays on disk.\n   301→        fs::rename(&project_root, &pending_path)?;\n   302→        Ok(())\n   303→    }\n   304→\n   305→    fn commit_delete(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<()> {\n   306→        let pending_path = FileSystem::pending_delete_path(base_dir, project_id);\n   307→        if pending_path.is_dir() {\n   308→            fs::remove_dir_all(&pending_path)?;\n   309→        }\n   310→        Ok(())\n   311→    }\n   312→\n   313→    fn rollback_delete(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<()> {\n   314→        let project_root = FileSystem::project_root(base_dir, project_id);\n   315→        let pending_path = FileSystem::pending_delete_path(base_dir, project_id);\n   316→\n   317→        if !pending_path.is_dir() {\n   318→            return Ok(());\n   319→        }\n   320→\n   321→        fs::rename(&pending_path, &project_root)?;\n   322→        Ok(())\n   323→    }\n   324→\n   325→    fn create_project_atomic(\n   326→        &self,\n   327→        base_dir: &Path,\n   328→        record: &ProjectRecord,\n   329→        prompt_contents: &str,\n   330→        run_snapshot: &RunSnapshot,\n   331→        initial_journal_line: &str,\n   332→        sessions: &SessionStore,\n   333→    ) -> AppResult<()> {\n   334→        let project_root = FileSystem::project_root(base_dir, &record.id);\n   335→\n   336→        // Stage into a temporary directory alongside the final location\n   337→        let staging_name = format!(\".{}.staging.{}\", record.id, std::process::id());\n   338→        let staging_root = project_root\n   339→            .parent()\n   340→            .expect(\"project root has parent\")\n   341→            .join(&staging_name);\n   342→\n   343→        // Clean up any leftover staging dir\n   344→        if staging_root.exists() {\n   345→            fs::remove_dir_all(&staging_root)?;\n   346→        }\n   347→\n   348→        // Create staging directory and all subdirs\n   349→        fs::create_dir_all(&staging_root)?;\n   350→        for subdir in PROJECT_SUBDIRS {\n   351→            fs::create_dir_all(staging_root.join(subdir))?;\n   352→        }\n   353→\n   354→        // Write all canonical files into staging\n   355→        let write_result = (|| -> AppResult<()> {\n   356→            // project.toml\n   357→            let project_toml = toml::to_string_pretty(record).map_err(|e| {\n   358→                AppError::Io(std::io::Error::other(e.to_string()))\n   359→            })?;\n   360→            fs::write(staging_root.join(PROJECT_CONFIG_FILE), project_toml)?;\n   361→\n   362→            // prompt.md\n   363→            fs::write(staging_root.join(PROMPT_FILE), prompt_contents)?;\n   364→\n   365→            // run.json\n   366→            let run_json = serde_json::to_string_pretty(run_snapshot)?;\n   367→            fs::write(staging_root.join(RUN_FILE), run_json)?;\n   368→\n   369→            // journal.ndjson (with initial event)\n   370→            let mut journal_content = initial_journal_line.to_owned();\n   371→            journal_content.push('\\n');\n   372→            fs::write(staging_root.join(JOURNAL_FILE), journal_content)?;\n   373→\n   374→            // sessions.json\n   375→            let sessions_json = serde_json::to_string_pretty(sessions)?;\n   376→            fs::write(staging_root.join(SESSIONS_FILE), sessions_json)?;\n   377→\n   378→            Ok(())\n   379→        })();\n   380→\n   381→        if let Err(e) = write_result {\n   382→            // Clean up staging on failure\n   383→            let _ = fs::remove_dir_all(&staging_root);\n   384→            return Err(e);\n   385→        }\n   386→\n   387→        // Atomic rename from staging to final location\n   388→        if let Err(e) = fs::rename(&staging_root, &project_root) {\n   389→            let _ = fs::remove_dir_all(&staging_root);\n   390→            return Err(e.into());\n   391→        }\n   392→\n   393→        Ok(())\n   394→    }\n   395→}\n   396→\n   397→/// Filesystem-backed implementation of `JournalStorePort`.\n   398→pub struct FsJournalStore;\n   399→\n   400→impl JournalStorePort for FsJournalStore {\n   401→    fn read_journal(\n   402→        &self,\n   403→        base_dir: &Path,\n   404→        project_id: &ProjectId,\n   405→    ) -> AppResult<Vec<JournalEvent>> {\n   406→        let path = FileSystem::project_root(base_dir, project_id).join(JOURNAL_FILE);\n   407→        match fs::read_to_string(&path) {\n   408→            Ok(contents) => journal::parse_journal(&contents),\n   409→            Err(e) if e.kind() == std::io::ErrorKind::NotFound => {\n   410→                Err(AppError::CorruptRecord {\n   411→                    file: format!(\"projects/{}/journal.ndjson\", project_id),\n   412→                    details: \"canonical file is missing\".to_owned(),\n   413→                })\n   414→            }\n   415→            Err(e) => Err(e.into()),\n   416→        }\n   417→    }\n   418→\n   419→    fn append_event(\n   420→        &self,\n   421→        base_dir: &Path,\n   422→        project_id: &ProjectId,\n   423→        line: &str,\n   424→    ) -> AppResult<()> {\n   425→        let path = FileSystem::project_root(base_dir, project_id).join(JOURNAL_FILE);\n   426→        FileSystem::append_line(&path, line)\n   427→    }\n   428→}\n   429→\n   430→/// Filesystem-backed implementation of `ArtifactStorePort`.\n   431→pub struct FsArtifactStore;\n   432→\n   433→impl ArtifactStorePort for FsArtifactStore {\n   434→    fn list_payloads(\n   435→        &self,\n   436→        base_dir: &Path,\n   437→        project_id: &ProjectId,\n   438→    ) -> AppResult<Vec<PayloadRecord>> {\n   439→        let dir = FileSystem::project_root(base_dir, project_id).join(\"history/payloads\");\n   440→        if !dir.is_dir() {\n   441→            return Ok(Vec::new());\n   442→        }\n   443→\n   444→        let mut records = Vec::new();\n   445→        for entry in fs::read_dir(&dir)? {\n   446→            let entry = entry?;\n   447→            let path = entry.path();\n   448→            if path.extension().is_some_and(|ext| ext == \"json\") {\n   449→                let raw = fs::read_to_string(&path)?;\n   450→                let record: PayloadRecord = serde_json::from_str(&raw).map_err(|e| {\n   451→                    AppError::CorruptRecord {\n   452→                        file: format!(\n   453→                            \"history/payloads/{}\",\n   454→                            path.file_name()\n   455→                                .unwrap_or_default()\n   456→                                .to_string_lossy()\n   457→                        ),\n   458→                        details: e.to_string(),\n   459→                    }\n   460→                })?;\n   461→                records.push(record);\n   462→            }\n   463→        }\n   464→\n   465→        records.sort_by_key(|r| r.created_at);\n   466→        Ok(records)\n   467→    }\n   468→\n   469→    fn list_artifacts(\n   470→        &self,\n   471→        base_dir: &Path,\n   472→        project_id: &ProjectId,\n   473→    ) -> AppResult<Vec<ArtifactRecord>> {\n   474→        let dir = FileSystem::project_root(base_dir, project_id).join(\"history/artifacts\");\n   475→        if !dir.is_dir() {\n   476→            return Ok(Vec::new());\n   477→        }\n   478→\n   479→        let mut records = Vec::new();\n   480→        for entry in fs::read_dir(&dir)? {\n   481→            let entry = entry?;\n   482→            let path = entry.path();\n   483→            if path.extension().is_some_and(|ext| ext == \"json\") {\n   484→                let raw = fs::read_to_string(&path)?;\n   485→                let record: ArtifactRecord =\n   486→                    serde_json::from_str(&raw).map_err(|e| AppError::CorruptRecord {\n   487→                        file: format!(\n   488→                            \"history/artifacts/{}\",\n   489→                            path.file_name()\n   490→                                .unwrap_or_default()\n   491→                                .to_string_lossy()\n   492→                        ),\n   493→                        details: e.to_string(),\n   494→                    })?;\n   495→                records.push(record);\n   496→            }\n   497→        }\n   498→\n   499→        records.sort_by_key(|r| r.created_at);\n   500→        Ok(records)\n   501→    }\n   502→}\n   503→\n   504→/// Filesystem-backed implementation of `RuntimeLogStorePort`.\n   505→pub struct FsRuntimeLogStore;\n   506→\n   507→impl RuntimeLogStorePort for FsRuntimeLogStore {\n   508→    fn read_runtime_logs(\n   509→        &self,\n   510→        base_dir: &Path,\n   511→        project_id: &ProjectId,\n   512→    ) -> AppResult<Vec<RuntimeLogEntry>> {\n   513→        let dir = FileSystem::project_root(base_dir, project_id).join(\"runtime/logs\");\n   514→        if !dir.is_dir() {\n   515→            return Ok(Vec::new());\n   516→        }\n   517→\n   518→        let mut entries = Vec::new();\n   519→        let mut paths: Vec<_> = fs::read_dir(&dir)?\n   520→            .filter_map(|e| e.ok())\n   521→            .map(|e| e.path())\n   522→            .filter(|p| p.extension().is_some_and(|ext| ext == \"ndjson\"))\n   523→            .collect();\n   524→        paths.sort();\n   525→\n   526→        // Only read the newest/latest log file per spec:\n   527→        // \"run tail --logs appends the newest runtime logs\"\n   528→        if let Some(path) = paths.last() {\n   529→            let contents = fs::read_to_string(path)?;\n   530→            for line in contents.lines() {\n   531→                let trimmed = line.trim();\n   532→                if trimmed.is_empty() {\n   533→                    continue;\n   534→                }\n   535→                if let Ok(entry) = serde_json::from_str::<RuntimeLogEntry>(trimmed) {\n   536→                    entries.push(entry);\n   537→                }\n   538→            }\n   539→        }\n   540→\n   541→        Ok(entries)\n   542→    }\n   543→}\n   544→\n   545→/// Filesystem-backed implementation of `RunSnapshotPort`.\n   546→pub struct FsRunSnapshotStore;\n   547→\n   548→impl RunSnapshotPort for FsRunSnapshotStore {\n   549→    fn read_run_snapshot(\n   550→        &self,\n   551→        base_dir: &Path,\n   552→        project_id: &ProjectId,\n   553→    ) -> AppResult<RunSnapshot> {\n   554→        let path = FileSystem::project_root(base_dir, project_id).join(RUN_FILE);\n   555→        match fs::read_to_string(&path) {\n   556→            Ok(raw) => {\n   557→                let snapshot: RunSnapshot =\n   558→                    serde_json::from_str(&raw).map_err(|e| AppError::CorruptRecord {\n   559→                        file: format!(\"projects/{}/run.json\", project_id),\n   560→                        details: e.to_string(),\n   561→                    })?;\n   562→                // Semantic validation: reject inconsistent status/active_run combinations\n   563→                snapshot\n   564→                    .validate_semantics()\n   565→                    .map_err(|details| AppError::CorruptRecord {\n   566→                        file: format!(\"projects/{}/run.json\", project_id),\n   567→                        details,\n   568→                    })?;\n   569→                Ok(snapshot)\n   570→            }\n   571→            Err(e) if e.kind() == std::io::ErrorKind::NotFound => {\n   572→                Err(AppError::CorruptRecord {\n   573→                    file: format!(\"projects/{}/run.json\", project_id),\n   574→                    details: \"canonical file is missing\".to_owned(),\n   575→                })\n   576→            }\n   577→            Err(e) => Err(e.into()),\n   578→        }\n   579→    }\n   580→}\n   581→\n   582→/// Filesystem-backed implementation of `ActiveProjectPort`.\n   583→pub struct FsActiveProjectStore;\n   584→\n   585→impl ActiveProjectPort for FsActiveProjectStore {\n   586→    fn read_active_project_id(&self, base_dir: &Path) -> AppResult<Option<String>> {\n   587→        FileSystem::read_active_project(&FileSystem::workspace_root_path(base_dir))\n   588→    }\n   589→\n   590→    fn clear_active_project(&self, base_dir: &Path) -> AppResult<()> {\n   591→        let path = FileSystem::workspace_root_path(base_dir).join(ACTIVE_PROJECT_FILE);\n   592→        match fs::remove_file(&path) {\n   593→            Ok(()) => Ok(()),\n   594→            Err(e) if e.kind() == std::io::ErrorKind::NotFound => Ok(()),\n   595→            Err(e) => Err(e.into()),\n   596→        }\n   597→    }\n   598→\n   599→    fn write_active_project(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<()> {\n   600→        FileSystem::write_active_project(\n   601→            &FileSystem::workspace_root_path(base_dir),\n   602→            project_id.as_str(),\n   603→        )\n   604→    }\n   605→}\n   606→\n   607→"}]},"parent_tool_use_id":"toolu_015umV9Ff8rGC1wuGDkBQWvr","session_id":"68f65612-956d-4383-9b3f-2ff2c684a050","uuid":"6d2dffad-ccde-4e97-9a82-c8561f9d8ad1"}
