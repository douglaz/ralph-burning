{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01KcEkBtNKYPugTbreitTqWk","type":"tool_result","content":"     1→use std::path::PathBuf;\n     2→\n     3→use thiserror::Error;\n     4→\n     5→use crate::shared::domain::{FailureClass, StageId};\n     6→\n     7→pub type AppResult<T> = Result<T, AppError>;\n     8→\n     9→#[derive(Debug, Error)]\n    10→pub enum AppError {\n    11→    #[error(\"workspace already initialized at {path}\")]\n    12→    AlreadyInitialized { path: PathBuf },\n    13→    #[error(\n    14→        \"cannot initialize workspace because {path} already exists without a workspace configuration\"\n    15→    )]\n    16→    WorkspaceConflict { path: PathBuf },\n    17→    #[error(\"invalid {field}: must be greater than zero\")]\n    18→    InvalidStageCursorField { field: &'static str },\n    19→    #[error(\"invalid identifier '{value}': identifiers must be non-empty single path segments\")]\n    20→    InvalidIdentifier { value: String },\n    21→    #[error(\n    22→        \"unknown flow preset '{flow_id}'. supported presets: standard, quick_dev, docs_change, ci_improvement\"\n    23→    )]\n    24→    InvalidFlowPreset { flow_id: String },\n    25→    #[error(\"unsupported workspace version {version}; supported version is {supported}\")]\n    26→    UnsupportedWorkspaceVersion { version: u32, supported: u32 },\n    27→    #[error(\n    28→        \"unknown config key '{key}'. supported keys: prompt_review.enabled, default_flow, default_backend, default_model\"\n    29→    )]\n    30→    UnknownConfigKey { key: String },\n    31→    #[error(\"invalid value '{value}' for config key '{key}': {reason}\")]\n    32→    InvalidConfigValue {\n    33→        key: String,\n    34→        value: String,\n    35→        reason: String,\n    36→    },\n    37→    #[error(\"no active project selected; run `ralph-burning project select <id>`\")]\n    38→    NoActiveProject,\n    39→    #[error(\n    40→        \"project '{project_id}' was not found under .ralph-burning/projects/ or is missing project.toml\"\n    41→    )]\n    42→    ProjectNotFound { project_id: String },\n    43→    #[error(\"editor '{editor}' failed{details}\")]\n    44→    EditorFailed { editor: String, details: String },\n    45→    #[error(\"project '{project_id}' already exists\")]\n    46→    DuplicateProject { project_id: String },\n    47→    #[error(\"corrupt record in {file}: {details}\")]\n    48→    CorruptRecord { file: String, details: String },\n    49→    #[error(\"invalid prompt file '{path}': {reason}\")]\n    50→    InvalidPrompt { path: String, reason: String },\n    51→    #[error(\"cannot delete project '{project_id}': it has an active run\")]\n    52→    ActiveRunDelete { project_id: String },\n    53→    #[error(\"journal sequence error: {details}\")]\n    54→    JournalSequence { details: String },\n    55→    #[error(\"{command} is not yet implemented\")]\n    56→    NotYetImplemented { command: String },\n    57→    #[error(transparent)]\n    58→    Io(#[from] std::io::Error),\n    59→    #[error(transparent)]\n    60→    TomlDeserialize(#[from] toml::de::Error),\n    61→    #[error(transparent)]\n    62→    TomlSerialize(#[from] toml::ser::Error),\n    63→    #[error(transparent)]\n    64→    TomlEdit(#[from] toml_edit::TomlError),\n    65→    #[error(transparent)]\n    66→    SerdeJson(#[from] serde_json::Error),\n    67→}\n    68→\n    69→/// Errors specific to stage contract evaluation.\n    70→///\n    71→/// Each variant maps to a distinct [`FailureClass`] for retry/terminal policy.\n    72→#[derive(Debug, Error)]\n    73→pub enum ContractError {\n    74→    #[error(\"schema validation failed for stage '{stage_id}': {details}\")]\n    75→    SchemaValidation { stage_id: StageId, details: String },\n    76→\n    77→    #[error(\"domain validation failed for stage '{stage_id}': {details}\")]\n    78→    DomainValidation { stage_id: StageId, details: String },\n    79→\n    80→    #[error(\"rendering failed for stage '{stage_id}': {details}\")]\n    81→    RenderError { stage_id: StageId, details: String },\n    82→\n    83→    #[error(\"non-passing QA/review outcome for stage '{stage_id}': {outcome}\")]\n    84→    QaReviewOutcome { stage_id: StageId, outcome: String },\n    85→}\n    86→\n    87→impl ContractError {\n    88→    pub fn failure_class(&self) -> FailureClass {\n    89→        match self {\n    90→            Self::SchemaValidation { .. } => FailureClass::SchemaValidationFailure,\n    91→            Self::DomainValidation { .. } | Self::RenderError { .. } => {\n    92→                FailureClass::DomainValidationFailure\n    93→            }\n    94→            Self::QaReviewOutcome { .. } => FailureClass::QaReviewOutcomeFailure,\n    95→        }\n    96→    }\n    97→\n    98→    pub fn stage_id(&self) -> StageId {\n    99→        match self {\n   100→            Self::SchemaValidation { stage_id, .. }\n   101→            | Self::DomainValidation { stage_id, .. }\n   102→            | Self::RenderError { stage_id, .. }\n   103→            | Self::QaReviewOutcome { stage_id, .. } => *stage_id,\n   104→        }\n   105→    }\n   106→}\n   107→"}]},"parent_tool_use_id":"toolu_015umV9Ff8rGC1wuGDkBQWvr","session_id":"68f65612-956d-4383-9b3f-2ff2c684a050","uuid":"3ac516c1-6008-4fea-998f-e25d58cd6112"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01B1RtywRLfJAL19BKjCRTyj","type":"tool_result","content":"     1→pub mod config;\n     2→\n     3→use std::path::{Path, PathBuf};\n     4→\n     5→use chrono::{DateTime, Utc};\n     6→\n     7→use crate::adapters::fs::FileSystem;\n     8→use crate::shared::domain::{ProjectId, WorkspaceConfig, CURRENT_WORKSPACE_VERSION};\n     9→use crate::shared::error::{AppError, AppResult};\n    10→\n    11→pub use config::{\n    12→    ConfigEntry, ConfigValue, ConfigValueSource, EffectiveConfig, DEFAULT_FLOW_PRESET,\n    13→    DEFAULT_PROMPT_REVIEW_ENABLED,\n    14→};\n    15→\n    16→pub const WORKSPACE_DIR: &str = \".ralph-burning\";\n    17→pub const WORKSPACE_CONFIG_FILE: &str = \"workspace.toml\";\n    18→pub const ACTIVE_PROJECT_FILE: &str = \"active-project\";\n    19→pub const PROJECTS_DIR: &str = \"projects\";\n    20→pub const PROJECT_CONFIG_FILE: &str = \"project.toml\";\n    21→pub const REQUIRED_WORKSPACE_DIRECTORIES: &[&str] =\n    22→    &[\"projects\", \"requirements\", \"daemon/tasks\", \"daemon/leases\"];\n    23→\n    24→#[derive(Debug, Clone, PartialEq)]\n    25→pub struct WorkspaceInitialization {\n    26→    pub workspace_root: PathBuf,\n    27→    pub config: WorkspaceConfig,\n    28→}\n    29→\n    30→pub fn initialize_workspace(\n    31→    base_dir: &Path,\n    32→    created_at: DateTime<Utc>,\n    33→) -> AppResult<WorkspaceInitialization> {\n    34→    let workspace_root = workspace_root(base_dir);\n    35→    let config_path = workspace_root.join(WORKSPACE_CONFIG_FILE);\n    36→\n    37→    if config_path.exists() {\n    38→        return Err(AppError::AlreadyInitialized {\n    39→            path: workspace_root,\n    40→        });\n    41→    }\n    42→\n    43→    if workspace_root.exists() {\n    44→        return Err(AppError::WorkspaceConflict {\n    45→            path: workspace_root,\n    46→        });\n    47→    }\n    48→\n    49→    let config = WorkspaceConfig::new(created_at);\n    50→    let rendered = FileSystem::render_workspace_config(&config)?;\n    51→    FileSystem::create_workspace(&workspace_root, &rendered, REQUIRED_WORKSPACE_DIRECTORIES)?;\n    52→\n    53→    Ok(WorkspaceInitialization {\n    54→        workspace_root,\n    55→        config,\n    56→    })\n    57→}\n    58→\n    59→pub fn load_workspace_config(base_dir: &Path) -> AppResult<WorkspaceConfig> {\n    60→    let raw = FileSystem::read_to_string(&workspace_config_path(base_dir))?;\n    61→    parse_workspace_config(&raw)\n    62→}\n    63→\n    64→pub fn ensure_supported_workspace_version(config: &WorkspaceConfig) -> AppResult<()> {\n    65→    if config.version != CURRENT_WORKSPACE_VERSION {\n    66→        return Err(AppError::UnsupportedWorkspaceVersion {\n    67→            version: config.version,\n    68→            supported: CURRENT_WORKSPACE_VERSION,\n    69→        });\n    70→    }\n    71→\n    72→    Ok(())\n    73→}\n    74→\n    75→pub fn resolve_active_project(base_dir: &Path) -> AppResult<ProjectId> {\n    76→    let _ = EffectiveConfig::load(base_dir)?;\n    77→    let active_project = FileSystem::read_active_project(&workspace_root(base_dir))?\n    78→        .ok_or(AppError::NoActiveProject)?;\n    79→    let project_id = ProjectId::new(active_project)?;\n    80→    validate_project_exists(base_dir, &project_id)?;"}]},"parent_tool_use_id":"toolu_01Gx1iRbRieStJESk4vaaNVA","session_id":"68f65612-956d-4383-9b3f-2ff2c684a050","uuid":"b3371ace-8bdf-4a17-99d4-4e34b02d7dbc"}
