ol) -> Vec<StageId> {\n    37\t    let flow_def = super::flow_definition(FlowPreset::Standard);\n    38\t    if prompt_review_enabled {\n    39\t        flow_def.stages.to_vec()\n    40\t    } else {\n    41\t        flow_def\n    42\t            .stages\n    43\t            .iter()\n    44\t            .copied()\n    45\t            .filter(|s| *s != StageId::PromptReview)\n    46\t            .collect()\n    47\t    }\n    48\t}\n    49\t\n    50\t/// Deterministic stage-to-role mapping per spec.\n    51\tpub fn role_for_stage(stage_id: StageId) -> BackendRole {\n    52\t    BackendRole::for_stage(stage_id)\n    53\t}\n    54\t\n    55\t/// Resolved target per stage for preflight.\n    56\tpub struct StagePlan {\n    57\t    pub stage_id: StageId,\n    58\t    pub role: BackendRole,\n    59\t    pub contract: contracts::StageContract,\n    60\t    pub target: ResolvedBackendTarget,\n    61\t}\n    62\t\n    63\t/// Resolve all stage targets ahead of execution for preflight validation.\n    64\tpub fn resolve_stage_plan(\n    65\t    stages: &[StageId],\n    66\t    resolver: &crate::contexts::agent_execution::service::BackendResolver,\n    67\t    workspace_defaults: Option<&BackendSelectionConfig>,\n    68\t) -> AppResult<Vec<StagePlan>> {\n    69\t    let mut plan = Vec::with_capacity(stages.len());\n    70\t    for &stage_id in stages {\n    71\t        let role = role_for_stage(stage_id);\n    72\t        let contract = contracts::contract_for_stage(stage_id);\n    73\t        let target = resolver.resolve(role, None, None, workspace_defaults)?;\n    74\t        plan.push(StagePlan {\n    75\t            stage_id,\n    76\t            role,\n    77\t            contract,\n    78\t            target,\n    79\t        });\n    80\t    }\n    81\t    Ok(plan)\n    82\t}\n    83\t\n    84\t/// Preflight: check capability and availability for every stage target.\n    85\tpub async fn preflight_check<A: AgentExecutionPort>(\n    86\t    adapter: &A,\n    87\t    plan: &[StagePlan],\n    88\t) -> AppResult<()> {\n    89\t    for entry in plan {\n    90\t        adapter\n    91\t            .check_capability(&entry.target, &entry.contract)\n    92\t            .await\n    93\t            .map_err(|e| AppError::PreflightFailed {\n    94\t                stage_id: entry.stage_id,\n    95\t                details: e.to_string(),\n    96\t            })?;\n    97\t        adapter\n    98\t            .check_availability(&entry.target)\n    99\t            .await\n   100\t            .map_err(|e| AppError::PreflightFailed {\n   101\t                stage_id: entry.stage_id,\n   102\t                details: e.to_string(),\n   103\t            })?;\n   104\t    }\n   105\t    Ok(())\n   106\t}\n   107\t\n   108\t/// Generate a new run ID from a timestamp.\n   109\tfn generate_run_id() -> AppResult<RunId> {\n   110\t    let now = Utc::now();\n   111\t    RunId::new(format!(\"run-{}\", now.format(\"%Y%m%d%H%M%S\")))\n   112\t}\n   113\t\n   114\t#[derive(Debug, Clone, Copy)]\n   115\tenum ExecutionOrigin {\n   116\t    Start,\n   117\t    Resume,\n   118\t}\n   119\t\n   120\timpl ExecutionOrigin {\n   121\t    fn error(self, reason: String) -> AppError {\n   122\t        match self {\n   123\t            Self::Start => AppError::RunStartFailed { reason },\n   124\t            Self::Resume => AppError::ResumeFailed { reason },\n   125\t        }\n   126\t    }\n   127\t}\n   128\t\n   129\t#[derive(Debug, Clone, Copy, PartialEq, Eq)]\n   130\tenum RunOutcome {\n   131\t    Completed,\n   132\t    Paused,\n   133\t}\n   134\t\n   135\t#[derive(Debug)]\n   136\tstruct ResumeState {\n   137\t    run_id: RunId,\n   138\t    started_at: DateTime<Utc>,\n   139\t    stage_index: usize,\n   140\t    cursor: StageCursor,\n   141\t}\n   142\t\n   143\t/// The standard-flow orchestration engine.\n   144\t#[allow(clippy::too_many_arguments)]\n   145\tpub async fn execute_standard_run<A, R, S>(\n   146\t    agent_service: &AgentExecutionService<A, R, S>,\n   147\t    run_snapshot_read: &dyn RunSnapshotPort,\n   148\t    run_snapshot_write: &dyn RunSnapshotWritePort,\n   149\t    journal_store: &dyn JournalStorePort,\n   150\t    artifact_write: &dyn PayloadArtifactWritePort,\n   151\t    log_write: &dyn RuntimeLogWritePort,\n   152\t    base_dir: &Path,\n   153\t    project_id: &ProjectId,\n   154\t    effective_config: &EffectiveConfig,\n   155\t) -> AppResult<()>\n   156\twhere\n   157\t    A: AgentExecutionPort,\n   158\t    R: RawOutputPort,\n   159\t    S: SessionStorePort,\n   160\t{\n   161\t    execute_standard_run_with_retry(\n   162\t        agent_service,\n   163\t        run_snapshot_read,\n   164\t        run_snapshot_write,\n   165\t        journal_store,\n   166\t        artifact_write,\n   167\t        log_write,\n   168\t        base_dir,\n   169\t        project_id,\n   170\t        effective_config,\n   171\t        &RetryPolicy::default_policy(),\n   172\t        CancellationToken::new(),\n   173\t    )\n   174\t    .await\n   175\t}\n   176\t\n   177\t#[allow(clippy::too_many_arguments)]\n   178\tpub async fn execute_standard_run_with_retry<A, R, S>(\n   179\t    agent_service: &AgentExecutionService<A, R, S>,\n   180\t    run_snapshot_read: &dyn RunSnapshotPort,\n   181\t    run_snapshot_write: &dyn RunSnapshotWritePort,\n   182\t    journal_store: &dyn JournalStorePort,\n   183\t    artifact_write: &dyn PayloadArtifactWritePort,\n   184\t    log_write: &dyn RuntimeLogWritePort,\n   185\t    base_dir: &Path,\n   186\t    project_id: &ProjectId,\n   187\t    effective_config: &EffectiveConfig,\n   188\t    retry_policy: &RetryPolicy,\n   189\t    cancellation_token: CancellationToken,\n   190\t) -> AppResult<()>\n   191\twhere\n   192\t    A: AgentExecutionPort,\n   193\t    R: RawOutputPort,\n   194\t    S: SessionStorePort,\n   195\t{\n   196\t    let snapshot = run_snapshot_read.read_run_snapshot(base_dir, project_id)?;\n   197\t\n   198\t    match snapshot.status {\n   199\t        RunStatus::NotStarted => {}\n   200\t        RunStatus::Failed | RunStatus::Paused => {\n   201\t            return Err(AppError::RunStartFailed {\n   202\t                reason: format!(\n   203\t                    \"project snapshot status is '{}'; use `ralph-burning run resume`\",\n   204\t                    snapshot.status\n   205\t                ),\n   206\t            });\n   207\t        }\n   208\t        status => {\n   209\t            return Err(AppError::RunStartFailed {\n   210\t                reason: format!(\n   211\t                    \"project snapshot status is '{}'; run start requires 'not_started'\",\n   212\t                    status\n   213\t                ),\n   214\t            });\n   215\t        }\n   216\t    }\n   217\t    if snapshot.has_active_run() {\n   218\t        return Err(AppError::RunStartFailed {\n   219\t            reason: \"project already has an active run\".to_owned(),\n   220\t        });\n   221\t    }\n   222\t\n   223\t    let stage_ids = standard_stage_plan(effective_config.prompt_review_enabled());\n   224\t    let workspace_defaults = BackendSelectionConfig::from_effective_config(effective_config)?;\n   225\t    let stage_plan = resolve_stage_plan(\n   226\t        stage_ids.as_slice(),\n   227\t        agent_service.resolver(),\n   228\t        Some(&workspace_defaults),\n   229\t    )?;\n   230\t    preflight_check(agent_service.adapter(), &stage_plan).await?;\n   231\t\n   232\t    let run_id = generate_run_id()?;\n   233\t    let now = Utc::now();\n   234\t    let events = journal_store.read_journal(base_dir, project_id)?;\n   235\t    let mut seq = journal::last_sequence(&events);\n   236\t    let first_stage = stage_plan[0].stage_id;\n   237\t    let initial_cursor = StageCursor::initial(first_stage);\n   238\t    let mut current_snapshot = RunSnapshot {\n   239\t        active_run: Some(ActiveRun {\n   240\t            run_id: run_id.as_str().to_owned(),\n   241\t            stage_cursor: initial_cursor.clone(),\n   242\t            started_at: now,\n   243\t        }),\n   244\t        status: RunStatus::Running,\n   245\t        cycle_history: snapshot.cycle_history.clone(),\n   246\t        completion_rounds: 1,\n   247\t        rollback_point_meta: snapshot.rollback_point_meta.clone(),\n   248\t        amendment_queue: snapshot.amendment_queue.clone(),\n   249\t        status_summary: format!(\"running: {}\", first_stage.display_name()),\n   250\t    };\n   251\t    run_snapshot_write.write_run_snapshot(base_dir, project_id, &current_snapshot)?;\n   252\t\n   253\t    seq += 1;\n   254\t    let run_started = journal::run_started_event(seq, now, &run_id, first_stage);\n   255\t    let run_started_line = journal::serialize_event(&run_started)?;\n   256\t    if let Err(error) = journal_store.append_event(base_dir, project_id, &run_started_line) {\n   257\t        seq -= 1;\n   258\t        return fail_run(\n   259\t            &AppError::RunStartFailed {\n   260\t                reason: format!(\"failed to persist run_started event: {}\", error),\n","exit_code":0,"status":"completed"}}
