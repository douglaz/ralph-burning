                  .await;\n   673\t                    }\n   674\t\n   675\t                    implementation_context = Some(remediation_context(stage_id, next_cursor.cycle, &bundle));\n   676\t                    stage_index = next_stage_index;\n   677\t                    cursor = next_cursor;\n   678\t                    continue;\n   679\t                }\n   680\t                ReviewOutcome::RequestChanges | ReviewOutcome::Rejected => {\n   681\t                    let failure = AppError::InvocationFailed {\n   682\t                        backend: stage_entry.target.backend.family.to_string(),\n   683\t                        stage_id,\n   684\t                        failure_class: FailureClass::QaReviewOutcomeFailure,\n   685\t                        details: format!(\"non-passing QA/review outcome: {}\", outcome),\n   686\t                    };\n   687\t                    return fail_run_result(\n   688\t                        &failure,\n   689\t                        stage_id,\n   690\t                        run_id,\n   691\t                        seq,\n   692\t                        snapshot,\n   693\t                        journal_store,\n   694\t                        run_snapshot_write,\n   695\t                        base_dir,\n   696\t                        project_id,\n   697\t                        origin,\n   698\t                    )\n   699\t                    .await;\n   700\t                }\n   701\t            }\n   702\t        }\n   703\t\n   704\t        if stage_index + 1 == stage_plan.len() {\n   705\t            complete_run(\n   706\t                snapshot,\n   707\t                run_snapshot_write,\n   708\t                journal_store,\n   709\t                base_dir,\n   710\t                project_id,\n   711\t                run_id,\n   712\t                seq,\n   713\t            )?;\n   714\t            return Ok(RunOutcome::Completed);\n   715\t        }\n   716\t\n   717\t        let next_stage = 