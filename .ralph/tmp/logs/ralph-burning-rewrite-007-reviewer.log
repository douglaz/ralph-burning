ntered, \"implementation\");\n  1245\t    assert_eq!(implementation_entered.len(), 3);\n  1246\t\n  1247\t    let implementation_failed =\n  1248\t        stage_events(&events, JournalEventType::StageFailed, \"implementation\");\n  1249\t    assert_eq!(implementation_failed.len(), 3);\n  1250\t    assert_eq!(implementation_failed[0].details[\"will_retry\"], true);\n  1251\t    assert_eq!(implementation_failed[1].details[\"will_retry\"], true);\n  1252\t    assert_eq!(implementation_failed[2].details[\"will_retry\"], false);\n  1253\t}\n  1254\t\n  1255\t#[tokio::test]\n  1256\tasync fn retry_success_on_second_attempt_completes_run() {\n  1257\t    let tmp = tempdir().unwrap();\n  1258\t    let base_dir = tmp.path();\n  1259\t\n  1260\t    setup_workspace(base_dir);\n  1261\t    let pid = create_standard_project(base_dir, \"retry-success\");\n  1262\t\n  1263\t    let agent_service = build_agent_service_with_adapter(\n  1264\t        StubBackendAdapter::default().with_transient_failure(StageId::Implementation, 1),\n  1265\t    );\n  1266\t    let config = EffectiveConfig::load(base_dir).unwrap();\n  1267\t\n  1268\t    let result = engine::execute_standard_run(\n  1269\t        &agent_service,\n  1270\t        &FsRunSnapshotStore,\n  1271\t        &FsRunSnapshotWriteStore,\n  1272\t        &FsJournalStore,\n  1273\t        &FsPayloadArtifactWriteStore,\n  1274\t        &FsRuntimeLogWriteStore,\n  1275\t        base_dir,\n  1276\t        &pid,\n  1277\t        &config,\n  1278\t    )\n  1279\t    .await;\n  1280\t\n  1281\t    assert!(result.is_ok(), \"{result:?}\");\n  1282\t\n  1283\t    let snapshot = FsRunSnapshotStore\n  1284\t        .read_run_snapshot(base_dir, &pid)\n  1285\t        .unwrap();\n  1286\t    assert_eq!(snapshot.status, RunStatus::Completed);\n  1287\t\n  1288\t    let events = FsJournalStore.read_journal(base_dir, &pid).unwrap();\n  1289\t    let implementation_entered =\n  1290\t        stage_events(&events, JournalEventType::StageEntered, \"implementation\");\n  1291\t    assert_eq!(implementation_entered.len(), 2);\n  1292\t\n  1293\t    let implementation_failed =\n  1294\t        stage_events(&events, JournalEventType::StageFailed, \"implementation\");\n  1295\t    assert_eq!(implementation_failed.len(), 1);\n  1296\t    assert_eq!(implementation_failed[0].details[\"will_retry\"], true);\n  1297\t\n  1298\t    let implementation_completed =\n  1299\t        stage_events(&events, JournalEventType::StageCompleted, \"implementation\");\n  1300\t    assert_eq!(implementation_completed.len(), 1);\n  1301\t    assert_eq!(implementation_completed[0].details[\"attempt\"], 2);\n  1302\t}\n  1303\t\n  1304\t#[tokio::test]\n  1305\tasync fn remediation_cycle_is_triggered_by_qa_request_changes() {\n  1306\t    let tmp = tempdir().unwrap();\n  1307\t    let base_dir = tmp.path();\n  1308\t\n  1309\t    setup_workspace(base_dir);\n  1310\t    let pid = create_standard_project(base_dir, \"remediation-cycle\");\n  1311\t\n  1312\t    let adapter = RecordingAdapter::new(StubBackendAdapter::default().with_stage_payload_sequence(\n  1313\t        StageId::Qa,\n  1314\t        vec![\n  1315\t            request_changes_payload(&[\"add missing regression test\"]),\n  1316\t            approved_validation_payload(),\n  1317\t        ],\n  1318\t    ));\n  1319\t    let adapter_handle = adapter.clone();\n  1320\t    let agent_service = build_agent_service_with_adapter(adapter);\n  1321\t    let config = EffectiveConfig::load(base_dir).unwrap();\n  1322\t\n  1323\t    let result = engine::execute_standard_run(\n  1324\t        &agent_service,\n  1325\t        &FsRunSnapshotStore,\n  1326\t        &FsRunSnapshotWriteStore,\n  1327\t        &FsJournalStore,\n  1328\t        &FsPayloadArtifactWriteStore,\n  1329\t        &FsRuntimeLogWriteStore,\n  1330\t        base_dir,\n  1331\t        &pid,\n  1332\t        &config,\n  1333\t    )\n  1334\t    .await;\n  1335\t\n  1336\t    assert!(result.is_ok(), \"{result:?}\");\n  1337\t\n  1338\t    let snapshot = FsRunSnapshotStore\n  1339\t        .read_run_snapshot(base_dir, &pid)\n  1340\t        .unwrap();\n  1341\t    assert_eq!(snapshot.status, RunStatus::Completed);\n  1342\t\n  1343\t    let events = FsJournalStore.read_journal(base_dir, &pid).unwrap();\n  1344\t    let implementation_entered =\n  1345\t        stage_events(&events, JournalEventType::StageEntered, \"implementation\");\n  1346\t    assert_eq!(implementation_entered.len(), 2);\n  1347\t\n  1348\t    let cycle_advanced: Vec<_> = events\n  1349\t        .iter()\n  1350\t        .filter(|event| event.event_type == JournalEventType::CycleAdvanced)\n  1351\t        .collect();\n  1352\t    assert_eq!(cycle_advanced.len(), 1);\n  1353\t    assert_eq!(cycle_advanced[0].details[\"to_cycle\"], 2);\n  1354\t\n  1355\t    let implementation_contexts = adapter_handle.contexts_for(StageId::Implementation);\n  1356\t    assert_eq!(implementation_contexts.len(), 2);\n  1357\t    assert_eq!(\n  1358\t        implementation_contexts[1][\"remediation\"][\"follow_up_or_amendments\"][0],\n  1359\t        \"add missing regression test\"\n  1360\t    );\n  1361\t}\n  1362\t\n  1363\t#[tokio::test]\n  1364\tasync fn remediation_limit_exceeded_fails_the_run() {\n  1365\t    let tmp = tempdir().unwrap();\n  1366\t    let base_dir = tmp.path();\n  1367\t\n  1368\t    setup_workspace(base_dir);\n  1369\t    let pid = create_standard_project(base_dir, \"remediation-limit\");\n  1370\t\n  1371\t    let agent_service = build_agent_service_with_adapter(\n  1372\t        StubBackendAdapter::default().with_stage_payload_sequence(\n  1373\t            StageId::Qa,\n  1374\t            vec![\n  1375\t                request_changes_payload(&[\"cycle-1\"]),\n  1376\t                request_changes_payload(&[\"cycle-2\"]),\n  1377\t                request_changes_payload(&[\"cycle-3\"]),\n  1378\t            ],\n  1379\t        ),\n  1380\t    );\n  1381\t    let config = EffectiveConfig::load(base_dir).unwrap();\n  1382\t\n  1383\t    let result = engine::execute_standard_run(\n  1384\t        &agent_service,\n  1385\t        &FsRunSnapshotStore,\n  1386\t        &FsRunSnapshotWriteStore,\n  1387\t        &FsJournalStore,\n  1388\t        &FsPayloadArtifactWriteStore,\n  1389\t        &FsRuntimeLogWriteStore,\n  1390\t        base_dir,\n  1391\t        &pid,\n  1392\t        &config,\n  1393\t    )\n  1394\t    .await;\n  1395\t\n  1396\t    assert!(result.is_err());\n  1397\t    let error = result.unwrap_err().to_string();\n  1398\t    assert!(error.contains(\"remediation exhausted\"), \"{error}\");\n  1399\t\n  1400\t    let snapshot = FsRunSnapshotStore\n  1401\t        .read_run_snapshot(base_dir, &pid)\n  1402\t        .unwrap();\n  1403\t    assert_eq!(snapshot.status, RunStatus::Failed);\n  1404\t    assert!(snapshot.active_run.is_none());\n  1405\t\n  1406\t    let events = FsJournalStore.read_journal(base_dir, &pid).unwrap();\n  1407\t    let cycle_advanced: Vec<_> = events\n  1408\t        .iter()\n  1409\t        .filter(|event| event.event_type == JournalEventType::CycleAdvanced)\n  1410\t        .collect();\n  1411\t    assert_eq!(cycle_advanced.len(), 2);\n  1412\t}\n  1413\t\n  1414\t#[tokio::test]\n  1415\tasync fn resume_after_cycle_advanced_append_failure_restarts_at_implementation() {\n  1416\t    let tmp = tempdir().unwrap();\n  1417\t    let base_dir = tmp.path();\n  1418\t\n  1419\t    setup_workspace(base_dir);\n  1420\t    let pid = create_standard_project(base_dir, \"resume-remediation-boundary\");\n  1421\t    let config = EffectiveConfig::load(base_dir).unwrap();\n  1422\t\n  1423\t    let adapter = RecordingAdapter::new(StubBackendAdapter::default().with_stage_payload_sequence(\n  1424\t        StageId::Qa,\n  1425\t        vec![\n  1426\t            request_changes_payload(&[\"carry remediation into cycle two\"]),\n  1427\t            approved_validation_payload(),\n  1428\t        ],\n  1429\t    ));\n  1430\t    let adapter_handle = adapter.clone();\n  1431\t    let agent_service = build_agent_service_with_adapter(adapter);\n  1432\t\n  1433\t    // Append order before the remediation handoff:\n  1434\t    //   1 run_started\n  1435\t    //   2 stage_entered(prompt_review)\n  1436\t    //   3 stage_completed(prompt_review)\n  1437\t    //   4 stage_entered(planning)\n  1438\t    //   5 stage_completed(planning)\n  1439\t    //   6 stage_entered(implementation)\n  1440\t    //   7 stage_completed(implementation)\n  1441\t    //   8 stage_entered(qa)\n  1442\t    //   9 stage_completed(qa)\n  1443\t    //  10 cycle_advanced -> fail here\n  1444\t    let failing_journal = FailingJournalStore::new(10);\n  1445\t\n  1446\t    let first_result = engine::execute_standard_run(\n  1447\t        &agent_service,\n  1448\t        &FsRunSnapshotStore,\n  1449\t        &FsRunSnapshotWriteStore,\n  1450\t        &failing_journal,\n  1451\t        &FsPayloadArtifactWriteStore,\n  1452\t        &FsRuntimeLogWriteStore,\n  1453\t        base_dir,\n  1454\t        &pid,\n  1455\t        &config,\n  1456\t    )\n  1457\t    .await;\n  1458\t    assert!(first_result.is_err());\n  1459\t\n  1460\t    let failed_snapshot = FsRunSnapshotStore\n  1461\t        .read_run_snapshot(base_dir, &pid)\n  1462\t        .unwrap();\n  1463\t    assert_eq!(failed_snapshot.status, RunStatus::Failed);\n  1464\t    assert!(failed_snapshot.active_run.is_none());\n  1465\t    assert_eq!(failed_snapshot.cycle_history.last().unwrap().cycle, 2);\n  1466\t\n  1467\t    let resume_result = engine::resume_standard_run(\n  1468\t        &agent_service,\n  1469\t        &FsRunSnapshotStore,\n  1470\t        &FsRunSnapshotWriteStore,\n  1471\t        &FsJournalStore,\n  1472\t        &FsArtifactStore,\n  1473\t        &FsPayloadArtifactWriteStore,\n  1474\t        &FsRuntimeLogWriteStore,\n  1475\t        base_dir,\n  1476\t        &pid,\n  1477\t        &config,\n  1478\t    )\n  1479\t    .await;\n  1480\t    assert!(resume_result.is_ok(), \"{resume_result:?}\");\n  1481\t\n  1482\t    let snapshot = FsRunSnapshotStore\n  1483\t        .read_run_snapshot(base_dir, &pid)\n  1484\t        .unwrap();\n  1485\t    assert_eq!(snapshot.status, RunStatus::Completed);\n  1486\t\n  1487\t    let events = FsJournalStore.read_journal(base_dir, &pid).unwrap();\n  1488\t    let implementation_entered =\n  1489\t        stage_events(&events, JournalEventType::StageEntered, \"implementation\");\n  1490\t    assert_eq!(\n  1491\t        implementation_entered.len(),\n  1492\t        2,\n  1493\t        \"resume must loop back through implementation for remediation\"\n  1494\t    );\n  1495\t\n  1496\t    let run_resumed = events\n  1497\t        .iter()\n  1498\t        .find(|event| event.event_type == JournalEventType::RunResumed)\n  1499\t        .expect(\"run_resumed\");\n  1500\t    assert_eq!(run_resumed.details[\"resume_stage\"], \"implementation\");\n  1501\t    assert_eq!(run_resumed.details[\"cycle\"], 2);\n  1502\t\n  1503\t    let implementation_contexts = adapter_handle.contexts_for(StageId::Implementation);\n  1504\t    assert_eq!(implementation_contexts.len(), 2);\n  1505\t    assert_eq!(\n  1506\t        implementation_contexts[1][\"remediation\"][\"follow_up_or_amendments\"][0],\n  1507\t        \"carry remediation into cycle two\"\n  1508\t    );\n  1509\t    assert_eq!(\n  1510\t        implementation_contexts[1][\"remediation\"][\"source_stage\"],\n  1511\t        \"qa\"\n  1512\t    );\n  1513\t}\n  1514\t\n  1515\t#[tokio::test]\n  1516\tasync fn resume_from_failed_run_skips_completed_stages() {\n  1517\t    let tmp = tempdir().unwrap();\n  1518\t    let base_dir = tmp.path();\n  1519\t\n  1520\t    setup_workspace(base_dir);\n  1521\t    let pid = create_standard_project(base_dir, \"resume-failed\");\n  1522\t    let config = EffectiveConfig::load(base_dir).unwrap();\n  1523\t\n  1524\t    let failing_agent_service = build_agent_service_with_adapter(\n  1525\t        StubBackendAdapter::default().with_transient_failure(StageId::Implementation, 3),\n  1526\t    );\n  1527\t    let first_result = engine::execute_standard_run(\n  1528\t        &failing_agent_service,\n  1529\t        &FsRunSnapshotStore,\n  1530\t        &FsRunSnapshotWriteStore,\n  1531\t        &FsJournalStore,\n  1532\t        &FsPayloadArtifactWriteStore,\n  1533\t        &FsRuntimeLogWriteStore,\n  1534\t        base_dir,\n  1535\t        &pid,\n  1536\t        &config,\n  1537\t    )\n  1538\t    .await;\n  1539\t    assert!(first_result.is_err());\n  1540\t\n  1541\t    let resume_agent_service = build_agent_service();\n  1542\t    let resume_result = engine::resume_standard_run(\n  1543\t        &resume_agent_service,\n  1544\t        &FsRunSnapshotStore,\n  1545\t        &FsRunSnapshotWriteStore,\n  1546\t        &FsJournalStore,\n  1547\t        &FsArtifactStore,\n  1548\t        &FsPayloadArtifactWriteStore,\n  1549\t        &FsRuntimeLogWriteStore,\n  1550\t        base_dir,\n  1551\t        &pid,\n  1552\t        &config,\n  1553\t    )\n  1554\t    .await;\n  1555\t    assert!(resume_result.is_ok(), \"{resume_result:?}\");\n  1556\t\n  1557\t    let snapshot = FsRunSnapshotStore\n  1558\t        .read_run_snapshot(base_dir, &pid)\n  1559\t        .unwrap();\n  1560\t    assert_eq!(snapshot.status, RunStatus::Completed);\n  1561\t\n  1562\t    let events = FsJournalStore.read_journal(base_dir, &pid).unwrap();\n  1563\t    let planning_entered = stage_events(&events, JournalEventType::StageEntered, \"planning\");\n  1564\t    assert_eq!(\n  1565\t        planning_entered.len(),\n  1566\t        1,\n  1567\t        \"planning should not rerun on resume\"\n  1568\t    );\n  1569\t\n  1570\t    let implementation_entered =\n  1571\t        stage_events(&events, JournalEventType::StageEntered, \"implementation\");\n  1572\t    assert_eq!(implementation_entered.len(), 4);\n  1573\t\n  1574\t    let run_started = events\n  1575\t        .iter()\n  1576\t        .find(|event| event.event_type == JournalEventType::RunStarted)\n  1577\t        .expect(\"run_started\");\n  1578\t    let run_resumed = events\n  1579\t        .iter()\n  1580\t        .find(|event| event.event_type == JournalEventType::RunResumed)\n  1581\t        .expect(\"run_resumed\");\n  1582\t    assert_eq!(run_started.details[\"run_id\"], run_resumed.details[\"run_id\"]);\n  1583\t    assert_eq!(run_resumed.details[\"resume_stage\"], \"implementation\");\n  1584\t}\n  1585\t\n  1586\t#[tokio::test]\n  1587\tasync fn resume_from_paused_prompt_review_run_continues_from_planning() {\n  1588\t    let tmp = tempdir().unwrap();\n  1589\t    let base_dir = tmp.path();\n  1590\t\n  1591\t    setup_workspace(base_dir);\n  1592\t    let pid = create_standard_project(base_dir, \"resume-paused\");\n  1593\t    let config = EffectiveConfig::load(base_dir).unwrap();\n  1594\t\n  1595\t    let paused_agent_service = build_agent_service_with_adapter(\n  1596\t        StubBackendAdapter::default()\n  1597\t            .with_stage_payload(StageId::PromptReview, prompt_review_payload(false)),\n  1598\t    );\n  1599\t    let first_result = engine::execute_standard_run(\n  1600\t        &paused_agent_service,\n  1601\t        &FsRunSnapshotStore,\n  1602\t        &FsRunSnapshotWriteStore,\n  1603\t        &FsJournalStore,\n  1604\t        &FsPayloadArtifactWriteStore,\n  1605\t        &FsRuntimeLogWriteStore,\n  1606\t        base_dir,\n  1607\t        &pid,\n  1608\t        &config,\n  1609\t    )\n  1610\t    .await;\n  1611\t    assert!(first_result.is_ok(), \"{first_result:?}\");\n  1612\t\n  1613\t    let paused_snapshot = FsRunSnapshotStore\n  1614\t        .read_run_snapshot(base_dir, &pid)\n  1615\t        .unwrap();\n  1616\t    assert_eq!(paused_snapshot.status, RunStatus::Paused);\n  1617\t    assert!(paused_snapshot.active_run.is_none());\n  1618\t    assert!(paused_snapshot.status_summary.contains(\"run resume\"));\n  1619\t\n  1620\t    let resume_agent_service = build_agent_service();\n  1621\t    let resume_result = engine::resume_standard_run(\n  1622\t        &resume_agent_service,\n  1623\t        &FsRunSnapshotStore,\n  1624\t        &FsRunSnapshotWriteStore,\n  1625\t        &FsJournalStore,\n  1626\t        &FsArtifactStore,\n  1627\t        &FsPayloadArtifactWriteStore,\n  1628\t        &FsRuntimeLogWriteStore,\n  1629\t        base_dir,\n  1630\t        &pid,\n  1631\t        &config,\n  1632\t    )\n  1633\t    .await;\n  1634\t    assert!(resume_result.is_ok(), \"{resume_result:?}\");\n  1635\t\n  1636\t    let snapshot = FsRunSnapshotStore\n  1637\t        .read_run_snapshot(base_dir, &pid)\n  1638\t        .unwrap();\n  1639\t    assert_eq!(snapshot.status, RunStatus::Completed);\n  1640\t\n  1641\t    let events = FsJournalStore.read_journal(base_dir, &pid).unwrap();\n  1642\t    assert_eq!(\n  1643\t        stage_events(&events, JournalEventType::StageEntered, \"prompt_review\").len(),\n  1644\t        1\n  1645\t    );\n  1646\t    assert_eq!(\n  1647\t        stage_events(&events, JournalEventType::StageEntered, \"planning\").len(),\n  1648\t        1\n  1649\t    );\n  1650\t\n  1651\t    let run_resumed = events\n  1652\t        .iter()\n  1653\t        .find(|event| event.event_type == JournalEventType::RunResumed)\n  1654\t        .expect(\"run_resumed\");\n  1655\t    assert_eq!(run_resumed.details[\"resume_stage\"], \"planning\");\n  1656\t}\n  1657\t\n  1658\t#[tokio::test]\n  1659\tasync fn cancellation_halts_retry_loop() {\n  1660\t    let tmp = tempdir().unwrap();\n  1661\t    let base_dir = tmp.path();\n  1662\t\n  1663\t    setup_workspace(base_dir);\n  1664\t    let pid = create_standard_project(base_dir, \"cancel-retry\");\n  1665\t\n  1666\t    let cancellation = CancellationToken::new();\n  1667\t    let agent_service =\n  1668\t        build_agent_service_with_adapter(CancelDuringRetryAdapter::new(cancellation.clone()));\n  1669\t    let config = EffectiveConfig::load(base_dir).unwrap();\n  1670\t\n  1671\t    let result = engine::execute_standard_run_with_retry(\n  1672\t        &agent_service,\n  1673\t        &FsRunSnapshotStore,\n  1674\t        &FsRunSnapshotWriteStore,\n  1675\t        &FsJournalStore,\n  1676\t        &FsPayloadArtifactWriteStore,\n  1677\t        &FsRuntimeLogWriteStore,\n  1678\t        base_dir,\n  1679\t        &pid,\n  1680\t        &config,\n  1681\t        &ralph_burning::contexts::workflow_composition::retry_policy::RetryPolicy::default_policy(),\n  1682\t        cancellation,\n  1683\t    )\n  1684\t    .await;\n  1685\t\n  1686\t    assert!(result.is_err());\n  1687\t\n  1688\t    let snapshot = FsRunSnapshotStore\n  1689\t        .read_run_snapshot(base_dir, &pid)\n  1690\t        .unwrap();\n  1691\t    assert_eq!(snapshot.status, RunStatus::Failed);\n  1692\t    assert!(snapshot.active_run.is_none());\n  1693\t\n  1694\t    let events = FsJournalStore.read_journal(base_dir, &pid).unwrap();\n  1695\t    let implementation_entered =\n  1696\t        stage_events(&events, JournalEventType::StageEntered, \"implementation\");\n  1697\t    assert_eq!(implementation_entered.len(), 1);\n  1698\t\n  1699\t    let implementation_failed =\n  1700\t        stage_events(&events, JournalEventType::StageFailed, \"implementation\");\n  1701\t    assert_eq!(implementation_failed.len(), 1);\n  1702\t    assert_eq!(implementation_failed[0].details[\"will_retry\"], false);\n  1703\t}\n  1704\t\n  1705\t#[tokio::test]\n  1706\tasync fn conditionally_approved_queues_amendments_and_proceeds() {\n  1707\t    let tmp = tempdir().unwrap();\n  1708\t    let base_dir = tmp.path();\n  1709\t\n  1710\t    setup_workspace(base_dir);\n  1711\t    let pid = create_standard_project(base_dir, \"conditional-review\");\n  1712\t\n  1713\t    let agent_service =\n  1714\t        build_agent_service_with_adapter(StubBackendAdapter::default().with_stage_payload(\n  1715\t            StageId::Review,\n  1716\t            conditionally_approved_payload(&[\"tighten the acceptance note\", \"add one QA case\"]),\n  1717\t        ));\n  1718\t    let config = EffectiveConfig::load(base_dir).unwrap();\n  1719\t\n  1720\t    let result = engine::execute_standard_run(\n  1721\t        &agent_service,\n  1722\t        &FsRunSnapshotStore,\n  1723\t        &FsRunSnapshotWriteStore,\n  1724\t        &FsJournalStore,\n  1725\t        &FsPayloadArtifactWriteStore,\n  1726\t        &FsRuntimeLogWriteStore,\n  1727\t        base_dir,\n  1728\t        &pid,\n  1729\t        &config,\n  1730\t    )\n  1731\t    .await;\n  1732\t\n  1733\t    assert!(result.is_ok(), \"{result:?}\");\n  1734\t\n  1735\t    let snapshot = FsRunSnapshotStore\n  1736\t        .read_run_snapshot(base_dir, &pid)\n  1737\t        .unwrap();\n  1738\t    assert_eq!(snapshot.status, RunStatus::Completed);\n  1739\t    assert_eq!(\n  1740\t        snapshot.amendment_queue.pending,\n  1741\t        vec![\n  1742\t            json!(\"tighten the acceptance note\"),\n  1743\t            json!(\"add one QA case\")\n  1744\t        ]\n  1745\t    );\n  1746\t}\n","exit_code":0,"status":"completed"}}
