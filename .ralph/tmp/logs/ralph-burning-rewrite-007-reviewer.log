tus_summary = summary;\n  1165\t    run_snapshot_write.write_run_snapshot(base_dir, project_id, snapshot)\n  1166\t}\n  1167\t\n  1168\t/// Record a run failure: persist failed snapshot, then journal event, return error.\n  1169\t#[allow(clippy::too_many_arguments)]\n  1170\tasync fn fail_run(\n  1171\t    err: &AppError,\n  1172\t    stage_id: StageId,\n  1173\t    run_id: &RunId,\n  1174\t    seq: &mut u64,\n  1175\t    snapshot: &mut RunSnapshot,\n  1176\t    journal_store: &dyn JournalStorePort,\n  1177\t    run_snapshot_write: &dyn RunSnapshotWritePort,\n  1178\t    base_dir: &Path,\n  1179\t    project_id: &ProjectId,\n  1180\t    origin: ExecutionOrigin,\n  1181\t) -> AppResult<()> {\n  1182\t    let failure_class = failure_label(err);\n  1183\t    let message = err.to_string();\n  1184\t\n  1185\t    snapshot.status = RunStatus::Failed;\n  1186\t    snapshot.active_run = None;\n  1187\t    snapshot.status_summary = format!(\"failed at {}: {}\", stage_id.display_name(), message);\n  1188\t    run_snapshot_write.write_run_snapshot(base_dir, project_id, snapshot)?;\n  1189\t\n  1190\t    *seq += 1;\n  1191\t    let run_failed =\n  1192\t        journal::run_failed_event(*seq, Utc::now(), run_id, stage_id, &failure_class, &message);\n  1193\t    if let Ok(run_failed_line) = journal::serialize_event(&run_failed) {\n  1194\t        let _ = journal_store.append_event(base_dir, project_id, &run_failed_line);\n  1195\t    }\n  1196\t\n  1197\t    Err(origin.error(format!(\n  1198\t        \"stage {} failed: {}\",\n  1199\t        stage_id.as_str(),\n  1200\t        message\n  1201\t    )))\n  1202\t}\n  1203\t\n  1204\t#[allow(clippy::too_many_arguments)]\n  1205\tasync fn fail_run_result<T>(\n  1206\t    err: &AppError,\n  1207\t    stage_id: StageId,\n  1208\t    run_id: &RunId,\n  1209\t    seq: &mut u64,\n  1210\t    snapshot: &mut RunSnapshot,\n  1211\t    journal_store: &dyn JournalStorePort,\n  1212\t    run_snapshot_write: &dyn RunSnapshotWritePort,\n  1213\t    base_dir: &Path,\n  1214\t    project_id: &ProjectId,\n  1215\t    origin: ExecutionOrigin,\n  1216\t) -> AppResult<T> {\n  1217\t    fail_run(\n  1218\t        err,\n  1219\t        stage_id,\n  1220\t        run_id,\n  1221\t        seq,\n  1222\t        snapshot,\n  1223\t        journal_store,\n  1224\t        run_snapshot_write,\n  1225\t        base_dir,\n  1226\t        project_id,\n  1227\t        origin,\n  1228\t    )\n  1229\t    .await?;\n  1230\t    unreachable!(\"fail_run always returns an error\")\n  1231\t}\n  1232\t\n  1233\tfn failure_label(error: &AppError) -> String {\n  1234\t    if let Some(failure_class) = error.failure_class() {\n  1235\t        return failure_class.as_str().to_owned();\n  1236\t    }\n  1237\t\n  1238\t    match error {\n  1239\t        AppError::RemediationExhausted { .. } => \"remediation_exhausted\".to_owned(),\n  1240\t        AppError::ResumeFailed { .. } => \"resume_failed\".to_owned(),\n  1241\t        _ => \"unknown\".to_owned(),\n  1242\t    }\n  1243\t}\n  1244\t\n  1245\tfn prompt_review_requires_pause(payload: &StagePayload) -> bool {\n  1246\t    matches!(\n  1247\t        payload,\n  1248\t        StagePayload::Planning(planning) if !planning.readiness.ready\n  1249\t    )\n  1250\t}\n  1251\t\n  1252\tfn validation_outcome(payload: &StagePayload) -> Option<ReviewOutcome> {\n  1253\t    match payload {\n  1254\t        StagePayload::Validation(validation) => Some(validation.outcome),\n  1255\t        _ => None,\n  1256\t    }\n  1257\t}\n  1258\t\n  1259\tfn validation_follow_ups(payload: &StagePayload) -> &[String] {\n  1260\t    match payload {\n  1261\t        StagePayload::Validation(validation) => &validation.follow_up_or_amendments,\n  1262\t        _ => &[],\n  1263\t    }\n  1264\t}\n  1265\t\n  1266\tfn append_amendments(snapshot: &mut RunSnapshot, amendments: &[String]) {\n  1267\t    snapshot\n  1268\t        .amendment_queue\n  1269\t        .pending\n  1270\t        .extend(amendments.iter().cloned().map(Value::String));\n  1271\t}\n  1272\t\n  1273\tfn is_remediation_stage(stage_id: StageId) -> bool {\n  1274\t    matches!(stage_id, StageId::Qa | StageId::Review)\n  1275\t}\n  1276\t\n  1277\tfn remediation_context(stage_id: StageId, next_cycle: u32, bundle: &ValidatedBundle) -> Value {\n  1278\t    match &bundle.payload {\n  1279\t        StagePayload::Validation(validation) => json!({\n  1280\t            \"source_stage\": stage_id.as_str(),\n  1281\t            \"cycle\": next_cycle,\n  1282\t            \"follow_up_or_amendments\": validation.follow_up_or_amendments,\n  1283\t            \"findings_or_gaps\": validation.findings_or_gaps,\n  1284\t        }),\n  1285\t        _ => json!({}),\n  1286\t    }\n  1287\t}\n  1288\t\n  1289\tfn invocation_context(cursor: &StageCursor, implementation_context: Option<&Value>) -> Value {\n  1290\t    let mut context = json!({\n  1291\t        \"cycle\": cursor.cycle,\n  1292\t        \"attempt\": cursor.attempt,\n  1293\t        \"completion_round\": cursor.completion_round,\n  1294\t    });\n  1295\t\n  1296\t    if let Some(implementation_context) = implementation_context {\n  1297\t        context[\"remediation\"] = implementation_context.clone();\n  1298\t    }\n  1299\t\n  1300\t    context\n  1301\t}\n  1302\t\n  1303\tfn stage_index_for(stage_plan: &[StagePlan], stage_id: StageId) -> AppResult<usize> {\n  1304\t    stage_plan\n  1305\t        .iter()\n  1306\t        .position(|entry| entry.stage_id == stage_id)\n  1307\t        .ok_or_else(|| AppError::CorruptRecord {\n  1308\t            file: \"journal.ndjson\".to_owned(),\n  1309\t            details: format!(\"stage '{}' is not part of the standard stage plan\", stage_id),\n  1310\t        })\n  1311\t}\n  1312\t\n  1313\tfn record_cycle_advance(snapshot: &mut RunSnapshot, next_cycle: u32) {\n  1314\t    snapshot.cycle_history.push(CycleHistoryEntry {\n  1315\t        cycle: next_cycle,\n  1316\t        stage_id: StageId::Implementation,\n  1317\t        started_at: Utc::now(),\n  1318\t        completed_at: None,\n  1319\t    });\n  1320\t}\n  1321\t\n  1322\tfn standard_stage_plan_for_resume(\n  1323\t    events: &[JournalEvent],\n  1324\t    effective_config: &EffectiveConfig,\n  1325\t) -> AppResult<Vec<StageId>> {\n  1326\t    let run_started = events\n  1327\t        .iter()\n  1328\t        .rev()\n  1329\t        .find(|event| event.event_type == crate::contexts::project_run_record::model::JournalEventType::RunStarted)\n  1330\t        .ok_or_else(|| AppError::ResumeFailed {\n  1331\t            reason: \"run journal does not contain a run_started event\".to_owned(),\n  1332\t        })?;\n  1333\t\n  1334\t    let first_stage = detail_stage_id(run_started, \"first_stage\")?;\n  1335\t    match first_stage {\n  1336\t        StageId::PromptReview => Ok(standard_stage_plan(true)),\n  1337\t        StageId::Planning => Ok(standard_stage_plan(false)),\n  1338\t        _ => Ok(standard_stage_plan(effective_config.prompt_review_enabled())),\n  1339\t    }\n  1340\t}\n  1341\t\n  1342\tfn derive_resume_state(\n  1343\t    events: &[JournalEvent],\n  1344\t    snapshot: &RunSnapshot,\n  1345\t    stage_plan: &[StagePlan],\n  1346\t) -> AppResult<ResumeState> {\n  1347\t    let run_started = events\n  1348\t        .iter()\n  1349\t        .rev()\n  1350\t        .find(|event| event.event_type == crate::contexts::project_run_record::model::JournalEventType::RunStarted)\n  1351\t        .ok_or_else(|| AppError::ResumeFailed {\n  1352\t            reason: \"run journal does not contain a run_started event\".to_owned(),\n  1353\t        })?;\n  1354\t    let run_id = RunId::new(detail_string(run_started, \"run_id\")?.to_owned())?;\n  1355\t    let started_at = run_started.timestamp;\n  1356\t    let implementation_stage_index = stage_index_for(stage_plan, StageId::Implementation)?;\n  1357\t    let mut current_cycle = snapshot\n  1358\t        .cycle_history\n  1359\t        .last()\n  1360\t        .map(|entry| entry.cycle)\n  1361\t        .unwrap_or(1);\n  1362\t    let mut next_stage_index = 0usize;\n  1363\t\n  1364\t    for event in events {\n  1365\t        match event.event_type {\n  1366\t            crate::contexts::project_run_record::model::JournalEventType::StageCompleted => {\n  1367\t                let stage_id = detail_stage_id(event, \"stage_id\")?;\n  1368\t                current_cycle = detail_u32(event, \"cycle\").unwrap_or(current_cycle);\n  1369\t                next_stage_index = stage_index_for(stage_plan, stage_id)? + 1;\n  1370\t            }\n  1371\t            crate::contexts::project_run_record::model::JournalEventType::CycleAdvanced => {\n  1372\t                current_cycle = detail_u32(event, \"to_cycle\").unwrap_or(current_cycle + 1);\n  1373\t                next_stage_index = implementation_stage_index;\n  1374\t            }\n  1375\t            crate::contexts::project_run_record::model::JournalEventType::RunCompleted => {\n  1376\t                next_stage_index = stage_plan.len();\n  1377\t            }\n  1378\t            _ => {}\n  1379\t        }\n  1380\t    }\n  1381\t\n  1382\t    if next_stage_index >= stage_plan.len() {\n  1383\t        return Err(AppError::ResumeFailed {\n  1384\t            reason: \"all standard-flow stages are already complete; there is nothing to resume\"\n  1385\t                .to_owned(),\n  1386\t        });\n  1387\t    }\n  1388\t\n  1389\t    let completion_round = snapshot.completion_rounds.max(1);\n  1390\t    let cursor = StageCursor::new(\n  1391\t        stage_plan[next_stage_index].stage_id,\n  1392\t        current_cycle.max(1),\n  1393\t        1,\n  1394\t        completion_round,\n  1395\t    )?;\n  1396\t\n  1397\t    Ok(ResumeState {\n  1398\t        run_id,\n  1399\t        started_at,\n  1400\t        stage_index: next_stage_index,\n  1401\t        cursor,\n  1402\t    })\n  1403\t}\n  1404\t\n  1405\tfn detail_string<'a>(event: &'a JournalEvent, key: &str) -> AppResult<&'a str> {\n  1406\t    event\n  1407\t        .details\n  1408\t        .get(key)\n  1409\t        .and_then(Value::as_str)\n  1410\t        .ok_or_else(|| AppError::CorruptRecord {\n  1411\t            file: \"journal.ndjson\".to_owned(),\n  1412\t            details: format!(\n  1413\t                \"event sequence {} is missing string field '{}'\",\n  1414\t                event.sequence, key\n  1415\t            ),\n  1416\t        })\n  1417\t}\n  1418\t\n  1419\tfn detail_stage_id(event: &JournalEvent, key: &str) -> AppResult<StageId> {\n  1420\t    detail_string(event, key)?.parse::<StageId>()\n","exit_code":0,"status":"completed"}}
{"type":"item.completed","item":{"id":"item_22","type":"command_execution","command":"/run/current-system/sw/bin/bash -lc \"nl -ba src/shared/domain.rs | sed -n '1,260p'\"","aggregated_output":"     1\tuse std::fmt;\n     2\tuse std::str::FromStr;\n     3\t\n     4\tuse chrono::{DateTime, Utc};\n     5\tuse serde::{Deserialize, Serialize};\n     6\tuse toml::Table;\n     7\t\n     8\tuse crate::shared::error::{AppError, AppResult};\n     9\t\n    10\tpub const CURRENT_WORKSPACE_VERSION: u32 = 1;\n    11\t\n    12\t/// Canonical failure classes for stage contract evaluation and retry semantics.\n    13\t#[derive(Debug, Clone, Copy, PartialEq, Eq, Hash, Serialize, Deserialize)]\n    14\t#[serde(rename_all = \"snake_case\")]\n    15\tpub enum FailureClass {\n    16\t    TransportFailure,\n    17\t    SchemaValidationFailure,\n    18\t    DomainValidationFailure,\n    19\t    Timeout,\n    20\t    Cancellation,\n    21\t    QaReviewOutcomeFailure,\n    22\t}\n    23\t\n    24\timpl FailureClass {\n    25\t    pub fn as_str(self) -> &'static str {\n    26\t        match self {\n    27\t            Self::TransportFailure => \"transport_failure\",\n    28\t            Self::SchemaValidationFailure => \"schema_validation_failure\",\n    29\t            Self::DomainValidationFailure => \"domain_validation_failure\",\n    30\t            Self::Timeout => \"timeout\",\n    31\t            Self::Cancellation => \"cancellation\",\n    32\t            Self::QaReviewOutcomeFailure => \"qa_review_outcome_failure\",\n    33\t        }\n    34\t    }\n    35\t}\n    36\t\n    37\timpl fmt::Display for FailureClass {\n    38\t    fn fmt(&self, f: &mut fmt::Formatter<'_>) -> fmt::Result {\n    39\t        f.write_str(self.as_str())\n    40\t    }\n    41\t}\n    42\t\n    43\t#[derive(Debug, Clone, Copy, PartialEq, Eq, Hash, Serialize, Deserialize)]\n    44\t#[serde(rename_all = \"snake_case\")]\n    45\tpub enum BackendFamily {\n    46\t    Claude,\n    47\t    Codex,\n    48\t    OpenRouter,\n    49\t    Stub,\n    50\t}\n    51\t\n    52\timpl BackendFamily {\n    53\t    pub fn as_str(self) -> &'static str {\n    54\t        match self {\n    55\t            Self::Claude => \"claude\",\n    56\t            Self::Codex => \"codex\",\n    57\t            Self::OpenRouter => \"openrouter\",\n    58\t            Self::Stub => \"stub\",\n    59\t        }\n    60\t    }\n    61\t\n    62\t    pub fn display_name(self) -> &'static str {\n    63\t        match self {\n    64\t            Self::Claude => \"Claude\",\n    65\t            Self::Codex => \"Codex\",\n    66\t            Self::OpenRouter => \"OpenRouter\",\n    67\t            Self::Stub => \"Stub\",\n    68\t        }\n    69\t    }\n    70\t\n    71\t    pub fn default_model_id(self) -> &'static str {\n    72\t        match self {\n    73\t            Self::Claude => \"opus-4.1\",\n    74\t            Self::Codex => \"gpt-5-codex\",\n    75\t            Self::OpenRouter => \"openai/gpt-5\",\n    76\t            Self::Stub => \"stub-default\",\n    77\t        }\n    78\t    }\n    79\t}\n    80\t\n    81\timpl fmt::Display for BackendFamily {\n    82\t    fn fmt(&self, f: &mut fmt::Formatter<'_>) -> fmt::Result {\n    83\t        f.write_str(self.as_str())\n    84\t    }\n    85\t}\n    86\t\n    87\timpl FromStr for BackendFamily {\n    88\t    type Err = AppError;\n    89\t\n    90\t    fn from_str(value: &str) -> Result<Self, Self::Err> {\n    91\t        match value {\n    92\t            \"claude\" => Ok(Self::Claude),\n    93\t            \"codex\" => Ok(Self::Codex),\n    94\t            \"openrouter\" => Ok(Self::OpenRouter),\n    95\t            \"stub\" => Ok(Self::Stub),\n    96\t            _ => Err(AppError::InvalidConfigValue {\n    97\t                key: \"backend\".to_owned(),\n    98\t                value: value.to_owned(),\n    99\t                reason: \"expected one of claude, codex, openrouter, stub\".to_owned(),\n   100\t            }),\n   101\t        }\n   102\t    }\n   103\t}\n   104\t\n   105\t#[derive(Debug, Clone, PartialEq, Eq, Serialize, Deserialize)]\n   106\tpub struct CapabilityMetadata {\n   107\t    pub supports_structured_output: bool,\n   108\t    pub supports_session_reuse: bool,\n   109\t    pub supports_cancellation: bool,\n   110\t    pub supported_stages: Vec<StageId>,\n   111\t}\n   112\t\n   113\timpl CapabilityMetadata {\n   114\t    pub fn for_all_stages(supports_session_reuse: bool, supports_cancellation: bool) -> Self {\n   115\t        Self {\n   116\t            supports_structured_output: true,\n   117\t            supports_session_reuse,\n   118\t            supports_cancellation,\n   119\t            supported_stages: StageId::ALL.to_vec(),\n   120\t        }\n   121\t    }\n   122\t\n   123\t    pub fn supports_stage(&self, stage_id: StageId) -> bool {\n   124\t        self.supported_stages.contains(&stage_id)\n   125\t    }\n   126\t}\n   127\t\n   128\t#[derive(Debug, Clone, PartialEq, Eq, Serialize, Deserialize)]\n   129\tpub struct BackendSpec {\n   130\t    pub family: BackendFamily,\n   131\t    pub display_name: String,\n   132\t    pub capabilities: CapabilityMetadata,\n   133\t}\n   134\t\n   135\timpl BackendSpec {\n   136\t    pub fn from_family(family: BackendFamily) -> Self {\n   137\t        let supports_session_reuse = !matches!(family, BackendFamily::OpenRouter);\n   138\t        Self {\n   139\t            family,\n   140\t            display_name: family.display_name().to_owned(),\n   141\t            capabilities: CapabilityMetadata::for_all_stages(supports_session_reuse, true),\n   142\t        }\n   143\t    }\n   144\t}\n   145\t\n   146\timpl fmt::Display for BackendSpec {\n   147\t    fn fmt(&self, f: &mut fmt::Formatter<'_>) -> fmt::Result {\n   148\t        f.write_str(&self.display_name)\n   149\t    }\n   150\t}\n   151\t\n   152\t#[derive(Debug, Clone, PartialEq, Eq, Serialize, Deserialize)]\n   153\tpub struct ModelSpec {\n   154\t    pub backend_family: BackendFamily,\n   155\t    pub model_id: String,\n   156\t    pub display_name: String,\n   157\t    pub capabilities: CapabilityMetadata,\n   158\t}\n   159\t\n   160\timpl ModelSpec {\n   161\t    pub fn new(backend_family: BackendFamily, model_id: impl Into<String>) -> Self {\n   162\t        let model_id = model_id.into();\n   163\t        let display_name = format!(\"{} {}\", backend_family.display_name(), model_id);\n   164\t        let supports_session_reuse = !matches!(backend_family, BackendFamily::OpenRouter);\n   165\t        Self {\n   166\t            backend_family,\n   167\t            model_id,\n   168\t            display_name,\n   169\t            capabilities: CapabilityMetadata::for_all_stages(supports_session_reuse, true),\n   170\t        }\n   171\t    }\n   172\t\n   173\t    pub fn default_for_backend(backend_family: BackendFamily) -> Self {\n   174\t        Self::new(backend_family, backend_family.default_model_id())\n   175\t    }\n   176\t}\n   177\t\n   178\timpl fmt::Display for ModelSpec {\n   179\t    fn fmt(&self, f: &mut fmt::Formatter<'_>) -> fmt::Result {\n   180\t        f.write_str(&self.display_name)\n   181\t    }\n   182\t}\n   183\t\n   184\t#[derive(Debug, Clone, PartialEq, Eq, Serialize, Deserialize)]\n   185\tpub struct ResolvedBackendTarget {\n   186\t    pub backend: BackendSpec,\n   187\t    pub model: ModelSpec,\n   188\t}\n   189\t\n   190\timpl ResolvedBackendTarget {\n   191\t    pub fn new(backend_family: BackendFamily, model_id: impl Into<String>) -> Self {\n   192\t        Self {\n   193\t            backend: BackendSpec::from_family(backend_family),\n   194\t            model: ModelSpec::new(backend_family, model_id),\n   195\t        }\n   196\t    }\n   197\t\n   198\t    pub fn supports_stage(&self, stage_id: StageId) -> bool {\n   199\t        self.backend.capabilities.supports_stage(stage_id)\n   200\t            && self.model.capabilities.supports_stage(stage_id)\n   201\t    }\n   202\t\n   203\t    pub fn supports_session_reuse(&self) -> bool {\n   204\t        self.backend.capabilities.supports_session_reuse\n   205\t            && self.model.capabilities.supports_session_reuse\n   206\t    }\n   207\t}\n   208\t\n   209\t#[derive(Debug, Clone, Copy, PartialEq, Eq, Hash, Serialize, Deserialize)]\n   210\t#[serde(rename_all = \"snake_case\")]\n   211\tpub enum BackendRole {\n   212\t    Planner,\n   213\t    Implementer,\n   214\t    Reviewer,\n   215\t    QaValidator,\n   216\t    CompletionJudge,\n   217\t}\n   218\t\n   219\timpl BackendRole {\n   220\t    pub fn as_str(self) -> &'static str {\n   221\t        match self {\n   222\t            Self::Planner => \"planner\",\n   223\t            Self::Implementer => \"implementer\",\n   224\t            Self::Reviewer => \"reviewer\",\n   225\t            Self::QaValidator => \"qa_validator\",\n   226\t            Self::CompletionJudge => \"completion_judge\",\n   227\t        }\n   228\t    }\n   229\t\n   230\t    pub fn display_name(self) -> &'static str {\n   231\t        match self {\n   232\t            Self::Planner => \"Planner\",\n   233\t            Self::Implementer => \"Implementer\",\n   234\t            Self::Reviewer => \"Reviewer\",\n   235\t            Self::QaValidator => \"QA Validator\",\n   236\t            Self::CompletionJudge => \"Completion Judge\",\n   237\t        }\n   238\t    }\n   239\t\n   240\t    pub fn default_target(self) -> ResolvedBackendTarget {\n   241\t        match self {\n   242\t            Self::Planner => ResolvedBackendTarget::new(BackendFamily::Claude, \"opus-4.1\"),\n   243\t            Self::Implementer => ResolvedBackendTarget::new(BackendFamily::Codex, \"gpt-5-codex\"),\n   244\t            Self::Reviewer => ResolvedBackendTarget::new(BackendFamily::Claude, \"sonnet-4.0\"),\n   245\t            Self::QaValidator => {\n   246\t                ResolvedBackendTarget::new(BackendFamily::OpenRouter, \"openai/gpt-5\")\n   247\t            }\n   248\t            Self::CompletionJudge => ResolvedBackendTarget::new(BackendFamily::Claude, \"opus-4.1\"),\n   249\t        }\n   250\t    }\n   251\t\n   252\t    pub fn allows_session_reuse(self) -> bool {\n   253\t        matches!(self, Self::Implementer | Self::Reviewer | Self::QaValidator)\n   254\t    }\n   255\t\n   256\t    pub fn for_stage(stage_id: StageId) -> Self {\n   257\t        match stage_id {\n   258\t            StageId::PromptReview | StageId::Planning | StageId::DocsPlan | StageId::CiPlan => {\n   259\t                Self::Planner\n   260\t            }\n","exit_code":0,"status":"completed"}}
