   RetryRule::terminal(),\n    53\t        );\n    54\t\n    55\t        Self {\n    56\t            rules,\n    57\t            max_remediation_cycles: 3,\n    58\t        }\n    59\t    }\n    60\t\n    61\t    pub fn with_rule(mut self, failure_class: FailureClass, rule: RetryRule) -> Self {\n    62\t        self.rules.insert(failure_class, rule);\n    63\t        self\n    64\t    }\n    65\t\n    66\t    pub fn with_max_remediation_cycles(mut self, max_remediation_cycles: u32) -> Self {\n    67\t        self.max_remediation_cycles = max_remediation_cycles.max(1);\n    68\t        self\n    69\t    }\n    70\t\n    71\t    pub fn rule_for(&self, failure_class: FailureClass) -> RetryRule {\n    72\t        self.rules\n    73\t            .get(&failure_class)\n    74\t            .copied()\n    75\t            .unwrap_or_else(RetryRule::terminal)\n    76\t    }\n    77\t\n    78\t    pub fn max_attempts(&self, failure_class: FailureClass) -> u32 {\n    79\t        self.rule_for(failure_class).max_attempts\n    80\t    }\n    81\t\n    82\t    pub fn is_retryable(&self, failure_class: FailureClass) -> bool {\n    83\t        self.rule_for(failure_class).retryable\n    84\t    }\n    85\t\n    86\t    pub fn max_remediation_cycles(&self) -> u32 {\n    87\t        self.max_remediation_cycles\n    88\t    }\n    89\t}\n","exit_code":0,"status":"completed"}}
