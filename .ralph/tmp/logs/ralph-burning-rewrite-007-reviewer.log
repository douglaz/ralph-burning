{"type":"item.completed","item":{"id":"item_11","type":"command_execution","command":"/run/current-system/sw/bin/bash -lc \"nl -ba ralph-burning-rewrite/src/contexts/workflow_composition/retry_policy.rs | sed -n '1,220p'\"","aggregated_output":"     1\tuse std::collections::HashMap;\n     2\t\n     3\tuse crate::shared::domain::FailureClass;\n     4\t\n     5\t#[derive(Debug, Clone, Copy, PartialEq, Eq)]\n     6\tpub struct RetryRule {\n     7\t    pub max_attempts: u32,\n     8\t    pub retryable: bool,\n     9\t}\n    10\t\n    11\timpl RetryRule {\n    12\t    pub const fn retryable(max_attempts: u32) -> Self {\n    13\t        Self {\n    14\t            max_attempts,\n    15\t            retryable: true,\n    16\t        }\n    17\t    }\n    18\t\n    19\t    pub const fn terminal() -> Self {\n    20\t        Self {\n    21\t            max_attempts: 1,\n    22\t            retryable: false,\n    23\t        }\n    24\t    }\n    25\t}\n    26\t\n    27\t#[derive(Debug, Clone, PartialEq, Eq)]\n    28\tpub struct RetryPolicy {\n    29\t    rules: HashMap<FailureClass, RetryRule>,\n    30\t    max_remediation_cycles: u32,\n    31\t}\n    32\t\n    33\timpl RetryPolicy {\n    34\t    pub fn default_policy() -> Self {\n    35\t        let mut rules = HashMap::new();\n    36\t        rules.insert(FailureClass::TransportFailure, RetryRule::retryable(3));\n    37\t        rules.insert(\n    38\t            FailureClass::SchemaValidationFailure,\n    39\t            RetryRule::retryable(2),\n    40\t        );\n    41\t        rules.insert(\n    42\t            FailureClass::DomainValidationFailure,\n    43\t            RetryRule::retryable(2),\n    44\t        );\n    45\t        rules.insert(FailureClass::Timeout, RetryRule::retryable(2));\n    46\t        rules.insert(FailureClass::Cancellation, RetryRule::terminal());\n    47\t        rules.insert(FailureClass::QaReviewOutcomeFailure, RetryRule::terminal());\n    48\t\n    49\t        Self {\n    50\t            rules,\n    51\t            max_remediation_cycles: 3,\n    52\t        }\n    53\t    }\n    54\t\n    55\t    pub fn with_rule(mut self, failure_class: FailureClass, rule: RetryRule) -> Self {\n    56\t        self.rules.insert(failure_class, rule);\n    57\t        self\n    58\t    }\n    59\t\n    60\t    pub fn with_max_remediation_cycles(mut self, max_remediation_cycles: u32) -> Self {\n    61\t        self.max_remediation_cycles = max_remediation_cycles.max(1);\n    62\t        self\n    63\t    }\n    64\t\n    65\t    pub fn rule_for(&self, failure_class: FailureClass) -> RetryRule {\n    66\t        self.rules\n    67\t            .get(&failure_class)\n    68\t            .copied()\n    69\t            .unwrap_or_else(RetryRule::terminal)\n    70\t    }\n    71\t\n    72\t    pub fn max_attempts(&self, failure_class: FailureClass) -> u32 {\n    73\t        self.rule_for(failure_class).max_attempts\n    74\t    }\n    75\t\n    76\t    pub fn is_retryable(&self, failure_class: FailureClass) -> bool {\n    77\t        self.rule_for(failure_class).retryable\n    78\t    }\n    79\t\n    80\t    pub fn max_remediation_cycles(&self) -> u32 {\n    81\t        self.max_remediation_cycles\n    82\t    }\n    83\t}\n","exit_code":0,"status":"completed"}}
