{"type":"item.completed","item":{"id":"item_12","type":"command_execution","command":"/run/current-system/sw/bin/bash -lc \"nl -ba src/contexts/project_run_record/journal.rs | sed -n '1,260p'\"","aggregated_output":"     1\tuse crate::shared::error::{AppError, AppResult};\n     2\t\n     3\tuse super::model::{JournalEvent, JournalEventType};\n     4\t\n     5\t/// Validates that a new event's sequence follows the last known sequence.\n     6\t/// The first event must have sequence 1.\n     7\tpub fn validate_sequence(last_sequence: u64, event: &JournalEvent) -> AppResult<()> {\n     8\t    let expected = last_sequence + 1;\n     9\t    if event.sequence != expected {\n    10\t        return Err(AppError::JournalSequence {\n    11\t            details: format!(\"expected sequence {expected}, got {}\", event.sequence),\n    12\t        });\n    13\t    }\n    14\t    Ok(())\n    15\t}\n    16\t\n    17\t/// Serializes a journal event to a single NDJSON line (no trailing newline).\n    18\tpub fn serialize_event(event: &JournalEvent) -> AppResult<String> {\n    19\t    Ok(serde_json::to_string(event)?)\n    20\t}\n    21\t\n    22\t/// Deserializes a single NDJSON line into a journal event.\n    23\tpub fn deserialize_event(line: &str) -> AppResult<JournalEvent> {\n    24\t    let trimmed = line.trim();\n    25\t    if trimmed.is_empty() {\n    26\t        return Err(AppError::CorruptRecord {\n    27\t            file: \"journal.ndjson\".to_owned(),\n    28\t            details: \"empty line in journal\".to_owned(),\n    29\t        });\n    30\t    }\n    31\t    serde_json::from_str(trimmed).map_err(|e| AppError::CorruptRecord {\n    32\t        file: \"journal.ndjson\".to_owned(),\n    33\t        details: format!(\"invalid journal event: {e}\"),\n    34\t    })\n    35\t}\n    36\t\n    37\t/// Parses the full contents of a journal.ndjson file into ordered events.\n    38\t/// Validates monotonic sequence ordering and journal integrity (first event\n    39\t/// must be `project_created` with sequence 1).\n    40\tpub fn parse_journal(contents: &str) -> AppResult<Vec<JournalEvent>> {\n    41\t    let mut events = Vec::new();\n    42\t    let mut last_sequence = 0u64;\n    43\t\n    44\t    for line in contents.lines() {\n    45\t        if line.trim().is_empty() {\n    46\t            continue;\n    47\t        }\n    48\t        let event = deserialize_event(line)?;\n    49\t        validate_sequence(last_sequence, &event)?;\n    50\t        last_sequence = event.sequence;\n    51\t        events.push(event);\n    52\t    }\n    53\t\n    54\t    validate_journal_integrity(&events)?;\n    55\t\n    56\t    Ok(events)\n    57\t}\n    58\t\n    59\t/// Validates that a journal has the required structure:\n    60\t/// - Must not be empty (must contain at least the initial `project_created` event)\n    61\t/// - First event must be `project_created` with sequence 1\n    62\tpub fn validate_journal_integrity(events: &[JournalEvent]) -> AppResult<()> {\n    63\t    if events.is_empty() {\n    64\t        return Err(AppError::CorruptRecord {\n    65\t            file: \"journal.ndjson\".to_owned(),\n    66\t            details: \"journal is empty — must contain at least the initial project_created event\"\n    67\t                .to_owned(),\n    68\t        });\n    69\t    }\n    70\t\n    71\t    let first = &events[0];\n    72\t    if first.event_type != JournalEventType::ProjectCreated {\n    73\t        return Err(AppError::CorruptRecord {\n    74\t            file: \"journal.ndjson\".to_owned(),\n    75\t            details: format!(\n    76\t                \"first journal event type is '{:?}', expected 'project_created'\",\n    77\t                first.event_type\n    78\t            ),\n    79\t        });\n    80\t    }\n    81\t\n    82\t    Ok(())\n    83\t}\n    84\t\n    85\t/// Returns the last sequence number from a set of events, or 0 if empty.\n    86\tpub fn last_sequence(events: &[JournalEvent]) -> u64 {\n    87\t    events.last().map_or(0, |e| e.sequence)\n    88\t}\n    89\t\n    90\t// ── Lifecycle event builders ────────────────────────────────────────────────\n    91\t\n    92\tuse chrono::{DateTime, Utc};\n    93\tuse crate::shared::domain::{FailureClass, RunId, StageId};\n    94\t\n    95\t/// Build a `run_started` journal event.\n    96\tpub fn run_started_event(\n    97\t    sequence: u64,\n    98\t    timestamp: DateTime<Utc>,\n    99\t    run_id: &RunId,\n   100\t    first_stage: StageId,\n   101\t) -> JournalEvent {\n   102\t    JournalEvent {\n   103\t        sequence,\n   104\t        timestamp,\n   105\t        event_type: JournalEventType::RunStarted,\n   106\t        details: serde_json::json!({\n   107\t            \"run_id\": run_id.as_str(),\n   108\t            \"first_stage\": first_stage.as_str(),\n   109\t        }),\n   110\t    }\n   111\t}\n   112\t\n   113\t/// Build a `run_resumed` journal event.\n   114\tpub fn run_resumed_event(\n   115\t    sequence: u64,\n   116\t    timestamp: DateTime<Utc>,\n   117\t    run_id: &RunId,\n   118\t    resume_stage: StageId,\n   119\t    cycle: u32,\n   120\t) -> JournalEvent {\n   121\t    JournalEvent {\n   122\t        sequence,\n   123\t        timestamp,\n   124\t        event_type: JournalEventType::RunResumed,\n   125\t        details: serde_json::json!({\n   126\t            \"run_id\": run_id.as_str(),\n   127\t            \"resume_stage\": resume_stage.as_str(),\n   128\t            \"cycle\": cycle,\n   129\t        }),\n   130\t    }\n   131\t}\n   132\t\n   133\t/// Build a `stage_entered` journal event.\n   134\tpub fn stage_entered_event(\n   135\t    sequence: u64,\n   136\t    timestamp: DateTime<Utc>,\n   137\t    run_id: &RunId,\n   138\t    stage_id: StageId,\n   139\t    cycle: u32,\n   140\t    attempt: u32,\n   141\t) -> JournalEvent {\n   142\t    JournalEvent {\n   143\t        sequence,\n   144\t        timestamp,\n   145\t        event_type: JournalEventType::StageEntered,\n   146\t        details: serde_json::json!({\n   147\t            \"run_id\": run_id.as_str(),\n   148\t            \"stage_id\": stage_id.as_str(),\n   149\t            \"cycle\": cycle,\n   150\t            \"attempt\": attempt,\n   151\t        }),\n   152\t    }\n   153\t}\n   154\t\n   155\t/// Build a `stage_completed` journal event.\n   156\t#[allow(clippy::too_many_arguments)]\n   157\tpub fn stage_completed_event(\n   158\t    sequence: u64,\n   159\t    timestamp: DateTime<Utc>,\n   160\t    run_id: &RunId,\n   161\t    stage_id: StageId,\n   162\t    cycle: u32,\n   163\t    attempt: u32,\n   164\t    payload_id: &str,\n   165\t    artifact_id: &str,\n   166\t) -> JournalEvent {\n   167\t    JournalEvent {\n   168\t        sequence,\n   169\t        timestamp,\n   170\t        event_type: JournalEventType::StageCompleted,\n   171\t        details: serde_json::json!({\n   172\t            \"run_id\": run_id.as_str(),\n   173\t            \"stage_id\": stage_id.as_str(),\n   174\t            \"cycle\": cycle,\n   175\t            \"attempt\": attempt,\n   176\t            \"payload_id\": payload_id,\n   177\t            \"artifact_id\": artifact_id,\n   178\t        }),\n   179\t    }\n   180\t}\n   181\t\n   182\t/// Build a `stage_failed` journal event.\n   183\t#[allow(clippy::too_many_arguments)]\n   184\tpub fn stage_failed_event(\n   185\t    sequence: u64,\n   186\t    timestamp: DateTime<Utc>,\n   187\t    run_id: &RunId,\n   188\t    stage_id: StageId,\n   189\t    cycle: u32,\n   190\t    attempt: u32,\n   191\t    failure_class: FailureClass,\n   192\t    message: &str,\n   193\t    will_retry: bool,\n   194\t) -> JournalEvent {\n   195\t    JournalEvent {\n   196\t        sequence,\n   197\t        timestamp,\n   198\t        event_type: JournalEventType::StageFailed,\n   199\t        details: serde_json::json!({\n   200\t            \"run_id\": run_id.as_str(),\n   201\t            \"stage_id\": stage_id.as_str(),\n   202\t            \"cycle\": cycle,\n   203\t            \"attempt\": attempt,\n   204\t            \"failure_class\": failure_class,\n   205\t            \"message\": message,\n   206\t            \"will_retry\": will_retry,\n   207\t        }),\n   208\t    }\n   209\t}\n   210\t\n   211\t/// Build a `cycle_advanced` journal event.\n   212\tpub fn cycle_advanced_event(\n   213\t    sequence: u64,\n   214\t    timestamp: DateTime<Utc>,\n   215\t    run_id: &RunId,\n   216\t    from_stage: StageId,\n   217\t    from_cycle: u32,\n   218\t    to_cycle: u32,\n   219\t    resume_stage: StageId,\n   220\t) -> JournalEvent {\n   221\t    JournalEvent {\n   222\t        sequence,\n   223\t        timestamp,\n   224\t        event_type: JournalEventType::CycleAdvanced,\n   225\t        details: serde_json::json!({\n   226\t            \"run_id\": run_id.as_str(),\n   227\t            \"from_stage\": from_stage.as_str(),\n   228\t            \"from_cycle\": from_cycle,\n   229\t            \"to_cycle\": to_cycle,\n   230\t            \"resume_stage\": resume_stage.as_str(),\n   231\t        }),\n   232\t    }\n   233\t}\n   234\t\n   235\t/// Build a `run_completed` journal event.\n   236\tpub fn run_completed_event(\n   237\t    sequence: u64,\n   238\t    timestamp: DateTime<Utc>,\n   239\t    run_id: &RunId,\n   240\t    completion_rounds: u32,\n   241\t) -> JournalEvent {\n   242\t    JournalEvent {\n   243\t        sequence,\n   244\t        timestamp,\n   245\t        event_type: JournalEventType::RunCompleted,\n   246\t        details: serde_json::json!({\n   247\t            \"run_id\": run_id.as_str(),\n   248\t            \"completion_rounds\": completion_rounds,\n   249\t        }),\n   250\t    }\n   251\t}\n   252\t\n   253\t/// Build a `run_failed` journal event.\n   254\tpub fn run_failed_event(\n   255\t    sequence: u64,\n   256\t    timestamp: DateTime<Utc>,\n   257\t    run_id: &RunId,\n   258\t    stage_id: StageId,\n   259\t    failure_class: &str,\n   260\t    message: &str,\n","exit_code":0,"status":"completed"}}
{"type":"item.completed","item":{"id":"item_11","type":"command_execution","command":"/run/current-system/sw/bin/bash -lc \"nl -ba src/contexts/workflow_composition/contracts.rs | sed -n '1,260p'\"","aggregated_output":"     1\t#![forbid(unsafe_code)]\n     2\t\n     3\t//! Stage contract registry and deterministic evaluation pipeline.\n     4\t//!\n     5\t//! Every stage in every built-in flow preset resolves to exactly one\n     6\t//! [`StageContract`]. Contract evaluation enforces a fixed order:\n     7\t//!\n     8\t//! 1. **Schema validation** — deserialize raw JSON into the typed payload.\n     9\t//! 2. **Semantic validation** — apply domain rules to the typed payload.\n    10\t//! 3. **Rendering** — produce a deterministic Markdown artifact.\n    11\t//!\n    12\t//! On schema failure, semantic validation and rendering do not run.\n    13\t//! On domain failure, rendering does not run.\n    14\t//! On any failure, no success bundle is returned.\n    15\t\n    16\tuse schemars::schema::RootSchema;\n    17\t\n    18\tuse crate::shared::domain::StageId;\n    19\tuse crate::shared::error::ContractError;\n    20\t\n    21\tuse super::payloads::{ExecutionPayload, PlanningPayload, StagePayload, ValidationPayload};\n    22\tuse super::renderers;\n    23\t\n    24\t// ── Contract family ─────────────────────────────────────────────────────────\n    25\t\n    26\t/// Classifies a stage into one of three payload families.\n    27\t#[derive(Debug, Clone, Copy, PartialEq, Eq, Hash)]\n    28\tpub enum ContractFamily {\n    29\t    /// prompt_review, planning, docs_plan, ci_plan\n    30\t    Planning,\n    31\t    /// implementation, plan_and_implement, apply_fixes, docs_update, ci_update\n    32\t    Execution,\n    33\t    /// qa, docs_validation, ci_validation, acceptance_qa, review, final_review,\n    34\t    /// completion_panel\n    35\t    Validation,\n    36\t}\n    37\t\n    38\t// ── Stage contract ──────────────────────────────────────────────────────────\n    39\t\n    40\t/// A stage contract binds a [`StageId`] to its payload family, schema,\n    41\t/// semantic validation rules, and renderer.\n    42\t#[derive(Debug, Clone, Copy, PartialEq, Eq)]\n    43\tpub struct StageContract {\n    44\t    pub stage_id: StageId,\n    45\t    pub family: ContractFamily,\n    46\t}\n    47\t\n    48\t/// Bundle of a validated payload and its rendered Markdown artifact.\n    49\t///\n    50\t/// Callers receive either a `ValidatedBundle` or an error — never one without\n    51\t/// the other. On any failure (schema, domain, or QA/review outcome), no bundle\n    52\t/// is returned.\n    53\t#[derive(Debug, Clone, PartialEq, Eq)]\n    54\tpub struct ValidatedBundle {\n    55\t    pub payload: StagePayload,\n    56\t    pub artifact: String,\n    57\t}\n    58\t\n    59\t// ── Registry ────────────────────────────────────────────────────────────────\n    60\t\n    61\t/// Look up the contract for a given stage. Every [`StageId`] variant resolves\n    62\t/// to exactly one contract.\n    63\tpub fn contract_for_stage(stage_id: StageId) -> StageContract {\n    64\t    let family = match stage_id {\n    65\t        StageId::PromptReview | StageId::Planning | StageId::DocsPlan | StageId::CiPlan => {\n    66\t            ContractFamily::Planning\n    67\t        }\n    68\t\n    69\t        StageId::Implementation\n    70\t        | StageId::PlanAndImplement\n    71\t        | StageId::ApplyFixes\n    72\t        | StageId::DocsUpdate\n    73\t        | StageId::CiUpdate => ContractFamily::Execution,\n    74\t\n    75\t        StageId::Qa\n    76\t        | StageId::DocsValidation\n    77\t        | StageId::CiValidation\n    78\t        | StageId::AcceptanceQa\n    79\t        | StageId::Review\n    80\t        | StageId::FinalReview\n    81\t        | StageId::CompletionPanel => ContractFamily::Validation,\n    82\t    };\n    83\t\n    84\t    StageContract { stage_id, family }\n    85\t}\n    86\t\n    87\t/// Return contracts for all stages, in [`StageId::ALL`] order.\n    88\tpub fn all_contracts() -> Vec<StageContract> {\n    89\t    StageId::ALL\n    90\t        .iter()\n    91\t        .map(|&id| contract_for_stage(id))\n    92\t        .collect()\n    93\t}\n    94\t\n    95\t// ── Contract implementation ─────────────────────────────────────────────────\n    96\t\n    97\timpl StageContract {\n    98\t    /// Generate the JSON Schema for this contract's payload family.\n    99\t    pub fn json_schema(&self) -> RootSchema {\n   100\t        match self.family {\n   101\t            ContractFamily::Planning => schemars::schema_for!(PlanningPayload),\n   102\t            ContractFamily::Execution => schemars::schema_for!(ExecutionPayload),\n   103\t            ContractFamily::Validation => schemars::schema_for!(ValidationPayload),\n   104\t        }\n   105\t    }\n   106\t\n   107\t    /// Evaluate a raw JSON value through the full contract pipeline.\n   108\t    ///\n   109\t    /// Schema validation → semantic validation → outcome check → rendering.\n   110\t    ///\n   111\t    /// Returns [`ValidatedBundle`] on success or a [`ContractError`] on any\n   112\t    /// failure. Non-passing QA/review outcomes are errors classified as\n   113\t    /// [`FailureClass::QaReviewOutcomeFailure`] — no success bundle is returned.\n   114\t    pub fn evaluate(&self, raw_json: &serde_json::Value) -> Result<ValidatedBundle, ContractError> {\n   115\t        let bundle = self.evaluate_permissive(raw_json)?;\n   116\t\n   117\t        self.check_outcome(&bundle.payload)?;\n   118\t\n   119\t        Ok(bundle)\n   120\t    }\n   121\t\n   122\t    /// Evaluate a raw JSON value without enforcing passing review outcomes.\n   123\t    ///\n   124\t    /// Schema validation → semantic validation → rendering.\n   125\t    ///\n   126\t    /// This is used by the engine so it can durably persist non-passing\n   127\t    /// validation payloads before applying remediation or terminal semantics.\n   128\t    pub fn evaluate_permissive(\n   129\t        &self,\n   130\t        raw_json: &serde_json::Value,\n   131\t    ) -> Result<ValidatedBundle, ContractError> {\n   132\t        // Step 1: Schema validation (deserialization into typed payload).\n   133\t        let payload = self.validate_schema(raw_json)?;\n   134\t\n   135\t        // Step 2: Semantic / domain validation.\n   136\t        self.validate_semantics(&payload)?;\n   137\t\n   138\t        // Step 3: Deterministic Markdown rendering (without outcome enforcement).\n   139\t        let artifact = self.render(&payload);\n   140\t\n   141\t        Ok(ValidatedBundle { payload, artifact })\n   142\t    }\n   143\t\n   144\t    // ── Private helpers ─────────────────────────────────────────────────\n   145\t\n   146\t    fn validate_schema(&self, raw: &serde_json::Value) -> Result<StagePayload, ContractError> {\n   147\t        match self.family {\n   148\t            ContractFamily::Planning => {\n   149\t                let p: PlanningPayload = serde_json::from_value(raw.clone()).map_err(|e| {\n   150\t                    ContractError::SchemaValidation {\n   151\t                        stage_id: self.stage_id,\n   152\t                        details: e.to_string(),\n   153\t                    }\n   154\t                })?;\n   155\t                Ok(StagePayload::Planning(p))\n   156\t            }\n   157\t            ContractFamily::Execution => {\n   158\t                let p: ExecutionPayload = serde_json::from_value(raw.clone()).map_err(|e| {\n   159\t                    ContractError::SchemaValidation {\n   160\t                        stage_id: self.stage_id,\n   161\t                        details: e.to_string(),\n   162\t                    }\n   163\t                })?;\n   164\t                Ok(StagePayload::Execution(p))\n   165\t            }\n   166\t            ContractFamily::Validation => {\n   167\t                let p: ValidationPayload = serde_json::from_value(raw.clone()).map_err(|e| {\n   168\t                    ContractError::SchemaValidation {\n   169\t                        stage_id: self.stage_id,\n   170\t                        details: e.to_string(),\n   171\t                    }\n   172\t                })?;\n   173\t                Ok(StagePayload::Validation(p))\n   174\t            }\n   175\t        }\n   176\t    }\n   177\t\n   178\t    fn validate_semantics(&self, payload: &StagePayload) -> Result<(), ContractError> {\n   179\t        match payload {\n   180\t            StagePayload::Planning(p) => {\n   181\t                let mut errors = Vec::new();\n   182\t                if p.problem_framing.trim().is_empty() {\n   183\t                    errors.push(\"problem_framing must not be empty\".to_string());\n   184\t                }\n   185\t                if p.proposed_work.is_empty() {\n   186\t                    errors.push(\"proposed_work must contain at least one item\".to_string());\n   187\t                }\n   188\t                for (i, item) in p.proposed_work.iter().enumerate() {\n   189\t                    if item.order == 0 {\n   190\t                        errors.push(format!(\"proposed_work[{i}].order must be positive\"));\n   191\t                    }\n   192\t                }\n   193\t                if !errors.is_empty() {\n   194\t                    return Err(ContractError::DomainValidation {\n   195\t                        stage_id: self.stage_id,\n   196\t                        details: errors.join(\"; \"),\n   197\t                    });\n   198\t                }\n   199\t            }\n   200\t            StagePayload::Execution(p) => {\n   201\t                let mut errors = Vec::new();\n   202\t                if p.change_summary.trim().is_empty() {\n   203\t                    errors.push(\"change_summary must not be empty\".to_string());\n   204\t                }\n   205\t                if p.steps.is_empty() {\n   206\t                    errors.push(\"steps must contain at least one item\".to_string());\n   207\t                }\n   208\t                for (i, step) in p.steps.iter().enumerate() {\n   209\t                    if step.order == 0 {\n   210\t                        errors.push(format!(\"steps[{i}].order must be positive\"));\n   211\t                    }\n   212\t                }\n   213\t                if !errors.is_empty() {\n   214\t                    return Err(ContractError::DomainValidation {\n   215\t                        stage_id: self.stage_id,\n   216\t                        details: errors.join(\"; \"),\n   217\t                    });\n   218\t                }\n   219\t            }\n   220\t            StagePayload::Validation(p) => {\n   221\t                if !p.outcome.is_passing() && p.follow_up_or_amendments.is_empty() {\n   222\t                    return Err(ContractError::DomainValidation {\n   223\t                        stage_id: self.stage_id,\n   224\t                        details: \"follow_up_or_amendments required when outcome is not approved\"\n   225\t                            .to_string(),\n   226\t                    });\n   227\t                }\n   228\t            }\n   229\t        }\n   230\t        Ok(())\n   231\t    }\n   232\t\n   233\t    fn render(&self, payload: &StagePayload) -> String {\n   234\t        match payload {\n   235\t            StagePayload::Planning(p) => renderers::render_planning(self.stage_id, p),\n   236\t            StagePayload::Execution(p) => renderers::render_execution(self.stage_id, p),\n   237\t            StagePayload::Validation(p) => renderers::render_validation(self.stage_id, p),\n   238\t        }\n   239\t    }\n   240\t\n   241\t    fn check_outcome(&self, payload: &StagePayload) -> Result<(), ContractError> {\n   242\t        if let StagePayload::Validation(p) = payload {\n   243\t            if !p.outcome.is_passing() {\n   244\t                return Err(ContractError::QaReviewOutcome {\n   245\t                    stage_id: self.stage_id,\n   246\t                    outcome: p.outcome.to_string(),\n   247\t                });\n   248\t            }\n   249\t        }\n   250\t        Ok(())\n   251\t    }\n   252\t}\n","exit_code":0,"status":"completed"}}
