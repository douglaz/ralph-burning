{"type":"item.completed","item":{"id":"item_12","type":"command_execution","command":"/run/current-system/sw/bin/bash -lc \"nl -ba ralph-burning-rewrite/src/contexts/workflow_composition/contracts.rs | sed -n '1,260p'\"","aggregated_output":"     1\t#![forbid(unsafe_code)]\n     2\t\n     3\t//! Stage contract registry and deterministic evaluation pipeline.\n     4\t//!\n     5\t//! Every stage in every built-in flow preset resolves to exactly one\n     6\t//! [`StageContract`]. Contract evaluation enforces a fixed order:\n     7\t//!\n     8\t//! 1. **Schema validation** — deserialize raw JSON into the typed payload.\n     9\t//! 2. **Semantic validation** — apply domain rules to the typed payload.\n    10\t//! 3. **Rendering** — produce a deterministic Markdown artifact.\n    11\t//!\n    12\t//! On schema failure, semantic validation and rendering do not run.\n    13\t//! On domain failure, rendering does not run.\n    14\t//! On any failure, no success bundle is returned.\n    15\t\n    16\tuse schemars::schema::RootSchema;\n    17\t\n    18\tuse crate::shared::domain::StageId;\n    19\tuse crate::shared::error::ContractError;\n    20\t\n    21\tuse super::payloads::{ExecutionPayload, PlanningPayload, StagePayload, ValidationPayload};\n    22\tuse super::renderers;\n    23\t\n    24\t// ── Contract family ─────────────────────────────────────────────────────────\n    25\t\n    26\t/// Classifies a stage into one of three payload families.\n    27\t#[derive(Debug, Clone, Copy, PartialEq, Eq, Hash)]\n    28\tpub enum ContractFamily {\n    29\t    /// prompt_review, planning, docs_plan, ci_plan\n    30\t    Planning,\n    31\t    /// implementation, plan_and_implement, apply_fixes, docs_update, ci_update\n    32\t    Execution,\n    33\t    /// qa, docs_validation, ci_validation, acceptance_qa, review, final_review,\n    34\t    /// completion_panel\n    35\t    Validation,\n    36\t}\n    37\t\n    38\t// ── Stage contract ──────────────────────────────────────────────────────────\n    39\t\n    40\t/// A stage contract binds a [`StageId`] to its payload family, schema,\n    41\t/// semantic validation rules, and renderer.\n    42\t#[derive(Debug, Clone, Copy, PartialEq, Eq)]\n    43\tpub struct StageContract {\n    44\t    pub stage_id: StageId,\n    45\t    pub family: ContractFamily,\n    46\t}\n    47\t\n    48\t/// Bundle of a validated payload and its rendered Markdown artifact.\n    49\t///\n    50\t/// Callers receive either a `ValidatedBundle` or an error — never one without\n    51\t/// the other. Schema and domain failures still prevent bundle creation. Review\n    52\t/// outcomes are enforced separately by [`StageContract::evaluate`], while\n    53\t/// [`StageContract::evaluate_permissive`] may return a bundle for non-passing\n    54\t/// validation payloads so the engine can persist them before remediation.\n    55\t#[derive(Debug, Clone, PartialEq, Eq)]\n    56\tpub struct ValidatedBundle {\n    57\t    pub payload: StagePayload,\n    58\t    pub artifact: String,\n    59\t}\n    60\t\n    61\t// ── Registry ────────────────────────────────────────────────────────────────\n    62\t\n    63\t/// Look up the contract for a given stage. Every [`StageId`] variant resolves\n    64\t/// to exactly one contract.\n    65\tpub fn contract_for_stage(stage_id: StageId) -> StageContract {\n    66\t    let family = match stage_id {\n    67\t        StageId::PromptReview | StageId::Planning | StageId::DocsPlan | StageId::CiPlan => {\n    68\t            ContractFamily::Planning\n    69\t        }\n    70\t\n    71\t        StageId::Implementation\n    72\t        | StageId::PlanAndImplement\n    73\t        | StageId::ApplyFixes\n    74\t        | StageId::DocsUpdate\n    75\t        | StageId::CiUpdate => ContractFamily::Execution,\n    76\t\n    77\t        StageId::Qa\n    78\t        | StageId::DocsValidation\n    79\t        | StageId::CiValidation\n    80\t        | StageId::AcceptanceQa\n    81\t        | StageId::Review\n    82\t        | StageId::FinalReview\n    83\t        | StageId::CompletionPanel => ContractFamily::Validation,\n    84\t    };\n    85\t\n    86\t    StageContract { stage_id, family }\n    87\t}\n    88\t\n    89\t/// Return contracts for all stages, in [`StageId::ALL`] order.\n    90\tpub fn all_contracts() -> Vec<StageContract> {\n    91\t    StageId::ALL\n    92\t        .iter()\n    93\t        .map(|&id| contract_for_stage(id))\n    94\t        .collect()\n    95\t}\n    96\t\n    97\t// ── Contract implementation ─────────────────────────────────────────────────\n    98\t\n    99\timpl StageContract {\n   100\t    /// Generate the JSON Schema for this contract's payload family.\n   101\t    pub fn json_schema(&self) -> RootSchema {\n   102\t        match self.family {\n   103\t            ContractFamily::Planning => schemars::schema_for!(PlanningPayload),\n   104\t            ContractFamily::Execution => schemars::schema_for!(ExecutionPayload),\n   105\t            ContractFamily::Validation => schemars::schema_for!(ValidationPayload),\n   106\t        }\n   107\t    }\n   108\t\n   109\t    /// Evaluate a raw JSON value through the full contract pipeline.\n   110\t    ///\n   111\t    /// Schema validation → semantic validation → outcome check → rendering.\n   112\t    ///\n   113\t    /// Returns [`ValidatedBundle`] on success or a [`ContractError`] on any\n   114\t    /// failure. Non-passing QA/review outcomes are still errors here and are\n   115\t    /// classified as [`FailureClass::QaReviewOutcomeFailure`].\n   116\t    pub fn evaluate(&self, raw_json: &serde_json::Value) -> Result<ValidatedBundle, ContractError> {\n   117\t        let bundle = self.evaluate_permissive(raw_json)?;\n   118\t\n   119\t        self.check_outcome(&bundle.payload)?;\n   120\t\n   121\t        Ok(bundle)\n   122\t    }\n   123\t\n   124\t    /// Evaluate a raw JSON value without enforcing passing review outcomes.\n   125\t    ///\n   126\t    /// Schema validation → semantic validation → rendering.\n   127\t    ///\n   128\t    /// This is used by the engine so it can durably persist non-passing\n   129\t    /// validation payloads before applying remediation or terminal semantics.\n   130\t    pub fn evaluate_permissive(\n   131\t        &self,\n   132\t        raw_json: &serde_json::Value,\n   133\t    ) -> Result<ValidatedBundle, ContractError> {\n   134\t        // Step 1: Schema validation (deserialization into typed payload).\n   135\t        let payload = self.validate_schema(raw_json)?;\n   136\t\n   137\t        // Step 2: Semantic / domain validation.\n   138\t        self.validate_semantics(&payload)?;\n   139\t\n   140\t        // Step 3: Deterministic Markdown rendering (without outcome enforcement).\n   141\t        let artifact = self.render(&payload);\n   142\t\n   143\t        Ok(ValidatedBundle { payload, artifact })\n   144\t    }\n   145\t\n   146\t    // ── Private helpers ─────────────────────────────────────────────────\n   147\t\n   148\t    fn validate_schema(&self, raw: &serde_json::Value) -> Result<StagePayload, ContractError> {\n   149\t        match self.family {\n   150\t            ContractFamily::Planning => {\n   151\t                let p: PlanningPayload = serde_json::from_value(raw.clone()).map_err(|e| {\n   152\t                    ContractError::SchemaValidation {\n   153\t                        stage_id: self.stage_id,\n   154\t                        details: e.to_string(),\n   155\t                    }\n   156\t                })?;\n   157\t                Ok(StagePayload::Planning(p))\n   158\t            }\n   159\t            ContractFamily::Execution => {\n   160\t                let p: ExecutionPayload = serde_json::from_value(raw.clone()).map_err(|e| {\n   161\t                    ContractError::SchemaValidation {\n   162\t                        stage_id: self.stage_id,\n   163\t                        details: e.to_string(),\n   164\t                    }\n   165\t                })?;\n   166\t                Ok(StagePayload::Execution(p))\n   167\t            }\n   168\t            ContractFamily::Validation => {\n   169\t                let p: ValidationPayload = serde_json::from_value(raw.clone()).map_err(|e| {\n   170\t                    ContractError::SchemaValidation {\n   171\t                        stage_id: self.stage_id,\n   172\t                        details: e.to_string(),\n   173\t                    }\n   174\t                })?;\n   175\t                Ok(StagePayload::Validation(p))\n   176\t            }\n   177\t        }\n   178\t    }\n   179\t\n   180\t    fn validate_semantics(&self, payload: &StagePayload) -> Result<(), ContractError> {\n   181\t        match payload {\n   182\t            StagePayload::Planning(p) => {\n   183\t                let mut errors = Vec::new();\n   184\t                if p.problem_framing.trim().is_empty() {\n   185\t                    errors.push(\"problem_framing must not be empty\".to_string());\n   186\t                }\n   187\t                if p.proposed_work.is_empty() {\n   188\t                    errors.push(\"proposed_work must contain at least one item\".to_string());\n   189\t                }\n   190\t                for (i, item) in p.proposed_work.iter().enumerate() {\n   191\t                    if item.order == 0 {\n   192\t                        errors.push(format!(\"proposed_work[{i}].order must be positive\"));\n   193\t                    }\n   194\t                }\n   195\t                if !errors.is_empty() {\n   196\t                    return Err(ContractError::DomainValidation {\n   197\t                        stage_id: self.stage_id,\n   198\t                        details: errors.join(\"; \"),\n   199\t                    });\n   200\t                }\n   201\t            }\n   202\t            StagePayload::Execution(p) => {\n   203\t                let mut errors = Vec::new();\n   204\t                if p.change_summary.trim().is_empty() {\n   205\t                    errors.push(\"change_summary must not be empty\".to_string());\n   206\t                }\n   207\t                if p.steps.is_empty() {\n   208\t                    errors.push(\"steps must contain at least one item\".to_string());\n   209\t                }\n   210\t                for (i, step) in p.steps.iter().enumerate() {\n   211\t                    if step.order == 0 {\n   212\t                        errors.push(format!(\"steps[{i}].order must be positive\"));\n   213\t                    }\n   214\t                }\n   215\t                if !errors.is_empty() {\n   216\t                    return Err(ContractError::DomainValidation {\n   217\t                        stage_id: self.stage_id,\n   218\t                        details: errors.join(\"; \"),\n   219\t                    });\n   220\t                }\n   221\t            }\n   222\t            StagePayload::Validation(p) => {\n   223\t                if !p.outcome.is_passing() && p.follow_up_or_amendments.is_empty() {\n   224\t                    return Err(ContractError::DomainValidation {\n   225\t                        stage_id: self.stage_id,\n   226\t                        details: \"follow_up_or_amendments required when outcome is not approved\"\n   227\t                            .to_string(),\n   228\t                    });\n   229\t                }\n   230\t            }\n   231\t        }\n   232\t        Ok(())\n   233\t    }\n   234\t\n   235\t    fn render(&self, payload: &StagePayload) -> String {\n   236\t        match payload {\n   237\t            StagePayload::Planning(p) => renderers::render_planning(self.stage_id, p),\n   238\t            StagePayload::Execution(p) => renderers::render_execution(self.stage_id, p),\n   239\t            StagePayload::Validation(p) => renderers::render_validation(self.stage_id, p),\n   240\t        }\n   241\t    }\n   242\t\n   243\t    fn check_outcome(&self, payload: &StagePayload) -> Result<(), ContractError> {\n   244\t        if let StagePayload::Validation(p) = payload {\n   245\t            if !p.outcome.is_passing() {\n   246\t                return Err(ContractError::QaReviewOutcome {\n   247\t                    stage_id: self.stage_id,\n   248\t                    outcome: p.outcome.to_string(),\n   249\t                });\n   250\t            }\n   251\t        }\n   252\t        Ok(())\n   253\t    }\n   254\t}\n","exit_code":0,"status":"completed"}}
