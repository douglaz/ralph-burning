ters\n    86\t            .insert(stage_id, Arc::new(AtomicU32::new(0)));\n    87\t        self\n    88\t    }\n    89\t\n    90\t    pub fn cancelled_invocations(&self) -> Vec<String> {\n    91\t        self.cancelled_invocations\n    92\t            .lock()\n    93\t            .expect(\"cancelled invocation lock poisoned\")\n    94\t            .clone()\n    95\t    }\n    96\t\n    97\t    fn payload_for_stage(&self, stage_id: StageId) -> Value {\n    98\t        let overrides = self\n    99\t            .stage_payload_overrides\n   100\t            .lock()\n   101\t            .expect(\"stage payload override lock poisoned\");\n   102\t        let Some(payloads) = overrides.get(&stage_id) else {\n   103\t            return canned_payload_for_stage(stage_id);\n   104\t        };\n   105\t        let Some(counter) = self.stage_payload_counters.get(&stage_id) else {\n   106\t            return payloads\n   107\t                .last()\n   108\t                .cloned()\n   109\t                .unwrap_or_else(|| canned_payload_for_stage(stage_id));\n   110\t        };\n   111\t        let idx = counter.fetch_add(1, Ordering::SeqCst) as usize;\n   112\t        payloads\n   113\t            .get(idx)\n   114\t            .cloned()\n   115\t            .or_else(|| payloads.last().cloned())\n   116\t            .unwrap_or_else(|| canned_payload_for_stage(stage_id))\n   117\t    }\n   118\t}\n   119\t\n   120\timpl AgentExecutionPort for StubBackendAdapter {\n   121\t    async fn check_capability(\n   122\t        &self,\n   123\t        backend: &crate::shared::domain::ResolvedBackendTarget,\n   124\t        stage_contract: &crate::contexts::workflow_composition::contracts::StageContract,\n   125\t    ) -> AppResult<()> {\n   126\t        if self.unsupported_stages.contains(&stage_contract.stage_id)\n   127\t            || !backend.supports_stage(stage_contract.stage_id)\n   128\t        {\n   129\t            return Err(AppError::CapabilityMismatch {\n   130\t                backend: backend.backend.family.to_string(),\n   131\t                stage_id: stage_contract.stage_id,\n   132\t                details: \"stub adapter does not support the requested stage\".to_owned(),\n   133\t            });\n   134\t        }\n   135\t\n   136\t        Ok(())\n   137\t    }\n   138\t\n   139\t    async fn check_availability(\n   140\t        &self,\n   141\t        backend: &crate::shared::domain::ResolvedBackendTarget,\n   142\t    ) -> AppResult<()> {\n   143\t        if self.available {\n   144\t            Ok(())\n   145\t        } else {\n   146\t            Err(AppError::BackendUnavailable {\n   147\t                backend: backend.backend.family.to_string(),\n   148\t                details: \"stub adapter configured as unavailable\".to_owned(),\n   149\t            })\n   150\t        }\n   151\t    }\n   152\t\n   153\t    async fn invoke(&self, request: InvocationRequest) -> AppResult<InvocationEnvelope> {\n   154\t        if request.cancellation_token.is_cancelled() {\n   155\t            return Err(AppError::InvocationCancelled {\n   156\t                backend: request.resolved_target.backend.family.to_string(),\n   157\t                stage_id: request.stage_contract.stage_id,\n   158\t            });\n   159\t        }\n   160\t\n   161\t        if let Some(limit) = self\n   162\t            .transient_failure_limits\n   163\t            .get(&request.stage_contract.stage_id)\n   164\t        {\n   165\t            let counter = self\n   166\t                .transient_failure_counters\n   167\t                .get(&request.stage_contract.stage_id)\n   168\t                .expect(\"transient failure counter missing\");\n   169\t            let attempt = counter.fetch_add(1, Ordering::SeqCst) + 1;\n   170\t            if attempt <= *limit {\n   171\t                return Err(AppError::InvocationFailed {\n   172\t                    backend: request.resolved_target.backend.family.to_string(),\n   173\t                    stage_id: request.stage_contract.stage_id,\n   174\t                    failure_class: FailureClass::TransportFailure,\n   175\t                    details: format!(\n   176\t                        \"stub adapter configured to fail invocation {attempt}/{limit} for this stage\"\n   177\t                    ),\n   178\t                });\n   179\t            }\n   180\t        }\n   181\t\n   182\t        if self\n   183\t            .fail_invoke_stages\n   184\t            .contains(&request.stage_contract.stage_id)\n   185\t        {\n   186\t            return Err(AppError::InvocationFailed {\n   187\t                backend: request.resolved_target.backend.family.to_string(),\n   188\t                stage_id: request.stage_contract.stage_id,\n   189\t                failure_class: FailureClass::TransportFailure,\n   190\t                details: \"stub adapter configured to fail invocation for this stage\".to_owned(),\n   191\t            });\n   192\t        }\n   193\t\n   194\t        if self.delay > Duration::from_millis(0) {\n   195\t            tokio::select! {\n   196\t                _ = request.cancellation_token.cancelled() => {\n   197\t                    return Err(AppError::InvocationCancelled {\n   198\t                        backend: request.resolved_target.backend.family.to_string(),\n   199\t                        stage_id: request.stage_contract.stage_id,\n   200\t                    });\n   201\t                }\n   202\t                _ = tokio::time::sleep(self.delay) => {}\n   203\t            }\n   204\t        }\n   205\t\n   206\t        let payload = self.payload_for_stage(request.stage_contract.stage_id);\n   207\t        let raw_output = serde_json::to_string_pretty(&payload)?;\n   208\t        let prompt_token_count = count_tokens(&request.payload.prompt);\n   209\t        let completion_token_count = count_tokens(&raw_output);\n   210\t        let prompt_tokens = Some(prompt_token_count);\n   211\t        let completion_tokens = Some(completion_token_count);\n   212\t        let total_tokens = Some(prompt_token_count + completion_token_count);\n   213\t\n   214\t        let supports_reuse =\n   215\t            request.role.allows_session_reuse() && request.resolved_target.supports_session_reuse();\n   216\t        let session_reused = supports_reuse\n   217\t            && matches!(request.session_policy, SessionPolicy::ReuseIfAllowed)\n   218\t            && request.prior_session.is_some();\n   219\t        let session_id = if supports_reuse {\n   220\t            request\n   221\t                .prior_session\n   222\t                .as_ref()\n   223\t                .map(|session| session.session_id.clone())\n   224\t                .filter(|_| session_reused)\n   225\t                .or_else(|| {\n   226\t                    Some(format!(\n   227\t                        \"stub-{}-{}\",\n   228\t                        request.role.as_str(),\n   229\t                        request.stage_contract.stage_id.as_str()\n   230\t                    ))\n   231\t                })\n   232\t        } else {\n   233\t            None\n   234\t        };\n   235\t\n   236\t        Ok(InvocationEnvelope {\n   237\t            raw_output_reference: RawOutputReference::Inline(raw_output),\n   238\t            parsed_payload: serde_json::Value::Null,\n   239\t            metadata: InvocationMetadata {\n   240\t                invocation_id: request.invocation_id,\n   241\t                duration: Duration::from_millis(0),\n   242\t                token_counts: TokenCounts {\n   243\t                    prompt_tokens,\n   244\t                    completion_tokens,\n   245\t                    total_tokens,\n   246\t                },\n   247\t                backend_used: request.resolved_target.backend,\n   248\t                model_used: request.resolved_target.model,\n   249\t                attempt_number: request.attempt_number,\n   250\t                session_id,\n   251\t                session_reused,\n   252\t            },\n   253\t            timestamp: Utc::now(),\n   254\t        })\n   255\t    }\n   256\t\n   257\t    async fn cancel(&self, invocation_id: &str) -> AppResult<()> {\n   258\t        self.cancelled_invocations\n   259\t            .lock()\n   260\t            .expect(\"cancelled invocation lock poisoned\")\n   261\t            .push(invocation_id.to_owned());\n   262\t        Ok(())\n   263\t    }\n   264\t}\n   265\t\n   266\tfn count_tokens(contents: &str) -> u32 {\n   267\t    contents.split_whitespace().count() as u32\n   268\t}\n   269\t\n   270\tfn canned_payload_for_stage(stage_id: StageId) -> serde_json::Value {\n   271\t    match stage_id {\n   272\t        StageId::PromptReview | StageId::Planning | StageId::DocsPlan | StageId::CiPlan => json!({\n   273\t            \"problem_framing\": format!(\"Stub planning output for {}\", stage_id.display_name()),\n   274\t            \"assumptions_or_open_questions\": [\n   275\t                format!(\"Assumption captured for {}\", stage_id.as_str())\n   276\t            ],\n   277\t            \"proposed_work\": [\n   278\t                {\n   279\t                    \"order\": 1,\n   280\t                    \"summary\": format!(\"Complete {}\", stage_id.display_name()),\n","exit_code":0,"status":"completed"}}
