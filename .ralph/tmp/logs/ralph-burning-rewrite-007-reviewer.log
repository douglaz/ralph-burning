t            session_policy: SessionPolicy::ReuseIfAllowed,\n   901\t            prior_session: None,\n   902\t            attempt_number: cursor.attempt,\n   903\t        };\n   904\t\n   905\t        let result = agent_service.invoke(request).await.and_then(|envelope| {\n   906\t            stage_entry\n   907\t                .contract\n   908\t                .evaluate_permissive(&envelope.parsed_payload)\n   909\t                .map_err(|contract_error| AppError::InvocationFailed {\n   910\t                    backend: stage_entry.target.backend.family.to_string(),\n   911\t                    stage_id,\n   912\t                    failure_class: contract_error.failure_class(),\n   913\t                    details: contract_error.to_string(),\n   914\t                })\n   915\t        });\n   916\t\n   917\t        match result {\n   918\t            Ok(bundle) => return Ok((cursor.clone(), bundle)),\n   919\t            Err(error) => {\n   920\t                let Some(failure_class) = error.failure_class() else {\n   921\t                    return fail_run_result(\n   922\t                        &error,\n   923\t                        stage_id,\n   924\t                        run_id,\n   925\t                        seq,\n   926\t                        snapshot,\n   927\t                        journal_store,\n   928\t                        run_snapshot_write,\n   929\t                        base_dir,\n   930\t                        project_id,\n   931\t                        origin,\n   932\t                    )\n   933\t                    .await;\n   934\t                };\n   935\t\n   936\t                let max_attempts = retry_policy.max_attempts(failure_class);\n   937\t                let will_retry = retry_policy.is_retryable(failure_class)\n   938\t                    && cursor.attempt < max_attempts\n   939\t                    && !matches!(failure_class, FailureClass::Cancellation)\n   940\t                    && !cancellation_token.is_cancelled();\n   941\t\n   942\t                *seq += 1;\n   943\t                let stage_failed = journal::stage_failed_event(\n   944\t                    *seq,\n   945\t                    Utc::now(),\n   946\t                    run_id,\n   947\t                    stage_id,\n   948\t                    cursor.cycle,\n   949\t                    cursor.attempt,\n   950\t                    failure_class,\n   951\t                    &error.to_string(),\n   952\t                    will_retry,\n   953\t                );\n   954\t                let stage_failed_line = journal::serialize_event(&stage_failed)?;\n   955\t                if let Err(append_error) =\n   956\t                    journal_store.append_event(base_dir, project_id, &stage_failed_line)\n   957\t                {\n   958\t                    *seq -= 1;\n   959\t                    return fail_run_result(\n   960\t                        &AppError::StageCommitFailed {\n   961\t                            stage_id,\n   962\t                            details: format!(\n   963\t                                \"failed to persist stage_failed event for {}: {}\",\n   964\t                                stage_id.as_str(),\n   965\t                                append_error\n   966\t                            ),\n   967\t                        },\n   968\t                        stage_id,\n   969\t                        run_id,\n   970\t                        seq,\n   971\t                        snapshot,\n   972\t                        journal_store,\n   973\t                        run_snapshot_write,\n   974\t                        base_dir,\n   975\t                        project_id,\n   976\t                        origin,\n   977\t                    )\n   978\t                    .await;\n   979\t                }\n   980\t\n   981\t                let _ = log_write.append_runtime_log(\n   982\t                    base_dir,\n   983\t                    project_id,\n   984\t                    &RuntimeLogEntry {\n   985\t                        timestamp: Utc::now(),\n   986\t                        level: LogLevel::Warn,\n   987\t                        source: \"engine\".to_owned(),\n   988\t                        message: format!(\n   989\t                            \"stage_failed: {} cycle={} attempt={} retry={}\",\n   990\t                            stage_id.as_str(),\n   991\t                            cursor.cycle,\n   992\t                            cursor.attempt,\n   993\t                            will_retry\n   994\t                        ),\n   995\t                    },\n   996\t                );\n   997\t\n   998\t                if will_retry {\n   999\t                    cursor = cursor.retry();\n  1000\t                    continue;\n  1001\t                }\n  1002\t\n  1003\t                return fail_run_result(\n  1004\t                    &error,\n  1005\t                    stage_id,\n  1006\t                    run_id,\n  1007\t                    seq,\n  1008\t                    snapshot,\n  1009\t                    journal_store,\n  1010\t                    run_snapshot_write,\n  1011\t                    base_dir,\n  1012\t                    project_id,\n  1013\t                    origin,\n  1014\t                )\n  1015\t                .await;\n  1016\t            }\n  1017\t        }\n  1018\t    }\n  1019\t}\n  1020\t\n  1021\t#[allow(clippy::too_many_arguments)]\n  1022\tasync fn persist_stage_success(\n  1023\t    artifact_write: &dyn PayloadArtifactWritePort,\n  1024\t    journal_store: &dyn JournalStorePort,\n  1025\t    run_snapshot_write: &dyn RunSnapshotWritePort,\n  1026\t    log_write: &dyn RuntimeLogWritePort,\n  1027\t    base_dir: &Path,\n  1028\t    project_id: &ProjectId,\n  1029\t    run_id: &RunId,\n  1030\t    seq: &mut u64,\n  1031\t    snapshot: &mut RunSnapshot,\n  1032\t    stage_id: StageId,\n  1033\t    cursor: &StageCursor,\n  1034\t    bundle: &ValidatedBundle,\n  1035\t    origin: ExecutionOrigin,\n  1036\t) -> AppResult<()> {\n  1037\t    let stage_now = Utc::now();\n  1038\t    let payload_id = format!(\n  1039\t        \"{}-{}-c{}-a{}\",\n  1040\t        run_id.as_str(),\n  1041\t        stage_id.as_str(),\n  1042\t        cursor.cycle,\n  1043\t        cursor.attempt\n  1044\t    );\n  1045\t    let artifact_id = format!(\"{}-artifact\", payload_id);\n  1046\t\n  1047\t    let payload_record = PayloadRecord {\n  1048\t        payload_id: payload_id.clone(),\n  1049\t        stage_id,\n  1050\t        cycle: cursor.cycle,\n  1051\t        attempt: cursor.attempt,\n  1052\t        created_at: stage_now,\n  1053\t        payload: serde_json::to_value(&bundle.payload)?,\n  1054\t    };\n  1055\t    let artifact_record = ArtifactRecord {\n  1056\t        artifact_id: artifact_id.clone(),\n  1057\t        payload_id: payload_id.clone(),\n  1058\t        stage_id,\n  1059\t        created_at: stage_now,\n  1060\t        content: bundle.artifact.clone(),\n","exit_code":0,"status":"completed"}}
