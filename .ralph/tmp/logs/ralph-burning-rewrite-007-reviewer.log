not satisfy stage '{stage_id}': {details}\")]\n    70\t    CapabilityMismatch {\n    71\t        backend: String,\n    72\t        stage_id: StageId,\n    73\t        details: String,\n    74\t    },\n    75\t    #[error(\"backend invocation failed for stage '{stage_id}' via '{backend}': {details}\")]\n    76\t    InvocationFailed {\n    77\t        backend: String,\n    78\t        stage_id: StageId,\n    79\t        failure_class: FailureClass,\n    80\t        details: String,\n    81\t    },\n    82\t    #[error(\n    83\t        \"backend invocation timed out for stage '{stage_id}' via '{backend}' after {timeout_ms} ms\"\n    84\t    )]\n    85\t    InvocationTimeout {\n    86\t        backend: String,\n    87\t        stage_id: StageId,\n    88\t        timeout_ms: u64,\n    89\t    },\n    90\t    #[error(\"backend invocation cancelled for stage '{stage_id}' via '{backend}'\")]\n    91\t    InvocationCancelled { backend: String, stage_id: StageId },\n    92\t    #[error(\"remediation exhausted at cycle {cycle}; maximum supported cycles is {max}\")]\n    93\t    RemediationExhausted { cycle: u32, max: u32 },\n    94\t    #[error(transparent)]\n    95\t    Io(#[from] std::io::Error),\n    96\t    #[error(transparent)]\n    97\t    TomlDeserialize(#[from] toml::de::Error),\n    98\t    #[error(transparent)]\n    99\t    TomlSerialize(#[from] toml::ser::Error),\n   100\t    #[error(transparent)]\n   101\t    TomlEdit(#[from] toml_edit::TomlError),\n   102\t    #[error(transparent)]\n   103\t    SerdeJson(#[from] serde_json::Error),\n   104\t}\n   105\t\n   106\t/// Errors specific to stage contract evaluation.\n   107\t///\n   108\t/// Each variant maps to a distinct [`FailureClass`] for retry/terminal policy.\n   109\t#[derive(Debug, Error)]\n   110\tpub enum ContractError {\n   111\t    #[error(\"schema validation failed for stage '{stage_id}': {details}\")]\n   112\t    SchemaValidation { stage_id: StageId, details: String },\n   113\t\n   114\t    #[error(\"domain validation failed for stage '{stage_id}': {details}\")]\n   115\t    DomainValidation { stage_id: StageId, details: String },\n   116\t\n   117\t    #[error(\"rendering failed for stage '{stage_id}': {details}\")]\n   118\t    RenderError { stage_id: StageId, details: String },\n   119\t\n   120\t    #[error(\"non-passing QA/review outcome for stage '{stage_id}': {outcome}\")]\n   121\t    QaReviewOutcome { stage_id: StageId, outcome: String },\n   122\t}\n   123\t\n   124\timpl ContractError {\n   125\t    pub fn failure_class(&self) -> FailureClass {\n   126\t        match self {\n   127\t            Self::SchemaValidation { .. } => FailureClass::SchemaValidationFailure,\n   128\t            Self::DomainValidation { .. } | Self::RenderError { .. } => {\n   129\t                FailureClass::DomainValidationFailure\n   130\t            }\n   131\t            Self::QaReviewOutcome { .. } => FailureClass::QaReviewOutcomeFailure,\n   132\t        }\n   133\t    }\n   134\t\n   135\t    pub fn stage_id(&self) -> StageId {\n   136\t        match self {\n   137\t            Self::SchemaValidation { stage_id, .. }\n   138\t            | Self::DomainValidation { stage_id, .. }\n   139\t            | Self::RenderError { stage_id, .. }\n   140\t            | Self::QaReviewOutcome { stage_id, .. } => *stage_id,\n   141\t        }\n   142\t    }\n   143\t}\n   144\t\n   145\timpl AppError {\n   146\t    pub fn failure_class(&self) -> Option<FailureClass> {\n   147\t        match self {\n   148\t            Self::BackendUnavailable { .. } => Some(FailureClass::TransportFailure),\n   149\t            Self::CapabilityMismatch { .. } => Some(FailureClass::DomainValidationFailure),\n   150\t            Self::InvocationFailed { failure_class, .. } => Some(*failure_class),\n   151\t            Self::InvocationTimeout { .. } => Some(FailureClass::Timeout),\n   152\t            Self::InvocationCancelled { .. } => Some(FailureClass::Cancellation),\n   153\t            _ => None,\n   154\t        }\n   155\t    }\n   156\t}\n","exit_code":0,"status":"completed"}}
