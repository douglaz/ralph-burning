d_reuses_prior_session_when_role_and_backend_allow_it() {\n    81\t    let adapter = StubBackendAdapter::default();\n    82\t    let timestamp = Utc\n    83\t        .with_ymd_and_hms(2026, 3, 11, 21, 0, 0)\n    84\t        .single()\n    85\t        .expect(\"valid timestamp\");\n    86\t    let mut request = request_fixture(StageId::Implementation);\n    87\t    request.session_policy = SessionPolicy::ReuseIfAllowed;\n    88\t    request.prior_session = Some(SessionMetadata {\n    89\t        role: BackendRole::Implementer,\n    90\t        backend_family: BackendFamily::Codex,\n    91\t        model_id: \"gpt-5-codex\".to_owned(),\n    92\t        session_id: \"existing-session\".to_owned(),\n    93\t        created_at: timestamp,\n    94\t        last_used_at: timestamp,\n    95\t        invocation_count: 1,\n    96\t    });\n    97\t\n    98\t    let envelope = adapter\n    99\t        .invoke(request)\n   100\t        .await\n   101\t        .expect(\"invoke with session reuse\");\n   102\t\n   103\t    assert!(envelope.metadata.session_reused);\n   104\t    assert_eq!(\n   105\t        envelope.metadata.session_id.as_deref(),\n   106\t        Some(\"existing-session\")\n   107\t    );\n   108\t}\n   109\t\n   110\t#[tokio::test(flavor = \"multi_thread\")]\n   111\tasync fn stub_backend_cancel_is_callable() {\n   112\t    let adapter = StubBackendAdapter::default();\n   113\t    adapter.cancel(\"stub-cancel\").await.expect(\"cancel stub\");\n   114\t    assert_eq!(\n   115\t        adapter.cancelled_invocations(),\n   116\t        vec![\"stub-cancel\".to_owned()]\n   117\t    );\n   118\t}\n   119\t\n   120\t#[tokio::test(flavor = \"multi_thread\")]\n   121\tasync fn stub_backend_transient_failure_succeeds_after_fail_count() {\n   122\t    let adapter = StubBackendAdapter::default().with_transient_failure(StageId::Implementation, 1);\n   123\t    let request = request_fixture(StageId::Implementation);\n   124\t\n   125\t    let first = adapter\n   126\t       