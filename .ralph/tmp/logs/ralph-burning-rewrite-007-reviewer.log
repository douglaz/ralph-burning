.with_rule(FailureClass::Timeout, RetryRule::retryable(4))\n    39\t        .with_max_remediation_cycles(5);\n    40\t\n    41\t    assert_eq!(policy.max_attempts(FailureClass::Timeout), 4);\n    42\t    assert!(policy.is_retryable(FailureClass::Timeout));\n    43\t    assert_eq!(policy.max_remediation_cycles(), 5);\n    44\t}\n","exit_code":0,"status":"completed"}}
