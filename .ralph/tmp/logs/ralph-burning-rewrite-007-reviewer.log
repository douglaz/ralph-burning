{"type":"item.completed","item":{"id":"item_24","type":"command_execution","command":"/run/current-system/sw/bin/bash -lc \"nl -ba ralph-burning-rewrite/tests/unit/retry_policy_test.rs | sed -n '1,220p'\"","aggregated_output":"     1\tuse ralph_burning::contexts::workflow_composition::retry_policy::{RetryPolicy, RetryRule};\n     2\tuse ralph_burning::shared::domain::FailureClass;\n     3\t\n     4\t#[test]\n     5\tfn default_retry_policy_matches_specified_attempt_limits() {\n     6\t    let policy = RetryPolicy::default_policy();\n     7\t\n     8\t    assert_eq!(policy.max_attempts(FailureClass::TransportFailure), 3);\n     9\t    assert_eq!(\n    10\t        policy.max_attempts(FailureClass::SchemaValidationFailure),\n    11\t        2\n    12\t    );\n    13\t    assert_eq!(\n    14\t        policy.max_attempts(FailureClass::DomainValidationFailure),\n    15\t        2\n    16\t    );\n    17\t    assert_eq!(policy.max_attempts(FailureClass::Timeout), 2);\n    18\t    assert_eq!(policy.max_attempts(FailureClass::Cancellation), 1);\n    19\t    assert_eq!(policy.max_attempts(FailureClass::QaReviewOutcomeFailure), 1);\n    20\t    assert_eq!(policy.max_remediation_cycles(), 3);\n    21\t}\n    22\t\n    23\t#[test]\n    24\tfn default_retry_policy_marks_retryable_and_terminal_classes() {\n    25\t    let policy = RetryPolicy::default_policy();\n    26\t\n    27\t    assert!(policy.is_retryable(FailureClass::TransportFailure));\n    28\t    assert!(policy.is_retryable(FailureClass::SchemaValidationFailure));\n    29\t    assert!(policy.is_retryable(FailureClass::DomainValidationFailure));\n    30\t    assert!(policy.is_retryable(FailureClass::Timeout));\n    31\t    assert!(!policy.is_retryable(FailureClass::Cancellation));\n    32\t    assert!(!policy.is_retryable(FailureClass::QaReviewOutcomeFailure));\n    33\t}\n    34\t\n    35\t#[test]\n    36\tfn retry_policy_can_be_customized() {\n    37\t    let policy = RetryPolicy::default_policy()\n    38\t        .with_rule(FailureClass::Timeout, RetryRule::retryable(4))\n    39\t        .with_max_remediation_cycles(5);\n    40\t\n    41\t    assert_eq!(policy.max_attempts(FailureClass::Timeout), 4);\n    42\t    assert!(policy.is_retryable(FailureClass::Timeout));\n    43\t    assert_eq!(policy.max_remediation_cycles(), 5);\n    44\t}\n","exit_code":0,"status":"completed"}}
