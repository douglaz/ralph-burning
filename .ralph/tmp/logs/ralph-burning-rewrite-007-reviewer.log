w(clippy::too_many_arguments)]\n  1195\tasync fn fail_run(\n  1196\t    err: &AppError,\n  1197\t    stage_id: StageId,\n  1198\t    run_id: &RunId,\n  1199\t    seq: &mut u64,\n  1200\t    snapshot: &mut RunSnapshot,\n  1201\t    journal_store: &dyn JournalStorePort,\n  1202\t    run_snapshot_write: &dyn RunSnapshotWritePort,\n  1203\t    base_dir: &Path,\n  1204\t    project_id: &ProjectId,\n  1205\t    origin: ExecutionOrigin,\n  1206\t) -> AppResult<()> {\n  1207\t    let failure_class = failure_label(err);\n  1208\t    let message = err.to_string();\n  1209\t\n  1210\t    snapshot.status = RunStatus::Failed;\n  1211\t    snapshot.active_run = None;\n  1212\t    snapshot.status_summary = format!(\"failed at {}: {}\", stage_id.display_name(), message);\n  1213\t    run_snapshot_write.write_run_snapshot(base_dir, project_id, snapshot)?;\n  1214\t\n  1215\t    *seq += 1;\n  1216\t    let run_failed =\n  1217\t        journal::run_failed_event(*seq, Utc::now(), run_id, stage_id, &failure_class, &message);\n  1218\t    if let Ok(run_failed_line) = journal::serialize_event(&run_failed) {\n  1219\t        let _ = journal_store.append_event(base_dir, project_id, &run_failed_line);\n  1220\t    }\n  1221\t\n  1222\t    Err(origin.error(format!(\"stage {} failed: {}\", stage_id.as_str(), message)))\n  1223\t}\n  1224\t\n  1225\t#[allow(clippy::too_many_arguments)]\n  1226\tasync fn fail_run_result<T>(\n  1227\t    err: &AppError,\n  1228\t    stage_id: StageId,\n  1229\t    run_id: &RunId,\n  1230\t    seq: &mut u64,\n  1231\t    snapshot: &mut RunSnapshot,\n  1232\t    journal_store: &dyn JournalStorePort,\n  1233\t    run_snapshot_write: &dyn RunSnapshotWritePort,\n  1234\t    base_dir: &Path,\n  1235\t    project_id: &ProjectId,\n  1236\t    origin: ExecutionOrigin,\n  1237\t) -> AppResult<T> {\n  1238\t    fail_run(\n  1239\t        err,\n  1240\t        stage_id,\n  1241\t        run_id,\n  1242\t        seq,\n  1243\t        snapshot,\n  1244\t        journal_store,