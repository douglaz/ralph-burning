RunSubcommand::Tail { logs } => handle_tail(logs).await,\n    47\t        RunSubcommand::Start => handle_start().await,\n    48\t        RunSubcommand::Resume => handle_resume().await,\n    49\t        RunSubcommand::Rollback { .. } => Err(AppError::NotYetImplemented {\n    50\t            command: \"run rollback\".to_owned(),\n    51\t        }),\n    52\t    }\n    53\t}\n    54\t\n    55\tpub fn build_agent_execution_service(\n    56\t) -> AgentExecutionService<StubBackendAdapter, FsRawOutputStore, FsSessionStore> {\n    57\t    let mut adapter = StubBackendAdapter::default();\n    58\t\n    59\t    // Test-only injection seam: environment variables configure the stub backend\n    60\t    // to simulate failure modes that aren't reachable through normal CLI usage.\n    61\t    if std::env::var(\"RALPH_BURNING_TEST_BACKEND_UNAVAILABLE\").is_ok() {\n    62\t        adapter = adapter.unavailable();\n    63\t    }\n    64\t    if let Ok(stage_str) = std::env::var(\"RALPH_BURNING_TEST_FAIL_INVOKE_STAGE\") {\n    65\t        if let Ok(stage_id) = stage_str.parse::<StageId>() {\n    66\t            adapter = adapter.with_invoke_failure(stage_id);\n    67\t        }\n    68\t    }\n    69\t\n    70\t    AgentExecutionService::new(adapter, FsRawOutputStore, FsSessionStore)\n    71\t}\n    72\t\n    73\tasync fn handle_start() -> AppResult<()> {\n    74\t    let current_dir = std::env::current_dir()?;\n    75\t\n    76\t    // Validate workspace version\n    77\t    let config = workspace_governance::load_workspace_config(&current_dir)?;\n    78\t    workspace_governance::ensure_supported_workspace_version(&config)?;\n    79\t\n    80\t    // Resolve active project\n    81\t    let project_id = workspace_governance::resolve_active_project(&current_dir)?;\n    82\t\n    83\t    // Validate canonical project record\n    84\t    let project_store = FsProjectStore;\n    85\t    let project_record = project_store.read_project_record(&current_dir, &project_id)?;\n    86\t\n    87\t    // Only standard flow is supported in this slice\n    88\t    if project_record.flow != FlowPreset::Standard {\n    89\t        return Err(AppError::UnsupportedFlow {\n    90\t            flow_id: project_record.flow.as_str().to_owned(),\n    91\t        });\n    92\t    }\n    93\t\n    94\t    // Validate run snapshot integrity\n    95\t    let run_snapshot_read = FsRunSnapshotStore;\n    96\t    let run_snapshot = run_snapshot_read.read_run_snapshot(&current_dir, &project_id)?;\n    97\t\n    98\t    // Check preconditions before engine call (fail fast with clear errors)\n    99\t    match run_snapshot.status {\n   100\t        RunStatus::NotStarted => {}\n   101\t        RunStatus::Failed | RunStatus::Paused => {\n   102\t            return Err(AppError::RunStartFailed {\n   103\t                reason: format!(\n   104\t                    \"project snapshot status is '{}'; use `ralph-burning run resume`\",\n   105\t                    run_snapshot.status\n   106\t                ),\n   107\t            });\n   108\t        }\n   109\t        status => {\n   110\t            return Err(AppError::RunStartFailed {\n   111\t                reason: format!(\n   112\t                    \"project snapshot status is '{}'; run start requires 'not_started'\",\n   113\t                    status\n   114\t                ),\n   115\t            });\n   116\t        }\n   117\t    }\n   118\t    if run_snapshot.has_active_run() {\n   119\t        return Err(AppError::RunStartFailed {\n   120\t            reason: \"project already has an active run\".to_owned(),\n   121\t        });\n   122\t    }\n   123\t\n   124\t    let effective_config = EffectiveConfig::load(&current_dir)?;\n   125\t\n   126\t    let agent_service = build_agent_execution_service();\n   127\t    let run_snapshot_write = FsRunSnapshotWriteStore;\n   128\t    let journal_store = FsJournalStore;\n   129\t    let artifact_write = FsPayloadArtifactWriteStore;\n   130\t    let log_write = FsRuntimeLogWriteStore;\n   131\t\n   132\t    println!(\"Starting run for project '{}'...\", project_id);\n   133\t\n   134\t    engine::execute_standard_run(\n   135\t        &agent_service,\n   136\t        &run_snapshot_read,\n   137\t        &run_snapshot_write,\n   138\t        &journal_store,\n   139\t        &artifact_write,\n   140\t        &log_write,\n   141\t        &current_dir,\n   142\t        &project_id,\n   143\t        &effective_config,\n   144\t    )\n   145\t    .await?;\n   146\t\n   147\t    let final_snapshot = run_snapshot_read.read_run_snapshot(&current_dir, &project_id)?;\n   148\t    match final_snapshot.status {\n   149\t        RunStatus::Completed => println!(\"Run completed successfully.\"),\n   150\t        RunStatus::Paused => println!(\"{}\", final_snapshot.status_summary),\n   151\t        status => println!(\"Run finished with status '{}'.\", status),\n   152\t    }\n   153\t    Ok(())\n   154\t}\n   155\t\n   156\tasync fn handle_resume() -> AppResult<()> {\n   157\t    let current_dir = std::env::current_dir()?;\n   158\t\n   159\t    let config = workspace_governance::load_workspace_config(&current_dir)?;\n   160\t    workspace_governance::ensure_supported_workspace_version(&config)?;\n   161\t\n   162\t    let project_id = workspace_governance::resolve_active_project(&current_dir)?;\n   163\t\n   164\t    let project_store = FsProjectStore;\n   165\t    let project_record = project_store.read_project_record(&current_dir, &project_id)?;\n   166\t    if project_record.flow != FlowPreset::Standard {\n   167\t        return Err(AppError::UnsupportedFlow {\n   168\t            flow_id: project_record.flow.as_str().to_owned(),\n   169\t        });\n   170\t    }\n   171\t\n   172\t    let run_snapshot_read = FsRunSnapshotStore;\n   173\t    let run_snapshot = run_snapshot_read.read_run_snapshot(&current_dir, &project_id)?;\n   174\t    match run_snapshot.status {\n   175\t        RunStatus::Failed | RunStatus::Paused => {}\n   176\t        RunStatus::NotStarted => {\n   177\t            return Err(AppError::ResumeFailed {\n   178\t                reason: \"project has not started a run yet; use `ralph-burning run start`\"\n   179\t                    .to_owned(),\n   180\t            });\n   181\t        }\n   182\t        RunStatus::Running => {\n   183\t            return Err(AppError::ResumeFailed {\n   184\t                reason: \"project already has a running run; `run resume` only works from failed or paused snapshots\".to_owned(),\n   185\t            });\n   186\t        }\n   187\t        RunStatus::Completed => {\n   188\t            return Err(AppError::ResumeFailed {\n   189\t                reason: \"project is already completed; there is nothing to resume\".to_owned(),\n   190\t            });\n   191\t        }\n   192\t    }\n   193\t    if run_snapshot.has_active_run() {\n   194\t        return Err(AppError::ResumeFailed {\n   195\t            reason: \"failed or paused snapshots must not retain an active run\".to_owned(),\n   196\t        });\n   197\t    }\n   198\t\n   199\t    let effective_config = EffectiveConfig::load(&current_dir)?;\n   200\t    let agent_service = build_agent_execution_service();\n   201\t    let run_snapshot_write = FsRunSnapshotWriteStore;\n   202\t    let journal_store = FsJournalStore;\n   203\t    let artifact_write = FsPayloadArtifactWriteStore;\n   204\t    let log_write = FsRuntimeLogWriteStore;\n   205\t\n   206\t    println!(\"Resuming run for project '{}'...\", project_id);\n   207\t\n   208\t    engine::resume_standard_run(\n   209\t        &agent_service,\n   210\t        &run_snapshot_read,\n   211\t        &run_snapshot_write,\n   212\t        &journal_store,\n   213\t        &artifact_write,\n   214\t        &log_write,\n   215\t        &current_dir,\n   216\t        &project_id,\n   217\t        &effective_config,\n   218\t    )\n   219\t    .await?;\n   220\t\n   221\t    let final_snapshot = run_snapshot_read.read_run_snapshot(&current_dir