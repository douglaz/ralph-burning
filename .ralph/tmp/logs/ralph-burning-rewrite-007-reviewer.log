{"type":"item.completed","item":{"id":"item_38","type":"command_execution","command":"/run/current-system/sw/bin/bash -lc \"nl -ba tests/unit/workflow_engine_test.rs | sed -n '404,520p'\"","aggregated_output":"   404\t// ── Failing-port tests: journal-append and snapshot-write errors ─────────\n   405\t\n   406\t/// A journal store that delegates to `FsJournalStore` but fails on the Nth\n   407\t/// append_event call (1-indexed). This lets us test failure at specific\n   408\t/// stage-commit boundaries.\n   409\tstruct FailingJournalStore {\n   410\t    call_count: AtomicU32,\n   411\t    fail_on_call: u32,\n   412\t}\n   413\t\n   414\timpl FailingJournalStore {\n   415\t    fn new(fail_on_call: u32) -> Self {\n   416\t        Self {\n   417\t            call_count: AtomicU32::new(0),\n   418\t            fail_on_call,\n   419\t        }\n   420\t    }\n   421\t}\n   422\t\n   423\timpl JournalStorePort for FailingJournalStore {\n   424\t    fn read_journal(\n   425\t        &self,\n   426\t        base_dir: &Path,\n   427\t        project_id: &ralph_burning::shared::domain::ProjectId,\n   428\t    ) -> AppResult<Vec<JournalEvent>> {\n   429\t        FsJournalStore.read_journal(base_dir, project_id)\n   430\t    }\n   431\t\n   432\t    fn append_event(\n   433\t        &self,\n   434\t        base_dir: &Path,\n   435\t        project_id: &ralph_burning::shared::domain::ProjectId,\n   436\t        line: &str,\n   437\t    ) -> AppResult<()> {\n   438\t        let n = self.call_count.fetch_add(1, Ordering::SeqCst) + 1;\n   439\t        if n == self.fail_on_call {\n   440\t            return Err(AppError::Io(std::io::Error::other(\n   441\t                \"simulated journal append failure\",\n   442\t            )));\n   443\t        }\n   444\t        FsJournalStore.append_event(base_dir, project_id, line)\n   445\t    }\n   446\t}\n   447\t\n   448\t/// A snapshot write store that delegates to `FsRunSnapshotWriteStore` but fails\n   449\t/// on the Nth write call (1-indexed).\n   450\tstruct FailingSnapshotWriteStore {\n   451\t    call_count: AtomicU32,\n   452\t    fail_on_call: u32,\n   453\t}\n   454\t\n   455\timpl FailingSnapshotWriteStore {\n   456\t    fn new(fail_on_call: u32) -> Self {\n   457\t        Self {\n   458\t            call_count: AtomicU32::new(0),\n   459\t            fail_on_call,\n   460\t        }\n   461\t    }\n   462\t}\n   463\t\n   464\timpl RunSnapshotWritePort for FailingSnapshotWriteStore {\n   465\t    fn write_run_snapshot(\n   466\t        &self,\n   467\t        base_dir: &Path,\n   468\t        project_id: &ralph_burning::shared::domain::ProjectId,\n   469\t        snapshot: &RunSnapshot,\n   470\t    ) -> AppResult<()> {\n   471\t        let n = self.call_count.fetch_add(1, Ordering::SeqCst) + 1;\n   472\t        if n == self.fail_on_call {\n   473\t            return Err(AppError::Io(std::io::Error::other(\n   474\t                \"simulated snapshot write failure\",\n   475\t            )));\n   476\t        }\n   477\t        FsRunSnapshotWriteStore.write_run_snapshot(base_dir, project_id, snapshot)\n   478\t    }\n   479\t}\n   480\t\n   481\t/// Stage-entered journal append failure must persist failed state.\n   482\t/// The run must never be left in an ambiguous running state when the\n   483\t/// stage_entered event cannot be persisted.\n   484\t#[tokio::test]\n   485\tasync fn stage_entered_journal_failure_persists_failed_state() {\n   486\t    let tmp = tempdir().unwrap();\n   487\t    let base_dir = tmp.path();\n   488\t\n   489\t    setup_workspace(base_dir);\n   490\t    let pid = create_standard_project(base_dir, \"stage-entry-fail\");\n   491\t\n   492\t    let agent_service = build_agent_service();\n   493\t    let config = EffectiveConfig::load(base_dir).unwrap();\n   494\t\n   495\t    // The engine calls append_event for:\n   496\t    //   1: run_started\n   497\t    //   2: stage_entered (stage 1) — fail here\n   498\t    let failing_journal = FailingJournalStore::new(2);\n   499\t\n   500\t    let result = engine::execute_standard_run(\n   501\t        &agent_service,\n   502\t        &FsRunSnapshotStore,\n   503\t        &FsRunSnapshotWriteStore,\n   504\t        &failing_journal,\n   505\t        &FsPayloadArtifactWriteStore,\n   506\t        &FsRuntimeLogWriteStore,\n   507\t        base_dir,\n   508\t        &pid,\n   509\t        &config,\n   510\t    )\n   511\t    .await;\n   512\t\n   513\t    assert!(result.is_err(), \"run should fail on stage_entered journal failure\");\n   514\t\n   515\t    // Run must be in failed state, not left in running\n   516\t    let snapshot = FsRunSnapshotStore.read_run_snapshot(base_dir, &pid).unwrap();\n   517\t    assert_eq!(snapshot.status, RunStatus::Failed);\n   518\t    assert!(snapshot.active_run.is_none());\n   519\t\n   520\t    // No stage_entered event should exist for the first stage since the append failed\n","exit_code":0,"status":"completed"}}
