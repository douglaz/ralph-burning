ntExecutionPort,\n   313\t    R: RawOutputPort,\n   314\t    S: SessionStorePort,\n   315\t{\n   316\t    resume_standard_run_with_retry(\n   317\t        agent_service,\n   318\t        run_snapshot_read,\n   319\t        run_snapshot_write,\n   320\t        journal_store,\n   321\t        artifact_write,\n   322\t        log_write,\n   323\t        base_dir,\n   324\t        project_id,\n   325\t        effective_config,\n   326\t        &RetryPolicy::default_policy(),\n   327\t        CancellationToken::new(),\n   328\t    )\n   329\t    .await\n   330\t}\n   331\t\n   332\t#[allow(clippy::too_many_arguments)]\n   333\tpub async fn resume_standard_run_with_retry<A, R, S>(\n   334\t    agent_service: &AgentExecutionService<A, R, S>,\n   335\t    run_snapshot_read: &dyn RunSnapshotPort,\n   336\t    run_snapshot_write: &dyn RunSnapshotWritePort,\n   337\t    journal_store: &dyn JournalStorePort,\n   338\t    artifact_write: &dyn PayloadArtifactWritePort,\n   339\t    log_write: &dyn RuntimeLogWritePort,\n   340\t    base_dir: &Path,\n   341\t    project_id: &ProjectId,\n   342\t    effective_config: &EffectiveConfig,\n   343\t    retry_policy: &RetryPolicy,\n   344\t    cancellation_token: CancellationToken,\n   345\t) -> AppResult<()>\n   346\twhere\n   347\t    A: AgentExecutionPort,\n   348\t    R: RawOutputPort,\n   349\t    S: SessionStorePort,\n   350\t{\n   351\t    let mut snapshot = run_snapshot_read.read_run_snapshot(base_dir, project_id)?;\n   352\t    match snapshot.status {\n   353\t        RunStatus::Failed | RunStatus::Paused => {}\n   354\t        RunStatus::NotStarted => {\n   355\t            return Err(AppError::ResumeFailed {\n   356\t                reason: \"project has not started a run yet; use `ralph-burning run start`\"\n   357\t                    .to_owned(),\n   358\t            });\n   359\t        }\n   360\t        RunStatus::Running => {\n   361\t            return Err(AppError::ResumeFailed {\n   362\t                reason: \"project already has a running run; `run resume` only works from failed or paused snapshots\".to_owned(),\n   363\t            });\n   364\t        }\n   365\t        RunStatus::Completed => {\n   366\t            return Err(AppError::ResumeFailed {\n   367\t                reason: \"project is already completed; there is nothing to resume\".to_owned(),\n   368\t            });\n   369\t        }\n   370\t    }\n   371\t    if snapshot.has_active_run() {\n   372\t        return Err(AppError::ResumeFailed {\n   373\t            reason: \"failed or paused snapshots must not retain an active run\".to_owned(),\n   374\t        });\n   375\t    }\n   376\t\n   377\t    let events = journal_store.read_journal(base_dir, project_id)?;\n   378\t    let stage_ids = standard_stage_plan_for_resume(&events, effective_config)?;\n   379\t    let workspace_defaults = BackendSelectionConfig::from_effective_config(effective_config)?;\n   380\t    let stage_plan = resolve_stage_plan(\n   381\t        stage_ids.as_slice(),\n   382\t        agent_service.resolver(),\n   383\t        Some(&workspace_defaults),\n   384\t    )?;\n   385\t    let resume_state = derive_resume_state(&events, &snapshot, &stage_plan)?;\n   386\t\n   387\t    preflight_check(agent_service.adapter(), &stage_plan[resume_state.stage_index..])\n   388\t        .await\n   389\t        .map_err(|error| AppError::ResumeFailed {\n   390\t            reason: error.to_string(),\n   391\t        })?;\n   392\t\n   393\t    let mut seq = journal::last_sequence(&events);\n   394\t    snapshot.status = RunStatus::Running;\n   395\t    snapshot.active_run = Some(ActiveRun {\n   396\t        run_id: resume_state.run_id.as_str().to_owned(),\n   397\t        stage_cursor: resume_state.cursor.clone(),\n   398\t        started_at: resume_state.started_at,\n   399\t    });\n   400\t    snapshot.completion_rounds = snapshot.completion_rounds.max(resume_state.cursor.completion_round);\n   401\t    snapshot.status_summary = format!(\"runnin