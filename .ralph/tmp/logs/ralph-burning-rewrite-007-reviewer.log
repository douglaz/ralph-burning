{"type":"item.completed","item":{"id":"item_29","type":"command_execution","command":"/run/current-system/sw/bin/bash -lc \"nl -ba ralph-burning-rewrite/tests/unit/adapter_contract_test.rs | sed -n '1,260p'\"","aggregated_output":"     1\t/// Adapter contract tests for filesystem-backed stores.\n     2\t/// Verifies round-trip persistence, corruption visibility, and edge cases\n     3\t/// for FsProjectStore, FsJournalStore, FsArtifactStore, FsRuntimeLogStore,\n     4\t/// FsRunSnapshotStore, and FsActiveProjectStore.\n     5\tuse std::fs;\n     6\t\n     7\tuse chrono::{TimeZone, Utc};\n     8\tuse tempfile::tempdir;\n     9\t\n    10\tuse ralph_burning::adapters::fs::{\n    11\t    FileSystem, FsActiveProjectStore, FsArtifactStore, FsJournalStore, FsProjectStore,\n    12\t    FsRunSnapshotStore, FsRuntimeLogStore,\n    13\t};\n    14\tuse ralph_burning::contexts::project_run_record::journal;\n    15\tuse ralph_burning::contexts::project_run_record::model::*;\n    16\tuse ralph_burning::contexts::project_run_record::service::{\n    17\t    ActiveProjectPort, ArtifactStorePort, JournalStorePort, ProjectStorePort, RunSnapshotPort,\n    18\t    RuntimeLogStorePort,\n    19\t};\n    20\tuse ralph_burning::shared::domain::{FlowPreset, ProjectId};\n    21\tuse ralph_burning::shared::error::AppError;\n    22\t\n    23\tfn test_timestamp() -> chrono::DateTime<Utc> {\n    24\t    Utc.with_ymd_and_hms(2026, 3, 11, 19, 0, 0)\n    25\t        .single()\n    26\t        .expect(\"valid timestamp\")\n    27\t}\n    28\t\n    29\tfn make_project_record(id: &str) -> ProjectRecord {\n    30\t    ProjectRecord {\n    31\t        id: ProjectId::new(id).unwrap(),\n    32\t        name: format!(\"Project {id}\"),\n    33\t        flow: FlowPreset::Standard,\n    34\t        prompt_reference: \"prompt.md\".to_owned(),\n    35\t        prompt_hash: \"abc123\".to_owned(),\n    36\t        created_at: test_timestamp(),\n    37\t        status_summary: ProjectStatusSummary::Created,\n    38\t    }\n    39\t}\n    40\t\n    41\tfn setup_workspace(base_dir: &std::path::Path) {\n    42\t    let ws = base_dir.join(\".ralph-burning\");\n    43\t    fs::create_dir_all(ws.join(\"projects\")).expect(\"create projects dir\");\n    44\t    let config = ralph_burning::shared::domain::WorkspaceConfig::new(test_timestamp());\n    45\t    let rendered = FileSystem::render_workspace_config(&config).expect(\"render config\");\n    46\t    FileSystem::write_atomic(&ws.join(\"workspace.toml\"), &rendered).expect(\"write config\");\n    47\t}\n    48\t\n    49\tfn create_project_on_disk(base_dir: &std::path::Path, id: &str) {\n    50\t    let store = FsProjectStore;\n    51\t    let record = make_project_record(id);\n    52\t    let snapshot = RunSnapshot::initial();\n    53\t    let sessions = SessionStore::empty();\n    54\t    let event = JournalEvent {\n    55\t        sequence: 1,\n    56\t        timestamp: test_timestamp(),\n    57\t        event_type: JournalEventType::ProjectCreated,\n    58\t        details: serde_json::json!({\"project_id\": id, \"flow\": \"standard\"}),\n    59\t    };\n    60\t    let journal_line = journal::serialize_event(&event).expect(\"serialize event\");\n    61\t    store\n    62\t        .create_project_atomic(\n    63\t            base_dir,\n    64\t            &record,\n    65\t            \"# Prompt\\n\",\n    66\t            &snapshot,\n    67\t            &journal_line,\n    68\t            &sessions,\n    69\t        )\n    70\t        .expect(\"create project\");\n    71\t}\n    72\t\n    73\t// ── FsProjectStore ──\n    74\t\n    75\t#[test]\n    76\tfn project_store_round_trip_create_and_read() {\n    77\t    let tmp = tempdir().unwrap();\n    78\t    setup_workspace(tmp.path());\n    79\t    create_project_on_disk(tmp.path(), \"alpha\");\n    80\t\n    81\t    let store = FsProjectStore;\n    82\t    let pid = ProjectId::new(\"alpha\").unwrap();\n    83\t    let record = store.read_project_record(tmp.path(), &pid).unwrap();\n    84\t\n    85\t    assert_eq!(record.id.as_str(), \"alpha\");\n    86\t    assert_eq!(record.flow, FlowPreset::Standard);\n    87\t    assert_eq!(record.prompt_reference, \"prompt.md\");\n    88\t    assert_eq!(record.prompt_hash, \"abc123\");\n    89\t    assert_eq!(record.status_summary, ProjectStatusSummary::Created);\n    90\t}\n    91\t\n    92\t#[test]\n    93\tfn project_store_exists_returns_true_for_created_project() {\n    94\t    let tmp = tempdir().unwrap();\n    95\t    setup_workspace(tmp.path());\n    96\t    create_project_on_disk(tmp.path(), \"alpha\");\n    97\t\n    98\t    let store = FsProjectStore;\n    99\t    let pid = ProjectId::new(\"alpha\").unwrap();\n   100\t    assert!(store.project_exists(tmp.path(), &pid).unwrap());\n   101\t}\n   102\t\n   103\t#[test]\n   104\tfn project_store_exists_returns_false_for_missing_project() {\n   105\t    let tmp = tempdir().unwrap();\n   106\t    setup_workspace(tmp.path());\n   107\t\n   108\t    let store = FsProjectStore;\n   109\t    let pid = ProjectId::new(\"nonexistent\").unwrap();\n   110\t    assert!(!store.project_exists(tmp.path(), &pid).unwrap());\n   111\t}\n   112\t\n   113\t#[test]\n   114\tfn project_store_list_returns_sorted_ids() {\n   115\t    let tmp = tempdir().unwrap();\n   116\t    setup_workspace(tmp.path());\n   117\t    create_project_on_disk(tmp.path(), \"beta\");\n   118\t    create_project_on_disk(tmp.path(), \"alpha\");\n   119\t\n   120\t    let store = FsProjectStore;\n   121\t    let ids = store.list_project_ids(tmp.path()).unwrap();\n   122\t    let id_strs: Vec<&str> = ids.iter().map(|p| p.as_str()).collect();\n   123\t    assert_eq!(id_strs, vec![\"alpha\", \"beta\"]);\n   124\t}\n   125\t\n   126\t#[test]\n   127\tfn project_store_stage_and_commit_delete_removes_project() {\n   128\t    let tmp = tempdir().unwrap();\n   129\t    setup_workspace(tmp.path());\n   130\t    create_project_on_disk(tmp.path(), \"alpha\");\n   131\t\n   132\t    let store = FsProjectStore;\n   133\t    let pid = ProjectId::new(\"alpha\").unwrap();\n   134\t\n   135\t    // Stage: project becomes invisible\n   136\t    store.stage_delete(tmp.path(), &pid).unwrap();\n   137\t    assert!(!store.project_exists(tmp.path(), &pid).unwrap());\n   138\t\n   139\t    // Commit: permanently remove\n   140\t    store.commit_delete(tmp.path(), &pid).unwrap();\n   141\t\n   142\t    // Verify pending-delete dir is also gone\n   143\t    let pending = tmp\n   144\t        .path()\n   145\t        .join(\".ralph-burning/projects/.alpha.pending-delete\");\n   146\t    assert!(!pending.exists());\n   147\t}\n   148\t\n   149\t#[test]\n   150\tfn project_store_stage_and_rollback_restores_project() {\n   151\t    let tmp = tempdir().unwrap();\n   152\t    setup_workspace(tmp.path());\n   153\t    create_project_on_disk(tmp.path(), \"alpha\");\n   154\t\n   155\t    let store = FsProjectStore;\n   156\t    let pid = ProjectId::new(\"alpha\").unwrap();\n   157\t\n   158\t    // Stage: project becomes invisible\n   159\t    store.stage_delete(tmp.path(), &pid).unwrap();\n   160\t    assert!(!store.project_exists(tmp.path(), &pid).unwrap());\n   161\t\n   162\t    // Rollback: project is restored\n   163\t    store.rollback_delete(tmp.path(), &pid).unwrap();\n   164\t    assert!(store.project_exists(tmp.path(), &pid).unwrap());\n   165\t\n   166\t    // Verify the record is intact\n   167\t    let record = store.read_project_record(tmp.path(), &pid).unwrap();\n   168\t    assert_eq!(record.id.as_str(), \"alpha\");\n   169\t}\n   170\t\n   171\t#[test]\n   172\tfn project_store_rollback_noop_when_no_pending_delete() {\n   173\t    let tmp = tempdir().unwrap();\n   174\t    setup_workspace(tmp.path());\n   175\t\n   176\t    let store = FsProjectStore;\n   177\t    let pid = ProjectId::new(\"alpha\").unwrap();\n   178\t\n   179\t    // Rollback with nothing pending should be a no-op\n   180\t    store.rollback_delete(tmp.path(), &pid).unwrap();\n   181\t}\n   182\t\n   183\t#[test]\n   184\tfn project_store_commit_noop_when_no_pending_delete() {\n   185\t    let tmp = tempdir().unwrap();\n   186\t    setup_workspace(tmp.path());\n   187\t\n   188\t    let store = FsProjectStore;\n   189\t    let pid = ProjectId::new(\"alpha\").unwrap();\n   190\t\n   191\t    // Commit with nothing pending should be a no-op\n   192\t    store.commit_delete(tmp.path(), &pid).unwrap();\n   193\t}\n   194\t\n   195\t#[test]\n   196\tfn project_store_read_missing_project_toml_returns_corrupt() {\n   197\t    let tmp = tempdir().unwrap();\n   198\t    setup_workspace(tmp.path());\n   199\t    create_project_on_disk(tmp.path(), \"alpha\");\n   200\t\n   201\t    // Remove project.toml but keep directory\n   202\t    let project_root = tmp.path().join(\".ralph-burning/projects/alpha\");\n   203\t    fs::remove_file(project_root.join(\"project.toml\")).unwrap();\n   204\t\n   205\t    let store = FsProjectStore;\n   206\t    let pid = ProjectId::new(\"alpha\").unwrap();\n   207\t    let err = store.read_project_record(tmp.path(), &pid).unwrap_err();\n   208\t    assert!(matches!(err, AppError::CorruptRecord { .. }));\n   209\t}\n   210\t\n   211\t#[test]\n   212\tfn project_store_exists_with_missing_project_toml_returns_corrupt() {\n   213\t    let tmp = tempdir().unwrap();\n   214\t    setup_workspace(tmp.path());\n   215\t    create_project_on_disk(tmp.path(), \"alpha\");\n   216\t\n   217\t    fs::remove_file(\n   218\t        tmp.path()\n   219\t            .join(\".ralph-burning/projects/alpha/project.toml\"),\n   220\t    )\n   221\t    .unwrap();\n   222\t\n   223\t    let store = FsProjectStore;\n   224\t    let pid = ProjectId::new(\"alpha\").unwrap();\n   225\t    let err = store.project_exists(tmp.path(), &pid).unwrap_err();\n   226\t    assert!(matches!(err, AppError::CorruptRecord { .. }));\n   227\t}\n   228\t\n   229\t#[test]\n   230\tfn project_store_list_with_corrupt_project_toml_returns_error() {\n   231\t    let tmp = tempdir().unwrap();\n   232\t    setup_workspace(tmp.path());\n   233\t    create_project_on_disk(tmp.path(), \"alpha\");\n   234\t\n   235\t    // Remove project.toml to simulate corruption\n   236\t    fs::remove_file(\n   237\t        tmp.path()\n   238\t            .join(\".ralph-burning/projects/alpha/project.toml\"),\n   239\t    )\n   240\t    .unwrap();\n   241\t\n   242\t    let store = FsProjectStore;\n   243\t    let err = store.list_project_ids(tmp.path()).unwrap_err();\n   244\t    assert!(matches!(err, AppError::CorruptRecord { .. }));\n   245\t}\n   246\t\n   247\t#[test]\n   248\tfn project_store_read_malformed_toml_returns_corrupt() {\n   249\t    let tmp = tempdir().unwrap();\n   250\t    setup_workspace(tmp.path());\n   251\t    create_project_on_disk(tmp.path(), \"alpha\");\n   252\t\n   253\t    // Write malformed TOML\n   254\t    fs::write(\n   255\t        tmp.path()\n   256\t            .join(\".ralph-burning/projects/alpha/project.toml\"),\n   257\t        \"this is not valid toml ][}{\",\n   258\t    )\n   259\t    .unwrap();\n   260\t\n","exit_code":0,"status":"completed"}}
