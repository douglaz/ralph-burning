 1299\t    match &bundle.payload {\n  1300\t        StagePayload::Validation(validation) => {\n  1301\t            remediation_context_from_validation(stage_id, next_cycle, validation)\n  1302\t        }\n  1303\t        _ => json!({}),\n  1304\t    }\n  1305\t}\n  1306\t\n  1307\tfn remediation_context_from_validation(\n  1308\t    stage_id: StageId,\n  1309\t    next_cycle: u32,\n  1310\t    validation: &ValidationPayload,\n  1311\t) -> Value {\n  1312\t    json!({\n  1313\t        \"source_stage\": stage_id.as_str(),\n  1314\t        \"cycle\": next_cycle,\n  1315\t        \"follow_up_or_amendments\": validation.follow_up_or_amendments,\n  1316\t        \"findings_or_gaps\": validation.findings_or_gaps,\n  1317\t    })\n  1318\t}\n  1319\t\n  1320\tfn invocation_context(cursor: &StageCursor, implementation_context: Option<&Value>) -> Value {\n  1321\t    let mut context = json!({\n  1322\t        \"cycle\": cursor.cycle,\n  1323\t        \"attempt\": cursor.attempt,\n  1324\t        \"completion_round\": cursor.completion_round,\n  1325\t    });\n  1326\t\n  1327\t    if let Some(implementation_context) = implementation_context {\n  1328\t        context[\"remediation\"] = implementation_context.clone();\n  1329\t    }\n  1330\t\n  1331\t    context\n  1332\t}\n  1333\t\n  1334\tfn stage_index_for(stage_plan: &[StagePlan], stage_id: StageId) -> AppResult<usize> {\n  1335\t    stage_plan\n  1336\t        .iter()\n  1337\t        .position(|entry| entry.stage_id == stage_id)\n  1338\t        .ok_or_else(|| AppError::CorruptRecord {\n  1339\t            file: \"journal.ndjson\".to_owned(),\n  1340\t            details: format!(\n  1341\t                \"stage '{}' is not part of the standard stage plan\",\n  1342\t                stage_id\n  1343\t            ),\n  1344\t        })\n  1345\t}\n  1346\t\n  1347\tfn record_cycle_advance(snapshot: &mut RunSnapshot, next_cycle: u32) {\n  1348\t    snapshot.cycle_history.push(CycleHistoryEntry {\n  1349\t        cycle: 