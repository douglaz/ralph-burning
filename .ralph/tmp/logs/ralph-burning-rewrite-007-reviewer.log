{"type":"item.completed","item":{"id":"item_31","type":"command_execution","command":"/run/current-system/sw/bin/bash -lc \"nl -ba tests/unit/retry_policy_test.rs | sed -n '1,220p'\"","aggregated_output":"     1\tuse ralph_burning::contexts::workflow_composition::retry_policy::{RetryPolicy, RetryRule};\n     2\tuse ralph_burning::shared::domain::FailureClass;\n     3\t\n     4\t#[test]\n     5\tfn default_retry_policy_matches_specified_attempt_limits() {\n     6\t    let policy = RetryPolicy::default_policy();\n     7\t\n     8\t    assert_eq!(policy.max_attempts(FailureClass::TransportFailure), 3);\n     9\t    assert_eq!(policy.max_attempts(FailureClass::SchemaValidationFailure), 2);\n    10\t    assert_eq!(policy.max_attempts(FailureClass::DomainValidationFailure), 2);\n    11\t    assert_eq!(policy.max_attempts(FailureClass::Timeout), 2);\n    12\t    assert_eq!(policy.max_attempts(FailureClass::Cancellation), 1);\n    13\t    assert_eq!(policy.max_attempts(FailureClass::QaReviewOutcomeFailure), 1);\n    14\t    assert_eq!(policy.max_remediation_cycles(), 3);\n    15\t}\n    16\t\n    17\t#[test]\n    18\tfn default_retry_policy_marks_retryable_and_terminal_classes() {\n    19\t    let policy = RetryPolicy::default_policy();\n    20\t\n    21\t    assert!(policy.is_retryable(FailureClass::TransportFailure));\n    22\t    assert!(policy.is_retryable(FailureClass::SchemaValidationFailure));\n    23\t    assert!(policy.is_retryable(FailureClass::DomainValidationFailure));\n    24\t    assert!(policy.is_retryable(FailureClass::Timeout));\n    25\t    assert!(!policy.is_retryable(FailureClass::Cancellation));\n    26\t    assert!(!policy.is_retryable(FailureClass::QaReviewOutcomeFailure));\n    27\t}\n    28\t\n    29\t#[test]\n    30\tfn retry_policy_can_be_customized() {\n    31\t    let policy = RetryPolicy::default_policy()\n    32\t        .with_rule(FailureClass::Timeout, RetryRule::retryable(4))\n    33\t        .with_max_remediation_cycles(5);\n    34\t\n    35\t    assert_eq!(policy.max_attempts(FailureClass::Timeout), 4);\n    36\t    assert!(policy.is_retryable(FailureClass::Timeout));\n    37\t    assert_eq!(policy.max_remediation_cycles(), 5);\n    38\t}\n","exit_code":0,"status":"completed"}}
