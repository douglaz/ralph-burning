         timeout: Duration::from_secs(300),\n  1241→            cancellation_token: cancellation_token.clone(),\n  1242→            session_policy: SessionPolicy::ReuseIfAllowed,\n  1243→            prior_session: None,\n  1244→            attempt_number: cursor.attempt,\n  1245→        };\n  1246→\n  1247→        let result = agent_service.invoke(request).await.and_then(|envelope| {\n  1248→            stage_entry\n  1249→                .contract\n  1250→                .evaluate_permissive(&envelope.parsed_payload)\n  1251→                .map_err(|contract_error| AppError::InvocationFailed {\n  1252→                    backend: stage_entry.target.backend.family.to_string(),\n  1253→                    stage_id,\n  1254→                    failure_class: contract_error.failure_class(),\n  1255→                    details: contract_error.to_string(),\n  1256→                })\n  1257→        });\n  1258→\n  1259→        match result {\n  1260→            Ok(bundle) => return Ok((cursor.clone(), bundle)),\n  1261→            Err(error) => {\n  1262→                let Some(failure_class) = error.failure_class() else {\n  1263→                    return fail_run_result(\n  1264→                        &error,\n  1265→                        stage_id,\n  1266→                        run_id,\n  1267→                        seq,\n  1268→                        snapshot,\n  1269→                        journal_store,\n  1270→                        run_snapshot_write,\n  1271→                        base_dir,\n  1272→                        project_id,\n  1273→                        origin,\n  1274→                    )\n  1275→                    .await;\n  1276→                };\n  1277→\n  1278→                let max_attempts = retry_policy.max_attempts(failure_class);\n  1279→                let will_retry = retry_policy.is_retryable(failure_class)\n  1280→                    && cursor.attempt < max_attempts\n  1281→                    && !matches!(failure_class, FailureClass::Cancellation)\n  1282→                    && !cancellation_token.is_cancelled();\n  1283→\n  1284→                *seq += 1;\n  1285→                let stage_failed = journal::stage_failed_event(\n  1286→                    *seq,\n  1287→                    Utc::now(),\n  1288→                    run_id,\n  1289→                    stage_id,\n  1290→                    cursor.cycle,\n  1291→                    cursor.attempt,\n  1292→                    failure_class,\n  1293→                    &error.to_string(),\n  1294→                    will_retry,\n  1295→                );\n  1296→                let stage_failed_line = journal::serialize_event(&stage_failed)?;\n  1297→                if let Err(append_error) =\n  1298→                    journal_store.append_event(base_dir, project_id, &stage_failed_line)\n  1299→                {\n  1300→                    *seq -= 1;\n  1301→                    return fail_run_result(\n  1302→                        &AppError::StageCommitFailed {\n  1303→                            stage_id,\n  1304→                            details: format!(\n  1305→                                \"failed to persist stage_failed event for {}: {}\",\n  1306→                                stage_id.as_str(),\n  1307→                                append_error\n  1308→                            ),\n  1309→                        },\n  1310→                        stage_id,\n  1311→                        run_id,\n  1312→                        seq,\n  1313→                        snapshot,\n  1314→                        journal_store,\n  1315→                        run_snapshot_write,\n  1316→                        base_dir,\n  1317→                        project_id,\n  1318→                        origin,\n  1319→                    )\n  1320→                    .await;\n  1321→                }\n  1322→\n  1323→                let _ = log_write.append_runtime_log(\n  1324→                    base_dir,\n  1325→                    project_id,\n  1326→                    &RuntimeLogEntry {\n  1327→                        timestamp: Utc::now(),\n  1328→                        level: LogLevel::Warn,\n  1329→                        source: \"engine\".to_owned(),\n  1330→                        message: format!(\n  1331→                            \"stage_failed: {} cycle={} attempt={} retry={}\",\n  1332→                            stage_id.as_str(),\n  1333→                            cursor.cycle,\n  1334→                            cursor.attempt,\n  1335→                            will_retry\n  1336→                        ),\n  1337→                    },\n  1338→                );\n  1339→\n  1340→                if will_retry {\n  1341→                    cursor = cursor.retry();\n  1342→                    continue;\n  1343→                }\n  1344→\n  1345→                return fail_run_result(\n  1346→                    &error,\n  1347→                    stage_id,\n  1348→                    run_id,\n  1349→                    seq,\n  1350→                    snapshot,\n  1351→                    journal_store,\n  1352→                    run_snapshot_write,\n  1353→                    base_dir,\n  1354→                    project_id,\n  1355→                    origin,\n  1356→                )\n  1357→                .await;\n  1358→            }\n  1359→        }\n  1360→    }\n  1361→}\n  1362→\n  1363→#[allow(clippy::too_many_arguments)]\n  1364→async fn persist_stage_success(\n  1365→    artifact_write: &dyn PayloadArtifactWritePort,\n  1366→    journal_store: &dyn JournalStorePort,\n  1367→    run_snapshot_write: &dyn RunSnapshotWritePort,\n  1368→    log_write: &dyn RuntimeLogWritePort,\n  1369→    base_dir: &Path,\n  1370→    project_id: &ProjectId,\n  1371→    run_id: &RunId,\n  1372→    seq: &mut u64,\n  1373→    snapshot: &mut RunSnapshot,\n  1374→    stage_id: StageId,\n  1375→    cursor: &StageCursor,\n  1376→    bundle: &ValidatedBundle,\n  1377→    origin: ExecutionOrigin,\n  1378→) -> AppResult<()> {\n  1379→    let stage_now = Utc::now();\n  1380→    let payload_id = format!(\n  1381→        \"{}-{}-c{}-a{}\",\n  1382→        run_id.as_str(),\n  1383→        stage_id.as_str(),\n  1384→        cursor.cycle,\n  1385→        cursor.attempt\n  1386→    );\n  1387→    let artifact_id = format!(\"{}-artifact\", payload_id);\n  1388→\n  1389→    let payload_record = PayloadRecord {\n  1390→        payload_id: payload_id.clone(),\n  1391→        stage_id,\n  1392→        cycle: cursor.cycle,\n  1393→        attempt: cursor.attempt,\n  1394→        created_at: stage_now,\n  1395→        payload: serde_json::to_value(&bundle.payload)?,\n  1396→    };\n  1397→    let artifact_record = ArtifactRecord {\n  1398→        artifact_id: artifact_id.clone(),\n  1399→        payload_id: payload_id.clone(),\n  1400→        stage_id,\n  1401→        created_at: stage_now,\n  1402→        content: bundle.artifact.clone(),\n  1403→    };\n  1404→\n  1405→    if let Err(error) = artifact_write.write_payload_artifact_pair(\n  1406→        base_dir,\n  1407→        project_id,\n  1408→        &payload_record,\n  1409→        &artifact_record,\n  1410→    ) {\n  1411→        let _ = artifact_write.remove_payload_artifact_pair(\n  1412→            base_dir,\n  1413→            project_id,\n  1414→            &payload_id,\n  1415→            &artifact_id,\n  1416→        );\n  1417→        return fail_run(\n  1418→            &AppError::StageCommitFailed {\n  1419→                stage_id,\n  1420→                details: format!(\"payload/artifact persistence failed: {}\", error),\n  1421→            },\n  1422→            stage_id,\n  1423→            run_id,\n  1424→            seq,\n  1425→            snapshot,\n  1426→            journal_store,\n  1427→            run_snapshot_write,\n  1428→            base_dir,\n  1429→            project_id,\n  1430→            origin,\n  1431→        )\n  1432→        .await;\n  1433→    }\n  1434→\n  1435→    *seq += 1;\n  1436→    let stage_completed = journal::stage_completed_event(\n  1437→        *seq,\n  1438→        Utc::now(),\n  1439→        run_id,\n  1440→        stage_id,\n  1441→        cursor.cycle,\n  1442→        cursor.attempt,\n  1443→        &payload_id,\n  1444→        &artifact_id,\n  1445→    );\n  1446→    let stage_completed_line = journal::serialize_event(&stage_completed)?;\n  1447→    if let Err(error) = journal_store.append_event(base_dir, project_id, &stage_completed_line) {\n  1448→        let _ = artifact_write.remove_payload_artifact_pair(\n  1449→            base_dir,\n  1450→            project_id,\n  1451→            &payload_id,\n  1452→            &artifact_id,\n  1453→        );\n  1454→        *seq -= 1;\n  1455→        return fail_run(\n  1456→            &AppError::StageCommitFailed {\n  1457→                stage_id,\n  1458→                details: format!(\"journal append failed during stage commit: {}\", error),\n  1459→            },\n  1460→            stage_id,\n  1461→            run_id,\n  1462→            seq,\n  1463→            snapshot,\n  1464→            journal_store,\n  1465→            run_snapshot_write,\n  1466→            base_dir,\n  1467→            project_id,\n  1468→            origin,\n  1469→        )\n  1470→        .await;\n  1471→    }\n  1472→\n  1473→    let _ = log_write.append_runtime_log(\n  1474→        base_dir,\n  1475→        project_id,\n  1476→        &RuntimeLogEntry {\n  1477→            timestamp: Utc::now(),\n  1478→            level: LogLevel::Info,\n  1479→            source: \"engine\".to_owned(),\n  1480→            message: format!(\"stage_completed: {}\", stage_id.as_str()),\n  1481→        },\n  1482→    );\n  1483→\n  1484→    Ok(())\n  1485→}\n  1486→\n  1487→fn complete_run(\n  1488→    snapshot: &mut RunSnapshot,\n  1489→    run_snapshot_write: &dyn RunSnapshotWritePort,\n  1490→    journal_store: &dyn JournalStorePort,\n  1491→    amendment_queue_port: &dyn AmendmentQueuePort,\n  1492→    base_dir: &Path,\n  1493→    project_id: &ProjectId,\n  1494→    run_id: &RunId,\n  1495→    seq: &mut u64,\n  1496→) -> AppResult<()> {\n  1497→    // Completion guard: block completion if pending amendments remain.\n  1498→    // On CompletionBlocked, persist a resumable (Failed, active_run=None) snapshot\n  1499→    // so that `run resume` can pick the run back up.\n  1500→    if let Err(e) = completion_guard(snapshot, amendment_queue_port, base_dir, project_id) {\n  1501→        if matches!(&e, AppError::CompletionBlocked { .. }) {\n  1502→            snapshot.status = RunStatus::Failed;\n  1503→            snapshot.active_run = None;\n  1504→            snapshot.status_summary = format!(\"blocked: {}\", e);\n  1505→            run_snapshot_write\n  1506→                .write_run_snapshot(base_dir, project_id, snapshot)\n  1507→                .map_err(|write_err| AppError::CompletionGuardSnapshotFailed {\n  1508→                    details: format!(\n  1509→                        \"completion guard fired ({}) but resumable snapshot could not be persisted: {}\",\n  1510→                        e, write_err\n  1511→                    ),\n  1512→                })?;\n  1513→        }\n  1514→        return Err(e);\n  1515→    }\n  1516→\n  1517→    snapshot.status = RunStatus::Completed;\n  1518→    snapshot.active_run = None;\n  1519→    snapshot.completion_rounds = snapshot.completion_rounds.max(1);\n  1520→    snapshot.status_summary = \"completed\".to_owned();\n  1521→    run_snapshot_write.write_run_snapshot(base_dir, project_id, snapshot)?;\n  1522→\n  1523→    *seq += 1;\n  1524→    let run_completed =\n  1525→        journal::run_completed_event(*seq, Utc::now(), run_id, snapshot.completion_rounds);\n  1526→    let run_completed_line = journal::serialize_event(&run_completed)?;\n  1527→    journal_store.append_event(base_dir, project_id, &run_completed_line)?;\n  1528→    Ok(())\n  1529→}\n  1530→\n  1531→fn pause_run(\n  1532→    snapshot: &mut RunSnapshot,\n  1533→    run_snapshot_write: &dyn RunSnapshotWritePort,\n  1534→    base_dir: &Path,\n  1535→    project_id: &ProjectId,\n  1536→    summary: String,\n  1537→) -> AppResult<()> {\n  1538→    snapshot.status = RunStatus::Paused;\n  1539→    snapshot.active_run = None;\n  1540→    snapshot.status_summary = summary;\n  1541→    run_snapshot_write.write_run_snapshot(base_dir, project_id, snapshot)\n  1542→}\n  1543→\n  1544→/// Record a run failure: persist failed snapshot, then journal event, return error.\n  1545→#[allow(clippy::too_many_arguments)]\n  1546→async fn fail_run(\n  1547→    err: &AppError,\n  1548→    stage_id: StageId,\n  1549→    run_id: &RunId,\n  1550→    seq: &mut u64,\n  1551→    snapshot: &mut RunSnapshot,\n  1552→    journal_store: &dyn JournalStorePort,\n  1553→    run_snapshot_write: &dyn RunSnapshotWritePort,\n  1554→    base_dir: &Path,\n  1555→    project_id: &ProjectId,\n  1556→    origin: ExecutionOrigin,\n  1557→) -> AppResult<()> {\n  1558→    let failure_class = failure_label(err);\n  1559→    let message = err.to_string();\n  1560→\n  1561→    snapshot.status = RunStatus::Failed;\n  1562→    snapshot.active_run = None;\n  1563→    snapshot.status_summary = format!(\"failed at {}: {}\", stage_id.display_name(), message);\n  1564→    run_snapshot_write.write_run_snapshot(base_dir, project_id, snapshot)?;\n  1565→\n  1566→    *seq += 1;\n  1567→    let run_failed =\n  1568→        journal::run_failed_event(*seq, Utc::now(), run_id, stage_id, &failure_class, &message);\n  1569→    if let Ok(run_failed_line) = journal::serialize_event(&run_failed) {\n  1570→        let _ = journal_store.append_event(base_dir, project_id, &run_failed_line);\n  1571→    }\n  1572→\n  1573→    Err(origin.error(format!(\"stage {} failed: {}\", stage_id.as_str(), message)))\n  1574→}\n  1575→\n  1576→#[allow(clippy::too_many_arguments)]\n  1577→async fn fail_run_result<T>(\n  1578→    err: &AppError,\n  1579→    stage_id: StageId,\n  1580→    run_id: &RunId,\n  1581→    seq: &mut u64,\n  1582→    snapshot: &mut RunSnapshot,\n  1583→    journal_store: &dyn JournalStorePort,\n  1584→    run_snapshot_write: &dyn RunSnapshotWritePort,\n  1585→    base_dir: &Path,\n  1586→    project_id: &ProjectId,\n  1587→    origin: ExecutionOrigin,\n  1588→) -> AppResult<T> {\n  1589→    fail_run(\n  1590→        err,\n  1591→        stage_id,\n  1592→        run_id,\n  1593→        seq,\n  1594→        snapshot,\n  1595→        journal_store,\n  1596→        run_snapshot_write,\n  1597→        base_dir,\n  1598→        project_id,\n  1599→        origin,","numLines":500,"startLine":1100,"totalLines":2074}}}
