e disk amendments into snapshot, avoiding duplicates by ID.\n  1720→    let existing_ids: std::collections::HashSet<String> = snapshot\n  1721→        .amendment_queue\n  1722→        .pending\n  1723→        .iter()\n  1724→        .map(|a| a.amendment_id.clone())\n  1725→        .collect();\n  1726→\n  1727→    for amendment in disk_amendments {\n  1728→        if !existing_ids.contains(&amendment.amendment_id) {\n  1729→            snapshot.amendment_queue.pending.push(amendment);\n  1730→        }\n  1731→    }\n  1732→\n  1733→    // Sort by (created_at, batch_sequence) for deterministic ordering.\n  1734→    snapshot.amendment_queue.pending.sort_by(|a, b| {\n  1735→        a.created_at\n  1736→            .cmp(&b.created_at)\n  1737→            .then_with(|| a.batch_sequence.cmp(&b.batch_sequence))\n  1738→    });\n  1739→\n  1740→    Ok(())\n  1741→}\n  1742→\n  1743→fn remediation_context(stage_id: StageId, next_cycle: u32, bundle: &ValidatedBundle) -> Value {\n  1744→    match &bundle.payload {\n  1745→        StagePayload::Validation(validation) => {\n  1746→            remediation_context_from_validation(stage_id, next_cycle, validation)\n  1747→        }\n  1748→        _ => json!({}),\n  1749→    }\n  1750→}\n  1751→\n  1752→fn remediation_context_from_validation(\n  1753→    stage_id: StageId,\n  1754→    next_cycle: u32,\n  1755→    validation: &ValidationPayload,\n  1756→) -> Value {\n  1757→    json!({\n  1758→        \"source_stage\": stage_id.as_str(),\n  1759→        \"cycle\": next_cycle,\n  1760→        \"follow_up_or_amendments\": validation.follow_up_or_amendments,\n  1761→        \"findings_or_gaps\": validation.findings_or_gaps,\n  1762→    })\n  1763→}\n  1764→\n  1765→fn invocation_context(\n  1766→    cursor: &StageCursor,\n  1767→    implementation_context: Option<&Value>,\n  1768→    pending_amendments: Option<&[QueuedAmendment]>,\n  1769→) -> Value {\n  1770→    let mut context = json!({\n  1771→        \"cycle\": cursor.cycle,\n  1772→        \"attempt\": cursor.attempt,\n  1773→        \"completion_round\": cursor.completion_round,\n  1774→    });\n  1775→\n  1776→    if let Some(implementation_context) = implementation_context {\n  1777→        context[\"remediation\"] = implementation_context.clone();\n  1778→    }\n  1779→\n  1780→    if let Some(amendments) = pending_amendments {\n  1781→        if !amendments.is_empty() {\n  1782→            let amendment_bodies: Vec<&str> = amendments.iter().map(|a| a.body.as_str()).collect();\n  1783→            context[\"pending_amendments\"] = json!(amendment_bodies);\n  1784→        }\n  1785→    }\n  1786→\n  1787→    context\n  1788→}\n  1789→\n  1790→fn stage_index_for(stage_plan: &[StagePlan], stage_id: StageId) -> AppResult<usize> {\n  1791→    stage_plan\n  1792→        .iter()\n  1793→        .position(|entry| entry.stage_id == stage_id)\n  1794→        .ok_or_else(|| AppError::CorruptRecord {\n  1795→            file: \"journal.ndjson\".to_owned(),\n  1796→            details: format!(\n  1797→                \"stage '{}' is not part of the standard stage plan\",\n  1798→                stage_id\n  1799→            ),\n  1800→        })\n  1801→}\n  1802→\n  1803→fn record_cycle_advance(snapshot: &mut RunSnapshot, next_cycle: u32) {\n  1804→    snapshot.cycle_history.push(CycleHistoryEntry {\n  1805→        cycle: next_cycle,\n  1806→        stage_id: StageId::Implementation,\n  1807→        started_at: Utc::now(),\n  1808→        completed_at: None,\n  1809→    });\n  1810→}\n  1811→\n  1812→fn pending_remediation_cycle(\n  1813→    snapshot: &RunSnapshot,\n  1814→    current_cycle: u32,\n  1815→    last_completed_stage: Option<StageId>,\n  1816→) -> Option<u32> {"}]},"parent_tool_use_id":null,"session_id":"22e84bba-de3d-49c0-8e45-9206d1dfe4ad","uuid":"86b3955d-8dd0-4db0-8695-7e854f6c5bec","tool_use_result":{"type":"text","file":{"filePath":"/root/new-ralph-burning/ralph-burning-rewrite/src/contexts/workflow_composition/engine.rs","content":"fn prompt_review_requires_pause(payload: &StagePayload) -> bool {\n    matches!(\n        payload,\n        StagePayload::Planning(planning) if !planning.readiness.ready\n    )\n}\n\nfn validation_outcome(payload: &StagePayload) -> Option<ReviewOutcome> {\n    match payload {\n        StagePayload::Validation(validation) => Some(validation.outcome),\n        _ => None,\n    }\n}\n\nfn validation_follow_ups(payload: &StagePayload) -> &[String] {\n    match payload {\n        StagePayload::Validation(validation) => &validation.follow_up_or_amendments,\n        _ => &[],\n    }\n}\n\nfn is_remediation_stage(stage_id: StageId) -> bool {\n    matches!(stage_id, StageId::Qa | StageId::Review)\n}\n\n/// Returns true if this is a late stage (completion_panel, acceptance_qa, final_review).\nfn is_late_stage(stage_id: StageId) -> bool {\n    matches!(\n        stage_id,\n        StageId::CompletionPanel | StageId::AcceptanceQa | StageId::FinalReview\n    )\n}\n\n/// Build typed QueuedAmendment records from follow-up strings.\nfn build_queued_amendments(\n    follow_ups: &[String],\n    source_stage: StageId,\n    source_cycle: u32,\n    source_completion_round: u32,\n    run_id: &RunId,\n) -> Vec<QueuedAmendment> {\n    let now = Utc::now();\n    follow_ups\n        .iter()\n        .enumerate()\n        .map(|(idx, body)| QueuedAmendment {\n            amendment_id: format!(\n                \"{}-{}-cr{}-amd{}\",\n                run_id.as_str(),\n                source_stage.as_str(),\n                source_completion_round,\n                idx + 1\n            ),\n            source_stage,\n            source_cycle,\n            source_completion_round,\n            body: body.clone(),\n            created_at: now,\n            batch_sequence: (idx + 1) as u32,\n        })\n        .collect()\n}\n\n/// Completion guard: blocks run_completed when pending amendments remain.\nfn completion_guard(\n    snapshot: &RunSnapshot,\n    amendment_queue_port: &dyn AmendmentQueuePort,\n    base_dir: &Path,\n    project_id: &ProjectId,\n) -> AppResult<()> {\n    // Check snapshot queue.\n    if !snapshot.amendment_queue.pending.is_empty() {\n        return Err(AppError::CompletionBlocked {\n            details: format!(\n                \"completion blocked: {} pending amendments remain in snapshot queue\",\n                snapshot.amendment_queue.pending.len()\n            ),\n        });\n    }\n\n    // Check disk.\n    if amendment_queue_port.has_pending_amendments(base_dir, project_id)? {\n        return Err(AppError::CompletionBlocked {\n            details: \"completion blocked: pending amendment files exist on disk\".to_owned(),\n        });\n    }\n\n    Ok(())\n}\n\n/// Reconcile amendments from disk into the snapshot during resume.\nfn reconcile_amendments_from_disk(\n    snapshot: &mut RunSnapshot,\n    amendment_queue_port: &dyn AmendmentQueuePort,\n    base_dir: &Path,\n    project_id: &ProjectId,\n) -> AppResult<()> {\n    let disk_amendments = amendment_queue_port.list_pending_amendments(base_dir, project_id)?;\n    if disk_amendments.is_empty() {\n        return Ok(());\n    }\n\n    // Merge disk amendments into snapshot, avoiding duplicates by ID.\n    let existing_ids: std::collections::HashSet<String> = snapshot\n        .amendment_queue\n        .pending\n        .iter()\n        .map(|a| a.amendment_id.clone())\n        .collect();\n\n    for amendment in disk_amendments {\n        if !existing_ids.contains(&amendment.amendment_id) {\n            snapshot.amendment_queue.pending.push(amendment);\n        }\n    }\n\n    // Sort by (created_at, batch_sequence) for deterministic ordering.\n    snapshot.amendment_queue.pending.sort_by(|a, b| {\n        a.created_at\n            .cmp(&b.created_at)\n            .then_with(|| a.batch_sequence.cmp(&b.batch_sequence))\n    });\n\n    Ok(())\n}\n\nfn remediation_context(stage_id: StageId, next_cycle: u32, bundle: &ValidatedBundle) -> Value {\n    match &bundle.payload {\n        StagePayload::Validation(validation) => {\n            remediation_context_from_validation(stage_id, next_cycle, validation)\n        }\n        _ => json!({}),\n    }\n}\n\nfn remediation_context_from_validation(\n    stage_id: StageId,\n    next_cycle: u32,\n    validation: &ValidationPayload,\n) -> Value {\n    json!({\n        \"source_stage\": stage_id.as_str(),\n        \"cycle\": next_cycle,\n        \"follow_up_or_amendments\": validation.follow_up_or_amendments,\n        \"findings_or_gaps\": validation.findings_or_gaps,\n    })\n}\n\nfn invocation_context(\n    cursor: &StageCursor,\n    implementation_context: Option<&Value>,\n    pending_amendments: Option<&[QueuedAmendment]>,\n) -> Value {\n    let mut context = json!({\n        \"cycle\": cursor.cycle,\n        \"attempt\": cursor.attempt,\n        \"completion_round\": cursor.completion_round,\n    });\n\n    if let Some(implementation_context) = implementation_context {\n        context[\"remediation\"] = implementation_context.clone();\n    }\n\n    if let Some(amendments) = pending_amendments {\n        if !amendments.is_empty() {\n            let amendment_bodies: Vec<&str> = amendments.iter().map(|a| a.body.as_str()).collect();\n            context[\"pending_amendments\"] = json!(amendment_bodies);\n        }\n    }\n\n    context\n}\n\nfn stage_index_for(stage_plan: &[StagePlan], stage_id: StageId) -> AppResult<usize> {\n    stage_plan\n        .iter()\n        .position(|entry| entry.stage_id == stage_id)\n        .ok_or_else(|| AppError::CorruptRecord {\n            file: \"journal.ndjson\".to_owned(),\n            details: format!(\n                \"stage '{}' is not part of the standard stage plan\",\n                stage_id\n            ),\n        })\n}\n\nfn record_cycle_advance(snapshot: &mut RunSnapshot, next_cycle: u32) {\n    snapshot.cycle_history.push(CycleHistoryEntry {\n        cycle: next_cycle,\n        stage_id: StageId::Implementation,\n        started_at: Utc::now(),\n        completed_at: None,\n    });\n}\n\nfn pending_remediation_cycle(\n    snapshot: &RunSnapshot,\n    current_cycle: u32,\n    last_completed_stage: Option<StageId>,\n) -> Option<u32> {","numLines":200,"startLine":1617,"totalLines":2074}}}
{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01X1sAsCT917Rs8SJpPP2pVr","type":"message","role":"assistant","content":[{"type":"thinking","thinking":"Now I have a thorough understanding of the codebase. Let me analyze:\n\n**Delivery Roadmap Progress:**\n1. ✅ Charter + v1 domain model + scenario IDs + workspace init + flow discovery (Loop 1)\n2. ✅ Flow preset definitions + stage contracts + renderer contracts (Loop 2)\n3. ✅ Workspace governance effective config + active project resolution (Loop 3)\n4. ✅ Project/run canonical store + journal + query commands (Loop 4)\n5. ✅ Agent execution facade with structured-output guarantee (Loop 5)\n6. ✅ Standard preset vertical path (`run start`) end-to-end (Loop 6)\n\n\n7. ✅ Retry/remediation, prompt review, resume, and failure class semantics (Loop 7)\n8. ✅ Completion/acceptance/final-review behavior + amendment queue (Loop 8)\n9. **NEXT**: docs and CI preset integration on same engine\n\nFor Loop 9, I need to decouple the engine from the standard flow. The execution and planning functions are currently hardcoded for the standard preset, and stage IDs are referenced directly throughout. I'll need to abstract these into preset-agnostic interfaces so other presets can plug in their own execution logic and stage definitions.\n\nThe docs flow skips final review and completion panels entirely, going straight from validation to review, while CI improvements follow a different progression altogether. I need to make the remediation, late-stage, and amendment logic work across these different stage sequences instead of assuming the standard flow's structure. Now I need to build out the implementation: introduce a `FlowSemantics` abstraction that captures flow-specific configuration like which stages handle planning, execution, and remediation, then generalize the core execution engine to work with any flow definition rather than being hardcoded for the standard flow, update the CLI to support the new flow types, and add test scenarios to validate both approaches work correctly.","signature":""}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":2751,"cache_read_input_tokens":67709,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":2751},"output_tokens":10,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"22e84bba-de3d-49c0-8e45-9206d1dfe4ad","uuid":"1393caef-9ee4-491c-9cb7-b6da2b0b2ea9"}
{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01X1sAsCT917Rs8SJpPP2pVr","type":"message","role":"assistant","content":[{"type":"text","text":"Now I have a complete picture of the codebase. The delivery roadmap clearly indicates Loop 9 should be **roadmap item 9: \"docs and CI preset integration on same engine\"**. The engine is currently hardcoded for the standard flow with explicit references to `StageId::Planning`, `StageId::Implementation`, etc. I need to plan the generalization.\n\n# Feature: Docs Change and CI Improvement Flow Execution\n\n## Description\nGeneralize the workflow engine to execute `docs_change` and `ci_improvement` flow presets on the same orchestration core that currently drives the `standard` flow. Today, `execute_standard_run` and `resume_standard_run` contain hardcoded references to standard-flow stage identifiers (`Planning`, `Implementation`, `PromptReview`, `CompletionPanel`, `AcceptanceQa`, `FinalReview`). This feature introduces a `FlowSemantics` descriptor that maps each flow preset's structural roles (planning stage, execution stage, remediation target, late stages, amendment injection point) so the engine can orchestrate any built-in flow without per-flow branching. The CLI `run start` and `run resume` commands are updated to accept `docs_change` and `ci_improvement` projects, and new conformance scenarios verify end-to-end behavior for both presets.\n\n## Acceptance Criteria\n- [ ] A `FlowSemantics` struct is introduced that captures per-flow structural roles: `planning_stage` (the stage that receives amendment injection and drains amendments after commit), `execution_stage` (the stage that remediation cycles restart from), `remediation_trigger_stages` (stages whose `RequestChanges` outcome triggers a remediation cycle, analogous to today's `is_remediation_stage`), `late_stages` (stages whose `RequestChanges`/`ConditionallyApproved` outcomes trigger completion-round advancement), and `prompt_review_stage` (optional, for flows that include prompt review).\n- [ ] `FlowSemantics` is derivable from a `FlowPreset` via a `flow_semantics(preset: FlowPreset) -> FlowSemantics` function. For `docs_change`: planning=`DocsPlan`, execution=`DocsUpdate`, remediation_triggers=[`DocsValidation`, `Review`], late_stages=[], prompt_review=None. For `ci_improvement`: planning=`CiPlan`, execution=`CiUpdate`, remediation_triggers=[`CiValidation`, `Review`], late_stages=[], prompt_review=None. For `standard`: planning=`Planning`, execution=`Implementation`, remediation_triggers=[`Qa`, `Review`], late_stages=[`CompletionPanel`, `AcceptanceQa`, `FinalReview`], prompt_review=Some(`PromptReview`).\n- [ ] The engine functions `execute_standard_run`, `execute_standard_run_with_retry`, `execute_standard_run_internal`, `resume_standard_run`, and `resume_standard_run_with_retry` are generalized to accept a `FlowPreset` parameter (or derive `FlowSemantics` internally) instead of hardcoding standard-flow stage IDs. All existing hardcoded references to `StageId::Planning`, `StageId::Implementation`, `StageId::PromptReview` in the orchestration loop are replaced with lookups against `FlowSemantics`.\n- [ ] The public engine API is renamed from `execute_standard_run` → `execute_run` and `resume_standard_run` → `resume_run` (keeping the old names as thin wrappers or removing them). The `_with_retry` variants follow the same rename.\n- [ ] `standard_stage_plan()` is generalized to `stage_plan_for_flow(preset: FlowPreset, prompt_review_enabled: bool) -> Vec<StageId>` that derives the executable stage sequence for any preset. For `docs_change` and `ci_improvement`, `prompt_review_enabled` has no effect (no prompt review stage exists). For `standard`, behavior is unchanged.\n- [ ] `standard_stage_plan_for_resume()` is generalized to `stage_plan_for_resume(preset: FlowPreset, events: &[JournalEvent], config: &EffectiveConfig)` with the same journal-reconstruction logic but using flow-specific stage definitions.\n- [ ] `is_remediation_stage()` and `is_late_stage()` are replaced by lookups against `FlowSemantics::remediation_trigger_stages` and `FlowSemantics::late_stages` respectively.\n- [ ] `record_cycle_advance()` uses `FlowSemantics::execution_stage` instead of hardcoded `StageId::Implementation`.\n- [ ] Amendment drain logic (currently keyed to `stage_id == StageId::Planning`) uses `FlowSemantics::planning_stage`.\n- [ ] Completion-round restart (currently targets `StageId::Planning`) uses `FlowSemantics::planning_stage`.\n- [ ] Remediation-cycle restart (currently targets `StageId::Implementation`) uses `FlowSemantics::execution_stage`.\n- [ ] Prompt-review pause check uses `FlowSemantics::prompt_review_stage` (skipped for flows without prompt review).\n- [ ] `docs_change` happy path: `run start` on a docs_change project executes `docs_plan → docs_update → docs_validation → review` in sequence, persisting payload + artifact + journal events at each stage boundary, completing with `RunStatus::Completed`.\n- [ ] `ci_improvement` happy path: `run start` on a ci_improvement project executes `ci_plan → ci_update → ci_validation → review` in sequence with the same persistence guarantees.\n- [ ] `docs_change` remediation: when `docs_validation` or `review` returns `RequestChanges`, the engine triggers a remediation cycle restarting from `docs_update` (not `implementation`), with `CycleAdvanced` journal event emitted.\n- [ ] `ci_improvement` remediation: when `ci_validation` or `review` returns `RequestChanges`, the engine triggers a remediation cycle restarting from `ci_update`.\n- [ ] `docs_change` and `ci_improvement` have no late stages: `ConditionallyApproved` from `docs_validation`, `ci_validation`, or `review` does not trigger completion-round advancement; it is treated as non-late-stage conditional approval (amendments accumulated in snapshot but no completion-round loop).\n- [ ] `Rejected` from any validation stage in docs_change/ci_improvement terminates the run with `QaReviewOutcomeFailure`, same as standard flow.\n- [ ] `run resume` works for `docs_change` and `ci_improvement` projects that are in `Failed` or `Paused` status, reconstructing resume state from journal using flow-specific stage definitions.\n- [ ] Retry semantics (transport failure, schema validation, timeout, cancellation) apply identically to docs_change/ci_improvement stages as they do to standard stages — no flow-specific retry policy changes.\n- [ ] The CLI `run start` and `run resume` handlers in `src/cli/run.rs` remove the `UnsupportedFlow` guard for `DocsChange` and `CiImprovement` (but keep it for `QuickDev` which is deferred to a later loop). They pass the project's `FlowPreset` to the generalized engine.\n- [ ] Completion guard still runs for docs_change/ci_improvement (it's a no-op since these flows have no late stages and thus never queue durable amendments, but the guard must not crash or produce false positives).\n- [ ] All existing standard-flow tests continue to pass without modification (behavioral regression gate).\n- [ ] New conformance Gherkin scenarios are added under `tests/conformance/features/`:\n  - `run_start_docs_change.feature` — happy path, remediation cycle, rejection, retry on failure\n  - `run_start_ci_improvement.feature` — happy path, remediation cycle, rejection, retry on failure\n  - `run_resume_non_standard.feature` — resume from failed/paused for docs_change and ci_improvement\n- [ ] New unit tests cover `FlowSemantics` derivation for all four presets, verifying each structural role field.\n- [ ] New engine-level tests verify that `execute_run` with `DocsChange` and `CiImprovement` presets produce correct journal event sequences and final snapshot states.\n\n## Files to Modify/Create\n- `src/contexts/workflow_composition/mod.rs` — Add `FlowSemantics` struct and `flow_semantics()` function; generalize `standard_stage_plan()` to `stage_plan_for_flow()`\n- `src/contexts/workflow_composition/engine.rs` — Generalize `execute_stand