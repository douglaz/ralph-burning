   39→    let flow_def = super::flow_definition(FlowPreset::Standard);\n    40→    if prompt_review_enabled {\n    41→        flow_def.stages.to_vec()\n    42→    } else {\n    43→        flow_def\n    44→            .stages\n    45→            .iter()\n    46→            .copied()\n    47→            .filter(|s| *s != StageId::PromptReview)\n    48→            .collect()\n    49→    }\n    50→}\n    51→\n    52→/// Deterministic stage-to-role mapping per spec.\n    53→pub fn role_for_stage(stage_id: StageId) -> BackendRole {\n    54→    BackendRole::for_stage(stage_id)\n    55→}\n    56→\n    57→/// Resolved target per stage for preflight.\n    58→pub struct StagePlan {\n    59→    pub stage_id: StageId,\n    60→    pub role: BackendRole,\n    61→    pub contract: contracts::StageContract,\n    62→    pub target: ResolvedBackendTarget,\n    63→}\n    64→\n    65→/// Resolve all stage targets ahead of execution for preflight validation.\n    66→pub fn resolve_stage_plan(\n    67→    stages: &[StageId],\n    68→    resolver: &crate::contexts::agent_execution::service::BackendResolver,\n    69→    workspace_defaults: Option<&BackendSelectionConfig>,\n    70→) -> AppResult<Vec<StagePlan>> {\n    71→    let mut plan = Vec::with_capacity(stages.len());\n    72→    for &stage_id in stages {\n    73→        let role = role_for_stage(stage_id);\n    74→        let contract = contracts::contract_for_stage(stage_id);\n    75→        let target = resolver.resolve(role, None, None, workspace_defaults)?;\n    76→        plan.push(StagePlan {\n    77→            stage_id,\n    78→            role,\n    79→            contract,\n    80→            target,\n    81→        });\n    82→    }\n    83→    Ok(plan)\n    84→}\n    85→\n    86→/// Preflight: check capability and availability for every stage target.\n    87→pub async fn preflight_check<A: AgentExecutionPort>(\n    88→    adapter: &A,\n    89→    plan: &[StagePlan],\n    90→) -> AppResult<()> {\n    91→    for entry in plan {\n    92→        adapter\n    93→            .check_capability(&entry.target, &entry.contract)\n    94→            .await\n    95→            .map_err(|e| AppError::PreflightFailed {\n    96→                stage_id: entry.stage_id,\n    97→                details: e.to_string(),\n    98→            })?;\n    99→        adapter\n   100→            .check_availability(&entry.target)"}]},"parent_tool_use_id":"toolu_01SkHWtcfo821tZDM1uBq1La","session_id":"22e84bba-de3d-49c0-8e45-9206d1dfe4ad","uuid":"ef333751-50ea-4587-8560-87d53edbc5d3"}
