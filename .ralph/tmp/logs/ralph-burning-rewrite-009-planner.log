{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Ho2RuZ1WSDgNT8UmeK25Gp","type":"tool_result","content":"     1→#![forbid(unsafe_code)]\n     2→\n     3→//! Stage contract registry and deterministic evaluation pipeline.\n     4→//!\n     5→//! Every stage in every built-in flow preset resolves to exactly one\n     6→//! [`StageContract`]. Contract evaluation enforces a fixed order:\n     7→//!\n     8→//! 1. **Schema validation** — deserialize raw JSON into the typed payload.\n     9→//! 2. **Semantic validation** — apply domain rules to the typed payload.\n    10→//! 3. **Rendering** — produce a deterministic Markdown artifact.\n    11→//!\n    12→//! On schema failure, semantic validation and rendering do not run.\n    13→//! On domain failure, rendering does not run.\n    14→//! On any failure, no success bundle is returned.\n    15→\n    16→use schemars::schema::RootSchema;\n    17→\n    18→use crate::shared::domain::StageId;\n    19→use crate::shared::error::ContractError;\n    20→\n    21→use super::payloads::{ExecutionPayload, PlanningPayload, StagePayload, ValidationPayload};\n    22→use super::renderers;\n    23→\n    24→// ── Contract family ─────────────────────────────────────────────────────────\n    25→\n    26→/// Classifies a stage into one of three payload families.\n    27→#[derive(Debug, Clone, Copy, PartialEq, Eq, Hash)]\n    28→pub enum ContractFamily {\n    29→    /// prompt_review, planning, docs_plan, ci_plan\n    30→    Planning,\n    31→    /// implementation, plan_and_implement, apply_fixes, docs_update, ci_update\n    32→    Execution,\n    33→    /// qa, docs_validation, ci_validation, acceptance_qa, review, final_review,\n    34→    /// completion_panel\n    35→    Validation,\n    36→}\n    37→\n    38→// ── Stage contract ──────────────────────────────────────────────────────────\n    39→\n    40→/// A stage contract binds a [`StageId`] to its payload family, schema,\n    41→/// semantic validation rules, and renderer.\n    42→#[derive(Debug, Clone, Copy, PartialEq, Eq)]\n    43→pub struct StageContract {\n    44→    pub stage_id: StageId,\n    45→    pub family: ContractFamily,\n    46→}\n    47→\n    48→/// Bundle of a validated payload and its rendered Markdown artifact.\n    49→///\n    50→/// Callers receive either a `ValidatedBundle` or an error — never one without\n    51→/// the other. Schema and domain failures still prevent bundle creation. Review\n    52→/// outcomes are enforced separately by [`StageContract::evaluate`], while\n    53→/// [`StageContract::evaluate_permissive`] may return a bundle for non-passing\n    54→/// validation payloads so the engine can persist them before remediation.\n    55→#[derive(Debug, Clone, PartialEq, Eq)]\n    56→pub struct ValidatedBundle {\n    57→    pub payload: StagePayload,\n    58→    pub artifact: String,\n    59→}\n    60→\n    61→// ── Registry ────────────────────────────────────────────────────────────────\n    62→\n    63→/// Look up the contract for a given stage. Every [`StageId`] variant resolves\n    64→/// to exactly one contract.\n    65→pub fn contract_for_stage(stage_id: StageId) -> StageContract {\n    66→    let family = match stage_id {\n    67→        StageId::PromptReview | StageId::Planning | StageId::DocsPlan | StageId::CiPlan => {\n    68→            ContractFamily::Planning\n    69→        }\n    70→\n    71→        StageId::Implementation\n    72→        | StageId::PlanAndImplement\n    73→        | StageId::ApplyFixes\n    74→        | StageId::DocsUpdate\n    75→        | StageId::CiUpdate => ContractFamily::Execution,\n    76→\n    77→        StageId::Qa\n    78→        | StageId::DocsValidation\n    79→        | StageId::CiValidation\n    80→        | StageId::AcceptanceQa\n    81→        | StageId::Review\n    82→        | StageId::FinalReview\n    83→        | StageId::CompletionPanel => ContractFamily::Validation,\n    84→    };\n    85→\n    86→    StageContract { stage_id, family }\n    87→}\n    88→\n    89→/// Return contracts for all stages, in [`StageId::ALL`] order.\n    90→pub fn all_contracts() -> Vec<StageContract> {\n    91→    StageId::ALL\n    92→        .iter()\n    93→        .map(|&id| contract_for_stage(id))\n    94→        .collect()\n    95→}\n    96→\n    97→// ── Contract implementation ─────────────────────────────────────────────────\n    98→\n    99→impl StageContract {\n   100→    /// Generate the JSON Schema for this contract's payload family.\n   101→    pub fn json_schema(&self) -> RootSchema {\n   102→        match self.family {\n   103→            ContractFamily::Planning => schemars::schema_for!(PlanningPayload),\n   104→            ContractFamily::Execution => schemars::schema_for!(ExecutionPayload),\n   105→            ContractFamily::Validation => schemars::schema_for!(ValidationPayload),\n   106→        }\n   107→    }\n   108→\n   109→    /// Evaluate a raw JSON value through the full contract pipeline.\n   110→    ///\n   111→    /// Schema validation → semantic validation → outcome check → rendering.\n   112→    ///\n   113→    /// Returns [`ValidatedBundle`] on success or a [`ContractError`] on any\n   114→    /// failure. Non-passing QA/review outcomes are still errors here and are\n   115→    /// classified as [`FailureClass::QaReviewOutcomeFailure`].\n   116→    pub fn evaluate(&self, raw_json: &serde_json::Value) -> Result<ValidatedBundle, ContractError> {\n   117→        let bundle = self.evaluate_permissive(raw_json)?;\n   118→\n   119→        self.check_outcome(&bundle.payload)?;\n   120→\n   121→        Ok(bundle)\n   122→    }\n   123→\n   124→    /// Evaluate a raw JSON value without enforcing passing review outcomes.\n   125→    ///\n   126→    /// Schema validation → semantic validation → rendering.\n   127→    ///\n   128→    /// This is used by the engine so it can durably persist non-passing\n   129→    /// validation payloads before applying remediation or terminal semantics.\n   130→    pub fn evaluate_permissive(\n   131→        &self,\n   132→        raw_json: &serde_json::Value,\n   133→    ) -> Result<ValidatedBundle, ContractError> {\n   134→        // Step 1: Schema validation (deserialization into typed payload).\n   135→        let payload = self.validate_schema(raw_json)?;\n   136→\n   137→        // Step 2: Semantic / domain validation.\n   138→        self.validate_semantics(&payload)?;\n   139→\n   140→        // Step 3: Deterministic Markdown rendering (without outcome enforcement).\n   141→        let artifact = self.render(&payload);\n   142→\n   143→        Ok(ValidatedBundle { payload, artifact })\n   144→    }\n   145→\n   146→    // ── Private helpers ─────────────────────────────────────────────────\n   147→\n   148→    fn validate_schema(&self, raw: &serde_json::Value) -> Result<StagePayload, ContractError> {\n   149→        match self.family {\n   150→            ContractFamily::Planning => {"}]},"parent_tool_use_id":"toolu_01SkHWtcfo821tZDM1uBq1La","session_id":"22e84bba-de3d-49c0-8e45-9206d1dfe4ad","uuid":"81dc6b95-f34b-410c-b203-a1b26d4988fb"}
