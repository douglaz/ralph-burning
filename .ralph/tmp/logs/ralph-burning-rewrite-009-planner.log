{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_019p8jkjscYZrjXUmDGWpthn","type":"tool_result","content":"     1→use clap::{Args, Subcommand};\n     2→\n     3→use crate::adapters::fs::{\n     4→    FsAmendmentQueueStore, FsArtifactStore, FsJournalStore, FsPayloadArtifactWriteStore,\n     5→    FsProjectStore, FsRawOutputStore, FsRunSnapshotStore, FsRunSnapshotWriteStore,\n     6→    FsRuntimeLogStore, FsRuntimeLogWriteStore, FsSessionStore,\n     7→};\n     8→use crate::adapters::stub_backend::StubBackendAdapter;\n     9→use crate::contexts::agent_execution::service::AgentExecutionService;\n    10→use crate::contexts::project_run_record::model::RunStatus;\n    11→use crate::contexts::project_run_record::service::{self, ProjectStorePort, RunSnapshotPort};\n    12→use crate::contexts::workflow_composition::engine;\n    13→use crate::contexts::workspace_governance;\n    14→use crate::contexts::workspace_governance::config::EffectiveConfig;\n    15→use crate::shared::domain::{FlowPreset, StageId};\n    16→use crate::shared::error::{AppError, AppResult};\n    17→\n    18→#[derive(Debug, Args)]\n    19→pub struct RunCommand {\n    20→    #[command(subcommand)]\n    21→    pub command: RunSubcommand,\n    22→}\n    23→\n    24→#[derive(Debug, Subcommand)]\n    25→pub enum RunSubcommand {\n    26→    Start,\n    27→    Resume,\n    28→    Status,\n    29→    History,\n    30→    Tail {\n    31→        #[arg(long)]\n    32→        logs: bool,\n    33→    },\n    34→    Rollback {\n    35→        #[arg(long)]\n    36→        to: String,\n    37→        #[arg(long)]\n    38→        hard: bool,\n    39→    },\n    40→}\n    41→\n    42→pub async fn handle(command: RunCommand) -> AppResult<()> {\n    43→    match command.command {\n    44→        RunSubcommand::Status => handle_status().await,\n    45→        RunSubcommand::History => handle_history().await,\n    46→        RunSubcommand::Tail { logs } => handle_tail(logs).await,\n    47→        RunSubcommand::Start => handle_start().await,\n    48→        RunSubcommand::Resume => handle_resume().await,\n    49→        RunSubcommand::Rollback { .. } => Err(AppError::NotYetImplemented {\n    50→            command: \"run rollback\".to_owned(),\n    51→        }),\n    52→    }\n    53→}\n    54→\n    55→pub fn build_agent_execution_service(\n    56→) -> AgentExecutionService<StubBackendAdapter, FsRawOutputStore, FsSessionStore> {\n    57→    let mut adapter = StubBackendAdapter::default();\n    58→\n    59→    // Test-only injection seam: environment variables configure the stub backend\n    60→    // to simulate failure modes that aren't reachable through normal CLI usage.\n    61→    if std::env::var(\"RALPH_BURNING_TEST_BACKEND_UNAVAILABLE\").is_ok() {\n    62→        adapter = adapter.unavailable();\n    63→    }\n    64→    if let Ok(stage_str) = std::env::var(\"RALPH_BURNING_TEST_FAIL_INVOKE_STAGE\") {\n    65→        if let Ok(stage_id) = stage_str.parse::<StageId>() {\n    66→            adapter = adapter.with_invoke_failure(stage_id);\n    67→        }\n    68→    }\n    69→\n    70→    AgentExecutionService::new(adapter, FsRawOutputStore, FsSessionStore)\n    71→}\n    72→\n    73→async fn handle_start() -> AppResult<()> {\n    74→    let current_dir = std::env::current_dir()?;\n    75→\n    76→    // Validate workspace version\n    77→    let config = workspace_governance::load_workspace_config(&current_dir)?;\n    78→    workspace_governance::ensure_supported_workspace_version(&config)?;\n    79→\n    80→    // Resolve active project\n    81→    let project_id = workspace_governance::resolve_active_project(&current_dir)?;\n    82→\n    83→    // Validate canonical project record\n    84→    let project_store = FsProjectStore;\n    85→    let project_record = project_store.read_project_record(&current_dir, &project_id)?;\n    86→\n    87→    // Only standard flow is supported in this slice\n    88→    if project_record.flow != FlowPreset::Standard {\n    89→        return Err(AppError::UnsupportedFlow {\n    90→            flow_id: project_record.flow.as_str().to_owned(),\n    91→        });\n    92→    }\n    93→\n    94→    // Validate run snapshot integrity\n    95→    let run_snapshot_read = FsRunSnapshotStore;\n    96→    let run_snapshot = run_snapshot_read.read_run_snapshot(&current_dir, &project_id)?;\n    97→\n    98→    // Check preconditions before engine call (fail fast with clear errors)\n    99→    match run_snapshot.status {\n   100→        RunStatus::NotStarted => {}\n   101→        RunStatus::Failed | RunStatus::Paused => {\n   102→            return Err(AppError::RunStartFailed {\n   103→                reason: format!(\n   104→                    \"project snapshot status is '{}'; use `ralph-burning run resume`\",\n   105→                    run_snapshot.status\n   106→                ),\n   107→            });\n   108→        }\n   109→        status => {\n   110→            return Err(AppError::RunStartFailed {\n   111→                reason: format!(\n   112→                    \"project snapshot status is '{}'; run start requires 'not_started'\",\n   113→                    status\n   114→                ),\n   115→            });\n   116→        }\n   117→    }\n   118→    if run_snapshot.has_active_run() {\n   119→        return Err(AppError::RunStartFailed {\n   120→            reason: \"project already has an active run\".to_owned(),\n   121→        });\n   122→    }\n   123→\n   124→    let effective_config = EffectiveConfig::load(&current_dir)?;\n   125→\n   126→    let agent_service = build_agent_execution_service();\n   127→    let run_snapshot_write = FsRunSnapshotWriteStore;\n   128→    let journal_store = FsJournalStore;\n   129→    let artifact_write = FsPayloadArtifactWriteStore;\n   130→    let log_write = FsRuntimeLogWriteStore;\n   131→\n   132→    println!(\"Starting run for project '{}'...\", project_id);\n   133→\n   134→    let amendment_queue = FsAmendmentQueueStore;\n   