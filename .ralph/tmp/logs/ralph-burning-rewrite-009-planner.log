// A durable history artifact record stored in `history/artifacts/`.\n   202→#[derive(Debug, Clone, PartialEq, Serialize, Deserialize)]\n   203→pub struct ArtifactRecord {\n   204→    pub artifact_id: String,\n   205→    pub payload_id: String,\n   206→    pub stage_id: StageId,\n   207→    pub created_at: DateTime<Utc>,\n   208→    pub content: String,\n   209→}\n   210→\n   211→/// A runtime log entry stored in `runtime/logs/`.\n   212→#[derive(Debug, Clone, PartialEq, Serialize, Deserialize)]\n   213→pub struct RuntimeLogEntry {\n   214→    pub timestamp: DateTime<Utc>,\n   215→    pub level: LogLevel,\n   216→    pub source: String,\n   217→    pub message: String,\n   218→}\n   219→\n   220→#[derive(Debug, Clone, Copy, PartialEq, Eq, Serialize, Deserialize)]\n   221→#[serde(rename_all = \"snake_case\")]\n   222→pub enum LogLevel {\n   223→    Debug,\n   224→    Info,\n   225→    Warn,\n   226→    Error,\n   227→}\n   228→\n   229→/// Rollback metadata stored in `rollback/`.\n   230→#[derive(Debug, Clone, PartialEq, Serialize, Deserialize)]\n   231→pub struct RollbackPoint {\n   232→    pub rollback_id: String,\n   233→    pub created_at: DateTime<Utc>,\n   234→    pub stage_id: StageId,\n   235→    pub cycle: u32,\n   236→    pub run_snapshot: RunSnapshot,\n   237→}\n   238→\n   239→/// Empty session store for `sessions.json`.\n   240→#[derive(Debug, Clone, PartialEq, Serialize, Deserialize)]\n   241→pub struct SessionStore {\n   242→    pub sessions: Vec<serde_json::Value>,\n   243→}\n   244→\n   245→impl SessionStore {\n   246→    pub fn empty() -> Self {\n   247→        Self {\n   248→            sessions: Vec::new(),\n   249→        }\n   250→    }\n   251→}\n   252→\n   253→/// Summary of a failed stage for run snapshot persistence.\n   254→#[derive(Debug, Clone, PartialEq, Serialize, Deserialize)]\n   255→pub struct FailedStageSummary {\n   256→    pub stage_id: StageId,\n   257→    pub cycle: u32,\n   258→    pub attempt: u32,\n   259→    pub failure_class: String,\n   260→    pub message: String,\n   261→    pub failed_at: DateTime<Utc>,\n   262→}\n   263→\n   264→/// Summary used in `project list` output.\n   265→#[derive(Debug, Clone)]\n   266→pub struct ProjectListEntry {\n   267→    pub id: ProjectId,\n   268→    pub name: String,\n   269→    pub flow: FlowPreset,\n   270→    pub status_summary: ProjectStatusSummary,\n   271→    pub created_at: DateTime<Utc>,\n   272→    pub is_active: bool,\n   273→}\n   274→\n   275→/// Detailed project view used in `project show` output.\n   276→#[derive(Debug, Clone)]\n   277→pub struct ProjectDetail {\n   278→    pub record: ProjectRecord,\n   279→    pub run_snapshot: RunSnapshot,\n   280→    pub journal_event_count: u64,\n   281→    pub rollback_count: usize,\n   282→    pub is_active: bool,\n   283→}\n   284→"}]},"parent_tool_use_id":"toolu_01SkHWtcfo821tZDM1uBq1La","session_id":"22e84bba-de3d-49c0-8e45-9206d1dfe4ad","uuid":"57860007-23f5-40be-b41d-b12bdf0ea3d4"}
