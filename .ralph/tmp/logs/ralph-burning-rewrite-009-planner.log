{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01QGWCchqMJqt5GK5PDz9VmF","type":"tool_result","content":"     1→     1→use std::path::{Path, PathBuf};\n     2→     2→use std::time::Duration;\n     3→     3→\n     4→     4→use chrono::{DateTime, Utc};\n     5→     5→use serde_json::{json, Value};\n     6→     6→\n     7→     7→use crate::contexts::agent_execution::model::{\n     8→     8→    CancellationToken, InvocationPayload, InvocationRequest,\n     9→     9→};\n    10→    10→use crate::contexts::agent_execution::service::{\n    11→    11→    AgentExecutionPort, BackendSelectionConfig, RawOutputPort,\n    12→    12→};\n    13→    13→use crate::contexts::agent_execution::session::SessionStorePort;\n    14→    14→use crate::contexts::agent_execution::AgentExecutionService;\n    15→    15→use crate::contexts::project_run_record::journal;\n    16→    16→use crate::contexts::project_run_record::model::{\n    17→    17→    ActiveRun, ArtifactRecord, CycleHistoryEntry, JournalEvent, LogLevel, PayloadRecord,\n    18→    18→    QueuedAmendment, RunSnapshot, RunStatus, RuntimeLogEntry,\n    19→    19→};\n    20→    20→use crate::contexts::project_run_record::service::{\n    21→    21→    AmendmentQueuePort, ArtifactStorePort, JournalStorePort, PayloadArtifactWritePort,\n    22→    22→    RunSnapshotPort, RunSnapshotWritePort, RuntimeLogWritePort,\n    23→    23→};\n    24→    24→use crate::contexts::workflow_composition::payloads::{\n    25→    25→    ReviewOutcome, StagePayload, ValidationPayload,\n    26→    26→};\n    27→    27→use crate::contexts::workspace_governance::config::EffectiveConfig;\n    28→    28→use crate::shared::domain::{\n    29→    29→    BackendRole, FailureClass, FlowPreset, ProjectId, ResolvedBackendTarget, RunId, SessionPolicy,\n    30→    30→    StageCursor, StageId,\n    31→    31→};\n    32→    32→use crate::shared::error::{AppError, AppResult};\n    33→    33→\n    34→    34→use super::contracts::{self, ValidatedBundle};\n    35→    35→use super::retry_policy::RetryPolicy;\n    36→    36→\n    37→    37→/// Derives the executable stage plan for the standard flow given prompt_review config.\n    38→    38→pub fn standard_stage_plan(prompt_review_enabled: bool) -> Vec<StageId> {\n    39→    39→    let flow_def = super::flow_definition(FlowPreset::Standard);\n    40→    40→    if prompt_review_enabled {\n    41→    41→        flow_def.stages.to_vec()\n    42→    42→    } else {\n    43→    43→        flow_def\n    44→    44→            .stages\n    45→    45→            .iter()\n    46→    46→            .copied()\n    47→    47→            .filter(|s| *s != StageId::PromptReview)\n    48→    48→            .collect()\n    49→    49→    }\n    50→    50→}\n    51→    51→\n    52→    52→/// Deterministic stage-to-role mapping per spec.\n    53→    53→pub fn role_for_stage(stage_id: StageId) -> BackendRole {\n    54→    54→    BackendRole::for_stage(stage_id)\n    55→    55→}\n    56→    56→\n    57→    57→/// Resolved target per stage for preflight.\n    58→    58→pub struct StagePlan {\n    59→    59→    pub stage_id: StageId,\n    60→    60→    pub role: BackendRole,\n    61→    61→    pub contract: contracts::StageContract,\n    62→    62→    pub target: ResolvedBackendTarget,\n    63→    63→}\n    64→    64→\n    65→    65→/// Resolve all stage targets ahead of execution for preflight validation.\n    66→    66→pub fn resolve_stage_plan(\n    67→    67→    stages: &[StageId],\n    68→    68→    resolver: &crate::contexts::agent_execution::service::BackendResolver,\n    69→    69→    workspace_defaults: Option<&BackendSelectionConfig>,\n    70→    70→) -> AppResult<Vec<StagePlan>> {\n    71→    71→    let mut plan = Vec::with_capacity(stages.len());\n    72→    72→    for &stage_id in stages {\n    73→    73→        let role = role_for_stage(stage_id);\n    74→    74→        let contract = contracts::contract_for_stage(stage_id);\n    75→    75→        let target = resolver.resolv