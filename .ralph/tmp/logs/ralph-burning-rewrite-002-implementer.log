{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01BAHcbVuUVVmHQ9jy8yvEK5","type":"tool_result","content":"     1→use std::process::Command;\n     2→\n     3→use tempfile::tempdir;\n     4→\n     5→fn binary() -> &'static str {\n     6→    env!(\"CARGO_BIN_EXE_ralph-burning\")\n     7→}\n     8→\n     9→#[test]\n    10→fn flow_list_prints_all_presets() {\n    11→    let output = Command::new(binary())\n    12→        .args([\"flow\", \"list\"])\n    13→        .output()\n    14→        .expect(\"run flow list\");\n    15→\n    16→    assert!(output.status.success());\n    17→\n    18→    let stdout = String::from_utf8_lossy(&output.stdout);\n    19→    assert!(stdout.contains(\"standard\"));\n    20→    assert!(stdout.contains(\"quick_dev\"));\n    21→    assert!(stdout.contains(\"docs_change\"));\n    22→    assert!(stdout.contains(\"ci_improvement\"));\n    23→}\n    24→\n    25→#[test]\n    26→fn flow_show_standard_prints_stage_sequence() {\n    27→    let output = Command::new(binary())\n    28→        .args([\"flow\", \"show\", \"standard\"])\n    29→        .output()\n    30→        .expect(\"run flow show\");\n    31→\n    32→    assert!(output.status.success());\n    33→\n    34→    let stdout = String::from_utf8_lossy(&output.stdout);\n    35→    assert!(stdout.contains(\"Stage count: 8\"));\n    36→    assert!(stdout.contains(\"1. prompt_review\"));\n    37→    assert!(stdout.contains(\"8. final_review\"));\n    38→    assert!(stdout.contains(\"Final review enabled: yes\"));\n    39→}\n    40→\n    41→#[test]\n    42→fn flow_show_invalid_preset_exits_non_zero_with_clear_error() {\n    43→    let output = Command::new(binary())\n    44→        .args([\"flow\", \"show\", \"unknown_flow\"])\n    45→        .output()\n    46→        .expect(\"run flow show invalid\");\n    47→\n    48→    assert!(!output.status.success());\n    49→\n    50→    let stderr = String::from_utf8_lossy(&output.stderr);\n    51→    assert!(stderr.contains(\"unknown flow preset 'unknown_flow'\"));\n    52→}\n    53→\n    54→#[test]\n    55→fn init_creates_workspace_layout() {\n    56→    let temp_dir = tempdir().expect(\"create temp dir\");\n    57→    let output = Command::new(binary())\n    58→        .arg(\"init\")\n    59→        .current_dir(temp_dir.path())\n    60→        .output()\n    61→        .expect(\"run init\");\n    62→\n    63→    assert!(output.status.success());\n    64→    assert!(temp_dir\n    65→        .path()\n    66→        .join(\".ralph-burning/workspace.toml\")\n    67→        .is_file());\n    68→    assert!(temp_dir.path().join(\".ralph-burning/projects\").is_dir());\n    69→    assert!(temp_dir.path().join(\".ralph-burning/requirements\").is_dir());\n    70→    assert!(temp_dir.path().join(\".ralph-burning/daemon/tasks\").is_dir());\n    71→    assert!(temp_dir\n    72→        .path()\n    73→        .join(\".ralph-burning/daemon/leases\")\n    74→        .is_dir());\n    75→}\n    76→\n    77→#[test]\n    78→fn init_fails_when_workspace_already_exists() {\n    79→    let temp_dir = tempdir().expect(\"create temp dir\");\n    80→\n    81→    let first = Command::new(binary())\n    82→        .arg(\"init\")\n    83→        .current_dir(temp_dir.path())\n    84→        .output()\n    85→        .expect(\"run first init\");\n    86→    assert!(first.status.success());\n    87→\n    88→    let second = Command::new(binary())\n    89→        .arg(\"init\")\n    90→        .current_dir(temp_dir.path())\n    91→        .output()\n    92→        .expect(\"run second init\");\n    93→\n    94→    assert!(!second.status.success());\n    95→\n    96→    let stderr = String::from_utf8_lossy(&second.stderr);\n    97→    assert!(stderr.contains(\"workspace already initialized\"));\n    98→}\n    99→"}]},"parent_tool_use_id":"toolu_01Vkm6Qg1JKzJKe5nJZV9C9K","session_id":"50421a6e-e879-47e1-9362-86cf29dfc606","uuid":"6146f36e-8178-4135-a78f-108650fe630d"}
