        }\n    44→    }\n    45→    writeln!(out).unwrap();\n    46→\n    47→    writeln!(out, \"## Readiness\").unwrap();\n    48→    writeln!(out).unwrap();\n    49→    let ready_str = if payload.readiness.ready { \"Yes\" } else { \"No\" };\n    50→    writeln!(out, \"- **Ready:** {ready_str}\").unwrap();\n    51→    if payload.readiness.risks.is_empty() {\n    52→        writeln!(out, \"- **Risks:** None identified.\").unwrap();\n    53→    } else {\n    54→        writeln!(out, \"- **Risks:**\").unwrap();\n    55→        for risk in &payload.readiness.risks {\n    56→            writeln!(out, \"  - {risk}\").unwrap();\n    57→        }\n    58→    }\n    59→\n    60→    out\n    61→}\n    62→\n    63→/// Render an execution payload to deterministic Markdown.\n    64→pub fn render_execution(stage_id: StageId, payload: &ExecutionPayload) -> String {\n    65→    let mut out = String::new();\n    66→\n    67→    writeln!(out, \"# {}\", stage_id.display_name()).unwrap();\n    68→    writeln!(out).unwrap();\n    69→    writeln!(out, \"## Change Summary\").unwrap();\n    70→    writeln!(out).unwrap();\n    71→    writeln!(out, \"{}\", payload.change_summary).unwrap();\n    72→    writeln!(out).unwrap();\n    73→\n    74→    writeln!(out, \"## Steps\").unwrap();\n    75→    writeln!(out).unwrap();\n    76→    for step in &payload.steps {\n    77→        writeln!(\n    78→            out,\n    79→            \"{}. [{}] {}\",\n    80→            step.order, step.status, step.description\n    81→        )\n    82→        .unwrap();\n    83→    }\n    84→    writeln!(out).unwrap();\n    85→\n    86→    writeln!(out, \"## Validation Evidence\").unwrap();\n    87→    writeln!(out).unwrap();\n    88→    if payload.validation_evidence.is_empty() {\n    89→        writeln!(out, \"None provided.\").unwrap();\n    90→    } else {\n    91→        for item in &payload.validation_evidence {\n    92→            writeln!(out, \"- {item}\").unwrap();\n    93→        }\n    94→    }\n    95→    writeln!(out).unwrap();\n    96→\n    97→    writeln!(out, \"## Outstanding Risks\").unwrap();\n    98→    writeln!(out).unwrap();\n    99→    if payload.outstanding_risks.is_empty() {\n   100→        writeln!(out, \"None identified.\").unwrap();\n   101→    } else {\n   102→        for risk in &payload.outstanding_risks {\n   103→            writeln!(out, \"- {risk}\").unwrap();\n   104→        }\n   105→    }\n   106→\n   107→    out\n   108→}\n   109→\n   110→/// Render a validation/review payload to deterministic Markdown.\n   111→pub fn render_validation(stage_id: StageId, payload: &ValidationPayload) -> String {\n   112→    let mut out = String::new();\n   113→\n   114→    writeln!(out, \"# {}\", stage_id.display_name()).unwrap();\n   115→    writeln!(out).unwrap();\n   116→    writeln!(out, \"## Outcome\").unwrap();\n   117→    writeln!(out).unwrap();\n   118→    writeln!(out, \"**{}**\", payload.outcome).unwrap();\n   119→    writeln!(out).unwrap();\n   120→\n   121→    writeln!(out, \"## Evidence\").unwrap();\n   122→    writeln!(out).unwrap();\n   123→    if payload.evidence.is_empty() {\n   124→        writeln!(out, \"None provided.\").unwrap();\n   125→    } else {\n   126→        for item in &payload.evidence {\n   127→            writeln!(out, \"- {item}\").unwrap();\n   128→        }\n   129→    }\n   130→    writeln!(out).unwrap();\n   131→\n   132→    writeln!(out, \"## Findings and Gaps\").unwrap();\n   133→    writeln!(out).unwrap();\n   134→    if payload.findings_or_gaps.is_empty() {\n   135→        writeln!(out, \"None identified.\").unwrap();\n   136→    } else {\n   137→        for item in &payload.findings_or_gaps {\n   138→            writeln!(out, \"- {item}\").unwrap();\n   139→        }\n   140→    }\n   141→    writeln!(out).unwrap();\n   142→\n   143→    writeln!(out, \"## Follow-up and Amendments\").unwrap();\n   144→    writeln!(out).unwrap();\n   145→    if payload.follow_up_or_amendments.is_empty() {\n   146→        writeln!(out, \"None.\").unwrap();\n   147→    } else {\n   148→        for item in &payload.follow_up_or_amendments {\n   149→            writeln!(out, \"- {item}\").unwrap();\n   150→        }\n   151→    }\n   152→\n   153→    out\n   154→}\n   155→"}]},"parent_tool_use_id":null,"session_id":"a43e306d-d21a-484c-9b37-70212164e32a","uuid":"2b469337-dd98-449c-a316-8669319d45f5","tool_use_result":{"type":"text","file":{"filePath":"/root/new-ralph-burning/ralph-burning-rewrite/src/contexts/workflow_composition/renderers.rs","content":"#![forbid(unsafe_code)]\n\n//! Deterministic Markdown renderers for validated stage payloads.\n//!\n//! Each renderer produces byte-identical output for the same input, uses canonical\n//! `cycle` terminology, and derives content only from validated structured fields —\n//! never from raw backend text.\n\nuse std::fmt::Write;\n\nuse crate::shared::domain::StageId;\n\nuse super::payloads::{ExecutionPayload, PlanningPayload, ValidationPayload};\n\n/// Render a planning payload to deterministic Markdown.\npub fn render_planning(stage_id: StageId, payload: &PlanningPayload) -> String {\n    let mut out = String::new();\n\n    writeln!(out, \"# {}\", stage_id.display_name()).unwrap();\n    writeln!(out).unwrap();\n    writeln!(out, \"## Problem Framing\").unwrap();\n    writeln!(out).unwrap();\n    writeln!(out, \"{}\", payload.problem_framing).unwrap();\n    writeln!(out).unwrap();\n\n    writeln!(out, \"## Assumptions and Open Questions\").unwrap();\n    writeln!(out).unwrap();\n    if payload.assumptions_or_open_questions.is_empty() {\n        writeln!(out, \"None.\").unwrap();\n    } else {\n        for item in &payload.assumptions_or_open_questions {\n            writeln!(out, \"- {item}\").unwrap();\n        }\n    }\n    writeln!(out).unwrap();\n\n    writeln!(out, \"## Proposed Work\").unwrap();\n    writeln!(out).unwrap();\n    for item in &payload.proposed_work {\n        writeln!(out, \"{}. **{}**\", item.order, item.summary).unwrap();\n        if !item.details.is_empty() {\n            writeln!(out, \"   {}\", item.details).unwrap();\n        }\n    }\n    writeln!(out).unwrap();\n\n    writeln!(out, \"## Readiness\").unwrap();\n    writeln!(out).unwrap();\n    let ready_str = if payload.readiness.ready { \"Yes\" } else { \"No\" };\n    writeln!(out, \"- **Ready:** {ready_str}\").unwrap();\n    if payload.readiness.risks.is_empty() {\n        writeln!(out, \"- **Risks:** None identified.\").unwrap();\n    } else {\n        writeln!(out, \"- **Risks:**\").unwrap();\n        for risk in &payload.readiness.risks {\n            writeln!(out, \"  - {risk}\").unwrap();\n        }\n    }\n\n    out\n}\n\n/// Render an execution payload to deterministic Markdown.\npub fn render_execution(stage_id: StageId, payload: &ExecutionPayload) -> String {\n    let mut out = String::new();\n\n    writeln!(out, \"# {}\", stage_id.display_name()).unwrap();\n    writeln!(out).unwrap();\n    writeln!(out, \"## Change Summary\").unwrap();\n    writeln!(out).unwrap();\n    writeln!(out, \"{}\", payload.change_summary).unwrap();\n    writeln!(out).unwrap();\n\n    writeln!(out, \"## Steps\").unwrap();\n    writeln!(out).unwrap();\n    for step in &payload.steps {\n        writeln!(\n            out,\n            \"{}. [{}] {}\",\n            step.order, step.status, step.description\n        )\n        .unwrap();\n    }\n    writeln!(out).unwrap();\n\n    writeln!(out, \"## Validation Evidence\").unwrap();\n    writeln!(out).unwrap();\n    if payload.validation_evidence.is_empty() {\n        writeln!(out, \"None provided.\").unwrap();\n    } else {\n        for item in &payload.validation_evidence {\n            writeln!(out, \"- {item}\").unwrap();\n        }\n    }\n    writeln!(out).unwrap();\n\n    writeln!(out, \"## Outstanding Risks\").unwrap();\n    writeln!(out).unwrap();\n    if payload.outstanding_risks.is_empty() {\n        writeln!(out, \"None identified.\").unwrap();\n    } else {\n        for risk in &payload.outstanding_risks {\n            writeln!(out, \"- {risk}\").unwrap();\n        }\n    }\n\n    out\n}\n\n/// Render a validation/review payload to deterministic Markdown.\npub fn render_validation(stage_id: StageId, payload: &ValidationPayload) -> String {\n    let mut out = String::new();\n\n    writeln!(out, \"# {}\", stage_id.display_name()).unwrap();\n    writeln!(out).unwrap();\n    writeln!(out, \"## Outcome\").unwrap();\n    writeln!(out).unwrap();\n    writeln!(out, \"**{}**\", payload.outcome).unwrap();\n    writeln!(out).unwrap();\n\n    writeln!(out, \"## Evidence\").unwrap();\n    writeln!(out).unwrap();\n    if payload.evidence.is_empty() {\n        writeln!(out, \"None provided.\").unwrap();\n    } else {\n        for item in &payload.evidence {\n            writeln!(out, \"- {item}\").unwrap();\n        }\n    }\n    writeln!(out).unwrap();\n\n    writeln!(out, \"## Findings and Gaps\").unwrap();\n    writeln!(out).unwrap();\n    if payload.findings_or_gaps.is_empty() {\n        writeln!(out, \"None identified.\").unwrap();\n    } else {\n        for item in &payload.findings_or_gaps {\n            writeln!(out, \"- {item}\").unwrap();\n        }\n    }\n    writeln!(out).unwrap();\n\n    writeln!(out, \"## Follow-up and Amendments\").unwrap();\n    writeln!(out).unwrap();\n    if payload.follow_up_or_amendments.is_empty() {\n        writeln!(out, \"None.\").unwrap();\n    } else {\n        for item in &payload.follow_up_or_amendments {\n            writeln!(out, \"- {item}\").unwrap();\n        }\n    }\n\n    out\n}\n","numLines":155,"startLine":1,"totalLines":155}}}
