{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01QDmvKa7RZfyWySsULoNSmL","type":"tool_result","content":"     1→use crate::shared::domain::{FlowPreset, StageId};\n     2→use crate::shared::error::AppResult;\n     3→\n     4→#[derive(Debug, Clone, Copy, PartialEq, Eq)]\n     5→pub struct ValidationProfile {\n     6→    pub name: &'static str,\n     7→    pub summary: &'static str,\n     8→    pub final_review_enabled: bool,\n     9→}\n    10→\n    11→#[derive(Debug, Clone, Copy, PartialEq, Eq)]\n    12→pub struct FlowDefinition {\n    13→    pub preset: FlowPreset,\n    14→    pub description: &'static str,\n    15→    pub stages: &'static [StageId],\n    16→    pub validation_profile: ValidationProfile,\n    17→}\n    18→\n    19→const STANDARD_STAGES: [StageId; 8] = [\n    20→    StageId::PromptReview,\n    21→    StageId::Planning,\n    22→    StageId::Implementation,\n    23→    StageId::Qa,\n    24→    StageId::Review,\n    25→    StageId::CompletionPanel,\n    26→    StageId::AcceptanceQa,\n    27→    StageId::FinalReview,\n    28→];\n    29→\n    30→const QUICK_DEV_STAGES: [StageId; 4] = [\n    31→    StageId::PlanAndImplement,\n    32→    StageId::Review,\n    33→    StageId::ApplyFixes,\n    34→    StageId::FinalReview,\n    35→];\n    36→\n    37→const DOCS_CHANGE_STAGES: [StageId; 4] = [\n    38→    StageId::DocsPlan,\n    39→    StageId::DocsUpdate,\n    40→    StageId::DocsValidation,\n    41→    StageId::Review,\n    42→];\n    43→\n    44→const CI_IMPROVEMENT_STAGES: [StageId; 4] = [\n    45→    StageId::CiPlan,\n    46→    StageId::CiUpdate,\n    47→    StageId::CiValidation,\n    48→    StageId::Review,\n    49→];\n    50→\n    51→const FLOW_DEFINITIONS: [FlowDefinition; 4] = [\n    52→    FlowDefinition {\n    53→        preset: FlowPreset::Standard,\n    54→        description:\n    55→            \"Full delivery flow with planning, implementation, QA, review, and acceptance.\",\n    56→        stages: &STANDARD_STAGES,\n    57→        validation_profile: ValidationProfile {\n    58→            name: \"standard-default\",\n    59→            summary: \"Full validation suite with completion and acceptance checks.\",\n    60→            final_review_enabled: true,\n    61→        },\n    62→    },\n    63→    FlowDefinition {\n    64→        preset: FlowPreset::QuickDev,\n    65→        description: \"Fast delivery flow for small code changes with lightweight review.\",\n    66→        stages: &QUICK_DEV_STAGES,\n    67→        validation_profile: ValidationProfile {\n    68→            name: \"quick-dev-default\",\n    69→            summary: \"Lightweight panel with final review enabled by default.\",\n    70→            final_review_enabled: true,\n    71→        },\n    72→    },\n    73→    FlowDefinition {\n    74→        preset: FlowPreset::DocsChange,\n    75→        description: \"Documentation-focused flow for planning, content updates, and validation.\",\n    76→        stages: &DOCS_CHANGE_STAGES,\n    77→        validation_profile: ValidationProfile {\n    78→            name: \"docs-default\",\n    79→            summary: \"Documentation validation with final review disabled by default.\",\n    80→            final_review_enabled: false,\n    81→        },\n    82→    },\n    83→    FlowDefinition {\n    84→        preset: FlowPreset::CiImprovement,\n    85→        description: \"CI improvement flow for automation planning, updates, and validation.\",\n    86→        stages: &CI_IMPROVEMENT_STAGES,\n    87→        validation_profile: ValidationProfile {\n    88→            name: \"ci-default\",\n    89→            summary: \"Automation validation with final review disabled by default.\",\n    90→            final_review_enabled: false,\n    91→        },\n    92→    },\n    93→];\n    94→\n    95→pub fn built_in_flows() -> &'static [FlowDefinition] {\n    96→    &FLOW_DEFINITIONS\n    97→}\n    98→\n    99→pub fn flow_definition(preset: FlowPreset) -> &'static FlowDefinit