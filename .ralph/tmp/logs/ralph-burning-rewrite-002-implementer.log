{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01RttjK3Bvy4DYrH6vxd9su7","type":"tool_result","content":"     1→#![forbid(unsafe_code)]\n     2→\n     3→//! Stage contract registry and deterministic evaluation pipeline.\n     4→//!\n     5→//! Every stage in every built-in flow preset resolves to exactly one\n     6→//! [`StageContract`]. Contract evaluation enforces a fixed order:\n     7→//!\n     8→//! 1. **Schema validation** — deserialize raw JSON into the typed payload.\n     9→//! 2. **Semantic validation** — apply domain rules to the typed payload.\n    10→//! 3. **Rendering** — produce a deterministic Markdown artifact.\n    11→//!\n    12→//! On schema failure, semantic validation and rendering do not run.\n    13→//! On domain failure, rendering does not run.\n    14→//! On any failure, no success bundle is returned.\n    15→\n    16→use schemars::schema::RootSchema;\n    17→\n    18→use crate::shared::domain::{FailureClass, StageId};\n    19→use crate::shared::error::ContractError;\n    20→\n    21→use super::payloads::{\n    22→    ExecutionPayload, PlanningPayload, StagePayload, ValidationPayload,\n    23→};\n    24→use super::renderers;\n    25→\n    26→// ── Contract family ─────────────────────────────────────────────────────────\n    27→\n    28→/// Classifies a stage into one of three payload families.\n    29→#[derive(Debug, Clone, Copy, PartialEq, Eq, Hash)]\n    30→pub enum ContractFamily {\n    31→    /// prompt_review, planning, docs_plan, ci_plan\n    32→    Planning,\n    33→    /// implementation, plan_and_implement, apply_fixes, docs_update, ci_update\n    34→    Execution,\n    35→    /// qa, docs_validation, ci_validation, acceptance_qa, review, final_review,\n    36→    /// completion_panel\n    37→    Validation,\n    38→}\n    39→\n    40→// ── Stage contract ──────────────────────────────────────────────────────────\n    41→\n    42→/// A stage contract binds a [`StageId`] to its payload family, schema,\n    43→/// semantic validation rules, and renderer.\n    44→#[derive(Debug, Clone, Copy, PartialEq, Eq)]\n    45→pub struct StageContract {\n    46→    pub stage_id: StageId,\n    47→    pub family: ContractFamily,\n    48→}\n    49→\n    50→/// Bundle of a validated payload and its rendered Markdown artifact.\n    51→///\n    52→/// Callers receive either a `ValidatedBundle` or an error — never one without\n    53→/// the other.\n    54→#[derive(Debug, Clone, PartialEq, Eq)]\n    55→pub struct ValidatedBundle {\n    56→    pub payload: StagePayload,\n    57→    pub artifact: String,\n    58→}\n    59→\n    60→/// Outcome of a successful contract evaluation.\n    61→#[derive(Debug, Clone, PartialEq, Eq)]\n    62→pub struct EvalSuccess {\n    63→    pub bundle: ValidatedBundle,\n    64→    /// Set to [`FailureClass::QaReviewOutcomeFailure`] when a validation/review\n    65→    /// stage produces a non-passing outcome. The bundle is still returned\n    66→    /// because the payload is structurally and semantically valid — only the\n    67→    /// workflow-level outcome is non-passing.\n    68→    pub outcome_failure: Option<FailureClass>,\n    69→}\n    70→\n    71→// ── Registry ────────────────────────────────────────────────────────────────\n    72→\n    73→/// Look up the contract for a given stage. Every [`StageId`] variant resolves\n    74→/// to exactly one contract.\n    75→pub fn contract_for_stage(stage_id: StageId) -> StageContract {\n    76→    let family = match stage_id {\n    77→        StageId::PromptReview\n    78→        | StageId::Planning\n    79→        | StageId::DocsPlan\n    80→        | StageId::CiPlan => ContractFamily::Planning,\n    81→\n    82→        StageId::Implementation\n    83→        | StageId::PlanAndImplement\n    84→        | StageId::ApplyFixes\n    85→        | StageId::DocsUpdate\n    86→        | StageId::CiUpdate => ContractFamily::Execution,\n    87→\n    88→        StageId::Qa\n    89→        | StageId::DocsValidation\n    90→        | StageId::CiValidation\n    91→        | StageId::AcceptanceQa\n    92→        | StageId::Review\n    93→        | StageId::FinalReview\n    94→        | StageId::CompletionPanel => ContractFamily::Validation,\n    95→    };\n    96→\n    97→    StageContract { stage_id, family }\n    98→}\n    99→\n   100→/// Return contracts for all stages, in [`StageId::ALL`] order.\n   101→pub fn all_contracts() -> Vec<StageContract> {\n   102→    StageId::ALL\n   103→        .iter()\n   104→        .map(|&id| contract_for_stage(id))\n   105→        .collect()\n   106→}\n   107→\n   108→// ── Contract implementation ─────────────────────────────────────────────────\n   109→\n   110→impl StageContract {\n   111→    /// Generate the JSON Schema for this contract's payload family.\n   112→    pub fn json_schema(&self) -> RootSchema {\n   113→        match self.family {\n   114→            ContractFamily::Planning => schemars::schema_for!(PlanningPayload),\n   115→            ContractFamily::Execution => schemars::schema_for!(ExecutionPayload),\n   116→            ContractFamily::Validation => schemars::schema_for!(ValidationPayload),\n   117→        }\n   118→    }\n   119→\n   120→    /// Evaluate a raw JSON value through the full contract pipeline.\n   121→    ///\n   122→    /// Schema validation → semantic validation → rendering.\n   123→    ///\n   124→    /// Returns [`EvalSuccess`] on success (which may still carry a\n   125→    /// [`FailureClass::QaReviewOutcomeFailure`] for non-passing review outcomes)\n   126→    /// or a [`ContractError`] on any hard failure.\n   127→    pub fn evaluate(&self, raw_json: &serde_json::Value) -> Result<EvalSuccess, ContractError> {\n   128→        // Step 1: Schema validation (deserialization into typed payload).\n   129→        let payload = self.validate_schema(raw_json)?;\n   130→\n   131→        // Step 2: Semantic / domain validation.\n   132→        self.validate_semantics(&payload)?;\n   133→\n   134→        // Step 3: Deterministic Markdown rendering.\n   135→        let artifact = self.render(&payload);\n   136→\n   137→        // Step 4: Map non-passing QA/review outcomes.\n   138→        let outcome_failure = Self::check_outcome_failure(&payload);\n   139→\n   140→        Ok(EvalSuccess {\n   141→            bundle: ValidatedBundle { payload, artifact },\n   142→            outcome_failure,\n   143→        })\n   144→    }\n   145→\n   146→    // ── Private helpers ─────────────────────────────────────────────────\n   147→\n   148→    fn validate_schema(&self, raw: &serde_json::Value) -> Result<StagePayload, ContractError> {\n   149→        match self.family {\n   150→            ContractFamily::Planning => {\n   151→                let p: PlanningPayload =\n   152→                    serde_json::from_value(raw.clone()).map_err(|e| {\n   153→                        ContractError::SchemaValidation {\n   154→                            stage_id: self.stage_id,\n   155→                            details: e.to_string(),\n   156→                        }\n   157→                    })?;\n   158→                Ok(StagePayload::Planning(p))\n   159→            }\n   160→            ContractFamily::Execution => {\n   161→                let p: ExecutionPayload =\n   162→                    serde_json::from_value(raw.clone()).map_err(|e| {\n   163→                        ContractError::SchemaValidation {\n   164→                            stage_id: self.stage_id,\n   165→                            details: e.to_string(),\n   166→                        }\n   167→                    })?;\n   168→                Ok(StagePayload::Execution(p))\n   169→            }\n   170→            ContractFamily::Validation => {\n   171→                let p: ValidationPayload =\n   172→                    serde_json::from_value(raw.clone()).map_err(|e| {\n   173→                        ContractError::SchemaValidation {\n   174→                            stage_id: self.stage_id,\n   175→                            details: e.to_string(),\n   176→                        }\n   177→                    })?;\n   178→                Ok(StagePayload::Validation(p))\n   179→            }\n   180→        }\n   181→    }\n   182→\n   183→    fn validate_semantics(&self, payload: &StagePayload) -> Result<(), ContractError> {\n   184→        match payload {\n   185→            StagePayload::Planning(p) => {\n   186→                let mut errors = Vec::new();\n   187→                if p.problem_framing.trim().is_empty() {\n   188→                    errors.push(\"problem_framing must not be empty\".to_string());\n   189→                }\n   190→                if p.proposed_work.is_empty() {\n   191→                    errors\n   192→                        .push(\"proposed_work must contain at least one item\".to_string());\n   193→                }\n   194→                for (i, item) in p.proposed_work.iter().enumerate() {\n   195→                    if item.order == 0 {\n   196→                        errors.push(format!(\n   197→                            \"proposed_work[{i}].order must be positive\"\n   198→                        ));\n   199→                    }\n   200→                }\n   201→                if !errors.is_empty() {\n   202→                    return Err(ContractError::DomainValidation {\n   203→                        stage_id: self.stage_id,\n   204→                        details: errors.join(\"; \"),\n   205→                    });\n   206→                }\n   207→            }\n   208→            StagePayload::Execution(p) => {\n   209→                let mut errors = Vec::new();\n   210→                if p.change_summary.trim().is_empty() {\n   211→                    errors.push(\"change_summary must not be empty\".to_string());\n   212→                }\n   213→                if p.steps.is_empty() {\n   214→                    errors.push(\"steps must contain at least one item\".to_string());\n   215→                }\n   216→                for (i, step) in p.steps.iter().enumerate() {\n   217→                    if step.order == 0 {\n   218→                        errors\n   219→                            .push(format!(\"steps[{i}].order must be positive\"));\n   220→                    }\n   221→                }\n   222→                if !errors.is_empty() {\n   223→                    return Err(ContractError::DomainValidation {\n   224→                        stage_id: self.stage_id,\n   225→                        details: errors.join(\"; \"),\n   226→                    });\n   227→                }\n   228→            }\n   229→            StagePayload::Validation(p) => {\n   230→                if !p.outcome.is_passing() && p.follow_up_or_amendments.is_empty()\n   231→                {\n   232→                    return Err(ContractError::DomainValidation {\n   233→                        stage_id: self.stage_id,\n   234→                        details:\n   235→                            \"follow_up_or_amendments required when outcome is not approved\"\n   236→                                .to_string(),\n   237→                    });\n   238→                }\n   239→            }\n   240→        }\n   241→        Ok(())\n   242→    }\n   243→\n   244→    fn render(&self, payload: &StagePayload) -> String {\n   245→        match payload {\n   246→            StagePayload::Planning(p) => {\n   247→                renderers::render_planning(self.stage_id, p)\n   248→            }\n   249→            StagePayload::Execution(p) => {\n   250→                renderers::render_execution(self.stage_id, p)\n   251→            }\n   252→            StagePayload::Validation(p) => {\n   253→                renderers::render_validation(self.stage_id, p)\n   254→            }\n   255→        }\n   256→    }\n   257→\n   258→    fn check_outcome_failure(payload: &StagePayload) -> Option<FailureClass> {\n   259→        if let StagePayload::Validation(p) = payload {\n   260→            if !p.outcome.is_passing() {\n   261→                return Some(FailureClass::QaReviewOutcomeFailure);\n   262→            }\n   263→        }\n   264→        None\n   265→    }\n   266→}\n   267→"}]},"parent_tool_use_id":null,"session_id":"a43e306d-d21a-484c-9b37-70212164e32a","uuid":"977b8264-9d24-472c-8991-b7f768c5b921","tool_use_result":{"type":"text","file":{"filePath":"/root/new-ralph-burning/ralph-burning-rewrite/src/contexts/workflow_composition/contracts.rs","content":"#![forbid(unsafe_code)]\n\n//! Stage contract registry and deterministic evaluation pipeline.\n//!\n//! Every stage in every built-in flow preset resolves to exactly one\n//! [`StageContract`]. Contract evaluation enforces a fixed order:\n//!\n//! 1. **Schema validation** — deserialize raw JSON into the typed payload.\n//! 2. **Semantic validation** — apply domain rules to the typed payload.\n//! 3. **Rendering** — produce a deterministic Markdown artifact.\n//!\n//! On schema failure, semantic validation and rendering do not run.\n//! On domain failure, rendering does not run.\n//! On any failure, no success bundle is returned.\n\nuse schemars::schema::RootSchema;\n\nuse crate::shared::domain::{FailureClass, StageId};\nuse crate::shared::error::ContractError;\n\nuse super::payloads::{\n    ExecutionPayload, PlanningPayload, StagePayload, ValidationPayload,\n};\nuse super::renderers;\n\n// ── Contract family ─────────────────────────────────────────────────────────\n\n/// Classifies a stage into one of three payload families.\n#[derive(Debug, Clone, Copy, PartialEq, Eq, Hash)]\npub enum ContractFamily {\n    /// prompt_review, planning, docs_plan, ci_plan\n    Planning,\n    /// implementation, plan_and_implement, apply_fixes, docs_update, ci_update\n    Execution,\n    /// qa, docs_validation, ci_validation, acceptance_qa, review, final_review,\n    /// completion_panel\n    Validation,\n}\n\n// ── Stage contract ──────────────────────────────────────────────────────────\n\n/// A stage contract binds a [`StageId`] to its payload family, schema,\n/// semantic validation rules, and renderer.\n#[derive(Debug, Clone, Copy, PartialEq, Eq)]\npub struct StageContract {\n    pub stage_id: StageId,\n    pub family: ContractFamily,\n}\n\n/// Bundle of a validated payload and its rendered Markdown artifact.\n///\n/// Callers receive either a `ValidatedBundle` or an error — never one without\n/// the other.\n#[derive(Debug, Clone, PartialEq, Eq)]\npub struct ValidatedBundle {\n    pub payload: StagePayload,\n    pub artifact: String,\n}\n\n/// Outcome of a successful contract evaluation.\n#[derive(Debug, Clone, PartialEq, Eq)]\npub struct EvalSuccess {\n    pub bundle: ValidatedBundle,\n    /// Set to [`FailureClass::QaReviewOutcomeFailure`] when a validation/review\n    /// stage produces a non-passing outcome. The bundle is still returned\n    /// because the payload is structurally and semantically valid — only the\n    /// workflow-level outcome is non-passing.\n    pub outcome_failure: Option<FailureClass>,\n}\n\n// ── Registry ────────────────────────────────────────────────────────────────\n\n/// Look up the contract for a given stage. Every [`StageId`] variant resolves\n/// to exactly one contract.\npub fn contract_for_stage(stage_id: StageId) -> StageContract {\n    let family = match stage_id {\n        StageId::PromptReview\n        | StageId::Planning\n        | StageId::DocsPlan\n        | StageId::CiPlan => ContractFamily::Planning,\n\n        StageId::Implementation\n        | StageId::PlanAndImplement\n        | StageId::ApplyFixes\n        | StageId::DocsUpdate\n        | StageId::CiUpdate => ContractFamily::Execution,\n\n        StageId::Qa\n        | StageId::DocsValidation\n        | StageId::CiValidation\n        | StageId::AcceptanceQa\n        | StageId::Review\n        | StageId::FinalReview\n        | StageId::CompletionPanel => ContractFamily::Validation,\n    };\n\n    StageContract { stage_id, family }\n}\n\n/// Return contracts for all stages, in [`StageId::ALL`] order.\npub fn all_contracts() -> Vec<StageContract> {\n    StageId::ALL\n        .iter()\n        .map(|&id| contract_for_stage(id))\n        .collect()\n}\n\n// ── Contract implementation ─────────────────────────────────────────────────\n\nimpl StageContract {\n    /// Generate the JSON Schema for this contract's payload family.\n    pub fn json_schema(&self) -> RootSchema {\n        match self.family {\n            ContractFamily::Planning => schemars::schema_for!(PlanningPayload),\n            ContractFamily::Execution => schemars::schema_for!(ExecutionPayload),\n            ContractFamily::Validation => schemars::schema_for!(ValidationPayload),\n        }\n    }\n\n    /// Evaluate a raw JSON value through the full contract pipeline.\n    ///\n    /// Schema validation → semantic validation → rendering.\n    ///\n    /// Returns [`EvalSuccess`] on success (which may still carry a\n    /// [`FailureClass::QaReviewOutcomeFailure`] for non-passing review outcomes)\n    /// or a [`ContractError`] on any hard failure.\n    pub fn evaluate(&self, raw_json: &serde_json::Value) -> Result<EvalSuccess, ContractError> {\n        // Step 1: Schema validation (deserialization into typed payload).\n        let payload = self.validate_schema(raw_json)?;\n\n        // Step 2: Semantic / domain validation.\n        self.validate_semantics(&payload)?;\n\n        // Step 3: Deterministic Markdown rendering.\n        let artifact = self.render(&payload);\n\n        // Step 4: Map non-passing QA/review outcomes.\n        let outcome_failure = Self::check_outcome_failure(&payload);\n\n        Ok(EvalSuccess {\n            bundle: ValidatedBundle { payload, artifact },\n            outcome_failure,\n        })\n    }\n\n    // ── Private helpers ─────────────────────────────────────────────────\n\n    fn validate_schema(&self, raw: &serde_json::Value) -> Result<StagePayload, ContractError> {\n        match self.family {\n            ContractFamily::Planning => {\n                let p: PlanningPayload =\n                    serde_json::from_value(raw.clone()).map_err(|e| {\n                        ContractError::SchemaValidation {\n                            stage_id: self.stage_id,\n                            details: e.to_string(),\n                        }\n                    })?;\n                Ok(StagePayload::Planning(p))\n            }\n            ContractFamily::Execution => {\n                let p: ExecutionPayload =\n                    serde_json::from_value(raw.clone()).map_err(|e| {\n                        ContractError::SchemaValidation {\n                            stage_id: self.stage_id,\n                            details: e.to_string(),\n                        }\n                    })?;\n                Ok(StagePayload::Execution(p))\n            }\n            ContractFamily::Validation => {\n                let p: ValidationPayload =\n                    serde_json::from_value(raw.clone()).map_err(|e| {\n                        ContractError::SchemaValidation {\n                            stage_id: self.stage_id,\n                            details: e.to_string(),\n                        }\n                    })?;\n                Ok(StagePayload::Validation(p))\n            }\n        }\n    }\n\n    fn validate_semantics(&self, payload: &StagePayload) -> Result<(), ContractError> {\n        match payload {\n            StagePayload::Planning(p) => {\n                let mut errors = Vec::new();\n                if p.problem_framing.trim().is_empty() {\n                    errors.push(\"problem_framing must not be empty\".to_string());\n                }\n                if p.proposed_work.is_empty() {\n                    errors\n                        .push(\"proposed_work must contain at least one item\".to_string());\n                }\n                for (i, item) in p.proposed_work.iter().enumerate() {\n                    if item.order == 0 {\n                        errors.push(format!(\n                            \"proposed_work[{i}].order must be positive\"\n                        ));\n                    }\n                }\n                if !errors.is_empty() {\n                    return Err(ContractError::DomainValidation {\n                        stage_id: self.stage_id,\n                        details: errors.join(\"; \"),\n                    });\n                }\n            }\n            StagePayload::Execution(p) => {\n                let mut errors = Vec::new();\n                if p.change_summary.trim().is_empty() {\n                    errors.push(\"change_summary must not be empty\".to_string());\n                }\n                if p.steps.is_empty() {\n                    errors.push(\"steps must contain at least one item\".to_string());\n                }\n                for (i, step) in p.steps.iter().enumerate() {\n                    if step.order == 0 {\n                        errors\n                            .push(format!(\"steps[{i}].order must be positive\"));\n                    }\n                }\n                if !errors.is_empty() {\n                    return Err(ContractError::DomainValidation {\n                        stage_id: self.stage_id,\n                        details: errors.join(\"; \"),\n                    });\n                }\n            }\n            StagePayload::Validation(p) => {\n                if !p.outcome.is_passing() && p.follow_up_or_amendments.is_empty()\n                {\n                    return Err(ContractError::DomainValidation {\n                        stage_id: self.stage_id,\n                        details:\n                            \"follow_up_or_amendments required when outcome is not approved\"\n                                .to_string(),\n                    });\n                }\n            }\n        }\n        Ok(())\n    }\n\n    fn render(&self, payload: &StagePayload) -> String {\n        match payload {\n            StagePayload::Planning(p) => {\n                renderers::render_planning(self.stage_id, p)\n            }\n            StagePayload::Execution(p) => {\n                renderers::render_execution(self.stage_id, p)\n            }\n            StagePayload::Validation(p) => {\n                renderers::render_validation(self.stage_id, p)\n            }\n        }\n    }\n\n    fn check_outcome_failure(payload: &StagePayload) -> Option<FailureClass> {\n        if let StagePayload::Validation(p) = payload {\n            if !p.outcome.is_passing() {\n                return Some(FailureClass::QaReviewOutcomeFailure);\n            }\n        }\n        None\n    }\n}\n","numLines":267,"startLine":1,"totalLines":267}}}
