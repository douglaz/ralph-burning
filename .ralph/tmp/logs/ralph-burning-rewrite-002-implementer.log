ad).\n        let payload = self.validate_schema(raw_json)?;\n\n        // Step 2: Semantic / domain validation.\n        self.validate_semantics(&payload)?;\n\n        // Step 3: Non-passing QA/review outcome check (before rendering).\n        self.check_outcome(&payload)?;\n\n        // Step 4: Deterministic Markdown rendering (only on full success).\n        let artifact = self.render(&payload);\n\n        Ok(ValidatedBundle { payload, artifact })\n    }"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":539,"cache_read_input_tokens":48303,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":539},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"a43e306d-d21a-484c-9b37-70212164e32a","uuid":"69ac13cf-3a62-4f3c-9358-9261c5cabf3e"}
