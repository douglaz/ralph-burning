{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01TH1jZvkE3pBjgdTDu1c6Qv","type":"tool_result","content":"     1→use clap::{Args, Subcommand};\n     2→\n     3→use crate::contexts::workflow_composition::{built_in_flows, flow_definition_by_id};\n     4→use crate::shared::error::AppResult;\n     5→\n     6→#[derive(Debug, Args)]\n     7→pub struct FlowCommand {\n     8→    #[command(subcommand)]\n     9→    pub command: FlowSubcommand,\n    10→}\n    11→\n    12→#[derive(Debug, Subcommand)]\n    13→pub enum FlowSubcommand {\n    14→    List,\n    15→    Show { flow_id: String },\n    16→}\n    17→\n    18→pub async fn handle(command: FlowCommand) -> AppResult<()> {\n    19→    match command.command {\n    20→        FlowSubcommand::List => {\n    21→            for definition in built_in_flows() {\n    22→                println!(\"{} - {}\", definition.preset, definition.description);\n    23→            }\n    24→            Ok(())\n    25→        }\n    26→        FlowSubcommand::Show { flow_id } => {\n    27→            let definition = flow_definition_by_id(&flow_id)?;\n    28→            println!(\"Flow: {}\", definition.preset);\n    29→            println!(\"Description: {}\", definition.description);\n    30→            println!(\n    31→                \"Validation profile: {} ({})\",\n    32→                definition.validation_profile.name, definition.validation_profile.summary\n    33→            );\n    34→            println!(\n    35→                \"Final review enabled: {}\",\n    36→                if definition.validation_profile.final_review_enabled {\n    37→                    \"yes\"\n    38→                } else {\n    39→                    \"no\"\n    40→                }\n    41→            );\n    42→            println!(\"Stage count: {}\", definition.stages.len());\n    43→            println!();\n    44→            println!(\"Stages:\");\n    45→            for (index, stage) in definition.stages.iter().enumerate() {\n    46→                println!(\"{}. {}\", index + 1, stage);\n    47→            }\n    48→            Ok(())\n    49→        }\n    50→    }\n    51→}\n    52→"}]},"parent_tool_use_id":"toolu_01Vkm6Qg1JKzJKe5nJZV9C9K","session_id":"50421a6e-e879-47e1-9362-86cf29dfc606","uuid":"929f14f7-147f-477f-b2d9-fb7b99a3acf5"}
