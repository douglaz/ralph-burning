{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01PJ4mXVcCrEEG4JXa43SY3K","type":"tool_result","content":"     1→use chrono::TimeZone;\n     2→use ralph_burning::contexts::workspace_governance::{\n     3→    initialize_workspace, load_workspace_config, REQUIRED_WORKSPACE_DIRECTORIES, WORKSPACE_DIR,\n     4→};\n     5→use ralph_burning::shared::domain::{WorkspaceConfig, CURRENT_WORKSPACE_VERSION};\n     6→use tempfile::tempdir;\n     7→\n     8→#[test]\n     9→fn workspace_config_serialization_round_trip() {\n    10→    let created_at = chrono::Utc\n    11→        .with_ymd_and_hms(2026, 3, 11, 17, 50, 55)\n    12→        .single()\n    13→        .expect(\"valid timestamp\");\n    14→    let config = WorkspaceConfig::new(created_at);\n    15→\n    16→    let serialized = toml::to_string_pretty(&config).expect(\"serialize config\");\n    17→    let parsed: WorkspaceConfig = toml::from_str(&serialized).expect(\"deserialize config\");\n    18→\n    19→    assert_eq!(config, parsed);\n    20→    assert_eq!(CURRENT_WORKSPACE_VERSION, parsed.version);\n    21→}\n    22→\n    23→#[test]\n    24→fn initialize_workspace_creates_required_directory_structure_and_config() {\n    25→    let temp_dir = tempdir().expect(\"create temp dir\");\n    26→    let created_at = chrono::Utc\n    27→        .with_ymd_and_hms(2026, 3, 11, 17, 50, 55)\n    28→        .single()\n    29→        .expect(\"valid timestamp\");\n    30→\n    31→    let result = initialize_workspace(temp_dir.path(), created_at).expect(\"initialize workspace\");\n    32→\n    33→    assert_eq!(temp_dir.path().join(WORKSPACE_DIR), result.workspace_root);\n    34→    for required_directory in REQUIRED_WORKSPACE_DIRECTORIES {\n    35→        assert!(result.workspace_root.join(required_directory).is_dir());\n    36→    }\n    37→\n    38→    let config = load_workspace_config(temp_dir.path()).expect(\"load workspace config\");\n    39→    assert_eq!(created_at, config.created_at);\n    40→    assert_eq!(CURRENT_WORKSPACE_VERSION, config.version);\n    41→}\n    42→\n    43→#[test]\n    44→fn initialize_workspace_fails_when_workspace_already_exists() {\n    45→    let temp_dir = tempdir().expect(\"create temp dir\");\n    46→    let created_at = chrono::Utc\n    47→        .with_ymd_and_hms(2026, 3, 11, 17, 50, 55)\n    48→        .single()\n    49→        .expect(\"valid timestamp\");\n    50→\n    51→    initialize_workspace(temp_dir.path(), created_at).expect(\"initial initialization succeeds\");\n    52→    let second_attempt = initialize_workspace(temp_dir.path(), created_at);\n    53→\n    54→    assert!(second_attempt.is_err());\n    55→}\n    56→"}]},"parent_tool_use_id":"toolu_01Vkm6Qg1JKzJKe5nJZV9C9K","session_id":"50421a6e-e879-47e1-9362-86cf29dfc606","uuid":"709c7aab-9199-4894-9b0e-b747a0e65501"}
