{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01WoL51Jj4B2qYZMQ45knmYW","type":"tool_result","content":"     1→use std::fmt;\n     2→use std::str::FromStr;\n     3→\n     4→use chrono::{DateTime, Utc};\n     5→use serde::{Deserialize, Serialize};\n     6→\n     7→use crate::shared::error::{AppError, AppResult};\n     8→\n     9→pub const CURRENT_WORKSPACE_VERSION: u32 = 1;\n    10→\n    11→/// Canonical failure classes for stage contract evaluation and retry semantics.\n    12→#[derive(Debug, Clone, Copy, PartialEq, Eq, Hash, Serialize, Deserialize)]\n    13→#[serde(rename_all = \"snake_case\")]\n    14→pub enum FailureClass {\n    15→    TransportFailure,\n    16→    SchemaValidationFailure,\n    17→    DomainValidationFailure,\n    18→    Timeout,\n    19→    Cancellation,\n    20→    QaReviewOutcomeFailure,\n    21→}\n    22→\n    23→#[derive(Debug, Clone, Copy, PartialEq, Eq, Hash, Serialize, Deserialize)]\n    24→#[serde(rename_all = \"snake_case\")]\n    25→pub enum FlowPreset {\n    26→    Standard,\n    27→    QuickDev,\n    28→    DocsChange,\n    29→    CiImprovement,\n    30→}\n    31→\n    32→impl FlowPreset {\n    33→    pub const ALL: [Self; 4] = [\n    34→        Self::Standard,\n    35→        Self::QuickDev,\n    36→        Self::DocsChange,\n    37→        Self::CiImprovement,\n    38→    ];\n    39→\n    40→    pub fn all() -> &'static [Self] {\n    41→        &Self::ALL\n    42→    }\n    43→\n    44→    pub fn as_str(self) -> &'static str {\n    45→        match self {\n    46→            Self::Standard => \"standard\",\n    47→            Self::QuickDev => \"quick_dev\",\n    48→            Self::DocsChange => \"docs_change\",\n    49→            Self::CiImprovement => \"ci_improvement\",\n    50→        }\n    51→    }\n    52→\n    53→    pub fn description(self) -> &'static str {\n    54→        match self {\n    55→            Self::Standard => {\n    56→                \"Full delivery flow with planning, implementation, QA, review, and acceptance.\"\n    57→            }\n    58→            Self::QuickDev => \"Fast delivery flow for small code changes with lightweight review.\",\n    59→            Self::DocsChange => {\n    60→                \"Documentation-focused flow for planning, content updates, and validation.\"\n    61→            }\n    62→            Self::CiImprovement => {\n    63→                \"CI improvement flow for automation planning, updates, and validation.\"\n    64→            }\n    65→        }\n    66→    }\n    67→}\n    68→\n    69→impl fmt::Display for FlowPreset {\n    70→    fn fmt(&self, f: &mut fmt::Formatter<'_>) -> fmt::Result {\n    71→        f.write_str(self.as_str())\n    72→    }\n    73→}\n    74→\n    75→impl FromStr for FlowPreset {\n    76→    type Err = AppError;\n    77→\n    78→    fn from_str(value: &str) -> Result<Self, Self::Err> {\n    79→        match value {\n    80→            \"standard\" => Ok(Self::Standard),\n    81→            \"quick_dev\" => Ok(Self::QuickDev),\n    82→            \"docs_change\" => Ok(Self::DocsChange),\n    83→            \"ci_improvement\" => Ok(Self::CiImprovement),\n    84→            _ => Err(AppError::InvalidFlowPreset {\n    85→                flow_id: value.to_owned(),\n    86→            }),\n    87→        }\n    88→    }\n    89→}\n    90→\n    91→#[derive(Debug, Clone, Copy, PartialEq, Eq, Hash, Serialize, Deserialize)]\n    92→#[serde(rename_all = \"snake_case\")]\n    93→pub enum StageId {\n    94→    PromptReview,\n    95→    Planning,\n    96→    Implementation,\n    97→    Qa,\n    98→    Review,\n    99→    CompletionPanel,\n   100→    AcceptanceQa,\n   101→    FinalReview,\n   102→    PlanAndImplement,\n   103→    ApplyFixes,\n   104→    DocsPlan,\n   105→    DocsUpdate,\n   106→    DocsValidation,\n   107→    CiPlan,\n   108→    CiUpdate,\n   109→    CiValidation,\n   110→}\n   111→\n   112→impl StageId {\n   113→    pub const ALL: [Self; 16] = [\n   114→        Self::Prompt