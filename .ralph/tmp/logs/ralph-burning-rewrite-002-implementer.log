{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Nen6zrZ4eZ75efv1L1fh8A","type":"tool_result","content":"     1→#![forbid(unsafe_code)]\n     2→\n     3→use ralph_burning::contexts::workflow_composition::contracts::{\n     4→    all_contracts, contract_for_stage, ContractFamily,\n     5→};\n     6→use ralph_burning::contexts::workflow_composition::{built_in_flows, flow_definition};\n     7→use ralph_burning::shared::domain::{FailureClass, FlowPreset, StageId};\n     8→use ralph_burning::shared::error::ContractError;\n     9→use serde_json::json;\n    10→\n    11→// ── Helpers ─────────────────────────────────────────────────────────────────\n    12→\n    13→fn valid_planning_json() -> serde_json::Value {\n    14→    json!({\n    15→        \"problem_framing\": \"Implement stage contracts for the orchestrator.\",\n    16→        \"assumptions_or_open_questions\": [\"Schema coverage is exhaustive.\"],\n    17→        \"proposed_work\": [\n    18→            {\n    19→                \"order\": 1,\n    20→                \"summary\": \"Define payload types\",\n    21→                \"details\": \"Create typed structs for each contract family.\"\n    22→            }\n    23→        ],\n    24→        \"readiness\": {\n    25→            \"ready\": true,\n    26→            \"risks\": []\n    27→        }\n    28→    })\n    29→}\n    30→\n    31→fn valid_execution_json() -> serde_json::Value {\n    32→    json!({\n    33→        \"change_summary\": \"Added stage contract registry.\",\n    34→        \"steps\": [\n    35→            {\n    36→                \"order\": 1,\n    37→                \"description\": \"Created payloads module\",\n    38→                \"status\": \"completed\"\n    39→            }\n    40→        ],\n    41→        \"validation_evidence\": [\"cargo test passes\"],\n    42→        \"outstanding_risks\": []\n    43→    })\n    44→}\n    45→\n    46→fn valid_validation_approved_json() -> serde_json::Value {\n    47→    json!({\n    48→        \"outcome\": \"approved\",\n    49→        \"evidence\": [\"All tests pass.\"],\n    50→        \"findings_or_gaps\": [],\n    51→        \"follow_up_or_amendments\": []\n    52→    })\n    53→}\n    54→\n    55→fn valid_validation_rejected_json() -> serde_json::Value {\n    56→    json!({\n    57→        \"outcome\": \"rejected\",\n    58→        \"evidence\": [\"Tests fail on CI.\"],\n    59→        \"findings_or_gaps\": [\"Missing edge-case coverage.\"],\n    60→        \"follow_up_or_amendments\": [\"Add tests for empty inputs.\"]\n    61→    })\n    62→}\n    63→\n    64→// ── Registry completeness ───────────────────────────────────────────────────\n    65→\n    66→#[test]\n    67→fn every_stage_id_has_a_contract() {\n    68→    let contracts = all_contracts();\n    69→    assert_eq!(contracts.len(), StageId::ALL.len());\n    70→\n    71→    for &stage_id in &StageId::ALL {\n    72→        let contract = contract_for_stage(stage_id);\n    73→        assert_eq!(contract.stage_id, stage_id);\n    74→    }\n    75→}\n    76→\n    77→#[test]\n    78→fn every_stage_in_every_built_in_flow_has_contract_coverage() {\n    79→    for flow in built_in_flows() {\n    80→        for &stage_id in flow.stages {\n    81→            let contract = contract_for_stage(stage_id);\n    82→            assert_eq!(\n    83→                contract.stage_id, stage_id,\n    84→                \"stage {} in flow {} has no matching contract\",\n    85→                stage_id, flow.preset\n    86→            );\n    87→        }\n    88→    }\n    89→}\n    90→\n    91→#[test]\n    92→fn planning_stages_map_to_planning_family() {\n    93→    for stage_id in [\n    94→        StageId::PromptReview,\n    95→        StageId::Planning,\n    96→        StageId::DocsPlan,\n    97→        StageId::CiPlan,\n    98→    ] {\n    99→        assert_eq!(\n   100→            contract_for_stage(stage_id).family,\n   101→            ContractFamily::Planning,\n   102→            \"{stage_id} should be Planning family\"\n   103→        );\n   104→    }\n   105→}\n   106→\n   107→#[test]\n   108→fn execution_stages_map_to_execution_family() {\n   109→    for stage_id in [\n   110→        StageId::Implementation,\n   111→        StageId::PlanAndImplement,\n   112→        StageId::ApplyFixes,\n   113→        StageId::DocsUpdate,\n   114→        StageId::CiUpdate,\n   115→    ] {\n   116→        assert_eq!(\n   117→            contract_for_stage(stage_id).family,\n   118→            ContractFamily::Execution,\n   119→            \"{stage_id} should be Execution family\"\n   120→        );\n   121→    }\n   122→}\n   123→\n   124→#[test]\n   125→fn validation_stages_map_to_validation_family() {\n   126→    for stage_id in [\n   127→        StageId::Qa,\n   128→        StageId::DocsValidation,\n   129→        StageId::CiValidation,\n   130→        StageId::AcceptanceQa,\n   131→        StageId::Review,\n   132→        StageId::FinalReview,\n   133→        StageId::CompletionPanel,\n   134→    ] {\n   135→        assert_eq!(\n   136→            contract_for_stage(stage_id).family,\n   137→            ContractFamily::Validation,\n   138→            \"{stage_id} should be Validation family\"\n   139→        );\n   140→    }\n   141→}\n   142→\n   143→// ── Schema validation ───────────────────────────────────────────────────────\n   144→\n   145→#[test]\n   146→fn schema_failure_short_circuits_semantic_validation() {\n   147→    let contract = contract_for_stage(StageId::Planning);\n   148→    // Missing required fields → schema error, no domain error.\n   149→    let bad_json = json!({\"not_a_real_field\": true});\n   150→    let err = contract.evaluate(&bad_json).unwrap_err();\n   151→    assert!(\n   152→        matches!(err, ContractError::SchemaValidation { .. }),\n   153→        \"expected SchemaValidation, got: {err:?}\"\n   154→    );\n   155→    assert_eq!(err.failure_class(), FailureClass::SchemaValidationFailure);\n   156→}\n   157→\n   158→#[test]\n   159→fn schema_failure_short_circuits_rendering() {\n   160→    // An execution contract with invalid JSON should never reach the renderer.\n   161→    let contract = contract_for_stage(StageId::Implementation);\n   162→    let bad_json = json!(42);\n   163→    let err = contract.evaluate(&bad_json).unwrap_err();\n   164→    assert!(matches!(err, ContractError::SchemaValidation { .. }));\n   165→}\n   166→\n   167→// ── Semantic / domain validation ────────────────────────────────────────────\n   168→\n   169→#[test]\n   170→fn domain_failure_short_circuits_rendering() {\n   171→    let contract = contract_for_stage(StageId::Planning);\n   172→    // Schema-valid but domain-invalid: empty problem_framing.\n   173→    let json = json!({\n   174→        \"problem_framing\": \"   \",\n   175→        \"assumptions_or_open_questions\": [],\n   176→        \"proposed_work\": [],\n   177→        \"readiness\": { \"ready\": false, \"risks\": [] }\n   178→    });\n   179→    let err = contract.evaluate(&json).unwrap_err();\n   180→    assert!(\n   181→        matches!(err, ContractError::DomainValidation { .. }),\n   182→        \"expected DomainValidation, got: {err:?}\"\n   183→    );\n   184→    assert_eq!(\n   185→        err.failure_class(),\n   186→        FailureClass::DomainValidationFailure\n   187→    );\n   188→}\n   189→\n   190→#[test]\n   191→fn planning_rejects_zero_order_work_item() {\n   192→    let contract = contract_for_stage(StageId::Planning);\n   193→    let json = json!({\n   194→        \"problem_framing\": \"Valid framing.\",\n   195→        \"assumptions_or_open_questions\": [],\n   196→        \"proposed_work\": [\n   197→            { \"order\": 0, \"summary\": \"Bad order\", \"details\": \"\" }\n   198→        ],\n   199→        \"readiness\": { \"ready\": true, \"risks\": [] }\n   200→    });\n   201→    let err = contract.evaluate(&json).unwrap_err();\n   202→    assert!(matches!(err, ContractError::DomainValidation { .. }));\n   203→}\n   204→\n   205→#[test]\n   206→fn execution_rejects_empty_change_summary() {\n   207→    let contract = contract_for_stage(StageId::Implementation);\n   208→    let json = json!({\n   209→        \"change_summary\": \"\",\n   210→        \"steps\": [{ \"order\": 1, \"description\": \"step\", \"status\": \"completed\" }],\n   211→        \"validation_evidence\": [],\n   212→        \"outstanding_risks\": []\n   213→    });\n   214→    let err = contract.evaluate(&json).unwrap_err();\n   215→    assert!(matches!(err, ContractError::DomainValidation { .. }));\n   216→}\n   217→\n   218→#[test]\n   219→fn execution_rejects_empty_steps() {\n   220→    let contract = contract_for_stage(StageId::Implementation);\n   221→    let json = json!({\n   222→        \"change_summary\": \"Did things.\",\n   223→        \"steps\": [],\n   224→        \"validation_evidence\": [],\n   225→        \"outstanding_risks\": []\n   226→    });\n   227→    let err = contract.evaluate(&json).unwrap_err();\n   228→    assert!(matches!(err, ContractError::DomainValidation { .. }));\n   229→}\n   230→\n   231→#[test]\n   232→fn validation_rejects_non_passing_without_follow_up() {\n   233→    let contract = contract_for_stage(StageId::Review);\n   234→    let json = json!({\n   235→        \"outcome\": \"request_changes\",\n   236→        \"evidence\": [\"Some evidence.\"],\n   237→        \"findings_or_gaps\": [\"A gap.\"],\n   238→        \"follow_up_or_amendments\": []\n   239→    });\n   240→    let err = contract.evaluate(&json).unwrap_err();\n   241→    assert!(matches!(err, ContractError::DomainValidation { .. }));\n   242→}\n   243→\n   244→// ── Successful evaluation ───────────────────────────────────────────────────\n   245→\n   246→#[test]\n   247→fn planning_contract_evaluates_successfully() {\n   248→    let contract = contract_for_stage(StageId::Planning);\n   249→    let result = contract.evaluate(&valid_planning_json()).unwrap();\n   250→    assert!(result.outcome_failure.is_none());\n   251→    assert!(!result.bundle.artifact.is_empty());\n   252→    assert!(result.bundle.artifact.contains(\"# Planning\"));\n   253→}\n   254→\n   255→#[test]\n   256→fn execution_contract_evaluates_successfully() {\n   257→    let contract = contract_for_stage(StageId::Implementation);\n   258→    let result = contract.evaluate(&valid_execution_json()).unwrap();\n   259→    assert!(result.outcome_failure.is_none());\n   260→    assert!(result.bundle.artifact.contains(\"# Implementation\"));\n   261→}\n   262→\n   263→#[test]\n   264→fn validation_approved_evaluates_with_no_outcome_failure() {\n   265→    let contract = contract_for_stage(StageId::Review);\n   266→    let result = contract.evaluate(&valid_validation_approved_json()).unwrap();\n   267→    assert!(result.outcome_failure.is_none());\n   268→    assert!(result.bundle.artifact.contains(\"**Approved**\"));\n   269→}\n   270→\n   271→// ── QA/Review outcome failure mapping ───────────────────────────────────────\n   272→\n   273→#[test]\n   274→fn non_passing_review_maps_to_qa_review_outcome_failure() {\n   275→    let contract = contract_for_stage(StageId::Review);\n   276→    let result = contract.evaluate(&valid_validation_rejected_json()).unwrap();\n   277→    assert_eq!(\n   278→        result.outcome_failure,\n   279→        Some(FailureClass::QaReviewOutcomeFailure)\n   280→    );\n   281→    // Bundle is still returned — the payload is valid.\n   282→    assert!(result.bundle.artifact.contains(\"**Rejected**\"));\n   283→}\n   284→\n   285→#[test]\n   286→fn conditionally_approved_maps_to_qa_review_outcome_failure() {\n   287→    let contract = contract_for_stage(StageId::Qa);\n   288→    let json = json!({\n   289→        \"outcome\": \"conditionally_approved\",\n   290→        \"evidence\": [\"Mostly good.\"],\n   291→        \"findings_or_gaps\": [\"Minor issue.\"],\n   292→        \"follow_up_or_amendments\": [\"Fix minor issue.\"]\n   293→    });\n   294→    let result = contract.evaluate(&json).unwrap();\n   295→    assert_eq!(\n   296→        result.outcome_failure,\n   297→        Some(FailureClass::QaReviewOutcomeFailure)\n   298→    );\n   299→}\n   300→\n   301→// ── JSON Schema generation ──────────────────────────────────────────────────\n   302→\n   303→#[test]\n   304→fn json_schema_is_generated_for_each_family() {\n   305→    for &stage_id in &StageId::ALL {\n   306→        let contract = contract_for_stage(stage_id);\n   307→        let schema = contract.json_schema();\n   308→        // Schema must have a root schema object with definitions.\n   309→        assert!(\n   310→            schema.schema.metadata.is_some() || !schema.definitions.is_empty()\n   311→                || schema.schema.object.is_some()\n   312→                || schema.schema.subschemas.is_some(),\n   313→            \"schema for {stage_id} should have content\"\n   314→        );\n   315→    }\n   316→}\n   317→\n   318→// ── Conformance scenario IDs ────────────────────────────────────────────────\n   319→// These tests verify the scenario IDs referenced in\n   320→// tests/conformance/features/stage_contracts.feature\n   321→\n   322→#[test]\n   323→fn sc_eval_001_successful_planning_contract_evaluation() {\n   324→    let contract = contract_for_stage(StageId::Planning);\n   325→    let result = contract.evaluate(&valid_planning_json());\n   326→    assert!(result.is_ok());\n   327→    let success = result.unwrap();\n   328→    assert!(success.outcome_failure.is_none());\n   329→}\n   330→\n   331→#[test]\n   332→fn sc_eval_002_successful_execution_contract_evaluation() {\n   333→    let contract = contract_for_stage(StageId::Implementation);\n   334→    let result = contract.evaluate(&valid_execution_json());\n   335→    assert!(result.is_ok());\n   336→}\n   337→\n   338→#[test]\n   339→fn sc_eval_003_successful_validation_contract_evaluation() {\n   340→    let contract = contract_for_stage(StageId::Review);\n   341→    let result = contract.evaluate(&valid_validation_approved_json());\n   342→    assert!(result.is_ok());\n   343→    assert!(result.unwrap().outcome_failure.is_none());\n   344→}\n   345→\n   346→#[test]\n   347→fn sc_eval_004_schema_failure_prevents_semantic_validation() {\n   348→    let contract = contract_for_stage(StageId::Planning);\n   349→    let err = contract.evaluate(&json!({})).unwrap_err();\n   350→    assert!(matches!(err, ContractError::SchemaValidation { .. }));\n   351→}\n   352→\n   353→#[test]\n   354→fn sc_eval_005_domain_failure_prevents_rendering() {\n   355→    let contract = contract_for_stage(StageId::Implementation);\n   356→    let json = json!({\n   357→        \"change_summary\": \"   \",\n   358→        \"steps\": [],\n   359→        \"validation_evidence\": [],\n   360→        \"outstanding_risks\": []\n   361→    });\n   362→    let err = contract.evaluate(&json).unwrap_err();\n   363→    assert!(matches!(err, ContractError::DomainValidation { .. }));\n   364→}\n   365→\n   366→#[test]\n   367→fn sc_eval_006_qa_review_outcome_failure() {\n   368→    let contract = contract_for_stage(StageId::FinalReview);\n   369→    let json = json!({\n   370→        \"outcome\": \"rejected\",\n   371→        \"evidence\": [\"Fails acceptance.\"],\n   372→        \"findings_or_gaps\": [\"Critical gap.\"],\n   373→        \"follow_up_or_amendments\": [\"Rework needed.\"]\n   374→    });\n   375→    let result = contract.evaluate(&json).unwrap();\n   376→    assert_eq!(\n   377→        result.outcome_failure,\n   378→        Some(FailureClass::QaReviewOutcomeFailure)\n   379→    );\n   380→}\n   381→\n   382→// ── All flows have complete contract coverage ───────────────────────────────\n   383→\n   384→#[test]\n   385→fn sc_eval_007_all_presets_have_complete_contract_coverage() {\n   386→    for preset in FlowPreset::all() {\n   387→        let flow = flow_definition(*preset);\n   388→        for &stage_id in flow.stages {\n   389→            let _contract = contract_for_stage(stage_id);\n   390→            // No panic = contract exists.\n   391→        }\n   392→    }\n   393→}\n   394→"}]},"parent_tool_use_id":null,"session_id":"a43e306d-d21a-484c-9b37-70212164e32a","uuid":"e6b1c47c-f9e5-47be-b397-6a9f83ac9e2c","tool_use_result":{"type":"text","file":{"filePath":"/root/new-ralph-burning/ralph-burning-rewrite/tests/unit/stage_contract_test.rs","content":"#![forbid(unsafe_code)]\n\nuse ralph_burning::contexts::workflow_composition::contracts::{\n    all_contracts, contract_for_stage, ContractFamily,\n};\nuse ralph_burning::contexts::workflow_composition::{built_in_flows, flow_definition};\nuse ralph_burning::shared::domain::{FailureClass, FlowPreset, StageId};\nuse ralph_burning::shared::error::ContractError;\nuse serde_json::json;\n\n// ── Helpers ─────────────────────────────────────────────────────────────────\n\nfn valid_planning_json() -> serde_json::Value {\n    json!({\n        \"problem_framing\": \"Implement stage contracts for the orchestrator.\",\n        \"assumptions_or_open_questions\": [\"Schema coverage is exhaustive.\"],\n        \"proposed_work\": [\n            {\n                \"order\": 1,\n                \"summary\": \"Define payload types\",\n                \"details\": \"Create typed structs for each contract family.\"\n            }\n        ],\n        \"readiness\": {\n            \"ready\": true,\n            \"risks\": []\n        }\n    })\n}\n\nfn valid_execution_json() -> serde_json::Value {\n    json!({\n        \"change_summary\": \"Added stage contract registry.\",\n        \"steps\": [\n            {\n                \"order\": 1,\n                \"description\": \"Created payloads module\",\n                \"status\": \"completed\"\n            }\n        ],\n        \"validation_evidence\": [\"cargo test passes\"],\n        \"outstanding_risks\": []\n    })\n}\n\nfn valid_validation_approved_json() -> serde_json::Value {\n    json!({\n        \"outcome\": \"approved\",\n        \"evidence\": [\"All tests pass.\"],\n        \"findings_or_gaps\": [],\n        \"follow_up_or_amendments\": []\n    })\n}\n\nfn valid_validation_rejected_json() -> serde_json::Value {\n    json!({\n        \"outcome\": \"rejected\",\n        \"evidence\": [\"Tests fail on CI.\"],\n        \"findings_or_gaps\": [\"Missing edge-case coverage.\"],\n        \"follow_up_or_amendments\": [\"Add tests for empty inputs.\"]\n    })\n}\n\n// ── Registry completeness ───────────────────────────────────────────────────\n\n#[test]\nfn every_stage_id_has_a_contract() {\n    let contracts = all_contracts();\n    assert_eq!(contracts.len(), StageId::ALL.len());\n\n    for &stage_id in &StageId::ALL {\n        let contract = contract_for_stage(stage_id);\n        assert_eq!(contract.stage_id, stage_id);\n    }\n}\n\n#[test]\nfn every_stage_in_every_built_in_flow_has_contract_coverage() {\n    for flow in built_in_flows() {\n        for &stage_id in flow.stages {\n            let contract = contract_for_stage(stage_id);\n            assert_eq!(\n                contract.stage_id, stage_id,\n                \"stage {} in flow {} has no matching contract\",\n                stage_id, flow.preset\n            );\n        }\n    }\n}\n\n#[test]\nfn planning_stages_map_to_planning_family() {\n    for stage_id in [\n        StageId::PromptReview,\n        StageId::Planning,\n        StageId::DocsPlan,\n        StageId::CiPlan,\n    ] {\n        assert_eq!(\n            contract_for_stage(stage_id).family,\n            ContractFamily::Planning,\n            \"{stage_id} should be Planning family\"\n        );\n    }\n}\n\n#[test]\nfn execution_stages_map_to_execution_family() {\n    for stage_id in [\n        StageId::Implementation,\n        StageId::PlanAndImplement,\n        StageId::ApplyFixes,\n        StageId::DocsUpdate,\n        StageId::CiUpdate,\n    ] {\n        assert_eq!(\n            contract_for_stage(stage_id).family,\n            ContractFamily::Execution,\n            \"{stage_id} should be Execution family\"\n        );\n    }\n}\n\n#[test]\nfn validation_stages_map_to_validation_family() {\n    for stage_id in [\n        StageId::Qa,\n        StageId::DocsValidation,\n        StageId::CiValidation,\n        StageId::AcceptanceQa,\n        StageId::Review,\n        StageId::FinalReview,\n        StageId::CompletionPanel,\n    ] {\n        assert_eq!(\n            contract_for_stage(stage_id).family,\n            ContractFamily::Validation,\n            \"{stage_id} should be Validation family\"\n        );\n    }\n}\n\n// ── Schema validation ───────────────────────────────────────────────────────\n\n#[test]\nfn schema_failure_short_circuits_semantic_validation() {\n    let contract = contract_for_stage(StageId::Planning);\n    // Missing required fields → schema error, no domain error.\n    let bad_json = json!({\"not_a_real_field\": true});\n    let err = contract.evaluate(&bad_json).unwrap_err();\n    assert!(\n        matches!(err, ContractError::SchemaValidation { .. }),\n        \"expected SchemaValidation, got: {err:?}\"\n    );\n    assert_eq!(err.failure_class(), FailureClass::SchemaValidationFailure);\n}\n\n#[test]\nfn schema_failure_short_circuits_rendering() {\n    // An execution contract with invalid JSON should never reach the renderer.\n    let contract = contract_for_stage(StageId::Implementation);\n    let bad_json = json!(42);\n    let err = contract.evaluate(&bad_json).unwrap_err();\n    assert!(matches!(err, ContractError::SchemaValidation { .. }));\n}\n\n// ── Semantic / domain validation ────────────────────────────────────────────\n\n#[test]\nfn domain_failure_short_circuits_rendering() {\n    let contract = contract_for_stage(StageId::Planning);\n    // Schema-valid but domain-invalid: empty problem_framing.\n    let json = json!({\n        \"problem_framing\": \"   \",\n        \"assumptions_or_open_questions\": [],\n        \"proposed_work\": [],\n        \"readiness\": { \"ready\": false, \"risks\": [] }\n    });\n    let err = contract.evaluate(&json).unwrap_err();\n    assert!(\n        matches!(err, ContractError::DomainValidation { .. }),\n        \"expected DomainValidation, got: {err:?}\"\n    );\n    assert_eq!(\n        err.failure_class(),\n        FailureClass::DomainValidationFailure\n    );\n}\n\n#[test]\nfn planning_rejects_zero_order_work_item() {\n    let contract = contract_for_stage(StageId::Planning);\n    let json = json!({\n        \"problem_framing\": \"Valid framing.\",\n        \"assumptions_or_open_questions\": [],\n        \"proposed_work\": [\n            { \"order\": 0, \"summary\": \"Bad order\", \"details\": \"\" }\n        ],\n        \"readiness\": { \"ready\": true, \"risks\": [] }\n    });\n    let err = contract.evaluate(&json).unwrap_err();\n    assert!(matches!(err, ContractError::DomainValidation { .. }));\n}\n\n#[test]\nfn execution_rejects_empty_change_summary() {\n    let contract = contract_for_stage(StageId::Implementation);\n    let json = json!({\n        \"change_summary\": \"\",\n        \"steps\": [{ \"order\": 1, \"description\": \"step\", \"status\": \"completed\" }],\n        \"validation_evidence\": [],\n        \"outstanding_risks\": []\n    });\n    let err = contract.evaluate(&json).unwrap_err();\n    assert!(matches!(err, ContractError::DomainValidation { .. }));\n}\n\n#[test]\nfn execution_rejects_empty_steps() {\n    let contract = contract_for_stage(StageId::Implementation);\n    let json = json!({\n        \"change_summary\": \"Did things.\",\n        \"steps\": [],\n        \"validation_evidence\": [],\n        \"outstanding_risks\": []\n    });\n    let err = contract.evaluate(&json).unwrap_err();\n    assert!(matches!(err, ContractError::DomainValidation { .. }));\n}\n\n#[test]\nfn validation_rejects_non_passing_without_follow_up() {\n    let contract = contract_for_stage(StageId::Review);\n    let json = json!({\n        \"outcome\": \"request_changes\",\n        \"evidence\": [\"Some evidence.\"],\n        \"findings_or_gaps\": [\"A gap.\"],\n        \"follow_up_or_amendments\": []\n    });\n    let err = contract.evaluate(&json).unwrap_err();\n    assert!(matches!(err, ContractError::DomainValidation { .. }));\n}\n\n// ── Successful evaluation ───────────────────────────────────────────────────\n\n#[test]\nfn planning_contract_evaluates_successfully() {\n    let contract = contract_for_stage(StageId::Planning);\n    let result = contract.evaluate(&valid_planning_json()).unwrap();\n    assert!(result.outcome_failure.is_none());\n    assert!(!result.bundle.artifact.is_empty());\n    assert!(result.bundle.artifact.contains(\"# Planning\"));\n}\n\n#[test]\nfn execution_contract_evaluates_successfully() {\n    let contract = contract_for_stage(StageId::Implementation);\n    let result = contract.evaluate(&valid_execution_json()).unwrap();\n    assert!(result.outcome_failure.is_none());\n    assert!(result.bundle.artifact.contains(\"# Implementation\"));\n}\n\n#[test]\nfn validation_approved_evaluates_with_no_outcome_failure() {\n    let contract = contract_for_stage(StageId::Review);\n    let result = contract.evaluate(&valid_validation_approved_json()).unwrap();\n    assert!(result.outcome_failure.is_none());\n    assert!(result.bundle.artifact.contains(\"**Approved**\"));\n}\n\n// ── QA/Review outcome failure mapping ───────────────────────────────────────\n\n#[test]\nfn non_passing_review_maps_to_qa_review_outcome_failure() {\n    let contract = contract_for_stage(StageId::Review);\n    let result = contract.evaluate(&valid_validation_rejected_json()).unwrap();\n    assert_eq!(\n        result.outcome_failure,\n        Some(FailureClass::QaReviewOutcomeFailure)\n    );\n    // Bundle is still returned — the payload is valid.\n    assert!(result.bundle.artifact.contains(\"**Rejected**\"));\n}\n\n#[test]\nfn conditionally_approved_maps_to_qa_review_outcome_failure() {\n    let contract = contract_for_stage(StageId::Qa);\n    let json = json!({\n        \"outcome\": \"conditionally_approved\",\n        \"evidence\": [\"Mostly good.\"],\n        \"findings_or_gaps\": [\"Minor issue.\"],\n        \"follow_up_or_amendments\": [\"Fix minor issue.\"]\n    });\n    let result = contract.evaluate(&json).unwrap();\n    assert_eq!(\n        result.outcome_failure,\n        Some(FailureClass::QaReviewOutcomeFailure)\n    );\n}\n\n// ── JSON Schema generation ──────────────────────────────────────────────────\n\n#[test]\nfn json_schema_is_generated_for_each_family() {\n    for &stage_id in &StageId::ALL {\n        let contract = contract_for_stage(stage_id);\n        let schema = contract.json_schema();\n        // Schema must have a root schema object with definitions.\n        assert!(\n            schema.schema.metadata.is_some() || !schema.definitions.is_empty()\n                || schema.schema.object.is_some()\n                || schema.schema.subschemas.is_some(),\n            \"schema for {stage_id} should have content\"\n        );\n    }\n}\n\n// ── Conformance scenario IDs ────────────────────────────────────────────────\n// These tests verify the scenario IDs referenced in\n// tests/conformance/features/stage_contracts.feature\n\n#[test]\nfn sc_eval_001_successful_planning_contract_evaluation() {\n    let contract = contract_for_stage(StageId::Planning);\n    let result = contract.evaluate(&valid_planning_json());\n    assert!(result.is_ok());\n    let success = result.unwrap();\n    assert!(success.outcome_failure.is_none());\n}\n\n#[test]\nfn sc_eval_002_successful_execution_contract_evaluation() {\n    let contract = contract_for_stage(StageId::Implementation);\n    let result = contract.evaluate(&valid_execution_json());\n    assert!(result.is_ok());\n}\n\n#[test]\nfn sc_eval_003_successful_validation_contract_evaluation() {\n    let contract = contract_for_stage(StageId::Review);\n    let result = contract.evaluate(&valid_validation_approved_json());\n    assert!(result.is_ok());\n    assert!(result.unwrap().outcome_failure.is_none());\n}\n\n#[test]\nfn sc_eval_004_schema_failure_prevents_semantic_validation() {\n    let contract = contract_for_stage(StageId::Planning);\n    let err = contract.evaluate(&json!({})).unwrap_err();\n    assert!(matches!(err, ContractError::SchemaValidation { .. }));\n}\n\n#[test]\nfn sc_eval_005_domain_failure_prevents_rendering() {\n    let contract = contract_for_stage(StageId::Implementation);\n    let json = json!({\n        \"change_summary\": \"   \",\n        \"steps\": [],\n        \"validation_evidence\": [],\n        \"outstanding_risks\": []\n    });\n    let err = contract.evaluate(&json).unwrap_err();\n    assert!(matches!(err, ContractError::DomainValidation { .. }));\n}\n\n#[test]\nfn sc_eval_006_qa_review_outcome_failure() {\n    let contract = contract_for_stage(StageId::FinalReview);\n    let json = json!({\n        \"outcome\": \"rejected\",\n        \"evidence\": [\"Fails acceptance.\"],\n        \"findings_or_gaps\": [\"Critical gap.\"],\n        \"follow_up_or_amendments\": [\"Rework needed.\"]\n    });\n    let result = contract.evaluate(&json).unwrap();\n    assert_eq!(\n        result.outcome_failure,\n        Some(FailureClass::QaReviewOutcomeFailure)\n    );\n}\n\n// ── All flows have complete contract coverage ───────────────────────────────\n\n#[test]\nfn sc_eval_007_all_presets_have_complete_contract_coverage() {\n    for preset in FlowPreset::all() {\n        let flow = flow_definition(*preset);\n        for &stage_id in flow.stages {\n            let _contract = contract_for_stage(stage_id);\n            // No panic = contract exists.\n        }\n    }\n}\n","numLines":394,"startLine":1,"totalLines":394}}}
