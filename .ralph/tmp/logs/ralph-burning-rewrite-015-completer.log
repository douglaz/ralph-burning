{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Tp82BrUUNd6ENiNmbv42V1","type":"tool_result","content":"     1→use std::collections::HashSet;\n     2→use std::path::Path;\n     3→\n     4→use crate::shared::error::{AppError, AppResult};\n     5→\n     6→use super::model::{IdSource, ScenarioKind, ScenarioMeta};\n     7→\n     8→/// Compile-time path to the conformance feature directory.\n     9→const FEATURES_DIR: &str = concat!(env!(\"CARGO_MANIFEST_DIR\"), \"/tests/conformance/features\");\n    10→\n    11→/// Returns the path to the conformance features directory.\n    12→pub fn features_dir() -> &'static Path {\n    13→    Path::new(FEATURES_DIR)\n    14→}\n    15→\n    16→/// Discover all conformance scenarios from `.feature` files.\n    17→///\n    18→/// Returns scenarios in deterministic order: feature files sorted by path,\n    19→/// then scenarios in file order.\n    20→///\n    21→/// Respects the `RALPH_BURNING_TEST_FEATURES_DIR` environment variable to\n    22→/// allow tests to point discovery at an isolated feature directory instead\n    23→/// of the checked-in corpus.\n    24→pub fn discover_scenarios() -> AppResult<Vec<ScenarioMeta>> {\n    25→    let dir = match std::env::var(\"RALPH_BURNING_TEST_FEATURES_DIR\") {\n    26→        Ok(override_dir) if !override_dir.is_empty() => {\n    27→            std::path::PathBuf::from(override_dir)\n    28→        }\n    29→        _ => features_dir().to_path_buf(),\n    30→    };\n    31→    discover_scenarios_from(&dir)\n    32→}\n    33→\n    34→/// Discover scenarios from a specific features directory (testable).\n    35→pub fn discover_scenarios_from(dir: &Path) -> AppResult<Vec<ScenarioMeta>> {\n    36→    if !dir.is_dir() {\n    37→        return Err(AppError::ConformanceDiscoveryFailed {\n    38→            details: format!(\"features directory not found: {}\", dir.display()),\n    39→        });\n    40→    }\n    41→\n    42→    let mut feature_files: Vec<_> = std::fs::read_dir(dir)\n    43→        .map_err(|e| AppError::ConformanceDiscoveryFailed {\n    44→            details: format!(\"cannot read features directory: {e}\"),\n    45→        })?\n    46→        .filter_map(|entry| {\n    47→            let entry = entry.ok()?;\n    48→            let path = entry.path();\n    49→            if path.extension().map_or(false, |ext| ext == \"feature\") {\n    50→                Some(path)\n    51→            } else {\n    52→                None\n    53→            }\n    54→        })\n    55→        .collect();\n    56→\n    57→    feature_files.sort();\n    58→\n    59→    let mut all_scenarios = Vec::new();\n    60→\n    61→    for file_path in &feature_files {\n    62→        let content = std::fs::read_to_string(file_path).map_err(|e| {\n    63→            AppError::ConformanceDiscoveryFailed {\n    64→                details: format!(\"cannot read {}: {e}\", file_path.display()),\n    65→            }\n    66→        })?;\n    67→        let file_name = file_path\n    68→            .file_name()\n    69→            .unwrap_or_default()\n    70→            .to_string_lossy()\n    71→            .to_string();\n    72→        let scenarios = parse_feature_file(&content, &file_name)?;\n    73→        all_scenarios.extend(scenarios);\n    74→    }\n    75→\n    76→    if all_scenarios.is_empty() {\n    77→        return Err(AppError::ConformanceDiscoveryFailed {\n    78→            details: \"no scenarios discovered from feature files\".to_owned(),\n    79→        });\n    80→    }\n    81→\n    82→    Ok(all_scenarios)\n    83→}\n    84→\n    85→/// Validate that all discovered scenario IDs are unique and well-formed.\n    86→pub fn validate_ids(scenarios: &[ScenarioMeta]) -> AppResult<()> {\n    87→    let mut seen = HashSet::new();\n    88→\n    89→    for scenario in scenarios {\n    90→        // Validate ID format: non-empty, no whitespace\n    91→        if scenario.id.is_empty() {\n    92→            return Err(AppError::ConformanceParseFailed {\n    93→                file: scenario.source_file.clone(),\n    94→                line: scenario.source_line,\n    95→                details: \"scenario ID is empty\".to_owned(),\n    96→            });\n    97→        }\n    98→\n    99→        if scenario.id.chars().any(|c| c.is_whitespace()) {\n   100→            return Err(AppError::ConformanceParseFailed {\n   101→                file: scenario.source_file.clone(),\n   102→                line: scenario.source_line,\n   103→                details: format!(\"scenario ID '{}' contains whitespace\", scenario.id),\n   104→            });\n   105→        }\n   106→\n   107→        // Check for duplicates\n   108→        if !seen.insert(&scenario.id) {\n   109→            return Err(AppError::ConformanceParseFailed {\n   110→                file: scenario.source_file.clone(),\n   111→                line: scenario.source_line,\n   112→                details: format!(\"duplicate scenario ID '{}'\", scenario.id),\n   113→            });\n   114→        }\n   115→    }\n   116→\n   117→    Ok(())\n   118→}\n   119→\n   120→/// Parse a single `.feature` file and extract scenario metadata.\n   121→fn parse_feature_file(content: &str, file_name: &str) -> AppResult<Vec<ScenarioMeta>> {\n   122→    let lines: Vec<&str> = content.lines().collect();\n   123→    let mut scenarios = Vec::new();\n   124→    let mut feature_title = String::new();\n   125→\n   126→    // Find the Feature: line\n   127→    for line in &lines {\n   128→        let trimmed = line.trim();\n   129→        if let Some(title) = trimmed.strip_prefix(\"Feature:\") {\n   130→            feature_title = title.trim().to_owned();\n   131→            break;\n   132→        }\n   133→    }\n   134→\n   135→    if feature_title.is_empty() {\n   136→        return Err(AppError::ConformanceParseFailed {\n   137→            file: file_name.to_owned(),\n   138→            line: 1,\n   139→            details: \"no Feature: line found\".to_owned(),\n   140→        });\n   141→    }\n   142→\n   143→    // Scan for Scenario: and Scenario Outline: lines\n   144→    for (idx, line) in lines.iter().enumerate() {\n   145→        let trimmed = line.trim();\n   146→        let line_number = idx + 1; // 1-indexed\n   147→\n   148→        let (kind, title) = if let Some(rest) = trimmed.strip_prefix(\"Scenario Outline:\") {\n   149→            (ScenarioKind::ScenarioOutline, rest.trim().to_owned())\n   150→        } else if let Some(rest) = trimmed.strip_prefix(\"Scenario:\") {\n   151→            (ScenarioKind::Scenario, rest.trim().to_owned())\n   152→        } else {\n   153→            continue;\n   154→        };\n   155→\n   156→        // Extract ID from preceding line(s)\n   157→        let (id, id_source) = extract_scenario_id(&lines, idx).ok_or_else(|| {\n   158→            AppError::ConformanceParseFailed {\n   159→                file: file_name.to_owned(),\n   160→                line: line_number,\n   161→                details: format!(\n   162→                    \"scenario '{}' has no ID (expected a # <id> comment or @<tag> on preceding line)\",\n   163→                    title\n   164→                ),\n   165→            }\n   166→        })?;\n   167→\n   168→        scenarios.push(ScenarioMeta {\n   169→            id,\n   170→            feature_title: feature_title.clone(),\n   171→            scenario_title: title,\n   172→            source_file: file_name.to_owned(),\n   173→            source_line: line_number,\n   174→            kind,\n   175→            id_source,\n   176→        });\n   177→    }\n   178→\n   179→    Ok(scenarios)\n   180→}\n   181→\n   182→/// Extract a scenario ID from the line(s) preceding a Scenario/Scenario Outline.\n   183→///\n   184→/// Preference order:\n   185→/// 1. A `# <scenario-id>` comment on the immediately preceding line\n   186→/// 2. A scenario-level `@<tag>` on the immediately preceding line\n   187→///\n   188→/// Feature-level tags (before the Feature: line) are NOT used as scenario IDs.\n   189→fn extract_scenario_id(lines: &[&str], scenario_line_idx: usize) -> Option<(String, IdSource)> {\n   190→    if scenario_line_idx == 0 {\n   191→        return None;\n   192→    }\n   193→\n   194→    let prev_line = lines[scenario_line_idx - 1].trim();\n   195→\n   196→    // Check for `# <scenario-id>` comment\n   197→    if let Some(rest) = prev_line.strip_prefix('#') {\n   198→        let id = rest.trim();\n   199→        if !id.is_empty() && !id.contains(' ') {\n   200→            return Some((id.to_owned(), IdSource::Comment));\n   201→        }\n   202→    }\n   203→\n   204→    // Check for `@<tag>` (scenario-level tag)\n   205→    if let Some(rest) = prev_line.strip_prefix('@') {\n   206→        let tag = rest.trim();\n   207→        if !tag.is_empty() && !tag.contains(' ') {\n   208→            return Some((tag.to_owned(), IdSource::Tag));\n   209→        }\n   210→    }\n   211→\n   212→    None\n   213→}\n   214→"}]},"parent_tool_use_id":"toolu_01Dr7L17oHNzJDJZ2NjoGq1U","session_id":"2cdec833-d9a4-4fe7-8fdf-432611cd39d7","uuid":"ad7f7fda-c8c4-48ce-9a22-8b653b96ef04"}
