{"type":"item.completed","item":{"id":"item_11","type":"command_execution","command":"/run/current-system/sw/bin/bash -lc \"sed -n '1,260p' /root/new-ralph-burning/ralph-burning-rewrite/src/main.rs && printf '\\\\n---LIB---\\\\n' && sed -n '1,260p' /root/new-ralph-burning/ralph-burning-rewrite/src/lib.rs\"","aggregated_output":"#![forbid(unsafe_code)]\n\nuse std::process::ExitCode;\n\nuse clap::Parser;\nuse ralph_burning::cli::{self, Cli};\n\n#[tokio::main(flavor = \"multi_thread\")]\nasync fn main() -> ExitCode {\n    init_tracing();\n\n    let cli = Cli::parse();\n\n    match cli::run(cli).await {\n        Ok(()) => ExitCode::SUCCESS,\n        Err(error) => {\n            eprintln!(\"{error}\");\n            ExitCode::FAILURE\n        }\n    }\n}\n\nfn init_tracing() {\n    let _ = tracing_subscriber::fmt()\n        .compact()\n        .with_target(false)\n        .without_time()\n        .try_init();\n}\n\n---LIB---\n#![forbid(unsafe_code)]\n\npub mod adapters;\npub mod cli;\npub mod contexts;\npub mod shared;\n","exit_code":0,"status":"completed"}}
