tate { run_id: String, details: String },\n   122→    #[error(\"answer validation failed for run '{run_id}': {details}\")]\n   123→    AnswerValidationFailed { run_id: String, details: String },\n   124→    #[error(\"seed persistence failed for run '{run_id}': {details}\")]\n   125→    SeedPersistenceFailed { run_id: String, details: String },\n   126→    #[error(\"remediation exhausted at cycle {cycle}; maximum supported cycles is {max}\")]\n   127→    RemediationExhausted { cycle: u32, max: u32 },\n   128→    #[error(\"amendment queue error: {details}\")]\n   129→    AmendmentQueueError { details: String },\n   130→    #[error(\"completion blocked: {details}\")]\n   131→    CompletionBlocked { details: String },\n   132→    #[error(\"completion guard snapshot commit failed: {details}\")]\n   133→    CompletionGuardSnapshotFailed { details: String },\n   134→    #[error(\"routing resolution failed for '{input}': {details}\")]\n   135→    RoutingResolutionFailed { input: String, details: String },\n   136→    #[error(\"ambiguous routing labels resolved to multiple flows: {labels:?}\")]\n   137→    AmbiguousRouting { labels: Vec<String> },\n   138→    #[error(\"task for issue '{issue_ref}' already exists with non-terminal status\")]\n   139→    DuplicateTaskForIssue { issue_ref: String },\n   140→    #[error(\"project writer lock is already held for '{project_id}'\")]\n   141→    ProjectWriterLockHeld { project_id: String },\n   142→    #[error(\"failed to create worktree for task '{task_id}': {details}\")]\n   143→    WorktreeCreationFailed { task_id: String, details: String },\n   144→    #[error(\"failed to remove worktree for task '{task_id}': {details}\")]\n   145→    WorktreeRemovalFailed { task_id: String, details: String },\n   146→    #[error(\"lease '{lease_id}' is stale\")]\n   147→    LeaseStale { lease_id: String },\n   148→    #[error(\"invalid task state transition for '{task_id}': {from} -> {to}\")]\n   149→    TaskStateTransitionInvalid {\n   150→   