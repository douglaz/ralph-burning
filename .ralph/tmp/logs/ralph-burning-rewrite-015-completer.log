ail { logs } => handle_tail(logs).await,\n    48→        RunSubcommand::Start => handle_start().await,\n    49→        RunSubcommand::Resume => handle_resume().await,\n    50→        RunSubcommand::Rollback { to, hard } => handle_rollback(to, hard).await,\n    51→    }\n    52→}\n    53→\n    54→pub fn build_agent_execution_service(\n    55→) -> AgentExecutionService<StubBackendAdapter, FsRawOutputStore, FsSessionStore> {\n    56→    let mut adapter = StubBackendAdapter::default();\n    57→\n    58→    // Test-only injection seam: environment variables configure the stub backend\n    59→    // to simulate failure modes that aren't reachable through normal CLI usage.\n    60→    if std::env::var(\"RALPH_BURNING_TEST_BACKEND_UNAVAILABLE\").is_ok() {\n    61→        adapter = adapter.unavailable();\n    62→    }\n    63→    if let Ok(stage_str) = std::env::var(\"RALPH_BURNING_TEST_FAIL_INVOKE_STAGE\") {\n    64→        if let Ok(stage_id) = stage_str.parse::<StageId>() {\n    65→            adapter = adapter.with_invoke_failure(stage_id);\n    66→        }\n    67→    }\n    68→    // Test-only seam: configure a stage to fail the first N invocations, then succeed.\n    69→    // Format: \"stage_id:count\" e.g. \"implementation:1\"\n    70→    if let Ok(spec) = std::env::var(\"RALPH_BURNING_TEST_TRANSIENT_FAILURE\") {\n    71→        if let Some((stage_str, count_str)) = spec.split_once(':') {\n    72→            if let (Ok(stage_id), Ok(count)) = (stage_str.parse::<StageId>(), count_str.parse::<u32>()) {\n    73→                adapter = adapter.with_transient_failure(stage_id, count);\n    74→            }\n    75→        }\n    76→    }\n    77→    // Test-only seam: JSON map from stage-id string to payload JSON.\n    78→    // Values may be a single object or an array of objects (payload sequence).\n    79→    // Example: {\"completion_panel\": {\"outcome\":\"conditionally_approved\",...}}\n    80→    // Example sequence: {\"qa\": [{\"outcome\":\"request_changes\",...}, {\"outcome\":\"approved\",...}]}\n    81→    if let Ok(overrides_json) = std::env::var(\"RALPH_BURNING_TEST_STAGE_OVERRIDES\") {\n    82→        if let Ok(overrides) =\n    83→            serde_json::from_str::<std::collections::HashMap<String, serde_json::Value>>(\n    84→                &overrides_json,\n    85→            )\n    86→        {\n    87→            for (stage_str, payload) in overrides {\n    88→                if let Ok(stage_id) = stage_str.parse::<StageId>() {\n    89→                    if let Some(arr) = payload.as_array() {\n    90→                        adapter = adapter.with_stage_payload_sequence(stage_id, arr.clone());\n    91→                    } else {\n    92→                        adapter = adapter.with_stage_payload(stage_id, payload);\n    93→                    }\n    94→                }\n    95→            }\n    96→        }\n    97→    }\n    98→\n    99→    AgentExecutionService::new(adapter, FsRawOutputStore, FsSessionStore)\n   100→}\n   101→\n   102→async fn handle_start() -> AppResult<()> {\n   103→    let current_dir = std::env::current_dir()?;\n   104→\n   105→    // Validate workspace version\n   106→    let config = workspace_governance::load_workspace_config(&current_dir)?;\n   107→    workspace_governance::ensure_supported_workspace_version(&config)?;\n   108→\n   109→    // Resolve active project\n   110→    let project_id = workspace_governance::resolve_active_project(&current_dir)?;\n   111→\n   112→    // Validate canonical project record\n   113→    let project_store = FsProjectStore;\n   114→    let project_record = project_store.read_project_record(&current_dir, &project_id)?;\n   115→\n   116→    // Validate run snapshot integrity\n   117→    let run_snapshot_read = FsRunSnapshotStore;\n   118→    let run_snapshot = run_snapshot_read.read_run_snapshot(&current_dir, &project_id)?;\n   119→\n   120→    // Check preconditions before engine call (fail fast with clear errors)\n   121→    match run_snapshot.status {\n   122→        RunStatus::NotStarted => {}\n   123→        RunStatus::Failed | RunStatus::Paused => {\n   124→            return Err(AppError::RunStartFailed {\n   125→                reason: format!(\n   126→                    \"project snapshot status is '{}'; use `ralph-burning run resume`\",\n   127→                    run_snapshot.status\n   128→                ),\n   129→            });\n   130→        }\n   131→        status => {\n   132→            return Err(AppError::RunStartFailed {\n   133→                reason: format!(\n   134→                    \"project snapshot status is '{}'; run start requires 'not_started'\",\n   135→                    status\n   136→                ),\n   137→            });\n   138→        }\n   139→    }\n   140→    if run_snapshot.has_active_run() {\n   141→        return Err(AppError::RunStartFailed {\n   142→            reason: \"project already has an active run\".to_owned(),\n   143→        });\n   144→    }\n   145→\n   146→    let effective_config = EffectiveConfig::load(&current_dir)?;\n   147→\n   148→    let agent_service = build_agent_execution_service();\n   149→    let run_snapshot_write = FsRunSnapshotWriteStore;\n   150→    let journal_store = FsJournalStore;\n   151→    let artifact_write = FsPayloadArtifactWriteStore;\n   152→    let log_write = FsRuntimeLogWriteStore;\n   153→\n   154→    println!(\"Starting run for project '{}'...\", project_id);\n   155→\n   156→    let amendment_queue = FsAmendmentQueueStore;\n   157→\n   158→    engine::execute_run(\n   159→        &agent_service,\n   160→        &run_snapshot_read,\n   161→        &run_snapshot_write,\n   162→        &journal_store,\n   163→        &artifact_write,\n   164→        &log_write,\n   165→        &amendment_queue,\n   166→        &current_dir,\n   167→        &project_id,\n   168→        project_record.flow,\n   169→        &effective_config,\n   170→    )\n   171→    .await?;\n   172→\n   173→    let final_snapshot = run_snapshot_read.read_run_snapshot(&current_dir, &project_id)?;\n   174→    match final_snapshot.status {\n   175→        RunStatus::Completed => println!(\"Run completed successfully.\"),\n   176→        RunStatus::Paused => println!(\"{}\", final_snapshot.status_summary),\n   177→        status => println!(\"Run finished with status '{}'.\", status),\n   178→    }\n   179→    Ok(())\n   180→}\n   181→\n   182→async fn handle_resume() -> AppResult<()> {\n   183→    let current_dir = std::env::current_dir()?;\n   184→\n   185→    let config = workspace_governance::load_workspace_config(&current_dir)?;\n   186→    workspace_governance::ensure_supported_workspace_version(&config)?;\n   187→\n   188→    let project_id = workspace_governance::resolve_active_project(&current_dir)?;\n   189→\n   190→    let project_store = FsProjectStore;\n   191→    let project_record = project_store.read_project_record(&current_dir, &project_id)?;\n   192→    let run_snapshot_read = FsRunSnapshotStore;\n   193→    let run_snapshot = run_snapshot_read.read_run_snapshot(&current_dir, &project_id)?;\n   194→    match run_snapshot.status {\n   195→        RunStatus::Failed | RunStatus::Paused => {}\n   196→        RunStatus::NotStarted => {\n   197→            return Err(AppError::ResumeFailed {\n   198→                reason: \"project has not started a run yet; use `ralph-burning run start`\"\n   199→                    .to_owned(),\n   200→            });\n   201→        }\n   202→        RunStatus::Running => {\n   203→            return Err(AppError::ResumeFailed {\n   204→                reason: \"project already has a running run; `run resume` only works from failed or paused snapshots\".to_owned(),\n   205→            });\n   206→        }\n   207→        RunStatus::Completed => {\n   208→            return Err(AppError::ResumeFailed {\n   209→                reason: \"project is already completed; there is nothing to resume\".to_owned(),\n   210→            });\n   211→        }\n   212→    }\n   213→    if run_snapshot.has_active_run() {\n   214→        return Err(AppError::ResumeFailed {\n   215→            reason: \"failed or paused snapshots must not retain an active run\".to_owned(),\n   216→        });\n   217→    }\n   218→\n   219→    let effective_config = EffectiveConfig::load(&current_dir)?;\n   220→    let agent_service = build_agent_execution_service();\n   221→    let run_snapshot_write = FsRunSnapshotWriteStore;\n   222→    let journal_store = FsJournalStore;\n   223→    let artifact_write = FsPayloadArtifactWriteStore;\n   224→    let log_write = FsRuntimeLogWriteStore;\n   225→\n   226→    println!(\"Resuming run for project '{}'...\", project_id);\n   227→\n   228→    let amendment_queue = FsAmendmentQueueStore;\n   229→\n   230→    engine::resume_run(\n   231→        &agent_service,\n   232→        &run_snapshot_read,\n   233→        &run_snapshot_write,\n   234→        &journal_store,\n   235→        &FsArtifactStore,\n   236→        &artifact_write,\n   237→        &log_write,\n   238→        &amendment_queue,\n   239→        &current_dir,\n   240→        &project_id,\n   241→        project_record.flow,\n   242→        &effective_config,\n   243→    )\n   244→    .await?;\n   245→\n   246→    let final_snapshot = run_snapshot_read.read_run_snapshot(&current_dir, &project_id)?;\n   247→    match final_snapshot.status {\n   248→        RunStatus::Completed => println!(\"Run completed successfully.\"),\n   249→        RunStatus::Paused => println!(\"{}\", final_snapshot.status_summary),\n   250→        status => println!(\"Run finished with status '{}'.\", status),\n   251→    }\n   252→\n   253→    Ok(())\n   254→}\n   255→\n   256→async fn handle_status() -> AppResult<()> {\n   257→    let current_dir = std::env::current_dir()?;\n   258→\n   259→    let config = workspace_governance::load_workspace_config(&current_dir)?;\n   260→    workspace_governance::ensure_supported_workspace_version(&config)?;\n   261→\n   262→    let project_id = workspace_governance::resolve_active_project(&current_dir)?;\n   263→\n   264→    // Validate canonical project record before proceeding with run queries\n   265→    let project_store = FsProjectStore;\n   266→    let _ = project_store.read_project_record(&current_dir, &project_id)?;\n   267→\n   268→    let run_store = FsRunSnapshotStore;\n   269→    let status = service::run_status(&run_store, &current_dir, &project_id)?;\n   270→\n   271→    println!(\"Project: {}\", status.project_id);\n   272→    println!(\"Status: {}\", status.status);\n   273→    if let Some(ref stage) = status.stage {\n   274→        println!(\"Stage: {}\", stage);\n   275→    }\n   276→    if let Some(cycle) = status.cycle {\n   277→        println!(\"Cycle: {}\", cycle);\n   278→    }\n   279→    if let Some(round) = status.completion_round {\n   280→        println!(\"Completion round: {}\", round);\n   281→    }\n   282→    println!(\"Summary: {}\", status.summary);\n   283→\n   284→    Ok(())\n   285→}\n   286→\n   287→async fn handle_history() -> AppResult<()> {\n   288→    let current_dir = std::env::current_dir()?;\n   289→\n   290→    let config = workspace_governance::load_workspace_config(&current_dir)?;\n   291→    workspace_governance::ensure_supported_workspace_version(&config)?;\n   292→\n   293→    let project_id = workspace_governance::resolve_active_project(&current_dir)?;\n   294→\n   295→    // Validate canonical project record before proceeding with run queries\n   296→    let project_store = FsProjectStore;\n   297→    let _ = project_store.read_project_record(&current_dir, &project_id)?;\n   298→\n   299→    let journal_store = FsJournalStore;\n   300→    let artifact_store = FsArtifactStore;\n   301→\n   302→    let history = service::run_history(&journal_store, &artifact_store, &current_dir, &project_id)?;\n   303→\n   304→    println!(\"Project: {}\", history.project_id);\n   305→    println!(\"--- Journal Events ---\");\n   306→    for event in &history.even