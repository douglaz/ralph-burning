lt;\n        };\n\n        devShells.default = pkgs.mkShell {\n          packages = with pkgs; [\n            cargo\n            rustc\n            rustfmt\n            clippy\n            rust-analyzer\n            git\n            gh\n            jq\n          ];\n\n          RUST_SRC_PATH = \"${pkgs.rustPlatform.rustLibSrc}\";\n        };\n      });\n}\n","exit_code":0,"status":"completed"}}
