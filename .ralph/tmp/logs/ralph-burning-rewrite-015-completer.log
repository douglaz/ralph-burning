{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01UcvggQjXWvPMPECbRTBrrC","type":"tool_result","content":"     1→use clap::{Args, Subcommand};\n     2→\n     3→use crate::adapters::fs::{\n     4→    FsAmendmentQueueStore, FsArtifactStore, FsJournalStore, FsPayloadArtifactWriteStore,\n     5→    FsProjectStore, FsRawOutputStore, FsRollbackPointStore, FsRunSnapshotStore,\n     6→    FsRunSnapshotWriteStore, FsRuntimeLogStore, FsRuntimeLogWriteStore, FsSessionStore,\n     7→};\n     8→use crate::adapters::stub_backend::StubBackendAdapter;\n     9→use crate::adapters::worktree::WorktreeAdapter;\n    10→use crate::contexts::agent_execution::service::AgentExecutionService;\n    11→use crate::contexts::project_run_record::model::RunStatus;\n    12→use crate::contexts::project_run_record::service::{self, ProjectStorePort, RunSnapshotPort};\n    13→use crate::contexts::workflow_composition::engine;\n    14→use crate::contexts::workspace_governance;\n    15→use crate::contexts::workspace_governance::config::EffectiveConfig;\n    16→use crate::shared::domain::StageId;\n    17→use crate::shared::error::{AppError, AppResult};\n    18→\n    19→#[derive(Debug, Args)]\n    20→pub struct RunCommand {\n    21→    #[command(subcommand)]\n    22→    pub command: RunSubcommand,\n    23→}\n    24→\n    25→#[derive(Debug, Subcommand)]\n    26→pub enum RunSubcommand {\n    27→    Start,\n    28→    Resume,\n    29→    Status,\n    30→    History,\n    31→    Tail {\n    32→        #[arg(long)]\n    33→        logs: bool,\n    34→    },\n    35→    Rollback {\n    36→        #[arg(long)]\n    37→        to: String,\n    38→        #[arg(long)]\n    39→        hard: bool,\n    40→    },\n    41→}\n    42→\n    43→pub async fn handle(command: RunCommand) -> AppResult<()> {\n    44→    match command.command {\n    45→        RunSubcommand::Status => handle_status().await,\n    46→        RunSubcommand::History => handle_history().await,\n    47→        RunSubcommand::Tail { logs } => handle_tail(logs).await,\n    48→        RunSubcommand::Start => handle_start().await,\n    49→        RunSubcommand::Resume => handle_resume().await,\n    50→        RunSubcommand::Rollback { to, hard } => handle_rollback(to, hard).await,\n    51→    }\n    52→}\n    53→\n    54→pub fn build_agent_execution_service(\n    55→) -> AgentExecutionService<StubBackendAdapter, FsRawOutputStore, FsSessionStore> {\n    56→    let mut adapter = StubBackendAdapter::default();\n    57→\n    58→    // Test-only injection seam: environment variables configure the stub backend\n    59→    // to simulate failure modes that aren't reachable through normal CLI usage.\n    60→    if std::env::var(\"RALPH_BURNING_TEST_BACKEND_UNAVAILABLE\").is_ok() {\n    61→        adapter = adapter.unavailable();\n    62→    }\n    63→    if let Ok(stage_str) = std::env::var(\"RALPH_BURNING_TEST_FAIL_INVOKE_STAGE\") {\n    64→        if let Ok(stage_id) = stage_str.parse::<StageId>() {\n    65→            adapter = adapter.with_invoke_failure(stage_id);\n    66→        }\n    67→    }\n    68→    // Test-only seam: configure a stage to fail the first N invocations, then succeed.\n    69→    // Format: \"stage_id:count\" e.g. \"implementation:1\"\n    70→    if let Ok(spec) = std::env::var(\"RALPH_BURNING_TEST_TRANSIENT_FAILURE\") {\n    71→        if let Some((stage_str, count_str)) = spec.split_once(':') {\n    72→            if let (Ok(stage_id), Ok(count)) = (stage_str.parse::<StageId>(), count_str.parse::<u32>()) {\n    73→                adapter = adapter.with_transient_failure(stage_id, count);\n    74→            }\n    75→        }\n    76→    }\n    77→    // Test-only seam: JSON map from stage-id string to payload JSON.\n    78→    // Values may be a single object or an array of objects (payload sequence).\n    79→    // Example: {\"completion_panel\": {\"outcome\":\"conditionally_approved\",...}}\n    80→    // Example sequence: {\"qa\": [{\"outcome\":\"request_changes\",...}, {\"outcome\":\"approved\",...}]}\n    81→    if let Ok(overrides_json) = std::env::var(\"RALPH_BURNING_TEST_STAGE_OVERRIDES\") {\n    82→        if let Ok(overrides) =\n    83→            serde_json::from_str::<std::collections::HashMap<String, serde_json::Value>>(\n    84→                &overrides_json,\n    85→            )\n    86→        {\n    87→            for (stage_str, payload) in overrides {\n    88→                if let Ok(stage_id) = stage_str.parse::<StageId>() {\n    89→                    if let Some(arr) = payload.as_array() {\n    90→                        adapter = adapter.with_stage_payload_sequence(stage_id, arr.clone());\n    91→                    } else {\n    92→                        adapter = adapter.with_stage_payload(stage_id, payload);\n    93→                    }\n    94→                }\n    95→            }\n    96→        }\n    97→    }\n    98→\n    99→    AgentExecutionService::new(adapter, FsRawOutputStore, FsSessionStore)\n   100→}\n   101→\n   102→async fn handle_start() -> AppResult<()> {\n   103→    let current_dir = std::env::current_dir()?;\n   104→\n   105→    // Validate workspace version\n   106→    let config = workspace_governance::load_workspace_config(&current_dir)?;\n   107→    workspace_governance::ensure_supported_workspace_version(&config)?;\n   108→\n   109→    // Resolve active project\n   110→    let project_id = workspace_governance::resolve_active_project(&current_dir)?;\n   111→\n   112→    // Validate canonical project record\n   113→    let project_store = FsProjectStore;\n   114→    let project_record = project_store.read_project_record(&current_dir, &project_id)?;\n   115→\n   116→    // Validate run snapshot integrity\n   117→    let run_snapshot_read = FsRunSnapshotStore;\n   118→    let run_snapshot = run_snapshot_read.read_run_snapshot(&current_dir, &project_id)?;\n   119→\n   120→    // Check preconditions before engine call (fail fast with clear errors)\n   121→    match run_snapshot.status {\n   122→        RunStatus::NotStarted => {}\n   123→        RunStatus::Failed | RunStatus::Paused => {\n   124→            return Err(AppError::RunStartFailed {\n   125→                reason: format!(\n   126→                    \"project snapshot status is '{}'; use `ralph-burning run resume`\",\n   127→                    run_snapshot.status\n   128→                ),\n   129→            });\n   130→        }\n   131→        status => {\n   132→            return Err(AppError::RunStartFailed {\n   133→                reason: format!(\n   134→                    \"project snapshot status is '{}'; run start requires 'not_started'\",\n   135→                    status\n   136→                ),\n   137→            });\n   138→        }\n   139→    }\n   140→    if run_snapshot.has_active_run() {\n   141→        return Err(AppError::RunStartFailed {\n   142→            reason: \"project already has an active run\".to_owned(),\n   143→        });\n   144→    }\n   145→\n   146→    let effective_config = EffectiveConfig::load(&current_dir)?;\n   147→\n   148→    let agent_service = build_agent_execution_service();\n   149→    let run_snapshot_write = FsRunSnapshotWriteStore;\n   150→    let journal_store = FsJournalStore;\n   151→    let artifact_write = FsPayloadArtifactWriteStore;\n   152→    let log_write = FsRuntimeLogWriteStore;\n   153→\n   154→    println!(\"Starting run for project '{}'...\", project_id);\n   155→\n   156→    let amendment_queue = FsAmendmentQueueStore;\n   157→\n   158→    engine::execute_run(\n   159→        &agent_service,\n   160→        &run_snapshot_read,\n   161→        &run_snapshot_write,\n   162→        &journal_store,\n   163→        &artifact_write,\n   164→        &log_write,\n   165→        &amendment_queue,\n   166→        &current_dir,\n   167→        &project_id,\n   168→        project_record.flow,\n   169→        &effective_config,\n   170→    )\n   171→    .await?;\n   172→\n   173→    let final_snapshot = run_snapsh