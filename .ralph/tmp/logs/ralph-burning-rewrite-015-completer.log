 run = RequirementsRun::new_quick(\"req-002\".to_owned(), \"Add a feature\".to_owned(), now);\n    43→\n    44→    assert_eq!(run.run_id, \"req-002\");\n    45→    assert_eq!(run.idea, \"Add a feature\");\n    46→    assert_eq!(run.mode, RequirementsMode::Quick);\n    47→    assert_eq!(run.status, RequirementsStatus::Drafting);\n    48→    assert_eq!(run.question_round, 0);\n    49→    assert_eq!(run.created_at, now);\n    50→    assert_eq!(run.updated_at, now);\n    51→}\n    52→\n    53→#[test]\n    54→fn requirements_run_is_terminal_returns_true_for_completed_and_failed() {\n    55→    let now = Utc::now();\n    56→\n    57→    let mut run = RequirementsRun::new_draft(\"t-1\".to_owned(), \"idea\".to_owned(), now);\n    58→    assert!(!run.is_terminal(), \"Drafting should not be terminal\");\n    59→\n    60→    run.status = RequirementsStatus::AwaitingAnswers;\n    61→    assert!(!run.is_terminal(), \"AwaitingAnswers should not be terminal\");\n    62→\n    63→    run.status = RequirementsStatus::Completed;\n    64→    assert!(run.is_terminal(), \"Completed should be terminal\");\n    65→\n    66→    run.status = RequirementsStatus::Failed;\n    67→    assert!(run.is_terminal(), \"Failed should be terminal\");\n    68→}\n    69→\n    70→#[test]\n    71→fn requirements_review_outcome_allows_completion_for_approved_and_conditionally_approved() {\n    72→    assert!(RequirementsReviewOutcome::Approved.allows_completion());\n    73→    assert!(RequirementsReviewOutcome::ConditionallyApproved.allows_completion());\n    74→    assert!(!RequirementsReviewOutcome::RequestChanges.allows_completion());\n    75→    assert!(!RequirementsReviewOutcome::Rejected.allows_completion());\n    76→}\n    77→\n    78→#[test]\n    79→fn requirements_stage_id_as_str_round_trips_via_serde() {\n    80→    let all_variants = [\n    81→        RequirementsStageId::QuestionSet,\n    82→        RequirementsStageId::RequirementsDraft,\n    83→        RequirementsStageId::RequirementsReview,\n    84→        RequirementsStageId::ProjectSeed,\n    85→    ];\n    86→\n    87→    for variant in all_variants {\n    88→        let as_str = variant.as_str();\n    89→        // Serialize via serde to a JSON string, then strip quotes to get the raw string\n    90→        let serialized = serde_json::to_value(variant).expect(\"serialize stage id\");\n    91→        let serde_str = serialized.as_str().expect(\"should be a string\");\n    92→        assert_eq!(\n    93→            as_str, serde_str,\n    94→            \"as_str and serde representation should match for {:?}\",\n    95→            variant\n    96→        );\n    97→\n    98→        // Deserialize back\n    99→        let deserialized: RequirementsStageId =\n   100→            serde_json::from_value(serialized).expect(\"deserialize stage id\");"}]},"parent_tool_use_id":"toolu_01CbvMMytrEsep8F3HzfNTmM","session_id":"2cdec833-d9a4-4fe7-8fdf-432611cd39d7","uuid":"973f3759-4275-4e9e-8552-e8a9cc9cddae"}
