{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01ABWYU5jnYJ7gEbcrG44ni4","type":"tool_result","content":"     1→use clap::{Args, Subcommand};\n     2→\n     3→use crate::contexts::conformance_spec::catalog;\n     4→use crate::contexts::conformance_spec::cutover_guard;\n     5→use crate::contexts::conformance_spec::runner;\n     6→use crate::contexts::conformance_spec::scenarios;\n     7→use crate::shared::error::{AppError, AppResult};\n     8→\n     9→#[derive(Debug, Args)]\n    10→pub struct ConformanceCommand {\n    11→    #[command(subcommand)]\n    12→    pub command: ConformanceSubcommand,\n    13→}\n    14→\n    15→#[derive(Debug, Subcommand)]\n    16→pub enum ConformanceSubcommand {\n    17→    List,\n    18→    Run {\n    19→        #[arg(long)]\n    20→        filter: Option<String>,\n    21→    },\n    22→}\n    23→\n    24→pub async fn handle(command: ConformanceCommand) -> AppResult<()> {\n    25→    match command.command {\n    26→        ConformanceSubcommand::List => handle_list(),\n    27→        ConformanceSubcommand::Run { filter } => handle_run(filter),\n    28→    }\n    29→}\n    30→\n    31→fn handle_list() -> AppResult<()> {\n    32→    let scenarios = catalog::discover_scenarios()?;\n    33→    catalog::validate_ids(&scenarios)?;\n    34→\n    35→    println!(\n    36→        \"{:<30} {:<40} {:<40} {}\",\n    37→        \"SCENARIO ID\", \"FEATURE\", \"SCENARIO\", \"SOURCE\"\n    38→    );\n    39→    println!(\"{}\", \"-\".repeat(140));\n    40→\n    41→    for s in &scenarios {\n    42→        println!(\n    43→            \"{:<30} {:<40} {:<40} {}:{}\",\n    44→            s.id,\n    45→            truncate(&s.feature_title, 38),\n    46→            truncate(&s.scenario_title, 38),\n    47→            s.source_file,\n    48→            s.source_line,\n    49→        );\n    50→    }\n    51→\n    52→    println!();\n    53→    println!(\"Total: {} scenarios\", scenarios.len());\n    54→\n    55→    Ok(())\n    56→}\n    57→\n    58→fn handle_run(filter: Option<String>) -> AppResult<()> {\n    59→    // Phase 1: Discovery and validation\n    60→    let scenarios = catalog::discover_scenarios()?;\n    61→    catalog::validate_ids(&scenarios)?;\n    62→\n    63→    // Phase 2: Build and validate registry\n    64→    let registry = scenarios::build_registry();\n    65→    runner::validate_registry(&scenarios, &registry)?;\n    66→\n    67→    // Phase 3: Cutover guard\n    68→    let src_dir = std::path::Path::new(concat!(env!(\"CARGO_MANIFEST_DIR\"), \"/src\"));\n    69→    cutover_guard::check_cutover_guard(src_dir)?;\n    70→\n    71→    // Phase 4: Filter resolution\n    72→    let selected: Vec<&_> = if let Some(ref filter_id) = filter {\n    73→        runner::resolve_filter(&scenarios, filter_id)?\n    74→    } else {\n    75→        scenarios.iter().collect()\n    76→    };\n    77→\n    78→    if selected.is_empty() {\n    79→        return Err(AppError::ConformanceDiscoveryFailed {\n    80→            details: \"no scenarios selected for execution\".to_owned(),\n    81→        });\n    82→    }\n    83→\n    84→    eprintln!(\"Running {} conformance scenarios...\", selected.len());\n    85→    eprintln!();\n    86→\n    87→    // Phase 5: Execution\n    88→    let report = runner::run_scenarios(&selected, &registry);\n    89→\n    90→    // Phase 6: Summary\n    91→    eprint!(\"{report}\");\n    92→\n    93→    // Phase 7: Exit code\n    94→    // The runner already printed the failing scenario ID and reason during execution;\n    95→    // returning ConformanceRunFailed gives a non-zero exit without double-printing.\n    96→    if report.failed > 0 {\n    97→        Err(AppError::ConformanceRunFailed)\n    98→    } else {\n    99→        Ok(())\n   100→    }\n   101→}\n   102→\n   103→fn truncate(s: &str, max_len: usize) -> String {\n   104→    if s.len() <= max_len {\n   105→        s.to_owned()\n   106→    } else {\n   107→        format!(\"{}...\", &s[..max_len - 3])\n   108→    }\n   109→}\n   110→"}]},"parent_tool_use_id":"toolu_01S4zLNqast3cuoLUonRhirT","session_id":"2cdec833-d9a4-4fe7-8fdf-432611cd39d7","uuid":"6f119a01-008b-4899-a2b4-9584a9ab5454"}
