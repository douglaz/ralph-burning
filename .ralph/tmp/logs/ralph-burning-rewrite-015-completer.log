     task_id: String,\n   151→        from: String,\n   152→        to: String,\n   153→    },\n   154→    #[error(\"rebase conflict for branch '{branch_name}': {details}\")]\n   155→    RebaseConflict {\n   156→        branch_name: String,\n   157→        details: String,\n   158→    },\n   159→    #[error(\"conformance parse error in {file} line {line}: {details}\")]\n   160→    ConformanceParseFailed {\n   161→        file: String,\n   162→        line: usize,\n   163→        details: String,\n   164→    },\n   165→    #[error(\"conformance discovery failed: {details}\")]\n   166→    ConformanceDiscoveryFailed { details: String },\n   167→    #[error(\"conformance registry drift: {details}\")]\n   168→    ConformanceRegistryDrift { details: String },\n   169→    #[error(\"conformance filter failed: unknown scenario ID '{scenario_id}'\")]\n   170→    ConformanceFilterFailed { scenario_id: String },\n   171→    #[error(\"cutover guard violation in {file} line {line}: {pattern}\")]\n   172→    ConformanceCutoverViolation {\n   173→        file: String,\n   174→        line: usize,\n   175→        pattern: String,\n   176→    },\n   177→    #[error(\"conformance scenario '{scenario_id}' failed: {details}\")]\n   178→    ConformanceScenarioFailed {\n   179→        scenario_id: String,\n   180→        details: String,\n   181→    },\n   182→    #[error(\"conformance run failed (see above for details)\")]\n   183→    ConformanceRunFailed,\n   184→    #[error(transparent)]\n   185→    Io(#[from] std::io::Error),\n   186→    #[error(transparent)]\n   187→    TomlDeserialize(#[from] toml::de::Error),\n   188→    #[error(transparent)]\n   189→    TomlSerialize(#[from] toml::ser::Error),\n   190→    #[error(transparent)]\n   191→    TomlEdit(#[from] toml_edit::TomlError),\n   192→    #[error(transparent)]\n   193→    SerdeJson(#[from] serde_json::Error),\n   194→}\n   195→\n   196→/// Errors specific to stage contract evaluation.\n   197→///\n   198→/// Each variant maps to a distinct [`FailureClass`] for retry/terminal policy.\n   199→/// The `stage_id` field is a domain-neutral string identifier, supporting both\n   200→/// workflow stage IDs and requirements stage IDs.\n   201→#[derive(Debug, Error)]\n   202→pub enum ContractError {\n   203→    #[error(\"schema validation failed for stage '{stage_id}': {details}\")]\n   204→    SchemaValidation { stage_id: String, details: String },\n   205→\n   206→    #[error(\"domain validation failed for stage '{stage_id}': {details}\")]\n   207→    DomainValidation { stage_id: String, details: String },\n   208→\n   209→    #[error(\"rendering failed for stage '{stage_id}': {details}\")]\n   210→    RenderError { stage_id: String, details: String },\n   211→\n   212→    #[error(\"non-passing QA/review outcome for stage '{stage_id}': {outcome}\")]\n   213→    QaReviewOutcome { stage_id: String, outcome: String },\n   214→}\n   215→\n   216→impl ContractError {\n   217→    pub fn failure_class(&self) -> FailureClass {\n   218→        match self {\n   219→            Self::SchemaValidation { .. } => FailureClass::SchemaValidationFailure,\n   220→            Self::DomainValidation { .. } | Self::RenderError { .. } => {\n   221→                FailureClass::DomainValidationFailure\n   222→            }\n   223→            Self::QaReviewOutcome { .. } => FailureClass::QaReviewOutcomeFailure,\n   224→        }\n   225→    }\n   226→\n   227→    pub fn stage_id(&self) -> &str {\n   228→        match self {\n   229→            Self::SchemaValidation { stage_id, .. }\n   230→            | Self::DomainValidation { stage_id, .. }\n   231→            | Self::RenderError { stage_id, .. }\n   232→            | Self::QaReviewOutcome { stage_id, .. } => stage_id,\n   233→        }\n   234→    }\n   235→}\n   236→\n   237→impl AppError {\n   238→    pub fn failure_class(&self) -> Option<FailureClass> {\n   239→        match self {\n   240→            Self::BackendUnavailable { .. } => Some(FailureClass::TransportFailure),\n   241→            Self::CapabilityMismatch { .. } => Some(FailureClass::DomainValidationFailure),\n   242→            Self::InvocationFailed { failure_class, .. } => Some(*failure_class),\n   243→            Self::InvocationTimeout { .. } => Some(FailureClass::Timeout),\n   244→            Self::InvocationCancelled { .. } => Some(FailureClass::Cancellation),\n   245→            _ => None,\n   246→        }\n   247→    }\n   248→}\n   249→"}]},"parent_tool_use_id":"toolu_01S4zLNqast3cuoLUonRhirT","session_id":"2cdec833-d9a4-4fe7-8fdf-432611cd39d7","uuid":"fb868235-c509-47fc-b4da-51cc55a0e65e"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_017kwQZKep1rvq6yRyUKPPSx","type":"tool_result","content":"     1→use std::path::{Path, PathBuf};\n     2→use std::time::Duration;\n     3→\n     4→use chrono::{DateTime, Utc};\n     5→use serde_json::{json, Value};\n     6→use uuid::Uuid;\n     7→\n     8→use crate::adapters::fs::FsRollbackPointStore;\n     9→use crate::adapters::worktree::WorktreeAdapter;\n    10→use crate::contexts::agent_execution::model::{\n    11→    CancellationToken, InvocationContract, InvocationPayload, InvocationRequest,\n    12→};\n    13→use crate::contexts::agent_execution::service::{\n    14→    AgentExecutionPort, BackendSelectionConfig, RawOutputPort,\n    15→};\n    16→use crate::contexts::agent_execution::session::SessionStorePort;\n    17→use crate::contexts::agent_execution::AgentExecutionService;\n    18→use crate::contexts::project_run_record::journal;\n    19→use crate::contexts::project_run_record::model::{\n    20→    ActiveRun, ArtifactRecord, CycleHistoryEntry, JournalEvent, LogLevel, PayloadRecord,\n    21→    QueuedAmendment, RollbackPoint, RunSnapshot, RunStatus, RuntimeLogEntry,\n    22→};\n    23→use crate::contexts::project_run_record::queries;\n    24→use crate::contexts::project_run_record::service::{\n    25→    AmendmentQueuePort, ArtifactStorePort, JournalStorePort, PayloadArtifactWritePort,\n    26→    RollbackPointStorePort, RunSnapshotPort, RunSnapshotWritePort, RuntimeLogWritePort,\n    27→};\n    28→use crate::contexts::workflow_composition::payloads::{\n    29→    ReviewOutcome, StagePayload, ValidationPayload,\n    30→};\n    31→use crate::contexts::workspace_governance::config::EffectiveConfig;\n    32→use crate::shared::domain::{\n    33→    BackendRole, FailureClass, FlowPreset, ProjectId, ResolvedBackendTarget, RunId, SessionPolicy,\n    34→    StageCursor, StageId,\n    35→};\n    36→use crate::shared::error::{AppError, AppResult};\n    37→\n    38→use super::contracts::{self, ValidatedBundle};\n    39→use super::retry_policy::RetryPolicy;\n    40→use super::{flow_semantics, stage_plan_for_flow, FlowSemantics};\n    41→\n    42→/// Compatibility wrapper for the legacy standard-flow helper.\n    43→pub fn standard_stage_plan(prompt_review_enabled: bool) -> Vec<StageId> {\n    44→    stage_plan_for_flow(FlowPreset::Standard, prompt_review_enabled)\n    45→}\n    46→\n    47→/// Deterministic stage-to-role mapping per spec.\n    48→pub fn role_for_stage(stage_id: StageId) -> BackendRole {\n    49→    BackendRole::for_stage(stage_id)\n    50→}\n    51→\n    52→/// Resolved target per stage for preflight.\n    53→pub struct StagePlan {\n    54→    pub stage_id: StageId,\n    55→    pub role: BackendRole,\n    56→    pub contract: contracts::StageContract,\n    57→    pub target: ResolvedBackendTarget,\n    58→}\n    59→\n    60→/// Resolve all stage targets ahead of execution for preflight validation.\n    61→pub fn resolve_stage_plan(\n    62→    stages: &[StageId],\n    63→    resolver: &crate::contexts::agent_execution::service::BackendResolver,\n    64→    workspace_defaults: Option<&BackendSelectionConfig>,\n    65→) -> AppResult<Vec<StagePlan>> {\n    66→    let mut plan = Vec::with_capacity(stages.len());\n    67→    for &stage_id in stages {\n    68→        let role = role_for_stage(stage_id);\n    69→        let contract = contracts::contract_for_stage(stage_id);\n    70→        let target = resolver.resolve(role, None, None, workspace_defaults)?;\n    71→        plan.push(StagePlan {\n    72→            stage_id,\n    73→            role,\n    74→            contract,\n    75→            target,\n    76→        });\n    77→    }\n    78→    Ok(plan)\n    79→}\n    80→\n    81→/// Preflight: check capability and availability for every stage target.\n    82→pub async fn preflight_check<A: AgentExecutionPort>(\n    83→    adapter: &A,\n    84→    plan: &[StagePlan],\n    85→) -> AppResult<()> {\n    86→    for entry in plan {\n    87→        adapter\n    88→            .check_capability(\n    89→                &entry.target,\n    90→                &InvocationContract::Stage(entry.contract.clone()),\n    91→            )\n    92→            .await\n    93→            .map_err(|e| AppError::PreflightFailed {\n    94→                stage_id: entry.stage_id,\n    95→                details: e.to_string(),\n    96→            })?;\n    97→        adapter\n    98→            .check_availability(&entry.target)\n    99→            .await\n   100→            .map_err(|e| AppError::PreflightFailed {\n   101→                stage_id: entry.stage_id,\n   102→                details: e.to_string(),\n   103→            })?;\n   104→    }\n   105→    Ok(())\n   106→}\n   107→\n   108→/// Generate a new run ID from a timestamp.\n   109→fn generate_run_id() -> AppResult<RunId> {\n   110→    let now = Utc::now();\n   111→    RunId::new(format!(\"run-{}\", now.format(\"%Y%m%d%H%M%S\")))\n   112→}\n   113→\n   114→fn history_record_base_id(\n   115→    run_id: &RunId,\n   116→    stage_id: StageId,\n   117→    cursor: &StageCursor,\n   118→    rollback_count: u32,\n   119→) -> String {\n   120→    let base_id = format!(\n   121→        \"{}-{}-c{}-a{}\",\n   122→        run_id.as_str(),\n   123→        stage_id.as_str(),\n   124→        cursor.cycle,\n   125→        cursor.attempt\n   126→    );\n   127→    if rollback_count == 0 {\n   128→        base_id\n   129→    } else {\n   130→        format!(\"{base_id}-rb{rollback_count}\")\n   131→    }\n   132→}\n   133→\n   134→#[derive(Debug, Clone, Copy)]\n   135→enum ExecutionOrigin {\n   136→    Start,\n   137→    Resume,\n   138→}\n   139→\n   140→impl ExecutionOrigin {\n   141→    fn error(self, reason: String) -> AppError {\n   142→        match self {\n   143→            Self::Start => AppError::RunStartFailed { reason },\n   144→            Self::Resume => AppError::ResumeFailed { reason },\n   145→        }\n   146→    }\n   147→}\n   148→\n   149→#[derive(Debug, Clone, Copy, PartialEq, Eq)]\n   150→enum RunOutcome {\n   151→    Completed,\n   152→    Paused,\n   153→}\n   154→\n   155→#[derive(Debug)]\n   156→struct ResumeState {\n   157→    run_id: RunId,\n   158→    started_at: DateTime<Utc>,\n   159→    stage_index: usize,\n   160→    cursor: StageCursor,\n   161→}\n   162→\n   163→#[allow(clippy::too_many_arguments)]\n   164→pub async fn execute_run<A, R, S>(\n   165→    agent_service: &AgentExecutionService<A, R, S>,\n   166→    run_snapshot_read: &dyn RunSnapshotPort,\n   167→    run_snapshot_write: &dyn RunSnapshotWritePort,\n   168→    journal_store: &dyn JournalStorePort,\n   169→    artifact_write: &dyn PayloadArtifactWritePort,\n   170→    log_write: &dyn RuntimeLogWritePort,\n   171→    amendment_queue_port: &dyn AmendmentQueuePort,\n   172→    base_dir: &Path,\n   173→    project_id: &ProjectId,\n   174→    preset: FlowPreset,\n   175→    effective_config: &EffectiveConfig,\n   176→) -> AppResult<()>\n   177→where\n   178→    A: AgentExecutionPort,\n   179→    R: RawOutputPort,\n   180→    S: SessionStorePort,\n   181→{\n   182→    let rollback_store = FsRollbackPointStore;\n   183→    execute_run_with_retry_internal(\n   184→        agent_service,\n   185→        run_snapshot_read,\n   186→        run_snapshot_write,\n   187→        journal_store,\n   188→        artifact_write,\n   189→        log_write,\n   190→        amendment_queue_port,\n   191→        &rollback_store,\n   192→        base_dir,\n   193→        project_id,\n   194→        preset,\n   195→        effective_config,\n   196→        &RetryPolicy::default_policy(),\n   197→        CancellationToken::new(),\n   198→    )\n   199→    .await\n   200→}"}]},"parent_tool_use_id":"toolu_01M4SZzK316UaJNgGSvtJ7TQ","session_id":"2cdec833-d9a4-4fe7-8fdf-432611cd39d7","uuid":"ba6ab65b-4b8e-4227-90a4-5af79d3f4684"}
