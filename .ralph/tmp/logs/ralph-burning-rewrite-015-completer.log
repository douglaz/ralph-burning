        let mut file = OpenOptions::new()\n    91→            .create_new(true)\n    92→            .write(true)\n    93→            .open(&temp_path)?;\n    94→        file.write_all(contents.as_bytes())?;\n    95→        file.sync_all()?;\n    96→        drop(file);\n    97→\n    98→        if let Err(error) = fs::rename(&temp_path, path) {\n    99→            let _ = fs::remove_file(&temp_path);\n   100→            return Err(error.into());\n   101→        }\n   102→\n   103→        Ok(())\n   104→    }\n   105→\n   106→    pub fn render_workspace_config(config: &WorkspaceConfig) -> AppResult<String> {\n   107→        Ok(toml::to_string_pretty(config)?)\n   108→    }\n   109→\n   110→    pub fn read_active_project(workspace_root: &Path) -> AppResult<Option<String>> {\n   111→        let path = workspace_root.join(ACTIVE_PROJECT_FILE);\n   112→        match fs::read_to_string(path) {\n   113→            Ok(raw) => {\n   114→                let trimmed = raw.trim();\n   115→                if trimmed.is_empty() {\n   116→                    Ok(None)\n   117→                } else {\n   118→                    Ok(Some(trimmed.to_owned()))\n   119→                }\n   120→            }\n   121→            Err(error) if error.kind() == std::io::ErrorKind::NotFound => Ok(None),\n   122→            Err(error) => Err(error.into()),\n   123→        }\n   124→    }\n   125→\n   126→    pub fn write_active_project(workspace_root: &Path, project_id: &str) -> AppResult<()> {\n   127→        Self::write_atomic(&workspace_root.join(ACTIVE_PROJECT_FILE), project_id)\n   128→    }\n   129→\n   130→    pub fn open_editor(path: &Path) -> AppResult<()> {\n   131→        let editor = env::var(\"EDITOR\")\n   132→            .ok()\n   133→            .filter(|value| !value.trim().is_empty())\n   134→            .or_else(|| {\n   135→                env::var(\"VISUAL\")\n   136→                    .ok()\n   137→                    .filter(|value| !value.trim().is_empty())\n   138→            })\n   139→            .unwrap_or_else(|| \"vi\".to_owned());\n   140→\n   141→        let mut parts = editor.split_whitespace();\n   142→        let program = parts.next().ok_or_else(|| AppError::EditorFailed {\n   143→            editor: editor.clone(),\n   144→            details: \": empty editor command\".to_owned(),\n   145→        })?;\n   146→        let status = Command::new(program).args(parts).arg(path).status()?;\n   147→\n   148→        if status.success() {\n   149→            Ok(())\n   150→        } else {"}]},"parent_tool_use_id":"toolu_01CbvMMytrEsep8F3HzfNTmM","session_id":"2cdec833-d9a4-4fe7-8fdf-432611cd39d7","uuid":"d6e615a3-0c9b-4dfd-8df6-8dabcbb55b61"}
