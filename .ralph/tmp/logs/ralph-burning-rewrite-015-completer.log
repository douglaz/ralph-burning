.json\", run_id),\n  1280→                details: e.to_string(),\n  1281→            }),\n  1282→            Err(e) if e.kind() == std::io::ErrorKind::NotFound => {\n  1283→                Err(AppError::InvalidRequirementsState {\n  1284→                    run_id: run_id.to_owned(),\n  1285→                    details: \"requirements run not found\".to_owned(),\n  1286→                })\n  1287→            }\n  1288→            Err(e) => Err(e.into()),\n  1289→        }\n  1290→    }\n  1291→\n  1292→    fn append_journal_event(\n  1293→        &self,\n  1294→        base_dir: &Path,\n  1295→        run_id: &str,\n  1296→        event: &RequirementsJournalEvent,\n  1297→    ) -> AppResult<()> {\n  1298→        let path = requirements_run_root(base_dir, run_id).join(\"journal.ndjson\");\n  1299→        let line = serde_json::to_string(event)?;\n  1300→        FileSystem::append_line(&path, &line)\n  1301→    }\n  1302→\n  1303→    fn read_journal(\n  1304→        &self,\n  1305→        base_dir: &Path,\n  1306→        run_id: &str,\n  1307→    ) -> AppResult<Vec<RequirementsJournalEvent>> {\n  1308→        let path = requirements_run_root(base_dir, run_id).join(\"journal.ndjson\");\n  1309→        match fs::read_to_string(&path) {\n  1310→            Ok(contents) => {\n  1311→                let mut events = Vec::new();\n  1312→                for line in contents.lines() {\n  1313→                    let trimmed = line.trim();\n  1314→                    if trimmed.is_empty() {\n  1315→                        continue;\n  1316→                    }\n  1317→                    let event: RequirementsJournalEvent =\n  1318→                        serde_json::from_str(trimmed).map_err(|e| AppError::CorruptRecord {\n  1319→                            file: format!(\"requirements/{}/journal.ndjson\", run_id),\n  1320→                            details: e.to_string(),\n  1321→                        })?;\n  1322→                    events.push(event);\n  1323→                }\n  1324→                Ok(events)\n  1325→            }\n  1326→            Err(e) if e.kind() == std::io::ErrorKind::NotFound => Ok(Vec::new()),\n  1327→            Err(e) => Err(e.into()),\n  1328→        }\n  1329→    }\n  1330→\n  1331→    fn write_payload(\n  1332→        &self,\n  1333→        base_dir: &Path,\n  1334→        run_id: &str,\n  1335→        payload_id: &str,\n  1336→        payload: &serde_json::Value,\n  1337→    ) -> AppResult<()> {\n  1338→        let path = requirements_run_root(base_dir, run_id)\n  1339→            .join(\"history/payloads\")\n  1340→            .join(format!(\"{payload_id}.json\"));\n  1341→        let contents = serde_json::to_string_pretty(payload)?;\n  1342→        FileSystem::write_atomic(&path, &contents)\n  1343→    }\n  1344→\n  1345→    fn write_artifact(\n  1346→        &self,\n  1347→        base_dir: &Path,\n  1348→        run_id: &str,\n  1349→        artifact_id: &str,\n  1350→        content: &str,\n  1351→    ) -> AppResult<()> {\n  1352→        let path = requirements_run_root(base_dir, run_id)\n  1353→            .join(\"history/artifacts\")\n  1354→            .join(format!(\"{artifact_id}.md\"));\n  1355→        FileSystem::write_atomic(&path, content)\n  1356→    }\n  1357→\n  1358→    fn read_payload(\n  1359→        &self,\n  1360→        base_dir: &Path,\n  1361→        run_id: &str,\n  1362→        payload_id: &str,\n  1363→    ) -> AppResult<serde_json::Value> {\n  1364→        let path = requirements_run_root(base_dir, run_id)\n  1365→            .join(\"history/payloads\")\n  1366→            .join(format!(\"{payload_id}.json\"));\n  1367→        let contents = FileSystem::read_to_string(&path)?;\n  1368→        serde_json::from_str(&contents).map_err(|e| AppError::CorruptRecord {\n  1369→            file: format!(\n  1370→                \"requirements/{}/history/payloads/{}.json\",\n  1371→                run_id, payload_id\n  1372→            ),\n  1373→            details: e.to_string(),\n  1374→        })\n  1375→    }\n  1376→\n  1377→    fn write_payload_artifact_pair_atomic(\n  1378→        &self,\n  1379→        base_dir: &Path,\n  1380→        run_id: &str,\n  1381→        payload_id: &str,\n  1382→        payload: &serde_json::Value,\n  1383→        artifact_id: &str,\n  1384→        artifact: &str,\n  1385→    ) -> AppResult<()> {\n  1386→        let run_root = requirements_run_root(base_dir, run_id);\n  1387→        let staging_dir = run_root.join(\"runtime/temp\");\n  1388→        fs::create_dir_all(&staging_dir)?;\n  1389→\n  1390→        let payload_final = run_root\n  1391→            .join(\"history/payloads\")\n  1392→            .join(format!(\"{payload_id}.json\"));\n  1393→        let artifact_final = run_root\n  1394→            .join(\"history/artifacts\")\n  1395→            .join(format!(\"{artifact_id}.md\"));\n  1396→\n  1397→        let payload_staging = staging_dir.join(format!(\".{payload_id}.payload.staging\"));\n  1398→        let artifact_staging = staging_dir.join(format!(\".{artifact_id}.artifact.staging\"));\n  1399→\n  1400→        let payload_contents = serde_json::to_string_pretty(payload)?;\n  1401→\n  1402→        // Write payload to staging\n  1403→        FileSystem::write_atomic(&payload_staging, &payload_contents)?;\n  1404→\n  1405→        // Write artifact to staging — if this fails, clean up payload staging\n  1406→        if let Err(e) = FileSystem::write_atomic(&artifact_staging, artifact) {\n  1407→            let _ = fs::remove_file(&payload_staging);\n  1408→            return Err(e);\n  1409→        }\n  1410→\n  1411→        // Rename payload staging into canonical location\n  1412→        if let Err(e) = fs::rename(&payload_staging, &payload_final) {\n  1413→            let _ = fs::remove_file(&payload_staging);\n  1414→            let _ = fs::remove_file(&artifact_staging);\n  1415→            return Err(e.into());\n  1416→        }\n  1417→\n  1418→        // Rename artifact staging into canonical location\n  1419→        if let Err(e) = fs::rename(&artifact_staging, &artifact_final) {\n  1420→            // Roll back the payload that was already moved to canonical location\n  1421→            // and remove the orphaned staged artifact file\n  1422→            let _ = fs::remove_file(&payload_final);\n  1423→            let _ = fs::remove_file(&artifact_staging);\n  1424→            return Err(e.into());\n  1425→        }\n  1426→\n  1427→        Ok(())\n  1428→    }\n  1429→\n  1430→    fn write_answers_toml(&self, base_dir: &Path, run_id: &str, template: &str) -> AppResult<()> {\n  1431→        let path = requirements_run_root(base_dir, run_id).join(\"answers.toml\");\n  1432→        FileSystem::write_atomic(&path, template)\n  1433→    }\n  1434→\n  1435→    fn read_answers_toml(&self, base_dir: &Path, run_id: &str) -> AppResult<String> {\n  1436→        let path = requirements_run_root(base_dir, run_id).join(\"answers.toml\");\n  1437→        FileSystem::read_to_string(&path)\n  1438→    }\n  1439→\n  1440→    fn write_answers_json(\n  1441→        &self,\n  1442→        base_dir: &Path,\n  1443→        run_id: &str,\n  1444→        answers: &PersistedAnswers,\n  1445→    ) -> AppResult<()> {\n  1446→        let path = requirements_run_root(base_dir, run_id).join(\"answers.json\");\n  1447→        let contents = serde_json::to_string_pretty(answers)?;\n  1448→        FileSystem::write_atomic(&path, &contents)\n  1449→    }\n  1450→\n  1451→    fn read_answers_json(&self, base_dir: &Path, run_id: &str) -> AppResult<PersistedAnswers> {\n  1452→        let path = requirements_run_root(base_dir, run_id).join(\"answers.json\");\n  1453→        let contents = FileSystem::read_to_string(&path)?;\n  1454→        serde_json::from_str(&contents).map_err(|e| AppError::CorruptRecord {\n  1455→            file: format!(\"requirements/{}/answers.json\", run_id),\n  1456→            details: e.to_string(),\n  1457→        })\n  1458→    }\n  1459→\n  1460→    fn write_seed_pair(\n  1461→        &self,\n  1462→        base_dir: &Path,\n  1463→        run_id: &str,\n  1464→        project_json: &serde_json::Value,\n  1465→        prompt_md: &str,\n  1466→    ) -> AppResult<()> {\n  1467→        let seed_dir = requirements_run_root(base_dir, run_id).join(\"seed\");\n  1468→        fs::create_dir_all(&seed_dir)?;\n  1469→\n  1470→        let project_path = seed_dir.join(\"project.json\");\n  1471→        let prompt_path = seed_dir.join(\"prompt.md\");\n  1472→\n  1473→        // Write project.json first\n  1474→        let project_contents = serde_json::to_string_pretty(project_json)?;\n  1475→        FileSystem::write_atomic(&project_path, &project_contents)?;\n  1476→\n  1477→        // Test injection: simulate prompt.md write failure after project.json succeeds\n  1478→        if std::env::var(\"RALPH_BURNING_TEST_SEED_PROMPT_WRITE_FAIL\").is_ok() {\n  1479→            let _ = fs::remove_file(&project_path);\n  1480→            return Err(AppError::Io(std::io::Error::new(\n  1481→                std::io::ErrorKind::PermissionDenied,\n  1482→                \"injected prompt.md write failure\",\n  1483→            )));\n  1484→        }\n  1485→\n  1486→        // Write prompt.md — if this fails, remove project.json too\n  1487→        if let Err(e) = FileSystem::write_atomic(&prompt_path, prompt_md) {\n  1488→            let _ = fs::remove_file(&project_path);\n  1489→            return Err(e);\n  1490→        }\n  1491→\n  1492→        Ok(())\n  1493→    }\n  1494→\n  1495→    fn remove_seed_pair(&self, base_dir: &Path, run_id: &str) -> AppResult<()> {\n  1496→        let seed_dir = requirements_run_root(base_dir, run_id).join(\"seed\");\n  1497→        let _ = fs::remove_file(seed_dir.join(\"project.json\"));\n  1498→        let _ = fs::remove_file(seed_dir.join(\"prompt.md\"));\n  1499→        Ok(())\n  1500→    }\n  1501→\n  1502→    fn remove_payload_artifact_pair(\n  1503→        &self,\n  1504→        base_dir: &Pa