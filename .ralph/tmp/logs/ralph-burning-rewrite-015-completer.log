le_name = path.file_name().unwrap_or_default().to_string_lossy();\n    45→            if file_name == \"cutover_guard.rs\" {\n    46→                continue;\n    47→            }\n    48→            scan_file(&path)?;\n    49→        }\n    50→    }\n    51→\n    52→    Ok(())\n    53→}\n    54→\n    55→fn scan_file(path: &Path) -> AppResult<()> {\n    56→    let content = std::fs::read_to_string(path).map_err(|e| {\n    57→        AppError::ConformanceDiscoveryFailed {\n    58→            details: format!(\"cannot read {}: {e}\", path.display()),\n    59→        }\n    60→    })?;\n    61→\n    62→    let file_display = path.display().to_string();\n    63→\n    64→    for (line_idx, line) in content.lines().enumerate() {\n    65→        let line_number = line_idx + 1;\n    66→        let trimmed = line.trim();\n    67→\n    68→        // Skip comments — legacy references in comments are informational only\n    69→        if trimmed.starts_with(\"//\") {\n    70→            continue;\n    71→        }\n    72→\n    73→        for pattern in LEGACY_PATTERNS {\n    74→            if line.contains(pattern) {\n    75→                return Err(AppError::ConformanceCutoverViolation {\n    76→                    file: file_display,\n    77→                    line: line_number,\n    78→                    pattern: pattern.to_string(),\n    79→                });\n    80→            }\n    81→        }\n    82→    }\n    83→\n    84→    Ok(())\n    85→}\n    86→"}]},"parent_tool_use_id":null,"session_id":"2cdec833-d9a4-4fe7-8fdf-432611cd39d7","uuid":"05561908-8f49-4e31-8088-d3241493438f","tool_use_result":{"type":"text","file":{"filePath":"/root/new-ralph-burning/ralph-burning-rewrite/src/contexts/conformance_spec/cutover_guard.rs","content":"use std::path::Path;\n\nuse crate::shared::error::{AppError, AppResult};\n\n/// Legacy runtime patterns that must not appear in production source code.\nconst LEGACY_PATTERNS: &[&str] = &[\n    \".ralph/\",\n    \"multibackend-orchestration\",\n    \"multibackend_orchestration\",\n];\n\n/// Scans production source code under `src/` for legacy runtime references.\n///\n/// Returns an error on the first violation found, including file path,\n/// line number, and the offending pattern.\npub fn check_cutover_guard(src_dir: &Path) -> AppResult<()> {\n    if !src_dir.is_dir() {\n        return Err(AppError::ConformanceDiscoveryFailed {\n            details: format!(\"source directory not found: {}\", src_dir.display()),\n        });\n    }\n\n    scan_directory(src_dir)\n}\n\nfn scan_directory(dir: &Path) -> AppResult<()> {\n    let mut entries: Vec<_> = std::fs::read_dir(dir)\n        .map_err(|e| AppError::ConformanceDiscoveryFailed {\n            details: format!(\"cannot read directory {}: {e}\", dir.display()),\n        })?\n        .filter_map(|e| e.ok())\n        .collect();\n\n    entries.sort_by_key(|e| e.path());\n\n    for entry in entries {\n        let path = entry.path();\n        if path.is_dir() {\n            scan_directory(&path)?;\n        } else if path.extension().map_or(false, |ext| ext == \"rs\") {\n            // Skip only this file (cutover_guard.rs) which defines the legacy\n            // pattern constants as string literals. All other conformance_spec\n            // files are scanned normally.\n            let file_name = path.file_name().unwrap_or_default().to_string_lossy();\n            if file_name == \"cutover_guard.rs\" {\n                continue;\n            }\n            scan_file(&path)?;\n        }\n    }\n\n    Ok(())\n}\n\nfn scan_file(path: &Path) -> AppResult<()> {\n    let content = std::fs::read_to_string(path).map_err(|e| {\n        AppError::ConformanceDiscoveryFailed {\n            details: format!(\"cannot read {}: {e}\", path.display()),\n        }\n    })?;\n\n    let file_display = path.display().to_string();\n\n    for (line_idx, line) in content.lines().enumerate() {\n        let line_number = line_idx + 1;\n        let trimmed = line.trim();\