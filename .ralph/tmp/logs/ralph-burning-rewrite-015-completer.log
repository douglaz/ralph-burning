{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01KphR2TUcbXm7TXAV6c9Czf","type":"tool_result","content":"     1→#![forbid(unsafe_code)]\n     2→\n     3→//! Requirements run state model.\n     4→//!\n     5→//! Persisted at `.ralph-burning/requirements/<run-id>/run.json`.\n     6→//! Defines the requirements run lifecycle, journal events, and\n     7→//! stage identifiers independent of the workflow `StageId` enum.\n     8→\n     9→use chrono::{DateTime, Utc};\n    10→use serde::{Deserialize, Serialize};\n    11→\n    12→use crate::shared::domain::FlowPreset;\n    13→\n    14→/// Requirements run mode.\n    15→#[derive(Debug, Clone, Copy, PartialEq, Eq, Serialize, Deserialize)]\n    16→#[serde(rename_all = \"snake_case\")]\n    17→pub enum RequirementsMode {\n    18→    Draft,\n    19→    Quick,\n    20→}\n    21→\n    22→impl std::fmt::Display for RequirementsMode {\n    23→    fn fmt(&self, f: &mut std::fmt::Formatter<'_>) -> std::fmt::Result {\n    24→        match self {\n    25→            Self::Draft => f.write_str(\"draft\"),\n    26→            Self::Quick => f.write_str(\"quick\"),\n    27→        }\n    28→    }\n    29→}\n    30→\n    31→/// Requirements run status.\n    32→#[derive(Debug, Clone, Copy, PartialEq, Eq, Serialize, Deserialize)]\n    33→#[serde(rename_all = \"snake_case\")]\n    34→pub enum RequirementsStatus {\n    35→    Drafting,\n    36→    AwaitingAnswers,\n    37→    Completed,\n    38→    Failed,\n    39→}\n    40→\n    41→impl std::fmt::Display for RequirementsStatus {\n    42→    fn fmt(&self, f: &mut std::fmt::Formatter<'_>) -> std::fmt::Result {\n    43→        match self {\n    44→            Self::Drafting => f.write_str(\"drafting\"),\n    45→            Self::AwaitingAnswers => f.write_str(\"awaiting_answers\"),\n    46→            Self::Completed => f.write_str(\"completed\"),\n    47→            Self::Failed => f.write_str(\"failed\"),\n    48→        }\n    49→    }\n    50→}\n    51→\n    52→/// Canonical requirements run state persisted in `run.json`.\n    53→#[derive(Debug, Clone, PartialEq, Serialize, Deserialize)]\n    54→pub struct RequirementsRun {\n    55→    pub run_id: String,\n    56→    pub idea: String,\n    57→    pub mode: RequirementsMode,\n    58→    pub status: RequirementsStatus,\n    59→    pub question_round: u32,\n    60→    pub latest_question_set_id: Option<String>,\n    61→    pub latest_draft_id: Option<String>,\n    62→    pub latest_review_id: Option<String>,\n    63→    pub latest_seed_id: Option<String>,\n    64→    #[serde(default, skip_serializing_if = \"Option::is_none\")]\n    65→    pub pending_question_count: Option<u32>,\n    66→    #[serde(default, skip_serializing_if = \"Option::is_none\")]\n    67→    pub recommended_flow: Option<FlowPreset>,\n    68→    pub created_at: DateTime<Utc>,\n    69→    pub updated_at: DateTime<Utc>,\n    70→    pub status_summary: String,\n    71→}\n    72→\n    73→impl RequirementsRun {\n    74→    /// Create a new requirements run in draft mode.\n    75→    pub fn new_draft(run_id: String, idea: String, now: DateTime<Utc>) -> Self {\n    76→        Self {\n    77→            run_id,\n    78→            idea,\n    79→            mode: RequirementsMode::Draft,\n    80→            status: RequirementsStatus::Drafting,\n    81→            question_round: 0,\n    82→            latest_question_set_id: None,\n    83→            latest_draft_id: None,\n    84→            latest_review_id: None,\n    85→            latest_seed_id: None,\n    86→            pending_question_count: None,\n    87→            recommended_flow: None,\n    88→            created_at: now,\n    89→            updated_at: now,\n    90→            status_summary: \"drafting: question generation\".to_owned(),\n    91→        }\n    92→    }\n    93→\n    94→    /// Create a new requirements run in quick mode.\n    95→    pub fn new_quick(run_id: String, idea: String, now: DateTime<Utc>) -> Self {\n    96→        Self {\n    97→            run_id,\n    98→            idea,\n    99→            mode: RequirementsMode::Quick,\n   100→            status: RequirementsStatus::Drafting,\n   101→            question_round: 0,\n   102→            latest_question_set_id: None,\n   103→            latest_draft_id: None,\n   104→            latest_review_id: None,\n   105→            latest_seed_id: None,\n   106→            pending_question_count: None,\n   107→            recommended_flow: None,\n   108→            created_at: now,\n   109→            updated_at: now,\n   110→            status_summary: \"drafting: generating requirements\".to_owned(),\n   111→        }\n   112→    }\n   113→\n   114→    /// Whether this run is in a terminal state.\n   115→    pub fn is_terminal(&self) -> bool {\n   116→        matches!(\n   117→            self.status,\n   118→            RequirementsStatus::Completed | RequirementsStatus::Failed\n   119→        )\n   120→    }\n   121→}\n   122→\n   123→/// Requirements stage identifiers — separate from workflow `StageId`.\n   124→#[derive(Debug, Clone, Copy, PartialEq, Eq, Hash, Serialize, Deserialize)]\n   125→#[serde(rename_all = \"snake_case\")]\n   126→pub enum RequirementsStageId {\n   127→    QuestionSet,\n   128→    RequirementsDraft,\n   129→    RequirementsReview,\n   130→    ProjectSeed,\n   131→}\n   132→\n   133→impl RequirementsStageId {\n   134→    pub fn as_str(self) -> &'static str {\n   135→        match self {\n   136→            Self::QuestionSet => \"question_set\",\n   137→            Self::RequirementsDraft => \"requirements_draft\",\n   138→            Self::RequirementsReview => \"requirements_review\",\n   139→            Self::ProjectSeed => \"project_seed\",\n   140→        }\n   141→    }\n   142→\n   143→    pub fn display_name(self) -> &'static str {\n   144→        match self {\n   145→            Self::QuestionSet => \"Question Set\",\n   146→            Self::RequirementsDraft => \"Requirements Draft\",\n   147→            Self::RequirementsReview => \"Requirements Review\",\n   148→            Self::ProjectSeed => \"Project Seed\",\n   149→        }\n   150→    }"}]},"parent_tool_use_id":"toolu_01CbvMMytrEsep8F3HzfNTmM","session_id":"2cdec833-d9a4-4fe7-8fdf-432611cd39d7","uuid":"e5722b96-4e50-4a21-95bd-a76498c1f3c6"}
