{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_018t8vm4A55y1ZLqB6CCMx4n","type":"tool_result","content":"   100→            return Err(error.into());\n   101→        }\n   102→\n   103→        Ok(())\n   104→    }\n   105→\n   106→    pub fn render_workspace_config(config: &WorkspaceConfig) -> AppResult<String> {\n   107→        Ok(toml::to_string_pretty(config)?)\n   108→    }\n   109→\n   110→    pub fn read_active_project(workspace_root: &Path) -> AppResult<Option<String>> {\n   111→        let path = workspace_root.join(ACTIVE_PROJECT_FILE);\n   112→        match fs::read_to_string(path) {\n   113→            Ok(raw) => {\n   114→                let trimmed = raw.trim();\n   115→                if trimmed.is_empty() {\n   116→                    Ok(None)\n   117→                } else {\n   118→                    Ok(Some(trimmed.to_owned()))\n   119→                }\n   120→            }\n   121→            Err(error) if error.kind() == std::io::ErrorKind::NotFound => Ok(None),\n   122→            Err(error) => Err(error.into()),\n   123→        }\n   124→    }\n   125→\n   126→    pub fn write_active_project(workspace_root: &Path, project_id: &str) -> AppResult<()> {\n   127→        Self::write_atomic(&workspace_root.join(ACTIVE_PROJECT_FILE), project_id)\n   128→    }\n   129→\n   130→    pub fn open_editor(path: &Path) -> AppResult<()> {\n   131→        let editor = env::var(\"EDITOR\")\n   132→            .ok()\n   133→            .filter(|value| !value.trim().is_empty())\n   134→            .or_else(|| {\n   135→                env::var(\"VISUAL\")\n   136→                    .ok()\n   137→                    .filter(|value| !value.trim().is_empty())\n   138→            })\n   139→            .unwrap_or_else(|| \"vi\".to_owned());\n   140→\n   141→        let mut parts = editor.split_whitespace();\n   142→        let program = parts.next().ok_or_else(|| AppError::EditorFailed {\n   143→            editor: editor.clone(),\n   144→            details: \": empty editor command\".to_owned(),\n   145→        })?;\n   146→        let status = Command::new(program).args(parts).arg(path).status()?;\n   147→\n   148→        if status.success() {\n   149→            Ok(())\n   150→        } else {\n   151→            let details = match status.code() {\n   152→                Some(code) => format!(\" with exit code {code}\"),\n   153→                None => \" after being terminated by a signal\".to_owned(),\n   154→            };\n   155→            Err(AppError::EditorFailed { editor, details })\n   156→        }\n   157→    }\n   158→\n   159→    /// Compute a simple hash of content for prompt integrity tracking.\n   160→    pub fn prompt_hash(contents: &str) -> String {\n   161→        use std::collections::hash_map::DefaultHasher;\n   162→        use std::hash::{Hash, Hasher};\n   163→        let mut hasher = DefaultHasher::new();\n   164→        contents.hash(&mut hasher);\n   165→        format!(\"{:016x}\", hasher.finish())\n   166→    }\n   167→\n   168→    // ── Helpers for project filesystem layout ──\n   169→\n   170→    pub(crate) fn workspace_root_path(base_dir: &Path) -> PathBuf {\n   171→        base_dir.join(WORKSPACE_DIR)\n   172→    }\n   173→\n   174→    pub(crate) fn daemon_root(base_dir: &Path) -> PathBuf {\n   175→        Self::workspace_root_path(base_dir).join(\"daemon\")\n   176→    }\n   177→\n   178→    fn project_root(base_dir: &Path, project_id: &ProjectId) -> PathBuf {\n   179→        Self::workspace_root_path(base_dir)\n   180→            .join(PROJECTS_DIR)\n   181→            .join(project_id.as_str())\n   182→    }\n   183→\n   184→    fn pending_delete_path(base_dir: &Path, project_id: &ProjectId) -> PathBuf {\n   185→        Self::workspace_root_path(base_dir)\n   186→            .join(PROJECTS_DIR)\n   187→            .join(format!(\".{}.pending-delete\", project_id))\n   188→    }\n   189→\n   190→    fn append_line(path: &Path, line: &str) -> AppResult<()> {\n   191→        let parent = path.parent().ok_or_else(|| {\n   192→            AppError::Io(std::io::Error::new(\n   193→                std::io::ErrorKind::InvalidInput,\n   194→                format!(\"path '{}' has no parent directory\", path.display()),\n   195→            ))\n   196→        })?;\n   197→        fs::create_dir_all(parent)?;\n   198→\n   199→        let needs_separator = match fs::read(path) {\n   200→            Ok(contents) => contents.last().is_some_and(|byte| *byte != b'\\n'),\n   201→            Err(error) if error.kind() == std::io::ErrorKind::NotFound => false,\n   202→            Err(error) => return Err(error.into()),\n   203→        };\n   204→\n   205→        let mut file = OpenOptions::new().create(true).append(true).open(path)?;\n   206→        if needs_separator {\n   207→            file.write_all(b\"\\n\")?;\n   208→        }\n   209→        writeln!(file, \"{}\", line)?;\n   210→        file.sync_all()?;\n   211→        Ok(())\n   212→    }\n   213→\n   214→    fn write_create_new(path: &Path, contents: &str) -> AppResult<()> {\n   215→        let parent = path.parent().ok_or_else(|| {\n   216→            AppError::Io(std::io::Error::new(\n   217→                std::io::ErrorKind::InvalidInput,\n   218→                format!(\"path '{}' has no parent directory\", path.display()),\n   219→            ))\n   220→        })?;\n   221→        fs::create_dir_all(parent)?;\n   222→\n   223→        let timestamp = SystemTime::now()\n   224→            .duration_since(UNIX_EPOCH)\n   225→            .map(|duration| duration.as_nanos())\n   226→            .unwrap_or_default();\n   227→        let temp_path = parent.join(format!(\n   228→            \".{}.{}.{}.tmp\",\n   229→            path.file_name()\n   230→                .and_then(|value| value.to_str())\n   231→                .unwrap_or(\"workspace\"),\n   232→            std::process::id(),\n   233→            timestamp\n   234→        ));\n   235→\n   236→        let mut file = OpenOptions::new()\n   237→            .create_new(true)\n   238→            .write(true)\n   239→            .open(&temp_path)?;\n   240→        file.write_all(contents.as_bytes())?;\n   241→        file.sync_all()?;\n   242→        drop(file);\n   243→\n   244→        match fs::hard_link(&temp_path, path) {\n   245→            Ok(()) => {\n   246→                let _ = fs::remove_file(&temp_path);\n   247→                Ok(())\n   248→            }\n   249→            Err(error) => {\n   250→                let _ = fs::remove_file(&temp_path);\n   251→                Err(error.into())\n   252→            }\n   253→        }\n   254→    }\n   255→}\n   256→\n   257→/// Filesystem-backed implementation of `ProjectStorePort`.\n   258→pub struct FsProjectStore;\n   259→\n   260→impl ProjectStorePort for FsProjectStore {\n   261→    fn project_exists(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<bool> {\n   262→        let project_root = FileSystem::project_root(base_dir, project_id);\n   263→        if !project_root.is_dir() {\n   264→            return Ok(false);\n   265→        }\n   266→        if !project_root.join(PROJECT_CONFIG_FILE).is_file() {\n   267→            return Err(AppError::CorruptRecord {\n   268→                file: format!(\"projects/{}/project.toml\", project_id),\n   269→                details: \"project directory exists but canonical project.toml is missing\"\n   270→                    .to_owned(),\n   271→            });\n   272→        }\n   273→        Ok(true)\n   274→    }\n   275→\n   276→    fn read_project_record(\n   277→        &self,\n   278→        base_dir: &Path,\n   279→        project_id: &ProjectId,\n   280→    ) -> AppResult<ProjectRecord> {\n   281→        let project_root = FileSystem::project_root(base_dir, project_id);\n   282→        let path = project_root.join(PROJECT_CONFIG_FILE);\n   283→        let raw = fs::read_to_string(&path).map_err(|e| {\n   284→            if e.kind() == std::io::ErrorKind::NotFound {\n   285→                if project_root.is_dir() {\n   286→                    // Directory exists but project.toml is missing — corruption\n   287→                    AppError::CorruptRecord {\n   288→                        file: format!(\"projects/{}/project.toml\", project_id),\n   289→                        details: \"project directory exists but canonical project.toml is missing\"\n   290→                            .to_owned(),\n   291→                    }\n   292→                } else {\n   293→                    AppError::ProjectNotFound {\n   294→                        project_id: project_id.to_string(),\n   295→                    }\n   296→                }\n   297→            } else {\n   298→                e.into()\n   299→            }"}]},"parent_tool_use_id":"toolu_01M4SZzK316UaJNgGSvtJ7TQ","session_id":"2cdec833-d9a4-4fe7-8fdf-432611cd39d7","uuid":"afa5bf41-f0ea-4bf7-828f-d35b9ea41bc4"}
