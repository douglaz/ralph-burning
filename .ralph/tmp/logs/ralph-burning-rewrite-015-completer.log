{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_018ofhG2vipvaE3hy6Vc5siv","type":"tool_result","content":"     1→use std::collections::HashMap;\n     2→use std::time::{Duration, Instant};\n     3→\n     4→use crate::shared::error::{AppError, AppResult};\n     5→\n     6→use super::model::{ConformanceReport, ScenarioMeta, ScenarioOutcome, ScenarioResult};\n     7→\n     8→/// Type alias for a scenario executor function.\n     9→pub type ScenarioExecutor = Box<dyn Fn() -> Result<(), String> + Send + Sync>;\n    10→\n    11→/// Validate that the registry and discovered scenarios are in one-to-one correspondence.\n    12→pub fn validate_registry(\n    13→    scenarios: &[ScenarioMeta],\n    14→    registry: &HashMap<String, ScenarioExecutor>,\n    15→) -> AppResult<()> {\n    16→    let mut errors = Vec::new();\n    17→\n    18→    // Check every discovered scenario has a registered executor\n    19→    for scenario in scenarios {\n    20→        if !registry.contains_key(&scenario.id) {\n    21→            errors.push(format!(\n    22→                \"discovered scenario '{}' ({}) has no registered executor\",\n    23→                scenario.id, scenario.source_file\n    24→            ));\n    25→        }\n    26→    }\n    27→\n    28→    // Check every registered executor maps to a discovered scenario\n    29→    let discovered_ids: std::collections::HashSet<&str> =\n    30→        scenarios.iter().map(|s| s.id.as_str()).collect();\n    31→\n    32→    let mut orphan_ids: Vec<&str> = registry\n    33→        .keys()\n    34→        .filter(|id| !discovered_ids.contains(id.as_str()))\n    35→        .map(|s| s.as_str())\n    36→        .collect();\n    37→    orphan_ids.sort();\n    38→\n    39→    for id in orphan_ids {\n    40→        errors.push(format!(\n    41→            \"registered executor '{id}' has no corresponding discovered scenario\"\n    42→        ));\n    43→    }\n    44→\n    45→    if !errors.is_empty() {\n    46→        return Err(AppError::ConformanceRegistryDrift {\n    47→            details: errors.join(\"; \"),\n    48→        });\n    49→    }\n    50→\n    51→    Ok(())\n    52→}\n    53→\n    54→/// Resolve the filter against discovered scenarios.\n    55→///\n    56→/// Returns the filtered subset in discovery order, or an error for unknown IDs.\n    57→pub fn resolve_filter<'a>(\n    58→    scenarios: &'a [ScenarioMeta],\n    59→    filter: &str,\n    60→) -> AppResult<Vec<&'a ScenarioMeta>> {\n    61→    let matched: Vec<&ScenarioMeta> = scenarios.iter().filter(|s| s.id == filter).collect();\n    62→\n    63→    if matched.is_empty() {\n    64→        return Err(AppError::ConformanceFilterFailed {\n    65→            scenario_id: filter.to_owned(),\n    66→        });\n    67→    }\n    68→\n    69→    Ok(matched)\n    70→}\n    71→\n    72→/// Execute selected scenarios with fail-fast semantics.\n    73→///\n    74→/// Runs scenarios in the order given. On the first failure, stops immediately,\n    75→/// marks remaining scenarios as not-run, and returns the full report.\n    76→pub fn run_scenarios(\n    77→    selected: &[&ScenarioMeta],\n    78→    registry: &HashMap<String, ScenarioExecutor>,\n    79→) -> ConformanceReport {\n    80→    let wall_start = Instant::now();\n    81→    let total = selected.len();\n    82→    let mut results = Vec::with_capacity(total);\n    83→    let mut passed = 0usize;\n    84→    let mut failed = 0usize;\n    85→    let mut hit_failure = false;\n    86→\n    87→    for (idx, scenario) in selected.iter().enumerate() {\n    88→        if hit_failure {\n    89→            // Mark remaining as not-run\n    90→            results.push(ScenarioResult {\n    91→                id: scenario.id.clone(),\n    92→                outcome: ScenarioOutcome::NotRun,\n    93→                duration: Duration::ZERO,\n    94→            });\n    95→            continue;\n    96→        }\n    97→\n    98→        let executor = registry.get(&scenario.id).expect(\"validated registry\");\n    99→\n   100→        let scenario_start = Instant::now();\n   101→\n   102→        // Test-only seam: force a specific executor to fail for CLI fail-fast testing.\n   103→        let forced_fail = std::env::var(\"RALPH_BURNING_TEST_CONFORMANCE_FAIL_EXECUTOR\")\n   104→            .ok()\n   105→            .map_or(false, |id| id == scenario.id);\n   106→\n   107→        // Execute with panic catching for isolation\n   108→        let exec_result = if forced_fail {\n   109→            Ok(Err(\"forced failure via RALPH_BURNING_TEST_CONFORMANCE_FAIL_EXECUTOR\".to_owned()))\n   110→        } else {\n   111→            std::panic::catch_unwind(std::panic::AssertUnwindSafe(|| executor()))\n   112→        };\n   113→        let scenario_duration = scenario_start.elapsed();\n   114→\n   115→        match exec_result {\n   116→            Ok(Ok(())) => {\n   117→                eprintln!(\n   118→                    \"  [{}/{}] {} ... PASS ({:.2}s)\",\n   119→                    idx + 1,\n   120→                    total,\n   121→                    scenario.id,\n   122→                    scenario_duration.as_secs_f64()\n   123→                );\n   124→                results.push(ScenarioResult {\n   125→                    id: scenario.id.clone(),\n   126→                    outcome: ScenarioOutcome::Passed,\n   127→                    duration: scenario_duration,\n   128→                });\n   129→                passed += 1;\n   130→            }\n   131→            Ok(Err(reason)) => {\n   132→                eprintln!(\n   133→                    \"  [{}/{}] {} ... FAIL ({:.2}s)\",\n   134→                    idx + 1,\n   135→                    total,\n   136→                    scenario.id,\n   137→                    scenario_duration.as_secs_f64()\n   138→                );\n   139→                eprintln!(\"    Reason: {reason}\");\n   140→                results.push(ScenarioResult {\n   141→                    id: scenario.id.clone(),\n   142→                    outcome: ScenarioOutcome::Failed(reason),\n   143→                    duration: scenario_duration,\n   144→                });\n   145→                failed += 1;\n   146→                hit_failure = true;\n   147→            }\n   148→            Err(panic_info) => {\n   149→                let reason = if let Some(msg) = panic_info.downcast_ref::<String>() {\n   150→                    msg.clone()\n   151→                } else if let Some(msg) = panic_info.downcast_ref::<&str>() {\n   152→                    msg.to_string()\n   153→                } else {\n   154→                    \"panic (no message)\".to_owned()\n   155→                };\n   156→                eprintln!(\n   157→                    \"  [{}/{}] {} ... PANIC ({:.2}s)\",\n   158→                    idx + 1,\n   159→                    total,\n   160→                    scenario.id,\n   161→                    scenario_duration.as_secs_f64()\n   162→                );\n   163→                eprintln!(\"    Reason: {reason}\");\n   164→                results.push(ScenarioResult {\n   165→                    id: scenario.id.clone(),\n   166→                    outcome: ScenarioOutcome::Failed(format!(\"panic: {reason}\")),\n   167→                    duration: scenario_duration,\n   168→                });\n   169→                failed += 1;\n   170→                hit_failure = true;\n   171→            }\n   172→        }\n   173→    }\n   174→\n   175→    let not_run = total - passed - failed;\n   176→\n   177→    ConformanceReport {\n   178→        selected: total,\n   179→        passed,\n   180→        failed,\n   181→        not_run,\n   182→        wall_clock: wall_start.elapsed(),\n   183→        results,\n   184→    }\n   185→}\n   186→"}]},"parent_tool_use_id":"toolu_01Dr7L17oHNzJDJZ2NjoGq1U","session_id":"2cdec833-d9a4-4fe7-8fdf-432611cd39d7","uuid":"786c4ba7-1e51-4117-8d24-f8c513477ff4"}
