le = format!(\n  1074→                \"daemon/tasks/{}\",\n  1075→                path.file_name().unwrap_or_default().to_string_lossy()\n  1076→            );\n  1077→            tasks.push(Self::read_json_file(&path, file)?);\n  1078→        }\n  1079→\n  1080→        tasks.sort_by(|a: &DaemonTask, b: &DaemonTask| {\n  1081→            a.status\n  1082→                .is_terminal()\n  1083→                .cmp(&b.status.is_terminal())\n  1084→                .then_with(|| a.created_at.cmp(&b.created_at))\n  1085→                .then_with(|| a.task_id.cmp(&b.task_id))\n  1086→        });\n  1087→        Ok(tasks)\n  1088→    }\n  1089→\n  1090→    fn read_task(&self, base_dir: &Path, task_id: &str) -> AppResult<DaemonTask> {\n  1091→        Self::read_json_file(\n  1092→            &Self::task_path(base_dir, task_id),\n  1093→            format!(\"daemon/tasks/{task_id}.json\"),\n  1094→        )\n  1095→    }\n  1096→\n  1097→    fn create_task(&self, base_dir: &Path, task: &DaemonTask) -> AppResult<()> {\n  1098→        let contents = serde_json::to_string_pretty(task)?;\n  1099→        FileSystem::write_create_new(&Self::task_path(base_dir, &task.task_id), &contents)\n  1100→    }\n  1101→\n  1102→    fn write_task(&self, base_dir: &Path, task: &DaemonTask) -> AppResult<()> {\n  1103→        let contents = serde_json::to_string_pretty(task)?;\n  1104→        FileSystem::write_atomic(&Self::task_path(base_dir, &task.task_id), &contents)\n  1105→    }\n  1106→\n  1107→    fn list_leases(&self, base_dir: &Path) -> AppResult<Vec<WorktreeLease>> {\n  1108→        let dir = Self::leases_dir(base_dir);\n  1109→        if !dir.is_dir() {\n  1110→            return Ok(Vec::new());\n  1111→        }\n  1112→\n  1113→        let mut leases = Vec::new();\n  1114→        for entry in fs::read_dir(&dir)? {\n  1115→            let entry = entry?;\n  1116→            let path = entry.path();\n  1117→            if !path.extension().is_some_and(|ext| ext == \"json\") {\n  1118→                continue;\n  1119→            }\n  1120→            let file = format!(\n  1121→                \"daemon/leases/{}\",\n  1122→                path.file_name().unwrap_or_default().to_string_lossy()\n  1123→            );\n  1124→            leases.push(Self::read_json_file(&path, file)?);\n  1125→        }\n  1126→        leases.sort_by_key(|lease: &WorktreeLease| lease.acquired_at);\n  1127→        Ok(leases)\n  1128→    }\n  1129→\n  1130→    fn read_lease(&self, base_dir: &Path, lease_id: &str) -> AppResult<WorktreeLease> {\n  1131→        Self::read_json_file(\n  1132→            &Self::lease_path(base_dir, lease_id),\n  1133→            format!(\"daemon/leases/{lease_id}.json\"),\n  1134→        )\n  1135→    }\n  1136→\n  1137→    fn write_lease(&self, base_dir: &Path, lease: &WorktreeLease) -> AppResult<()> {\n  1138→        let contents = serde_json::to_string_pretty(lease)?;\n  1139→        FileSystem::write_atomic(&Self::lease_path(base_dir, &lease.lease_id), &contents)\n  1140→    }\n  1141→\n  1142→    fn remove_lease(&self, base_dir: &Path, lease_id: &str) -> AppResult<()> {\n  1143→        match fs::remove_file(Self::lease_path(base_dir, lease_id)) {\n  1144→            Ok(()) => Ok(()),\n  1145→            Err(error) if error.kind() == std::io::ErrorKind::NotFound => Ok(()),\n  1146→            Err(error) => Err(error.into()),\n  1147→        }\n  1148→    }\n  1149→\n  1150→    fn read_daemon_journal(&self, base_dir: &Path) -> AppResult<Vec<DaemonJournalEvent>> {\n  1151→        let path = Self::daemon_journal_path(base_dir);\n  1152→        match fs::read_to_string(&path) {\n  1153→            Ok(contents) => {\n  1154→                let mut events = Vec::new();\n  1155→                for line in contents.lines() {\n  1156→                    let trimmed = line.trim();\n  1157→                    if trimmed.is_empty() {\n  1158→                        continue;\n  1159→                    }\n  1160→                    let event: DaemonJournalEvent =\n  1161→                        serde_json::from_str(trimmed).map_err(|error| AppError::CorruptRecord {\n  1162→                            file: \"daemon/journal.ndjson\".to_owned(),\n  1163→                            details: error.to_string(),\n  1164→                        })?;\n  1165→                    events.push(event);\n  1166→                }\n  1167→                Ok(events)\n  1168→            }\n  1169→            Err(error) if error.kind() == std::io::ErrorKind::NotFound => Ok(Vec::new()),\n  1170→            Err(error) => Err(error.into()),\n  1171→        }\n  1172→    }\n  1173→\n  1174→    fn append_daemon_journal_event(\n  1175→        &self,\n  1176→        base_dir: &Path,\n  1177→        event: &DaemonJournalEvent,\n  1178→    ) -> AppResult<()> {\n  1179→        let line = serde_json::to_string(event)?;\n  1180→        FileSystem::append_line(&Self::daemon_journal_path(base_dir), &line)\n  1181→    }\n  1182→\n  1183→    fn acquire_writer_lock(\n  1184→        &self,\n  1185→        base_dir: &Path,\n  1186→        project_id: &ProjectId,\n  1187→        lease_id: &str,\n  1188→    ) -> AppResult<()> {\n  1189→        let path = Self::writer_lock_path(base_dir, project_id);\n  1190→        match FileSystem::write_create_new(&path, lease_id) {\n  1191→            Ok(()) => Ok(()),\n  1192→            Err(AppError::Io(error)) if error.kind() == std::io::ErrorKind::AlreadyExists => {\n  1193→                Err(AppError::ProjectWriterLockHeld {\n  1194→                    project_id: project_id.to_string(),\n  1195→                })\n  1196→            }\n  1197→            Err(error) => Err(error),\n  1198→        }\n  1199→    }\n  1200→\n  1201→    fn release_writer_lock(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<()> {\n  1202→        match fs::remove_file(Self::writer_lock_path(base_dir, project_id)) {\n  1203→            Ok(()) => Ok(()),\n  1204→            Err(error) if error.kind() == std::io::ErrorKind::NotFound => Ok(()),\n  1205→            Err(error) => Err(error.into()),\n  1206→        }\n  1207→    }\n  1208→}\n  1209→\n  1210→// ── Requirements drafting filesystem store ──────────────────────────────────\n  1211→\n  1212→use crate::contexts::requirements_drafting::model::{\n  1213→    PersistedAnswers, RequirementsJournalEvent, RequirementsRun,\n  1214→};\n  1215→use crate::contexts::requirements_drafting::service::RequirementsStorePort;\n  1216→\n  1217→const REQUIREMENTS_DIR: &str = \"requirements\";\n  1218→\n  1219→/// Required subdirectories inside a requirements run.\n  1220→const REQUIREMENTS_RUN_SUBDIRS: &[&str] = &[\n  1221→    \"history/payloads\",\n  1222→    \"history/artifacts\",\n  1223→    \"runtime/logs\",\n  1224→    \"runtime/backend\",\n  1225→    \"runtime/temp\",\n  1226→    \"seed\",\n  1227→];\n  1228→\n  1229→/// Filesystem-backed implementation of `RequirementsStorePort`."}]},"parent_tool_use_id":"toolu_01M4SZzK316UaJNgGSvtJ7TQ","session_id":"2cdec833-d9a4-4fe7-8fdf-432611cd39d7","uuid":"0ee14399-2797-4ed8-912e-2dfd6b7f24c5"}
