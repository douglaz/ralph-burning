{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Txk8RQWMnXYBnYgCvTJGGe","type":"tool_result","content":"     1→use chrono::{DateTime, Utc};\n     2→use serde::{Deserialize, Serialize};\n     3→\n     4→use crate::shared::domain::{FlowPreset, ProjectId, StageCursor, StageId};\n     5→\n     6→/// Immutable project metadata persisted in `project.toml`.\n     7→#[derive(Debug, Clone, PartialEq, Serialize, Deserialize)]\n     8→pub struct ProjectRecord {\n     9→    pub id: ProjectId,\n    10→    pub name: String,\n    11→    pub flow: FlowPreset,\n    12→    pub prompt_reference: String,\n    13→    pub prompt_hash: String,\n    14→    pub created_at: DateTime<Utc>,\n    15→    pub status_summary: ProjectStatusSummary,\n    16→}\n    17→\n    18→#[derive(Debug, Clone, Copy, PartialEq, Eq, Serialize, Deserialize)]\n    19→#[serde(rename_all = \"snake_case\")]\n    20→pub enum ProjectStatusSummary {\n    21→    Created,\n    22→    Active,\n    23→    Completed,\n    24→    Failed,\n    25→}\n    26→\n    27→/// Canonical run state persisted in `run.json`.\n    28→/// This is the single source of truth for run progression - never inferred from artifacts.\n    29→#[derive(Debug, Clone, PartialEq, Serialize, Deserialize)]\n    30→pub struct RunSnapshot {\n    31→    pub active_run: Option<ActiveRun>,\n    32→    pub status: RunStatus,\n    33→    pub cycle_history: Vec<CycleHistoryEntry>,\n    34→    pub completion_rounds: u32,\n    35→    pub rollback_point_meta: RollbackPointMeta,\n    36→    pub amendment_queue: AmendmentQueueState,\n    37→    pub status_summary: String,\n    38→}\n    39→\n    40→impl RunSnapshot {\n    41→    pub fn initial() -> Self {\n    42→        Self {\n    43→            active_run: None,\n    44→            status: RunStatus::NotStarted,\n    45→            cycle_history: Vec::new(),\n    46→            completion_rounds: 0,\n    47→            rollback_point_meta: RollbackPointMeta::default(),\n    48→            amendment_queue: AmendmentQueueState::default(),\n    49→            status_summary: \"not started\".to_owned(),\n    50→        }\n    51→    }\n    52→\n    53→    pub fn has_active_run(&self) -> bool {\n    54→        self.active_run.is_some()\n    55→    }\n    56→\n    57→    /// Semantic validation of run snapshot consistency.\n    58→    /// Returns `Err` with a description if status and active_run are inconsistent.\n    59→    pub fn validate_semantics(&self) -> Result<(), String> {\n    60→        match (&self.status, &self.active_run) {\n    61→            // Running requires an active run cursor.\n    62→            (RunStatus::Running, None) => Err(\n    63→                \"status is 'running' but active_run is null — inconsistent canonical state\"\n    64→                    .to_owned(),\n    65→            ),\n    66→            (RunStatus::Paused, Some(_)) => Err(\n    67→                \"status is 'paused' but active_run is present — inconsistent canonical state\"\n    68→                    .to_owned(),\n    69→            ),\n    70→            // All non-running states must not retain an active run cursor.\n    71→            (RunStatus::NotStarted, Some(_)) => Err(\n    72→                \"status is 'not_started' but active_run is present — inconsistent canonical state\"\n    73→                    .to_owned(),\n    74→            ),\n    75→            (RunStatus::Completed, Some(_)) => Err(\n    76→                \"status is 'completed' but active_run is present — inconsistent canonical state\"\n    77→                    .to_owned(),\n    78→            ),\n    79→            (RunStatus::Failed, Some(_)) => Err(\n    80→                \"status is 'failed' but active_run is present — inconsistent canonical state\"\n    81→                    .to_owned(),\n    82→            ),\n    83→            // Valid combinations:\n    84→            // NotStarted/Paused/Completed/Failed + None, Running + Some\n    85→            _ => Ok(()),\n    86→        }\n    87→    }\n    88→}\n    89→\n    90→#[derive(Debug, Clone, PartialEq, Serialize, Deserialize)]\n    91→pub struct ActiveRun {\n    92→    pub run_id: String,\n    93→    pub stage_cursor: StageCursor,\n    94→    pub started_at: DateTime<Utc>,\n    95→}\n    96→\n    97→#[derive(Debug, Clone, Copy, PartialEq, Eq, Serialize, Deserialize)]\n    98→#[serde(rename_all = \"snake_case\")]\n    99→pub enum RunStatus {\n   100→    NotStarted,\n   101→    Running,\n   102→    Paused,\n   103→    Completed,\n   104→    Failed,\n   105→}\n   106→\n   107→impl RunStatus {\n   108→    /// Human-readable status string for CLI output.\n   109→    pub fn display_str(self) -> &'static str {\n   110→        match self {\n   111→            Self::NotStarted => \"not started\",\n   112→            Self::Running => \"running\",\n   113→            Self::Paused => \"paused\",\n   114→            Self::Completed => \"completed\",\n   115→            Self::Failed => \"failed\",\n   116→        }\n   117→    }\n   118→}\n   119→\n   120→impl std::fmt::Display for RunStatus {\n   121→    fn fmt(&self, f: &mut std::fmt::Formatter<'_>) -> std::fmt::Result {\n   122→        f.write_str(self.display_str())\n   123→    }\n   124→}\n   125→\n   126→/// A single entry in the cycle history tracking progression through work cycles.\n   127→#[derive(Debug, Clone, PartialEq, Serialize, Deserialize)]\n   128→pub struct CycleHistoryEntry {\n   129→    pub cycle: u32,\n   130→    pub stage_id: StageId,\n   131→    pub started_at: DateTime<Utc>,\n   132→    pub completed_at: Option<DateTime<Utc>>,\n   133→}\n   134→\n   135→/// Rollback-point metadata tracked in the canonical run snapshot.\n   136→#[derive(Debug, Clone, Default, PartialEq, Serialize, Deserialize)]\n   137→pub struct RollbackPointMeta {\n   138→    pub last_rollback_id: Option<String>,\n   139→    pub rollback_count: u32,\n   140→}\n   141→\n   142→/// A typed queued amendment record for durable persistence.\n   143→#[derive(Debug, Clone, PartialEq, Serialize, Deserialize)]\n   144→pub struct QueuedAmendment {\n   145→    pub amendment_id: String,\n   146→    pub source_stage: StageId,\n   147→    pub source_cycle: u32,\n   148→    pub source_completion_round: u32,\n   149→    pub body: String,\n   150→    pub created_at: DateTime<Utc>,"}]},"parent_tool_use_id":"toolu_01M4SZzK316UaJNgGSvtJ7TQ","session_id":"2cdec833-d9a4-4fe7-8fdf-432611cd39d7","uuid":"a9690700-8d28-4cbe-a306-4046dbecf31f"}
