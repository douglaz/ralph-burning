   .open(&temp_path)?;\n   240→        file.write_all(contents.as_bytes())?;\n   241→        file.sync_all()?;\n   242→        drop(file);\n   243→\n   244→        match fs::hard_link(&temp_path, path) {\n   245→            Ok(()) => {\n   246→                let _ = fs::remove_file(&temp_path);\n   247→                Ok(())\n   248→            }\n   249→            Err(error) => {"}]},"parent_tool_use_id":"toolu_01CbvMMytrEsep8F3HzfNTmM","session_id":"2cdec833-d9a4-4fe7-8fdf-432611cd39d7","uuid":"bb474bf2-6ed0-4109-86ee-1ae69e0e5f57"}
