 PartialEq, Serialize, Deserialize)]\n   197→pub struct PayloadRecord {\n   198→    pub payload_id: String,\n   199→    pub stage_id: StageId,\n   200→    pub cycle: u32,\n   201→    pub attempt: u32,\n   202→    pub created_at: DateTime<Utc>,\n   203→    pub payload: serde_json::Value,\n   204→}\n   205→\n   206→/// A durable history artifact record stored in `history/artifacts/`.\n   207→#[derive(Debug, Clone, PartialEq, Serialize, Deserialize)]\n   208→pub struct ArtifactRecord {\n   209→    pub artifact_id: String,\n   210→    pub payload_id: String,\n   211→    pub stage_id: StageId,\n   212→    pub created_at: DateTime<Utc>,\n   213→    pub content: String,\n   214→}\n   215→\n   216→/// A runtime log entry stored in `runtime/logs/`.\n   217→#[derive(Debug, Clone, PartialEq, Serialize, Deserialize)]\n   218→pub struct RuntimeLogEntry {\n   219→    pub timestamp: DateTime<Utc>,\n   220→    pub level: LogLevel,\n   221→    pub source: String,\n   222→    pub message: String,\n   223→}\n   224→\n   225→#[derive(Debug, Clone, Copy, PartialEq, Eq, Serialize, Deserialize)]\n   226→#[serde(rename_all = \"snake_case\")]\n   227→pub enum LogLevel {\n   228→    Debug,\n   229→    Info,\n   230→    Warn,\n   231→    Error,\n   232→}\n   233→\n   234→/// Rollback metadata stored in `rollback/`.\n   235→#[derive(Debug, Clone, PartialEq, Serialize, Deserialize)]\n   236→pub struct RollbackPoint {\n   237→    pub rollback_id: String,\n   238→    pub created_at: DateTime<Utc>,\n   239→    pub stage_id: StageId,\n   240→    pub cycle: u32,\n   241→    #[serde(default, skip_serializing_if = \"Option::is_none\")]\n   242→    pub git_sha: Option<String>,\n   243→    pub run_snapshot: RunSnapshot,\n   244→}\n   245→\n   246→/// Empty session store for `sessions.json`.\n   247→#[derive(Debug, Clone, PartialEq, Serialize, Deserialize)]\n   248→pub struct SessionStore {\n   249→    pub sessions: Vec<serde_json::Value>,\n   250→}\n   251→\n   252→impl SessionStore {\n   253→    pub fn