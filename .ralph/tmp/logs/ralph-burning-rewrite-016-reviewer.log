for_shutdown_signal() -> AppResult<()> {\n    #[cfg(unix)]\n    {\n        let mut sigterm =\n            tokio::signal::unix::signal(tokio::signal::unix::SignalKind::terminate())?;\n        tokio::select! {\n            _ = tokio::signal::ctrl_c() => Ok(()),\n            _ = sigterm.recv() => Ok(()),\n        }\n    }\n\n","exit_code":0,"status":"completed"}}
