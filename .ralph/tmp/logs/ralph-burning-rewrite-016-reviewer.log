tatus::Failed => {\nralph-burning-rewrite/src/contexts/requirements_drafting/service.rs:380:        let failure_summary = if run.status == RequirementsStatus::Failed {\nralph-burning-rewrite/src/contexts/requirements_drafting/service.rs:386:        let seed_prompt_path = if run.status == RequirementsStatus::Completed {\nralph-burning-rewrite/src/contexts/requirements_drafting/service.rs:420:            RequirementsStatus::AwaitingAnswers => {\nralph-burning-rewrite/src/contexts/requirements_drafting/service.rs:431:            RequirementsStatus::Failed\nralph-burning-rewrite/src/contexts/requirements_drafting/service.rs:478:        run.status = RequirementsStatus::Drafting;\nralph-burning-rewrite/src/contexts/requirements_drafting/service.rs:816:        run.status = RequirementsStatus::Completed;\nralph-burning-rewrite/src/contexts/requirements_drafting/service.rs:939:        run.status = RequirementsStatus::Failed;\nralph-burning-rewrite/src/contexts/requirements_drafting/service.rs:1006:pub fn is_requirements_run_complete(\nralph-burning-rewrite/src/contexts/requirements_drafting/service.rs:1012:    Ok(run.status == RequirementsStatus::Completed)\nralph-burning-rewrite/src/contexts/requirements_drafting/service.rs:1015:/// Extract seed handoff data from a completed requirements run.\nralph-burning-rewrite/src/contexts/requirements_drafting/service.rs:1017:pub fn extract_seed_handoff(\nralph-burning-rewrite/src/contexts/requirements_drafting/service.rs:1023:    if run.status != RequirementsStatus::Completed {\n","exit_code":0,"status":"completed"}}
