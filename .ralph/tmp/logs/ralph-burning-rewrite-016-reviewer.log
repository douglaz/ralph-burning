et result2 = DaemonTaskService::create_task_from_watched_issue(\n   334\t        &store,\n   335\t        temp.path(),\n   336\t        &routing,\n   337\t        FlowPreset::Standard,\n   338\t        &issue2,\n   339\t        DispatchMode::Workflow,\n   340\t    )\n   341\t    .expect(\"create second for new revision\");\n   342\t    assert!(result2.is_some());\n   343\t}\n   344\t\n   345\t#[test]\n   346\tfn watched_issue_different_revision_while_non_terminal_fails() {\n   347\t    let store = FsDaemonStore;\n   348\t    let temp = tempdir().expect(\"tempdir\");\n   349\t    let routing = RoutingEngine::new();\n   350\t\n   351\t    let issue1 = WatchedIssueMeta {\n   352\t        issue_ref: \"org/repo#60\".to_owned(),\n   353\t        source_revision: \"aaa11111\".to_owned(),\n   354\t        title: \"First\".to_owned(),\n   355\t        body: \"Body\".to_owned(),\n   356\t        labels: vec![],\n   357\t        routing_command: None,\n   358\t    };\n   359\t\n   360\t    DaemonTaskService::create_task_from_watched_issue(\n   361\t        &store,\n   362\t        temp.path(),\n   363\t        &routing,\n   364\t        FlowPreset::Standard,\n   365\t        &issue1,\n   366\t        DispatchMode::Workflow,\n   367\t    )\n   368\t    .expect(\"create first\");\n   369\t\n   370\t    let issue2 = WatchedIssueMeta {\n   371\t        issue_ref: \"org/repo#60\".to_owned(),\n   372\t        source_revision: \"bbb22222\".to_owned(),\n   373\t        title: \"Second\".to_owned(),\n   374\t        body: \"Body\".to_owned(),\n   375\t        labels: vec![],\n   376\t        routing_command: None,\n   377\t    };\n   378\t\n   379\t    let err = DaemonTaskService::create_task_from_watched_issue(\n   380\t        &store,\n   381\t        temp.path(),\n   382\t        &routing,\n   383\t        FlowPreset::Standard,\n   384\t        &issue2,\n   385\t        DispatchMode::Workflow,\n   386\t    )\n   387\t    .expect_err(\"should reject different revision while non-terminal\");\n   388\t\n   389\t    assert!(matches!(err, AppError::DuplicateWatchedIssue { .. }));\n   390\t}\n   391\t\n   392\t#[test]\n   393\tfn waiting_for_requirements_resume_transitions() {\n   394\t    let store = FsDaemonStore;\n   395\t    let temp = tempdir().expect(\"tempdir\");\n   396\t\n   397\t    let mut task = sample_task();\n   398\t    task.status = TaskStatus::Active;\n   399\t    store.create_task(temp.path(), &task).expect(\"persist task\");\n   400\t\n   401\t    // Transition to waiting\n   402\t    let waiting = DaemonTaskService::mark_waiting_for_requirements(\n   403\t        &store,\n   404\t        temp.path(),\n   405\t        &task.task_id,\n   406\t        \"req-20260313\",\n   407\t    )\n   408\t    .expect(\"mark waiting\");\n   409\t    assert_eq!(TaskStatus::WaitingForRequirements, waiting.status);\n   410\t    assert_eq!(Some(\"req-20260313\".to_owned()), waiting.requirements_run_id);\n   411\t    assert!(waiting.lease_id.is_none());\n   412\t\n   413\t    // Resume from waiting\n   414\t    let resumed = DaemonTaskService::resume_from_waiting(&store, temp.path(), &task.task_id)\n   415\t        .expect(\"resume from waiting\");\n   416\t    assert_eq!(TaskStatus::Pending, resumed.status);\n   417\t    assert_eq!(DispatchMode::Workflow, resumed.dispatch_mode);\n   418\t}\n   419\t\n   420\t#[test]\n   421\tfn resume_from_non_waiting_state_fails() {\n   422\t    let store = FsDaemonStore;\n   423\t    let temp = tempdir().expect(\"tempdir\");\n   424\t\n   425\t    let task = sample_task();\n   426\t    store.create_task(temp.path(), &task).expect(\"persist task\");\n   427\t\n   428\t    let err = DaemonTaskService::resume_from_waiting(&store, temp.path(), &task.task_id)\n   429\t        .expect_err(\"should fail for pending task\");\n   430\t    assert!(matches!(err, AppError::TaskStateTransitionInvalid { .. }));\n","exit_code":0,"status":"completed"}}
