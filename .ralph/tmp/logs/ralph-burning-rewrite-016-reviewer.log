l {\n         match (self, next) {\n             (Self::Pending, Self::Claimed | Self::Failed) => true,\n             (Self::Claimed, Self::Active | Self::Failed | Self::Aborted) => true,\n-            (Self::Active, Self::Completed | Self::Failed | Self::Aborted) => true,\n+            (Self::Active, Self::Completed | Self::Failed | Self::Aborted | Self::WaitingForRequirements) => true,\n+            (Self::WaitingForRequirements, Self::Pending | Self::Failed | Self::Aborted) => true,\n             (Self::Failed, Self::Pending) => true,\n             _ if self == next => true,\n             _ => false,\n@@ -182,4 +244,8 @@ pub enum DaemonJournalEventType {\n     LeaseAcquired,\n     LeaseReleased,\n     ReconciliationRun,\n+    WatcherIngestion,\n+    RequirementsHandoff,\n+    RequirementsWaiting,\n+    RequirementsResumed,\n }\n","exit_code":0,"status":"completed"}}
