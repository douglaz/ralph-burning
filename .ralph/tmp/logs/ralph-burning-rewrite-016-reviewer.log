ePort,\n   133\t    Q: RequirementsStorePort,\n   134\t{\n   135\t    /// Execute `requirements draft --idea \"<text>\"`.\n   136\t    pub async fn draft(\n   137\t        &self,\n   138\t        base_dir: &Path,\n   139\t        idea: &str,\n   140\t        now: DateTime<Utc>,\n   141\t    ) -> AppResult<String> {\n   142\t        let run_id = generate_run_id(now);\n   143\t        let mut run = RequirementsRun::new_draft(run_id.clone(), idea.to_owned(), now);\n   144\t\n   145\t        // Create run directory and initial state\n   146\t        self.store.create_run_dir(base_dir, &run_id)?;\n   147\t        self.store.write_run(base_dir, &run_id, &run)?;\n   148\t\n   149\t        let created_event = journal_event(1, now, RequirementsJournalEventType::RunCreated, &run);\n   150\t        if let Err(e) = self\n   151\t            .store\n   152\t            .append_journal_event(base_dir, &run_id, &created_event)\n   153\t        {\n   154\t            self.fail_run(\n   155\t                base_dir,\n   156\t                &mut run,\n   157\t                1,\n   158\t                &format!(\"journal append failed for run_created: {e}\"),\n   159\t            )\n   160\t            .await?;\n   161\t            return Err(e);\n   162\t        }\n   163\t\n   164\t        // Generate questions\n   165\t        let run_root = requirements_run_root(base_dir, &run_id);\n   166\t        let question_result = self\n   167\t            .invoke_stage(\n   168\t                &run_root,\n   169\t                RequirementsStageId::QuestionSet,\n   170\t                BackendRole::Planner,\n   171\t                &format!(\"Generate clarifying questions for the following idea:\\n\\n{idea}\"),\n   172\t            )\n   173\t            .await;\n   174\t\n   175\t        match question_result {\n   176\t            Ok(bundle) => {\n   177\t                let RequirementsPayload::QuestionSet(ref qs) = bundle.payload else {\n   178\t                    unreachable!(\"QuestionSet contract always returns QuestionSet payload\");\n   179\t                };\n   180\t\n   181\t                let payload_id = format!(\"{run_id}-qs-1\");\n   182\t                let artifact_id = format!(\"{run_id}-qs-art-1\");\n   183\t\n   184\t                // Persist payload and artifact atomically\n   185\t                let payload_json = serde_json::to_value(qs)?;\n   186\t                if let Err(e) = self.store.write_payload_artifact_pair_atomic(\n   187\t                    base_dir,\n   188\t                    &run_id,\n   189\t                    &payload_id,\n   190\t                    &payload_json,\n   191\t                    &artifact_id,\n   192\t                    &bundle.artifact,\n   193\t                ) {\n   194\t                    // State invariant: if payload/artifact pair fails, run must not\n   195\t                    // transition and no partial files remain (handled by atomic write).\n   196\t                    // Durably journal the failure so show() can report it.\n   197\t                    run.status = RequirementsStatus::Failed;\n   198\t                    run.status_summary = format!(\"failed: could not persist question set: {e}\");\n   199\t                    run.updated_at = Utc::now();\n   200\t                    let _ = self.store.write_run(base_dir, &run_id, &run);\n   201\t                    let fail_event =\n   202\t                        journal_event(2, Utc::now(), RequirementsJournalEventType::RunFailed, &run);\n   203\t                    let _ = self\n   204\t                        .store\n   205\t                        .append_journal_event(base_dir, &run_id, &fail_event);\n   206\t                    return Err(e);\n   207\t                }\n   208\t\n   209\t                // Record the committed question-set boundary in canonical state and\n   210\t                // journal immediately after the payload/artifact pair succeeds,\n   211\t                // before branching into a