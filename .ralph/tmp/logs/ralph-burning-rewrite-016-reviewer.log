{"type":"item.completed","item":{"id":"item_51","type":"command_execution","command":"/run/current-system/sw/bin/bash -lc \"nl -ba ralph-burning-rewrite/src/contexts/automation_runtime/watcher.rs | sed -n '1,120p'\"","aggregated_output":"     1\tuse std::path::Path;\n     2\t\n     3\tuse crate::shared::error::{AppError, AppResult};\n     4\t\n     5\tuse super::model::{DispatchMode, WatchedIssueMeta};\n     6\tuse super::routing::RoutingEngine;\n     7\tuse crate::shared::domain::FlowPreset;\n     8\t\n     9\t/// Port trait for watching external issue sources.\n    10\t///\n    11\t/// Implementations poll an external source (e.g. GitHub issues, files) and\n    12\t/// return candidate issues that should be ingested as daemon tasks.\n    13\tpub trait IssueWatcherPort {\n    14\t    /// Poll the external source and return watched issue candidates.\n    15\t    fn poll(&self, base_dir: &Path) -> AppResult<Vec<WatchedIssueMeta>>;\n    16\t}\n    17\t\n    18\t/// Parse a requirements command from issue body or routing command.\n    19\t///\n    20\t/// Accepts:\n    21\t/// - `/rb requirements draft`\n    22\t/// - `/rb requirements quick`\n    23\t///\n    24\t/// Returns `None` if the text does not contain a requirements command,\n    25\t/// allowing the caller to default to `DispatchMode::Workflow`.\n    26\tpub fn parse_requirements_command(text: &str) -> AppResult<Option<DispatchMode>> {\n    27\t    for line in text.lines() {\n    28\t        let trimmed = line.trim();\n    29\t        let tokens: Vec<&str> = trimmed.split_whitespace().collect();\n    30\t        if tokens.len() == 3\n    31\t            && matches!(tokens[0], \"/rb\" | \"rb\")\n    32\t            && tokens[1] == \"requirements\"\n    33\t        {\n    34\t            return match tokens[2] {\n    35\t                \"draft\" => Ok(Some(DispatchMode::RequirementsDraft)),\n    36\t                \"quick\" => Ok(Some(DispatchMode::RequirementsQuick)),\n    37\t                other => Err(AppError::WatcherIngestionFailed {\n    38\t                    issue_ref: trimmed.to_owned(),\n    39\t                    details: format!(\n    40\t                        \"unknown requirements subcommand '{}'; expected 'draft' or 'quick'\",\n    41\t                        other\n    42\t                    ),\n    43\t                }),\n    44\t            };\n    45\t        }\n    46\t    }\n    47\t    Ok(None)\n    48\t}\n    49\t\n    50\t/// Resolve the dispatch mode for a watched issue.\n    51\t///\n    52\t/// Checks the routing command first, then the issue body for `/rb requirements ...`.\n    53\t/// Falls back to `DispatchMode::Workflow` if no requirements command is found.\n    54\tpub fn resolve_dispatch_mode(issue: &WatchedIssueMeta) -> AppResult<DispatchMode> {\n    55\t    // Check routing command first\n    56\t    if let Some(ref cmd) = issue.routing_command {\n    57\t        if let Some(mode) = parse_requirements_command(cmd)? {\n    58\t            return Ok(mode);\n    59\t        }\n    60\t    }\n    61\t    // Check issue body\n    62\t    if let Some(mode) = parse_requirements_command(&issue.body)? {\n    63\t        return Ok(mode);\n    64\t    }\n    65\t    Ok(DispatchMode::Workflow)\n    66\t}\n    67\t\n    68\t/// Resolve flow from watched issue metadata using the routing engine.\n    69\tpub fn resolve_watched_issue_flow(\n    70\t    issue: &WatchedIssueMeta,\n    71\t    routing_engine: &RoutingEngine,\n    72\t    default_flow: FlowPreset,\n    73\t) -> AppResult<super::model::RoutingResolution> {\n    74\t    routing_engine.resolve_flow(\n    75\t        issue.routing_command.as_deref(),\n    76\t        &issue.labels,\n    77\t        default_flow,\n    78\t    )\n    79\t}\n","exit_code":0,"status":"completed"}}
