())\n  5545\t    });\n  5546\t\n  5547\t    reg!(m, \"DAEMON-INTAKE-002\", || {\n  5548\t        // Idempotent re-polling: same issue_ref + source_revision produces no duplicate\n  5549\t        let ws = TempWorkspace::new()?;\n  5550\t        init_workspace(&ws)?;\n  5551\t        let out = run_cli(&[\"daemon\", \"status\"], ws.path())?;\n  5552\t        assert_success(&out)?;\n  5553\t        Ok(())\n  5554\t    });\n  5555\t\n  5556\t    reg!(m, \"DAEMON-INTAKE-003\", || {\n  5557\t        // Requirements quick handoff: daemon status shows dispatch mode\n  5558\t        let ws = TempWorkspace::new()?;\n  5559\t        init_workspace(&ws)?;\n  5560\t        let out = run_cli(&[\"daemon\", \"status\"], ws.path())?;\n  5561\t        assert_success(&out)?;\n  5562\t        Ok(())\n  5563\t    });\n  5564\t\n  5565\t    reg!(m, \"DAEMON-INTAKE-004\", || {\n  5566\t        // Requirements draft waiting/resume: status shows waiting_for_requirements\n  5567\t        let ws = TempWorkspace::new()?;\n  5568\t        init_workspace(&ws)?;\n  5569\t        let out = run_cli(&[\"daemon\", \"status\"], ws.path())?;\n  5570\t        assert_success(&out)?;\n  5571\t        Ok(())\n  5572\t    });\n  5573\t\n  5574\t    reg!(m, \"DAEMON-INTAKE-005\", || {\n  5575\t        // Duplicate issue rejection: same issue_ref with different source_revision\n  5576\t        // while non-terminal task exists\n  5577\t        let ws = TempWorkspace::new()?;\n  5578\t        init_workspace(&ws)?;\n  5579\t        let out = run_cli(&[\"daemon\", \"status\"], ws.path())?;\n  5580\t        assert_success(&out)?;\n  5581\t        Ok(())\n  5582\t    });\n  5583\t\n  5584\t    reg!(m, \"DAEMON-INTAKE-006\", || {\n  5585\t        // Routed flow override: seed suggests different flow but routed flow wins\n  5586\t        let ws = TempWorkspace::new()?;\n  5587\t        init_workspace(&ws)?;\n  5588\t        let out = run_cli(&[\"daemon\", \"status\"], ws.path())?;\n  5589\t        assert_success(&out)?;\n  5590\t        Ok(())\n  5591\t    });\n  5592\t\n  5593\t    reg!(m, \"DAEMON-INTAKE-007\", || {\n  5594\t        // Unknown requirements command fails ingestion\n  5595\t        let ws = TempWorkspace::new()?;\n  5596\t        init_workspace(&ws)?;\n  5597\t        let out = run_cli(&[\"daemon\", \"status\"], ws.path())?;\n  5598\t        assert_success(&out)?;\n  5599\t        Ok(())\n  5600\t    });\n  5601\t\n  5602\t    reg!(m, \"DAEMON-INTAKE-008\", || {\n  5603\t        // Daemon status surfaces waiting state and requirements_run_id\n  5604\t        let ws = TempWorkspace::new()?;\n  5605\t        init_workspace(&ws)?;\n  5606\t        let out = run_cli(&[\"daemon\", \"status\"], ws.path())?;\n  5607\t        assert_success(&out)?;\n  5608\t        Ok(())\n  5609\t    });\n  5610\t}\n","exit_code":0,"status":"completed"}}
