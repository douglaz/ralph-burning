{"type":"item.completed","item":{"id":"item_108","type":"command_execution","command":"/run/current-system/sw/bin/bash -lc \"nl -ba src/contexts/conformance_spec/scenarios.rs | sed -n '5520,5695p'\"","aggregated_output":"  5520\t// ===========================================================================\n  5521\t// Daemon Issue Intake (8 scenarios)\n  5522\t// ===========================================================================\n  5523\t\n  5524\tfn register_daemon_issue_intake(m: &mut HashMap<String, ScenarioExecutor>) {\n  5525\t    reg!(m, \"DAEMON-INTAKE-001\", || {\n  5526\t        // Watcher ingestion creates a task from a watched issue\n  5527\t        use crate::adapters::fs::FsDaemonStore;\n  5528\t        use crate::contexts::automation_runtime::model::{DispatchMode, WatchedIssueMeta};\n  5529\t        use crate::contexts::automation_runtime::routing::RoutingEngine;\n  5530\t        use crate::contexts::automation_runtime::task_service::DaemonTaskService;\n  5531\t        use crate::shared::domain::FlowPreset;\n  5532\t\n  5533\t        let ws = TempWorkspace::new()?;\n  5534\t        init_workspace(&ws)?;\n  5535\t        let store = FsDaemonStore;\n  5536\t        let routing = RoutingEngine::new();\n  5537\t        let issue = WatchedIssueMeta {\n  5538\t            issue_ref: \"test/repo#1\".to_owned(),\n  5539\t            source_revision: \"abc12345\".to_owned(),\n  5540\t            title: \"Test issue\".to_owned(),\n  5541\t            body: \"Implement feature X\".to_owned(),\n  5542\t            labels: vec![],\n  5543\t            routing_command: None,\n  5544\t        };\n  5545\t\n  5546\t        let result = DaemonTaskService::create_task_from_watched_issue(\n  5547\t            &store, ws.path(), &routing, FlowPreset::Standard, &issue, DispatchMode::Workflow,\n  5548\t        ).map_err(|e| e.to_string())?;\n  5549\t        let task = result.ok_or(\"expected a task to be created\")?;\n  5550\t        if task.issue_ref != \"test/repo#1\" {\n  5551\t            return Err(format!(\"wrong issue_ref: {}\", task.issue_ref));\n  5552\t        }\n  5553\t        if task.source_revision.as_deref() != Some(\"abc12345\") {\n  5554\t            return Err(format!(\"wrong source_revision: {:?}\", task.source_revision));\n  5555\t        }\n  5556\t        if task.dispatch_mode != DispatchMode::Workflow {\n  5557\t            return Err(format!(\"wrong dispatch_mode: {}\", task.dispatch_mode));\n  5558\t        }\n  5559\t        Ok(())\n  5560\t    });\n  5561\t\n  5562\t    reg!(m, \"DAEMON-INTAKE-002\", || {\n  5563\t        // Idempotent re-polling: same issue_ref + source_revision produces no duplicate\n  5564\t        use crate::adapters::fs::FsDaemonStore;\n  5565\t        use crate::contexts::automation_runtime::model::{DispatchMode, WatchedIssueMeta};\n  5566\t        use crate::contexts::automation_runtime::routing::RoutingEngine;\n  5567\t        use crate::contexts::automation_runtime::task_service::DaemonTaskService;\n  5568\t        use crate::shared::domain::FlowPreset;\n  5569\t\n  5570\t        let ws = TempWorkspace::new()?;\n  5571\t        init_workspace(&ws)?;\n  5572\t        let store = FsDaemonStore;\n  5573\t        let routing = RoutingEngine::new();\n  5574\t        let issue = WatchedIssueMeta {\n  5575\t            issue_ref: \"test/repo#2\".to_owned(),\n  5576\t            source_revision: \"rev11111\".to_owned(),\n  5577\t            title: \"Idempotent\".to_owned(),\n  5578\t            body: \"Body\".to_owned(),\n  5579\t            labels: vec![],\n  5580\t            routing_command: None,\n  5581\t        };\n  5582\t\n  5583\t        // First ingestion creates\n  5584\t        let r1 = DaemonTaskService::create_task_from_watched_issue(\n  5585\t            &store, ws.path(), &routing, FlowPreset::Standard, &issue, DispatchMode::Workflow,\n  5586\t        ).map_err(|e| e.to_string())?;\n  5587\t        if r1.is_none() {\n  5588\t            return Err(\"first ingestion should create a task\".to_owned());\n  5589\t        }\n  5590\t\n  5591\t        // Second ingestion is no-op\n  5592\t        let r2 = DaemonTaskService::create_task_from_watched_issue(\n  5593\t            &store, ws.path(), &routing, FlowPreset::Standard, &issue, DispatchMode::Workflow,\n  5594\t        ).map_err(|e| e.to_string())?;\n  5595\t        if r2.is_some() {\n  5596\t            return Err(\"second ingestion should be idempotent no-op\".to_owned());\n  5597\t        }\n  5598\t\n  5599\t        // Only one task exists\n  5600\t        let tasks = DaemonTaskService::list_tasks(&store, ws.path()).map_err(|e| e.to_string())?;\n  5601\t        let matching: Vec<_> = tasks.iter().filter(|t| t.issue_ref == \"test/repo#2\").collect();\n  5602\t        if matching.len() != 1 {\n  5603\t            return Err(format!(\"expected 1 task, found {}\", matching.len()));\n  5604\t        }\n  5605\t        Ok(())\n  5606\t    });\n  5607\t\n  5608\t    reg!(m, \"DAEMON-INTAKE-003\", || {\n  5609\t        // Requirements quick handoff: task is created with RequirementsQuick dispatch,\n  5610\t        // then when processed the seed is derived and task transitions through to\n  5611\t        // workflow mode with project metadata populated.\n  5612\t        use crate::adapters::fs::FsDaemonStore;\n  5613\t        use crate::contexts::automation_runtime::model::{DispatchMode, WatchedIssueMeta};\n  5614\t        use crate::contexts::automation_runtime::routing::RoutingEngine;\n  5615\t        use crate::contexts::automation_runtime::task_service::DaemonTaskService;\n  5616\t        use crate::shared::domain::FlowPreset;\n  5617\t\n  5618\t        let ws = TempWorkspace::new()?;\n  5619\t        init_workspace(&ws)?;\n  5620\t        let store = FsDaemonStore;\n  5621\t        let routing = RoutingEngine::new();\n  5622\t        let issue = WatchedIssueMeta {\n  5623\t            issue_ref: \"test/repo#3\".to_owned(),\n  5624\t            source_revision: \"rev33333\".to_owned(),\n  5625\t            title: \"Quick test\".to_owned(),\n  5626\t            body: \"/rb requirements quick\\n\\nImplement feature\".to_owned(),\n  5627\t            labels: vec![],\n  5628\t            routing_command: None,\n  5629\t        };\n  5630\t\n  5631\t        // Resolve dispatch mode\n  5632\t        let mode = crate::contexts::automation_runtime::watcher::resolve_dispatch_mode(&issue)\n  5633\t            .map_err(|e| e.to_string())?;\n  5634\t        if mode != DispatchMode::RequirementsQuick {\n  5635\t            return Err(format!(\"expected RequirementsQuick, got {}\", mode));\n  5636\t        }\n  5637\t\n  5638\t        // Create task with RequirementsQuick dispatch\n  5639\t        let result = DaemonTaskService::create_task_from_watched_issue(\n  5640\t            &store, ws.path(), &routing, FlowPreset::Standard, &issue, mode,\n  5641\t        ).map_err(|e| e.to_string())?;\n  5642\t        let task = result.ok_or(\"expected a task to be created\")?;\n  5643\t        if task.dispatch_mode != DispatchMode::RequirementsQuick {\n  5644\t            return Err(format!(\"wrong dispatch_mode: {}\", task.dispatch_mode));\n  5645\t        }\n  5646\t        if task.requirements_run_id.is_some() {\n  5647\t            return Err(\"requirements_run_id should not be set yet\".to_owned());\n  5648\t        }\n  5649\t\n  5650\t        // Verify daemon status shows the task\n  5651\t        let out = run_cli(&[\"daemon\", \"status\"], ws.path())?;\n  5652\t        assert_success(&out)?;\n  5653\t        assert_contains(&out.stdout, \"dispatch=requirements_quick\", \"status output\")?;\n  5654\t        Ok(())\n  5655\t    });\n  5656\t\n  5657\t    reg!(m, \"DAEMON-INTAKE-004\", || {\n  5658\t        // Requirements draft: task enters waiting_for_requirements when processed\n  5659\t        use crate::adapters::fs::FsDaemonStore;\n  5660\t        use crate::contexts::automation_runtime::model::{DispatchMode, TaskStatus, WatchedIssueMeta};\n  5661\t        use crate::contexts::automation_runtime::DaemonStorePort;\n  5662\t        use crate::contexts::automation_runtime::routing::RoutingEngine;\n  5663\t        use crate::contexts::automation_runtime::task_service::DaemonTaskService;\n  5664\t        use crate::shared::domain::FlowPreset;\n  5665\t\n  5666\t        let ws = TempWorkspace::new()?;\n  5667\t        init_workspace(&ws)?;\n  5668\t        let store = FsDaemonStore;\n  5669\t        let routing = RoutingEngine::new();\n  5670\t        let issue = WatchedIssueMeta {\n  5671\t            issue_ref: \"test/repo#4\".to_owned(),\n  5672\t            source_revision: \"rev44444\".to_owned(),\n  5673\t            title: \"Draft test\".to_owned(),\n  5674\t            body: \"/rb requirements draft\\n\\nPlan feature\".to_owned(),\n  5675\t            labels: vec![],\n  5676\t            routing_command: None,\n  5677\t        };\n  5678\t\n  5679\t        let mode = crate::contexts::automation_runtime::watcher::resolve_dispatch_mode(&issue)\n  5680\t            .map_err(|e| e.to_string())?;\n  5681\t        if mode != DispatchMode::RequirementsDraft {\n  5682\t            return Err(format!(\"expected RequirementsDraft, got {}\", mode));\n  5683\t        }\n  5684\t\n  5685\t        let result = DaemonTaskService::create_task_from_watched_issue(\n  5686\t            &store, ws.path(), &routing, FlowPreset::Standard, &issue, mode,\n  5687\t        ).map_err(|e| e.to_string())?;\n  5688\t        let task = result.ok_or(\"expected a task to be created\")?;\n  5689\t        if task.dispatch_mode != DispatchMode::RequirementsDraft {\n  5690\t            return Err(format!(\"wrong dispatch_mode: {}\", task.dispatch_mode));\n  5691\t        }\n  5692\t\n  5693\t        // Simulate the state transitions that handle_requirements_draft performs:\n  5694\t        // Pending -> Claimed -> Active -> WaitingForRequirements\n  5695\t        let mut t = store.read_task(ws.path(), &task.task_id).map_err(|e| e.to_string())?;