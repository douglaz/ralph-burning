cate-issue detection purposes.\n   167\t    pub fn is_active_for_issue(self) -> bool {\n   168\t        !self.is_terminal()\n   169\t    }\n   170\t\n   171\t    pub fn can_transition_to(self, next: Self) -> bool {\n   172\t        match (self, next) {\n   173\t            (Self::Pending, Self::Claimed | Self::Failed) => true,\n   174\t            (Self::Claimed, Self::Active | Self::Failed | Self::Aborted) => true,\n   175\t            (Self::Active, Self::Completed | Self::Failed | Self::Aborted | Self::WaitingForRequirements) => true,\n   176\t            (Self::WaitingForRequirements, Self::Pending | Self::Failed | Self::Aborted) => true,\n   177\t            (Self::Failed, Self::Pending) => true,\n   178\t            _ if self == next => true,\n   179\t            _ => false,\n   180\t        }\n   181\t    }\n   182\t}\n   183\t\n   184\timpl std::fmt::Display for TaskStatus {\n   185\t    fn fmt(&self, f: &mut std::fmt::Formatter<'_>) -> std::fmt::Result {\n   186\t        f.write_str(self.as_str())\n   187\t    }\n   188\t}\n   189\t\n   190\t#[derive(Debug, Clone, PartialEq, Eq, Serialize, Deserialize)]\n   191\tpub struct WorktreeLease {\n   192\t    pub lease_id: String,\n   193\t    pub task_id: String,\n   194\t    pub project_id: String,\n   195\t    pub worktree_path: PathBuf,\n   196\t    pub branch_name: String,\n   197\t    pub acquired_at: DateTime<Utc>,\n   198\t    pub ttl_seconds: u64,\n   199\t    pub last_heartbeat: DateTime<Utc>,\n   200\t}\n   201\t\n   202\timpl WorktreeLease {\n   203\t    pub fn heartbeat_deadline(&self) -> DateTime<Utc> {\n   204\t        self.last_heartbeat + Duration::seconds(self.ttl_seconds.min(i64::MAX as u64) as i64)\n   205\t    }\n   206\t\n   207\t    pub fn is_stale_at(&self, now: DateTime<Utc>) -> bool {\n   208\t        now > self.heartbeat_deadline()\n   209\t    }\n   210\t}\n","exit_code":0,"status":"completed"}}
