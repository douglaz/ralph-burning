,\n   600\t                details: \"task has no resolved flow\".to_owned(),\n   601\t            })?;\n   602\t\n   603\t        let run_snapshot = self\n   604\t            .run_snapshot_read\n   605\t            .read_run_snapshot(base_dir, &project_id)?;\n   606\t        let dispatch_future = self.dispatch_in_worktree(\n   607\t            base_dir,\n   608\t            &project_id,\n   609\t            flow,\n   610\t            run_snapshot.status,\n   611\t            effective_config,\n   612\t            &lease.worktree_path,\n   613\t            task_cancel.clone(),\n   614\t        );\n   615\t        tokio::pin!(dispatch_future);\n   616\t\n   617\t        let heartbeat_interval = config.heartbeat_interval.max(Duration::from_secs(1));\n   618\t        let mut heartbeat = tokio::time::interval(heartbeat_interval);\n   619\t        let mut abort_poll = tokio::time::interval(Duration::from_millis(250));\n   620\t\n   621\t        loop {\n   622\t            tokio::select! {\n   623\t                result = &mut dispatch_future => break result,\n   624\t                _ = heartbeat.tick() => {\n   625\t                    let _ = LeaseService::heartbeat(self.store, base_dir, &lease.lease_id);\n   626\t                }\n   627\t                _ = abort_poll.tick() => {\n   628\t                    let current = self.store.read_task(base_dir, &task.task_id)?;\n   629\t                    if current.status == TaskStatus::Aborted {\n   630\t                        task_cancel.cancel();\n   631\t                    }\n   632\t                }\n   633\t                _ = shutdown.cancelled() => {\n   634\t                    let _ = DaemonTaskService::mark_aborted(self.store, base_dir, &task.task_id);\n   635\t                    task_cancel.cancel();\n   636\t                }\n   637\t            }\n   638\t        }\n   639\t    }\n   640\t\n   641\t    async fn dispatch_in_worktree(\n   642\t        &self,\n   643\t        base_dir: &Path,\n   644\t        project_id: &ProjectId,\n   645\t        flow: FlowPreset,\n   646\t        run_status: RunStatus,\n   647\t        effective_config: &EffectiveConfig,\n   648\t        worktree_path: &Path,\n   649\t        cancellation_token: CancellationToken,\n   650\t    ) -> AppResult<()> {\n   651\t        let original_dir = std::env::current_dir()?;\n   652\t        std::env::set_current_dir(worktree_path)?;\n   653\t\n   654\t        let result = match run_status {\n   655\t            RunStatus::NotStarted => {\n   656\t                engine::execute_run_with_retry(\n   657\t                    self.agent_service,\n   658\t                    self.run_snapshot_read,\n   659\t                    self.run_snapshot_write,\n   660\t                    self.journal_store,\n   661\t                    self.artifact_write,\n   662\t                    self.log_write,\n   663\t                    self.amendment_queue,\n   664\t                    base_dir,\n   665\t                    project_id,\n   666\t                    flow,\n   667\t                    effective_config,\n   668\t                    &RetryPolicy::default_policy(),\n   669\t                    cancellation_token,\n   670\t                )\n   671\t                .await\n   672\t            }\n   673\t            RunStatus::Failed | RunStatus::Paused => {\n   674\t                engine::resume_run_with_retry(\n   675\t                    self.agent_service,\n   676\t                    self.run_snapshot_read,\n   677\t                    self.run_snapshot_write,\n   678\t                    self.journal_store,\n   679\t                    self.artifact_store,\n   680\t                    self.artifact_write,\n   681\t                    self.log_write,\n   682\t                    self.amendment_queue,\n   683\t                    base_dir,\n   684\t                    project_id,\n   685\t                    flow,\n   686\t                    effective_config,\n   687\t                    &RetryPolicy