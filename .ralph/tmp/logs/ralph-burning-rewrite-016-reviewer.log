e routing warning should be\n  5854\t        // durably persisted on the task.\n  5855\t        let _out = run_cli(\n  5856\t            &[\"daemon\", \"start\", \"--single-iteration\"],\n  5857\t            ws.path(),\n  5858\t        )?;\n  5859\t\n  5860\t        // Verify the task used the routed flow (quick_dev), not the seed's recommendation\n  5861\t        let store = FsDaemonStore;\n  5862\t        let tasks = store.list_tasks(ws.path()).map_err(|e| e.to_string())?;\n  5863\t        let task = tasks.iter()\n  5864\t            .find(|t| t.issue_ref == \"test/repo#6\")\n  5865\t            .ok_or(\"no task created for issue test/repo#6\")?;\n  5866\t\n  5867\t        if task.resolved_flow != Some(crate::shared::domain::FlowPreset::QuickDev) {\n  5868\t            return Err(format!(\"expected quick_dev, got {:?}\", task.resolved_flow));\n  5869\t        }\n  5870\t\n  5871\t        // Verify that the flow-override warning is persisted on the task\n  5872\t        if task.routing_warnings.is_empty() {\n  5873\t            return Err(\"routing_warnings should contain the flow override warning\".to_owned());\n  5874\t        }\n  5875\t        let has_override_warning = task.routing_warnings.iter()\n  5876\t            .any(|w| w.contains(\"seed suggests flow\") && w.contains(\"authoritative\"));\n  5877\t        if !has_override_warning {\n  5878\t            return Err(format!(\n  5879\t                \"expected flow override warning in routing_warnings, got: {:?}\",\n  5880\t                task.routing_warnings\n  5881\t            ));\n  5882\t        }\n  5883\t\n  5884\t        // Verify the daemon journal also recorded the warning\n  5885\t        let journal_path = ws.path().join(\".ralph-burning/daemon/journal.ndjson\");\n  5886\t        if journal_path.is_file() {\n  5887\t            let journal = std::fs::read_to_string(&journal_path)\n  5888\t                .map_err(|e| format!(\"read daemon journal: {e}\"))?;\n  5889\t            let has_journa