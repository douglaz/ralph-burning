{"type":"item.completed","item":{"id":"item_26","type":"command_execution","command":"/run/current-system/sw/bin/bash -lc \"nl -ba ralph-burning-rewrite/src/contexts/automation_runtime/task_service.rs | sed -n '300,420p'\"","aggregated_output":"   300\t    }\n   301\t\n   302\t    pub fn clear_lease_reference(\n   303\t        store: &dyn DaemonStorePort,\n   304\t        base_dir: &Path,\n   305\t        task_id: &str,\n   306\t    ) -> AppResult<DaemonTask> {\n   307\t        let mut task = store.read_task(base_dir, task_id)?;\n   308\t        task.clear_lease();\n   309\t        task.updated_at = Utc::now();\n   310\t        store.write_task(base_dir, &task)?;\n   311\t        Ok(task)\n   312\t    }\n   313\t\n   314\t    /// Create a task from a watched issue, enforcing idempotency by\n   315\t    /// `(issue_ref, source_revision)`. If a non-terminal task already exists\n   316\t    /// for the same issue_ref and source_revision, the call is a no-op.\n   317\t    /// If a prior task for the same issue_ref is terminal and a newer\n   318\t    /// source_revision appears, a fresh task may be created.\n   319\t    pub fn create_task_from_watched_issue(\n   320\t        store: &dyn DaemonStorePort,\n   321\t        base_dir: &Path,\n   322\t        routing_engine: &RoutingEngine,\n   323\t        default_flow: FlowPreset,\n   324\t        issue: &WatchedIssueMeta,\n   325\t        dispatch_mode: DispatchMode,\n   326\t    ) -> AppResult<Option<DaemonTask>> {\n   327\t        let issue_ref = normalize_required(\"issue_ref\", &issue.issue_ref)?;\n   328\t        let source_revision = normalize_required(\"source_revision\", &issue.source_revision)?;\n   329\t\n   330\t        let existing_tasks = store.list_tasks(base_dir)?;\n   331\t\n   332\t        // Check for exact (issue_ref, source_revision) match on non-terminal task\n   333\t        for task in &existing_tasks {\n   334\t            if task.issue_ref == issue_ref && !task.is_terminal() {\n   335\t                if task.source_revision.as_deref() == Some(source_revision.as_str()) {\n   336\t                    // Idempotent: same issue + same revision, already tracked\n   337\t                    return Ok(None);\n   338\t                }\n   339\t                // Different source_revision but same issue_ref with non-terminal task\n   340\t                return Err(AppError::DuplicateWatchedIssue {\n   341\t                    issue_ref,\n   342\t                    source_revision,\n   343\t                });\n   344\t            }\n   345\t        }\n   346\t\n   347\t        let resolution = routing_engine.resolve_flow(\n   348\t            issue.routing_command.as_deref(),\n   349\t            &issue.labels,\n   350\t            default_flow,\n   351\t        )?;\n   352\t\n   353\t        let task_id = format!(\n   354\t            \"watch-{}-{}\",\n   355\t            issue_ref.replace('/', \"-\").replace('#', \"\"),\n   356\t            &source_revision[..source_revision.len().min(8)]\n   357\t        );\n   358\t        validate_identifier(&task_id)?;\n   359\t\n   360\t        let now = Utc::now();\n   361\t        let task = DaemonTask {\n   362\t            task_id,\n   363\t            issue_ref: issue_ref.clone(),\n   364\t            project_id: format!(\n   365\t                \"watched-{}\",\n   366\t                issue_ref.replace('/', \"-\").replace('#', \"\")\n   367\t            ),\n   368\t            project_name: Some(issue.title.clone()),\n   369\t            prompt: Some(issue.body.clone()),\n   370\t            routing_command: issue.routing_command.clone(),\n   371\t            routing_labels: issue.labels.clone(),\n   372\t            resolved_flow: Some(resolution.flow),\n   373\t            routing_source: Some(resolution.source),\n   374\t            routing_warnings: resolution.warnings.clone(),\n   375\t            status: TaskStatus::Pending,\n   376\t            created_at: now,\n   377\t            updated_at: now,\n   378\t            attempt_count: 0,\n   379\t            lease_id: None,\n   380\t            failure_class: None,\n   381\t            failure_message: None,\n   382\t            dispatch_mode,\n   383\t            source_revision: Some(source_revision),\n   384\t            requirements_run_id: None,\n   385\t        };\n   386\t\n   387\t        store.create_task(base_dir, &task)?;\n   388\t        Self::append_journal_event(\n   389\t            store,\n   390\t            base_dir,\n   391\t            DaemonJournalEventType::WatcherIngestion,\n   392\t            json!({\n   393\t                \"task_id\": task.task_id,\n   394\t                \"issue_ref\": task.issue_ref,\n   395\t                \"source_revision\": task.source_revision,\n   396\t                \"dispatch_mode\": task.dispatch_mode,\n   397\t                \"flow\": resolution.flow,\n   398\t            }),\n   399\t        )?;\n   400\t\n   401\t        Ok(Some(task))\n   402\t    }\n   403\t\n   404\t    /// Transition an active task to waiting_for_requirements.\n   405\t    /// Releases the lease and writer lock, leaving no external resources held.\n   406\t    pub fn mark_waiting_for_requirements(\n   407\t        store: &dyn DaemonStorePort,\n   408\t        base_dir: &Path,\n   409\t        task_id: &str,\n   410\t        requirements_run_id: &str,\n   411\t    ) -> AppResult<DaemonTask> {\n   412\t        let mut task = store.read_task(base_dir, task_id)?;\n   413\t        task.transition_to(TaskStatus::WaitingForRequirements, Utc::now())?;\n   414\t        task.requirements_run_id = Some(requirements_run_id.to_owned());\n   415\t        task.clear_lease();\n   416\t        store.write_task(base_dir, &task)?;\n   417\t        Self::append_journal_event(\n   418\t            store,\n   419\t            base_dir,\n   420\t            DaemonJournalEventType::RequirementsWaiting,\n","exit_code":0,"status":"completed"}}
