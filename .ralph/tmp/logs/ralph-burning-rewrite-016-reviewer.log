path(base_dir, &run_id);\n   288\t                    println!(\n   289\t                        \"Questions generated. Edit answers at:\\n  {}\\n\\nThen run:\\n  ralph-burning requirements answer {}\",\n   290\t                        answers_path.display(),\n   291\t                        run_id\n   292\t                    );\n   293\t                }\n   294\t            }\n   295\t            Err(e) => {\n   296\t                run.status = RequirementsStatus::Failed;\n   297\t                run.status_summary = format!(\"failed: question generation: {e}\");\n   298\t                run.updated_at = Utc::now();\n   299\t                self.store.write_run(base_dir, &run_id, &run)?;\n   300\t\n   301\t                let event =\n   302\t                    journal_event(2, Utc::now(), RequirementsJournalEventType::RunFailed, &run);\n   303\t                self.store.append_journal_event(base_dir, &run_id, &event)?;\n   304\t                return Err(e);\n   305\t            }\n   306\t        }\n   307\t\n   308\t        Ok(run_id)\n   309\t    }\n   310\t\n   311\t    /// Execute `requirements quick --idea \"<text>\"`.\n   312\t    pub async fn quick(\n   313\t        &self,\n   314\t        base_dir: &Path,\n   315\t        idea: &str,\n   316\t        now: DateTime<Utc>,\n   317\t    ) -> AppResult<String> {\n   318\t        let run_id = generate_run_id(now);\n   319\t        let mut run = RequirementsRun::new_quick(run_id.clone(), idea.to_owned(), now);\n   320\t\n","exit_code":0,"status":"completed"}}
