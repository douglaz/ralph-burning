k.task_id, lease);\n        }\n\n        let failure_class = error\n            .failure_class()\n            .map(|class| class.as_str().to_owned())\n            .unwrap_or_else(|| \"daemon_dispatch_failed\".to_owned());\n        self.fail_claimed_task(\n","exit_code":0,"status":"completed"}}
