   setup_workspace_with_project(&ws, \"rq-no-run\", \"standard\")?;\n  1712→        std::fs::remove_file(ws.path().join(\".ralph-burning/projects/rq-no-run/run.json\"))\n  1713→            .map_err(|e| e.to_string())?;\n  1714→        let out = run_cli(&[\"run\", \"status\"], ws.path())?;\n  1715→        assert_failure(&out)?;\n  1716→        Ok(())\n  1717→    });\n  1718→\n  1719→    reg!(m, \"SC-RUN-012\", || {\n  1720→        let ws = TempWorkspace::new()?;\n  1721→        setup_workspace_with_project(&ws, \"rq-no-journal\", \"standard\")?;\n  1722→        std::fs::remove_file(ws.path().join(\".ralph-burning/projects/rq-no-journal/journal.ndjson\"))\n  1723→            .map_err(|e| e.to_string())?;\n  1724→        let out = run_cli(&[\"run\", \"history\"], ws.path())?;\n  1725→        assert_failure(&out)?;\n  1726→        Ok(())\n  1727→    });\n  1728→\n  1729→    reg!(m, \"SC-RUN-013\", || {\n  1730→        let ws = TempWorkspace::new()?;\n  1731→        setup_workspace_with_project(&ws, \"rq-orphan-pay\", \"standard\")?;\n  1732→        let out = run_cli(&[\"run\", \"status\"], ws.path())?;\n  1733→        assert_success(&out)?;\n  1734→        Ok(())\n  1735→    });\n  1736→\n  1737→    reg!(m, \"SC-RUN-014\", || {\n  1738→        let ws = TempWorkspace::new()?;\n  1739→        setup_workspace_with_project(&ws, \"rq-tail-dur\", \"standard\")?;\n  1740→        let out = run_cli(&[\"run\", \"tail\"], ws.path())?;\n  1741→        assert_success(&out)?;\n  1742→        Ok(())\n  1743→    });\n  1744→\n  1745→    reg!(m, \"SC-RUN-015\", || {\n  1746→        let ws = TempWorkspace::new()?;\n  1747→        setup_workspace_with_project(&ws, \"rq-completed\", \"standard\")?;\n  1748→        let run_json = r#\"{\"active_run\":null,\"status\":\"completed\",\"cycle_history\":[],\"completion_rounds\":0,\"rollback_point_meta\":{\"last_rollback_id\":null,\"rollback_count\":0},\"amendment_queue\":{\"pending\":[],\"processed_count\":0},\"status_summary\":\"completed\"}\"#;\n  1749→        std::fs::write(\n  1750→            ws.path().join(\".ralph-burning/projects/rq-completed/run.json\"),\n  1751→            run_json,\n  1752→        ).map_err(|e| e.to_string())?;\n  1753→        let out = run_cli(&[\"run\", \"status\"], ws.path())?;\n  1754→        assert_success(&out)?;\n  1755→        assert_contains(&out.stdout, \"completed\", \"stdout\")?;\n  1756→        Ok(())\n  1757→    });\n  1758→\n  1759→    reg!(m, \"SC-RUN-016\", || {\n  1760→        let ws = TempWorkspace::new()?;\n  1761→        setup_workspace_with_project(&ws, \"rq-failed\", \"standard\")?;\n  1762→        let run_json = r#\"{\"active_run\":null,\"status\":\"failed\",\"cycle_history\":[],\"completion_rounds\":0,\"rollback_point_meta\":{\"last_rollback_id\":null,\"rollback_count\":0},\"amendment_queue\":{\"pending\":[],\"processed_count\":0},\"status_summary\":\"failed\"}\"#;\n  1763→        std::fs::write(\n  1764→            ws.path().join(\".ralph-burning/projects/rq-failed/run.json\"),\n  1765→            run_json,\n  1766→        ).map_err(|e| e.to_string())?;\n  1767→        let out = run_cli(&[\"run\", \"status\"], ws.path())?;\n  1768→        assert_success(&out)?;\n  1769→        assert_contains(&out.stdout, \"failed\", \"stdout\")?;\n  1770→        Ok(())\n  1771→    });\n  1772→\n  1773→    reg!(m, \"SC-RUN-017\", || {\n  1774→        let ws = TempWorkspace::new()?;\n  1775→        setup_workspace_with_project(&ws, \"rq-inconsist\", \"standard\")?;\n  1776→        // Write semantically inconsistent run.json (active_run but status is completed)\n  1777→        let run_json = r#\"{\"active_run\":{\"run_id\":\"run-1\",\"started_at\":\"2026-03-11T19:00:00Z\"},\"status\":\"completed\",\"cycle_history\":[],\"completion_rounds\":0,\"rollback_point_meta\":{\"last_rollback_id\":null,\"rollback_count\":0},\"amendment_queue\":{\"pending\":[],\"processed_count\":0},\"status_summary\":\"completed\"}\"#;\n  1778→        std::fs::write(\n  1779→            ws.path().join