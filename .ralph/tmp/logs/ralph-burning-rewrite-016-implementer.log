   44→#[test]\n    45→fn routing_resolution_prefers_command_over_label_and_default() {\n    46→    let engine = RoutingEngine::new();\n    47→    let resolution = engine\n    48→        .resolve_flow(\n    49→            Some(\"/rb flow quick_dev\"),\n    50→            &[String::from(\"rb:flow:docs_change\")],\n    51→            FlowPreset::CiImprovement,\n    52→        )\n    53→        .expect(\"resolve flow\");\n    54→\n    55→    assert_eq!(FlowPreset::QuickDev, resolution.flow);\n    56→}\n    57→\n    58→#[test]\n    59→fn routing_labels_ignore_malformed_values_with_warning() {\n    60→    let engine = RoutingEngine::new();\n    61→    let resolution = engine\n    62→        .resolve_flow(\n    63→            None,\n    64→            &[String::from(\"rb:flow\"), String::from(\"rb:flow:docs_change\")],\n    65→            FlowPreset::Standard,\n    66→        )\n    67→        .expect(\"resolve labels\");\n    68→\n    69→    assert_eq!(FlowPreset::DocsChange, resolution.flow);\n    70→    assert_eq!(1, resolution.warnings.len());\n    71→}\n    72→\n    73→#[test]\n    74→fn conflicting_routing_labels_fail_resolution() {\n    75→    let engine = RoutingEngine::new();\n    76→    let error = engine\n    77→        .resolve_flow(\n    78→            None,\n    79→            &[\n    80→                String::from(\"rb:flow:standard\"),\n    81→                String::from(\"rb:flow:quick_dev\"),\n    82→            ],\n    83→            FlowPreset::Standard,\n    84→        )\n    85→        .expect_err(\"conflicting labels should fail\");\n    86→\n    87→    assert!(matches!(error, AppError::AmbiguousRouting { .. }));\n    88→}\n    89→\n    90→#[test]\n    91→fn task_state_machine_accepts_expected_transitions() {\n    92→    let mut task = sample_task();\n    93→    task.transition_to(TaskStatus::Claimed, Utc::now())\n    94→        .expect(\"pending -> claimed\");\n    95→    task.transition_to(TaskStatus::Active, Utc::now())\n    96→        .expect(\"claimed -> active\");\n    97→    task.transition_to(TaskStatus::Completed, Utc::now())\n    98→        .expect(\"active -> completed\");\n    99→}\n   100→\n   101→#[test]\n   102→fn task_state_machine_rejects_invalid_transition() {\n   103→    let mut task = sample_task();\n   104→    let error = task\n   105→        .transition_to(TaskStatus::Completed, Utc::now())\n   106→        .expect_err(\"pending -> completed should fail\");\n   107→\n   108→    assert!(matches!(error, AppError::TaskStateTransitionInvalid { .. }));\n   109→}\n   110→\n   111→#[test]\n   112→fn task_state_machine_active_to_waiting() {\n   113→    let mut task = sample_task();\n   114→    task.transition_to(TaskStatus::Claimed, Utc::now())\n   115→        .expect(\"pending -> claimed\");\n   116→    task.transition_to(TaskStatus::Active, Utc::now())\n   117→        .expect(\"claimed -> active\");\n   118→    task.transition_to(TaskStatus::WaitingForRequirements, Utc::now())\n   119→        .expect(\"active -> waiting_for_requirements\");\n   120→    assert_eq!(TaskStatus::WaitingForRequirements, task.status);\n   121→    assert!(!task.is_terminal());\n   122→}\n   123→\n   124→#[test]\n   125→fn task_state_machine_waiting_to_pending() {\n   126→    let mut task = sample_task();\n   127→    task.status = TaskStatus::WaitingForRequirements;\n   128→    task.transition_to(TaskStatus::Pending, Utc::now())\n   129→        .expect(\"waiting -> pending\");\n   130→    assert_eq!(TaskStatus::Pending, task.status);\n   131→}\n   132→\n   133→#[test]\n   134→fn task_state_machine_waiting_to_failed() {\n   135→    let mut task = sample_task();\n   136→    task.status = TaskStatus::WaitingForRequirements;\n   137→    task.transition_to(TaskStatus::Failed, Utc::now())\n   138→        .expect(\"waiting -> failed\");\n   139→    assert_eq!(TaskStatus::Failed, task.status);\n   140→}\n   141→\n   142→#[test]\n   143→fn task_state_machine_waiting_to_aborted() {\n   144→    let mut task = sample_task();\n   145→    task.status = TaskStatus::WaitingForRequirements;\n   146→    task.transition_to(TaskStatus::Aborted, Utc::now())\n   147→        .expect(\"waiting -> aborted\");\n   148→    assert_eq!(TaskStatus::Aborted, task.status);\n   149→}\n   150→\n   151→#[test]\n   152→fn lease_ttl_detects_staleness() {\n   153→    let now = Utc::now();\n   154→    let lease = WorktreeLease {\n   155→        lease_id: \"lease-1\".to_owned(),\n   156→        task_id: \"task-1\".to_owned(),\n   157→        project_id: \"demo\".to_owned(),\n   158→        worktree_path: \"/tmp/demo\".into(),\n   159→        branch_name: \"rb/task/task-1\".to_owned(),\n   160→        acquired_at: now,\n   161→        ttl_seconds: 300,\n   162→        last_heartbeat: now,\n   163→    };\n   164→\n   165→    assert!(!lease.is_stale_at(now + Duration::seconds(299)));\n   166→    assert!(lease.is_stale_at(now + Duration::seconds(301)));\n   167→}\n   168→\n   169→#[test]\n   170→fn worktree_path_derivation_is_deterministic() {\n   171→    let adapter = WorktreeAdapter;\n   172→    let temp = tempdir().expect(\"tempdir\");\n   173→    let path = adapter.worktree_path(temp.path(), \"task-99\");\n   174→\n   175→    assert_eq!(temp.path().join(\".ralph-burning/worktrees/task-99\"), path);\n   176→    assert_eq!(\"rb/task/task-99\", adapter.branch_name(\"task-99\"));\n   177→}\n   178→\n   179→#[test]\n   180→fn create_task_rejects_duplicate_active_issue() {\n   181→    let store = FsDaemonStore;\n   182→    let temp = tempdir().expect(\"tempdir\");\n   183→    let routing = RoutingEngine::new();\n   184→\n   185→    DaemonTaskService::create_task(\n   186→        &store,\n   187→        temp.path(),\n   188→        &routing,\n   189→        FlowPreset::Standard,\n   190→        CreateTaskInput {\n   191→            task_id: \"task-1\".to_owned(),\n   192→            issue_ref: \"repo#1\".to_owned(),\n   193→            project_id: \"demo\".to_owned(),\n   194→            project_name: Some(\"Demo\".to_owned()),\n   195→            prompt: Some(\"Prompt\".to_owned()),\n   196→            routing_command: None,\n   197→            routing_labels: vec![],\n   198→            dispatch_mode: DispatchMode::Workflow,\n   199→            source_revision: None,\n   200→        },\n   201→    )\n   202→    .expect(\"create first task\");\n   203→\n   204→    let error = DaemonTaskService::create_task(\n   205→        &store,\n   206→        temp.path(),\n   207→        &routing,\n   208→        FlowPreset::Standard,\n   209→        CreateTaskInput {\n   210→            task_id: \"task-2\".to_owned(),\n   211→            issue_ref: \"repo#1\".to_owned(),\n   212→            project_id: \"demo-2\".to_owned(),\n   213→            project_name: Some(\"Demo Two\".to_owned()),\n   214→            prompt: Some(\"Prompt\".to_owned()),\n   215→            routing_command: None,\n   216→            routing_labels: vec![],\n   217→            dispatch_mode: DispatchMode::Workflow,\n   218→            source_revision: None,\n   219→        },\n   220→    )\n   221→    .expect_err(\"duplicate issue should fail\");\n   222→\n   223→    assert!(matches!(error, AppError::DuplicateTaskForIssue { .. }));\n   224→}\n   225→\n   226→#[test]\n   227→fn retry_resets_failed_task_to_pending_and_increments_attempt_count() {\n   228→    let store = FsDaemonStore;\n   229→    let temp = tempdir().expect(\"tempdir\");\n   230→    let mut task = sample_task();\n   231→    task.status = TaskStatus::Failed;\n   232→    task.set_failure(\"daemon_dispatch_failed\", \"boom\");\n   233→    store.create_task(temp.path(), &task).expect(\"persist task\");\n   234→\n   235→    let retried = DaemonTaskService::retry_task(&store, temp.path(), &task.task_id)\n   236→        .expect(\"retry failed task\");\n   237→\n   238→    assert_eq!(TaskStatus::Pending, retried.status);\n   239→    assert_eq!(1, retried.attempt_count);\n   240→    assert!(retried.failure_class.is_none());\n   241→    assert!(retried.failure_message.is_none());\n   242→}\n   243→\n   244→// ── Watched-issue ingestion tests ───────────────────────────────────────────\n   245→\n   246→#[test]\n   247→fn watched_issue_ingestion_creates_task_idempotently() {\n   248→    let store = FsDaemonStore;\n   249→    let temp = tempdir().expect(\"tempdir\");\n   250→    let routing = RoutingEngine::new();\n   251→\n   252→    let issue = WatchedIssueMeta {\n   253→        issue_ref: \"org/repo#42\".to_owned(),\n   254→        source_revision: \"deadbeef\".to_owned(),\n   255→        title: \"Fix the thing\".to_owned(),\n   256→        body: \"It is broken\".to_owned(),\n   257→        labels: vec![],\n   258→        routing_command: None,\n   259→    };\n   260→\n   261→    // First ingestion creates a task\n   262→    let result = DaemonTaskService::create_task_from_watched_issue(\n   263→        &store,\n   264→        temp.path(),\n   265→        &routing,\n   266→        FlowPreset::Standard,\n   267→        &issue,\n   268→        DispatchMode::Workflow,\n   269→    )\n   270→    .expect(\"create from watched issue\");\n   271→    assert!(result.is_some());\n   272→    let task = result.unwrap();\n   273→    assert_eq!(\"org/repo#42\", task.issue_ref);\n   274→    assert_eq!(Some(\"deadbeef\".to_owned()), task.source_revision);\n   275→    assert_eq!(DispatchMode::Workflow, task.dispatch_mode);\n   276→\n   277→    // Second ingestion with same (issue_ref, source_revision) is a no-op\n   278→    let result2 = DaemonTaskService::create_task_from_watched_issue(\n   279→        &store,\n   280→        temp.path(),\n   281→        &routing,\n   282→        FlowPreset::Standard,\n   283→        &issue,\n   284→        DispatchMode::Workflow,\n   285→    )\n   286→    .expect(\"idempotent re-ingestion\");\n   287→    assert!(result2.is_none());\n   288→}\n   289→\n   290→#[test]\n   291→fn watched_issue_newer_revision_after_terminal_creates_fresh_task() {\n   292→    let store = FsDaemonStore;\n   293→    let temp = tempdir().expect(\"tempdir\");\n   294→    let routing = RoutingEngine::new();\n   295→\n   296→    let issue1 = WatchedIssueMeta {\n   297→        issue_ref: \"org/repo#50\".to_owned(),\n   298→        source_revision: \"rev1aaaa\".to_owned(),\n   299→        title: \"First\".to_owned(),\n   300→        body: \"Body\".to_owned(),\n   301→        labels: vec![],\n   302→        routing_command: None,\n   303→    };\n   304→\n   305→    // Create and complete the first task\n   306→    let result = DaemonTaskService::create_task_from_watched_issue(\n   307→        &store,\n   308→        temp.path(),\n   309→        &routing,\n   310→        FlowPreset::Standard,\n   311→        &issue1,\n   312→        DispatchMode::Workflow,\n   313→    )\n   314→    .expect(\"create first\");\n   315→    let task = result.unwrap();\n   316→    DaemonTaskService::mark_completed(&store, temp.path(), &task.task_id)\n   317→        .expect(\"mark completed - need claimed/active first\");\n   318→\n   319→    // Mark the task completed (need to go through the state machine)\n   320→    let mut raw = store.read_task(temp.path(), &task.task_id).unwrap();\n   321→    raw.status = TaskStatus::Completed;\n   322→    raw.updated_at = Utc::now();\n   323→    store.write_task(temp.path(), &raw).unwrap();\n   324→\n   325→    // New revision should create a fresh task\n   326→    let issue2 = WatchedIssueMeta {\n   327→        issue_ref: \"org/repo#50\".to_owned(),\n   328→        source_revision: \"rev2bbbb\".to_owned(),\n   329→        title: \"Second\".to_owned(),\n   330→        body: \"Updated body\".to_owned(),\n   331→        labels: vec![],\n   332→        routing_command: None,\n   333→    };\n   334→\n   335→    let result2 = DaemonTaskService::create_task_from_watched_issue(\n   336→        &store,\n   337→        temp.path(),\n   338→        &routing,\n   339→        FlowPreset::Standard,\n   340→        &issue2,\n   341→        DispatchMode::Workflow,\n   342→    )\n   343→    .expect(\"create second for new revision\");\n   344→    assert!(result2.is_some());\n   345→}\n   346→\n   347→#[test]\n   348→fn watched_issue_different_revision_while_non_terminal_fails() {\n   349→    let store = FsDaemonStore;\n   350→    let temp = tempdir().expect(\"tempdir\");\n   351→    let routing = RoutingEngine::new();\n   352→\n   353→    let issue1 = WatchedIssueMeta {\n   354→        issue_ref: \"org/repo#60\".to_owned(),\n   355→        source_revision: \"aaa11111\".to_owned(),\n   356→        title: \"First\".to_owned(),\n   357→        body: \"Body\".to_owned(),\n   358→        labels: vec![],\n   359→        routing_command: None,\n   360→    };\n   361→\n   362→    DaemonTaskService::create_task_from_watched_issue(\n   363→        &store,\n   364→        temp.path(),\n   365→        &routing,\n   366→        FlowPreset::Standard,\n   367→        &issue1,\n   368→        DispatchMode::Workflow,\n   369→    )\n   370→    .expect(\"create first\");\n   371→\n   372→    let issue2 = WatchedIssueMeta {\n   373→        issue_ref: \"org/repo#60\".to_owned(),\n   374→        source_revision: \"bbb22222\".to_owned(),\n   375→        title: \"Second\".to_owned(),\n   376→        body: \"Body\".to_owned(),\n   377→        labels: vec![],\n   378→        routing_command: None,\n   379→    };\n   380→\n   381→    let err = DaemonTaskService::create_task_from_watched_issue(\n   382→        &store,\n   383→        temp.path(),\n   384→        &routing,\n   385→        FlowPreset::Standard,\n   386→        &issue2,\n   387→        DispatchMode::Workflow,\n   388→    )\n   389→    .expect_err(\"should reject different revision while non-terminal\");\n   390→\n   391→    assert!(matches!(err, AppError::DuplicateWatchedIssue { .. }));\n   392→}\n   393→\n   394→#[test]\n   395→fn waiting_for_requirements_resume_transitions() {\n   396→    let store = FsDaemonStore;\n   397→    let temp = tempdir().expect(\"tempdir\");\n   398→\n   399→    let mut task = sample_task();\n   400→    task.status = TaskStatus::Active;\n   401→    store.create_task(temp.path(), &task).expect(\"persist task\");\n   402→\n   403→    // Transition to waiting\n   404→    let waiting = DaemonTaskService::mark_waiting_for_requirements(\n   405→        &store,\n   406→        temp.path(),\n   407→        &task.task_id,\n   408→        \"req-20260313\",\n   409→    )\n   410→    .expect(\"mark waiting\");\n   411→    assert_eq!(TaskStatus::WaitingForRequirements, waiting.status);\n   412→    assert_eq!(Some(\"req-20260313\".to_owned()), waiting.requirements_run_id);\n   413→    assert!(waiting.lease_id.is_none());\n   414→\n   415→    // Resume from waiting\n   416→    let resumed = DaemonTaskService::resume_from_waiting(&store, temp.path(), &task.task_id)\n   417→        .expect(\"resume from waiting\");\n   418→    assert_eq!(TaskStatus::Pending, resumed.status);\n   419→    assert_eq!(DispatchMode::Workflow, resumed.dispatch_mode);\n   420→}\n   421→\n   422→#[test]\n   423→fn resume_from_non_waiting_state_fails() {\n   424→    let store = FsDaemonStore;\n   425→    let temp = tempdir().expect(\"tempdir\");\n   426→\n   427→    let task = sample_task();\n   428→    store.create_task(temp.path(), &task).expect(\"persist task\");\n   429→\n   430→    let err = DaemonTaskService::resume_from_waiting(&store, temp.path(), &task.task_id)\n   431→        .expect_err(\"should fail for pending task\");\n   432→    assert!(matches!(err, AppError::TaskStateTransitionInvalid { .. }));\n   433→}\n   434→\n   435→// ── Requirements command parsing ────────────────────────────────────────────\n   436→\n   437→#[test]\n   438→fn parse_requirements_command_draft() {\n   439→    let result = parse_requirements_command(\"/rb requirements draft\").unwrap();\n   440→    assert_eq!(Some(DispatchMode::RequirementsDraft), result);\n   441→}\n   442→\n   443→#[test]\n   444→fn parse_requirements_command_quick() {\n   445→    let result = parse_requirements_command(\"/rb requirements quick\").unwrap();\n   446→    assert_eq!(Some(DispatchMode::RequirementsQuick), result);\n   447→}\n   448→\n   449→#[test]\n   450→fn parse_requirements_command_unknown_fails() {\n   451→    let result = parse_requirements_command(\"/rb requirements bogus\");\n   452→    assert!(result.is_err());\n   453→}\n   454→\n   455→#[test]\n   456→fn parse_requirements_command_no_match() {\n   457→    let result = parse_requirements_command(\"/rb flow standard\").unwrap();\n   458→    assert_eq!(None, result);\n   459→}\n   460→\n   461→#[test]\n   462→fn parse_requirements_command_multiline_body() {\n   463→    let body = \"Please help.\\n\\n/rb requirements quick\\n\\nThanks!\";\n   464→    let result = parse_requirements_command(body).unwrap();\n   465→    assert_eq!(Some(DispatchMode::RequirementsQuick), result);\n   466→}\n   467→\n   468→// ── Dispatch mode serialization ─────────────────────────────────────────────\n   469→\n   470→#[test]\n   471→fn dispatch_mode_display() {\n   472→    assert_eq!(\"workflow\", DispatchMode::Workflow.as_str());\n   473→    assert_eq!(\"requirements_draft\", DispatchMode::RequirementsDraft.as_str());\n   474→    assert_eq!(\"requirements_quick\", DispatchMode::RequirementsQuick.as_str());\n   475→}\n   476→\n   477→#[test]\n   478→fn task_with_dispatch_mode_roundtrips_through_json() {\n   479→    let mut task = sample_task();\n   480→    task.dispatch_mode = DispatchMode::RequirementsQuick;\n   481→    task.source_revision = Some(\"abc123\".to_owned());\n   482→    task.requirements_run_id = Some(\"req-123\".to_owned());\n   483→\n   484→    let json = serde_json::to_string(&task).expect(\"serialize\");\n   485→    let deserialized: DaemonTask = serde_json::from_str(&json).expect(\"deserialize\");\n   486→\n   487→    assert_eq!(DispatchMode::RequirementsQuick, deserialized.dispatch_mode);\n   488→    assert_eq!(Some(\"abc123\".to_owned()), deserialized.source_revision);\n   489→    assert_eq!(Some(\"req-123\".to_owned()), deserialized.requirements_run_id);\n   490→}\n   491→\n   492→#[test]\n   493→fn task_without_dispatch_mode_defaults_to_workflow() {\n   494→    // Backward compat: older JSON without dispatch_mode should default to workflow\n   495→    let json = r#\"{\n   496→        \"task_id\": \"task-old\",\n   497→        \"issue_ref\": \"repo#1\",\n   498→        \"project_id\": \"demo\",\n   499→        \"status\": \"pending\",\n   500→        \"created_at\": \"2026-03-13T00:00:00Z\",\n   501→        \"updated_at\": \"2026-03-13T00:00:00Z\",\n   502→        \"attempt_count\": 0\n   503→    }\"#;\n   504→    let task: DaemonTask = serde_json::from_str(json).expect(\"deserialize legacy task\");\n   505→    assert_eq!(DispatchMode::Workflow, task.dispatch_mode);\n   506→    assert!(task.source_revision.is_none());\n   507→    assert!(task.requirements_run_id.is_none());\n   508→}\n   509→"}]},"parent_tool_use_id":null,"session_id":"8dacb19c-9278-40df-b484-c803ec7bbb98","uuid":"4f26bee1-bd40-458c-98be-a6ab4a700e93","tool_use_result":{"type":"text","file":{"filePath":"/root/new-ralph-burning/ralph-burning-rewrite/tests/unit/automation_runtime_test.rs","content":"use chrono::{Duration, Utc};\nuse tempfile::tempdir;\n\nuse ralph_burning::adapters::fs::FsDaemonStore;\nuse ralph_burning::adapters::worktree::WorktreeAdapter;\nuse ralph_burning::contexts::automation_runtime::model::{\n    DaemonTask, DispatchMode, TaskStatus, WatchedIssueMeta, WorktreeLease,\n};\nuse ralph_burning::contexts::automation_runtime::routing::RoutingEngine;\nuse ralph_burning::contexts::automation_runtime::task_service::{\n    CreateTaskInput, DaemonTaskService,\n};\nuse ralph_burning::contexts::automation_runtime::watcher::parse_requirements_command;\nuse ralph_burning::contexts::automation_runtime::{DaemonStorePort, WorktreePort};\nuse ralph_burning::shared::domain::FlowPreset;\nuse ralph_burning::shared::error::AppError;\n\nfn sample_task() -> DaemonTask {\n    let now = Utc::now();\n    DaemonTask {\n        task_id: \"task-1\".to_owned(),\n        issue_ref: \"repo#1\".to_owned(),\n        project_id: \"demo\".to_owned(),\n        project_name: Some(\"Demo\".to_owned()),\n        prompt: Some(\"Prompt\".to_owned()),\n        routing_command: None,\n        routing_labels: vec![],\n        resolved_flow: Some(FlowPreset::Standard),\n        routing_source: None,\n        routing_warnings: vec![],\n        status: TaskStatus::Pending,\n        created_at: now,\n        updated_at: now,\n        attempt_count: 0,\n        lease_id: None,\n        failure_class: None,\n        failure_message: None,\n        dispatch_mode: DispatchMode::Workflow,\n        source_revision: None,\n        requirements_run_id: None,\n    }\n}\n\n#[test]\nfn routing_resolution_prefers_command_over_label_and_default() {\n    let engine = RoutingEngine::new();\n    let resolution = engine\n        .resolve_flow(\n            Some(\"/rb flow quick_dev\"),\n            &[String::from(\"rb:flow:docs_change\")],\n            FlowPreset::CiImprovement,\n        )\n        .expect(\"resolve flow\");\n\n    assert_eq!(FlowPreset::QuickDev, resolution.flow);\n}\n\n#[test]\nfn routing_labels_ignore_malformed_values_with_warning() {\n    let engine = RoutingEngine::new();\n    let resolution = engine\n        .resolve_flow(\n            None,\n            &[String::from(\"rb:flow\"), String::from(\"rb:flow:docs_change\")],\n            FlowPreset::Standard,\n        )\n        .expect(\"resolve labels\");\n\n    assert_eq!(FlowPreset::DocsChange, resolution.flow);\n    assert_eq!(1, resolution.warnings.len());\n}\n\n#[test]\nfn conflicting_routing_labels_fail_resolution() {\n    let engine = RoutingEngine::new();\n    let error = engine\n        .resolve_flow(\n            None,\n            &[\n                String::from(\"rb:flow:standard\"),\n                String::from(\"rb:flow:quick_dev\"),\n            ],\n            FlowPreset::Standard,\n        )\n        .expect_err(\"conflicting labels should fail\");\n\n    assert!(matches!(error, AppError::AmbiguousRouting { .. }));\n}\n\n#[test]\nfn task_state_machine_accepts_expected_transitions() {\n    let mut task = sample_task();\n    task.transition_to(TaskStatus::Claimed, Utc::now())\n        .expect(\"pending -> claimed\");\n    task.transition_to(TaskStatus::Active, Utc::now())\n        .expect(\"claimed -> active\");\n    task.transition_to(TaskStatus::Completed, Utc::now())\n        .expect(\"active -> completed\");\n}\n\n#[test]\nfn task_state_machine_rejects_invalid_transition() {\n    let mut task = sample_task();\n    let error = task\n        .transition_to(TaskStatus::Completed, Utc::now())\n        .expect_err(\"pending -> completed should fail\");\n\n    assert!(matches!(error, AppError::TaskStateTransitionInvalid { .. }));\n}\n\n#[test]\nfn task_state_machine_active_to_waiting() {\n    let mut task = sample_task();\n    task.transition_to(TaskStatus::Claimed, Utc::now())\n        .expect(\"pending -> claimed\");\n    task.transition_to(TaskStatus::Active, Utc::now())\n        .expect(\"claimed -> active\");\n    task.transition_to(TaskStatus::WaitingForRequirements, Utc::now())\n        .expect(\"active -> waiting_for_requirements\");\n    assert_eq!(TaskStatus::WaitingForRequirements, task.status);\n    assert!(!task.is_terminal());\n}\n\n#[test]\nfn task_state_machine_waiting_to_pending() {\n    let mut task = sample_task();\n    task.status = TaskStatus::WaitingForRequirements;\n    task.transition_to(TaskStatus::Pending, Utc::now())\n        .expect(\"waiting -> pending\");\n    assert_eq!(TaskStatus::Pending, task.status);\n}\n\n#[test]\nfn task_state_machine_waiting_to_failed() {\n    let mut task = sample_task();\n    task.status = TaskStatus::WaitingForRequirements;\n    task.transition_to(TaskStatus::Failed, Utc::now())\n        .expect(\"waiting -> failed\");\n    assert_eq!(TaskStatus::Failed, task.status);\n}\n\n#[test]\nfn task_state_machine_waiting_to_aborted() {\n    let mut task = sample_task();\n    task.status = TaskStatus::WaitingForRequirements;\n    task.transition_to(TaskStatus::Aborted, Utc::now())\n        .expect(\"waiting -> aborted\");\n    assert_eq!(TaskStatus::Aborted, task.status);\n}\n\n#[test]\nfn lease_ttl_detects_staleness() {\n    let now = Utc::now();\n    let lease = WorktreeLease {\n        lease_id: \"lease-1\".to_owned(),\n        task_id: \"task-1\".to_owned(),\n        project_id: \"demo\".to_owned(),\n        worktree_path: \"/tmp/demo\".into(),\n        branch_name: \"rb/task/task-1\".to_owned(),\n        acquired_at: now,\n        ttl_seconds: 300,\n        last_heartbeat: now,\n    };\n\n    assert!(!lease.is_stale_at(now + Duration::seconds(299)));\n    assert!(lease.is_stale_at(now + Duration::seconds(301)));\n}\n\n#[test]\nfn worktree_path_derivation_is_deterministic() {\n    let adapter = WorktreeAdapter;\n    let temp = tempdir().expect(\"tempdir\");\n    let path = adapter.worktree_path(temp.path(), \"task-99\");\n\n    assert_eq!(temp.path().join(\".ralph-burning/worktrees/task-99\"), path);\n    assert_eq!(\"rb/task/task-99\", adapter.branch_name(\"task-99\"));\n}\n\n#[test]\nfn create_task_rejects_duplicate_active_issue() {\n    let store = FsDaemonStore;\n    let temp = tempdir().expect(\"tempdir\");\n    let routing = RoutingEngine::new();\n\n    DaemonTaskService::create_task(\n        &store,\n        temp.path(),\n        &routing,\n        FlowPreset::Standard,\n        CreateTaskInput {\n            task_id: \"task-1\".to_owned(),\n            issue_ref: \"repo#1\".to_owned(),\n            project_id: \"demo\".to_owned(),\n            project_name: Some(\"Demo\".to_owned()),\n            prompt: Some(\"Prompt\".to_owned()),\n            routing_command: None,\n            routing_labels: vec![],\n            dispatch_mode: DispatchMode::Workflow,\n            source_revision: None,\n        },\n    )\n    .expect(\"create first task\");\n\n    let error = DaemonTaskService::create_task(\n        &store,\n        temp.path(),\n        &routing,\n        FlowPreset::Standard,\n        CreateTaskInput {\n            task_id: \"task-2\".to_owned(),\n            issue_ref: \"repo#1\".to_owned(),\n            project_id: \"demo-2\".to_owned(),\n            project_name: Some(\"Demo Two\".to_owned()),\n            prompt: Some(\"Prompt\".to_owned()),\n            routing_command: None,\n            routing_labels: vec![],\n            dispatch_mode: DispatchMode::Workflow,\n            source_revision: None,\n        },\n    )\n    .expect_err(\"duplicate issue should fail\");\n\n    assert!(matches!(error, AppError::DuplicateTaskForIssue { .. }));\n}\n\n#[test]\nfn retry_resets_failed_task_to_pending_and_increments_attempt_count() {\n    let store = FsDaemonStore;\n    let temp = tempdir().expect(\"tempdir\");\n    let mut task = sample_task();\n    task.status = TaskStatus::Failed;\n    task.set_failure(\"daemon_dispatch_failed\", \"boom\");\n    store.create_task(temp.path(), &task).expect(\"persist task\");\n\n    let retried = DaemonTaskService::retry_task(&store, temp.path(), &task.task_id)\n        .expect(\"retry failed task\");\n\n    assert_eq!(TaskStatus::Pending, retried.status);\n    assert_eq!(1, retried.attempt_count);\n    assert!(retried.failure_class.is_none());\n    assert!(retried.failure_message.is_none());\n}\n\n// ── Watched-issue ingestion tests ───────────────────────────────────────────\n\n#[test]\nfn watched_issue_ingestion_creates_task_idempotently() {\n    let store = FsDaemonStore;\n    let temp = tempdir().expect(\"tempdir\");\n    let routing = RoutingEngine::new();\n\n    let issue = WatchedIssueMeta {\n        issue_ref: \"org/repo#42\".to_owned(),\n        source_revision: \"deadbeef\".to_owned(),\n        title: \"Fix the thing\".to_owned(),\n        body: \"It is broken\".to_owned(),\n        labels: vec![],\n        routing_command: None,\n    };\n\n    // First ingestion creates a task\n    let result = DaemonTaskService::create_task_from_watched_issue(\n        &store,\n        temp.path(),\n        &routing,\n        FlowPreset::Standard,\n        &issue,\n        DispatchMode::Workflow,\n    )\n    .expect(\"create from watched issue\");\n    assert!(result.is_some());\n    let task = result.unwrap();\n    assert_eq!(\"org/repo#42\", task.issue_ref);\n    assert_eq!(Some(\"deadbeef\".to_owned()), task.source_revision);\n    assert_eq!(DispatchMode::Workflow, task.dispatch_mode);\n\n    // Second ingestion with same (issue_ref, source_revision) is a no-op\n    let result2 = DaemonTaskService::create_task_from_watched_issue(\n        &store,\n        temp.path(),\n        &routing,\n        FlowPreset::Standard,\n        &issue,\n        DispatchMode::Workflow,\n    )\n    .expect(\"idempotent re-ingestion\");\n    assert!(result2.is_none());\n}\n\n#[test]\nfn watched_issue_newer_revision_after_terminal_creates_fresh_task() {\n    let store = FsDaemonStore;\n    let temp = tempdir().expect(\"tempdir\");\n    let routing = RoutingEngine::new();\n\n    let issue1 = WatchedIssueMeta {\n        issue_ref: \"org/repo#50\".to_owned(),\n        source_revision: \"rev1aaaa\".to_owned(),\n        title: \"First\".to_owned(),\n        body: \"Body\".to_owned(),\n        labels: vec![],\n        routing_command: None,\n    };\n\n    // Create and complete the first task\n    let result = DaemonTaskService::create_task_from_watched_issue(\n        &store,\n        temp.path(),\n        &routing,\n        FlowPreset::Standard,\n        &issue1,\n        DispatchMode::Workflow,\n    )\n    .expect(\"create first\");\n    let task = result.unwrap();\n    DaemonTaskService::mark_completed(&store, temp.path(), &task.task_id)\n        .expect(\"mark completed - need claimed/active first\");\n\n    // Mark the task completed (need to go through the state machine)\n    let mut raw = store.read_task(temp.path(), &task.task_id).unwrap();\n    raw.status = TaskStatus::Completed;\n    raw.updated_at = Utc::now();\n    store.write_task(temp.path(), &raw).unwrap();\n\n    // New revision should create a fresh task\n    let issue2 = WatchedIssueMeta {\n        issue_ref: \"org/repo#50\".to_owned(),\n        source_revision: \"rev2bbbb\".to_owned(),\n        title: \"Second\".to_owned(),\n        body: \"Updated body\".to_owned(),\n        labels: vec![],\n        routing_command: None,\n    };\n\n    let result2 = DaemonTaskService::create_task_from_watched_issue(\n        &store,\n        temp.path(),\n        &routing,\n        FlowPreset::Standard,\n        &issue2,\n        DispatchMode::Workflow,\n    )\n    .expect(\"create second for new revision\");\n    assert!(result2.is_some());\n}\n\n#[test]\nfn watched_issue_different_revision_while_non_terminal_fails() {\n    let store = FsDaemonStore;\n    let temp = tempdir().expect(\"tempdir\");\n    let routing = RoutingEngine::new();\n\n    let issue1 = WatchedIssueMeta {\n        issue_ref: \"org/repo#60\".to_owned(),\n        source_revision: \"aaa11111\".to_owned(),\n        title: \"First\".to_owned(),\n        body: \"Body\".to_owned(),\n        labels: vec![],\n        routing_command: None,\n    };\n\n    DaemonTaskService::create_task_from_watched_issue(\n        &store,\n        temp.path(),\n        &routing,\n        FlowPreset::Standard,\n        &issue1,\n        DispatchMode::Workflow,\n    )\n    .expect(\"create first\");\n\n    let issue2 = WatchedIssueMeta {\n        issue_ref: \"org/repo#60\".to_owned(),\n        source_revision: \"bbb22222\".to_owned(),\n        title: \"Second\".to_owned(),\n        body: \"Body\".to_owned(),\n        labels: vec![],\n        routing_command: None,\n    };\n\n    let err = DaemonTaskService::create_task_from_watched_issue(\n        &store,\n        temp.path(),\n        &routing,\n        FlowPreset::Standard,\n        &issue2,\n        DispatchMode::Workflow,\n    )\n    .expect_err(\"should reject different revision while non-terminal\");\n\n    assert!(matches!(err, AppError::DuplicateWatchedIssue { .. }));\n}\n\n#[test]\nfn waiting_for_requirements_resume_transitions() {\n    let store = FsDaemonStore;\n    let temp = tempdir().expect(\"tempdir\");\n\n    let mut task = sample_task();\n    task.status = TaskStatus::Active;\n    store.create_task(temp.path(), &task).expect(\"persist task\");\n\n    // Transition to waiting\n    let waiting = DaemonTaskService::mark_waiting_for_requirements(\n        &store,\n        temp.path(),\n        &task.task_id,\n        \"req-20260313\",\n    )\n    .expect(\"mark waiting\");\n    assert_eq!(TaskStatus::WaitingForRequirements, waiting.status);\n    assert_eq!(Some(\"req-20260313\".to_owned()), waiting.requirements_run_id);\n    assert!(waiting.lease_id.is_none());\n\n    // Resume from waiting\n    let resumed = DaemonTaskService::resume_from_waiting(&store, temp.path(), &task.task_id)\n        .expect(\"resume from waiting\");\n    assert_eq!(TaskStatus::Pending, resumed.status);\n    assert_eq!(DispatchMode::Workflow, resumed.dispatch_mode);\n}\n\n#[test]\nfn resume_from_non_waiting_state_fails() {\n    let store = FsDaemonStore;\n    let temp = tempdir().expect(\"tempdir\");\n\n    let task = sample_task();\n    store.create_task(temp.path(), &task).expect(\"persist task\");\n\n    let err = DaemonTaskService::resume_from_waiting(&store, temp.path(), &task.task_id)\n        .expect_err(\"should fail for pending task\");\n    assert!(matches!(err, AppError::TaskStateTransitionInvalid { .. }));\n}\n\n// ── Requirements command parsing ────────────────────────────────────────────\n\n#[test]\nfn parse_requirements_command_draft() {\n    let result = parse_requirements_command(\"/rb requirements draft\").unwrap();\n    assert_eq!(Some(DispatchMode::RequirementsDraft), result);\n}\n\n#[test]\nfn parse_requirements_command_quick() {\n    let result = parse_requirements_command(\"/rb requirements quick\").unwrap();\n    assert_eq!(Some(DispatchMode::RequirementsQuick), result);\n}\n\n#[test]\nfn parse_requirements_command_unknown_fails() {\n    let result = parse_requirements_command(\"/rb requirements bogus\");\n    assert!(result.is_err());\n}\n\n#[test]\nfn parse_requirements_command_no_match() {\n    let result = parse_requirements_command(\"/rb flow standard\").unwrap();\n    assert_eq!(None, result);\n}\n\n#[test]\nfn parse_requirements_command_multiline_body() {\n    let body = \"Please help.\\n\\n/rb requirements quick\\n\\nThanks!\";\n    let result = parse_requirements_command(body).unwrap();\n    assert_eq!(Some(DispatchMode::RequirementsQuick), result);\n}\n\n// ── Dispatch mode serialization ─────────────────────────────────────────────\n\n#[test]\nfn dispatch_mode_display() {\n    assert_eq!(\"workflow\", DispatchMode::Workflow.as_str());\n    assert_eq!(\"requirements_draft\", DispatchMode::RequirementsDraft.as_str());\n    assert_eq!(\"requirements_quick\", DispatchMode::RequirementsQuick.as_str());\n}\n\n#[test]\nfn task_with_dispatch_mode_roundtrips_through_json() {\n    let mut task = sample_task();\n    task.dispatch_mode = DispatchMode::RequirementsQuick;\n    task.source_revision = Some(\"abc123\".to_owned());\n    task.requirements_run_id = Some(\"req-123\".to_owned());\n\n    let json = serde_json::to_string(&task).expect(\"serialize\");\n    let deserialized: DaemonTask = serde_json::from_str(&json).expect(\"deserialize\");\n\n    assert_eq!(DispatchMode::RequirementsQuick, deserialized.dispatch_mode);\n    assert_eq!(Some(\"abc123\".to_owned()), deserialized.source_revision);\n    assert_eq!(Some(\"req-123\".to_owned()), deserialized.requirements_run_id);\n}\n\n#[test]\nfn task_without_dispatch_mode_defaults_to_workflow() {\n    // Backward compat: older JSON without dispatch_mode should default to workflow\n    let json = r#\"{\n        \"task_id\": \"task-old\",\n        \"issue_ref\": \"repo#1\",\n        \"project_id\": \"demo\",\n        \"status\": \"pending\",\n        \"created_at\": \"2026-03-13T00:00:00Z\",\n        \"updated_at\": \"2026-03-13T00:00:00Z\",\n        \"attempt_count\": 0\n    }\"#;\n    let task: DaemonTask = serde_json::from_str(json).expect(\"deserialize legacy task\");\n    assert_eq!(DispatchMode::Workflow, task.dispatch_mode);\n    assert!(task.source_revision.is_none());\n    assert!(task.requirements_run_id.is_none());\n}\n","numLines":509,"startLine":1,"totalLines":509}}}
