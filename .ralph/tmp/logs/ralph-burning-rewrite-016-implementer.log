\", &overrides.to_string())],\n  3537→        )?;\n  3538→        // The run may complete or fail depending on engine behavior\n  3539→        // Either way, rollback points should have been created\n  3540→\n  3541→        // Read current status and journal\n  3542→        let pre_events = read_journal(&ws, \"rb-soft\")?;\n  3543→        let types = journal_event_types(&pre_events);\n  3544→        let has_rollback_created = types.iter().any(|t| t == \"rollback_created\");\n  3545→        if !has_rollback_created {\n  3546→            return Err(\"expected rollback_created event in journal\".into());\n  3547→        }\n  3548→\n  3549→        // If run completed, manually set to failed for rollback test\n  3550→        let pre_snap = read_run_snapshot(&ws, \"rb-soft\")?;\n  3551→        let status = pre_snap.get(\"status\").and_then(|v| v.as_str()).unwrap_or(\"\");\n  3552→        if status == \"completed\" || status == \"running\" {\n  3553→            let mut snap = pre_snap.clone();\n  3554→            snap[\"status\"] = serde_json::json!(\"failed\");\n  3555→            snap[\"active_run\"] = serde_json::json!(null);\n  3556→            snap[\"status_summary\"] = serde_json::json!(\"failed for rollback test\");\n  3557→            std::fs::write(\n  3558→                ws.path().join(\".ralph-burning/projects/rb-soft/run.json\"),\n  3559→                serde_json::to_string_pretty(&snap).unwrap(),\n  3560→            ).map_err(|e| e.to_string())?;\n  3561→        }\n  3562→\n  3563→        // Now rollback to planning\n  3564→        let rb = run_cli(&[\"run\", \"rollback\", \"--to\", \"planning\"], ws.path())?;\n  3565→        assert_success(&rb)?;\n  3566→\n  3567→        // Verify: status is paused, journal has rollback_performed\n  3568→        let post_snap = read_run_snapshot(&ws, \"rb-soft\")?;\n  3569→        let post_status = post_snap.get(\"status\").and_then(|v| v.as_str()).unwrap_or(\"\");\n  3570→        if post_status != \"paused\" {\n  3571→            return Err(format!(\"expected paused after rollback, got '{post_status}'\"));\n  3572→        }\n  3573→        let post_events = read_journal(&ws, \"rb-soft\")?;\n  3574→        let post_types = journal_event_types(&post_events);\n  3575→        if !post_types.iter().any(|t| t == \"rollback_performed\") {\n  3576→            return Err(\"journal missing rollback_performed event\".into());\n  3577→        }\n  3578→        Ok(())\n  3579→    });\n  3580→\n  3581→    reg!(m, \"SC-ROLLBACK-002\", || {\n  3582→        // Hard rollback resets canonical state before the repository.\n  3583→        // Feature: the target rollback point for \"implementation\" records a git SHA,\n  3584→        // and the repository reset targets that SHA. The logical rollback is committed\n  3585→        // before the git reset is attempted.\n  3586→        let ws = TempWorkspace::new()?;\n  3587→        setup_workspace_with_project(&ws, \"rb-hard\", \"standard\")?;\n  3588→\n  3589→        // Initialize a git repo so rollback points record a real git SHA\n  3590→        let _initial_sha = init_git_repo(&ws)?;\n  3591→\n  3592→        // Create rollback points via conditionally_approved completion_panel\n  3593→        let overrides = serde_json::json!({\n  3594→            \"completion_panel\": [\n  3595→                {\n  3596→                    \"outcome\": \"conditionally_approved\",\n  3597→                    \"evidence\": [\"Changes\"],\n  3598→                    \"findings_or_gaps\": [],\n  3599→                    \"follow_up_or_amendments\": [{\"summary\": \"Fix\", \"details\": \"D\"}]\n  3600→                },\n  3601→                {\n  3602→                    \"outcome\": \"approved\",\n  3603→                    \"evidence\": [\"OK\"],\n  3604→                    \"findings_or_gaps\": [],\n  3605→                    \"follow_up_or_amendments\": []\n  3606→                }\n  3607→            ]\n  3608→        });\n  3609→        let _start = run_cli_with_env(\n  3610→            &[\"run\", \"start\"],\n  3611→            ws.path(),\n  3612→            &[(\"RALPH_BURNING_TEST_STAGE_OVERRIDES\", &overrides.to_string())],\n  3613→        )?;\n  3614→\n  3615→        // Verify rollback points were created with a git SHA\n  3616→        let pre_events = read_journal(&ws, \"rb-hard\")?;\n  3617→        let rb_created = pre_events.iter().find(|e| {\n  3618→            e.get(\"event_type\").and_then(|v| v.as_str()) == Some(\"rollback_created\")\n  3619→        });\n  3620→        if rb_created.is_none() {\n  3621→            return Err(\"expected rollback_created event after run start\".into());\n  3622→        }\n  3623→        let created_sha = rb_created.unwrap()\n  3624→            .get(\"details\")\n  3625→            .and_then(|d| d.get(\"git_sha\"))\n  3626→            .and_then(|v| v.as_str())\n  3627→            .unwrap_or(\"\");\n  3628→        if created_sha.is_empty() {\n  3629→            return Err(\"rollback_created event should record a non-empty git_sha\".into());\n  3630→        }\n  3631→\n  3632→        // Set to paused for rollback\n  3633→        let snap = read_run_snapshot(&ws, \"rb-hard\")?;\n  3634→        let mut snap = snap.clone();\n  3635→        snap[\"status\"] = serde_json::json!(\"paused\");\n  3636→        snap[\"active_run\"] = serde_json::json!(null);\n  3637→        snap[\"status_summary\"] = serde_json::json!(\"paused for rollback test\");\n  3638→        std::fs::write(\n  3639→            ws.path().join(\".ralph-burning/projects/rb-hard/run.json\"),\n  3640→            serde_json::to_string_pretty(&snap).unwrap(),\n  3641→        ).map_err(|e| e.to_string())?;\n  3642→\n  3643→        // Hard rollback to implementation — git repo exists so reset should succeed.\n  3644→        let rb = run_cli(&[\"run\", \"rollback\", \"--to\", \"implementation\", \"--hard\"], ws.path())?;\n  3645→        assert_success(&rb)?;\n  3646→\n  3647→        // Verify logical rollback committed\n  3648→        let post_snap = read_run_snapshot(&ws, \"rb-hard\")?;\n  3649→        let post_status = post_snap.get(\"status\").and_then(|v| v.as_str()).unwrap_or(\"\");\n  3650→        if post_status != \"paused\" {\n  3651→            return Err(format!(\"logical rollback should set paused, got '{post_status}'\"));\n  3652→        }\n  3653→\n  3654→        // Journal should have rollback_performed\n  3655→        let post_events = read_journal(&ws, \"rb-hard\")?;\n  3656→        let rb_event = post_events.iter().find(|e| {\n  3657→            e.get(\"event_type\").and_then(|v| v.as_str()) == Some(\"rollback_performed\")\n  3658→        });\n  3659→        if rb_event.is_none() {\n  3660→            return Err(\"journal should have rollback_performed event\".into());\n  3661→        }\n  3662→        let rb_event = rb_event.unwrap();\n  3663→\n  3664→        // Verify the rollback_performed event targets implementation\n  3665→        let rb_stage = rb_event\n  3666→            .get(\"details\")\n  3667→            .and_then(|d| d.get(\"stage_id\"))\n  3668→            .and_then(|v| v.as_str())\n  3669→            .unwrap_or(\"\");\n  3670→        if rb_stage != \"implementation\" {\n  3671→            return Err(format!(\"rollback_performed should target implementation, got '{rb_stage}'\"));\n  3672→        }\n  3673→\n  3674→        // Verify hard=true\n  3675→        let hard_flag = rb_event\n  3676→            .get(\"details\")\n  3677→            .and_then(|d| d.get(\"hard\"))\n  3678→            .and_then(|v| v.as_bool())\n  3679→            .unwrap_or(false);\n  3680→        if !hard_flag {\n  3681→            return Err(\"rollback_performed event should have hard=true\".into());\n  3682→        }\n  3683→\n  3684→        // Verify the event records a concrete git_sha matching the rollback point\n  3685→        let event_sha = rb_event\n  3686→            .get(\"details\")\n  3687→            .and_then(|d| d.get(\"git_sha\"))\n  3688→            .and_then(|v| v.as_str())\n  3689→            .unwrap_or(\"\");\n  3690→        if event_sha.is_empty() {\n  3691→            return Err(\"rollback_performed event must record a non-empty git_sha for hard rollback\".into());\n  3692→        }\n  3693→\n  3694→        // Verify the repository reset targeted the recorded SHA — after hard reset,\n  3695→        // HEAD should point at the SHA from the rollback point\n  3696→        let head_output = Command::new(\"git\")\n  3697→            .args([\"rev-parse\", \"HEAD\"])\n  3698→            .current_dir(ws.path())\n  3699→            .output()\n  3700→            .map_err(|e| format!(\"git rev-parse HEAD: {e}\"))?;\n  3701→        let current_head = String::from_utf8_lossy(&head_output.stdout).trim().to_owned();\n  3702→        if current_head != event_sha {\n  3703→            return Err(format!(\n  3704→                \"repository HEAD should be reset to rollback SHA {event_sha}, got {current_head}\"\n  3705→            ));\n  3706→        }\n  3707→\n  3708→        Ok(())\n  3709→    });\n  3710→\n  3711→    reg!(m, \"SC-ROLLBACK-003\", || {\n  3712→        // Rollback rejects non-resumable run statuses\n  3713→        let ws = TempWorkspace::new()?;\n  3714→        setup_workspace_with_project(&ws, \"rb-reject\", \"standard\")?;\n  3715→        // not_started → rollback should fail\n  3716→        let out = run_cli(&[\"run\", \"rollback\", \"--to\", \"planning\"], ws.path())?;\n  3717→        assert_failure(&out)?;\n  3718→        Ok(())\n  3719→    });\n  3720→\n  3721→    reg!(m, \"SC-ROLLBACK-004\", || {\n  3722→        // Rollback rejects a stage outside the project flow\n  3723→        let ws = TempWorkspace::new()?;\n  3724→        setup_workspace_with_project(&ws, \"rb-bad-stage\", \"standard\")?;\n  3725→        let run_json = r#\"{\"active_run\":null,\"status\":\"failed\",\"cycle_history\":[],\"completion_rounds\":0,\"rollback_point_meta\":{\"last_rollback_id\":null,\"rollback_count\":0},\"amendment_queue\":{\"pending\":[],\"processed_count\":0},\"status_summary\":\"failed\"}\"#;\n  3726→        std::fs::write(\n  3727→            ws.path().join(\".ralph-burning/projects/rb-bad-stage/run.json\"),\n  3728→            run_json,\n  3729→        ).map_err(|e| e.to_string())?;\n  3730→        // ci_plan is not part of the standard flow\n  3731→        let out = run_cli(&[\"run\", \"rollback\", \"--to\", \"ci_plan\"], ws.path())?;\n  3732→        assert_failure(&out)?;\n  3733→        assert_contains(&out.stderr, \"not part of flow\", \"stderr\")?;\n  3734→        Ok(())\n  3735→    });\n  3736→\n  3737→    reg!(m, \"SC-ROLLBACK-005\", || {\n  3738→        // Rollback rejects stage with no visible checkpoint\n  3739→        let ws = TempWorkspace::new()?;\n  3740→        setup_workspace_with_project(&ws, \"rb-no-point\", \"standard\")?;\n  3741→        let run_json = r#\"{\"active_run\":null,\"status\":\"failed\",\"cycle_history\":[],\"completion_rounds\":0,\"rollback_point_meta\":{\"last_rollback_id\":null,\"rollback_count\":0},\"amendment_queue\":{\"pending\":[],\"processed_count\":0},\"status_summary\":\"failed\"}\"#;\n  3742→        std::fs::write(\n  3743→            ws.path().join(\".ralph-burning/projects/rb-no-point/run.json\"),\n  3744→            run_json,\n  3745→        ).map_err(|e| e.to_string())?;\n  3746→        let out = run_cli(&[\"run\", \"rollback\", \"--to\", \"review\"], ws.path())?;\n  3747→        assert_failure(&out)?;\n  3748→        assert_contains(&out.stderr, \"rollback point\", \"stderr\")?;\n  3749→        Ok(())\n  3750→    });\n  3751→\n  3752→    reg!(m, \"SC-ROLLBACK-006\", || {\n  3753→        // Multiple sequential rollbacks keep rollback metadata monotonic.\n  3754→        // Feature: roll back to \"implementation\" and then to \"planning\".\n  3755→        // Verify rollback_count increases, last_rollback_id matches, and\n  3756→        // run history (the user-visible output) excludes the abandoned branch\n  3757→        // after each rollback.\n  3758→        let ws = TempWorkspace::new()?;\n  3759→        setup_workspace_with_project(&ws, \"rb-multi\", \"standard\")?;\n  3760→\n  3761→        // Create rollback points by running with conditionally_approved panel\n  3762→        let overrides = serde_json::json!({\n  3763→            \"completion_panel\": [\n  3764→                {\n  3765→                    \"outcome\": \"conditionally_approved\",\n  3766→                    \"evidence\": [\"Changes\"],\n  3767→                    \"findings_or_gaps\": [],\n  3768→                    \"follow_up_or_amendments\": [{\"summary\": \"Fix\", \"details\": \"D\"}]\n  3769→                },\n  3770→                {\n  3771→                    \"outcome\": \"approved\",\n  3772→                    \"evidence\": [\"OK\"],\n  3773→                    \"findings_or_gaps\": [],\n  3774→                    \"follow_up_or_amendments\": []\n  3775→                }\n  3776→            ]\n  3777→        });\n  3778→        let _start = run_cli_with_env(\n  3779→            &[\"run\", \"start\"],\n  3780→            ws.path(),\n  3781→            &[(\"RALPH_BURNING_TEST_STAGE_OVERRIDES\", &overrides.to_string())],\n  3782→        )?;\n  3783→\n  3784→        // Capture the pre-rollback history to compare later\n  3785→        let pre_history = run_cli(&[\"run\", \"history\"], ws.path())?;\n  3786→        assert_success(&pre_history)?;\n  3787→        // Count stage_completed events visible before any rollback\n  3788→        let pre_completed_count = pre_history.stdout.matches(\"stage_completed\").count();\n  3789→\n  3790→        // Set to failed for rollback\n  3791→        let snap = read_run_snapshot(&ws, \"rb-multi\")?;\n  3792→        let mut snap = snap.clone();\n  3793→        snap[\"status\"] = serde_json::json!(\"failed\");\n  3794→        snap[\"active_run\"] = serde_json::json!(null);\n  3795→        std::fs::write(\n  3796→            ws.path().join(\".ralph-burning/projects/rb-multi/run.json\"),\n  3797→            