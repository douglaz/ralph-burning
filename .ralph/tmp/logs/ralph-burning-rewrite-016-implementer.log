{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01UtGxxdyDBBGCukv4UqqAnR","type":"tool_result","content":"     1→use serde_json::json;\n     2→\n     3→use ralph_burning::contexts::requirements_drafting::contracts::RequirementsContract;\n     4→use ralph_burning::contexts::requirements_drafting::model::{\n     5→    RequirementsMode, RequirementsReviewOutcome, RequirementsRun, RequirementsStageId,\n     6→    RequirementsStatus,\n     7→};\n     8→use ralph_burning::contexts::requirements_drafting::renderers;\n     9→use ralph_burning::shared::error::ContractError;\n    10→\n    11→use chrono::{TimeZone, Utc};\n    12→\n    13→// ── Model tests ─────────────────────────────────────────────────────────────\n    14→\n    15→#[test]\n    16→fn requirements_run_new_draft_creates_run_in_draft_mode_and_drafting_status() {\n    17→    let now = Utc\n    18→        .with_ymd_and_hms(2026, 3, 12, 10, 0, 0)\n    19→        .single()\n    20→        .expect(\"valid timestamp\");\n    21→    let run = RequirementsRun::new_draft(\"req-001\".to_owned(), \"Build a widget\".to_owned(), now);\n    22→\n    23→    assert_eq!(run.run_id, \"req-001\");\n    24→    assert_eq!(run.idea, \"Build a widget\");\n    25→    assert_eq!(run.mode, RequirementsMode::Draft);\n    26→    assert_eq!(run.status, RequirementsStatus::Drafting);\n    27→    assert_eq!(run.question_round, 0);\n    28→    assert!(run.latest_question_set_id.is_none());\n    29→    assert!(run.latest_draft_id.is_none());\n    30→    assert!(run.latest_review_id.is_none());\n    31→    assert!(run.latest_seed_id.is_none());\n    32→    assert_eq!(run.created_at, now);\n    33→    assert_eq!(run.updated_at, now);\n    34→}\n    35→\n    36→#[test]\n    37→fn requirements_run_new_quick_creates_run_in_quick_mode_and_drafting_status() {\n    38→    let now = Utc\n    39→        .with_ymd_and_hms(2026, 3, 12, 10, 0, 0)\n    40→        .single()\n    41→        .expect(\"valid timestamp\");\n    42→    let run = RequirementsRun::new_quick(\"req-002\".to_owned(), \"Add a feature\".to_owned(), now);\n    43→\n    44→    assert_eq!(run.run_id, \"req-002\");\n    45→    assert_eq!(run.idea, \"Add a feature\");\n    46→    assert_eq!(run.mode, RequirementsMode::Quick);\n    47→    assert_eq!(run.status, RequirementsStatus::Drafting);\n    48→    assert_eq!(run.question_round, 0);\n    49→    assert_eq!(run.created_at, now);\n    50→    assert_eq!(run.updated_at, now);\n    51→}\n    52→\n    53→#[test]\n    54→fn requirements_run_is_terminal_returns_true_for_completed_and_failed() {\n    55→    let now = Utc::now();\n    56→\n    57→    let mut run = RequirementsRun::new_draft(\"t-1\".to_owned(), \"idea\".to_owned(), now);\n    58→    assert!(!run.is_terminal(), \"Drafting should not be terminal\");\n    59→\n    60→    run.status = RequirementsStatus::AwaitingAnswers;\n    61→    assert!(!run.is_terminal(), \"AwaitingAnswers should not be terminal\");\n    62→\n    63→    run.status = RequirementsStatus::Completed;\n    64→    assert!(run.is_terminal(), \"Completed should be terminal\");\n    65→\n    66→    run.status = RequirementsStatus::Failed;\n    67→    assert!(run.is_terminal(), \"Failed should be terminal\");\n    68→}\n    69→\n    70→#[test]\n    71→fn requirements_review_outcome_allows_completion_for_approved_and_conditionally_approved() {\n    72→    assert!(RequirementsReviewOutcome::Approved.allows_completion());\n    73→    assert!(RequirementsReviewOutcome::ConditionallyApproved.allows_completion());\n    74→    assert!(!RequirementsReviewOutcome::RequestChanges.allows_completion());\n    75→    assert!(!RequirementsReviewOutcome::Rejected.allows_completion());\n    76→}\n    77→\n    78→#[test]\n    79→fn requirements_stage_id_as_str_round_trips_via_serde() {\n    80→    let all_variants = [\n    81→        RequirementsStageId::QuestionSet,\n    82→        RequirementsStageId::RequirementsDraft,\n    83→        RequirementsStageId::RequirementsReview,\n    84→        RequirementsStageId::ProjectSeed,\n    85→    ];\n    86→\n    87→    for variant in all_variants {\n    88→        let as_str = variant.as_str();\n    89→        // Serialize via serde to a JSON string, then strip quotes to get the raw string\n    90→        let serialized = serde_json::to_value(variant).expect(\"serialize stage id\");\n    91→        let serde_str = serialized.as_str().expect(\"should be a string\");\n    92→        assert_eq!(\n    93→            as_str, serde_str,\n    94→            \"as_str and serde representation should match for {:?}\",\n    95→            variant\n    96→        );\n    97→\n    98→        // Deserialize back\n    99→        let deserialized: RequirementsStageId =\n   100→            serde_json::from_value(serialized).expect(\"deserialize stage id\");\n   101→        assert_eq!(variant, deserialized);\n   102→    }\n   103→}\n   104→\n   105→// ── Contract tests ──────────────────────────────────────────────────────────\n   106→\n   107→#[test]\n   108→fn question_set_contract_accepts_valid_json() {\n   109→    let valid = json!({\n   110→        \"questions\": [\n   111→            {\n   112→                \"id\": \"q1\",\n   113→                \"prompt\": \"What framework?\",\n   114→                \"rationale\": \"Determines architecture\",\n   115→                \"required\": true\n   116→            }\n   117→        ]\n   118→    });\n   119→\n   120→    let bundle = RequirementsContract::question_set()\n   121→        .evaluate(&valid)\n   122→        .expect(\"valid question set should pass\");\n   123→    assert!(!bundle.artifact.is_empty());\n   124→}\n   125→\n   126→#[test]\n   127→fn question_set_with_duplicate_ids_fails_domain_validation() {\n   128→    let duplicate_ids = json!({\n   129→        \"questions\": [\n   130→            {\n   131→                \"id\": \"q1\",\n   132→                \"prompt\": \"First question?\",\n   133→                \"rationale\": \"Reason A\",\n   134→                \"required\": true\n   135→            },\n   136→            {\n   137→                \"id\": \"q1\",\n   138→                \"prompt\": \"Second question?\",\n   139→                \"rationale\": \"Reason B\",\n   140→                \"required\": false\n   141→            }\n   142→        ]\n   143→    });\n   144→\n   145→    let err = RequirementsContract::question_set()\n   146→        .evaluate(&duplicate_ids)\n   147→        .expect_err(\"duplicate IDs should fail\");\n   148→    assert!(\n   149→        matches!(err, ContractError::DomainValidation { .. }),\n   150→        \"expected DomainValidation, got: {err:?}\"\n   151→    );\n   152→}\n   153→\n   154→#[test]\n   155→fn question_set_with_empty_prompt_fails_domain_validation() {\n   156→    let empty_prompt = json!({\n   157→        \"questions\": [\n   158→            {\n   159→                \"id\": \"q1\",\n   160→                \"prompt\": \"   \",\n   161→                \"rationale\": \"Reason\",\n   162→                \"required\": true\n   163→            }\n   164→        ]\n   165→    });\n   166→\n   167→    let err = RequirementsContract::question_set()\n   168→        .evaluate(&empty_prompt)\n   169→        .expect_err(\"empty prompt should fail\");\n   170→    assert!(\n   171→        matches!(err, ContractError::DomainValidation { .. }),\n   172→        \"expected DomainValidation, got: {err:?}\"\n   173→    );\n   174→}\n   175→\n   176→#[test]\n   177→fn question_set_with_space_in_id_fails_domain_validation() {\n   178→    let space_id = json!({\n   179→        \"questions\": [\n   180→            {\n   181→                \"id\": \"team name\",\n   182→                \"prompt\": \"What is the team name?\",\n   183→                \"rationale\": \"Needed for naming\",\n   184→                \"required\": true\n   185→            }\n   186→        ]\n   187→    });\n   188→\n   189→    let err = RequirementsContract::question_set()\n   190→        .evaluate(&space_id)\n   191→        .expect_err(\"ID with spaces should fail\");\n   192→    match &err {\n   193→        ContractError::DomainValidation { details, .. } => {\n   194→            assert!(\n   195→                details.contains(\"TOML bare keys\"),\n   196→                \"error should mention TOML bare keys, got: {details}\"\n   197→            );\n   198→        }\n   199→        _ => panic!(\"expected DomainValidation, got: {err:?}\"),\n   200→    }\n   201→}\n   202→\n   203→#[test]\n   204→fn question_set_with_dot_in_id_fails_domain_validation() {\n   205→    let dot_id = json!({\n   206→        \"questions\": [\n   207→            {\n   208→                \"id\": \"api.version\",\n   209→                \"prompt\": \"Which API version?\",\n   210→                \"rationale\": \"Determines compatibility\",\n   211→                \"required\": false\n   212→            }\n   213→        ]\n   214→    });\n   215→\n   216→    let err = RequirementsContract::question_set()\n   217→        .evaluate(&dot_id)\n   218→        .expect_err(\"ID with dots should fail\");\n   219→    match &err {\n   220→        ContractError::DomainValidation { details, .. } => {\n   221→            assert!(\n   222→                details.contains(\"TOML bare keys\"),\n   223→                \"error should mention TOML bare keys, got: {details}\"\n   224→            );\n   225→        }\n   226→        _ => panic!(\"expected DomainValidation, got: {err:?}\"),\n   227→    }\n   228→}\n   229→\n   230→#[test]\n   231→fn question_set_with_valid_bare_key_ids_passes_validation() {\n   232→    let valid = json!({\n   233→        \"questions\": [\n   234→            {\n   235→                \"id\": \"team-name\",\n   236→                \"prompt\": \"What is the team name?\",\n   237→                \"rationale\": \"Needed\",\n   238→                \"required\": true\n   239→            },\n   240→            {\n   241→                \"id\": \"api_version_2\",\n   242→                \"prompt\": \"Which API version?\",\n   243→                \"rationale\": \"Compat\",\n   244→                \"required\": false\n   245→            }\n   246→        ]\n   247→    });\n   248→\n   249→    RequirementsContract::question_set()\n   250→        .evaluate(&valid)\n   251→        .expect(\"IDs with alphanumeric, underscore, hyphen should pass\");\n   252→}\n   253→\n   254→#[test]\n   255→fn draft_contract_accepts_valid_json() {\n   256→    let valid = json!({\n   257→        \"problem_summary\": \"We need a caching layer.\",\n   258→        \"goals\": [\"Reduce latency by 50%\"],\n   259→        \"non_goals\": [],\n   260→        \"constraints\": [\"Must use existing infrastructure\"],\n   261→        \"acceptance_criteria\": [\"P95 latency < 100ms\"],\n   262→        \"risks_or_open_questions\": [],\n   263→        \"recommended_flow\": \"standard\"\n   264→    });\n   265→\n   266→    let bundle = RequirementsContract::draft()\n   267→        .evaluate(&valid)\n   268→        .expect(\"valid draft should pass\");\n   269→    assert!(!bundle.artifact.is_empty());\n   270→}\n   271→\n   272→#[test]\n   273→fn draft_with_empty_problem_summary_fails_domain_validation() {\n   274→    let empty_summary = json!({\n   275→        \"problem_summary\": \"   \",\n   276→        \"goals\": [\"A goal\"],\n   277→        \"non_goals\": [],\n   278→        \"constraints\": [],\n   279→        \"acceptance_criteria\": [\"Criteria\"],\n   280→        \"risks_or_open_questions\": [],\n   281→        \"recommended_flow\": \"standard\"\n   282→    });\n   283→\n   284→    let err = RequirementsContract::draft()\n   285→        .evaluate(&empty_summary)\n   286→        .expect_err(\"empty problem_summary should fail\");\n   287→    assert!(\n   288→        matches!(err, ContractError::DomainValidation { .. }),\n   289→        \"expected DomainValidation, got: {err:?}\"\n   290→    );\n   291→}\n   292→\n   293→#[test]\n   294→fn draft_with_empty_goals_fails_domain_validation() {\n   295→    let empty_goals = json!({\n   296→        \"problem_summary\": \"A valid summary.\",\n   297→        \"goals\": [],\n   298→        \"non_goals\": [],\n   299→        \"constraints\": [],\n   300→        \"acceptance_criteria\": [\"Criteria\"],"}]},"parent_tool_use_id":"toolu_01PonAeiQu5NceZBvGqbs1CE","session_id":"8dacb19c-9278-40df-b484-c803ec7bbb98","uuid":"6ffeeba8-9bc5-47ef-8d00-f53978c5cd82"}
