   let out = Command::new(binary_path())\n   410→            .args([\"config\", \"edit\"])\n   411→            .current_dir(ws.path())\n   412→            .env(\"EDITOR\", script_path.to_string_lossy().as_ref())\n   413→            .output()\n   414→            .map_err(|e| format!(\"run config edit: {e}\"))?;\n   415→        if !out.status.success() {\n   416→            return Err(format!(\"config edit failed: {}\", String::from_utf8_lossy(&out.stderr)));\n   417→        }\n   418→        let toml = std::fs::read_to_string(ws.path().join(\".ralph-burning/workspace.toml\"))\n   419→            .map_err(|e| e.to_string())?;\n   420→        assert_contains(&toml, \"claude\", \"workspace.toml\")?;\n   421→        Ok(())\n   422→    });\n   423→\n   424→    reg!(m, \"workspace-config-edit-invalid\", || {\n   425→        let ws = TempWorkspace::new()?;\n   426→        init_workspace(&ws)?;\n   427→        let script_path = ws.path().join(\"editor.sh\");\n   428→        std::fs::write(\n   429→            &script_path,\n   430→            \"#!/bin/sh\\necho 'not valid toml {{{' > \\\"$1\\\"\\n\",\n   431→        ).map_err(|e| e.to_string())?;\n   432→        #[cfg(unix)]\n   433→        {\n   434→            use std::os::unix::fs::PermissionsExt;\n   435→            let mut perms = std::fs::metadata(&script_path).map_err(|e| e.to_string())?.permissions();\n   436→            perms.set_mode(0o755);\n   437→            std::fs::set_permissions(&script_path, perms).map_err(|e| e.to_string())?;\n   438→        }\n   439→        let out = Command::new(binary_path())\n   440→            .args([\"config\", \"edit\"])\n   441→            .current_dir(ws.path())\n   442→            .env(\"EDITOR\", script_path.to_string_lossy().as_ref())\n   443→            .output()\n   444→            .map_err(|e| format!(\"run config edit: {e}\"))?;\n   445→        if out.status.success() {\n   446→            return Err(\"config edit with invalid toml should fail\".into());\n   447→        }\