s\n    46→            .iter()\n    47→            .any(|task| task.issue_ref == issue_ref && !task.is_terminal())\n    48→        {\n    49→            return Err(AppError::DuplicateTaskForIssue { issue_ref });\n    50→        }\n    51→\n    52→        let resolution = routing_engine.resolve_flow(\n    53→            input.routing_command.as_deref(),\n    54→            &input.routing_labels,\n    55→            default_flow,\n    56→        )?;\n    57→\n    58→        let now = Utc::now();\n    59→        let task = DaemonTask {\n    60→            task_id: input.task_id,\n    61→            issue_ref: normalize_required(\"issue_ref\", &input.issue_ref)?,\n    62→            project_id: project_id.to_string(),\n    63→            project_name: input.project_name.filter(|value| !value.trim().is_empty()),\n    64→            prompt: input.prompt.filter(|value| !value.trim().is_empty()),\n    65→            routing_command: input\n    66→                .routing_command\n    67→                .filter(|value| !value.trim().is_empty()),\n    68→            routing_labels: input.routing_labels,\n    69→            resolved_flow: Some(resolution.flow),\n    70→            routing_source: Some(resolution.source),\n    71→            routing_warnings: resolution.warnings.clone(),\n    72→            status: TaskStatus::Pending,\n    73→            created_at: now,\n    74→            updated_at: now,\n    75→            attempt_count: 0,\n    76→            lease_id: None,\n    77→            failure_class: None,\n    78→            failure_message: None,\n    79→        };\n    80→\n    81→        store.create_task(base_dir, &task)?;\n    82→        Self::append_journal_event(\n    83→            store,\n    84→            base_dir,\n    85→            DaemonJournalEventType::TaskCreated,\n    86→            json!({\n    87→                \"task_id\": task.task_id,\n    88→                \"issue_ref\": task.issue_ref,\n    89→                \"project_id\": task.project_id,\n    90→                \"flow\": resolution.flow,\n    91→                \"routing_source\": resolution.source,\n    92→                \"warnings\": resolution.warnings,\n    93→            }),\n    94→        )?;\n    95→\n    96→        Ok(task)\n    97→    }\n    98→\n    99→    pub fn claim_task(\n   100→        store: &dyn DaemonStorePort,\n   101→        worktree: &dyn WorktreePort,\n   102→        routing_engine: &RoutingEngine,\n   103→        base_dir: &Path,\n   104→        repo_root: &Path,\n   105→        task_id: &str,\n   106→        default_flow: FlowPreset,\n   107→        lease_ttl_seconds: u64,\n   108→    ) -> AppResult<(DaemonTask, WorktreeLease)> {\n   109→        let mut task = store.read_task(base_dir, task_id)?;\n   110→        if task.status != TaskStatus::Pending {\n   111→            return Err(AppError::TaskStateTransitionInvalid {\n   112→                task_id: task.task_id.clone(),\n   113→                from: task.status.as_str().to_owned(),\n   114→                to: TaskStatus::Claimed.as_str().to_owned(),\n   115→            });\n   116→        }\n   117→\n   118→        if task.lease_id.is_some()\n   119→            || store\n   120→                .list_leases(base_dir)?\n   121→                .iter()\n   122→                .any(|lease| lease.task_id == task.task_id)\n   123→        {\n   124→            return Err(AppError::TaskStateTransitionInvalid {\n   125→                task_id: task.task_id.clone(),\n   126→                from: task.status.as_str().to_owned(),\n   127→                to: \"claimed_with_duplicate_lease\".to_owned(),\n   128→            });\n   129→        }\n   130→\n   131→        hydrate_routing(&mut task, routing_engine, default_flow)?;\n   132→        let project_id = ProjectId::new(task.project_id.clone())?;\n   133→        let lease = match LeaseService::acquire(\n   134→            store,\n   135→            worktree,\n   136→            base_dir,\n   137→            repo_root,\n   138→            &task.task_id,\n   139→            &project_id,\n   140→            lease_ttl_seconds,\n   141→        ) {\n   142→            Ok(lease) => lease,\n   143→            Err(AppError::ProjectWriterLockHeld { .. }) => {\n   144→                return Err(AppError::ProjectWriterLockHeld {\n   145→                    project_id: project_id.to_string(),\n   146→                })\n   147→            }\n   148→            Err(error) => {\n   149→                let _ = Self::mark_failed(\n   150→                    store,\n   151→                    base_dir,\n   152→                    &task.task_id,\n   153→                    \"worktree_creation_failed\",\n   154→                    &error.to_string(),\n   155→                );\n   156→                return Err(error);\n   157→            }\n   158→        };\n   159→\n   160→        let now = Utc::now();\n   161→        task.transition_to(TaskStatus::Claimed, now)?;\n   162→        task.attach_lease(lease.lease_id.clone());\n   163→        store.write_task(base_dir, &task).map_err(|error| {\n   164→            let _ = LeaseService::release(store, worktree, base_dir, repo_root, &lease);\n   165→            error\n   166→        })?;\n   167→\n   168→        Self::append_journal_event(\n   169→            store,\n   170→            base_dir,\n   171→            DaemonJournalEventType::LeaseAcquired,\n   172→            json!({\n   173→                \"task_id\": task.task_id,\n   174→                \"lease_id\": lease.lease_id,\n   175→                \"project_id\": project_id,\n   176→                \"worktree_path\": lease.worktree_path,\n   177→                \"branch_name\": lease.branch_name,\n   178→                \"ttl_seconds\": lease.ttl_seconds,\n   179→            }),\n   180→        )?;\n   181→        Self::append_journal_event(\n   182→            store,\n   183→            base_dir,\n   184→            DaemonJournalEventType::TaskClaimed,\n   185→            json!({\n   186→                \"task_id\": task.task_id,\n   187→                \"lease_id\": lease.lease_id,\n   188→                \"project_id\": project_id,\n   189→            }),\n   190→        )?;\n   191→\n   192→        Ok((task, lease))\n   193→    }\n   194→\n   195→    pub fn mark_active(\n   196→        store: &dyn DaemonStorePort,\n   197→        base_dir: &Path,\n   198→        task_id: &str,\n   199→    ) -> AppResult<DaemonTask> {\n   200→        let mut task = store.read_task(base_dir, task_id)?;\n   201→        task.transition_to(TaskStatus::Active, Utc::now())?;\n   202→        store.write_task(base_dir, &task)?;\n   203→        Ok(task)\n   204→    }\n   205→\n   206→    pub fn mark_completed(\n   207→        store: &dyn DaemonStorePort,\n   208→        base_dir: &Path,\n   209→        task_id: &str,\n   210→    ) -> AppResult<DaemonTask> {\n   211→        let mut task = store.read_task(base_dir, task_id)?;\n   212→        task.transition_to(TaskStatus::Completed, Utc::now())?;\n   213→        store.write_task(base_dir, &task)?;\n   214→        Self::append_journal_event(\n   215→            store,\n   216→            base_dir,\n   217→            DaemonJournalEventType::TaskCompleted,\n   218→            json!({ \"task_id\": task.task_id }),\n   219→        )?;\n   220→        Ok(task)\n   221→    }\n   222→\n   223→    pub fn mark_failed(\n   224→        store: &dyn DaemonStorePort,\n   225→        base_dir: &Path,\n   226→        task_id: &str,\n   227→        failure_class: &str,\n   228→        failure_message: &str,\n   229→    ) -> AppResult<DaemonTask> {\n   230→        let mut task = store.read_task(base_dir, task_id)?;\n   231→        task.transition_to(TaskStatus::Failed, Utc::now())?;\n   232→        task.set_failure(failure_class, failure_message);\n   233→        store.write_task(base_dir, &task)?;\n   234→        Self::append_journal_event(\n   235→            store,\n   236→            base_dir,\n   237→            DaemonJournalEventType::TaskFailed,\n   238→            json!({\n   239→                \"task_id\": task.task_id,\n   240→                \"failure_class\": failure_class,\n   241→                \"failure_message\": failure_message,\n   242→            }),\n   243→        )?;\n   244→        Ok(task)\n   245→    }\n   246→\n   247→    pub fn mark_aborted(\n   248→        store: &dyn DaemonStorePort,\n   249→        base_dir: &Path,\n   250→        task_id: &str,\n   251→    ) -> AppResult<DaemonTask> {\n   252→        let mut task = store.read_task(base_dir, task_id)?;\n   253→        if matches!(\n   254→            task.status,\n   255→            TaskStatus::Completed | TaskStatus::Failed | TaskStatus::Aborted\n   256→        ) {\n   257→            return Err(AppError::TaskStateTransitionInvalid {\n   258→                task_id: task.task_id.clone(),\n   259→                from: task.status.as_str().to_owned(),\n   260→                to: TaskStatus::Aborted.as_str().to_owned(),\n   261→            });\n   262→        }\n   263→        task.transition_to(TaskStatus::Aborted, Utc::now())?;\n   264→        store.write_task(base_dir, &task)?;\n   265→        Self::append_journal_event(\n   266→            store,\n   267→            base_dir,\n   268→            DaemonJournalEventType::TaskAborted,\n   269→            json!({ \"task_id\": task.task_id }),\n   270→        )?;\n   271→        Ok(task)\n   272→    }\n   273→\n   274→    pub fn retry_task(\n   275→        store: &dyn DaemonStorePort,\n   276→        base_dir: &Path,\n   277→        task_id: &str,\n   278→    ) -> AppResult<DaemonTask> {\n   279→        let mut task = store.read_task(base_dir, task_id)?;\n   280→        if task.status != TaskStatus::Failed {\n   281→            return Err(AppError::TaskStateTransitionInvalid {\n   282→                task_id: task.task_id.clone(),\n   283→                from: task.status.as_str().to_owned(),\n   284→                to: TaskStatus::Pending.as_str().to_owned(),\n   285→            });\n   286→        }\n   287→\n   288→        task.transition_to(TaskStatus::Pending, Utc::now())?;\n   289→        task.attempt_count += 1;\n   290→        task.clear_failure();\n   291→        task.clear_lease();\n   292→        store.write_task(base_dir, &task)?;\n   293→        Ok(task)\n   294→    }\n   295→\n   296→    pub fn clear_lease_reference(\n   297→        store: &dyn DaemonStorePort,\n   298→        base_dir: &Path,\n   299→        task_id: &str,\n   300→    ) -> AppResult<DaemonTask> {\n   301→        let mut task = store.read_task(base_dir, task_id)?;\n   302→        task.clear_lease();\n   303→        task.updated_at = Utc::now();\n   304→        store.write_task(base_dir, &task)?;\n   305→        Ok(task)\n   306→    }\n   307→\n   308→    pub(crate) fn append_journal_event(\n   309→        store: &dyn DaemonStorePort,\n   310→        base_dir: &Path,\n   311→        event_type: DaemonJournalEventType,\n   312→        details: serde_json::Value,\n   313→    ) -> AppResult<()> {\n   314→        let events = store.read_daemon_journal(base_dir)?;\n   315→        let sequence = events.last().map_or(1, |event| event.sequence + 1);\n   316→        let event = DaemonJournalEvent {\n   317→            sequence,\n   318→            timestamp: Utc::now(),\n   319→            event_type,\n   320→            details,\n   321→        };\n   322→        store.append_daemon_journal_event(base_dir, &event)\n   323→    }\n   324→}\n   325→\n   326→fn hydrate_routing(\n   327→    task: &mut DaemonTask,\n   328→    routing_engine: &RoutingEngine,\n   329→    default_flow: FlowPreset,\n   330→) -> AppResult<()> {\n   331→    if task.resolved_flow.is_some() {\n   332→        return Ok(());\n   333→    }\n   334→\n   335→    let resolution = routing_engine.resolve_flow(\n   336→        task.routing_command.as_deref(),\n   337→        &task.routing_labels,\n   338→        default_flow,\n   339→    )?;\n   340→    task.resolved_flow = Some(resolution.flow);\n   341→    task.routing_source = Some(resolution.source);\n   342→    task.routing_warnings = resolution.warnings;\n   343→    Ok(())\n   344→}\n   345→\n   346→fn validate_identifier(value: &str) -> AppResult<()> {\n   347→    let _ = ProjectId::new(value.to_owned())?;\n   348→    Ok(())\n   349→}\n   350→\n   351→fn normalize_required(field: &'static str, value: &str) -> AppResult<String> {\n   352→    let trimmed = value.trim();\n   353→    if trimmed.is_empty() {\n   354→        return Err(AppError::InvalidConfigValue {\n   355→            key: field.to_owned(),\n   356→            value: value.to_owned(),\n   357→            reason: \"value cannot be empty\".to_owned(),\n   358→        });\n   359→    }\n   360→    Ok(trimmed.to_owned())\n   361→}\n   362→"}]},"parent_tool_use_id":"toolu_01127w93r2hddj2R7DxzcewM","session_id":"8dacb19c-9278-40df-b484-c803ec7bbb98","uuid":"c779dfc1-0912-4f36-be8d-b125edf0ad9e"}
