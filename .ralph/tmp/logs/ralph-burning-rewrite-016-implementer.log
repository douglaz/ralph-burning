      \"task_id\": task.task_id,\n   187→                \"lease_id\": lease.lease_id,\n   188→                \"project_id\": project_id,\n   189→            }),\n   190→        )?;\n   191→\n   192→        Ok((task, lease))\n   193→    }\n   194→\n   195→    pub fn mark_active(\n   196→        store: &dyn DaemonStorePort,\n   197→        base_dir: &Path,\n   198→        task_id: &str,\n   199→    ) -> AppResult<DaemonTask> {\n   200→        let mut task = store.read_task(base_dir, task_id)?;\n   201→        task.transition_to(TaskStatus::Active, Utc::now())?;\n   202→        store.write_task(base_dir, &task)?;\n   203→        Ok(task)\n   204→    }\n   205→\n   206→    pub fn mark_completed(\n   207→        store: &dyn DaemonStorePort,\n   208→        base_dir: &Path,\n   209→        task_id: &str,\n   210→    ) -> AppResult<DaemonTask> {\n   211→        let mut task = store.read_task(base_dir, task_id)?;\n   212→        task.transition_to(TaskStatus::Completed, Utc::now())?;\n   213→        store.write_task(base_dir, &task)?;\n   214→        Self::append_journal_event(\n   215→            store,\n   216→            base_dir,\n   217→            DaemonJournalEventType::TaskCompleted,\n   218→            json!({ \"task_id\": task.task_id }),\n   219→        )?;\n   220→        Ok(task)\n   221→    }\n   222→\n   223→    pub fn mark_failed(\n   224→        store: &dyn DaemonStorePort,\n   225→        base_dir: &Path,\n   226→        task_id: &str,\n   227→        failure_class: &str,\n   228→        failure_message: &str,\n   229→    ) -> AppResult<DaemonTask> {\n   230→        let mut task = store.read_task(base_dir, task_id)?;\n   231→        task.transition_to(TaskStatus::Failed, Utc::now())?;\n   232→        task.set_failure(failure_class, failure_message);\n   233→        store.write_task(base_dir, &task)?;\n   234→        Self::append_journal_event(\n   235→            store,\n   236→            base_dir,\n   237→            DaemonJournalEventType::TaskFailed,