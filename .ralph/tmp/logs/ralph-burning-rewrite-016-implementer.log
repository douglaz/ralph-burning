               review_payload.outcome,\n   693→                    review_payload.findings.join(\"; \")\n   694→                );\n   695→                self.fail_run(base_dir, run, seq, &msg).await?;\n   696→                return Err(AppError::InvalidRequirementsState {\n   697→                    run_id: run_id.clone(),\n   698→                    details: msg,\n   699→                });\n   700→            }\n   701→        }\n   702→\n   703→        // ── Seed ────────────────────────────────────────────────────────\n   704→        let follow_ups =\n   705→            if review_payload.outcome == RequirementsReviewOutcome::ConditionallyApproved {\n   706→                review_payload.follow_ups.clone()\n   707→            } else {\n   708→                Vec::new()\n   709→            };\n   710→\n   711→        let seed_prompt = format!(\n   712→            \"Generate a project seed from the following requirements:\\n\\n{}\\n\\nFollow-ups: {}\",\n   713→            draft_bundle.artifact,\n   714→            if follow_ups.is_empty() {\n   715→                \"none\".to_owned()\n   716→            } else {\n   717→                follow_ups.join(\"; \")\n   718→            }\n   719→        );\n   720→\n   721→        let seed_result = self\n   722→            .invoke_stage(\n   723→                &run_root,\n   724→                RequirementsStageId::ProjectSeed,\n   725→                BackendRole::Planner,\n   726→                &seed_prompt,\n   727→            )\n   728→            .await;\n   729→\n   730→        let seed_bundle = match seed_result {\n   731→            Ok(b) => b,\n   732→            Err(e) => {\n   733→                self.fail_run(base_dir, run, seq, &format!(\"seed generation: {e}\"))\n   734→                    .await?;\n   735→                return Err(e);\n   736→            }\n   737→        };\n   738→\n   739→        // Extract seed payload and merge review follow-ups for conditional approvals\n   740→        let mut seed_payload = match seed_bundle.payload {\n   741→            RequirementsPayload::Seed(p) => p,\n   742→            _ => unreachable!(),\n   743→        };\n   744→\n   745→        if !follow_ups.is_empty() {\n   746→            // Merge review follow-ups into canonical seed metadata\n   747→            for fu in &follow_ups {\n   748→                if !seed_payload.follow_ups.contains(fu) {\n   749→                    seed_payload.follow_ups.push(fu.clone());\n   750→                }\n   751→            }\n   752→            // Append follow-ups to the rendered handoff summary\n   753→            seed_payload.handoff_summary = format!(\n   754→                \"{}\\n\\nFollow-ups from conditional approval:\\n{}\",\n   755→                seed_payload.handoff_summary,\n   756→                follow_ups\n   757→                    .iter()\n   758→                    .map(|f| format!(\"- {f}\"))\n   759→                    .collect::<Vec<_>>()\n   760→                    .join(\"\\n\")\n   761→            );\n   762→        }\n   763→\n   764→        // Re-render seed artifact with merged follow-ups\n   765→        let seed_artifact = renderers::render_project_seed(&seed_payload);\n   766→\n   767→        let seed_payload_id = format!(\"{run_id}-seed-1\");\n   768→        let seed_artifact_id = format!(\"{run_id}-seed-art-1\");\n   769→        let seed_json = serde_json::to_value(&seed_payload)?;\n   770→\n   771→        // Write seed files BEFORE committing history, so that if seed file\n   772→        // writes fail, no orphaned seed history payload/artifact remains.\n   773→        // Only the already committed draft/review history survives.\n   774→        let project_json = serde_json::to_value(&seed_payload)?;\n   775→        if let Err(e) =\n   776→            self.store\n   777→                .write_seed_pair(base_dir, &run_id, &project_json, &seed_payload.prompt_body)\n   778→        {\n   779→            // Terminal-transition ordering: persist the failed state BEFORE\n   780→            // cleaning up external side effects. This ensures that if the\n   781→            // process crashes after cleanup, canonical state is already\n   782→            // terminal rather than appearing non-terminal with missing files.\n   783→            self.fail_run(base_dir, run, seq, &format!(\"seed file write: {e}\"))\n   784→                .await?;\n   785→            let _ = self.store.remove_seed_pair(base_dir, &run_id);\n   786→            return Err(AppError::SeedPersistenceFailed {\n   787→                run_id: run_id.clone(),\n   788→                details: e.to_string(),\n   789→            });\n   790→        }\n   791→\n   792→        // Now commit the seed payload/artifact to history.\n   793→        if let Err(e) = self.store.write_payload_artifact_pair_atomic(\n   794→            base_dir,\n   795→            &run_id,\n   796→            &seed_payload_id,\n   797→            &seed_json,\n   798→            &seed_artifact_id,\n   799→            &seed_artifact,\n   800→        ) {\n   801→            // Terminal-transition ordering: persist the failed state BEFORE\n   802→            // cleaning up seed files, so canonical state is terminal even if\n   803→            // the process crashes between cleanup and state persistence.\n   804→            self.fail_run(\n   805→                base_dir,\n   806→                run,\n   807→                seq,\n   808→                &format!(\"seed history persistence: {e}\"),\n   809→            )\n   810→            .await?;\n   811→            let _ = self.store.remove_seed_pair(base_dir, &run_id);\n   812→            return Err(e);\n   813→        }\n   814→\n   815→        run.latest_seed_id = Some(seed_payload_id.clone());\n   816→        run.status = RequirementsStatus::Completed;\n   817→        run.status_summary = \"completed\".to_owned();\n   818→        run.updated_at = Utc::now();\n   819→        self.store.write_run(base_dir, &run_id, run)?;\n   820→\n   821→        let event = journal_event(\n   822→            seq,\n   823→            Utc::now(),\n   824→            RequirementsJournalEventType::SeedGenerated,\n   825→            run,\n   826→        );\n   827→        if let Err(e) = self.store.append_journal_event(base_dir, &run_id, &event) {\n   828→            // Roll back seed payload/artifact, boundary marker, and seed files.\n   829→            // Persist Failed state BEFORE cleanup (terminal-transition ordering).\n   830→            let _ = self.store.remove_payload_artifact_pair(\n   831→                base_dir,\n   832→                &run_id,\n   833→                &seed_payload_id,\n   834→                &seed_artifact_id,\n   835→            );\n   836→            run.latest_seed_id = None;\n   837→            self.fail_run(\n   838→                base_dir,\n   839→                run,\n   840→                seq,\n   841→                &format!(\"journal append failed for seed_generated: {e}\"),\n   842→            )\n   843→            .await?;\n   844→            let _ = self.store.remove_seed_pair(base_dir, &run_id);\n   845→            return Err(e);\n   846→        }\n   847→        seq += 1;\n   848→\n   849→        let event = journal_event(\n   850→            seq,\n   851→            Utc::now(),\n   852→            RequirementsJournalEventType::RunCompleted,\n   853→            run,\n   854→        );\n   855→        // Best-effort: the run is already durably complete in run.json with all\n   856→        // seed files and history committed. A missing RunCompleted journal event\n   857→        // is non-ideal but does not affect run state consistency.\n   858→        let _ = self.store.append_journal_event(base_dir, &run_id, &event);\n   859→\n   860→        let seed_path = self.store.seed_prompt_path(base_dir, &run_id);\n   861→        println!(\"Requirements completed. Seed files at:\");\n   862→        println!(\"  {}\", seed_path.display());\n   863→        println!(\n   864→            \"\\nCreate project:\\n  ralph-burning project create --id {} --name \\\"{}\\\" --flow {} --prompt {}\",\n   865→            seed_payload.project_id,\n   866→            seed_payload.project_name,\n   867→            seed_payload.flow,\n   868→            seed_path.display()\n   869→        );\n   870→\n   871→        Ok(())\n   872→    }\n   873→\n   874→    async fn invoke_stage(\n   875→        &self,\n   876→        run_root: &Path,\n   877→        stage_id: RequirementsStageId,\n   878→        role: BackendRole,\n   879→        prompt: &str,\n   880→    ) -> AppResult<super::contracts::RequirementsValidatedBundle> {\n   881→        let contract_label = format!(\"requirements:{}\", stage_id.as_str());\n   882→        let target = self.agent_service.resolver().resolve(\n   883→            role,\n   884→            None,\n   885→            None,\n   886→            self.workspace_defaults.as_ref(),\n   887→        )?;\n   888→\n   889→        let request = InvocationRequest {\n   890→            invocation_id: format!(\n   891→                \"req-{}-{}\",\n   892→                stage_id.as_str(),\n   893→                Utc::now().format(\"%Y%m%d%H%M%S\")\n   894→            ),\n   895→            project_root: run_root.to_path_buf(),\n   896→            contract: InvocationContract::Requirements {\n   897→                label: contract_label,\n   898→            },\n   899→            role,\n   900→            resolved_target: target,\n   901→            payload: InvocationPayload {\n   902→                prompt: prompt.to_owned(),\n   903→                context: serde_json::Value::Null,\n   904→            },\n   905→            timeout: std::time::Duration::from_secs(300),\n   906→            cancellation_token: CancellationToken::new(),\n   907→            session_policy: SessionPolicy::NewSession,\n   908→            prior_session: None,\n   909→            attempt_number: 1,\n   910→        };\n   911→\n   912→        let envelope = self.agent_service.invoke(request).await?;\n   913→\n   914→        // Validate using requirements contract\n   915→        let contract = match stage_id {\n   916→            RequirementsStageId::QuestionSet => RequirementsContract::question_set(),\n   917→            RequirementsStageId::RequirementsDraft => RequirementsContract::draft(),\n   918→            RequirementsStageId::RequirementsReview => RequirementsContract::review(),\n   919→            RequirementsStageId::ProjectSeed => RequirementsContract::seed(),\n   920→        };\n   921→\n   922→        let bundle = contract.evaluate(&envelope.parsed_payload).map_err(|e| {\n   923→            AppError::InvalidRequirementsState {\n   924→                run_id: \"\".to_owned(),\n   925→                details: format!(\"contract validation failed for {}: {e}\", stage_id),\n   926→            }\n   927→        })?;\n   928→\n   929→        Ok(bundle)\n   930→    }\n   931→\n   932→    async fn fail_run(\n   933→        &self,\n   934→        base_dir: &Path,\n   935→        run: &mut RequirementsRun,\n   936→        seq: u64,\n   937→        message: &str,\n   938→    ) -> AppResult<()> {\n   939→        run.status = RequirementsStatus::Failed;\n   940→        run.status_summary = format!(\"failed: {message}\");\n   941→        run.updated_at = Utc::now();\n   942→        self.store.write_run(base_dir, &run.run_id, run)?;\n   943→\n   944→        let event = journal_event(\n   945→            seq,\n   946→            Utc::now(),\n   947→            RequirementsJournalEventType::RunFailed,\n   948→            run,\n   949→        );\n   950→        // Best-effort journal append: if the journal is failing, the run.json\n   951→        // Failed state is already committed and is the authoritative record.\n   952→        // This matches the workflow engine's fail_run() pattern (engine.rs:1755).\n   953→        let _ = self\n   954→            .store\n   955→            .append_journal_event(base_dir, &run.run_id, &event);\n   956→        Ok(())\n   957→    }\n   958→\n   959→    /// Check whether answers have already been durably stored past the question\n   960→    /// boundary, by consulting both the journal (for AnswersSubmitted events) and\n   961→    /// the persisted answers.json (for non-empty answer content written before the\n   962→    /// run/journal transition could complete).\n   963→    fn answers_already_durably_stored(&self, base_dir: &Path, run_id: &str) -> AppResult<bool> {\n   964→        // Check journal first — authoritative event source.\n   965→        let journal = self.store.read_journal(base_dir, run_id)?;\n   966→        if journal\n   967→            .iter()\n   968→            .any(|e| e.event_type == RequirementsJournalEventType::AnswersSubmitted)\n   969→        {\n   970→            return Ok(true);\n   971→        }\n   972→\n   973→        // Check answers.json content — covers the case where answers.json was\n   974→        // durably written but write_run()/journal append failed afterward.\n   975→        // If answers.json doesn't exist or can't be read, treat as no answers\n   976→        // stored (same as the initial empty state from create_run_dir).\n   977→        if let Ok(persisted) = self.store.read_answers_json(base_dir, run_id) {\n   978→            if !persisted.answers.is_empty() {\n   979→                return Ok(true);\n   980→            }\n   981→        }\n   982→\n   983→        Ok(false)\n   984→    }\n   985→\n   986→    fn next_sequence(&self, base_dir: &Path, run_id: &str) -> AppResult<u64> {\n   987→        let events = self.store.read_journal(base_dir, run_id)?;\n   988→        Ok(events.last().map_or(0, |e| e.sequence) + 1)\n   989→    }\n   990→}\n   991→\n   992→// ── Show result ─────────────────────────────────────────────────────────────\n   993→\n   994→/// Read model for `requirements show`.\n   995→#[derive(Debug)]\n   996→pub struct RequirementsShowResult {\n   997→    pub run: RequirementsRun,\n   998→    pub journal_event_count: u64,\n   999→    pub pending_question_count: Option<u32>,\n  1000→    pub recommended_flow: Option<FlowPreset>,\n  1001→    pub failure_summary: Option<String>,\n  1002→    pub seed_prompt_path: Option<std::path::PathBuf>,\n  1003→}\n  1004→\n  1005→// ── Helpers ─────────────────────────────────────────────────────────────────\n  1006→\n  1007→fn generate_run_id(now: DateTime<Utc>) -> String {\n  1008→    format!(\"req-{}\", now.format(\"%Y%m%d-%H%M%S\"))\n  1009→}\n  1010→\n  1011→fn requirements_run_root(base_dir: &Path, run_id: &str) -> std::path::PathBuf {\n  1012→    base_dir\n  1013→        .join(\".ralph-burning\")\n  1014→        .join(\"requirements\")\n  1015→        .join(run_id)\n  1016→}\n  1017→\n  1018→fn journal_event(\n  1019→    sequence: u64,\n  1020→    timestamp: DateTime<Utc>,\n  1021→    event_type: RequirementsJournalEventType,\n  1022→    run: &RequirementsRun,\n  1023→) -> RequirementsJournalEvent {\n  1024→    RequirementsJournalEvent {\n  1025→        sequence,\n  1026→        timestamp,\n  1027→        event_type,\n  1028→        details: serde_json::json!({\n  1029→            \"run_id\": run.run_id,\n  1030→            \"status\": run.status,\n  1031→            \"status_summary\": run.status_summary,\n  1032→        }),\n  1033→    }\n  1034→}\n  1035→\n  1036→fn generate_answers_template(qs: &QuestionSetPayload) -> String {\n  1037→    let mut out = String::new();\n  1038→    out.push_str(\"# Answers for clarifying questions\\n\");\n  1039→    out.push_str(\"# Fill in answers below each question.\\n\\n\");\n  1040→\n  1041→    for q in &qs.questions {\n  1042→        let required = if q.required { \" (required)\" } else { \"\" };\n  1043→        // Write prompt as comment lines, handling embedded newlines so each\n  1044→        // continuation line starts with `# `.\n  1045→        let mut first_prompt_line = true;\n  1046→        for line in q.prompt.lines() {\n  1047→            if first_prompt_line {\n  1048→                out.push_str(&format!(\"# {}{}\\n\", line, required));\n  1049→                first_prompt_line = false;\n  1050→            } else {\n  1051→                out.push_str(&format!(\"# {}\\n\", line));\n  1052→            }\n  1053→        }\n  1054→        // If prompt was empty or had no lines iterator output, ensure at least\n  1055→        // one comment line is emitted.\n  1056→        if first_prompt_line {\n  1057→            out.push_str(&format!(\"# {}\\n\", required.trim()));\n  1058→        }\n  1059→\n  1060→        if !q.rationale.is_empty() {\n  1061→            // Handle multi-line rationale in comments.\n  1062→            let mut first = true;\n  1063→            for line in q.rationale.lines() {\n  1064→                if first {\n  1065→                    out.push_str(&format!(\"# Rationale: {}\\n\", line));\n  1066→                    first = false;\n  1067→                } else {\n  1068→                    out.push_str(&format!(\"#   {}\\n\", line));\n  1069→                }\n  1070→            }\n  1071→        }\n  1072→\n  1073→        let default_value = q.suggested_default.as_deref().unwrap_or(\"\");\n  1074→        // Escape the default value for TOML basic string safety.\n  1075→        let escaped = toml_escape_basic_string(default_value);\n  1076→        out.push_str(&format!(\"{} = \\\"{}\\\"\\n\\n\", q.id, escaped));\n  1077→    }\n  1078→\n  1079→    out\n  1080→}\n  1081→\n  1082→/// Escape a string value for safe embedding in a TOML basic string (double-quoted).\n  1083→fn toml_escape_basic_string(s: &str) -> String {\n  1084→    let mut out = String::with_capacity(s.len());\n  1085→    for c in s.chars() {\n  1086→        match c {\n  1087→            '\\\\' => out.push_str(\"\\\\\\\\\"),\n  1088→            '\"' => out.push_str(\"\\\\\\\"\"),\n  1089→            '\\n' => out.push_str(\"\\\\n\"),\n  1090→            '\\r' => out.push_str(\"\\\\r\"),\n  1091→            '\\t' => out.push_str(\"\\\\t\"),\n  1092→            '\\u{0008}' => out.push_str(\"\\\\b\"),\n  1093→            '\\u{000C}' => out.push_str(\"\\\\f\"),\n  1094→            _ => out.push(c),\n  1095→        }\n  1096→    }\n  1097→    out\n  1098→}\n  1099→\n  1100→/// Validate answers against the committed question set payload.\n  1101→///\n  1102→/// Loads the question set from persisted payloads, rejects unknown answer keys,\n  1103→/// and requires non-empty values for required questions.\n  1104→fn parse_and_validate_answers<Q: RequirementsStorePort>(\n  1105→    answers_raw: &str,\n  1106→    base_dir: &Path,\n  1107→    run_id: &str,\n  1108→    store: &Q,\n  1109→) -> AppResult<PersistedAnswers> {\n  1110→    // Parse TOML\n  1111→    let table: toml::Table =\n  1112→        toml::from_str(answers_raw).map_err(|e| AppError::AnswerValidationFailed {\n  1113→            run_id: run_id.to_owned(),\n  1114→            details: format!(\"invalid TOML: {e}\"),\n  1115→        })?;\n  1116→\n  1117→    // Load the committed question set payload\n  1118→    let run = store.read_run(base_dir, run_id)?;\n  1119→    let qs_id =\n  1120→        run.latest_question_set_id\n  1121→            .as_ref()\n  1122→            .ok_or_else(|| AppError::InvalidRequirementsState {\n  1123→                run_id: run_id.to_owned(),\n  1124→                details: \"no question set committed\".to_owned(),\n  1125→            })?;\n  1126→\n  1127→    let qs_json = store.read_payload(base_dir, run_id, qs_id)?;\n  1128→    let qs: QuestionSetPayload =\n  1129→        serde_json::from_value(qs_json).map_err(|e| AppError::InvalidRequirementsState {\n  1130→            run_id: run_id.to_owned(),\n  1131→            details: format!(\"corrupt question set payload: {e}\"),\n  1132→        })?;\n  1133→\n  1134→    // Build valid question ID set\n  1135→    let valid_ids: HashSet<&str> = qs.questions.iter().map(|q| q.id.as_str()).collect();\n  1136→\n  1137→    // Reject unknown answer keys\n  1138→    for key in table.keys() {\n  1139→        if !valid_ids.contains(key.as_str()) {\n  1140→            return Err(AppError::AnswerValidationFailed {\n  1141→                run_id: run_id.to_owned(),\n  1142→                details: format!(\"unknown question ID: '{key}'\"),\n  1143→            });\n  1144→        }\n  1145→    }\n  1146→\n  1147→    // Require non-empty answers for required questions\n  1148→    for q in &qs.questions {\n  1149→        if q.required {\n  1150→            match table.get(&q.id) {\n  1151→                None => {\n  1152→                    return Err(AppError::AnswerValidationFailed {\n  1153→                        run_id: run_id.to_owned(),\n  1154→                        details: format!(\"required question '{}' has no answer\", q.id),\n  1155→                    });\n  1156→                }\n  1157→                Some(v) => {\n  1158→                    let text = v.as_str().unwrap_or(\"\");\n  1159→                    if text.trim().is_empty() {\n  1160→                        return Err(AppError::AnswerValidationFailed {\n  1161→                            run_id: run_id.to_owned(),\n  1162→                            details: format!(\"required question '{}' has an empty answer\", q.id),\n  1163→                        });\n  1164→                    }\n  1165→                }\n  1166→            }\n  1167→        }\n  1168→    }\n  1169→\n  1170→    // Build answers from TOML keys\n  1171→    let mut answers = Vec::new();\n  1172→    for (key, value) in &table {\n  1173→        let answer_text = match value.as_str() {\n  1174→            Some(s) => s.to_owned(),\n  1175→            None => value.to_string(),\n  1176→        };\n  1177→        answers.push(AnswerEntry {\n  1178→            question_id: key.clone(),\n  1179→            answer: answer_text,\n  1180→        });\n  1181→    }\n  1182→\n  1183→    Ok(PersistedAnswers { answers })\n  1184→}\n  1185→\n  1186→fn build_draft_prompt(idea: &str, answers: &[(String, String)]) -> String {\n  1187→    let mut prompt = format!(\"Draft requirements for the following idea:\\n\\n{idea}\\n\");\n  1188→\n  1189→    if !answers.is_empty() {\n  1190→        prompt.push_str(\"\\nClarifying answers:\\n\");\n  1191→        for (qid, answer) in answers {\n  1192→            prompt.push_str(&format!(\"- {qid}: {answer}\\n\"));\n  1193→        }\n  1194→    }\n  1195→\n  1196→    prompt\n  1197→}\n  1198→"}]},"parent_tool_use_id":"toolu_01TPm9s3pvANoTMXVd4pedbq","session_id":"8dacb19c-9278-40df-b484-c803ec7bbb98","uuid":"2f4a3692-458b-4e87-8044-5efa10c74056"}
