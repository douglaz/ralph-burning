ed branch events. The resumed run re-creates\n  4034→        // new stage events, but the old abandoned ones should remain hidden.\n  4035→        let final_history = run_cli(&[\"run\", \"history\"], ws.path())?;\n  4036→        assert_success(&final_history)?;\n  4037→        // The abandoned branch's implementation events (between the rollback\n  4038→        // boundary and rollback_performed) must not appear in the visible output.\n  4039→        // After rollback to planning + resume, the visible history should have\n  4040→        // at most as many stage_completed events as a fresh run from planning.\n  4041→        // If the abandoned branch is visible, the count would be inflated.\n  4042→        let final_completed = final_history.stdout.matches(\"stage_completed\").count();\n  4043→        if final_completed > pre_completed + 2 {\n  4044→            // A small margin accounts for the resumed stages; the key invariant\n  4045→            // is that the old abandoned implementation history is hidden and the\n  4046→            // total does not blow up with duplicate abandoned events.\n  4047→            return Err(format!(\n  4048→                \"final history should hide abandoned branch: pre={pre_completed}, final={final_completed}\"\n  4049→            ));\n  4050→        }\n  4051→\n  4052→        // Additionally verify that `run history` output doesn't contain a\n  4053→        // \"rollback_performed\" marker interleaved with duplicate stage events\n  4054→        // from the abandoned branch — the abandoned events should be gone.\n  4055→        let rollback_in_history = final_history.stdout.contains(\"rollback_performed\");\n  4056→        if !rollback_in_history {\n  4057→            // rollback_performed should still be visible as a durable event\n  4058→            return Err(\"run history should include rollback_performed event\".into());\n  4059→        }\n  4060→\n  4061→        // Verify completed\n  4062→        let final_snap = read_run_snapshot(&ws, \"rb-resume\")?;\n  4063→        if final_snap.get(\"status\").and_then(|v| v.as_str()) != Some(\"completed\") {\n  4064→            return Err(\"expected completed after rollback+resume\".into());\n  4065→        }\n  4066→        Ok(())\n  4067→    });\n  4068→\n  4069→    reg!(m, \"SC-ROLLBACK-008\", || {\n  4070→        // Hard rollback failure preserves the logical rollback.\n  4071→        // Feature: the target rollback point for \"implementation\" records a git SHA,\n  4072→        // the repository reset will fail, the command exits with a git-reset error,\n  4073→        // but run.json remains in the logically rolled-back paused state and the\n  4074→        // journal still contains rollback_performed — proving logical rollback is\n  4075→        // committed before the git-reset path, not the earlier missing-SHA guard.\n  4076→        let ws = TempWorkspace::new()?;\n  4077→        setup_workspace_with_project(&ws, \"rb-hard-fail\", \"standard\")?;\n  4078→\n  4079→        // Initialize a git repo so rollback points record a real git SHA\n  4080→        let _initial_sha = init_git_repo(&ws)?;\n  4081→\n  4082→        // Create rollback points (they will capture a valid git_sha)\n  4083→        let overrides = serde_json::json!({\n  4084→            \"completion_panel\": [\n  4085→                {\n  4086→                    \"outcome\": \"conditionally_approved\",\n  4087→                    \"evidence\": [\"Changes\"],\n  4088→                    \"findings_or_gaps\": [],\n  4089→                    \"follow_up_or_amendments\": [{\"summary\": \"Fix\", \"details\": \"D\"}]\n  4090→                },\n  4091→                {\n  4092→                    \"outcome\": \"approved\",\n  4093→                    \"evidence\": [\"OK\"],\n  4094→                    \"findings_or_gaps\": [],\n  4095→                    \"follow_up_or_amendments\": []\n  4096→                }\n  4097→            ]\n  4098→        });\n  4099→        let _start = run_cli_with_env(\n  4100→            &[\"run\", \"start\"],\n  4101→            ws.path(),\n  4102→            &[(\"RALPH_BURNING_TEST_STAGE_OVERRIDES\", &overrides.to_string())],\n  4103→        )?;\n  4104→\n  4105→        // Verify rollback points captured a real SHA\n  4106→        let pre_events = read_journal(&ws, \"rb-hard-fail\")?;\n  4107→        let rb_created = pre_events.iter().find(|e| {\n  4108→            e.get(\"event_type\").and_then(|v| v.as_str()) == Some(\"rollback_created\")\n  4109→        });\n  4110→        let created_sha = rb_created\n  4111→            .and_then(|e| e.get(\"details\"))\n  4112→            .and_then(|d| d.get(\"git_sha\"))\n  4113→            .and_then(|v| v.as_str())\n  4114→            .unwrap_or(\"\");\n  4115→        if created_sha.is_empty() {\n  4116→            return Err(\"rollback_created must record a real git_sha for this test\".into());\n  4117→        }\n  4118→\n  4119→        // Now destroy the git repo so that `git reset --hard <sha>` will fail\n  4120→        std::fs::remove_dir_all(ws.path().join(\".git\"))\n  4121→            .map_err(|e| format!(\"remove .git: {e}\"))?;\n  4122→\n  4123→        // Set to failed\n  4124→        let snap = read_run_snapshot(&ws, \"rb-hard-fail\")?;\n  4125→        let mut snap = snap.clone();\n  4126→        snap[\"status\"] = serde_json::json!(\"failed\");\n  4127→        snap[\"active_run\"] = serde_json::json!(null);\n  4128→        std::fs::write(\n  4129→            ws.path().join(\".ralph-burning/projects/rb-hard-fail/run.json\"),\n  4130→            serde_json::to_string_pretty(&snap).unwrap(),\n  4131→        ).map_err(|e| e.to_string())?;\n  4132→\n  4133→        // Hard rollback to implementation — the rollback point has a valid SHA but\n  4134→        // git reset will fail because the .git directory no longer exists.\n  4135→        let rb = run_cli(&[\"run\", \"rollback\", \"--to\", \"implementation\", \"--hard\"], ws.path())?;\n  4136→        // The command should fail with a git-reset error\n  4137→        assert_failure(&rb)?;\n  4138→\n  4139→        // Verify run.json is in paused state — the logical rollback (snapshot + journal)\n  4140→        // was committed before the git reset was attempted and failed\n  4141→        let post_snap = read_run_snapshot(&ws, \"rb-hard-fail\")?;\n  4142→        let post_status = post_snap.get(\"status\").and_then(|v| v.as_str()).unwrap_or(\"\");\n  4143→        if post_status != \"paused\" {\n  4144→            return Err(format!(\n  4145→                \"expected paused (logical rollback committed before git failure), got '{post_status}'\"\n  4146→            ));\n  4147→        }\n  4148→\n  4149→        // Journal should have rollback_performed event even though git reset failed\n  4150→        let post_events = read_journal(&ws, \"rb-hard-fail\")?;\n  4151→        let rb_event = post_events.iter().find(|e| {\n  4152→            e.get(\"event_type\").and_then(|v| v.as_str()) == Some(\"rollback_performed\")\n  4153→        });\n  4154→        if rb_event.is_none() {\n  4155→            return Err(\"journal should have rollback_performed even when git reset fails\".into());\n  4156→        }\n  4157→        let rb_event = rb_event.unwrap();\n  4158→\n  4159→        // Verify the rollback_performed event targets implementation\n  4160→        let rb_stage = rb_event\n  4161→            .get(\"details\")\n  4162→            .and_then(|d| d.get(\"stage_id\"))\n  4163→            .and_then(|v| v.as_str())\n  4164→            .unwrap_or(\"\");\n  4165→        if rb_stage != \"implementation\" {\n  4166→            return Err(format!(\"rollback_performed should target implementation, got '{rb_stage}'\"));\n  4167→        }\n  4168→\n  4169→        // Verify the event records the git_sha — this proves the failure occurred on the\n  4170→        // git-reset path (not the earlier missing-SHA guard)\n  4171→        let event_sha = rb_event\n  4172→            .get(\"details\")\n  4173→  