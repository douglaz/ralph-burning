s\n    46→            .iter()\n    47→            .any(|task| task.issue_ref == issue_ref && !task.is_terminal())\n    48→        {\n    49→            return Err(AppError::DuplicateTaskForIssue { issue_ref });\n    50→        }\n    51→\n    52→        let resolution = routing_engine.resolve_flow(\n    53→            input.routing_command.as_deref(),\n    54→            &input.routing_labels,\n    55→            default_flow,\n    56→        )?;\n    57→\n    58→        let now = Utc::now();\n    59→        let task = DaemonTask {\n    60→            task_id: input.task_id,\n    61→            issue_ref: normalize_required(\"issue_ref\", &input.issue_ref)?,\n    62→            project_id: project_id.to_string(),\n    63→            project_name: input.project_name.filter(|value| !value.trim().is_empty()),\n    64→            prompt: input.prompt.filter(|value| !value.trim().is_empty()),\n    65→            routing_command: input\n    66→                .routing_command\n    67→                .filter(|value| !value.trim().is_empty()),\n    68→            routing_labels: input.routing_labels,\n    69→            resolved_flow: Some(resolution.flow),\n    70→            routing_source: Some(resolution.source),\n    71→            routing_warnings: resolution.warnings.clone(),\n    72→            status: TaskStatus::Pending,\n    73→            created_at: now,\n    74→            updated_at: now,\n    75→            attempt_count: 0,\n    76→            lease_id: None,\n    77→            failure_class: None,\n    78→            failure_message: None,\n    79→        };\n    80→\n    81→        store.create_task(base_dir, &task)?;\n    82→        Self::append_journal_event(\n    83→            store,\n    84→            base_dir,\n    85→            DaemonJournalEventType::TaskCreated,\n    86→            json!({\n    87→                \"task_id\": task.task_id,\n    88→                \"issue_ref\": task.issue_ref,\n    89→                \"project_id\": task.proje