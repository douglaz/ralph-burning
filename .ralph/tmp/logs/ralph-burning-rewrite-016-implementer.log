_SUBDIRS: &[&str] = &[\n    37→    \"history/payloads\",\n    38→    \"history/artifacts\",\n    39→    \"runtime/logs\",\n    40→    \"runtime/backend\",\n    41→    \"runtime/temp\",\n    42→    \"amendments\",\n    43→    \"rollback\",\n    44→];\n    45→\n    46→pub struct FileSystem;\n    47→\n    48→impl FileSystem {\n    49→    pub fn create_workspace(\n    50→        workspace_root: &Path,\n    51→        workspace_config: &str,\n    52→        required_directories: &[&str],\n    53→    ) -> AppResult<()> {\n    54→        fs::create_dir_all(workspace_root)?;\n    55→\n    56→        for directory in required_directories {\n    57→            fs::create_dir_all(workspace_root.join(directory))?;\n    58→        }\n    59→\n    60→        Self::write_atomic(&workspace_root.join(\"workspace.toml\"), workspace_config)?;\n    61→        Ok(())\n    62→    }\n    63→\n    64→    pub fn read_to_string(path: &Path) -> AppResult<String> {\n    65→        Ok(fs::read_to_string(path)?)\n    66→    }\n    67→\n    68→    pub fn write_atomic(path: &Path, contents: &str) -> AppResult<()> {\n    69→        let parent = path.parent().ok_or_else(|| {\n    70→            AppError::Io(std::io::Error::new(\n    71→                std::io::ErrorKind::InvalidInput,\n    72→                format!(\"path '{}' has no parent directory\", path.display()),\n    73→            ))\n    74→        })?;\n    75→        fs::create_dir_all(parent)?;\n    76→\n    77→        let timestamp = SystemTime::now()\n    78→            .duration_since(UNIX_EPOCH)\n    79→            .map(|duration| duration.as_nanos())\n    80→            .unwrap_or_default();\n    81→        let temp_path = parent.join(format!(\n    82→            \".{}.{}.{}.tmp\",\n    83→            path.file_name()\n    84→                .and_then(|value| value.to_str())\n    85→                .unwrap_or(\"workspace\"),\n    86→            std::process::id(),\n    87→            timestamp\n    88→        ));\n    89→\n    90→        let mut file = OpenOptions::new()\n    91→            .create_new(true)\n    92→            .write(true)\n    93→            .open(&temp_path)?;\n    94→        file.write_all(contents.as_bytes())?;\n    95→        file.sync_all()?;\n    96→        drop(file);\n    97→\n    98→        if let Err(error) = fs::rename(&temp_path, path) {\n    99→            let _ = fs::remove_file(&temp_path);\n   100→            return Err(error.into());\n   101→        }\n   102→\n   103→        Ok(())\n   104→    }\n   105→\n   106→    pub fn render_workspace_config(config: &WorkspaceConfig) -> AppResult<String> {\n   107→        Ok(toml::to_string_pretty(config)?)\n   108→    }\n   109→\n   110→    pub fn read_active_project(workspace_root: &Path) -> AppResult<Option<String>> {\n   111→        let path = workspace_root.join(ACTIVE_PROJECT_FILE);\n   112→        match fs::read_to_string(path) {\n   113→            Ok(raw) => {\n   114→                let trimmed = raw.trim();\n   115→                if trimmed.is_empty() {\n   116→                    Ok(None)\n   117→                } else {\n   118→                    Ok(Some(trimmed.to_owned()))\n   119→                }\n   120→            }\n   121→            Err(error) if error.kind() == std::io::ErrorKind::NotFound => Ok(None),\n   122→            Err(error) => Err(error.into()),\n   123→        }\n   124→    }\n   125→\n   126→    pub fn write_active_project(workspace_root: &Path, project_id: &str) -> AppResult<()> {\n   127→        Self::write_atomic(&workspace_root.join(ACTIVE_PROJECT_FILE), project_id)\n   128→    }\n   129→\n   130→    pub fn open_editor(path: &Path) -> AppResult<()> {\n   131→        let editor = env::var(\"EDITOR\")\n   132→            .ok()\n   133→            .filter(|value| !value.trim().is_empty())\n   134→            .or_else(|| {\n   135→                env::var(\"VISUAL\")\n   136→                    .ok()\n   137→                    .filter(|value| !value.trim().is_empty())\n   138→            })\n   139→            .unwrap_or_else(|| \"vi\".to_owned());\n   140→\n   141→        let mut parts = editor.split_whitespace();\n   142→        let program = parts.next().ok_or_else(|| AppError::EditorFailed {\n   143→            editor: editor.clone(),\n   144→            details: \": empty editor command\".to_owned(),\n   145→        })?;\n   146→        let status = Command::new(program).args(parts).arg(path).status()?;\n   147→\n   148→        if status.success() {\n   149→            Ok(())\n   150→        } else {\n   151→            let details = match status.code() {\n   152→                Some(code) => format!(\" with exit code {code}\"),\n   153→                None => \" after being terminated by a signal\".to_owned(),\n   154→            };\n   155→            Err(AppError::EditorFailed { editor, details })\n   156→        }\n   157→    }\n   158→\n   159→    /// Compute a simple hash of content for prompt integrity tracking.\n   160→    pub fn prompt_hash(contents: &str) -> String {\n   161→        use std::collections::hash_map::DefaultHasher;\n   162→        use std::hash::{Hash, Hasher};\n   163→        let mut hasher = DefaultHasher::new();\n   164→        contents.hash(&mut hasher);\n   165→        format!(\"{:016x}\", hasher.finish())\n   166→    }\n   167→\n   168→    // ── Helpers for project filesystem layout ──\n   169→\n   170→    pub(crate) fn workspace_root_path(base_dir: &Path) -> PathBuf {\n   171→        base_dir.join(WORKSPACE_DIR)\n   172→    }\n   173→\n   174→    pub(crate) fn daemon_root(base_dir: &Path) -> PathBuf {\n   175→        Self::workspace_root_path(base_dir).join(\"daemon\")\n   176→    }\n   177→\n   178→    fn project_root(base_dir: &Path, project_id: &ProjectId) -> PathBuf {\n   179→        Self::workspace_root_path(base_dir)\n   180→            .join(PROJECTS_DIR)\n   181→            .join(project_id.as_str())\n   182→    }\n   183→\n   184→    fn pending_delete_path(base_dir: &Path, project_id: &ProjectId) -> PathBuf {\n   185→        Self::workspace_root_path(base_dir)\n   186→            .join(PROJECTS_DIR)\n   187→            .join(format!(\".{}.pending-delete\", project_id))\n   188→    }\n   189→\n   190→    fn append_line(path: &Path, line: &str) -> AppResult<()> {\n   191→        let parent = path.parent().ok_or_else(|| {\n   192→            AppError::Io(std::io::Error::new(\n   193→                std::io::ErrorKind::InvalidInput,\n   194→                format!(\"path '{}' has no parent directory\", path.display()),\n   195→            ))\n   196→        })?;\n   197→        fs::create_dir_all(parent)?;\n   198→\n   199→        let needs_separator = match fs::read(path) {\n   200→            Ok(contents) => contents.last().is_some_and(|byte| *byte != b'\\n'),\n   201→            Err(error) if error.kind() == std::io::ErrorKind::NotFound => false,\n   202→            Err(error) => return Err(error.into()),\n   203→        };\n   204→\n   205→        let mut file = OpenOptions::new().create(true).append(true).open(path)?;\n   206→        if needs_separator {\n   207→            file.write_all(b\"\\n\")?;\n   208→        }\n   209→        writeln!(file, \"{}\", line)?;\n   210→        file.sync_all()?;\n   211→        Ok(())\n   212→    }\n   213→\n   214→    fn write_create_new(path: &Path, contents: &str) -> AppResult<()> {\n   215→        let parent = path.parent().ok_or_else(|| {\n   216→            AppError::Io(std::io::Error::new(\n   217→                std::io::ErrorKind::InvalidInput,\n   218→                format!(\"path '{}' has no parent directory\", path.display()),\n   219→            ))\n   220→        })?;\n   221→        fs::create_dir_all(parent)?;\n   222→\n   223→        let timestamp = SystemTime::now()\n   224→            .duration_since(UNIX_EPOCH)\n   225→            .map(|duration| duration.as_nanos())\n   226→            .unwrap_or_default();\n   227→        let temp_path = parent.join(format!(\n   228→            \".{}.{}.{}.tmp\",\n   229→            path.file_name()\n   230→                .and_then(|value| value.to_str())\n   231→                .unwrap_or(\"workspace\"),\n   232→            std::process::id(),\n   233→            timestamp\n   234→        ));\n   235→\n   236→        let mut file = OpenOptions::new()\n   237→            .create_new(true)\n   238→            .write(true)\n   239→            .open(&temp_path)?;\n   240→        file.write_all(contents.as_bytes())?;\n   241→        file.sync_all()?;\n   242→        drop(file);\n   243→\n   244→        match fs::hard_link(&temp_path, path) {\n   245→            Ok(()) => {\n   246→                let _ = fs::remove_file(&temp_path);\n   247→                Ok(())\n   248→            }\n   249→            Err(error) => {\n   250→                let _ = fs::remove_file(&temp_path);\n   251→                Err(error.into())\n   252→            }\n   253→        }\n   254→    }\n   255→}\n   256→\n   257→/// Filesystem-backed implementation of `ProjectStorePort`.\n   258→pub struct FsProjectStore;\n   259→\n   260→impl ProjectStorePort for FsProjectStore {\n   261→    fn project_exists(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<bool> {\n   262→        let project_root = FileSystem::project_root(base_dir, project_id);\n   263→        if !project_root.is_dir() {\n   264→            return Ok(false);\n   265→        }\n   266→        if !project_root.join(PROJECT_CONFIG_FILE).is_file() {\n   267→            return Err(AppError::CorruptRecord {\n   268→                file: format!(\"projects/{}/project.toml\", project_id),\n   269→                details: \"project directory exists but canonical project.toml is missing\"\n   270→                    .to_owned(),\n   271→            });\n   272→        }\n   273→        Ok(true)\n   274→    }\n   275→\n   276→    fn read_project_record(\n   277→        &self,\n   278→        base_dir: &Path,\n   279→        project_id: &ProjectId,\n   280→    ) -> AppResult<ProjectRecord> {\n   281→        let project_root = FileSystem::project_root(base_dir, project_id);\n   282→        let path = project_root.join(PROJECT_CONFIG_FILE);\n   283→        let raw = fs::read_to_string(&path).map_err(|e| {\n   284→            if e.kind() == std::io::ErrorKind::NotFound {\n   285→                if project_root.is_dir() {\n   286→                    // Directory exists but project.toml is missing — corruption\n   287→                    AppError::CorruptRecord {\n   288→                        file: format!(\"projects/{}/project.toml\", project_id),\n   289→                        details: \"project directory exists but canonical project.toml is missing\"\n   290→                            .to_owned(),\n   291→                    }\n   292→                } else {\n   293→                    AppError::ProjectNotFound {\n   294→                        project_id: project_id.to_string(),\n   295→                    }\n   296→                }\n   297→            } else {\n   298→                e.into()\n   299→            }\n   300→        })?;\n   301→        toml::from_str(&raw).map_err(|e| AppError::CorruptRecord {\n   302→            file: format!(\"projects/{}/project.toml\", project_id),\n   303→            details: e.to_string(),\n   304→        })\n   305→    }\n   306→\n   307→    fn list_project_ids(&self, base_dir: &Path) -> AppResult<Vec<ProjectId>> {\n   308→        let projects_dir = FileSystem::workspace_root_path(base_dir).join(PROJECTS_DIR);\n   309→        if !projects_dir.is_dir() {\n   310→            return Ok(Vec::new());\n   311→        }\n   312→\n   313→        let mut ids = Vec::new();\n   314→        for entry in fs::read_dir(&projects_dir)? {\n   315→            let entry = entry?;\n   316→            if !entry.file_type()?.is_dir() {\n   317→                continue;\n   318→            }\n   319→            let name = entry.file_name();\n   320→            let name_str = name.to_string_lossy();\n   321→            // Skip hidden directories (staging/trash from transactional operations)\n   322→            if name_str.starts_with('.') {\n   323→                continue;\n   324→            }\n   325→            if let Ok(pid) = ProjectId::new(name_str.as_ref()) {\n   326→                if !entry.path().join(PROJECT_CONFIG_FILE).is_file() {\n   327→                    return Err(AppError::CorruptRecord {\n   328→                        file: format!(\"projects/{}/project.toml\", name_str),\n   329→                        details: \"project directory exists but canonical project.toml is missing\"\n   330→                            .to_owned(),\n   331→                    });\n   332→                }\n   333→                ids.push(pid);\n   334→            }\n   335→        }\n   336→\n   337→        ids.sort_by(|a, b| a.as_str().cmp(b.as_str()));\n   338→        Ok(ids)\n   339→    }\n   340→\n   341→    fn stage_delete(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<()> {\n   342→        let project_root = FileSystem::project_root(base_dir, project_id);\n   343→        if !project_root.is_dir() {\n   344→            return Err(AppError::ProjectNotFound {\n   345→                project_id: project_id.to_string(),\n   346→            });\n   347→        }\n   348→\n   349→        let pending_path = FileSystem::pending_delete_path(base_dir, project_id);\n   350→\n   351→        // Clean up any leftover pending-delete from a previous crash\n   352→        if pending_path.exists() {\n   353→            fs::remove_dir_all(&pending_path)?;\n   354→        }\n   355→\n   356→        // Atomic rename to pending-delete location — project becomes\n   357→        // invisible to list/show but data stays on disk.\n   358→        fs::rename(&project_root, &pending_path)?;\n   359→        Ok(())\n   360→    }\n   361→\n   362→    fn commit_delete(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<()> {\n   363→        let pending_path = FileSystem::pending_delete_path(base_dir, project_id);\n   364→        if pending_path.is_dir() {\n   365→            fs::remove_dir_all(&pending_path)?;\n   366→        }\n   367→        Ok(())\n   368→    }\n   369→\n   370→    fn rollback_delete(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<()> {\n   371→        let project_root = FileSystem::project_root(base_dir, project_id);\n   372→        let pending_path = FileSystem::pending_delete_path(base_dir, project_id);\n   373→\n   374→        if !pending_path.is_dir() {\n   375→            return Ok(());\n   376→        }\n   377→\n   378→        fs::rename(&pending_path, &project_root)?;\n   379→        Ok(())\n   380→    }\n   381→\n   382→    fn create_project_atomic(\n   383→        &self,\n   384→        base_dir: &Path,\n   385→        record: &ProjectRecord,\n   386→        prompt_contents: &str,\n   387→        run_snapshot: &RunSnapshot,\n   388→        initial_journal_line: &str,\n   389→        sessions: &SessionStore,\n   390→    ) -> AppResult<()> {\n   391→        let project_root = FileSystem::project_root(base_dir, &record.id);\n   392→\n   393→        // Stage into a temporary directory alongside the final location\n   394→        let staging_name = format!(\".{}.staging.{}\", record.id, std::process::id());\n   395→        let staging_root = project_root\n   396→            .parent()\n   397→            .expect(\"project root has parent\")\n   398→            .join(&staging_name);\n   399→\n   400→        // Clean up any leftover staging dir\n   401→        if staging_root.exists() {\n   402→            fs::remove_dir_all(&staging_root)?;\n   403→        }\n   404→\n   405→        // Create staging directory and all subdirs\n   406→        fs::create_dir_all(&staging_root)?;\n   407→        for subdir in PROJECT_SUBDIRS {\n   408→            fs::create_dir_all(staging_root.join(subdir))?;\n   409→        }\n   410→\n   411→        // Write all canonical files into staging\n   412→        let write_result = (|| -> AppResult<()> {\n   413→            // project.toml\n   414→            let project_toml = toml::to_string_pretty(record)\n   415→                .map_err(|e| AppError::Io(std::io::Error::other(e.to_string())))?;\n   416→            fs::write(staging_root.join(PROJECT_CONFIG_FILE), project_toml)?;\n   417→\n   418→            // prompt.md\n   419→            fs::write(staging_root.join(PROMPT_FILE), prompt_contents)?;\n   420→\n   421→            // run.json\n   422→            let run_json = serde_json::to_string_pretty(run_snapshot)?;\n   423→            fs::write(staging_root.join(RUN_FILE), run_json)?;\n   424→\n   425→            // journal.ndjson (with initial event)\n   426→            let mut journal_content = initial_journal_line.to_owned();\n   427→            journal_content.push('\\n');\n   428→            fs::write(staging_root.join(JOURNAL_FILE), journal_content)?;\n   429→\n   430→            // sessions.json\n   431→            let sessions_json = serde_json::to_string_pretty(sessions)?;\n   432→            fs::write(staging_root.join(SESSIONS_FILE), sessions_json)?;\n   433→\n   434→            Ok(())\n   435→        })();\n   436→\n   437→        if let Err(e) = write_result {\n   438→            // Clean up staging on failure\n   439→            let _ = fs::remove_dir_all(&staging_root);\n   440→            return Err(e);\n   441→        }\n   442→\n   443→        // Atomic rename from staging to final location\n   444→        if let Err(e) = fs::rename(&staging_root, &project_root) {\n   445→            let _ = fs::remove_dir_all(&staging_root);\n   446→            return Err(e.into());\n   447→        }\n   448→\n   449→        Ok(())\n   450→    }\n   451→}\n   452→\n   453→/// Filesystem-backed implementation of `JournalStorePort`.\n   454→pub struct FsJournalStore;\n   455→\n   456→impl JournalStorePort for FsJournalStore {\n   457→    fn read_journal(\n   458→        &self,\n   459→        base_dir: &Path,\n   460→        project_id: &ProjectId,\n   461→    ) -> AppResult<Vec<JournalEvent>> {\n   462→        let path = FileSystem::project_root(base_dir, project_id).join(JOURNAL_FILE);\n   463→        match fs::read_to_string(&path) {\n   464→            Ok(contents) => journal::parse_journal(&contents),\n   465→            Err(e) if e.kind() == std::io::ErrorKind::NotFound => Err(AppError::CorruptRecord {\n   466→                file: format!(\"projects/{}/journal.ndjson\", project_id),\n   467→                details: \"canonical file is missing\".to_owned(),\n   468→            }),\n   469→            Err(e) => Err(e.into()),\n   470→        }\n   471→    }\n   472→\n   473→    fn append_event(&self, base_dir: &Path, project_id: &ProjectId, line: &str) -> AppResult<()> {\n   474→        let path = FileSystem::project_root(base_dir, project_id).join(JOURNAL_FILE);\n   475→        FileSystem::append_line(&path, line)\n   476→    }\n   477→}\n   478→\n   479→/// Filesystem-backed implementation of `ArtifactStorePort`.\n   480→pub struct FsArtifactStore;\n   481→\n   482→impl ArtifactStorePort for FsArtifactStore {\n   483→    fn list_payloads(\n   484→        &self,\n   485→        base_dir: &Path,\n   486→        project_id: &ProjectId,\n   487→    ) -> AppResult<Vec<PayloadRecord>> {\n   488→        let dir = FileSystem::project_root(base_dir, project_id).join(\"history/payloads\");\n   489→        if !dir.is_dir() {\n   490→            return Ok(Vec::new());\n   491→        }\n   492→\n   493→        let mut records = Vec::new();\n   494→        for entry in fs::read_dir(&dir)? {\n   495→            let entry = entry?;\n   496→            let path = entry.path();\n   497→            if path.extension().is_some_and(|ext| ext == \"json\") {\n   498→                let raw = fs::read_to_string(&path)?;\n   499→                let record: PayloadRecord =\n   500→                    serde_json::from_str(&raw).map_err(|e| AppError::CorruptRecord {\n   501→                        file: format!(\n   502→                            \"history/payloads/{}\",\n   503→                            path.file_name().unwrap_or_default().to_string_lossy()\n   504→                        ),\n   505→                        details: e.to_string(),\n   506→                    })?;\n   507→                records.push(record);\n   508→            }\n   509→        }\n   510→\n   511→        records.sort_by_key(|r| r.created_at);\n   512→        Ok(records)\n   513→    }\n   514→\n   515→    fn list_artifacts(\n   516→        &self,\n   517→        base_dir: &Path,\n   518→        project_id: &ProjectId,\n   519→    ) -> AppResult<Vec<ArtifactRecord>> {\n   520→        let dir = FileSystem::project_root(base_dir, project_id).join(\"history/artifacts\");\n   521→        if !dir.is_dir() {\n   522→            return Ok(Vec::new());\n   523→        }\n   524→\n   525→        let mut records = Vec::new();\n   526→        for entry in fs::read_dir(&dir)? {\n   527→            let entry = entry?;\n   528→            let path = entry.path();\n   529→            if path.extension().is_some_and(|ext| ext == \"json\") {\n   530→                let raw = fs::read_to_string(&path)?;\n   531→                let record: ArtifactRecord =\n   532→                    serde_json::from_str(&raw).map_err(|e| AppError::CorruptRecord {\n   533→                        file: format!(\n   534→                            \"history/artifacts/{}\",\n   535→                            path.file_name().unwrap_or_default().to_string_lossy()\n   536→                        ),\n   537→                        details: e.to_string(),\n   538→                    })?;\n   539→                records.push(record);\n   540→            }\n   541→        }\n   542→\n   543→        records.sort_by_key(|r| r.created_at);\n   544→        Ok(records)\n   545→    }\n   546→}\n   547→\n   548→/// Filesystem-backed implementation of `RuntimeLogStorePort`.\n   549→pub struct FsRuntimeLogStore;\n   550→\n   551→impl RuntimeLogStorePort fo