{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01HJTDJgsLrcy79z1xKnAKv2","type":"tool_result","content":"     1→use std::path::Path;\n     2→\n     3→use chrono::{DateTime, Utc};\n     4→use serde_json::json;\n     5→\n     6→use crate::contexts::automation_runtime::model::{TaskStatus, WorktreeLease};\n     7→use crate::contexts::automation_runtime::task_service::DaemonTaskService;\n     8→use crate::contexts::automation_runtime::{DaemonStorePort, WorktreePort};\n     9→use crate::shared::domain::ProjectId;\n    10→use crate::shared::error::{AppError, AppResult};\n    11→\n    12→#[derive(Debug, Clone, Default, PartialEq, Eq)]\n    13→pub struct ReconcileReport {\n    14→    pub stale_lease_ids: Vec<String>,\n    15→    pub failed_task_ids: Vec<String>,\n    16→    pub released_lease_ids: Vec<String>,\n    17→    pub removed_worktrees: Vec<String>,\n    18→}\n    19→\n    20→pub struct LeaseService;\n    21→\n    22→impl LeaseService {\n    23→    pub fn acquire(\n    24→        store: &dyn DaemonStorePort,\n    25→        worktree: &dyn WorktreePort,\n    26→        base_dir: &Path,\n    27→        repo_root: &Path,\n    28→        task_id: &str,\n    29→        project_id: &ProjectId,\n    30→        ttl_seconds: u64,\n    31→    ) -> AppResult<WorktreeLease> {\n    32→        if store\n    33→            .list_leases(base_dir)?\n    34→            .iter()\n    35→            .any(|lease| lease.task_id == task_id)\n    36→        {\n    37→            return Err(AppError::TaskStateTransitionInvalid {\n    38→                task_id: task_id.to_owned(),\n    39→                from: \"lease_exists\".to_owned(),\n    40→                to: \"lease_acquire\".to_owned(),\n    41→            });\n    42→        }\n    43→\n    44→        let lease_id = format!(\"lease-{task_id}\");\n    45→        store.acquire_writer_lock(base_dir, project_id, &lease_id)?;\n    46→\n    47→        let worktree_path = worktree.worktree_path(base_dir, task_id);\n    48→        let branch_name = worktree.branch_name(task_id);\n    49→        if let Err(error) =\n    50→            worktree.create_worktree(repo_root, &worktree_path, &branch_name, task_id)\n    51→        {\n    52→            let _ = store.release_writer_lock(base_dir, project_id);\n    53→            return Err(error);\n    54→        }\n    55→\n    56→        let now = Utc::now();\n    57→        let lease = WorktreeLease {\n    58→            lease_id,\n    59→            task_id: task_id.to_owned(),\n    60→            project_id: project_id.to_string(),\n    61→            worktree_path,\n    62→            branch_name,\n    63→            acquired_at: now,\n    64→            ttl_seconds,\n    65→            last_heartbeat: now,\n    66→        };\n    67→        if let Err(error) = store.write_lease(base_dir, &lease) {\n    68→            let _ = worktree.remove_worktree(repo_root, &lease.worktree_path, task_id);\n    69→            let _ = store.release_writer_lock(base_dir, project_id);\n    70→            return Err(error);\n    71→        }\n    72→\n    73→        Ok(lease)\n    74→    }\n    75→\n    76→    pub fn heartbeat(\n    77→        store: &dyn DaemonStorePort,\n    78→        base_dir: &Path,\n    79→        lease_id: &str,\n    80→    ) -> AppResult<WorktreeLease> {\n    81→        let mut lease = store.read_lease(base_dir, lease_id)?;\n    82→        let now = Utc::now();\n    83→        if lease.is_stale_at(now) {\n    84→            return Err(AppError::LeaseStale {\n    85→                lease_id: lease_id.to_owned(),\n    86→            });\n    87→        }\n    88→        lease.last_heartbeat = now;\n    89→        store.write_lease(base_dir, &lease)?;\n    90→        Ok(lease)\n    91→    }\n    92→\n    93→    pub fn release(\n    94→        store: &dyn DaemonStorePort,\n    95→        worktree: &dyn WorktreePort,\n    96→        base_dir: &Path,\n    97→        repo_root: &Path,\n    98→        lease: &WorktreeLease,\n    99→    ) -> AppResult<()> {\n   100→        let project_id = ProjectId::new(lease.project_id.clone())?;\n   101→        let remove_error = worktree\n   102→            .remove_worktree(repo_root, &lease.worktree_path, &lease.task_id)\n   103→            .err();\n   104→        store.remove_lease(base_dir, &lease.lease_id)?;\n   105→        store.release_writer_lock(base_dir, &project_id)?;\n   106→        DaemonTaskService::append_journal_event(\n   107→            store,\n   108→            base_dir,\n   109→            crate::contexts::automation_runtime::model::DaemonJournalEventType::LeaseReleased,\n   110→            json!({\n   111→                \"task_id\": lease.task_id,\n   112→                \"lease_id\": lease.lease_id,\n   113→                \"project_id\": lease.project_id,\n   114→            }),\n   115→        )?;\n   116→\n   117→        if let Some(error) = remove_error {\n   118→            return Err(error);\n   119→        }\n   120→\n   121→        Ok(())\n   122→    }\n   123→\n   124→    pub fn find_lease_for_task(\n   125→        store: &dyn DaemonStorePort,\n   126→        base_dir: &Path,\n   127→        task_id: &str,\n   128→    ) -> AppResult<Option<WorktreeLease>> {\n   129→        Ok(store\n   130→            .list_leases(base_dir)?\n   131→            .into_iter()\n   132→            .find(|lease| lease.task_id == task_id))\n   133→    }\n   134→\n   135→    pub fn reconcile(\n   136→        store: &dyn DaemonStorePort,\n   137→        worktree: &dyn WorktreePort,\n   138→        base_dir: &Path,\n   139→        repo_root: &Path,\n   140→        ttl_override_seconds: Option<u64>,\n   141→        now: DateTime<Utc>,\n   142→    ) -> AppResult<ReconcileReport> {\n   143→        let mut report = ReconcileReport::default();\n   144→        let leases = store.list_leases(base_dir)?;\n   145→\n   146→        for lease in leases {\n   147→            let is_stale = ttl_override_seconds\n   148→                .map(|ttl| now > lease.last_heartbeat + chrono::Duration::seconds(ttl as i64))\n   149→                .unwrap_or_else(|| lease.is_stale_at(now));\n   150→            if !is_stale {\n   151→                continue;\n   152→            }\n   153→\n   154→            report.stale_lease_ids.push(lease.lease_id.clone());\n   155→            let task = store.read_task(base_dir, &lease.task_id)?;\n   156→            if matches!(task.status, TaskStatus::Claimed | TaskStatus::Active) {\n   157→                DaemonTaskService::mark_failed(\n   158→                    store,\n   159→                    base_dir,\n   160→                    &task.task_id,\n   161→                    \"reconciliation_timeout\",\n   162→                    \"stale lease heartbeat exceeded ttl\",\n   163→                )?;\n   164→                report.failed_task_ids.push(task.task_id.clone());\n   165→            }\n   166→\n   167→            let _ = Self::release(store, worktree, base_dir, repo_root, &lease);\n   168→            let _ = DaemonTaskService::clear_lease_reference(store, base_dir, &task.task_id);\n   169→            report.released_lease_ids.push(lease.lease_id.clone());\n   170→            report\n   171→                .removed_worktrees\n   172→                .push(lease.worktree_path.display().to_string());\n   173→        }\n   174→\n   175→        DaemonTaskService::append_journal_event(\n   176→            store,\n   177→            base_dir,\n   178→            crate::contexts::automation_runtime::model::DaemonJournalEventType::ReconciliationRun,\n   179→            json!({\n   180→                \"stale_lease_ids\": report.stale_lease_ids,\n   181→                \"failed_task_ids\": report.failed_task_ids,\n   182→                \"released_lease_ids\": report.released_lease_ids,\n   183→            }),\n   184→        )?;\n   185→\n   186→        Ok(report)\n   187→    }\n   188→}\n   189→"}]},"parent_tool_use_id":"toolu_01127w93r2hddj2R7DxzcewM","session_id":"8dacb19c-9278-40df-b484-c803ec7bbb98","uuid":"6e0d0de5-0126-4702-bb1c-adb56e14dae6"}
