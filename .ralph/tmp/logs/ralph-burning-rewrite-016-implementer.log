{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Bp4VZBkWnY9zpcSs7MqBa9","type":"tool_result","content":"     1→use std::collections::HashMap;\n     2→use std::path::{Path, PathBuf};\n     3→use std::process::Command;\n     4→\n     5→use super::runner::ScenarioExecutor;\n     6→\n     7→use crate::contexts::workflow_composition::contracts::{contract_for_stage, all_contracts, ContractFamily};\n     8→use crate::shared::domain::StageId;\n     9→use crate::shared::error::ContractError;\n    10→\n    11→// ---------------------------------------------------------------------------\n    12→// Temp workspace helper\n    13→// ---------------------------------------------------------------------------\n    14→\n    15→struct TempWorkspace {\n    16→    path: PathBuf,\n    17→}\n    18→\n    19→impl TempWorkspace {\n    20→    fn new() -> Result<Self, String> {\n    21→        let path = std::env::temp_dir().join(format!(\n    22→            \"ralph-conformance-{}\",\n    23→            uuid::Uuid::new_v4()\n    24→        ));\n    25→        std::fs::create_dir_all(&path).map_err(|e| format!(\"create temp workspace: {e}\"))?;\n    26→        Ok(Self { path })\n    27→    }\n    28→\n    29→    fn path(&self) -> &Path {\n    30→        &self.path\n    31→    }\n    32→}\n    33→\n    34→impl Drop for TempWorkspace {\n    35→    fn drop(&mut self) {\n    36→        let _ = std::fs::remove_dir_all(&self.path);\n    37→    }\n    38→}\n    39→\n    40→// ---------------------------------------------------------------------------\n    41→// CLI helpers\n    42→// ---------------------------------------------------------------------------\n    43→\n    44→fn binary_path() -> PathBuf {\n    45→    std::env::current_exe().expect(\"current executable path\")\n    46→}\n    47→\n    48→struct CmdOutput {\n    49→    success: bool,\n    50→    stdout: String,\n    51→    stderr: String,\n    52→}\n    53→\n    54→fn run_cli(args: &[&str], cwd: &Path) -> Result<CmdOutput, String> {\n    55→    run_cli_with_env(args, cwd, &[])\n    56→}\n    57→\n    58→fn run_cli_with_env(\n    59→    args: &[&str],\n    60→    cwd: &Path,\n    61→    env: &[(&str, &str)],\n    62→) -> Result<CmdOutput, String> {\n    63→    let mut cmd = Command::new(binary_path());\n    64→    cmd.args(args).current_dir(cwd);\n    65→    for (k, v) in env {\n    66→        cmd.env(k, v);\n    67→    }\n    68→    let output = cmd.output().map_err(|e| format!(\"failed to run CLI: {e}\"))?;\n    69→\n    70→    Ok(CmdOutput {\n    71→        success: output.status.success(),\n    72→        stdout: String::from_utf8_lossy(&output.stdout).to_string(),\n    73→        stderr: String::from_utf8_lossy(&output.stderr).to_string(),\n    74→    })\n    75→}\n    76→\n    77→// ---------------------------------------------------------------------------\n    78→// Journal and durable-state assertion helpers\n    79→// ---------------------------------------------------------------------------\n    80→\n    81→fn read_journal(ws: &TempWorkspace, project_id: &str) -> Result<Vec<serde_json::Value>, String> {\n    82→    let path = ws\n    83→        .path()\n    84→        .join(format!(\".ralph-burning/projects/{project_id}/journal.ndjson\"));\n    85→    let content = std::fs::read_to_string(&path).map_err(|e| format!(\"read journal: {e}\"))?;\n    86→    content\n    87→        .lines()\n    88→        .filter(|l| !l.trim().is_empty())\n    89→        .map(|l| serde_json::from_str(l).map_err(|e| format!(\"parse journal line: {e}\")))\n    90→        .collect()\n    91→}\n    92→\n    93→fn read_run_snapshot(\n    94→    ws: &TempWorkspace,\n    95→    project_id: &str,\n    96→) -> Result<serde_json::Value, String> {\n    97→    let path = ws\n    98→        .path()\n    99→        .join(format!(\".ralph-burning/projects/{project_id}/run.json\"));\n   100→    let content = std::fs::read_to_string(&path).map_err(|e| format!(\"read run.json: {e}\"))?;\n   101→    serde_json::from_str(&content).map_err(|e| format!(\"parse run.json: {e}\"))\n   102→}\n   103→\n   104→fn count_payload_files(ws: &TempWorkspace, project_id: &str) -> Result<usize, String> {\n   105→    let dir = ws\n   106→        .path()\n   107→        .join(format!(\".ralph-burning/projects/{project_id}/history/payloads\"));\n   108→    let count = std::fs::read_dir(&dir)\n   109→        .map_err(|e| format!(\"read payloads dir: {e}\"))?\n   110→        .filter_map(|e| e.ok())\n   111→        .filter(|e| e.path().extension().map_or(false, |ext| ext == \"json\"))\n   112→        .count();\n   113→    Ok(count)\n   114→}\n   115→\n   116→fn count_artifact_files(ws: &TempWorkspace, project_id: &str) -> Result<usize, String> {\n   117→    let dir = ws\n   118→        .path()\n   119→        .join(format!(\".ralph-burning/projects/{project_id}/history/artifacts\"));\n   120→    let count = std::fs::read_dir(&dir)\n   121→        .map_err(|e| format!(\"read artifacts dir: {e}\"))?\n   122→        .filter_map(|e| e.ok())\n   123→        .filter(|e| e.path().extension().map_or(false, |ext| ext == \"md\"))\n   124→        .count();\n   125→    Ok(count)\n   126→}\n   127→\n   128→fn journal_event_types(events: &[serde_json::Value]) -> Vec<String> {\n   129→    events\n   130→        .iter()\n   131→        .filter_map(|e| e.get(\"event_type\").and_then(|v| v.as_str()).map(String::from))\n   132→        .collect()\n   133→}\n   134→\n   135→/// Check that `haystack` does not contain `needle`, returning a descriptive error if it does.\n   136→#[allow(dead_code)]\n   137→fn assert_not_contains(haystack: &str, needle: &str, context: &str) -> Result<(), String> {\n   138→    if haystack.contains(needle) {\n   139→        return Err(format!(\n   140→            \"{context}: expected NOT to contain '{needle}', got: {haystack}\"\n   141→        ));\n   142→    }\n   143→    Ok(())\n   144→}\n   145→\n   146→fn assert_success(out: &CmdOutput) -> Result<(), String> {\n   147→    if !out.success {\n   148→        return Err(format!(\"expected success, got failure. stderr: {}\", out.stderr));\n   149→    }\n   150→    Ok(())\n   151→}\n   152→\n   153→fn assert_failure(out: &CmdOutput) -> Result<(), String> {\n   154→    if out.success {\n   155→        return Err(\"expected failure, got success\".to_owned());\n   156→    }\n   157→    Ok(())\n   158→}\n   159→\n   160→fn assert_contains(haystack: &str, needle: &str, context: &str) -> Result<(), String> {\n   161→    if !haystack.contains(needle) {\n   162→        return Err(format!(\"{context}: expected to contain '{needle}', got: {haystack}\"));\n   163→    }\n   164→    Ok(())\n   165→}\n   166→\n   167→fn init_workspace(ws: &TempWorkspace) -> Result<(), String> {\n   168→    let out = run_cli(&[\"init\"], ws.path())?;\n   169→    assert_success(&out)\n   170→}\n   171→\n   172→fn create_project_fixture(base_dir: &Path, project_id: &str, flow: &str) {\n   173→    let project_root = base_dir.join(\".ralph-burning/projects\").join(project_id);\n   174→    std::fs::create_dir_all(&project_root).expect(\"create project directory\");\n   175→    let project_toml = format!(\n   176→        r#\"id = \"{project_id}\"\n   177→name = \"Fixture {project_id}\"\n   178→flow = \"{flow}\"\n   179→prompt_reference = \"prompt.md\"\n   180→prompt_hash = \"0000000000000000\"\n   181→created_at = \"2026-03-11T19:00:00Z\"\n   182→status_summary = \"created\"\n   183→\"#\n   184→    );\n   185→    std::fs::write(project_root.join(\"project.toml\"), project_toml).expect(\"write project\");\n   186→    std::fs::write(project_root.join(\"prompt.md\"), \"# Fixture prompt\\n\").expect(\"write prompt\");\n   187→    std::fs::write(\n   188→        project_root.join(\"run.json\"),\n   189→        r#\"{\"active_run\":null,\"status\":\"not_started\",\"cycle_history\":[],\"completion_rounds\":0,\"rollback_point_meta\":{\"last_rollback_id\":null,\"rollback_count\":0},\"amendment_queue\":{\"pending\":[],\"processed_count\":0},\"status_summary\":\"not started\"}\"#,\n   190→    ).expect(\"write run.json\");\n   191→    std::fs::write(\n   192→        project_root.join(\"journal.ndjson\"),\n   193→        format!(\n   194→            r#\"{{\"sequence\":1,\"timestamp\":\"2026-03-11T19:00:00Z\",\"event_type\":\"project_created\",\"details\":{{\"project_id\":\"{project_id}\",\"flow\":\"{flow}\"}}}}\"#,\n   195→        ),\n   196→    ).expect(\"write journal\");\n   197→    std::fs::write(project_root.join(\"sessions.json\"), r#\"{\"sessions\":[]}\"#).expect(\"write sessions\");\n   198→    for subdir in &[\n   199→        \"history/payloads\",\n   200→        \"history/artifacts\",\n   201→        \"runtime/logs\",\n   202→        \"runtime/backend\",\n   203→        \"runtime/temp\",\n   204→        \"amendments\",\n   205→        \"rollback\",\n   206→    ] {\n   207→        std::fs::create_dir_all(project_root.join(subdir)).expect(\"create project subdirectory\");\n   208→    }\n   209→}\n   210→\n   211→fn select_project(base_dir: &Path, project_id: &str) {\n   212→    std::fs::write(\n   213→        base_dir.join(\".ralph-burning/active-project\"),\n   214→        format!(\"{project_id}\\n\"),\n   215→    )\n   216→    .expect(\"write active-project\");\n   217→}\n   218→\n   219→fn setup_workspace_with_project(\n   220→    ws: &TempWorkspace,\n   221→    project_id: &str,\n   222→    flow: &str,\n   223→) -> Result<(), String> {\n   224→    init_workspace(ws)?;\n   225→    create_project_fixture(ws.path(), project_id, flow);\n   226→    select_project(ws.path(), project_id);\n   227→    Ok(())\n   228→}\n   229→\n   230→/// Initialize a git repository in the temp workspace with an initial commit.\n   231→/// Returns the SHA of the initial commit so tests can assert against it.\n   232→fn init_git_repo(ws: &TempWorkspace) -> Result<String, String> {\n   233→    let run = |args: &[&str]| -> Result<String, String> {\n   234→        let output = Command::new(\"git\")\n   235→          