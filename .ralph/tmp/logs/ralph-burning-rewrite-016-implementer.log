 41→impl DaemonTask {\n    42→    pub fn is_terminal(&self) -> bool {\n    43→        self.status.is_terminal()\n    44→    }\n    45→\n    46→    pub fn transition_to(&mut self, next: TaskStatus, now: DateTime<Utc>) -> AppResult<()> {\n    47→        if !self.status.can_transition_to(next) {\n    48→            return Err(AppError::TaskStateTransitionInvalid {\n    49→                task_id: self.task_id.clone(),\n    50→                from: self.status.as_str().to_owned(),\n    51→                to: next.as_str().to_owned(),\n    52→            });\n    53→        }\n    54→\n    55→        self.status = next;\n    56→        self.updated_at = now;\n    57→        Ok(())\n    58→    }\n    59→\n    60→    pub fn attach_lease(&mut self, lease_id: impl Into<String>) {\n    61→        self.lease_id = Some(lease_id.into());\n    62→    }\n    63→\n    64→    pub fn clear_lease(&mut self) {\n    65→        self.lease_id = None;\n    66→    }\n    67→\n    68→    pub fn clear_failure(&mut self) {\n    69→        self.failure_class = None;\n    70→        self.failure_message = None;\n    71→    }\n    72→\n    73→    pub fn set_failure(\n    74→        &mut self,\n    75→        failure_class: impl Into<String>,\n    76→        failure_message: impl Into<String>,\n    77→    ) {\n    78→        self.failure_class = Some(failure_class.into());\n    79→        self.failure_message = Some(failure_message.into());\n    80→    }\n    81→}\n    82→\n    83→#[derive(Debug, Clone, Copy, PartialEq, Eq, Serialize, Deserialize)]\n    84→#[serde(rename_all = \"snake_case\")]\n    85→pub enum TaskStatus {\n    86→    Pending,\n    87→    Claimed,\n    88→    Active,\n    89→    Completed,\n    90→    Failed,\n    91→    Aborted,\n    92→}\n    93→\n    94→impl TaskStatus {\n    95→    pub fn as_str(self) -> &'static str {\n    96→        match self {\n    97→            Self::Pending => \"pending\",\n    98→            Self::Claimed => \"claimed\",\n    99→            Self::Active => \"active\",\n   100→            Self::Completed => \"completed\",\n   101→            Self::Failed => \"failed\",\n   102→            Self::Aborted => \"aborted\",\n   103→        }\n   104→    }\n   105→\n   106→    pub fn is_terminal(self) -> bool {\n   107→        matches!(self, Self::Completed | Self::Failed | Self::Aborted)\n   108→    }\n   109→\n   110→    pub fn can_transition_to(self, next: Self) -> bool {\n   111→        match (self, next) {\n   112→            (Self::Pending, Self::Claimed | Self::Failed) => true,\n   113→            (Self::Claimed, Self::Active | Self::Failed | Self::Aborted) => true,\n   114→            (Self::Active, Self::Completed | Self::Failed | Self::Aborted) => true,\n   115→            (Self::Failed, Self::Pending) => true,\n   116→            _ if self == next => true,\n   117→            _ => false,\n   118→        }\n   119→    }\n   120→}\n   121→\n   122→impl std::fmt::Display for TaskStatus {\n   123→    fn fmt(&self, f: &mut std::fmt::Formatter<'_>) -> std::fmt::Result {\n   124→        f.write_str(self.as_str())\n   125→    }\n   126→}\n   127→\n   128→#[derive(Debug, Clone, PartialEq, Eq, Serialize, Deserialize)]\n   129→pub struct WorktreeLease {\n   130→    pub lease_id: String,\n   131→    pub task_id: String,\n   132→    pub project_id: String,\n   133→    pub worktree_path: PathBuf,\n   134→    pub branch_name: String,\n   135→    pub acquired_at: DateTime<Utc>,\n   136→    pub ttl_seconds: u64,\n   137→    pub last_heartbeat: DateTime<Utc>,\n   138→}\n   139→\n   140→impl WorktreeLease {\n   141→    pub fn heartbeat_deadline(&self) -> DateTime<Utc> {\n   142→        self.last_heartbeat + Duration::seconds(self.ttl_seconds.min(i64::MAX as u64) as i64)\n   143→    }\n   144→\n   145→    pub fn is_stale_at(&self, now: DateTime<Utc>) -> bool {\n   146→        now > self.heartbeat_deadline()\n   147→    }\n   148→}\n   149→\n   150→#[derive(Debug, Clone, Copy, PartialEq, Eq, Serialize, Deserialize)]\n   151→#[serd