{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01R5HhN3qKxzSKqxCwEGnYSN","type":"tool_result","content":"     1→use std::path::Path;\n     2→use std::time::Duration;\n     3→\n     4→use chrono::Utc;\n     5→\n     6→use crate::adapters::fs::FileSystem;\n     7→use crate::contexts::agent_execution::model::CancellationToken;\n     8→use crate::contexts::agent_execution::service::{AgentExecutionPort, RawOutputPort};\n     9→use crate::contexts::agent_execution::session::SessionStorePort;\n    10→use crate::contexts::agent_execution::AgentExecutionService;\n    11→use crate::contexts::automation_runtime::lease_service::LeaseService;\n    12→use crate::contexts::automation_runtime::model::{DaemonTask, TaskStatus};\n    13→use crate::contexts::automation_runtime::routing::RoutingEngine;\n    14→use crate::contexts::automation_runtime::task_service::DaemonTaskService;\n    15→use crate::contexts::automation_runtime::{DaemonStorePort, WorktreePort};\n    16→use crate::contexts::project_run_record::model::RunStatus;\n    17→use crate::contexts::project_run_record::service::{\n    18→    create_project, AmendmentQueuePort, ArtifactStorePort, JournalStorePort,\n    19→    PayloadArtifactWritePort, ProjectStorePort, RunSnapshotPort, RunSnapshotWritePort,\n    20→    RuntimeLogWritePort,\n    21→};\n    22→use crate::contexts::project_run_record::CreateProjectInput;\n    23→use crate::contexts::workflow_composition::engine;\n    24→use crate::contexts::workflow_composition::retry_policy::RetryPolicy;\n    25→use crate::contexts::workspace_governance::config::EffectiveConfig;\n    26→use crate::shared::domain::{FlowPreset, ProjectId};\n    27→use crate::shared::error::{AppError, AppResult};\n    28→\n    29→#[derive(Debug, Clone, PartialEq, Eq)]\n    30→pub struct DaemonLoopConfig {\n    31→    pub poll_interval: Duration,\n    32→    pub lease_ttl: Duration,\n    33→    pub heartbeat_interval: Duration,\n    34→    pub single_iteration: bool,\n    35→}\n    36→\n    37→impl Default for DaemonLoopConfig {\n    38→    fn default() -> Self {\n    39→        Self {\n    40→            poll_interval: Duration::from_secs(10),\n    41→            lease_ttl: Duration::from_secs(300),\n    42→            heartbeat_interval: Duration::from_secs(30),\n    43→            single_iteration: false,\n    44→        }\n    45→    }\n    46→}\n    47→\n    48→pub struct DaemonLoop<'a, A, R, S> {\n    49→    store: &'a dyn DaemonStorePort,\n    50→    worktree: &'a dyn WorktreePort,\n    51→    project_store: &'a dyn ProjectStorePort,\n    52→    run_snapshot_read: &'a dyn RunSnapshotPort,\n    53→    run_snapshot_write: &'a dyn RunSnapshotWritePort,\n    54→    journal_store: &'a dyn JournalStorePort,\n    55→    artifact_store: &'a dyn ArtifactStorePort,\n    56→    artifact_write: &'a dyn PayloadArtifactWritePort,\n    57→    log_write: &'a dyn RuntimeLogWritePort,\n    58→    amendment_queue: &'a dyn AmendmentQueuePort,\n    59→    agent_service: &'a AgentExecutionService<A, R, S>,\n    60→    routing_engine: RoutingEngine,\n    61→}\n    62→\n    63→impl<'a, A, R, S> DaemonLoop<'a, A, R, S> {\n    64→    #[allow(clippy::too_many_arguments)]\n    65→    pub fn new(\n    66→        store: &'a dyn DaemonStorePort,\n    67→        worktree: &'a dyn WorktreePort,\n    68→        project_store: &'a dyn ProjectStorePort,\n    69→        run_snapshot_read: &'a dyn RunSnapshotPort,\n    70→        run_snapshot_write: &'a dyn RunSnapshotWritePort,\n    71→        journal_store: &'a dyn JournalStorePort,\n    72→        artifact_store: &'a dyn ArtifactStorePort,\n    73→        artifact_write: &'a dyn PayloadArtifactWritePort,\n    74→        log_write: &'a dyn RuntimeLogWritePort,\n    75→        amendment_queue: &'a dyn AmendmentQueuePort,\n    76→        agent_service: &'a AgentExecutionService<A, R, S>,\n    77→    ) -> Self {\n    78→        Self {\n    79→            store,\n    80→            worktree,\n    81→            project_store,\n    82→            run_snapshot_read,\n    83→            run_snapshot_write,\n    84→            journal_store,\n    85→            artifact_store,\n    86→            artifact_write,\n    87→            log_write,\n    88→            amendment_queue,\n    89→            agent_service,\n    90→            routing_engine: RoutingEngine::new(),\n    91→        }\n    92→    }\n    93→}\n    94→\n    95→impl<A, R, S> DaemonLoop<'_, A, R, S>\n    96→where\n    97→    A: AgentExecutionPort,\n    98→    R: RawOutputPort,\n    99→    S: SessionStorePort,\n   100→{\n   101→    pub async fn run(&self, base_dir: &Path, config: &DaemonLoopConfig) -> AppResult<()> {\n   102→        let shutdown = CancellationToken::new();\n   103→        let shutdown_watcher = shutdown.clone();\n   104→        tokio::spawn(async move {\n   105→            let _ = wait_for_shutdown_signal().await;\n   106→            shutdown_watcher.cancel();\n   107→        });\n   108→\n   109→        loop {\n   110→            if shutdown.is_cancelled() {\n   111→                self.cleanup_active_leases(base_dir)?;\n   112→                break;\n   113→            }\n   114→\n   115→            let processed = self\n   116→                .process_cycle(base_dir, config, shutdown.clone())\n   117→                .await?;\n   118→            if config.single_iteration {\n   119→                break;\n   120→            }\n   121→\n   122→            let _ = processed;\n   123→            tokio::select! {\n   124→                _ = shutdown.cancelled() => {\n   125→                    self.cleanup_active_leases(base_dir)?;\n   126→                    break;\n   127→                }\n   128→                _ = tokio::time::sleep(config.poll_interval) => {}\n   129→            }\n   130→        }\n   131→\n   132→        Ok(())\n   133→    }\n   134→\n   135→    async fn process_cycle(\n   136→        &self,\n   137→        base_dir: &Path,\n   138→        config: &DaemonLoopConfig,\n   139→        shutdown: CancellationToken,\n   140→    ) -> AppResult<bool> {\n   141→        let pending_task = DaemonTaskService::list_tasks(self.store, base_dir)?\n   142→            .into_iter()\n   143→            .find(|task| task.status == TaskStatus::Pending);\n   144→        let Some(task) = pending_task else {\n   145→            return Ok(false);\n   146→        };\n   147→\n   148→        self.process_task(base_dir, &task, config, shutdown).await?;\n   149→        Ok(true)\n   150→    }\n   151→\n   152→    async fn process_task(\n   153→        &self,\n   154→        base_dir: &Path,\n   155→        task: &DaemonTask,\n   156→        config: &DaemonLoopConfig,\n   157→        shutdown: CancellationToken,\n   158→    ) -> AppResult<()> {\n   159→        let effective_config = EffectiveConfig::load(base_dir)?;\n   160→        let default_flow = effective_config.default_flow();\n   161→        let repo_root = base_dir;\n   162→\n   163→        let (claimed_task, lease) = match DaemonTaskService::claim_task(\n   164→            self.store,\n   165→            self.worktree,\n   166→            &self.routing_engine,\n   167→            base_dir,\n   168→            repo_root,\n   169→            &task.task_id,\n   170→            default_flow,\n   171→            config.lease_ttl.as_secs(),\n   172→        ) {\n   173→            Ok(value) => value,\n   174→            Err(AppError::ProjectWriterLockHeld { .. }) => return Ok(()),\n   175→            Err(error) => return Err(error),\n   176→        };\n   177→\n   178→        println!(\"claimed task {}\", claimed_task.task_id);\n   179→\n   180→        if let Err(error) = self.worktree.rebase_onto_default_branch(\n   181→            repo_root,\n   182→            &lease.worktree_path,\n   183→            &lease.branch_name,\n   184→        ) {\n   185→            let _ = self.fail_claimed_task(\n   186→                base_dir,\n   187→                repo_root,\n   188→                &claimed_task.task_id,\n   189→                &lease,\n   190→                \"rebase_conflict\",\n   191→                &error.to_string(),\n   192→            );\n   193→            println!(\"failed task {}: {}\", claimed_task.task_id, error);\n   194→            return Ok(());\n   195→        }\n   196→\n   197→        if let Err(error) = self.ensure_project(base_dir, &claimed_task) {\n   198→            self.handle_post_claim_failure(base_dir, repo_root, &claimed_task, &lease, &error)?;\n   199→            println!(\"failed task {}: {}\", claimed_task.task_id, error);\n   200→            return Ok(());\n   201→        }\n   202→        let task_on_disk = self.store.read_task(base_dir, &claimed_task.task_id)?;\n   203→        if task_on_disk.status == TaskStatus::Aborted {\n   204→            let _ = self.release_task_lease(base_dir, repo_root, &task_on_disk.task_id, &lease);\n   205→            return Ok(());\n   206→        }\n   207→\n   208→        let active_task =\n   209→            match DaemonTaskService::mark_active(self.store, base_dir, &claimed_task.task_id) {\n   210→                Ok(task) => task,\n   211→                Err(error) => {\n   212→                    self.handle_post_claim_failure(\n   213→                        base_dir,\n   214→                        repo_root,\n   215→                        &claimed_task,\n   216→                        &lease,\n   217→                        &error,\n   218→                    )?;\n   219→                    println!(\"failed task {}: {}\", claimed_task.task_id, error);\n   220→                    return Ok(());\n   221→                }\n   222→            };\n   223→        println!(\"active task {}\", active_task.task_id);\n   224→\n   225→        let task_cancel = CancellationToken::new();\n   226→        let outcome = self\n   227→            .drive_dispatch(\n   228→                base_dir,\n   229→                &active_task,\n   230→                &lease,\n   231→                &effective_config,\n   232→                config,\n   233→                shutdown,\n   234→                task_cancel,\n   235→            )\n   236→            .await;\n   237→\n   238→        let latest_task = self.store.read_task(base_dir, &active_task.task_id)?;\n   239→        if latest_task.status == TaskStatus::Aborted {\n   240→            let _ = self.release_task_lease(base_dir, repo_root, &active_task.task_id, &lease);\n   241→            return Ok(());\n   242→        }\n   243→\n   244→        match outcome {\n   245→            Ok(()) => {\n   246→                let _ =\n   247→                    DaemonTaskService::mark_completed(self.store, base_dir, &active_task.task_id)?;\n   248→                let _ = self.release_task_lease(base_dir, repo_root, &active_task.task_id, &lease);\n   249→                println!(\"completed task {}\", active_task.task_id);\n   250→            }\n   251→            Err(error) => {\n   252→                let failure_class = error\n   253→                    .failure_class()\n   254→                    .map(|class| class.as_str().to_owned())\n   255→                    .unwrap_or_else(|| \"daemon_dispatch_failed\".to_owned());\n   256→                let _ = DaemonTaskService::mark_failed(\n   257→                    self.store,\n   258→                    base_dir,\n   259→                    &active_task.task_id,\n   260→                    &failure_class,\n   261→                    &error.to_string(),\n   262→                )?;\n   263→                let _ = self.release_task_lease(base_dir, repo_root, &active_task.task_id, &lease);\n   264→                println!(\"failed task {}: {}\", active_task.task_id, error);\n   265→            }\n   266→        }\n   267→\n   268→        Ok(())\n   269→    }\n   270→\n   271→    async fn drive_dispatch(\n   272→        &self,\n   273→        base_dir: &Path,\n   274→        task: &DaemonTask,\n   275→        lease: &crate::contexts::automation_runtime::model::WorktreeLease,\n   276→        effective_config: &EffectiveConfig,\n   277→        config: &DaemonLoopConfig,\n   278→        shutdown: CancellationToken,\n   279→        task_cancel: CancellationToken,\n   280→    ) -> AppResult<()> {\n   281→        let project_id = ProjectId::new(task.project_id.clone())?;\n   282→        let flow = task\n   283→            .resolved_flow\n   284→            .ok_or_else(|| AppError::RoutingResolutionFailed {\n   285→                input: task.task_id.clone(),\n   286→                details: \"task has no resolved flow\".to_owned(),\n   287→            })?;\n   288→\n   289→        let run_snapshot = self\n   290→            .run_snapshot_read\n   291→            .read_run_snapshot(base_dir, &project_id)?;\n   292→        let dispatch_future = self.dispatch_in_worktree(\n   293→            base_dir,\n   294→            &project_id,\n   295→            flow,\n   296→            run_snapshot.status,\n   297→            effective_config,\n   298→            &lease.worktree_path,\n   299→            task_cancel.clone(),\n   300→        );\n   301→        tokio::pin!(dispatch_future);\n   302→\n   303→        let heartbeat_interval = config.heartbeat_interval.max(Duration::from_secs(1));\n   304→        let mut heartbeat = tokio::time::interval(heartbeat_interval);\n   305→        let mut abort_poll = tokio::time::interval(Duration::from_millis(250));\n   306→\n   307→        loop {\n   308→            tokio::select! {\n   309→                result = &mut dispatch_future => break result,\n   310→                _ = heartbeat.tick() => {\n   311→                    let _ = LeaseService::heartbeat(self.store, base_dir, &lease.lease_id);\n   312→                }\n   313→                _ = abort_poll.tick() => {\n   314→                    let current = self.store.read_task(base_dir, &task.task_id)?;\n   315→                    if current.status == TaskStatus::Aborted {\n   316→                        task_cancel.cancel();\n   317→                    }\n   318→                }\n   319→                _ = shutdown.cancelled() => {\n   320→                    let _ = DaemonTaskService::mark_aborted(self.store, base_dir, &task.task_id);\n   321→                    task_cancel.cancel();\n   322→                }\n   323→            }\n   324→        }\n   325→    }\n   326→\n   327→    async fn dispatch_in_worktree(\n   328→        &self,\n   329→        base_dir: &Path,\n   330→        project_id: &ProjectId,\n   331→        flow: FlowPreset,\n   332→        run_status: RunStatus,\n   333→        effective_config: &EffectiveConfig,\n   334→        worktree_path: &Path,\n   335→        cancellation_token: CancellationToken,\n   336→    ) -> AppResult<()> {\n   337→        let original_dir = std::env::current_dir()?;\n   338→        std::env::set_current_dir(worktree_path)?;\n   339→\n   340→        let result = match run_status {\n   341→            RunStatus::NotStarted => {\n   342→                engine::execute_run_with_retry(\n   343→                    self.agent_service,\n   344→                    self.run_snapshot_read,\n   345→                    self.run_snapshot_write,\n   346→                    self.journal_store,\n   347→                    self.artifact_write,\n   348→                    self.log_write,\n   349→                    self.amendment_queue,\n   350→                    base_dir,\n   351→                    project_id,\n   352→                    flow,\n   353→                    effective_config,\n   354→                    &RetryPolicy::default_policy(),\n   355→                    cancellation_token,\n   356→                )\n   357→                .await\n   358→            }\n   359→            RunStatus::Failed | RunStatus::Paused => {\n   360→                engine::resume_run_with_retry(\n   361→                    self.agent_service,\n   362→                    self.run_snapshot_read,\n   363→                    self.run_snapshot_write,\n   364→                    self.journal_store,\n   365→                    self.artifact_store,\n   366→                    self.artifact_write,\n   367→                    self.log_write,\n   368→                    self.amendment_queue,\n   369→                    base_dir,\n   370→                    project_id,\n   371→                    flow,\n   372→                    effective_config,\n   373→                    &RetryPolicy::default_policy(),\n   374→                    cancellation_token,\n   375→                )\n   376→                .await\n   377→            }\n   378→            RunStatus::Running => Err(AppError::TaskStateTransitionInvalid {\n   379→                task_id: project_id.to_string(),\n   380→                from: \"run_running\".to_owned(),\n   381→                to: \"daemon_dispatch\".to_owned(),\n   382→            }),\n   383→            RunStatus::Completed => Err(AppError::TaskStateTransitionInvalid {\n   384→                task_id: project_id.to_string(),\n   385→                from: \"run_completed\".to_owned(),\n   386→                to: \"daemon_dispatch\".to_owned(),\n   387→            }),\n   388→        };\n   389→\n   390→        let reset_result = std::env::set_current_dir(original_dir);\n   391→        match (result, reset_result) {\n   392→            (Ok(()), Ok(())) => Ok(()),\n   393→            (Err(error), Ok(())) => Err(error),\n   394→            (Ok(()), Err(error)) => Err(error.into()),\n   395→            (Err(error), Err(_)) => Err(error),\n   396→        }\n   397→    }\n   398→\n   399→    fn ensure_project(&self, base_dir: &Path, task: &DaemonTask) -> AppResult<()> {\n   400→        let project_id = ProjectId::new(task.project_id.clone())?;\n   401→        if self.project_store.project_exists(base_dir, &project_id)? {\n   402→            let record = self\n   403→                .project_store\n   404→                .read_project_record(base_dir, &project_id)?;\n   405→            let flow = task\n   406→                .resolved_flow\n   407→                .ok_or_else(|| AppError::RoutingResolutionFailed {\n   408→                    input: task.task_id.clone(),\n   409→                    details: \"task has no resolved flow\".to_owned(),\n   410→                })?;\n   411→            if record.flow != flow {\n   412→                return Err(AppError::RoutingResolutionFailed {\n   413→                    input: task.task_id.clone(),\n   414→                    details: format!(\n   415→                        \"existing project flow '{}' does not match routed flow '{}'\",\n   416→                        record.flow.as_str(),\n   417→                        flow.as_str()\n   418→                    ),\n   419→                });\n   420→            }\n   421→            return Ok(());\n   422→        }\n   423→\n   424→        let prompt_contents = task.prompt.clone().unwrap_or_else(|| {\n   425→            format!(\n   426→                \"# Automated task {}\\n\\nIssue: {}\\n\",\n   427→                task.task_id, task.issue_ref\n   428→            )\n   429→        });\n   430→        let flow = task\n   431→            .resolved_flow\n   432→            .ok_or_else(|| AppError::RoutingResolutionFailed {\n   433→                input: task.task_id.clone(),\n   434→                details: \"task has no resolved flow\".to_owned(),\n   435→            })?;\n   436→        let name = task\n   437→            .project_name\n   438→            .clone()\n   439→            .unwrap_or_else(|| format!(\"Task {}\", task.issue_ref));\n   440→        let input = CreateProjectInput {\n   441→            id: project_id,\n   442→            name,\n   443→            flow,\n   444→            prompt_path: \"daemon\".to_owned(),\n   445→            prompt_contents: prompt_contents.clone(),\n   446→            prompt_hash: FileSystem::prompt_hash(&prompt_contents),\n   447→            created_at: Utc::now(),\n   448→        };\n   449→        create_project(self.project_store, self.journal_store, base_dir, input)?;\n   450→        Ok(())\n   451→    }\n   452→\n   453→    fn cleanup_active_leases(&self, base_dir: &Path) -> AppResult<()> {\n   454→        let leases = self.store.list_leases(base_dir)?;\n   455→        for lease in leases {\n   456→            let _ = DaemonTaskService::mark_aborted(self.store, base_dir, &lease.task_id);\n   457→            let _ = self.release_task_lease(base_dir, base_dir, &lease.task_id, &lease);\n   458→        }\n   459→        Ok(())\n   460→    }\n   461→\n   462→    fn handle_post_claim_failure(\n   463→        &self,\n   464→        base_dir: &Path,\n   465→        repo_root: &Path,\n   466→        task: &DaemonTask,\n   467→        lease: &crate::contexts::automation_runtime::model::WorktreeLease,\n   468→        error: &AppError,\n   469→    ) -> AppResult<()> {\n   470→        let latest_task = self.store.read_task(base_dir, &task.task_id)?;\n   471→        if latest_task.status == TaskStatus::Aborted {\n   472→            return self.release_task_lease(base_dir, repo_root, &task.task_id, lease);\n   473→        }\n   474→\n   475→        let failure_class = error\n   476→            .failure_class()\n   477→            .map(|class| class.as_str().to_owned())\n   478→            .unwrap_or_else(|| \"daemon_dispatch_failed\".to_owned());\n   479→        self.fail_claimed_task(\n   480→            base_dir,\n   481→            repo_root,\n   482→            &task.task_id,\n   483→            lease,\n   484→            &failure_class,\n   485→            &error.to_string(),\n   486→        )\n   487→    }\n   488→\n   489→    fn fail_claimed_task(\n   490→        &self,\n   491→        base_dir: &Path,\n   492→        repo_root: &Path,\n   493→        task_id: &str,\n   494→        lease: &crate::contexts::automation_runtime::model::WorktreeLease,\n   495→        failure_class: &str,\n   496→        failure_message: &str,\n   497→    ) -> AppResult<()> {\n   498→        let mark_result = DaemonTaskService::mark_failed(\n   499→            self.store,\n   500→            base_dir,\n   501→            task_id,\n   502→            failure_class,\n   503→            failure_message,\n   504→        )\n   505→        .map(|_| ());\n   506→        let cleanup_result = self.release_task_lease(base_dir, repo_root, task_id, lease);\n   507→\n   508→        match (mark_result, cleanup_result) {\n   509→            (Ok(()), Ok(())) => Ok(()),\n   510→            (Err(error), Ok(())) => Err(error),\n   511→            (Ok(()), Err(error)) => Err(error),\n   512→            (Err(error), Err(_)) => Err(error),\n   513→        }\n   514→    }\n   515→\n   516→    fn release_task_lease(\n   517→        &self,\n   518→        base_dir: &Path,\n   519→        repo_root: &Path,\n   520→        task_id: &str,\n   521→        lease: &crate::contexts::automation_runtime::model::WorktreeLease,\n   522→    ) -> AppResult<()> {\n   523→        let release_result =\n   524→            LeaseService::release(self.store, self.worktree, base_dir, repo_root, lease);\n   525→        let clear_result =\n   526→            DaemonTaskService::clear_lease_reference(self.store, base_dir, task_id).map(|_| ());\n   527→\n   528→        match (release_result, clear_result) {\n   529→            (Ok(()), Ok(())) => Ok(()),\n   530→            (Err(error), Ok(())) => Err(error),\n   531→            (Ok(()), Err(error)) => Err(error),\n   532→            (Err(error), Err(_)) => Err(error),\n   533→        }\n   534→    }\n   535→}\n   536→\n   537→async fn wait_for_shutdown_signal() -> AppResult<()> {\n   538→    #[cfg(unix)]\n   539→    {\n   540→        let mut sigterm =\n   541→            tokio::signal::unix::signal(tokio::signal::unix::SignalKind::terminate())?;\n   542→        tokio::select! {\n   543→            _ = tokio::signal::ctrl_c() => Ok(()),\n   544→            _ = sigterm.recv() => Ok(()),\n   545→        }\n   546→    }\n   547→\n   548→    #[cfg(not(unix))]\n   549→    {\n   550→        tokio::signal::ctrl_c().await.map_err(AppError::from)\n   551→    }\n   552→}\n   553→"}]},"parent_tool_use_id":null,"session_id":"8dacb19c-9278-40df-b484-c803ec7bbb98","uuid":"01d92ac4-4fc8-49c2-8e33-91b63ec87dc0","tool_use_result":{"type":"text","file":{"filePath":"/root/new-ralph-burning/ralph-burning-rewrite/src/contexts/automation_runtime/daemon_loop.rs","content":"use std::path::Path;\nuse std::time::Duration;\n\nuse chrono::Utc;\n\nuse crate::adapters::fs::FileSystem;\nuse crate::contexts::agent_execution::model::CancellationToken;\nuse crate::contexts::agent_execution::service::{AgentExecutionPort, RawOutputPort};\nuse crate::contexts::agent_execution::session::SessionStorePort;\nuse crate::contexts::agent_execution::AgentExecutionService;\nuse crate::contexts::automation_runtime::lease_service::LeaseService;\nuse crate::contexts::automation_runtime::model::{DaemonTask, TaskStatus};\nuse crate::contexts::automation_runtime::routing::RoutingEngine;\nuse crate::contexts::automation_runtime::task_service::DaemonTaskService;\nuse crate::contexts::automation_runtime::{DaemonStorePort, WorktreePort};\nuse crate::contexts::project_run_record::model::RunStatus;\nuse crate::contexts::project_run_record::service::{\n    create_project, AmendmentQueuePort, ArtifactStorePort, JournalStorePort,\n    PayloadArtifactWritePort, ProjectStorePort, RunSnapshotPort, RunSnapshotWritePort,\n    RuntimeLogWritePort,\n};\nuse crate::contexts::project_run_record::CreateProjectInput;\nuse crate::contexts::workflow_composition::engine;\nuse crate::contexts::workflow_composition::retry_policy::RetryPolicy;\nuse crate::contexts::workspace_governance::config::EffectiveConfig;\nuse crate::shared::domain::{FlowPreset, ProjectId};\nuse crate::shared::error::{AppError, AppResult};\n\n#[derive(Debug, Clone, PartialEq, Eq)]\npub struct DaemonLoopConfig {\n    pub poll_interval: Duration,\n    pub lease_ttl: Duration,\n    pub heartbeat_interval: Duration,\n    pub single_iteration: bool,\n}\n\nimpl Default for DaemonLoopConfig {\n    fn default() -> Self {\n        Self {\n            poll_interval: Duration::from_secs(10),\n            lease_ttl: Duration::from_secs(300),\n            heartbeat_interval: Duration::from_secs(30),\n            single_iteration: false,\n        }\n    }\n}\n\npub struct DaemonLoop<'a, A, R, S> {\n    store: &'a dyn DaemonStorePort,\n    worktree: &'a dyn WorktreePort,\n    project_store: &'a dyn ProjectStorePort,\n    run_snapshot_read: &'a dyn RunSnapshotPort,\n    run_snapshot_write: &'a dyn RunSnapshotWritePort,\n    journal_store: &'a dyn JournalStorePort,\n    artifact_store: &'a dyn ArtifactStorePort,\n    artifact_write: &'a dyn PayloadArtifactWritePort,\n    log_write: &'a dyn RuntimeLogWritePort,\n    amendment_queue: &'a dyn AmendmentQueuePort,\n    agent_service: &'a AgentExecutionService<A, R, S>,\n    routing_engine: RoutingEngine,\n}\n\nimpl<'a, A, R, S> DaemonLoop<'a, A, R, S> {\n    #[allow(clippy::too_many_arguments)]\n    pub fn new(\n        store: &'a dyn DaemonStorePort,\n        worktree: &'a dyn WorktreePort,\n        project_store: &'a dyn ProjectStorePort,\n        run_snapshot_read: &'a dyn RunSnapshotPort,\n        run_snapshot_write: &'a dyn RunSnapshotWritePort,\n        journal_store: &'a dyn JournalStorePort,\n        artifact_store: &'a dyn ArtifactStorePort,\n        artifact_write: &'a dyn PayloadArtifactWritePort,\n        log_write: &'a dyn RuntimeLogWritePort,\n        amendment_queue: &'a dyn AmendmentQueuePort,\n        agent_service: &'a AgentExecutionService<A, R, S>,\n    ) -> Self {\n        Self {\n            store,\n            worktree,\n            project_store,\n            run_snapshot_read,\n            run_snapshot_write,\n            journal_store,\n            artifact_store,\n            artifact_write,\n            log_write,\n            amendment_queue,\n            agent_service,\n            routing_engine: RoutingEngine::new(),\n        }\n    }\n}\n\nimpl<A, R, S> DaemonLoop<'_, A, R, S>\nwhere\n    A: AgentExecutionPort,\n    R: RawOutputPort,\n    S: SessionStorePort,\n{\n    pub async fn run(&self, base_dir: &Path, config: &DaemonLoopConfig) -> AppResult<()> {\n        let shutdown = CancellationToken::new();\n        let shutdown_watcher = shutdown.clone();\n        tokio::spawn(async move {\n            let _ = wait_for_shutdown_signal().await;\n            shutdown_watcher.cancel();\n        });\n\n        loop {\n            if shutdown.is_cancelled() {\n                self.cleanup_active_leases(base_dir)?;\n                break;\n            }\n\n            let processed = self\n                .process_cycle(base_dir, config, shutdown.clone())\n                .await?;\n            if config.single_iteration {\n                break;\n            }\n\n            let _ = processed;\n            tokio::select! {\n                _ = shutdown.cancelled() => {\n                    self.cleanup_active_leases(base_dir)?;\n                    break;\n                }\n                _ = tokio::time::sleep(config.poll_interval) => {}\n            }\n        }\n\n        Ok(())\n    }\n\n    async fn process_cycle(\n        &self,\n        base_dir: &Path,\n        config: &DaemonLoopConfig,\n        shutdown: CancellationToken,\n    ) -> AppResult<bool> {\n        let pending_task = DaemonTaskService::list_tasks(self.store, base_dir)?\n            .into_iter()\n            .find(|task| task.status == TaskStatus::Pending);\n        let Some(task) = pending_task else {\n            return Ok(false);\n        };\n\n        self.process_task(base_dir, &task, config, shutdown).await?;\n        Ok(true)\n    }\n\n    async fn process_task(\n        &self,\n        base_dir: &Path,\n        task: &DaemonTask,\n        config: &DaemonLoopConfig,\n        shutdown: CancellationToken,\n    ) -> AppResult<()> {\n        let effective_config = EffectiveConfig::load(base_dir)?;\n        let default_flow = effective_config.default_flow();\n        let repo_root = base_dir;\n\n        let (claimed_task, lease) = match DaemonTaskService::claim_task(\n            self.store,\n            self.worktree,\n            &self.routing_engine,\n            base_dir,\n            repo_root,\n            &task.task_id,\n            default_flow,\n            config.lease_ttl.as_secs(),\n        ) {\n            Ok(value) => value,\n            Err(AppError::ProjectWriterLockHeld { .. }) => return Ok(()),\n            Err(error) => return Err(error),\n        };\n\n        println!(\"claimed task {}\", claimed_task.task_id);\n\n        if let Err(error) = self.worktree.rebase_onto_default_branch(\n            repo_root,\n            &lease.worktree_path,\n            &lease.branch_name,\n        ) {\n            let _ = self.fail_claimed_task(\n                base_dir,\n                repo_root,\n                &claimed_task.task_id,\n                &lease,\n                \"rebase_conflict\",\n                &error.to_string(),\n            );\n            println!(\"failed task {}: {}\", claimed_task.task_id, error);\n            return Ok(());\n        }\n\n        if let Err(error) = self.ensure_project(base_dir, &claimed_task) {\n            self.handle_post_claim_failure(base_dir, repo_root, &claimed_task, &lease, &error)?;\n            println!(\"failed task {}: {}\", claimed_task.task_id, error);\n            return Ok(());\n        }\n        let task_on_disk = self.store.read_task(base_dir, &claimed_task.task_id)?;\n        if task_on_disk.status == TaskStatus::Aborted {\n            let _ = self.release_task_lease(base_dir, repo_root, &task_on_disk.task_id, &lease);\n            return Ok(());\n        }\n\n        let active_task =\n            match DaemonTaskService::mark_active(self.store, base_dir, &claimed_task.task_id) {\n                Ok(task) => task,\n                Err(error) => {\n                    self.handle_post_claim_failure(\n                        base_dir,\n                        repo_root,\n                        &claimed_task,\n                        &lease,\n                        &error,\n                    )?;\n                    println!(\"failed task {}: {}\", claimed_task.task_id, error);\n                    return Ok(());\n                }\n            };\n        println!(\"active task {}\", active_task.task_id);\n\n        let task_cancel = CancellationToken::new();\n        let outcome = self\n            .drive_dispatch(\n                base_dir,\n                &active_task,\n                &lease,\n                &effective_config,\n                config,\n                shutdown,\n                task_cancel,\n            )\n            .await;\n\n        let latest_task = self.store.read_task(base_dir, &active_task.task_id)?;\n        if latest_task.status == TaskStatus::Aborted {\n            let _ = self.release_task_lease(base_dir, repo_root, &active_task.task_id, &lease);\n            return Ok(());\n        }\n\n        match outcome {\n            Ok(()) => {\n                let _ =\n                    DaemonTaskService::mark_completed(self.store, base_dir, &active_task.task_id)?;\n                let _ = self.release_task_lease(base_dir, repo_root, &active_task.task_id, &lease);\n                println!(\"completed task {}\", active_task.task_id);\n            }\n            Err(error) => {\n                let failure_class = error\n                    .failure_class()\n                    .map(|class| class.as_str().to_owned())\n                    .unwrap_or_else(|| \"daemon_dispatch_failed\".to_owned());\n                let _ = DaemonTaskService::mark_failed(\n                    self.store,\n                    base_dir,\n                    &active_task.task_id,\n                    &failure_class,\n                    &error.to_string(),\n                )?;\n                let _ = self.release_task_lease(base_dir, repo_root, &active_task.task_id, &lease);\n                println!(\"failed task {}: {}\", active_task.task_id, error);\n            }\n        }\n\n        Ok(())\n    }\n\n    async fn drive_dispatch(\n        &self,\n        base_dir: &Path,\n        task: &DaemonTask,\n        lease: &crate::contexts::automation_runtime::model::WorktreeLease,\n        effective_config: &EffectiveConfig,\n        config: &DaemonLoopConfig,\n        shutdown: CancellationToken,\n        task_cancel: CancellationToken,\n    ) -> AppResult<()> {\n        let project_id = ProjectId::new(task.project_id.clone())?;\n        let flow = task\n            .resolved_flow\n            .ok_or_else(|| AppError::RoutingResolutionFailed {\n                input: task.task_id.clone(),\n                details: \"task has no resolved flow\".to_owned(),\n            })?;\n\n        let run_snapshot = self\n            .run_snapshot_read\n            .read_run_snapshot(base_dir, &project_id)?;\n        let dispatch_future = self.dispatch_in_worktree(\n            base_dir,\n            &project_id,\n            flow,\n            run_snapshot.status,\n            effective_config,\n            &lease.worktree_path,\n            task_cancel.clone(),\n        );\n        tokio::pin!(dispatch_future);\n\n        let heartbeat_interval = config.heartbeat_interval.max(Duration::from_secs(1));\n        let mut heartbeat = tokio::time::interval(heartbeat_interval);\n        let mut abort_poll = tokio::time::interval(Duration::from_millis(250));\n\n        loop {\n            tokio::select! {\n                result = &mut dispatch_future => break result,\n                _ = heartbeat.tick() => {\n                    let _ = LeaseService::heartbeat(self.store, base_dir, &lease.lease_id);\n                }\n                _ = abort_poll.tick() => {\n                    let current = self.store.read_task(base_dir, &task.task_id)?;\n                    if current.status == TaskStatus::Aborted {\n                        task_cancel.cancel();\n                    }\n                }\n                _ = shutdown.cancelled() => {\n                    let _ = DaemonTaskService::mark_aborted(self.store, base_dir, &task.task_id);\n                    task_cancel.cancel();\n                }\n            }\n        }\n    }\n\n    async fn dispatch_in_worktree(\n        &self,\n        base_dir: &Path,\n        project_id: &ProjectId,\n        flow: FlowPreset,\n        run_status: RunStatus,\n        effective_config: &EffectiveConfig,\n        worktree_path: &Path,\n        cancellation_token: CancellationToken,\n    ) -> AppResult<()> {\n        let original_dir = std::env::current_dir()?;\n        std::env::set_current_dir(worktree_path)?;\n\n        let result = match run_status {\n            RunStatus::NotStarted => {\n                engine::execute_run_with_retry(\n                    self.agent_service,\n                    self.run_snapshot_read,\n                    self.run_snapshot_write,\n                    self.journal_store,\n                    self.artifact_write,\n                    self.log_write,\n                    self.amendment_queue,\n                    base_dir,\n                    project_id,\n                    flow,\n                    effective_config,\n                    &RetryPolicy::default_policy(),\n                    cancellation_token,\n                )\n                .await\n            }\n            RunStatus::Failed | RunStatus::Paused => {\n                engine::resume_run_with_retry(\n                    self.agent_service,\n                    self.run_snapshot_read,\n                    self.run_snapshot_write,\n                    self.journal_store,\n                    self.artifact_store,\n                    self.artifact_write,\n                    self.log_write,\n                    self.amendment_queue,\n                    base_dir,\n                    project_id,\n                    flow,\n                    effective_config,\n                    &RetryPolicy::default_policy(),\n                    cancellation_token,\n                )\n                .await\n            }\n            RunStatus::Running => Err(AppError::TaskStateTransitionInvalid {\n                task_id: project_id.to_string(),\n                from: \"run_running\".to_owned(),\n                to: \"daemon_dispatch\".to_owned(),\n            }),\n            RunStatus::Completed => Err(AppError::TaskStateTransitionInvalid {\n                task_id: project_id.to_string(),\n                from: \"run_completed\".to_owned(),\n                to: \"daemon_dispatch\".to_owned(),\n            }),\n        };\n\n        let reset_result = std::env::set_current_dir(original_dir);\n        match (result, reset_result) {\n            (Ok(()), Ok(())) => Ok(()),\n            (Err(error), Ok(())) => Err(error),\n            (Ok(()), Err(error)) => Err(error.into()),\n            (Err(error), Err(_)) => Err(error),\n        }\n    }\n\n    fn ensure_project(&self, base_dir: &Path, task: &DaemonTask) -> AppResult<()> {\n        let project_id = ProjectId::new(task.project_id.clone())?;\n        if self.project_store.project_exists(base_dir, &project_id)? {\n            let record = self\n                .project_store\n                .read_project_record(base_dir, &project_id)?;\n            let flow = task\n                .resolved_flow\n                .ok_or_else(|| AppError::RoutingResolutionFailed {\n                    input: task.task_id.clone(),\n                    details: \"task has no resolved flow\".to_owned(),\n                })?;\n            if record.flow != flow {\n                return Err(AppError::RoutingResolutionFailed {\n                    input: task.task_id.clone(),\n                    details: format!(\n                        \"existing project flow '{}' does not match routed flow '{}'\",\n                        record.flow.as_str(),\n                        flow.as_str()\n                    ),\n                });\n            }\n            return Ok(());\n        }\n\n        let prompt_contents = task.prompt.clone().unwrap_or_else(|| {\n            format!(\n                \"# Automated task {}\\n\\nIssue: {}\\n\",\n                task.task_id, task.issue_ref\n            )\n        });\n        let flow = task\n            .resolved_flow\n            .ok_or_else(|| AppError::RoutingResolutionFailed {\n                input: task.task_id.clone(),\n                details: \"task has no resolved flow\".to_owned(),\n            })?;\n        let name = task\n            .project_name\n            .clone()\n            .unwrap_or_else(|| format!(\"Task {}\", task.issue_ref));\n        let input = CreateProjectInput {\n            id: project_id,\n            name,\n            flow,\n            prompt_path: \"daemon\".to_owned(),\n            prompt_contents: prompt_contents.clone(),\n            prompt_hash: FileSystem::prompt_hash(&prompt_contents),\n            created_at: Utc::now(),\n        };\n        create_project(self.project_store, self.journal_store, base_dir, input)?;\n        Ok(())\n    }\n\n    fn cleanup_active_leases(&self, base_dir: &Path) -> AppResult<()> {\n        let leases = self.store.list_leases(base_dir)?;\n        for lease in leases {\n            let _ = DaemonTaskService::mark_aborted(self.store, base_dir, &lease.task_id);\n            let _ = self.release_task_lease(base_dir, base_dir, &lease.task_id, &lease);\n        }\n        Ok(())\n    }\n\n    fn handle_post_claim_failure(\n        &self,\n        base_dir: &Path,\n        repo_root: &Path,\n        task: &DaemonTask,\n        lease: &crate::contexts::automation_runtime::model::WorktreeLease,\n        error: &AppError,\n    ) -> AppResult<()> {\n        let latest_task = self.store.read_task(base_dir, &task.task_id)?;\n        if latest_task.status == TaskStatus::Aborted {\n            return self.release_task_lease(base_dir, repo_root, &task.task_id, lease);\n        }\n\n        let failure_class = error\n            .failure_class()\n            .map(|class| class.as_str().to_owned())\n            .unwrap_or_else(|| \"daemon_dispatch_failed\".to_owned());\n        self.fail_claimed_task(\n            base_dir,\n            repo_root,\n            &task.task_id,\n            lease,\n            &failure_class,\n            &error.to_string(),\n        )\n    }\n\n    fn fail_claimed_task(\n        &self,\n        base_dir: &Path,\n        repo_root: &Path,\n        task_id: &str,\n        lease: &crate::contexts::automation_runtime::model::WorktreeLease,\n        failure_class: &str,\n        failure_message: &str,\n    ) -> AppResult<()> {\n        let mark_result = DaemonTaskService::mark_failed(\n            self.store,\n            base_dir,\n            task_id,\n            failure_class,\n            failure_message,\n        )\n        .map(|_| ());\n        let cleanup_result = self.release_task_lease(base_dir, repo_root, task_id, lease);\n\n        match (mark_result, cleanup_result) {\n            (Ok(()), Ok(())) => Ok(()),\n            (Err(error), Ok(())) => Err(error),\n            (Ok(()), Err(error)) => Err(error),\n            (Err(error), Err(_)) => Err(error),\n        }\n    }\n\n    fn release_task_lease(\n        &self,\n        base_dir: &Path,\n        repo_root: &Path,\n        task_id: &str,\n        lease: &crate::contexts::automation_runtime::model::WorktreeLease,\n    ) -> AppResult<()> {\n        let release_result =\n            LeaseService::release(self.store, self.worktree, base_dir, repo_root, lease);\n        let clear_result =\n            DaemonTaskService::clear_lease_reference(self.store, base_dir, task_id).map(|_| ());\n\n        match (release_result, clear_result) {\n            (Ok(()), Ok(())) => Ok(()),\n            (Err(error), Ok(())) => Err(error),\n            (Ok(()), Err(error)) => Err(error),\n            (Err(error), Err(_)) => Err(error),\n        }\n    }\n}\n\nasync fn wait_for_shutdown_signal() -> AppResult<()> {\n    #[cfg(unix)]\n    {\n        let mut sigterm =\n            tokio::signal::unix::signal(tokio::signal::unix::SignalKind::terminate())?;\n        tokio::select! {\n            _ = tokio::signal::ctrl_c() => Ok(()),\n            _ = sigterm.recv() => Ok(()),\n        }\n    }\n\n    #[cfg(not(unix))]\n    {\n        tokio::signal::ctrl_c().await.map_err(AppError::from)\n    }\n}\n","numLines":553,"startLine":1,"totalLines":553}}}
