      \"summary\": \"Fix formatting\",\n  1939→                        \"details\": \"Update code formatting to match style guide.\"\n  1940→                    }\n  1941→                ]\n  1942→            }\n  1943→        });\n  1944→        let overrides_str = overrides.to_string();\n  1945→\n  1946→        let out = run_cli_with_env(\n  1947→            &[\"run\", \"start\"],\n  1948→            ws.path(),\n  1949→            &[(\"RALPH_BURNING_TEST_STAGE_OVERRIDES\", &overrides_str)],\n  1950→        )?;\n  1951→        assert_success(&out)?;\n  1952→\n  1953→        // Verify journal contains amendment_queued and completion_round_advanced events\n  1954→        let events = read_journal(&ws, \"cr-alpha\")?;\n  1955→        let types = journal_event_types(&events);\n  1956→        if !types.iter().any(|t| t == \"amendment_queued\") {\n  1957→            return Err(\"journal missing 'amendment_queued' event\".into());\n  1958→        }\n  1959→        if !types.iter().any(|t| t == \"completion_round_advanced\") {\n  1960→            return Err(\"journal missing 'completion_round_advanced' event\".into());\n  1961→        }\n  1962→\n  1963→        // Verify planning stage was entered a second time (restart from planning)\n  1964→        let planning_entered_count = events\n  1965→            .iter()\n  1966→            .filter(|e| {\n  1967→                e.get(\"event_type\").and_then(|v| v.as_str()) == Some(\"stage_entered\")\n  1968→                    && e.get(\"details\")\n  1969→                        .and_then(|d| d.get(\"stage_id\"))\n  1970→                        .and_then(|v| v.as_str())\n  1971→                        == Some(\"planning\")\n  1972→            })\n  1973→            .count();\n  1974→        if planning_entered_count < 2 {\n  1975→            return Err(format!(\n  1976→                \"expected planning stage_entered >= 2 times, got {planning_entered_count}\"\n  1977→            ));\n  1978→        }\n  1979→\n  1980→        //