   approved_validation_payload(),\n2170:    let pid = create_standard_project(base_dir, \"guard-resume\");\n2244:    let resume_result = engine::resume_standard_run(\n2294:    let pid = create_standard_project(base_dir, \"fr-cond\");\n2298:            .with_stage_payload_sequence(\n2302:                    approved_validation_payload(),\n2386:    let pid = create_standard_project(base_dir, \"fr-reqch\");\n2390:            .with_stage_payload_sequence(\n2394:                    approved_validation_payload(),\n","exit_code":0,"status":"completed"}}
