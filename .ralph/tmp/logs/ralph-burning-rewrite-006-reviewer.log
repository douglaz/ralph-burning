{"type":"item.completed","item":{"id":"item_7","type":"command_execution","command":"/run/current-system/sw/bin/bash -lc \"nl -ba src/contexts/workflow_composition/engine.rs | sed -n '1,260p'\"","aggregated_output":"     1\tuse std::path::{Path, PathBuf};\n     2\tuse std::time::Duration;\n     3\t\n     4\tuse chrono::Utc;\n     5\t\n     6\tuse crate::contexts::agent_execution::model::{\n     7\t    CancellationToken, InvocationPayload, InvocationRequest,\n     8\t};\n     9\tuse crate::contexts::agent_execution::service::{\n    10\t    AgentExecutionPort, BackendSelectionConfig, RawOutputPort,\n    11\t};\n    12\tuse crate::contexts::agent_execution::session::SessionStorePort;\n    13\tuse crate::contexts::agent_execution::AgentExecutionService;\n    14\tuse crate::contexts::project_run_record::journal;\n    15\tuse crate::contexts::project_run_record::model::{\n    16\t    ActiveRun, ArtifactRecord, LogLevel, PayloadRecord, RunSnapshot, RunStatus, RuntimeLogEntry,\n    17\t};\n    18\tuse crate::contexts::project_run_record::service::{\n    19\t    JournalStorePort, PayloadArtifactWritePort, RunSnapshotPort, RunSnapshotWritePort,\n    20\t    RuntimeLogWritePort,\n    21\t};\n    22\tuse crate::contexts::workspace_governance::config::EffectiveConfig;\n    23\tuse crate::shared::domain::{\n    24\t    BackendRole, FlowPreset, ProjectId, ResolvedBackendTarget, RunId, SessionPolicy, StageCursor,\n    25\t    StageId,\n    26\t};\n    27\tuse crate::shared::error::{AppError, AppResult};\n    28\t\n    29\tuse super::contracts;\n    30\t\n    31\t/// Derives the executable stage plan for the standard flow given prompt_review config.\n    32\tpub fn standard_stage_plan(prompt_review_enabled: bool) -> Vec<StageId> {\n    33\t    let flow_def = super::flow_definition(FlowPreset::Standard);\n    34\t    if prompt_review_enabled {\n    35\t        flow_def.stages.to_vec()\n    36\t    } else {\n    37\t        flow_def\n    38\t            .stages\n    39\t            .iter()\n    40\t            .copied()\n    41\t            .filter(|s| *s != StageId::PromptReview)\n    42\t            .collect()\n    43\t    }\n    44\t}\n    45\t\n    46\t/// Deterministic stage-to-role mapping per spec.\n    47\tpub fn role_for_stage(stage_id: StageId) -> BackendRole {\n    48\t    BackendRole::for_stage(stage_id)\n    49\t}\n    50\t\n    51\t/// Resolved target per stage for preflight.\n    52\tpub struct StagePlan {\n    53\t    pub stage_id: StageId,\n    54\t    pub role: BackendRole,\n    55\t    pub contract: contracts::StageContract,\n    56\t    pub target: ResolvedBackendTarget,\n    57\t}\n    58\t\n    59\t/// Resolve all stage targets ahead of execution for preflight validation.\n    60\tpub fn resolve_stage_plan(\n    61\t    stages: &[StageId],\n    62\t    resolver: &crate::contexts::agent_execution::service::BackendResolver,\n    63\t    workspace_defaults: Option<&BackendSelectionConfig>,\n    64\t) -> AppResult<Vec<StagePlan>> {\n    65\t    let mut plan = Vec::with_capacity(stages.len());\n    66\t    for &stage_id in stages {\n    67\t        let role = role_for_stage(stage_id);\n    68\t        let contract = contracts::contract_for_stage(stage_id);\n    69\t        let target = resolver.resolve(role, None, None, workspace_defaults)?;\n    70\t        plan.push(StagePlan {\n    71\t            stage_id,\n    72\t            role,\n    73\t            contract,\n    74\t            target,\n    75\t        });\n    76\t    }\n    77\t    Ok(plan)\n    78\t}\n    79\t\n    80\t/// Preflight: check capability and availability for every stage target.\n    81\tpub async fn preflight_check<A: AgentExecutionPort>(\n    82\t    adapter: &A,\n    83\t    plan: &[StagePlan],\n    84\t) -> AppResult<()> {\n    85\t    for entry in plan {\n    86\t        adapter\n    87\t            .check_capability(&entry.target, &entry.contract)\n    88\t            .await\n    89\t            .map_err(|e| AppError::PreflightFailed {\n    90\t                stage_id: entry.stage_id,\n    91\t                details: e.to_string(),\n    92\t            })?;\n    93\t        adapter\n    94\t            .check_availability(&entry.target)\n    95\t            .await\n    96\t            .map_err(|e| AppError::PreflightFailed {\n    97\t                stage_id: entry.stage_id,\n    98\t                details: e.to_string(),\n    99\t            })?;\n   100\t    }\n   101\t    Ok(())\n   102\t}\n   103\t\n   104\t/// Generate a new run ID from a timestamp.\n   105\tfn generate_run_id() -> AppResult<RunId> {\n   106\t    let now = Utc::now();\n   107\t    RunId::new(format!(\"run-{}\", now.format(\"%Y%m%d%H%M%S\")))\n   108\t}\n   109\t\n   110\t/// The standard-flow orchestration engine.\n   111\t///\n   112\t/// Executes all enabled standard stages in canonical order against the provided\n   113\t/// backend adapter, persisting validated payloads and rendered artifacts at\n   114\t/// durable stage boundaries.\n   115\t#[allow(clippy::too_many_arguments)]\n   116\tpub async fn execute_standard_run<A, R, S>(\n   117\t    agent_service: &AgentExecutionService<A, R, S>,\n   118\t    run_snapshot_read: &dyn RunSnapshotPort,\n   119\t    run_snapshot_write: &dyn RunSnapshotWritePort,\n   120\t    journal_store: &dyn JournalStorePort,\n   121\t    artifact_write: &dyn PayloadArtifactWritePort,\n   122\t    log_write: &dyn RuntimeLogWritePort,\n   123\t    base_dir: &Path,\n   124\t    project_id: &ProjectId,\n   125\t    effective_config: &EffectiveConfig,\n   126\t) -> AppResult<()>\n   127\twhere\n   128\t    A: AgentExecutionPort,\n   129\t    R: RawOutputPort,\n   130\t    S: SessionStorePort,\n   131\t{\n   132\t    // 1. Read current snapshot and validate preconditions\n   133\t    let snapshot = run_snapshot_read.read_run_snapshot(base_dir, project_id)?;\n   134\t\n   135\t    if snapshot.status != RunStatus::NotStarted {\n   136\t        return Err(AppError::RunStartFailed {\n   137\t            reason: format!(\n   138\t                \"project snapshot status is '{}'; run start requires 'not_started'\",\n   139\t                snapshot.status\n   140\t            ),\n   141\t        });\n   142\t    }\n   143\t    if snapshot.has_active_run() {\n   144\t        return Err(AppError::RunStartFailed {\n   145\t            reason: \"project already has an active run\".to_owned(),\n   146\t        });\n   147\t    }\n   148\t\n   149\t    // 2. Derive the stage plan\n   150\t    let prompt_review_enabled = effective_config.prompt_review_enabled();\n   151\t    let stages = standard_stage_plan(prompt_review_enabled);\n   152\t\n   153\t    // 3. Resolve backend targets for every stage\n   154\t    let workspace_defaults = BackendSelectionConfig::from_effective_config(effective_config)?;\n   155\t    let stage_plan = resolve_stage_plan(\n   156\t        stages.as_slice(),\n   157\t        agent_service.resolver(),\n   158\t        Some(&workspace_defaults),\n   159\t    )?;\n   160\t\n   161\t    // 4. Preflight checks — if any fail, leave all state unchanged\n   162\t    preflight_check(agent_service.adapter(), &stage_plan).await?;\n   163\t\n   164\t    // 5. Generate run ID and read journal for sequence tracking\n   165\t    let run_id = generate_run_id()?;\n   166\t    let now = Utc::now();\n   167\t    let events = journal_store.read_journal(base_dir, project_id)?;\n   168\t    let mut seq = journal::last_sequence(&events);\n   169\t\n   170\t    let first_stage = stage_plan[0].stage_id;\n   171\t\n   172\t    // 6. Persist run_started: write run.json with running status FIRST, then journal events.\n   173\t    // The snapshot must be durable before journal events become visible.\n   174\t    let initial_cursor = StageCursor::initial(first_stage);\n   175\t    let mut current_snapshot = RunSnapshot {\n   176\t        active_run: Some(ActiveRun {\n   177\t            run_id: run_id.as_str().to_owned(),\n   178\t            stage_cursor: initial_cursor.clone(),\n   179\t            started_at: now,\n   180\t        }),\n   181\t        status: RunStatus::Running,\n   182\t        cycle_history: vec![],\n   183\t        completion_rounds: 1,\n   184\t        rollback_point_meta: snapshot.rollback_point_meta.clone(),\n   185\t        amendment_queue: snapshot.amendment_queue.clone(),\n   186\t        status_summary: format!(\"running: {}\", first_stage.display_name()),\n   187\t    };\n   188\t    run_snapshot_write.write_run_snapshot(base_dir, project_id, &current_snapshot)?;\n   189\t\n   190\t    seq += 1;\n   191\t    let run_started = journal::run_started_event(seq, now, &run_id, first_stage);\n   192\t    let run_started_line = journal::serialize_event(&run_started)?;\n   193\t    if let Err(e) = journal_store.append_event(base_dir, project_id, &run_started_line) {\n   194\t        seq -= 1; // event was not persisted\n   195\t        return fail_run(\n   196\t            &AppError::RunStartFailed {\n   197\t                reason: format!(\"failed to persist run_started event: {}\", e),\n   198\t            },\n   199\t            first_stage,\n   200\t            &run_id,\n   201\t            &mut seq,\n   202\t            &mut current_snapshot,\n   203\t            journal_store,\n   204\t            run_snapshot_write,\n   205\t            base_dir,\n   206\t            project_id,\n   207\t        )\n   208\t        .await;\n   209\t    }\n   210\t\n   211\t    let project_root = project_root_path(base_dir, project_id);\n   212\t\n   213\t    // 7. Execute stages in order\n   214\t    for (idx, stage_entry) in stage_plan.iter().enumerate() {\n   215\t        let stage_id = stage_entry.stage_id;\n   216\t        let cursor = StageCursor::initial(stage_id);\n   217\t\n   218\t        // Emit stage_entered — if journal append fails after run_started,\n   219\t        // the run must persist failed state at this stage boundary.\n   220\t        seq += 1;\n   221\t        let stage_entered = journal::stage_entered_event(\n   222\t            seq,\n   223\t            Utc::now(),\n   224\t            &run_id,\n   225\t            stage_id,\n   226\t            cursor.cycle,\n   227\t            cursor.attempt,\n   228\t        );\n   229\t        let stage_entered_line = journal::serialize_event(&stage_entered)?;\n   230\t        if let Err(e) = journal_store.append_event(base_dir, project_id, &stage_entered_line) {\n   231\t            seq -= 1; // event was not persisted\n   232\t            return fail_run(\n   233\t                &AppError::RunStartFailed {\n   234\t                    reason: format!(\n   235\t                        \"failed to persist stage_entered event for {}: {}\",\n   236\t                        stage_id.as_str(),\n   237\t                        e\n   238\t                    ),\n   239\t                },\n   240\t                stage_id,\n   241\t                &run_id,\n   242\t                &mut seq,\n   243\t                &mut current_snapshot,\n   244\t                journal_store,\n   245\t                run_snapshot_write,\n   246\t                base_dir,\n   247\t                project_id,\n   248\t            )\n   249\t            .await;\n   250\t        }\n   251\t\n   252\t        // Update cursor in snapshot — if this fails after stage_entered,\n   253\t        // the run must persist failed state at this stage boundary.\n   254\t        current_snapshot.active_run.as_mut().unwrap().stage_cursor = cursor.clone();\n   255\t        current_snapshot.status_summary = format!(\"running: {}\", stage_id.display_name());\n   256\t        if let Err(e) =\n   257\t            run_snapshot_write.write_run_snapshot(base_dir, project_id, &current_snapshot)\n   258\t        {\n   259\t            return fail_run(\n   260\t                &AppError::RunStartFailed {\n","exit_code":0,"status":"completed"}}
