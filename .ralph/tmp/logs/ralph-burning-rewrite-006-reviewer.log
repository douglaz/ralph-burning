failed state. Since the failing store only fails\n   560\t    // on call 3, the fail_run recovery can still write the failed snapshot\n   561\t    // (calls 4+).\n   562\t    let snapshot = FsRunSnapshotStore.read_run_snapshot(base_dir, &pid).unwrap();\n   563\t    assert_eq!(snapshot.status, RunStatus::Failed);\n   564\t    assert!(snapshot.active_run.is_none());\n   565\t\n   566\t    // No payload/artifact should be visible for the first stage\n   567\t    let payloads_dir = base_dir\n   568\t        .join(\".ralph-burning/projects/snap-fail/history/payloads\");\n   569\t    let payload_count = fs::read_dir(&payloads_dir).unwrap().count();\n   570\t    assert_eq!(payload_count, 0, \"payload should have been rolled back\");\n   571\t\n   572\t    let artifacts_dir = base_dir\n   573\t        .join(\".ralph-burning/projects/snap-fail/history/artifacts\");\n   574\t    let artifact_count = fs::read_dir(&artifacts_dir).unwrap().count();\n   575\t    assert_eq!(artifact_count, 0, \"artifact should have been rolled back\");\n","exit_code":0,"status":"completed"}}
