{"type":"item.completed","item":{"id":"item_10","type":"command_execution","command":"/run/current-system/sw/bin/bash -lc \"nl -ba ralph-burning-rewrite/src/contexts/project_run_record/model.rs | sed -n '1,360p'\"","aggregated_output":"     1\tuse chrono::{DateTime, Utc};\n     2\tuse serde::{Deserialize, Serialize};\n     3\t\n     4\tuse crate::shared::domain::{FlowPreset, ProjectId, StageCursor, StageId};\n     5\t\n     6\t/// Immutable project metadata persisted in `project.toml`.\n     7\t#[derive(Debug, Clone, PartialEq, Serialize, Deserialize)]\n     8\tpub struct ProjectRecord {\n     9\t    pub id: ProjectId,\n    10\t    pub name: String,\n    11\t    pub flow: FlowPreset,\n    12\t    pub prompt_reference: String,\n    13\t    pub prompt_hash: String,\n    14\t    pub created_at: DateTime<Utc>,\n    15\t    pub status_summary: ProjectStatusSummary,\n    16\t}\n    17\t\n    18\t#[derive(Debug, Clone, Copy, PartialEq, Eq, Serialize, Deserialize)]\n    19\t#[serde(rename_all = \"snake_case\")]\n    20\tpub enum ProjectStatusSummary {\n    21\t    Created,\n    22\t    Active,\n    23\t    Completed,\n    24\t    Failed,\n    25\t}\n    26\t\n    27\t/// Canonical run state persisted in `run.json`.\n    28\t/// This is the single source of truth for run progression - never inferred from artifacts.\n    29\t#[derive(Debug, Clone, PartialEq, Serialize, Deserialize)]\n    30\tpub struct RunSnapshot {\n    31\t    pub active_run: Option<ActiveRun>,\n    32\t    pub status: RunStatus,\n    33\t    pub cycle_history: Vec<CycleHistoryEntry>,\n    34\t    pub completion_rounds: u32,\n    35\t    pub rollback_point_meta: RollbackPointMeta,\n    36\t    pub amendment_queue: AmendmentQueueState,\n    37\t    pub status_summary: String,\n    38\t}\n    39\t\n    40\timpl RunSnapshot {\n    41\t    pub fn initial() -> Self {\n    42\t        Self {\n    43\t            active_run: None,\n    44\t            status: RunStatus::NotStarted,\n    45\t            cycle_history: Vec::new(),\n    46\t            completion_rounds: 0,\n    47\t            rollback_point_meta: RollbackPointMeta::default(),\n    48\t            amendment_queue: AmendmentQueueState::default(),\n    49\t            status_summary: \"not started\".to_owned(),\n    50\t        }\n    51\t    }\n    52\t\n    53\t    pub fn has_active_run(&self) -> bool {\n    54\t        self.active_run.is_some()\n    55\t    }\n    56\t\n    57\t    /// Semantic validation of run snapshot consistency.\n    58\t    /// Returns `Err` with a description if status and active_run are inconsistent.\n    59\t    pub fn validate_semantics(&self) -> Result<(), String> {\n    60\t        match (&self.status, &self.active_run) {\n    61\t            // Running or Paused requires an active run cursor\n    62\t            (RunStatus::Running, None) => Err(\n    63\t                \"status is 'running' but active_run is null — inconsistent canonical state\"\n    64\t                    .to_owned(),\n    65\t            ),\n    66\t            (RunStatus::Paused, None) => Err(\n    67\t                \"status is 'paused' but active_run is null — inconsistent canonical state\"\n    68\t                    .to_owned(),\n    69\t            ),\n    70\t            // NotStarted must not have an active run cursor\n    71\t            (RunStatus::NotStarted, Some(_)) => Err(\n    72\t                \"status is 'not_started' but active_run is present — inconsistent canonical state\"\n    73\t                    .to_owned(),\n    74\t            ),\n    75\t            // All other combinations are valid:\n    76\t            // NotStarted + None, Running/Paused + Some, Completed/Failed + None/Some\n    77\t            _ => Ok(()),\n    78\t        }\n    79\t    }\n    80\t}\n    81\t\n    82\t#[derive(Debug, Clone, PartialEq, Serialize, Deserialize)]\n    83\tpub struct ActiveRun {\n    84\t    pub run_id: String,\n    85\t    pub stage_cursor: StageCursor,\n    86\t    pub started_at: DateTime<Utc>,\n    87\t}\n    88\t\n    89\t#[derive(Debug, Clone, Copy, PartialEq, Eq, Serialize, Deserialize)]\n    90\t#[serde(rename_all = \"snake_case\")]\n    91\tpub enum RunStatus {\n    92\t    NotStarted,\n    93\t    Running,\n    94\t    Paused,\n    95\t    Completed,\n    96\t    Failed,\n    97\t}\n    98\t\n    99\timpl RunStatus {\n   100\t    /// Human-readable status string for CLI output.\n   101\t    pub fn display_str(self) -> &'static str {\n   102\t        match self {\n   103\t            Self::NotStarted => \"not started\",\n   104\t            Self::Running => \"running\",\n   105\t            Self::Paused => \"paused\",\n   106\t            Self::Completed => \"completed\",\n   107\t            Self::Failed => \"failed\",\n   108\t        }\n   109\t    }\n   110\t}\n   111\t\n   112\timpl std::fmt::Display for RunStatus {\n   113\t    fn fmt(&self, f: &mut std::fmt::Formatter<'_>) -> std::fmt::Result {\n   114\t        f.write_str(self.display_str())\n   115\t    }\n   116\t}\n   117\t\n   118\t/// A single entry in the cycle history tracking progression through work cycles.\n   119\t#[derive(Debug, Clone, PartialEq, Serialize, Deserialize)]\n   120\tpub struct CycleHistoryEntry {\n   121\t    pub cycle: u32,\n   122\t    pub stage_id: StageId,\n   123\t    pub started_at: DateTime<Utc>,\n   124\t    pub completed_at: Option<DateTime<Utc>>,\n   125\t}\n   126\t\n   127\t/// Rollback-point metadata tracked in the canonical run snapshot.\n   128\t#[derive(Debug, Clone, Default, PartialEq, Serialize, Deserialize)]\n   129\tpub struct RollbackPointMeta {\n   130\t    pub last_rollback_id: Option<String>,\n   131\t    pub rollback_count: u32,\n   132\t}\n   133\t\n   134\t/// Amendment queue state tracked in the canonical run snapshot.\n   135\t#[derive(Debug, Clone, Default, PartialEq, Serialize, Deserialize)]\n   136\tpub struct AmendmentQueueState {\n   137\t    pub pending: Vec<serde_json::Value>,\n   138\t    pub processed_count: u32,\n   139\t}\n   140\t\n   141\t/// A single journal event stored in `journal.ndjson`.\n   142\t#[derive(Debug, Clone, PartialEq, Serialize, Deserialize)]\n   143\tpub struct JournalEvent {\n   144\t    pub sequence: u64,\n   145\t    pub timestamp: DateTime<Utc>,\n   146\t    pub event_type: JournalEventType,\n   147\t    pub details: serde_json::Value,\n   148\t}\n   149\t\n   150\t#[derive(Debug, Clone, PartialEq, Eq, Serialize, Deserialize)]\n   151\t#[serde(rename_all = \"snake_case\")]\n   152\tpub enum JournalEventType {\n   153\t    ProjectCreated,\n   154\t    RunStarted,\n   155\t    StageEntered,\n   156\t    StageCompleted,\n   157\t    CycleAdvanced,\n   158\t    CompletionRoundAdvanced,\n   159\t    RunCompleted,\n   160\t    RunFailed,\n   161\t    RollbackCreated,\n   162\t    AmendmentQueued,\n   163\t}\n   164\t\n   165\t/// A durable history payload record stored in `history/payloads/`.\n   166\t#[derive(Debug, Clone, PartialEq, Serialize, Deserialize)]\n   167\tpub struct PayloadRecord {\n   168\t    pub payload_id: String,\n   169\t    pub stage_id: StageId,\n   170\t    pub cycle: u32,\n   171\t    pub attempt: u32,\n   172\t    pub created_at: DateTime<Utc>,\n   173\t    pub payload: serde_json::Value,\n   174\t}\n   175\t\n   176\t/// A durable history artifact record stored in `history/artifacts/`.\n   177\t#[derive(Debug, Clone, PartialEq, Serialize, Deserialize)]\n   178\tpub struct ArtifactRecord {\n   179\t    pub artifact_id: String,\n   180\t    pub payload_id: String,\n   181\t    pub stage_id: StageId,\n   182\t    pub created_at: DateTime<Utc>,\n   183\t    pub content: String,\n   184\t}\n   185\t\n   186\t/// A runtime log entry stored in `runtime/logs/`.\n   187\t#[derive(Debug, Clone, PartialEq, Serialize, Deserialize)]\n   188\tpub struct RuntimeLogEntry {\n   189\t    pub timestamp: DateTime<Utc>,\n   190\t    pub level: LogLevel,\n   191\t    pub source: String,\n   192\t    pub message: String,\n   193\t}\n   194\t\n   195\t#[derive(Debug, Clone, Copy, PartialEq, Eq, Serialize, Deserialize)]\n   196\t#[serde(rename_all = \"snake_case\")]\n   197\tpub enum LogLevel {\n   198\t    Debug,\n   199\t    Info,\n   200\t    Warn,\n   201\t    Error,\n   202\t}\n   203\t\n   204\t/// Rollback metadata stored in `rollback/`.\n   205\t#[derive(Debug, Clone, PartialEq, Serialize, Deserialize)]\n   206\tpub struct RollbackPoint {\n   207\t    pub rollback_id: String,\n   208\t    pub created_at: DateTime<Utc>,\n   209\t    pub stage_id: StageId,\n   210\t    pub cycle: u32,\n   211\t    pub run_snapshot: RunSnapshot,\n   212\t}\n   213\t\n   214\t/// Empty session store for `sessions.json`.\n   215\t#[derive(Debug, Clone, PartialEq, Serialize, Deserialize)]\n   216\tpub struct SessionStore {\n   217\t    pub sessions: Vec<serde_json::Value>,\n   218\t}\n   219\t\n   220\timpl SessionStore {\n   221\t    pub fn empty() -> Self {\n   222\t        Self {\n   223\t            sessions: Vec::new(),\n   224\t        }\n   225\t    }\n   226\t}\n   227\t\n   228\t/// Summary of a failed stage for run snapshot persistence.\n   229\t#[derive(Debug, Clone, PartialEq, Serialize, Deserialize)]\n   230\tpub struct FailedStageSummary {\n   231\t    pub stage_id: StageId,\n   232\t    pub cycle: u32,\n   233\t    pub attempt: u32,\n   234\t    pub failure_class: String,\n   235\t    pub message: String,\n   236\t    pub failed_at: DateTime<Utc>,\n   237\t}\n   238\t\n   239\t/// Summary used in `project list` output.\n   240\t#[derive(Debug, Clone)]\n   241\tpub struct ProjectListEntry {\n   242\t    pub id: ProjectId,\n   243\t    pub name: String,\n   244\t    pub flow: FlowPreset,\n   245\t    pub status_summary: ProjectStatusSummary,\n   246\t    pub created_at: DateTime<Utc>,\n   247\t    pub is_active: bool,\n   248\t}\n   249\t\n   250\t/// Detailed project view used in `project show` output.\n   251\t#[derive(Debug, Clone)]\n   252\tpub struct ProjectDetail {\n   253\t    pub record: ProjectRecord,\n   254\t    pub run_snapshot: RunSnapshot,\n   255\t    pub journal_event_count: u64,\n   256\t    pub rollback_count: usize,\n   257\t    pub is_active: bool,\n   258\t}\n","exit_code":0,"status":"completed"}}
