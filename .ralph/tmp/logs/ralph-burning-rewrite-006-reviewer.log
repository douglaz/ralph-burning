{"type":"item.completed","item":{"id":"item_6","type":"command_execution","command":"/run/current-system/sw/bin/bash -lc \"nl -ba ralph-burning-rewrite/src/contexts/workflow_composition/engine.rs | sed -n '1,460p'\"","aggregated_output":"     1\tuse std::path::{Path, PathBuf};\n     2\tuse std::time::Duration;\n     3\t\n     4\tuse chrono::Utc;\n     5\t\n     6\tuse crate::contexts::agent_execution::model::{\n     7\t    CancellationToken, InvocationPayload, InvocationRequest,\n     8\t};\n     9\tuse crate::contexts::agent_execution::service::{\n    10\t    AgentExecutionPort, BackendSelectionConfig, RawOutputPort,\n    11\t};\n    12\tuse crate::contexts::agent_execution::session::SessionStorePort;\n    13\tuse crate::contexts::agent_execution::AgentExecutionService;\n    14\tuse crate::contexts::project_run_record::journal;\n    15\tuse crate::contexts::project_run_record::model::{\n    16\t    ActiveRun, ArtifactRecord, LogLevel, PayloadRecord, RunSnapshot, RunStatus, RuntimeLogEntry,\n    17\t};\n    18\tuse crate::contexts::project_run_record::service::{\n    19\t    JournalStorePort, PayloadArtifactWritePort, RunSnapshotPort, RunSnapshotWritePort,\n    20\t    RuntimeLogWritePort,\n    21\t};\n    22\tuse crate::contexts::workspace_governance::config::EffectiveConfig;\n    23\tuse crate::shared::domain::{\n    24\t    BackendRole, FlowPreset, ProjectId, ResolvedBackendTarget, RunId, SessionPolicy, StageCursor,\n    25\t    StageId,\n    26\t};\n    27\tuse crate::shared::error::{AppError, AppResult};\n    28\t\n    29\tuse super::contracts;\n    30\t\n    31\t/// Derives the executable stage plan for the standard flow given prompt_review config.\n    32\tpub fn standard_stage_plan(prompt_review_enabled: bool) -> Vec<StageId> {\n    33\t    let flow_def = super::flow_definition(FlowPreset::Standard);\n    34\t    if prompt_review_enabled {\n    35\t        flow_def.stages.to_vec()\n    36\t    } else {\n    37\t        flow_def\n    38\t            .stages\n    39\t            .iter()\n    40\t            .copied()\n    41\t            .filter(|s| *s != StageId::PromptReview)\n    42\t            .collect()\n    43\t    }\n    44\t}\n    45\t\n    46\t/// Deterministic stage-to-role mapping per spec.\n    47\tpub fn role_for_stage(stage_id: StageId) -> BackendRole {\n    48\t    BackendRole::for_stage(stage_id)\n    49\t}\n    50\t\n    51\t/// Resolved target per stage for preflight.\n    52\tpub struct StagePlan {\n    53\t    pub stage_id: StageId,\n    54\t    pub role: BackendRole,\n    55\t    pub contract: contracts::StageContract,\n    56\t    pub target: ResolvedBackendTarget,\n    57\t}\n    58\t\n    59\t/// Resolve all stage targets ahead of execution for preflight validation.\n    60\tpub fn resolve_stage_plan(\n    61\t    stages: &[StageId],\n    62\t    resolver: &crate::contexts::agent_execution::service::BackendResolver,\n    63\t    workspace_defaults: Option<&BackendSelectionConfig>,\n    64\t) -> AppResult<Vec<StagePlan>> {\n    65\t    let mut plan = Vec::with_capacity(stages.len());\n    66\t    for &stage_id in stages {\n    67\t        let role = role_for_stage(stage_id);\n    68\t        let contract = contracts::contract_for_stage(stage_id);\n    69\t        let target = resolver.resolve(role, None, None, workspace_defaults)?;\n    70\t        plan.push(StagePlan {\n    71\t            stage_id,\n    72\t            role,\n    73\t            contract,\n    74\t            target,\n    75\t        });\n    76\t    }\n    77\t    Ok(plan)\n    78\t}\n    79\t\n    80\t/// Preflight: check capability and availability for every stage target.\n    81\tpub async fn preflight_check<A: AgentExecutionPort>(\n    82\t    adapter: &A,\n    83\t    plan: &[StagePlan],\n    84\t) -> AppResult<()> {\n    85\t    for entry in plan {\n    86\t        adapter\n    87\t            .check_capability(&entry.target, &entry.contract)\n    88\t            .await\n    89\t            .map_err(|e| AppError::PreflightFailed {\n    90\t                stage_id: entry.stage_id,\n    91\t                details: e.to_string(),\n    92\t            })?;\n    93\t        adapter\n    94\t            .check_availability(&entry.target)\n    95\t            .await\n    96\t            .map_err(|e| AppError::PreflightFailed {\n    97\t                stage_id: entry.stage_id,\n    98\t                details: e.to_string(),\n    99\t            })?;\n   100\t    }\n   101\t    Ok(())\n   102\t}\n   103\t\n   104\t/// Generate a new run ID from a timestamp.\n   105\tfn generate_run_id() -> AppResult<RunId> {\n   106\t    let now = Utc::now();\n   107\t    RunId::new(format!(\"run-{}\", now.format(\"%Y%m%d%H%M%S\")))\n   108\t}\n   109\t\n   110\t/// The standard-flow orchestration engine.\n   111\t///\n   112\t/// Executes all enabled standard stages in canonical order against the provided\n   113\t/// backend adapter, persisting validated payloads and rendered artifacts at\n   114\t/// durable stage boundaries.\n   115\t#[allow(clippy::too_many_arguments)]\n   116\tpub async fn execute_standard_run<A, R, S>(\n   117\t    agent_service: &AgentExecutionService<A, R, S>,\n   118\t    run_snapshot_read: &dyn RunSnapshotPort,\n   119\t    run_snapshot_write: &dyn RunSnapshotWritePort,\n   120\t    journal_store: &dyn JournalStorePort,\n   121\t    artifact_write: &dyn PayloadArtifactWritePort,\n   122\t    log_write: &dyn RuntimeLogWritePort,\n   123\t    base_dir: &Path,\n   124\t    project_id: &ProjectId,\n   125\t    effective_config: &EffectiveConfig,\n   126\t) -> AppResult<()>\n   127\twhere\n   128\t    A: AgentExecutionPort,\n   129\t    R: RawOutputPort,\n   130\t    S: SessionStorePort,\n   131\t{\n   132\t    // 1. Read current snapshot and validate preconditions\n   133\t    let snapshot = run_snapshot_read.read_run_snapshot(base_dir, project_id)?;\n   134\t\n   135\t    if snapshot.status != RunStatus::NotStarted {\n   136\t        return Err(AppError::RunStartFailed {\n   137\t            reason: format!(\n   138\t                \"project snapshot status is '{}'; run start requires 'not_started'\",\n   139\t                snapshot.status\n   140\t            ),\n   141\t        });\n   142\t    }\n   143\t    if snapshot.has_active_run() {\n   144\t        return Err(AppError::RunStartFailed {\n   145\t            reason: \"project already has an active run\".to_owned(),\n   146\t        });\n   147\t    }\n   148\t\n   149\t    // 2. Derive the stage plan\n   150\t    let prompt_review_enabled = effective_config.prompt_review_enabled();\n   151\t    let stages = standard_stage_plan(prompt_review_enabled);\n   152\t\n   153\t    // 3. Resolve backend targets for every stage\n   154\t    let workspace_defaults = BackendSelectionConfig::from_effective_config(effective_config)?;\n   155\t    let stage_plan = resolve_stage_plan(\n   156\t        stages.as_slice(),\n   157\t        agent_service.resolver(),\n   158\t        Some(&workspace_defaults),\n   159\t    )?;\n   160\t\n   161\t    // 4. Preflight checks — if any fail, leave all state unchanged\n   162\t    preflight_check(agent_service.adapter(), &stage_plan).await?;\n   163\t\n   164\t    // 5. Generate run ID and read journal for sequence tracking\n   165\t    let run_id = generate_run_id()?;\n   166\t    let now = Utc::now();\n   167\t    let events = journal_store.read_journal(base_dir, project_id)?;\n   168\t    let mut seq = journal::last_sequence(&events);\n   169\t\n   170\t    let first_stage = stage_plan[0].stage_id;\n   171\t\n   172\t    // 6. Persist run_started: create run.json with running status + journal events\n   173\t    seq += 1;\n   174\t    let run_started = journal::run_started_event(seq, now, &run_id, first_stage);\n   175\t    let run_started_line = journal::serialize_event(&run_started)?;\n   176\t    journal_store.append_event(base_dir, project_id, &run_started_line)?;\n   177\t\n   178\t    let initial_cursor = StageCursor::initial(first_stage);\n   179\t    let mut current_snapshot = RunSnapshot {\n   180\t        active_run: Some(ActiveRun {\n   181\t            run_id: run_id.as_str().to_owned(),\n   182\t            stage_cursor: initial_cursor.clone(),\n   183\t            started_at: now,\n   184\t        }),\n   185\t        status: RunStatus::Running,\n   186\t        cycle_history: vec![],\n   187\t        completion_rounds: 1,\n   188\t        rollback_point_meta: snapshot.rollback_point_meta.clone(),\n   189\t        amendment_queue: snapshot.amendment_queue.clone(),\n   190\t        status_summary: format!(\"running: {}\", first_stage.display_name()),\n   191\t    };\n   192\t    run_snapshot_write.write_run_snapshot(base_dir, project_id, &current_snapshot)?;\n   193\t\n   194\t    let project_root = project_root_path(base_dir, project_id);\n   195\t\n   196\t    // 7. Execute stages in order\n   197\t    for (idx, stage_entry) in stage_plan.iter().enumerate() {\n   198\t        let stage_id = stage_entry.stage_id;\n   199\t        let cursor = StageCursor::initial(stage_id);\n   200\t\n   201\t        // Emit stage_entered\n   202\t        seq += 1;\n   203\t        let stage_entered = journal::stage_entered_event(\n   204\t            seq,\n   205\t            Utc::now(),\n   206\t            &run_id,\n   207\t            stage_id,\n   208\t            cursor.cycle,\n   209\t            cursor.attempt,\n   210\t        );\n   211\t        let stage_entered_line = journal::serialize_event(&stage_entered)?;\n   212\t        journal_store.append_event(base_dir, project_id, &stage_entered_line)?;\n   213\t\n   214\t        // Update cursor in snapshot\n   215\t        current_snapshot.active_run.as_mut().unwrap().stage_cursor = cursor.clone();\n   216\t        current_snapshot.status_summary = format!(\"running: {}\", stage_id.display_name());\n   217\t        run_snapshot_write.write_run_snapshot(base_dir, project_id, &current_snapshot)?;\n   218\t\n   219\t        // Best-effort runtime log\n   220\t        let _ = log_write.append_runtime_log(\n   221\t            base_dir,\n   222\t            project_id,\n   223\t            &RuntimeLogEntry {\n   224\t                timestamp: Utc::now(),\n   225\t                level: LogLevel::Info,\n   226\t                source: \"engine\".to_owned(),\n   227\t                message: format!(\"stage_entered: {}\", stage_id.as_str()),\n   228\t            },\n   229\t        );\n   230\t\n   231\t        // Invoke the backend\n   232\t        let invocation_id = format!(\n   233\t            \"{}-{}-c{}-a{}\",\n   234\t            run_id.as_str(),\n   235\t            stage_id.as_str(),\n   236\t            cursor.cycle,\n   237\t            cursor.attempt\n   238\t        );\n   239\t        let request = InvocationRequest {\n   240\t            invocation_id,\n   241\t            project_root: project_root.clone(),\n   242\t            stage_contract: stage_entry.contract,\n   243\t            role: stage_entry.role,\n   244\t            resolved_target: stage_entry.target.clone(),\n   245\t            payload: InvocationPayload {\n   246\t                prompt: format!(\"Execute stage: {}\", stage_id.display_name()),\n   247\t                context: serde_json::json!({}),\n   248\t            },\n   249\t            timeout: Duration::from_secs(300),\n   250\t            cancellation_token: CancellationToken::new(),\n   251\t            session_policy: SessionPolicy::ReuseIfAllowed,\n   252\t            prior_session: None,\n   253\t            attempt_number: cursor.attempt,\n   254\t        };\n   255\t\n   256\t        let envelope = match agent_service.invoke(request).await {\n   257\t            Ok(env) => env,\n   258\t            Err(e) => {\n   259\t                return fail_run(\n   260\t                    &e,\n   261\t                    stage_id,\n   262\t                    &run_id,\n   263\t                    &mut seq,\n   264\t                    &mut current_snapshot,\n   265\t                    journal_store,\n   266\t                    run_snapshot_write,\n   267\t                    base_dir,\n   268\t                    project_id,\n   269\t                )\n   270\t                .await;\n   271\t            }\n   272\t        };\n   273\t\n   274\t        // Evaluate the contract (schema + domain + outcome + render)\n   275\t        let bundle = match stage_entry.contract.evaluate(&envelope.parsed_payload) {\n   276\t            Ok(bundle) => bundle,\n   277\t            Err(contract_err) => {\n   278\t                let app_err = AppError::InvocationFailed {\n   279\t                    backend: stage_entry.target.backend.family.to_string(),\n   280\t                    stage_id,\n   281\t                    failure_class: contract_err.failure_class(),\n   282\t                    details: contract_err.to_string(),\n   283\t                };\n   284\t                return fail_run(\n   285\t                    &app_err,\n   286\t                    stage_id,\n   287\t                    &run_id,\n   288\t                    &mut seq,\n   289\t                    &mut current_snapshot,\n   290\t                    journal_store,\n   291\t                    run_snapshot_write,\n   292\t                    base_dir,\n   293\t                    project_id,\n   294\t                )\n   295\t                .await;\n   296\t            }\n   297\t        };\n   298\t\n   299\t        // Persist payload + artifact pair atomically\n   300\t        let stage_now = Utc::now();\n   301\t        let payload_id = format!(\n   302\t            \"{}-{}-c{}-a{}\",\n   303\t            run_id.as_str(),\n   304\t            stage_id.as_str(),\n   305\t            cursor.cycle,\n   306\t            cursor.attempt\n   307\t        );\n   308\t        let artifact_id = format!(\"{}-artifact\", payload_id);\n   309\t\n   310\t        let payload_record = PayloadRecord {\n   311\t            payload_id: payload_id.clone(),\n   312\t            stage_id,\n   313\t            cycle: cursor.cycle,\n   314\t            attempt: cursor.attempt,\n   315\t            created_at: stage_now,\n   316\t            payload: serde_json::to_value(&bundle.payload)?,\n   317\t        };\n   318\t        let artifact_record = ArtifactRecord {\n   319\t            artifact_id: artifact_id.clone(),\n   320\t            payload_id: payload_id.clone(),\n   321\t            stage_id,\n   322\t            created_at: stage_now,\n   323\t            content: bundle.artifact.clone(),\n   324\t        };\n   325\t\n   326\t        // Atomic stage commit: payload + artifact + journal + snapshot\n   327\t        artifact_write\n   328\t            .write_payload_artifact_pair(base_dir, project_id, &payload_record, &artifact_record)\n   329\t            .map_err(|e| AppError::StageCommitFailed {\n   330\t                stage_id,\n   331\t                details: format!(\"payload/artifact persistence failed: {}\", e),\n   332\t            })?;\n   333\t\n   334\t        // stage_completed journal event\n   335\t        seq += 1;\n   336\t        let stage_completed = journal::stage_completed_event(\n   337\t            seq,\n   338\t            Utc::now(),\n   339\t            &run_id,\n   340\t            stage_id,\n   341\t            cursor.cycle,\n   342\t            cursor.attempt,\n   343\t            &payload_id,\n   344\t            &artifact_id,\n   345\t        );\n   346\t        let stage_completed_line = journal::serialize_event(&stage_completed)?;\n   347\t        if let Err(e) = journal_store.append_event(base_dir, project_id, &stage_completed_line) {\n   348\t            return Err(AppError::StageCommitFailed {\n   349\t                stage_id,\n   350\t                details: format!(\"journal append failed after payload/artifact write: {}\", e),\n   351\t            });\n   352\t        }\n   353\t\n   354\t        // Update snapshot cursor to reflect completed stage\n   355\t        if idx + 1 < stage_plan.len() {\n   356\t            let next_stage = stage_plan[idx + 1].stage_id;\n   357\t            current_snapshot.active_run.as_mut().unwrap().stage_cursor =\n   358\t                StageCursor::initial(next_stage);\n   359\t            current_snapshot.status_summary = format!(\n   360\t                \"running: completed {}, next {}\",\n   361\t                stage_id.display_name(),\n   362\t                next_stage.display_name()\n   363\t            );\n   364\t        }\n   365\t        run_snapshot_write.write_run_snapshot(base_dir, project_id, &current_snapshot)?;\n   366\t\n   367\t        // Best-effort runtime log\n   368\t        let _ = log_write.append_runtime_log(\n   369\t            base_dir,\n   370\t            project_id,\n   371\t            &RuntimeLogEntry {\n   372\t                timestamp: Utc::now(),\n   373\t                level: LogLevel::Info,\n   374\t                source: \"engine\".to_owned(),\n   375\t                message: format!(\"stage_completed: {}\", stage_id.as_str()),\n   376\t            },\n   377\t        );\n   378\t    }\n   379\t\n   380\t    // 8. All stages completed — mark run as completed\n   381\t    seq += 1;\n   382\t    let run_completed = journal::run_completed_event(seq, Utc::now(), &run_id, 1);\n   383\t    let run_completed_line = journal::serialize_event(&run_completed)?;\n   384\t    journal_store.append_event(base_dir, project_id, &run_completed_line)?;\n   385\t\n   386\t    current_snapshot.status = RunStatus::Completed;\n   387\t    current_snapshot.active_run = None;\n   388\t    current_snapshot.completion_rounds = 1;\n   389\t    current_snapshot.status_summary = \"completed\".to_owned();\n   390\t    run_snapshot_write.write_run_snapshot(base_dir, project_id, &current_snapshot)?;\n   391\t\n   392\t    Ok(())\n   393\t}\n   394\t\n   395\t/// Record a run failure: persist journal event, update snapshot, return error.\n   396\t#[allow(clippy::too_many_arguments)]\n   397\tasync fn fail_run(\n   398\t    err: &AppError,\n   399\t    stage_id: StageId,\n   400\t    run_id: &RunId,\n   401\t    seq: &mut u64,\n   402\t    snapshot: &mut RunSnapshot,\n   403\t    journal_store: &dyn JournalStorePort,\n   404\t    run_snapshot_write: &dyn RunSnapshotWritePort,\n   405\t    base_dir: &Path,\n   406\t    project_id: &ProjectId,\n   407\t) -> AppResult<()> {\n   408\t    let failure_class = err\n   409\t        .failure_class()\n   410\t        .map(|fc| format!(\"{:?}\", fc))\n   411\t        .unwrap_or_else(|| \"unknown\".to_owned());\n   412\t    let message = err.to_string();\n   413\t\n   414\t    *seq += 1;\n   415\t    let run_failed =\n   416\t        journal::run_failed_event(*seq, Utc::now(), run_id, stage_id, &failure_class, &message);\n   417\t    let run_failed_line = journal::serialize_event(&run_failed)?;\n   418\t    journal_store.append_event(base_dir, project_id, &run_failed_line)?;\n   419\t\n   420\t    snapshot.status = RunStatus::Failed;\n   421\t    snapshot.active_run = None;\n   422\t    snapshot.status_summary = format!(\"failed at {}: {}\", stage_id.display_name(), message);\n   423\t    run_snapshot_write.write_run_snapshot(base_dir, project_id, snapshot)?;\n   424\t\n   425\t    Err(AppError::RunStartFailed {\n   426\t        reason: format!(\"stage {} failed: {}\", stage_id.as_str(), message),\n   427\t    })\n   428\t}\n   429\t\n   430\t/// Helper to get project root path.\n   431\tfn project_root_path(base_dir: &Path, project_id: &ProjectId) -> PathBuf {\n   432\t    base_dir\n   433\t        .join(\".ralph-burning\")\n   434\t        .join(\"projects\")\n   435\t        .join(project_id.as_str())\n   436\t}\n","exit_code":0,"status":"completed"}}
