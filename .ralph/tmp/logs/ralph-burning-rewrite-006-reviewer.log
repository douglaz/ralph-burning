est]\n  2215\tfn run_start_persists_payload_and_artifact_records() {\n  2216\t    let temp_dir = initialize_workspace_fixture();\n  2217\t    setup_standard_project(&temp_dir, \"run-artifacts\");\n  2218\t\n  2219\t    let start = Command::new(binary())\n  2220\t        .args([\"run\", \"start\"])\n  2221\t        .current_dir(temp_dir.path())\n  2222\t        .output()\n  2223\t        .expect(\"run start\");\n  2224\t    assert!(start.status.success());\n  2225\t\n  2226\t    let payloads_dir = temp_dir\n  2227\t        .path()\n  2228\t        .join(\".ralph-burning/projects/run-artifacts/history/payloads\");\n  2229\t    let artifacts_dir = temp_dir\n  2230\t        .path()\n  2231\t        .join(\".ralph-burning/projects/run-artifacts/history/artifacts\");\n  2232\t\n  2233\t    // Standard flow has 8 stages, each producing a payload + artifact\n  2234\t    let payload_files: Vec<_> = fs::read_dir(&payloads_dir)\n  2235\t        .expect(\"read payloads dir\")\n  2236\t        .filter_map(|e| e.ok())\n  2237\t        .filter(|e| e.path().extension().is_some_and(|ext| ext == \"json\"))\n  2238\t        .collect();\n  2239\t    let artifact_files: Vec<_> = fs::read_dir(&artifacts_dir)\n  2240\t        .expect(\"read artifacts dir\")\n  2241\t        .filter_map(|e| e.ok())\n  2242\t        .filter(|e| e.path().extension().is_some_and(|ext| ext == \"json\"))\n  2243\t        .collect();\n  2244\t\n  2245\t    assert_eq!(\n  2246\t        payload_files.len(),\n  2247\t        8,\n  2248\t        \"expected 8 payload files for standard flow, got {}\",\n  2249\t        payload_files.len()\n  2250\t    );\n  2251\t    assert_eq!(\n  2252\t        artifact_files.len(),\n  2253\t        8,\n  2254\t        \"expected 8 artifact files for standard flow, got {}\",\n  2255\t        artifact_files.len()\n  2256\t    );\n  2257\t}\n  2258\t\n  2259\t#[test]\n  2260\tfn run_start_status_shows_completed_after_run() {\n  2261\t    let temp_dir = initialize_workspace_fixture();\n  2262\t    setup_standard_project(&temp_dir, \"run-status-after\");\n  2263\t\n  2264\t    let start = Command::new(binary())\n  2265\t        .args([\"run\", \"start\"])\n  2266\t        .current_dir(temp_dir.path())\n  2267\t        .output()\n  2268\t        .expect(\"run start\");\n  2269\t    assert!(start.status.success());\n  2270\t\n  2271\t    let status = Command::new(binary())\n  2272\t        .args([\"run\", \"status\"])\n  2273\t        .current_dir(temp_dir.path())\n  2274\t        .output()\n  2275\t        .expect(\"run status\");\n  2276\t\n  2277\t    assert!(status.status.success());\n  2278\t    let stdout = String::from_utf8_lossy(&status.stdout);\n  2279\t    assert!(\n  2280\t        stdout.contains(\"Status: completed\"),\n  2281\t        \"run status should show completed after successful run, got: {stdout}\"\n  2282\t    );\n  2283\t}\n  2284\t\n  2285\t#[test]\n  2286\tfn run_start_rejects_non_standard_flow() {\n  2287\t    let temp_dir = initialize_workspace_fixture();\n  2288\t    let prompt = write_prompt_fixture(temp_dir.path());\n  2289\t\n  2290\t    Command::new(binary())\n  2291\t        .args([\n  2292\t            \"project\",\n  2293\t            \"create\",\n  2294\t            \"--id\",\n  2295\t            \"quickdev\",\n  2296\t            \"--name\",\n  2297\t            \"Quick Dev\",\n  2298\t            \"--prompt\",\n  2299\t            prompt.to_str().unwrap(),\n  2300\t            \"--flow\",\n  2301\t            \"quick_dev\",\n  2302\t        ])\n  2303\t        .current_dir(temp_dir.path())\n  2304\t        .output()\n  2305\t        .expect(\"create project\");\n  2306\t\n  2307\t    Command::new(binary())\n  2308\t        .args([\"project\", \"select\", \"quickdev\"])\n  2309\t        .current_dir(temp_dir.path())\n  2310\t        .output()\n  2311\t        .expect(\"select project\");\n  2312\t\n  2313\t    let output = Command::new(binary())\n  2314\t        .args([\"run\", \"start\"])\n  2315\t        .curren