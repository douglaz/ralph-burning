{"type":"item.completed","item":{"id":"item_27","type":"command_execution","command":"/run/current-system/sw/bin/bash -lc \"nl -ba tests/unit/workflow_engine_test.rs | sed -n '1,420p'\"","aggregated_output":"     1\tuse std::fs;\n     2\tuse std::path::Path;\n     3\t\n     4\tuse chrono::Utc;\n     5\tuse tempfile::tempdir;\n     6\t\n     7\tuse ralph_burning::adapters::fs::{\n     8\t    FsJournalStore, FsPayloadArtifactWriteStore, FsProjectStore, FsRawOutputStore,\n     9\t    FsRunSnapshotStore, FsRunSnapshotWriteStore, FsRuntimeLogWriteStore, FsSessionStore,\n    10\t};\n    11\tuse ralph_burning::adapters::stub_backend::StubBackendAdapter;\n    12\tuse ralph_burning::contexts::agent_execution::service::AgentExecutionService;\n    13\tuse ralph_burning::contexts::project_run_record::model::{\n    14\t    JournalEvent, JournalEventType, RunSnapshot, RunStatus,\n    15\t};\n    16\tuse ralph_burning::contexts::project_run_record::service::{\n    17\t    self, CreateProjectInput, JournalStorePort, RunSnapshotPort, RunSnapshotWritePort,\n    18\t};\n    19\tuse ralph_burning::shared::error::{AppError, AppResult};\n    20\tuse ralph_burning::contexts::workflow_composition::engine;\n    21\tuse ralph_burning::contexts::workspace_governance;\n    22\tuse ralph_burning::contexts::workspace_governance::config::EffectiveConfig;\n    23\tuse ralph_burning::shared::domain::{FlowPreset, ProjectId, StageId};\n    24\t\n    25\tfn setup_workspace(base_dir: &Path) {\n    26\t    workspace_governance::initialize_workspace(base_dir, Utc::now()).unwrap();\n    27\t}\n    28\t\n    29\tfn create_standard_project(base_dir: &Path, project_id: &str) -> ProjectId {\n    30\t    let pid = ProjectId::new(project_id).unwrap();\n    31\t    let store = FsProjectStore;\n    32\t    let journal_store = FsJournalStore;\n    33\t    service::create_project(\n    34\t        &store,\n    35\t        &journal_store,\n    36\t        base_dir,\n    37\t        CreateProjectInput {\n    38\t            id: pid.clone(),\n    39\t            name: format!(\"Test {}\", project_id),\n    40\t            flow: FlowPreset::Standard,\n    41\t            prompt_path: \"prompt.md\".to_owned(),\n    42\t            prompt_contents: \"# Test prompt\".to_owned(),\n    43\t            prompt_hash: \"testhash123\".to_owned(),\n    44\t            created_at: Utc::now(),\n    45\t        },\n    46\t    )\n    47\t    .unwrap();\n    48\t\n    49\t    // Select as active\n    50\t    workspace_governance::set_active_project(base_dir, &pid).unwrap();\n    51\t    pid\n    52\t}\n    53\t\n    54\tfn build_agent_service(\n    55\t) -> AgentExecutionService<StubBackendAdapter, FsRawOutputStore, FsSessionStore> {\n    56\t    AgentExecutionService::new(\n    57\t        StubBackendAdapter::default(),\n    58\t        FsRawOutputStore,\n    59\t        FsSessionStore,\n    60\t    )\n    61\t}\n    62\t\n    63\t// ── Stage plan tests ────────────────────────────────────────────────────────\n    64\t\n    65\t#[test]\n    66\tfn stage_plan_with_prompt_review_enabled() {\n    67\t    let plan = engine::standard_stage_plan(true);\n    68\t    assert_eq!(plan.len(), 8);\n    69\t    assert_eq!(plan[0], StageId::PromptReview);\n    70\t    assert_eq!(plan[1], StageId::Planning);\n    71\t    assert_eq!(plan[7], StageId::FinalReview);\n    72\t}\n    73\t\n    74\t#[test]\n    75\tfn stage_plan_with_prompt_review_disabled() {\n    76\t    let plan = engine::standard_stage_plan(false);\n    77\t    assert_eq!(plan.len(), 7);\n    78\t    assert_eq!(plan[0], StageId::Planning);\n    79\t    assert!(!plan.contains(&StageId::PromptReview));\n    80\t}\n    81\t\n    82\t#[test]\n    83\tfn role_mapping_is_deterministic() {\n    84\t    use ralph_burning::shared::domain::BackendRole;\n    85\t    assert_eq!(engine::role_for_stage(StageId::PromptReview), BackendRole::Planner);\n    86\t    assert_eq!(engine::role_for_stage(StageId::Planning), BackendRole::Planner);\n    87\t    assert_eq!(engine::role_for_stage(StageId::Implementation), BackendRole::Implementer);\n    88\t    assert_eq!(engine::role_for_stage(StageId::Qa), BackendRole::QaValidator);\n    89\t    assert_eq!(engine::role_for_stage(StageId::Review), BackendRole::Reviewer);\n    90\t    assert_eq!(engine::role_for_stage(StageId::CompletionPanel), BackendRole::CompletionJudge);\n    91\t    assert_eq!(engine::role_for_stage(StageId::AcceptanceQa), BackendRole::QaValidator);\n    92\t    assert_eq!(engine::role_for_stage(StageId::FinalReview), BackendRole::CompletionJudge);\n    93\t}\n    94\t\n    95\t// ── Happy path tests ────────────────────────────────────────────────────────\n    96\t\n    97\t#[tokio::test]\n    98\tasync fn happy_path_standard_run_completes() {\n    99\t    let tmp = tempdir().unwrap();\n   100\t    let base_dir = tmp.path();\n   101\t\n   102\t    setup_workspace(base_dir);\n   103\t    let pid = create_standard_project(base_dir, \"happy-test\");\n   104\t\n   105\t    let agent_service = build_agent_service();\n   106\t    let config = EffectiveConfig::load(base_dir).unwrap();\n   107\t\n   108\t    let result = engine::execute_standard_run(\n   109\t        &agent_service,\n   110\t        &FsRunSnapshotStore,\n   111\t        &FsRunSnapshotWriteStore,\n   112\t        &FsJournalStore,\n   113\t        &FsPayloadArtifactWriteStore,\n   114\t        &FsRuntimeLogWriteStore,\n   115\t        base_dir,\n   116\t        &pid,\n   117\t        &config,\n   118\t    )\n   119\t    .await;\n   120\t\n   121\t    assert!(result.is_ok(), \"execute_standard_run failed: {:?}\", result.err());\n   122\t\n   123\t    // Verify final run snapshot\n   124\t    let snapshot = FsRunSnapshotStore.read_run_snapshot(base_dir, &pid).unwrap();\n   125\t    assert_eq!(snapshot.status, RunStatus::Completed);\n   126\t    assert!(snapshot.active_run.is_none());\n   127\t    assert_eq!(snapshot.completion_rounds, 1);\n   128\t    assert_eq!(snapshot.status_summary, \"completed\");\n   129\t\n   130\t    // Verify journal events\n   131\t    let events = FsJournalStore.read_journal(base_dir, &pid).unwrap();\n   132\t    // project_created + run_started + (8 * (stage_entered + stage_completed)) + run_completed\n   133\t    // = 1 + 1 + 16 + 1 = 19 events (with prompt_review enabled by default)\n   134\t    assert!(events.len() >= 19, \"expected >= 19 events, got {}\", events.len());\n   135\t\n   136\t    // First event should be project_created, second run_started\n   137\t    assert_eq!(events[0].event_type, JournalEventType::ProjectCreated);\n   138\t    assert_eq!(events[1].event_type, JournalEventType::RunStarted);\n   139\t\n   140\t    // Last event should be run_completed\n   141\t    assert_eq!(events.last().unwrap().event_type, JournalEventType::RunCompleted);\n   142\t\n   143\t    // Verify payloads and artifacts were written\n   144\t    let payloads_dir = base_dir\n   145\t        .join(\".ralph-burning/projects/happy-test/history/payloads\");\n   146\t    let artifacts_dir = base_dir\n   147\t        .join(\".ralph-burning/projects/happy-test/history/artifacts\");\n   148\t    let payload_count = fs::read_dir(&payloads_dir).unwrap().count();\n   149\t    let artifact_count = fs::read_dir(&artifacts_dir).unwrap().count();\n   150\t    assert_eq!(payload_count, 8, \"expected 8 payloads\");\n   151\t    assert_eq!(artifact_count, 8, \"expected 8 artifacts\");\n   152\t}\n   153\t\n   154\t#[tokio::test]\n   155\tasync fn happy_path_prompt_review_disabled() {\n   156\t    let tmp = tempdir().unwrap();\n   157\t    let base_dir = tmp.path();\n   158\t\n   159\t    setup_workspace(base_dir);\n   160\t\n   161\t    // Disable prompt review in config\n   162\t    workspace_governance::config::EffectiveConfig::set(base_dir, \"prompt_review.enabled\", \"false\")\n   163\t        .unwrap();\n   164\t\n   165\t    let pid = create_standard_project(base_dir, \"no-pr-test\");\n   166\t\n   167\t    let agent_service = build_agent_service();\n   168\t    let config = EffectiveConfig::load(base_dir).unwrap();\n   169\t    assert!(!config.prompt_review_enabled());\n   170\t\n   171\t    let result = engine::execute_standard_run(\n   172\t        &agent_service,\n   173\t        &FsRunSnapshotStore,\n   174\t        &FsRunSnapshotWriteStore,\n   175\t        &FsJournalStore,\n   176\t        &FsPayloadArtifactWriteStore,\n   177\t        &FsRuntimeLogWriteStore,\n   178\t        base_dir,\n   179\t        &pid,\n   180\t        &config,\n   181\t    )\n   182\t    .await;\n   183\t\n   184\t    assert!(result.is_ok());\n   185\t\n   186\t    // Verify 7 stages completed (no prompt_review)\n   187\t    let payloads_dir = base_dir\n   188\t        .join(\".ralph-burning/projects/no-pr-test/history/payloads\");\n   189\t    let payload_count = fs::read_dir(&payloads_dir).unwrap().count();\n   190\t    assert_eq!(payload_count, 7, \"expected 7 payloads without prompt_review\");\n   191\t\n   192\t    // Verify no prompt_review stage_entered in journal\n   193\t    let events = FsJournalStore.read_journal(base_dir, &pid).unwrap();\n   194\t    let pr_events: Vec<_> = events\n   195\t        .iter()\n   196\t        .filter(|e| {\n   197\t            if e.event_type == JournalEventType::StageEntered {\n   198\t                e.details.get(\"stage_id\").and_then(|v| v.as_str()) == Some(\"prompt_review\")\n   199\t            } else {\n   200\t                false\n   201\t            }\n   202\t        })\n   203\t        .collect();\n   204\t    assert!(pr_events.is_empty(), \"prompt_review stage should not appear\");\n   205\t}\n   206\t\n   207\t// ── Precondition failure tests ──────────────────────────────────────────────\n   208\t\n   209\t#[tokio::test]\n   210\tasync fn run_start_rejects_already_running() {\n   211\t    let tmp = tempdir().unwrap();\n   212\t    let base_dir = tmp.path();\n   213\t\n   214\t    setup_workspace(base_dir);\n   215\t    let pid = create_standard_project(base_dir, \"running-test\");\n   216\t\n   217\t    // Manually set status to running\n   218\t    let snapshot = RunSnapshot {\n   219\t        active_run: Some(ralph_burning::contexts::project_run_record::model::ActiveRun {\n   220\t            run_id: \"run-fake\".to_owned(),\n   221\t            stage_cursor: ralph_burning::shared::domain::StageCursor::initial(StageId::Planning),\n   222\t            started_at: Utc::now(),\n   223\t        }),\n   224\t        status: RunStatus::Running,\n   225\t        cycle_history: vec![],\n   226\t        completion_rounds: 0,\n   227\t        rollback_point_meta: Default::default(),\n   228\t        amendment_queue: Default::default(),\n   229\t        status_summary: \"running\".to_owned(),\n   230\t    };\n   231\t    FsRunSnapshotWriteStore\n   232\t        .write_run_snapshot(base_dir, &pid, &snapshot)\n   233\t        .unwrap();\n   234\t\n   235\t    let agent_service = build_agent_service();\n   236\t    let config = EffectiveConfig::load(base_dir).unwrap();\n   237\t\n   238\t    let result = engine::execute_standard_run(\n   239\t        &agent_service,\n   240\t        &FsRunSnapshotStore,\n   241\t        &FsRunSnapshotWriteStore,\n   242\t        &FsJournalStore,\n   243\t        &FsPayloadArtifactWriteStore,\n   244\t        &FsRuntimeLogWriteStore,\n   245\t        base_dir,\n   246\t        &pid,\n   247\t        &config,\n   248\t    )\n   249\t    .await;\n   250\t\n   251\t    assert!(result.is_err());\n   252\t    let err = result.unwrap_err().to_string();\n   253\t    assert!(err.contains(\"not_started\"), \"unexpected error: {}\", err);\n   254\t}\n   255\t\n   256\t#[tokio::test]\n   257\tasync fn run_start_rejects_completed_project() {\n   258\t    let tmp = tempdir().unwrap();\n   259\t    let base_dir = tmp.path();\n   260\t\n   261\t    setup_workspace(base_dir);\n   262\t    let pid = create_standard_project(base_dir, \"completed-test\");\n   263\t\n   264\t    let snapshot = RunSnapshot {\n   265\t        active_run: None,\n   266\t        status: RunStatus::Completed,\n   267\t        cycle_history: vec![],\n   268\t        completion_rounds: 1,\n   269\t        rollback_point_meta: Default::default(),\n   270\t        amendment_queue: Default::default(),\n   271\t        status_summary: \"completed\".to_owned(),\n   272\t    };\n   273\t    FsRunSnapshotWriteStore\n   274\t        .write_run_snapshot(base_dir, &pid, &snapshot)\n   275\t        .unwrap();\n   276\t\n   277\t    let agent_service = build_agent_service();\n   278\t    let config = EffectiveConfig::load(base_dir).unwrap();\n   279\t\n   280\t    let result = engine::execute_standard_run(\n   281\t        &agent_service,\n   282\t        &FsRunSnapshotStore,\n   283\t        &FsRunSnapshotWriteStore,\n   284\t        &FsJournalStore,\n   285\t        &FsPayloadArtifactWriteStore,\n   286\t        &FsRuntimeLogWriteStore,\n   287\t        base_dir,\n   288\t        &pid,\n   289\t        &config,\n   290\t    )\n   291\t    .await;\n   292\t\n   293\t    assert!(result.is_err());\n   294\t}\n   295\t\n   296\t// ── Preflight failure tests ─────────────────────────────────────────────────\n   297\t\n   298\t#[tokio::test]\n   299\tasync fn preflight_failure_leaves_state_unchanged() {\n   300\t    let tmp = tempdir().unwrap();\n   301\t    let base_dir = tmp.path();\n   302\t\n   303\t    setup_workspace(base_dir);\n   304\t    let pid = create_standard_project(base_dir, \"preflight-test\");\n   305\t\n   306\t    // Use an unavailable backend to trigger preflight failure\n   307\t    let agent_service = AgentExecutionService::new(\n   308\t        StubBackendAdapter::default().unavailable(),\n   309\t        FsRawOutputStore,\n   310\t        FsSessionStore,\n   311\t    );\n   312\t    let config = EffectiveConfig::load(base_dir).unwrap();\n   313\t\n   314\t    let result = engine::execute_standard_run(\n   315\t        &agent_service,\n   316\t        &FsRunSnapshotStore,\n   317\t        &FsRunSnapshotWriteStore,\n   318\t        &FsJournalStore,\n   319\t        &FsPayloadArtifactWriteStore,\n   320\t        &FsRuntimeLogWriteStore,\n   321\t        base_dir,\n   322\t        &pid,\n   323\t        &config,\n   324\t    )\n   325\t    .await;\n   326\t\n   327\t    assert!(result.is_err());\n   328\t\n   329\t    // Verify run.json is still not_started\n   330\t    let snapshot = FsRunSnapshotStore.read_run_snapshot(base_dir, &pid).unwrap();\n   331\t    assert_eq!(snapshot.status, RunStatus::NotStarted);\n   332\t    assert!(snapshot.active_run.is_none());\n   333\t\n   334\t    // Verify journal only has project_created\n   335\t    let events = FsJournalStore.read_journal(base_dir, &pid).unwrap();\n   336\t    assert_eq!(events.len(), 1);\n   337\t    assert_eq!(events[0].event_type, JournalEventType::ProjectCreated);\n   338\t\n   339\t    // Verify no payloads or artifacts created\n   340\t    let payloads_dir = base_dir\n   341\t        .join(\".ralph-burning/projects/preflight-test/history/payloads\");\n   342\t    let payload_count = fs::read_dir(&payloads_dir).unwrap().count();\n   343\t    assert_eq!(payload_count, 0);\n   344\t}\n   345\t\n   346\t// ── Stage plan resolution tests ─────────────────────────────────────────────\n   347\t\n   348\t#[test]\n   349\tfn resolve_stage_plan_produces_correct_targets() {\n   350\t    let resolver = ralph_burning::contexts::agent_execution::service::BackendResolver::new();\n   351\t    let stages = engine::standard_stage_plan(true);\n   352\t    let plan = engine::resolve_stage_plan(&stages, &resolver, None).unwrap();\n   353\t\n   354\t    assert_eq!(plan.len(), 8);\n   355\t    assert_eq!(plan[0].stage_id, StageId::PromptReview);\n   356\t    assert_eq!(\n   357\t        plan[0].role,\n   358\t        ralph_burning::shared::domain::BackendRole::Planner\n   359\t    );\n   360\t    assert_eq!(plan[2].stage_id, StageId::Implementation);\n   361\t    assert_eq!(\n   362\t        plan[2].role,\n   363\t        ralph_burning::shared::domain::BackendRole::Implementer\n   364\t    );\n   365\t}\n   366\t\n   367\t// ── Preflight check unit test ───────────────────────────────────────────────\n   368\t\n   369\t#[tokio::test]\n   370\tasync fn preflight_check_succeeds_with_default_stub() {\n   371\t    let resolver = ralph_burning::contexts::agent_execution::service::BackendResolver::new();\n   372\t    let stages = engine::standard_stage_plan(true);\n   373\t    let plan = engine::resolve_stage_plan(&stages, &resolver, None).unwrap();\n   374\t\n   375\t    let adapter = StubBackendAdapter::default();\n   376\t    let result = engine::preflight_check(&adapter, &plan).await;\n   377\t    assert!(result.is_ok());\n   378\t}\n   379\t\n   380\t#[tokio::test]\n   381\tasync fn preflight_check_fails_with_unavailable_backend() {\n   382\t    let resolver = ralph_burning::contexts::agent_execution::service::BackendResolver::new();\n   383\t    let stages = engine::standard_stage_plan(true);\n   384\t    let plan = engine::resolve_stage_plan(&stages, &resolver, None).unwrap();\n   385\t\n   386\t    let adapter = StubBackendAdapter::default().unavailable();\n   387\t    let result = engine::preflight_check(&adapter, &plan).await;\n   388\t    assert!(result.is_err());\n   389\t}\n   390\t\n   391\t// ── Failing-port tests: journal-append and snapshot-write errors ─────────\n   392\t\n   393\tuse std::sync::atomic::{AtomicU32, Ordering};\n   394\t\n   395\t/// A journal store that delegates to `FsJournalStore` but fails on the Nth\n   396\t/// append_event call (1-indexed). This lets us test failure at specific\n   397\t/// stage-commit boundaries.\n   398\tstruct FailingJournalStore {\n   399\t    call_count: AtomicU32,\n   400\t    fail_on_call: u32,\n   401\t}\n   402\t\n   403\timpl FailingJournalStore {\n   404\t    fn new(fail_on_call: u32) -> Self {\n   405\t        Self {\n   406\t            call_count: AtomicU32::new(0),\n   407\t            fail_on_call,\n   408\t        }\n   409\t    }\n   410\t}\n   411\t\n   412\timpl JournalStorePort for FailingJournalStore {\n   413\t    fn read_journal(\n   414\t        &self,\n   415\t        base_dir: &Path,\n   416\t        project_id: &ralph_burning::shared::domain::ProjectId,\n   417\t    ) -> AppResult<Vec<JournalEvent>> {\n   418\t        FsJournalStore.read_journal(base_dir, project_id)\n   419\t    }\n   420\t\n","exit_code":0,"status":"completed"}}
