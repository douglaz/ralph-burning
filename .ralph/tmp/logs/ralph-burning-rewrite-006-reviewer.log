FlowDefinition; 4] = [\n    57\t    FlowDefinition {\n    58\t        preset: FlowPreset::Standard,\n    59\t        description:\n    60\t            \"Full delivery flow with planning, implementation, QA, review, and acceptance.\",\n    61\t        stages: &STANDARD_STAGES,\n    62\t        validation_profile: ValidationProfile {\n    63\t            name: \"standard-default\",\n    64\t            summary: \"Full validation suite with completion and acceptance checks.\",\n    65\t            final_review_enabled: true,\n    66\t        },\n    67\t    },\n    68\t    FlowDefinition {\n    69\t        preset: FlowPreset::QuickDev,\n    70\t        description: \"Fast delivery flow for small code changes with lightweight review.\",\n    71\t        stages: &QUICK_DEV_STAGES,\n    72\t        validation_profile: ValidationProfile {\n    73\t            name: \"quick-dev-default\",\n    74\t            summary: \"Lightweight panel with final review enabled by default.\",\n    75\t            final_review_enabled: true,\n    76\t        },\n    77\t    },\n    78\t    FlowDefinition {\n    79\t        preset: FlowPreset::DocsChange,\n    80\t        description: \"Documentation-focused flow for planning, content updates, and validation.\",\n    81\t        stages: &DOCS_CHANGE_STAGES,\n    82\t        validation_profile: ValidationProfile {\n    83\t            name: \"docs-default\",\n    84\t            summary: \"Documentation validation with final review disabled by default.\",\n    85\t            final_review_enabled: false,\n    86\t        },\n    87\t    },\n    88\t    FlowDefinition {\n    89\t        preset: FlowPreset::CiImprovement,\n    90\t        description: \"CI improvement flow for automation planning, updates, and validation.\",\n    91\t        stages: &CI_IMPROVEMENT_STAGES,\n    92\t        validation_profile: ValidationProfile {\n    93\t            name: \"ci-default\",\n    94\t            summary: \"Automation validation with final review disabled by default.\",\n    95\t            final_review_enabled: false,\n    96\t        },\n    97\t    },\n    98\t];\n    99\t\n   100\tpub fn built_in_flows() -> &'static [FlowDefinition] {\n   101\t    &FLOW_DEFINITIONS\n   102\t}\n   103\t\n   104\tpub fn flow_definition(preset: FlowPreset) -> &'static FlowDefinition {\n   105\t    match preset {\n   106\t        FlowPreset::Standard => &FLOW_DEFINITIONS[0],\n   107\t        FlowPreset::QuickDev => &FLOW_DEFINITIONS[1],\n   108\t        FlowPreset::DocsChange => &FLOW_DEFINITIONS[2],\n   109\t        FlowPreset::CiImprovement => &FLOW_DEFINITIONS[3],\n   110\t    }\n   111\t}\n   112\t\n   113\tpub fn flow_definition_by_id(flow_id: &str) -> AppResult<&'static FlowDefinition> {\n   114\t    let preset = flow_id.parse::<FlowPreset>()?;\n   115\t    Ok(flow_definition(preset))\n   116\t}\n","exit_code":0,"status":"completed"}}
