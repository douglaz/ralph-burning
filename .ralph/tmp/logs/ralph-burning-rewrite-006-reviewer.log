{"type":"item.completed","item":{"id":"item_18","type":"command_execution","command":"/run/current-system/sw/bin/bash -lc \"nl -ba ralph-burning-rewrite/tests/unit/workflow_engine_test.rs | sed -n '1,380p'\"","aggregated_output":"     1\tuse std::fs;\n     2\tuse std::path::Path;\n     3\t\n     4\tuse chrono::Utc;\n     5\tuse tempfile::tempdir;\n     6\t\n     7\tuse ralph_burning::adapters::fs::{\n     8\t    FsJournalStore, FsPayloadArtifactWriteStore, FsProjectStore, FsRawOutputStore,\n     9\t    FsRunSnapshotStore, FsRunSnapshotWriteStore, FsRuntimeLogWriteStore, FsSessionStore,\n    10\t};\n    11\tuse ralph_burning::adapters::stub_backend::StubBackendAdapter;\n    12\tuse ralph_burning::contexts::agent_execution::service::AgentExecutionService;\n    13\tuse ralph_burning::contexts::project_run_record::model::{\n    14\t    JournalEventType, RunSnapshot, RunStatus,\n    15\t};\n    16\tuse ralph_burning::contexts::project_run_record::service::{\n    17\t    self, CreateProjectInput, JournalStorePort, RunSnapshotPort, RunSnapshotWritePort,\n    18\t};\n    19\tuse ralph_burning::contexts::workflow_composition::engine;\n    20\tuse ralph_burning::contexts::workspace_governance;\n    21\tuse ralph_burning::contexts::workspace_governance::config::EffectiveConfig;\n    22\tuse ralph_burning::shared::domain::{FlowPreset, ProjectId, StageId};\n    23\t\n    24\tfn setup_workspace(base_dir: &Path) {\n    25\t    workspace_governance::initialize_workspace(base_dir, Utc::now()).unwrap();\n    26\t}\n    27\t\n    28\tfn create_standard_project(base_dir: &Path, project_id: &str) -> ProjectId {\n    29\t    let pid = ProjectId::new(project_id).unwrap();\n    30\t    let store = FsProjectStore;\n    31\t    let journal_store = FsJournalStore;\n    32\t    service::create_project(\n    33\t        &store,\n    34\t        &journal_store,\n    35\t        base_dir,\n    36\t        CreateProjectInput {\n    37\t            id: pid.clone(),\n    38\t            name: format!(\"Test {}\", project_id),\n    39\t            flow: FlowPreset::Standard,\n    40\t            prompt_path: \"prompt.md\".to_owned(),\n    41\t            prompt_contents: \"# Test prompt\".to_owned(),\n    42\t            prompt_hash: \"testhash123\".to_owned(),\n    43\t            created_at: Utc::now(),\n    44\t        },\n    45\t    )\n    46\t    .unwrap();\n    47\t\n    48\t    // Select as active\n    49\t    workspace_governance::set_active_project(base_dir, &pid).unwrap();\n    50\t    pid\n    51\t}\n    52\t\n    53\tfn build_agent_service(\n    54\t) -> AgentExecutionService<StubBackendAdapter, FsRawOutputStore, FsSessionStore> {\n    55\t    AgentExecutionService::new(\n    56\t        StubBackendAdapter::default(),\n    57\t        FsRawOutputStore,\n    58\t        FsSessionStore,\n    59\t    )\n    60\t}\n    61\t\n    62\t// ── Stage plan tests ────────────────────────────────────────────────────────\n    63\t\n    64\t#[test]\n    65\tfn stage_plan_with_prompt_review_enabled() {\n    66\t    let plan = engine::standard_stage_plan(true);\n    67\t    assert_eq!(plan.len(), 8);\n    68\t    assert_eq!(plan[0], StageId::PromptReview);\n    69\t    assert_eq!(plan[1], StageId::Planning);\n    70\t    assert_eq!(plan[7], StageId::FinalReview);\n    71\t}\n    72\t\n    73\t#[test]\n    74\tfn stage_plan_with_prompt_review_disabled() {\n    75\t    let plan = engine::standard_stage_plan(false);\n    76\t    assert_eq!(plan.len(), 7);\n    77\t    assert_eq!(plan[0], StageId::Planning);\n    78\t    assert!(!plan.contains(&StageId::PromptReview));\n    79\t}\n    80\t\n    81\t#[test]\n    82\tfn role_mapping_is_deterministic() {\n    83\t    use ralph_burning::shared::domain::BackendRole;\n    84\t    assert_eq!(engine::role_for_stage(StageId::PromptReview), BackendRole::Planner);\n    85\t    assert_eq!(engine::role_for_stage(StageId::Planning), BackendRole::Planner);\n    86\t    assert_eq!(engine::role_for_stage(StageId::Implementation), BackendRole::Implementer);\n    87\t    assert_eq!(engine::role_for_stage(StageId::Qa), BackendRole::QaValidator);\n    88\t    assert_eq!(engine::role_for_stage(StageId::Review), BackendRole::Reviewer);\n    89\t    assert_eq!(engine::role_for_stage(StageId::CompletionPanel), BackendRole::CompletionJudge);\n    90\t    assert_eq!(engine::role_for_stage(StageId::AcceptanceQa), BackendRole::QaValidator);\n    91\t    assert_eq!(engine::role_for_stage(StageId::FinalReview), BackendRole::Reviewer);\n    92\t}\n    93\t\n    94\t// ── Happy path tests ────────────────────────────────────────────────────────\n    95\t\n    96\t#[tokio::test]\n    97\tasync fn happy_path_standard_run_completes() {\n    98\t    let tmp = tempdir().unwrap();\n    99\t    let base_dir = tmp.path();\n   100\t\n   101\t    setup_workspace(base_dir);\n   102\t    let pid = create_standard_project(base_dir, \"happy-test\");\n   103\t\n   104\t    let agent_service = build_agent_service();\n   105\t    let config = EffectiveConfig::load(base_dir).unwrap();\n   106\t\n   107\t    let result = engine::execute_standard_run(\n   108\t        &agent_service,\n   109\t        &FsRunSnapshotStore,\n   110\t        &FsRunSnapshotWriteStore,\n   111\t        &FsJournalStore,\n   112\t        &FsPayloadArtifactWriteStore,\n   113\t        &FsRuntimeLogWriteStore,\n   114\t        base_dir,\n   115\t        &pid,\n   116\t        &config,\n   117\t    )\n   118\t    .await;\n   119\t\n   120\t    assert!(result.is_ok(), \"execute_standard_run failed: {:?}\", result.err());\n   121\t\n   122\t    // Verify final run snapshot\n   123\t    let snapshot = FsRunSnapshotStore.read_run_snapshot(base_dir, &pid).unwrap();\n   124\t    assert_eq!(snapshot.status, RunStatus::Completed);\n   125\t    assert!(snapshot.active_run.is_none());\n   126\t    assert_eq!(snapshot.completion_rounds, 1);\n   127\t    assert_eq!(snapshot.status_summary, \"completed\");\n   128\t\n   129\t    // Verify journal events\n   130\t    let e