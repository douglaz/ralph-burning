ot(base_dir, project_id);\n   662\t\n   663\t        // Write payload first\n   664\t        let payload_path = project_root\n   665\t            .join(\"history/payloads\")\n   666\t            .join(format!(\"{}.json\", payload.payload_id));\n   667\t        let payload_json = serde_json::to_string_pretty(payload)?;\n   668\t        FileSystem::write_atomic(&payload_path, &payload_json)?;\n   669\t\n   670\t        // Write artifact second — if this fails, remove the payload to maintain pairing invariant.\n   671\t        // Propagate cleanup failure so the caller knows leaked state may exist.\n   672\t        let artifact_path = project_root\n   673\t            .join(\"history/artifacts\")\n   674\t            .join(format!(\"{}.json\", artifact.artifact_id));\n   675\t        let artifact_json = serde_json::to_string_pretty(artifact)?;\n   676\t        if let Err(e) = FileSystem::write_atomic(&artifact_path, &artifact_json) {\n   677\t            if let Err(cleanup_err) = fs::remove_file(&payload_path) {\n   678\t                if cleanup_err.kind() != std::io::ErrorKind::NotFound {\n   679\t                    return Err(AppError::Io(std::io::Error::other(format!(\n   680\t                        \"artifact write failed: {}; payload cleanup also failed: {} — leaked payload at {}\",\n   681\t                        e, cleanup_err, payload_path.display()\n   682\t                    ))));\n   683\t                }\n   684\t            }\n   685\t            return Err(e);\n   686\t        }\n   687\t\n   688\t        Ok(())\n   689\t    }\n   690\t\n   691\t    fn remove_payload_artifact_pair(\n   692\t        &self,\n   693\t        base_dir: &Path,\n   694\t        project_id: &ProjectId,\n   695\t        payload_id: &str,\n   696\t        artifact_id: &str,\n   697\t    ) -> AppResult<()> {\n   698\t        let project_root = FileSystem::project_root(base_dir, project_id);\n   699\t\n   700\t        let payload_path = project_root\n   701\t            .join(\"history/payloads\")\n   702\t            .join(format!(\"{}.json\", payload_id));\n   703\t        let artifact_path = project_root\n   704\t            .join(\"history/artifacts\")\n   705\t            .join(format!(\"{}.json\", artifact_id));\n   706\t\n   707\t        // Remove both files, propagating errors so the caller knows about\n   708\t        // leaked durable history. NotFound is not an error (already cleaned up).\n   709\t        let mut errors = Vec::new();\n   710\t        if let Err(e) = fs::remove_file(&artifact_path) {\n   711\t            if e.kind() != std::io::ErrorKind::NotFound {\n   712\t                errors.push(format!(\"artifact {}: {}\", artifact_id, e));\n   713\t            }\n   714\t        }\n   715\t        if let Err(e) = fs::remove_file(&payload_path) {\n   716\t            if e.kind() != std::io::ErrorKind::NotFound {\n   717\t                errors.push(format!(\"payload {}: {}\", payload_id, e));\n   718\t            }\n   719\t        }\n   720\t\n   721\t        if errors.is_empty() {\n   722\t            Ok(())\n   723\t        } else {\n   724\t            Err(AppError::Io(std::io::Error::other(format!(\n   725\t                \"failed to remove payload/artifact pair: {}\",\n   726\t                errors.join(\"; \")\n   727\t            ))))\n   728\t        }\n   729\t    }\n   730\t}\n   731\t\n   732\t/// Filesystem-backed implementation of `RuntimeLogWritePort`.\n   733\tpub struct FsRuntimeLogWriteStore;\n   734\t\n   735\timpl RuntimeLogWritePort for FsRuntimeLogWriteStore {\n   736\t    fn append_runtime_log(\n   737\t        &self,\n   738\t        base_dir: &Path,\n   739\t        project_id: &ProjectId,\n   740\t        entry: &RuntimeLogEntry,\n   741\t    ) -> AppResult<()> {\n   742\t        let dir = FileSystem::project_root(base_dir, project_id).join(\"runtime/logs\");\n   743\t        fs::create_dir_all(&dir)?;\n   744\t        let path = dir.join(\"run.ndjson\");\n   745\t        let line = serde_json::to_string(entry)?;\n   746\t        FileSystem::append_line(&path, &line)\n   747\t    }\n   748\t}\n","exit_code":0,"status":"completed"}}
