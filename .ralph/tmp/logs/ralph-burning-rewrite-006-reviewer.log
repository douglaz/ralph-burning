{"type":"item.completed","item":{"id":"item_15","type":"command_execution","command":"/run/current-system/sw/bin/bash -lc \"nl -ba src/contexts/project_run_record/queries.rs | sed -n '1,280p'\"","aggregated_output":"     1\tuse crate::shared::error::AppResult;\n     2\t\n     3\tuse super::model::{ArtifactRecord, JournalEvent, PayloadRecord, RunSnapshot, RuntimeLogEntry};\n     4\t\n     5\t/// Read model for `run status`: canonical state only, no inference from artifacts.\n     6\t#[derive(Debug, Clone)]\n     7\tpub struct RunStatusView {\n     8\t    pub project_id: String,\n     9\t    pub status: String,\n    10\t    pub stage: Option<String>,\n    11\t    pub cycle: Option<u32>,\n    12\t    pub completion_round: Option<u32>,\n    13\t    pub summary: String,\n    14\t}\n    15\t\n    16\timpl RunStatusView {\n    17\t    pub fn from_snapshot(project_id: &str, snapshot: &RunSnapshot) -> Self {\n    18\t        match &snapshot.active_run {\n    19\t            Some(active) => Self {\n    20\t                project_id: project_id.to_owned(),\n    21\t                status: snapshot.status.display_str().to_owned(),\n    22\t                stage: Some(active.stage_cursor.stage.as_str().to_owned()),\n    23\t                cycle: Some(active.stage_cursor.cycle),\n    24\t                completion_round: Some(active.stage_cursor.completion_round),\n    25\t                summary: snapshot.status_summary.clone(),\n    26\t            },\n    27\t            None => Self {\n    28\t                project_id: project_id.to_owned(),\n    29\t                status: snapshot.status.display_str().to_owned(),\n    30\t                stage: None,\n    31\t                cycle: None,\n    32\t                completion_round: None,\n    33\t                summary: snapshot.status_summary.clone(),\n    34\t            },\n    35\t        }\n    36\t    }\n    37\t}\n    38\t\n    39\t/// Read model for `run history`: durable history only (journal + payloads + artifacts).\n    40\t/// Runtime logs never appear here.\n    41\t#[derive(Debug, Clone)]\n    42\tpub struct RunHistoryView {\n    43\t    pub project_id: String,\n    44\t    pub events: Vec<JournalEvent>,\n    45\t    pub payloads: Vec<PayloadRecord>,\n    46\t    pub artifacts: Vec<ArtifactRecord>,\n    47\t}\n    48\t\n    49\t/// Read model for `run tail`: durable history by default, with optional runtime logs.\n    50\t#[derive(Debug, Clone)]\n    51\tpub struct RunTailView {\n    52\t    pub project_id: String,\n    53\t    pub events: Vec<JournalEvent>,\n    54\t    pub payloads: Vec<PayloadRecord>,\n    55\t    pub artifacts: Vec<ArtifactRecord>,\n    56\t    pub runtime_logs: Option<Vec<RuntimeLogEntry>>,\n    57\t}\n    58\t\n    59\t/// Build a status view from canonical run state.\n    60\tpub fn build_status_view(project_id: &str, snapshot: &RunSnapshot) -> RunStatusView {\n    61\t    RunStatusView::from_snapshot(project_id, snapshot)\n    62\t}\n    63\t\n    64\t/// Build a history view from durable records only. No runtime logs.\n    65\tpub fn build_history_view(\n    66\t    project_id: &str,\n    67\t    events: Vec<JournalEvent>,\n    68\t    payloads: Vec<PayloadRecord>,\n    69\t    artifacts: Vec<ArtifactRecord>,\n    70\t) -> RunHistoryView {\n    71\t    RunHistoryView {\n    72\t        project_id: project_id.to_owned(),\n    73\t        events,\n    74\t        payloads,\n    75\t        artifacts,\n    76\t    }\n    77\t}\n    78\t\n    79\t/// Build a tail view: durable history always, runtime logs only when requested.\n    80\tpub fn build_tail_view(\n    81\t    project_id: &str,\n    82\t    events: Vec<JournalEvent>,\n    83\t    payloads: Vec<PayloadRecord>,\n    84\t    artifacts: Vec<ArtifactRecord>,\n    85\t    include_logs: bool,\n    86\t    runtime_logs: Vec<RuntimeLogEntry>,\n    87\t) -> RunTailView {\n    88\t    RunTailView {\n    89\t        project_id: project_id.to_owned(),\n    90\t        events,\n    91\t        payloads,\n    92\t        artifacts,\n    93\t        runtime_logs: if include_logs {\n    94\t            Some(runtime_logs)\n    95\t        } else {\n    96\t            None\n    97\t        },\n    98\t    }\n    99\t}\n   100\t\n   101\t/// Validate that durable history records are consistent:\n   102\t/// every artifact has a matching payload and every payload has a matching artifact.\n   103\t/// Payload + artifact are treated as a paired durable-history unit.\n   104\tpub fn validate_history_consistency(\n   105\t    payloads: &[PayloadRecord],\n   106\t    artifacts: &[ArtifactRecord],\n   107\t) -> AppResult<()> {\n   108\t    // Check orphaned artifacts (artifact without matching payload)\n   109\t    for artifact in artifacts {\n   110\t        if !payloads.iter().any(|p| p.payload_id == artifact.payload_id) {\n   111\t            return Err(crate::shared::error::AppError::CorruptRecord {\n   112\t                file: format!(\"history/artifacts/{}\", artifact.artifact_id),\n   113\t                details: format!(\n   114\t                    \"artifact references payload '{}' which does not exist\",\n   115\t                    artifact.payload_id\n   116\t                ),\n   117\t            });\n   118\t        }\n   119\t    }\n   120\t    // Check orphaned payloads (payload without matching artifact)\n   121\t    for payload in payloads {\n   122\t        if !artifacts.iter().any(|a| a.payload_id == payload.payload_id) {\n   123\t            return Err(crate::shared::error::AppError::CorruptRecord {\n   124\t                file: format!(\"history/payloads/{}\", payload.payload_id),\n   125\t                details: \"payload has no matching artifact\".to_owned(),\n   126\t            });\n   127\t        }\n   128\t    }\n   129\t    Ok(())\n   130\t}\n","exit_code":0,"status":"completed"}}
{"type":"item.completed","item":{"id":"item_14","type":"command_execution","command":"/run/current-system/sw/bin/bash -lc \"nl -ba src/contexts/project_run_record/journal.rs | sed -n '1,320p'\"","aggregated_output":"     1\tuse crate::shared::error::{AppError, AppResult};\n     2\t\n     3\tuse super::model::{JournalEvent, JournalEventType};\n     4\t\n     5\t/// Validates that a new event's sequence follows the last known sequence.\n     6\t/// The first event must have sequence 1.\n     7\tpub fn validate_sequence(last_sequence: u64, event: &JournalEvent) -> AppResult<()> {\n     8\t    let expected = last_sequence + 1;\n     9\t    if event.sequence != expected {\n    10\t        return Err(AppError::JournalSequence {\n    11\t            details: format!(\"expected sequence {expected}, got {}\", event.sequence),\n    12\t        });\n    13\t    }\n    14\t    Ok(())\n    15\t}\n    16\t\n    17\t/// Serializes a journal event to a single NDJSON line (no trailing newline).\n    18\tpub fn serialize_event(event: &JournalEvent) -> AppResult<String> {\n    19\t    Ok(serde_json::to_string(event)?)\n    20\t}\n    21\t\n    22\t/// Deserializes a single NDJSON line into a journal event.\n    23\tpub fn deserialize_event(line: &str) -> AppResult<JournalEvent> {\n    24\t    let trimmed = line.trim();\n    25\t    if trimmed.is_empty() {\n    26\t        return Err(AppError::CorruptRecord {\n    27\t            file: \"journal.ndjson\".to_owned(),\n    28\t            details: \"empty line in journal\".to_owned(),\n    29\t        });\n    30\t    }\n    31\t    serde_json::from_str(trimmed).map_err(|e| AppError::CorruptRecord {\n    32\t        file: \"journal.ndjson\".to_owned(),\n    33\t        details: format!(\"invalid journal event: {e}\"),\n    34\t    })\n    35\t}\n    36\t\n    37\t/// Parses the full contents of a journal.ndjson file into ordered events.\n    38\t/// Validates monotonic sequence ordering and journal integrity (first event\n    39\t/// must be `project_created` with sequence 1).\n    40\tpub fn parse_journal(contents: &str) -> AppResult<Vec<JournalEvent>> {\n    41\t    let mut events = Vec::new();\n    42\t    let mut last_sequence = 0u64;\n    43\t\n    44\t    for line in contents.lines() {\n    45\t        if line.trim().is_empty() {\n    46\t            continue;\n    47\t        }\n    48\t        let event = deserialize_event(line)?;\n    49\t        validate_sequence(last_sequence, &event)?;\n    50\t        last_sequence = event.sequence;\n    51\t        events.push(event);\n    52\t    }\n    53\t\n    54\t    validate_journal_integrity(&events)?;\n    55\t\n    56\t    Ok(events)\n    57\t}\n    58\t\n    59\t/// Validates that a journal has the required structure:\n    60\t/// - Must not be empty (must contain at least the initial `project_created` event)\n    61\t/// - First event must be `project_created` with sequence 1\n    62\tpub fn validate_journal_integrity(events: &[JournalEvent]) -> AppResult<()> {\n    63\t    if events.is_empty() {\n    64\t        return Err(AppError::CorruptRecord {\n    65\t            file: \"journal.ndjson\".to_owned(),\n    66\t            details: \"journal is empty — must contain at least the initial project_created event\"\n    67\t                .to_owned(),\n    68\t        });\n    69\t    }\n    70\t\n    71\t    let first = &events[0];\n    72\t    if first.event_type != JournalEventType::ProjectCreated {\n    73\t        return Err(AppError::CorruptRecord {\n    74\t            file: \"journal.ndjson\".to_owned(),\n    75\t            details: format!(\n    76\t                \"first journal event type is '{:?}', expected 'project_created'\",\n    77\t                first.event_type\n    78\t            ),\n    79\t        });\n    80\t    }\n    81\t\n    82\t    Ok(())\n    83\t}\n    84\t\n    85\t/// Returns the last sequence number from a set of events, or 0 if empty.\n    86\tpub fn last_sequence(events: &[JournalEvent]) -> u64 {\n    87\t    events.last().map_or(0, |e| e.sequence)\n    88\t}\n    89\t\n    90\t// ── Lifecycle event builders ────────────────────────────────────────────────\n    91\t\n    92\tuse chrono::{DateTime, Utc};\n    93\tuse crate::shared::domain::{RunId, StageId};\n    94\t\n    95\t/// Build a `run_started` journal event.\n    96\tpub fn run_started_event(\n    97\t    sequence: u64,\n    98\t    timestamp: DateTime<Utc>,\n    99\t    run_id: &RunId,\n   100\t    first_stage: StageId,\n   101\t) -> JournalEvent {\n   102\t    JournalEvent {\n   103\t        sequence,\n   104\t        timestamp,\n   105\t        event_type: JournalEventType::RunStarted,\n   106\t        details: serde_json::json!({\n   107\t            \"run_id\": run_id.as_str(),\n   108\t            \"first_stage\": first_stage.as_str(),\n   109\t        }),\n   110\t    }\n   111\t}\n   112\t\n   113\t/// Build a `stage_entered` journal event.\n   114\tpub fn stage_entered_event(\n   115\t    sequence: u64,\n   116\t    timestamp: DateTime<Utc>,\n   117\t    run_id: &RunId,\n   118\t    stage_id: StageId,\n   119\t    cycle: u32,\n   120\t    attempt: u32,\n   121\t) -> JournalEvent {\n   122\t    JournalEvent {\n   123\t        sequence,\n   124\t        timestamp,\n   125\t        event_type: JournalEventType::StageEntered,\n   126\t        details: serde_json::json!({\n   127\t            \"run_id\": run_id.as_str(),\n   128\t            \"stage_id\": stage_id.as_str(),\n   129\t            \"cycle\": cycle,\n   130\t            \"attempt\": attempt,\n   131\t        }),\n   132\t    }\n   133\t}\n   134\t\n   135\t/// Build a `stage_completed` journal event.\n   136\t#[allow(clippy::too_many_arguments)]\n   137\tpub fn stage_completed_event(\n   138\t    sequence: u64,\n   139\t    timestamp: DateTime<Utc>,\n   140\t    run_id: &RunId,\n   141\t    stage_id: StageId,\n   142\t    cycle: u32,\n   143\t    attempt: u32,\n   144\t    payload_id: &str,\n   145\t    artifact_id: &str,\n   146\t) -> JournalEvent {\n   147\t    JournalEvent {\n   148\t        sequence,\n   149\t        timestamp,\n   150\t        event_type: JournalEventType::StageCompleted,\n   151\t        details: serde_json::json!({\n   152\t            \"run_id\": run_id.as_str(),\n   153\t            \"stage_id\": stage_id.as_str(),\n   154\t            \"cycle\": cycle,\n   155\t            \"attempt\": attempt,\n   156\t            \"payload_id\": payload_id,\n   157\t            \"artifact_id\": artifact_id,\n   158\t        }),\n   159\t    }\n   160\t}\n   161\t\n   162\t/// Build a `run_completed` journal event.\n   163\tpub fn run_completed_event(\n   164\t    sequence: u64,\n   165\t    timestamp: DateTime<Utc>,\n   166\t    run_id: &RunId,\n   167\t    completion_rounds: u32,\n   168\t) -> JournalEvent {\n   169\t    JournalEvent {\n   170\t        sequence,\n   171\t        timestamp,\n   172\t        event_type: JournalEventType::RunCompleted,\n   173\t        details: serde_json::json!({\n   174\t            \"run_id\": run_id.as_str(),\n   175\t            \"completion_rounds\": completion_rounds,\n   176\t        }),\n   177\t    }\n   178\t}\n   179\t\n   180\t/// Build a `run_failed` journal event.\n   181\tpub fn run_failed_event(\n   182\t    sequence: u64,\n   183\t    timestamp: DateTime<Utc>,\n   184\t    run_id: &RunId,\n   185\t    stage_id: StageId,\n   186\t    failure_class: &str,\n   187\t    message: &str,\n   188\t) -> JournalEvent {\n   189\t    JournalEvent {\n   190\t        sequence,\n   191\t        timestamp,\n   192\t        event_type: JournalEventType::RunFailed,\n   193\t        details: serde_json::json!({\n   194\t            \"run_id\": run_id.as_str(),\n   195\t            \"stage_id\": stage_id.as_str(),\n   196\t            \"failure_class\": failure_class,\n   197\t            \"message\": message,\n   198\t        }),\n   199\t    }\n   200\t}\n","exit_code":0,"status":"completed"}}
