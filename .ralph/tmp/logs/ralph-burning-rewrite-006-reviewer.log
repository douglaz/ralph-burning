\"set\", \"prompt_review.enabled\", \"false\"])\n  2409\t        .current_dir(temp_dir.path())\n  2410\t        .output()\n  2411\t        .expect(\"config set\");\n  2412\t    assert!(\n  2413\t        set_output.status.success(),\n  2414\t        \"config set failed: {}\",\n  2415\t        String::from_utf8_lossy(&set_output.stderr)\n  2416\t    );\n  2417\t\n  2418\t    setup_standard_project(&temp_dir, \"no-pr-cli\");\n  2419\t\n  2420\t    let start = Command::new(binary())\n  2421\t        .args([\"run\", \"start\"])\n  2422\t        .current_dir(temp_dir.path())\n  2423\t        .output()\n  2424\t        .expect(\"run start\");\n  2425\t    assert!(\n  2426\t        start.status.success(),\n  2427\t        \"run start failed: {}\",\n  2428\t        String::from_utf8_lossy(&start.stderr)\n  2429\t    );\n  2430\t\n  2431\t    // Verify 7 payloads (no prompt_review)\n  2432\t    let payloads_dir = temp_dir\n  2433\t        .path()\n  2434\t        .join(\".ralph-burning/projects/no-pr-cli/history/payloads\");\n  2435\t    let payload_count = fs::read_dir(&payloads_dir)\n  2436\t        .expect(\"read payloads dir\")\n  2437\t        .filter_map(|e| e.ok())\n  2438\t        .filter(|e| e.path().extension().is_some_and(|ext| ext == \"json\"))\n  2439\t        .count();\n  2440\t    assert_eq!(\n  2441\t        payload_count, 7,\n  2442\t        \"expected 7 payloads without prompt_review, got {payload_count}\"\n  2443\t    );\n  2444\t\n  2445\t    // Verify no prompt_review stage in journal\n  2446\t    let journal = fs::read_to_string(\n  2447\t        temp_dir\n  2448\t            .path()\n  2449\t            .join(\".ralph-burning/projects/no-pr-cli/journal.ndjson\"),\n  2450\t    )\n  2451\t    .expect(\"read journal\");\n  2452\t    assert!(\n  2453\t        !journal.contains(\"\\\"prompt_review\\\"\"),\n  2454\t        \"journal should not contain prompt_review stage when disabled\"\n  2455\t    );\n  2456\t\n  2457\t    // Verify completed status\n  2458\t    let run_json = fs::read_to_string(\n  2459\t        temp_dir\n  2460\t            .path()\n  2461\t            .join(\".ralph-burning/projects/no-pr-cli/run.json\"),\n  2462\t    )\n  2463\t    .expect(\"read run.json\");\n  2464\t    assert!(\n  2465\t        run_json.contains(\"\\\"completed\\\"\"),\n  2466\t        \"run should be completed, got: {run_json}\"\n  2467\t    );\n  2468\t}\n  2469\t\n  2470\t#[test]\n  2471\tfn run_start_preflight_failure_leaves_state_unchanged() {\n  2472\t    let temp_dir = initialize_workspace_fixture();\n  2473\t    setup_standard_project(&temp_dir, \"preflight-cli\");\n  2474\t\n  2475\t    // Corrupt the run.json to simulate a state that would fail validation\n  2476\t    // before the engine can proceed. We test that the CLI properly handles\n  2477\t    // preflight-like errors with no state mutation.\n  2478\t    //\n  2479\t    // The stub backend always passes preflight, so we verify the no-mutation\n  2480\t    // invariant via the workspace-version validation path: an unsupported\n  2481\t    // workspace version must leave all project state unchanged.\n  2482\t    let ws_toml_path = temp_dir.path().join(\".ralph-burning/workspace.toml\");\n  2483\t    let ws_toml = fs::read_to_string(&ws_toml_path).expect(\"read workspace.toml\");\n  2484\t    let corrupted = ws_toml.replace(\"version = 1\", \"version = 999\");\n  2485\t    fs::write(&ws_toml_path, corrupted).expect(\"write corrupted workspace.toml\");\n  2486\t\n  2487\t    // Capture pre-run state\n  2488\t    let pre_run_json = fs::read_to_string(\n  2489\t        temp_dir\n  2490\t            .path()\n  2491\t            .join(\".ralph-burning/projects/preflight-cli/run.json\"),\n  2492\t    )\n  2493\t    .expect(\"read run.json before\");\n  2494\t    let pre_journal = fs::read_to_string(\n  2495\t        temp_dir\n  2496\t            .path()\n  2497\t            .join(\".ralph-burning/projects/preflight-cli/journal.ndjson\"),\n  2498\t    )\n  2499\t    .expect(\"read journal before\");\n  2500\t\n  2501\t    let output = Command::new(binary())\n  2502\t        .args([\"run\", \"start\"])\n  2503\t        .current_dir(temp_dir.path())\n  2504\t        .output()\n  2505\t        .expect(\"run start\");\n  2506\t\n  2507\t    assert!(!output.status.success(), \"run start should fail with bad workspace version\");\n  2508\t\n  2509\t    // Verify NO state mutation occurred\n  2510\t    let post_run_json = fs::read_to_string(\n  2511\t        temp_dir\n  2512\t            .path()\n  2513\t            .join(\".ralph-burning/projects/preflight-cli/run.json\"),\n  2514\t    )\n  2515\t    .expect(\"read run.json after\");\n  2516\t    let post_journal = fs::read_to_string(\n  2517\t        temp_dir\n  2518\t            .path()\n  2519\t            .join(\".ralph-burning/projects/preflight-cli/journal.ndjson\"),\n  2520\t    )\n  2521\t    .expect(\"read journal after\");\n  2522\t\n  2523\t    assert_eq!(\n  2524\t        pre_run_json, post_run_json,\n  2525\t        \"run.json must not change on pre-engine failure\"\n  2526\t    );\n  2527\t    assert_eq!(\n  2528\t        pre_journal, post_journal,\n  2529\t        \"journal must not change on pre-engine failure\"\n  2530\t    );\n  2531\t\n  2532\t    let payloads_dir = temp_dir\n  2533\t        .path()\n  2534\t        .join(\".ralph-burning/projects/preflight-cli/history/payloads\");\n  2535\t    let payload_count = fs::read_dir(&payloads_dir)\n  2536\t        .expect(\"read payloads dir\")\n  2537\t        .filter_map(|e| e.ok())\n  2538\t        .count();\n  2539\t    assert_eq!(payload_count, 0, \"no payloads should exist after preflight failure\");\n  2540\t}\n  2541\t\n  2542\t#[test]\n  2543\tfn run_start_backend_preflight_failure_leaves_state_unchanged() {\n  2544\t    let temp_dir = initialize_workspace_fixture();\n  2545\t    setup_standard_project(&temp_dir, \"preflight-backend\");\n  2546\t\n  2547\t    // Capture pre-run state\n  2548\t    let pre_run_json = fs::read_to_string(\n  2549\t        temp_dir\n  2550\t            .path()\n  2551\t            .join(\".ralph-burning/projects/preflight-backend/run.json\"),\n  2552\t    )\n  2553\t    .expect(\"read run.json before\");\n  2554\t    let pre_journal = fs::read_to_string(\n  2555\t        temp_dir\n  2556\t            .path()\n  2557\t            .join(\".ralph-burning/projects/preflight-backend/journal.ndjson\"),\n  2558\t    )\n  2559\t    .expect(\"read journal before\");\n  2560\t\n  2561\t    // Use env var to make the backend unavailable at preflight\n  2562\t    let output = Command::new(binary())\n  2563\t        .args([\"run\", \"start\"])\n  2564\t        .env(\"RALPH_BURNING_TEST_BACKEND_UNAVAILABLE\", \"1\")\n  2565\t        .current_dir(temp_dir.path())\n  2566\t        .output()\n  2567\t        .expect(\"run start\");\n  2568\t\n  2569\t    assert!(\n  2570\t        !output.status.success(),\n  2571\t        \"run start should fail with unavailable backend\"\n  2572\t    );\n  2573\t    let stderr = String::from_utf8_lossy(&output.stderr);\n  2574\t    assert!(\n  2575\t        stderr.contains(\"preflight\") || stderr.contains(\"unavailable\"),\n  2576\t        \"error should reference preflight or unavailable, got: {stderr}\"\n  2577\t    );\n  2578\t\n  2579\t    // Verify NO state mutation occurred — byte-identical\n  2580\t    let post_run_json = fs::read_to_string(\n  2581\t        temp_dir\n  2582\t            .path()\n  2583\t            .join(\".ralph-burning/projects/preflight-backend/run.json\"),\n  2584\t    )\n  2585\t    .expect(\"read run.json after\");\n  2586\t    let post_journal = fs::read_to_string(\n  2587\t        temp_dir\n  2588\t            .path()\n  2589\t            .join(\".ralph-burning/projects/preflight-backend/journal.ndjson\"),\n  2590\t    )\n  2591\t    .expect(\"read journal after\");\n  2592\t\n  2593\t    assert_eq!(\n  2594\t        pre_run_json, post_run_json,\n  2595\t        \"run.json must be byte-identical after preflight failure\"\n  2596\t    );\n  2597\t    assert_eq!(\n  2598\t        pre_journal, post_journal,\n  2599\t        \"journal must be byte-identical after preflight failure\"\n  2600\t    );\n  2601\t\n  2602\t    let payloads_dir = temp_dir\n  2603\t        .path()\n  2604\t        .join(\".ralph-burning/projects/preflight-backend/history/payloads\");\n  2605\t    let payload_count = fs::read_dir(&payloads_dir)\n  2606\t        .expect(\"read payloads dir\")\n  2607\t        .filter_map(|e| e.ok())\n  2608\t        .count();\n  2609\t    assert_eq!(payload_count, 0, \"no payloads should exist after preflight failure\");\n  2610\t\n  2611\t    let artifacts_dir = temp_dir\n  2612\t        .path()\n  2613\t        .join(\".ralph-burning/projects/preflight-backend/history/artifacts\");\n  2614\t    let artifact_count = fs::read_dir(&artifacts_dir)\n  2615\t        .expect(\"read artifacts dir\")\n  2616\t        .filter_map(|e| e.ok())\n  2617\t        .count();\n  2618\t    assert_eq!(artifact_count, 0, \"no artifacts should exist after preflight failure\");\n  2619\t}\n  2620\t\n  2621\t#[test]\n  2622\tfn run_start_mid_stage_failure_no_partial_durable_history() {\n  2623\t    let temp_dir = initialize_workspace_fixture();\n  2624\t    setup_standard_project(&temp_dir, \"midstage-fail\");\n  2625\t\n  2626\t    // Use env var to fail the first stage's invocation (prompt_review is\n  2627\t    // enabled by default, so it's the first stage executed).\n  2628\t    let output = Command::new(binary())\n  2629\t        .args([\"run\", \"start\"])\n  2630\t        .env(\"RALPH_BURNING_TEST_FAIL_INVOKE_STAGE\", \"prompt_review\")\n  2631\t        .current_dir(temp_dir.path())\n  2632\t        .output()\n  2633\t        .expect(\"run start\");\n  2634\t\n  2635\t    assert!(\n  2636\t        !output.status.success(),\n  2637\t        \"run start should fail on mid-stage invoke failure\"\n  2638\t    );\n  2639\t\n  2640\t    // Run snapshot must be failed, not running\n  2641\t    let run_json = fs::read_to_string(\n  2642\t        temp_dir\n  2643\t            .path()\n  2644\t            .join(\".ralph-burning/projects/midstage-fail/run.json\"),\n  2645\t    )\n  2646\t    .expect(\"read run.json\");\n  2647\t    assert!(\n  2648\t        run_json.contains(\"\\\"failed\\\"\"),\n  2649\t        \"run.json should show failed status, got: {run_json}\"\n  2650\t    );\n  2651\t    assert!(\n  2652\t        run_json.contains(\"\\\"active_run\\\":null\") || run_json.contains(\"\\\"active_run\\\": null\"),\n  2653\t        \"active_run should be null after failure\"\n  2654\t    );\n  2655\t\n  2656\t    // No payload or artifact files should exist — no partial durable history\n  2657\t    let payloads_dir = temp_dir\n  2658\t        .path()\n  2659\t        .join(\".ralph-burning/projects/midstage-fail/history/payloads\");\n  2660\t    let payload_count = fs::read_dir(&payloads_dir)\n  2661\t        .expect(\"read payloads dir\")\n  2662\t        .filter_map(|e| e.ok())\n  2663\t        .filter(|e| e.path().extension().is_some_and(|ext| ext == \"json\"))\n  2664\t        .count();\n  2665\t    assert_eq!(\n  2666\t        payload_count, 0,\n  2667\t        \"no payloads should exist after mid-stage failure\"\n  2668\t    );\n  2669\t\n  2670\t    let artifacts_dir = temp_dir\n  2671\t        .path()\n  2672\t        .join(\".ralph-burning/projects/midstage-fail/history/artifacts\");\n  2673\t    let artifact_count = fs::read_dir(&artifacts_dir)\n  2674\t        .expect(\"read artifacts dir\")\n  2675\t        .filter_map(|e| e.ok())\n  2676\t        .filter(|e| e.path().extension().is_some_and(|ext| ext == \"json\"))\n  2677\t        .count();\n  2678\t    assert_eq!(\n  2679\t        artifact_count, 0,\n  2680\t        \"no artifacts should exist after mid-stage failure\"\n  2681\t    );\n  2682\t\n  2683\t    // No stage_completed event should exist in the journal\n  2684\t    let journal = fs::read_to_string(\n  2685\t        temp_dir\n  2686\t            .path()\n  2687\t            .join(\".ralph-burning/projects/midstage-fail/journal.ndjson\"),\n  2688\t    )\n  2689\t    .expect(\"read journal\");\n  2690\t    assert!(\n  2691\t        !journal.contains(\"\\\"stage_completed\\\"\"),\n  2692\t        \"no stage_completed event should exist after mid-stage failure\"\n  2693\t    );\n  2694\t\n  2695\t    // Journal should end with run_failed event\n  2696\t    let last_line = journal.lines().last().expect(\"journal should not be empty\");\n  2697\t    assert!(\n  2698\t        last_line.contains(\"\\\"run_failed\\\"\"),\n  2699\t        \"last journal event should be run_failed, got: {last_line}\"\n  2700\t    );\n  2701\t}\n","exit_code":0,"status":"completed"}}
