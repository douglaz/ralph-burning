\", project_id),\n   556\t                details: \"canonical file is missing\".to_owned(),\n   557\t            }),\n   558\t            Err(e) => Err(e.into()),\n   559\t        }\n   560\t    }\n   561\t}\n   562\t\n   563\t/// Filesystem-backed implementation of `ActiveProjectPort`.\n   564\tpub struct FsActiveProjectStore;\n   565\t\n   566\timpl ActiveProjectPort for FsActiveProjectStore {\n   567\t    fn read_active_project_id(&self, base_dir: &Path) -> AppResult<Option<String>> {\n   568\t        FileSystem::read_active_project(&FileSystem::workspace_root_path(base_dir))\n   569\t    }\n   570\t\n   571\t    fn clear_active_project(&self, base_dir: &Path) -> AppResult<()> {\n   572\t        let path = FileSystem::workspace_root_path(base_dir).join(ACTIVE_PROJECT_FILE);\n   573\t        match fs::remove_file(&path) {\n   574\t            Ok(()) => Ok(()),\n   575\t            Err(e) if e.kind() == std::io::ErrorKind::NotFound => Ok(()),\n   576\t            Err(e) => Err(e.into()),\n   577\t        }\n   578\t    }\n   579\t\n   580\t    fn write_active_project(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<()> {\n   581\t        FileSystem::write_active_project(\n   582\t            &FileSystem::workspace_root_path(base_dir),\n   583\t            project_id.as_str(),\n   584\t        )\n   585\t    }\n   586\t}\n   587\t\n   588\t/// Filesystem-backed implementation of `RawOutputPort`.\n   589\tpub struct FsRawOutputStore;\n   590\t\n   591\timpl RawOutputPort for FsRawOutputStore {\n   592\t    fn persist_raw_output(\n   593\t        &self,\n   594\t        project_root: &Path,\n   595\t        invocation_id: &str,\n   596\t        contents: &str,\n   597\t    ) -> AppResult<RawOutputReference> {\n   598\t        let path = project_root\n   599\t            .join(\"runtime/backend\")\n   600\t            .join(format!(\"{invocation_id}.raw\"));\n   601\t        FileSystem::write_atomic(&path, contents)?;\n   602\t        Ok(RawOutputReference::Stored(path))\n   603\t    }\n   604\t}\n   605\t\n   606\t/// Filesystem-backed implementation of `SessionStorePort`.\n   607\tpub struct FsSessionStore;\n   608\t\n   609\timpl SessionStorePort for FsSessionStore {\n   610\t    fn load_sessions(&self, project_root: &Path) -> AppResult<PersistedSessions> {\n   611\t        let path = project_root.join(SESSIONS_FILE);\n   612\t        match fs::read_to_string(&path) {\n   613\t            Ok(raw) => serde_json::from_str(&raw).map_err(|error| AppError::CorruptRecord {\n   614\t                file: format!(\"{}/{}\", project_root.display(), SESSIONS_FILE),\n   615\t                details: error.to_string(),\n   616\t            }),\n   617\t            Err(error) if error.kind() == std::io::ErrorKind::NotFound => {\n   618\t                Err(AppError::CorruptRecord {\n   619\t                    file: format!(\"{}/{}\", project_root.display(), SESSIONS_FILE),\n   620\t                    details: \"canonical file is missing\".to_owned(),\n   621\t                })\n   622\t            }\n   623\t            Err(error) => Err(error.into()),\n   624\t        }\n   625\t    }\n   626\t\n   627\t    fn save_sessions(&self, project_root: &Path, sessions: &PersistedSessions) -> AppResult<()> {\n   628\t        let path = project_root.join(SESSIONS_FILE);\n   629\t        let contents = serde_json::to_string_pretty(sessions)?;\n   630\t        FileSystem::write_atomic(&path, &contents)\n   631\t    }\n   632\t}\n   633\t\n   634\t/// Filesystem-backed implementation of `RunSnapshotWritePort`.\n   635\tpub struct FsRunSnapshotWriteStore;\n   636\t\n   637\timpl RunSnapshotWritePort for FsRunSnapshotWriteStore {\n   638\t    fn write_run_snapshot(\n   639\t        &self,\n   640\t        base_dir: &Path,\n   641\t        project_id: &ProjectId,\n   642\t        snapshot: &RunSnapshot,\n   643\t    ) -> AppResult<()> {\n   644\t        let path = FileSystem::project_root(base_dir, project_id).join(RUN_FILE);\n   645\t        let contents = serde_json::to_string_pretty(snapshot)?;\n   646\t        FileSystem::write_atomic(&path, &contents)\n   647\t    }\n   648\t}\n   649\t\n   650\t/// Filesystem-backed implementation of `PayloadArtifactWritePort`.\n   651\tpub struct FsPayloadArtifactWriteStore;\n   652\t\n   653\timpl PayloadArtifactWritePort for FsPayloadArtifactWriteStore {\n   654\t    fn write_payload_artifact_pair(\n   655\t        &self,\n   656\t        base_dir: &Path,\n   657\t        project_id: &ProjectId,\n   658\t        payload: &PayloadRecord,\n   659\t        artifact: &ArtifactRecord,\n   660\t    ) -> AppResult<()> {\n   661\t        let project_root = FileSystem::project_root(base_dir, project_id);\n   662\t\n   663\t        // Write payload first\n   664\t        let payload_path = project_root\n   665\t            .join(\"history/payloads\")\n   666\t            .join(format!(\"{}.json\", payload.payload_id));\n   667\t        let payload_json = serde_json::to_string_pretty(payload)?;\n   668\t        FileSystem::write_atomic(&payload_path, &payload_json)?;\n   669\t\n   670\t        // Write artifact second — if this fails, remove the payload to maintain pairing invariant\n   671\t        let artifact_path = project_root\n   672\t            .join(\"history/artifacts\")\n   673\t            .join(format!(\"{}.json\", artifact.artifact_id));\n   674\t        let artifact_json = serde_json::to_string_pretty(artifact)?;\n   675\t        if let Err(e) = FileSystem::write_atomic(&artifact_path, &artifact_json) {\n   676\t            let _ = fs::remove_file(&payload_path);\n   677\t            return Err(e);\n   678\t        }\n   679\t\n   680\t        Ok(())\n   681\t    }\n   682\t}\n   683\t\n   684\t/// Filesystem-backed implementation of `RuntimeLogWritePort`.\n   685\tpub struct FsRuntimeLogWriteStore;\n   686\t\n   687\timpl RuntimeLogWritePort for FsRuntimeLogWriteStore {\n   688\t    fn append_runtime_log(\n   689\t        &self,\n   690\t        base_dir: &Path,\n   691\t        project_id: &ProjectId,\n   692\t        entry: &RuntimeLogEntry,\n   693\t    ) -> AppResult<()> {\n   694\t        let dir = FileSystem::project_root(base_dir, project_id).join(\"runtime/logs\");\n   695\t        fs::create_dir_all(&dir)?;\n   696\t        let path = dir.join(\"run.ndjson\");\n   697\t        let line = serde_json::to_string(entry)?;\n   698\t        FileSystem::append_line(&path, &line)\n   699\t    }\n   700\t}\n","exit_code":0,"status":"completed"}}
