{"type":"item.completed","item":{"id":"item_9","type":"command_execution","command":"/run/current-system/sw/bin/bash -lc \"nl -ba ralph-burning-rewrite/src/contexts/project_run_record/service.rs | sed -n '1,420p'\"","aggregated_output":"     1\tuse std::path::Path;\n     2\t\n     3\tuse chrono::{DateTime, Utc};\n     4\t\n     5\tuse crate::shared::domain::{FlowPreset, ProjectId};\n     6\tuse crate::shared::error::{AppError, AppResult};\n     7\t\n     8\tuse super::journal;\n     9\tuse super::model::{\n    10\t    ArtifactRecord, JournalEvent, JournalEventType, PayloadRecord, ProjectDetail, ProjectListEntry,\n    11\t    ProjectRecord, ProjectStatusSummary, RunSnapshot, RuntimeLogEntry, SessionStore,\n    12\t};\n    13\tuse super::queries::{self, RunHistoryView, RunStatusView, RunTailView};\n    14\t\n    15\t/// Port for reading and writing project records.\n    16\tpub trait ProjectStorePort {\n    17\t    fn project_exists(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<bool>;\n    18\t    fn read_project_record(\n    19\t        &self,\n    20\t        base_dir: &Path,\n    21\t        project_id: &ProjectId,\n    22\t    ) -> AppResult<ProjectRecord>;\n    23\t    fn list_project_ids(&self, base_dir: &Path) -> AppResult<Vec<ProjectId>>;\n    24\t\n    25\t    /// Stage a project for deletion: makes it invisible to list/show but\n    26\t    /// keeps data on disk for potential rollback.\n    27\t    fn stage_delete(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<()>;\n    28\t\n    29\t    /// Finalize a staged delete: permanently removes the project data.\n    30\t    fn commit_delete(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<()>;\n    31\t\n    32\t    /// Roll back a staged delete: restores the project to its canonical path.\n    33\t    fn rollback_delete(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<()>;\n    34\t\n    35\t    /// Atomically stage and commit a new project. If any step fails,\n    36\t    /// the project must not be visible to list/show.\n    37\t    fn create_project_atomic(\n    38\t        &self,\n    39\t        base_dir: &Path,\n    40\t        record: &ProjectRecord,\n    41\t        prompt_contents: &str,\n    42\t        run_snapshot: &RunSnapshot,\n    43\t        initial_journal_line: &str,\n    44\t        sessions: &SessionStore,\n    45\t    ) -> AppResult<()>;\n    46\t}\n    47\t\n    48\t/// Port for reading and appending journal events.\n    49\tpub trait JournalStorePort {\n    50\t    fn read_journal(&self, base_dir: &Path, project_id: &ProjectId)\n    51\t        -> AppResult<Vec<JournalEvent>>;\n    52\t    fn append_event(&self, base_dir: &Path, project_id: &ProjectId, line: &str) -> AppResult<()>;\n    53\t}\n    54\t\n    55\t/// Port for reading payload and artifact durable history.\n    56\tpub trait ArtifactStorePort {\n    57\t    fn list_payloads(\n    58\t        &self,\n    59\t        base_dir: &Path,\n    60\t        project_id: &ProjectId,\n    61\t    ) -> AppResult<Vec<PayloadRecord>>;\n    62\t    fn list_artifacts(\n    63\t        &self,\n    64\t        base_dir: &Path,\n    65\t        project_id: &ProjectId,\n    66\t    ) -> AppResult<Vec<ArtifactRecord>>;\n    67\t}\n    68\t\n    69\t/// Port for reading runtime logs (separate from durable history).\n    70\tpub trait RuntimeLogStorePort {\n    71\t    fn read_runtime_logs(\n    72\t        &self,\n    73\t        base_dir: &Path,\n    74\t        project_id: &ProjectId,\n    75\t    ) -> AppResult<Vec<RuntimeLogEntry>>;\n    76\t}\n    77\t\n    78\t/// Port for reading/writing the run snapshot.\n    79\tpub trait RunSnapshotPort {\n    80\t    fn read_run_snapshot(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<RunSnapshot>;\n    81\t}\n    82\t\n    83\t/// Port for writing the run snapshot atomically.\n    84\tpub trait RunSnapshotWritePort {\n    85\t    fn write_run_snapshot(\n    86\t        &self,\n    87\t        base_dir: &Path,\n    88\t        project_id: &ProjectId,\n    89\t        snapshot: &RunSnapshot,\n    90\t    ) -> AppResult<()>;\n    91\t}\n    92\t\n    93\t/// Port for writing payload and artifact records atomically as a pair.\n    94\tpub trait PayloadArtifactWritePort {\n    95\t    fn write_payload_artifact_pair(\n    96\t        &self,\n    97\t        base_dir: &Path,\n    98\t        project_id: &ProjectId,\n    99\t        payload: &PayloadRecord,\n   100\t        artifact: &ArtifactRecord,\n   101\t    ) -> AppResult<()>;\n   102\t\n   103\t    /// Remove a previously written payload/artifact pair.\n   104\t    /// Used to roll back a stage commit when journal or snapshot persistence\n   105\t    /// fails after the pair was already written.\n   106\t    fn remove_payload_artifact_pair(\n   107\t        &self,\n   108\t        base_dir: &Path,\n   109\t        project_id: &ProjectId,\n   110\t        payload_id: &str,\n   111\t        artifact_id: &str,\n   112\t    ) -> AppResult<()>;\n   113\t}\n   114\t\n   115\t/// Port for appending runtime log entries (best-effort, not durable history).\n   116\tpub trait RuntimeLogWritePort {\n   117\t    fn append_runtime_log(\n   118\t        &self,\n   119\t        base_dir: &Path,\n   120\t        project_id: &ProjectId,\n   121\t        entry: &RuntimeLogEntry,\n   122\t    ) -> AppResult<()>;\n   123\t}\n   124\t\n   125\t/// Port for reading/writing/clearing the active project pointer.\n   126\tpub trait ActiveProjectPort {\n   127\t    fn read_active_project_id(&self, base_dir: &Path) -> AppResult<Option<String>>;\n   128\t    fn clear_active_project(&self, base_dir: &Path) -> AppResult<()>;\n   129\t    fn write_active_project(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<()>;\n   130\t}\n   131\t\n   132\t/// Input for the `project create` use case.\n   133\tpub struct CreateProjectInput {\n   134\t    pub id: ProjectId,\n   135\t    pub name: String,\n   136\t    pub flow: FlowPreset,\n   137\t    pub prompt_path: String,\n   138\t    pub prompt_contents: String,\n   139\t    pub prompt_hash: String,\n   140\t    pub created_at: DateTime<Utc>,\n   141\t}\n   142\t\n   143\t/// Create a new project with all canonical files.\n   144\tpub fn create_project(\n   145\t    store: &dyn ProjectStorePort,\n   146\t    journal_store: &dyn JournalStorePort,\n   147\t    base_dir: &Path,\n   148\t    input: CreateProjectInput,\n   149\t) -> AppResult<ProjectRecord> {\n   150\t    // Check for duplicate project ID\n   151\t    if store.project_exists(base_dir, &input.id)? {\n   152\t        return Err(AppError::DuplicateProject {\n   153\t            project_id: input.id.to_string(),\n   154\t        });\n   155\t    }\n   156\t\n   157\t    let record = ProjectRecord {\n   158\t        id: input.id.clone(),\n   159\t        name: input.name,\n   160\t        flow: input.flow,\n   161\t        prompt_reference: \"prompt.md\".to_owned(),\n   162\t        prompt_hash: input.prompt_hash,\n   163\t        created_at: input.created_at,\n   164\t        status_summary: ProjectStatusSummary::Created,\n   165\t    };\n   166\t\n   167\t    let run_snapshot = RunSnapshot::initial();\n   168\t    let sessions = SessionStore::empty();\n   169\t\n   170\t    // Create the initial journal event\n   171\t    let initial_event = JournalEvent {\n   172\t        sequence: 1,\n   173\t        timestamp: input.created_at,\n   174\t        event_type: JournalEventType::ProjectCreated,\n   175\t        details: serde_json::json!({\n   176\t            \"project_id\": record.id.as_str(),\n   177\t            \"flow\": record.flow.as_str(),\n   178\t        }),\n   179\t    };\n   180\t    let journal_line = journal::serialize_event(&initial_event)?;\n   181\t\n   182\t    // Atomic creation: all files or nothing\n   183\t    store.create_project_atomic(\n   184\t        base_dir,\n   185\t        &record,\n   186\t        &input.prompt_contents,\n   187\t        &run_snapshot,\n   188\t        &journal_line,\n   189\t        &sessions,\n   190\t    )?;\n   191\t\n   192\t    // create_project_atomic writes the journal as part of the atomic init,\n   193\t    // but we don't call journal_store.append_event here because the atomic\n   194\t    // creation already wrote the initial journal line. The journal_store\n   195\t    // parameter is kept for interface consistency and future use.\n   196\t    let _ = journal_store;\n   197\t\n   198\t    Ok(record)\n   199\t}\n   200\t\n   201\t/// List all projects with summary data.\n   202\tpub fn list_projects(\n   203\t    store: &dyn ProjectStorePort,\n   204\t    active_port: &dyn ActiveProjectPort,\n   205\t    base_dir: &Path,\n   206\t) -> AppResult<Vec<ProjectListEntry>> {\n   207\t    let active_id = active_port.read_active_project_id(base_dir)?;\n   208\t    let project_ids = store.list_project_ids(base_dir)?;\n   209\t\n   210\t    let mut entries = Vec::new();\n   211\t    for pid in project_ids {\n   212\t        let record = store.read_project_record(base_dir, &pid)?;\n   213\t        let is_active = active_id.as_deref() == Some(pid.as_str());\n   214\t        entries.push(ProjectListEntry {\n   215\t            id: record.id,\n   216\t            name: record.name,\n   217\t            flow: record.flow,\n   218\t            status_summary: record.status_summary,\n   219\t            created_at: record.created_at,\n   220\t            is_active,\n   221\t        });\n   222\t    }\n   223\t\n   224\t    Ok(entries)\n   225\t}\n   226\t\n   227\t/// Show detailed project information.\n   228\tpub fn show_project(\n   229\t    store: &dyn ProjectStorePort,\n   230\t    run_port: &dyn RunSnapshotPort,\n   231\t    journal_port: &dyn JournalStorePort,\n   232\t    active_port: &dyn ActiveProjectPort,\n   233\t    base_dir: &Path,\n   234\t    project_id: &ProjectId,\n   235\t) -> AppResult<ProjectDetail> {\n   236\t    if !store.project_exists(base_dir, project_id)? {\n   237\t        return Err(AppError::ProjectNotFound {\n   238\t            project_id: project_id.to_string(),\n   239\t        });\n   240\t    }\n   241\t\n   242\t    let record = store.read_project_record(base_dir, project_id)?;\n   243\t    let run_snapshot = run_port.read_run_snapshot(base_dir, project_id)?;\n   244\t    let events = journal_port.read_journal(base_dir, project_id)?;\n   245\t    let journal_event_count = events.len() as u64;\n   246\t    let active_id = active_port.read_active_project_id(base_dir)?;\n   247\t    let is_active = active_id.as_deref() == Some(project_id.as_str());\n   248\t\n   249\t    // Count rollback points from journal events\n   250\t    let rollback_count = events\n   251\t        .iter()\n   252\t        .filter(|e| e.event_type == JournalEventType::RollbackCreated)\n   253\t        .count();\n   254\t\n   255\t    Ok(ProjectDetail {\n   256\t        record,\n   257\t        run_snapshot,\n   258\t        journal_event_count,\n   259\t        rollback_count,\n   260\t        is_active,\n   261\t    })\n   262\t}\n   263\t\n   264\t/// Delete a project. Fails if project has an active run.\n   265\t/// Clears active-project pointer if it pointed to the deleted project.\n   266\t///\n   267\t/// Transactional: if any post-validation step fails, the project remains\n   268\t/// addressable at its canonical path and the active-project pointer is\n   269\t/// unchanged.\n   270\tpub fn delete_project(\n   271\t    store: &dyn ProjectStorePort,\n   272\t    run_port: &dyn RunSnapshotPort,\n   273\t    active_port: &dyn ActiveProjectPort,\n   274\t    base_dir: &Path,\n   275\t    project_id: &ProjectId,\n   276\t) -> AppResult<()> {\n   277\t    if !store.project_exists(base_dir, project_id)? {\n   278\t        return Err(AppError::ProjectNotFound {\n   279\t            project_id: project_id.to_string(),\n   280\t        });\n   281\t    }\n   282\t\n   283\t    // Check for active run\n   284\t    let run_snapshot = run_port.read_run_snapshot(base_dir, project_id)?;\n   285\t    if run_snapshot.has_active_run() {\n   286\t        return Err(AppError::ActiveRunDelete {\n   287\t            project_id: project_id.to_string(),\n   288\t        });\n   289\t    }\n   290\t\n   291\t    // Check if this is the active project (before delete)\n   292\t    let active_id = active_port.read_active_project_id(base_dir)?;\n   293\t    let was_active = active_id.as_deref() == Some(project_id.as_str());\n   294\t\n   295\t    // Phase 1: Stage the delete — project becomes invisible to list/show\n   296\t    // but data remains on disk for rollback.\n   297\t    store.stage_delete(base_dir, project_id)?;\n   298\t\n   299\t    // Phase 2: Clear the active-project pointer if needed.\n   300\t    // If this fails, roll back the staged delete so the project remains\n   301\t    // addressable and the pointer is unchanged.\n   302\t    if was_active {\n   303\t        if let Err(clear_err) = active_port.clear_active_project(base_dir) {\n   304\t            store\n   305\t                .rollback_delete(base_dir, project_id)\n   306\t                .map_err(|restore_err| AppError::CorruptRecord {\n   307\t                    file: format!(\"projects/{}\", project_id),\n   308\t                    details: format!(\n   309\t                        \"delete partially failed: pointer clear error: {}, restore error: {}\",\n   310\t                        clear_err, restore_err\n   311\t                    ),\n   312\t                })?;\n   313\t            return Err(clear_err);\n   314\t        }\n   315\t    }\n   316\t\n   317\t    // Phase 3: Finalize — permanently remove the project data.\n   318\t    // At this point the logical delete has succeeded (project is invisible,\n   319\t    // pointer is cleared). Best-effort cleanup of the staged data.\n   320\t    let _ = store.commit_delete(base_dir, project_id);\n   321\t\n   322\t    Ok(())\n   323\t}\n   324\t\n   325\t/// Get run status for the active project.\n   326\tpub fn run_status(\n   327\t    run_port: &dyn RunSnapshotPort,\n   328\t    base_dir: &Path,\n   329\t    project_id: &ProjectId,\n   330\t) -> AppResult<RunStatusView> {\n   331\t    let snapshot = run_port.read_run_snapshot(base_dir, project_id)?;\n   332\t    Ok(queries::build_status_view(project_id.as_str(), &snapshot))\n   333\t}\n   334\t\n   335\t/// Get run history (durable only, no runtime logs).\n   336\tpub fn run_history(\n   337\t    journal_port: &dyn JournalStorePort,\n   338\t    artifact_port: &dyn ArtifactStorePort,\n   339\t    base_dir: &Path,\n   340\t    project_id: &ProjectId,\n   341\t) -> AppResult<RunHistoryView> {\n   342\t    let events = journal_port.read_journal(base_dir, project_id)?;\n   343\t    let payloads = artifact_port.list_payloads(base_dir, project_id)?;\n   344\t    let artifacts = artifact_port.list_artifacts(base_dir, project_id)?;\n   345\t\n   346\t    queries::validate_history_consistency(&payloads, &artifacts)?;\n   347\t\n   348\t    Ok(queries::build_history_view(\n   349\t        project_id.as_str(),\n   350\t        events,\n   351\t        payloads,\n   352\t        artifacts,\n   353\t    ))\n   354\t}\n   355\t\n   356\t/// Get run tail: durable history by default, with optional runtime logs.\n   357\tpub fn run_tail(\n   358\t    journal_port: &dyn JournalStorePort,\n   359\t    artifact_port: &dyn ArtifactStorePort,\n   360\t    log_port: &dyn RuntimeLogStorePort,\n   361\t    base_dir: &Path,\n   362\t    project_id: &ProjectId,\n   363\t    include_logs: bool,\n   364\t) -> AppResult<RunTailView> {\n   365\t    let events = journal_port.read_journal(base_dir, project_id)?;\n   366\t    let payloads = artifact_port.list_payloads(base_dir, project_id)?;\n   367\t    let artifacts = artifact_port.list_artifacts(base_dir, project_id)?;\n   368\t\n   369\t    queries::validate_history_consistency(&payloads, &artifacts)?;\n   370\t\n   371\t    let runtime_logs = if include_logs {\n   372\t        log_port.read_runtime_logs(base_dir, project_id)?\n   373\t    } else {\n   374\t        Vec::new()\n   375\t    };\n   376\t\n   377\t    Ok(queries::build_tail_view(\n   378\t        project_id.as_str(),\n   379\t        events,\n   380\t        payloads,\n   381\t        artifacts,\n   382\t        include_logs,\n   383\t        runtime_logs,\n   384\t    ))\n   385\t}\n","exit_code":0,"status":"completed"}}
