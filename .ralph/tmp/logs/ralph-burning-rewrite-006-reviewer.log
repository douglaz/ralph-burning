  45\t        &self,\n    46\t        role: BackendRole,\n    47\t        explicit_model_override: Option<ModelSpec>,\n    48\t        project_config: Option<&BackendSelectionConfig>,\n    49\t        workspace_defaults: Option<&BackendSelectionConfig>,\n    50\t    ) -> AppResult<ResolvedBackendTarget> {\n    51\t        let mut target = role.default_target();\n    52\t\n    53\t        if let Some(workspace_defaults) = workspace_defaults {\n    54\t            Self::apply_selection(&mut target, workspace_defaults);\n    55\t        }\n    56\t        if let Some(project_config) = project_config {\n    57\t            Self::apply_selection(&mut target, project_config);\n    58\t        }\n    59\t        if let Some(model_override) = explicit_model_override {\n    60\t            Self::apply_model_override(&mut target, model_override);\n    61\t        }\n    62\t\n    63\t        Ok(target)\n    64\t    }\n    65\t\n    66\t    pub fn resolve_from_effective_config(\n    67\t        &self,\n    68\t        role: BackendRole,\n    69\t        explicit_model_override: Option<ModelSpec>,\n    70\t        project_config: Option<&BackendSelectionConfig>,\n    71\t        effective_config: &EffectiveConfig,\n    72\t    ) -> AppResult<ResolvedBackendTarget> {\n    73\t        let workspace_defaults = BackendSelectionConfig::from_effective_config(effective_config)?;\n    74\t        self.resolve(\n    75\t            role,\n    76\t            explicit_model_override,\n    77\t            project_config,\n    78\t            Some(&workspace_defaults),\n    79\t        )\n    80\t    }\n    81\t\n    82\t    fn apply_selection(target: &mut ResolvedBackendTarget, selection: &BackendSelectionConfig) {\n    83\t        if let Some(backend_family) = selection.backend_family {\n    84\t            target.backend = BackendSpec::from_family(backend_family);\n    85\t            if target.model.backend_family != backend_family {\n    86\t                target.model = ModelSpec::default_for_backend(backend_family);\n    87\t            }\n    88\t        }\n    89\t\n    90\t        if let Some(model_id) = &selection.model_id {\n    91\t            target.model = ModelSpec::new(target.backend.family, model_id.clone());\n    92\t        }\n    93\t    }\n    94\t\n    95\t    fn apply_model_override(target: &mut ResolvedBackendTarget, model_override: ModelSpec) {\n    96\t        if target.backend.family != model_override.backend_family {\n    97\t            target.backend = BackendSpec::from_family(model_override.backend_family);\n    98\t        }\n    99\t        target.model = model_override;\n   100\t    }\n   101\t}\n   102\t\n   103\t#[allow(async_fn_in_trait)]\n   104\tpub trait AgentExecutionPort {\n   105\t    async fn check_capability(\n   106\t        &self,\n   107\t        backend: &ResolvedBackendTarget,\n   108\t        stage_contract: &StageContract,\n   109\t    ) -> AppResult<()>;\n   110\t\n   111\t    async fn check_availability(&self, backend: &ResolvedBackendTarget) -> AppResult<()>;\n   112\t\n   113\t    async fn invoke(&self, request: InvocationRequest) -> AppResult<InvocationEnvelope>;\n   114\t\n   115\t    async fn cancel(&self, invocation_id: &str) -> AppResult<()>;\n   116\t}\n   117\t\n   118\tpub trait RawOutputPort {\n   119\t    fn persist_raw_output(\n   120\t        &self,\n   121\t        project_root: &Path,\n   122\t        invocation_id: &str,\n   123\t        contents: &str,\n   124\t    ) -> AppResult<RawOutputReference>;\n   125\t}\n   126\t\n   127\tpub struct AgentExecutionService<A, R, S> {\n   128\t    adapter: A,\n   129\t    raw_output_store: R,\n   130\t    session_manager: SessionManager<S>,\n   131\t    resolver: BackendResolver,\n   132\t}\n   133\t\n   134\timpl<A, R, S> AgentExecutionService<A, R, S> {\n   135\t    pub fn new(adapter: A, raw_output_store: R, session_store: S) -> Self {\n   136\t        Self {\n   137\t            adapter,\n   138\t            raw_output_store,\n   139\t            session_manager: SessionManager::new(session_store),\n   140\t            resolver: BackendResolver::new(),\n   141\t        }\n   142\t    }\n   143\t\n   144\t    pub fn resolver(&self) -> &BackendResolver {\n   145\t        &self.resolver\n   146\t    }\n   147\t\n   148\t    pub fn adapter(&self) -> &A {\n   149\t        &self.adapter\n   150\t    }\n   151\t}\n   152\t\n   153\timpl<A, R, S> AgentExecutionService<A, R, S>\n   154\twhere\n   155\t    A: AgentExecutionPort,\n   156\t    R: RawOutputPort,\n   157\t    S: SessionStorePort,\n   158\t{\n   159\t    pub async fn invoke(&self, request: InvocationRequest) -> AppResult<InvocationEnvelope> {\n   160\t        let _ = CapabilityCheck::success(&request.resolved_target, request.stage_contract);\n   161\t\n   162\t        self.adapter\n   163\t            .check_capability(&request.resolved_target, &request.stage_contract)\n   164\t            .await\n   165\t            .map_err(|error| map_capability_error(error, &request))?;\n   166\t\n   167\t        self.adapter\n   168\t            .check_availability(&request.resolved_target)\n   169\t            .await\n   170\t            .map_err(|error| map_availability_error(error, &request))?;\n   171\t\n   172\t        let prior_session = self.session_manager.load_reusable_session(\n   173\t            &request.project_root,\n   174\t            request.role,\n   175\t            &request.resolved_target,\n   176\t            request.session_policy,\n   177\t        )?;\n   178\t\n   179\t        let mut request = request;\n   180\t        request.prior_session = prior_session;\n   181\t\n   182\t        if request.cancellation_token.is_cancelled() {\n   183\t            return Err(AppError::InvocationCancelled {\n   184\t                backend: request.resolved_target.backend.family.to_string(),\n   185\t                stage_id: request.stage_contract.stage_id,\n   186\t            });\n   187\t        }\n   188\t\n   189\t        let started_at = Utc::now();\n   190\t        let started = Instant::now();\n   191\t        let invocation_id = request.invocation_id.clone();\n   192\t        let timeout_ms = request.timeout.as_millis().min(u64::MAX as u128) as u64;\n   193\t\n   194\t        let invoke_future = self.adapter.invoke(request.clone());\n   195\t        tokio::pin!(invoke_future);\n   196\t\n   197\t        let mut envelope = tokio::select! {\n   198\t            _ = request.cancellation_token.cancelled() => {\n   199\t                let _ = self.adapter.cancel(&invocation_id).await;\n   200\t                return Err(AppError::InvocationCancelled {\n   201\t                    backend: request.resolved_target.backend.family.to_string(),\n   202\t                    stage_id: request.stage_contract.stage_id,\n   203\t                });\n   204\t            }\n   205\t            result = tokio::time::timeout(request.timeout, &mut invoke_future) => {\n   206\t                match result {\n   207\t                    Ok(result) => result.map_err(|error| map_invoke_error(error, &request))?,\n   208\t                    Err(_) => {\n   209\t                        let _ = self.adapter.cancel(&invocation_id).await;\n   210\t                        return Err(AppError::InvocationTimeout {\n   211\t                            backend: request.resolved_target.backend.family.to_string(),\n   212\t                            stage_id: request.stage_contract.stage_id,\n   213\t                            timeout_ms,\n   214\t                        });\n   215\t                    }\n   216\t                }\n   217\t            }\n   218\t        };\n   219\t\n   220\t        let duration = started.elapsed();\n   221\t        envelope.metadata.duration = duration;\n   222\t        envelope.metadata.attempt_number = request.attempt_number;\n   223\t        envelope.metadata.backend_used = request.resolved_target.backend.clone();\n   224\t        envelope.metadata.model_used = request.resolved_target.model.clone();\n   225\t        envelope.timestamp = Utc::now();\n   226\t\n   227\t        let raw_output = extract_raw_output(&envelope.raw_output_reference)?;\n   228\t        let stored_reference = self.raw_output_store.persist_raw_output(\n   229\t            &request.project_root,\n   230\t            &request.invocation_id,\n   231\t            &raw_output,\n   232\t        )?;\n   233\t\n   234\t        let parsed_payload =\n   235\t            extract_structured_payload(&request, envelope.parsed_payload, &raw_output)?;\n   236\t\n   237\t        request\n   238\t            .stage_contract\n   239\t            .evaluate(&parsed_payload)\n   240\t            .map_err(|error| map_contract_error(error, &request))?;\n   241\t\n   242\t        envelope.raw_output_reference = stored_reference;\n   243\t        envelope.parsed_payload = parsed_payload;\n   244\t        envelope.timestamp = started_at + duration;\n   245\t\n   246\t        self.session_manager.record_session(\n   247\t            &request.project_root,\n   248\t            request.role,\n   249\t            &request.resolved_target,\n   250\t            envelope.metadata.session_id.as_deref(),\n   251\t            envelope.timestamp,\n   252\t        )?;\n   253\t\n   254\t        Ok(envelope)\n   255\t    }\n   256\t}\n   257\t\n   258\tfn parse_backend_family(key: &str, value: &str) -> AppResult<BackendFamily> {\n   259\t    match value {\n   260\t        \"claude\" => Ok(BackendFamily::Claude),\n   261\t        \"codex\" => Ok(BackendFamily::Codex),\n   262\t        \"openrouter\" => Ok(BackendFamily::OpenRouter),\n   263\t        \"stub\" => Ok(BackendFamily::Stub),\n   264\t        _ => Err(AppError::InvalidConfigValue {\n   265\t            key: key.to_owned(),\n   266\t            value: value.to_owned(),\n   267\t            reason: \"expected one of claude, codex, openrouter, stub\".to_owned(),\n   268\t        }),\n   269\t    }\n   270\t}\n   271\t\n   272\tfn extract_raw_output(raw_output_reference: &RawOutputReference) -> AppResult<String> {\n   273\t    match raw_output_reference {\n   274\t        RawOutputReference::Inline(contents) => Ok(contents.clone()),\n   275\t        RawOutputReference::Stored(path) => std::fs::read_to_string(path).map_err(AppError::from),\n   276\t    }\n   277\t}\n   278\t\n   279\tfn extract_structured_payload(\n   280\t    request: &InvocationRequest,\n   281\t    parsed_payload: Value,\n   282\t    raw_output: &str,\n   283\t) -> AppResult<Value> {\n   284\t    if !parsed_payload.is_null() {\n   285\t        return Ok(parsed_payload);\n   286\t    }\n   287\t\n   288\t    serde_json::from_str(raw_output).map_err(|error| AppError::InvocationFailed {\n   289\t        backend: request.resolved_target.backend.family.to_string(),\n   290\t        stage_id: request.stage_contract.stage_id,\n   291\t        failure_class: FailureClass::SchemaValidationFailure,\n   292\t        details: error.to_string(),\n   293\t    })\n   294\t}\n   295\t\n   296\tfn map_capability_error(error: AppError, request: &InvocationRequest) -> AppError {\n   297\t    match error {\n   298\t        AppError::CapabilityMismatch { .. } => error,\n   299\t        other => AppError::CapabilityMismatch {\n   300\t            backend: request.resolved_target.backend.family.to_string(),\n   301\t            stage_id: request.stage_contract.stage_id,\n   302\t            details: other.to_string(),\n   303\t        },\n   304\t    }\n   305\t}\n   306\t\n   307\tfn map_availability_error(error: AppError, request: &InvocationRequest) -> AppError {\n   308\t    match error {\n   309\t        AppError::BackendUnavailable { .. } => error,\n   310\t        other => AppError::BackendUnavailable {\n   311\t            backend: request.resolved_target.backend.family.to_string(),\n   312\t            details: other.to_string(),\n   313\t        },\n   314\t    }\n   315\t}\n   316\t\n   317\tfn map_invoke_error(error: AppError, request: &InvocationRequest) -> AppError {\n   318\t    match error {\n   319\t        AppError::InvocationFailed { .. }\n   320\t        | AppError::InvocationTimeout { .. }\n   321\t        | AppError::InvocationCancelled { .. } => error,\n   322\t        other => AppError::InvocationFailed {\n   323\t            backend: request.resolved_target.backend.family.to_string(),\n   324\t            stage_id: request.stage_contract.stage_id,\n   325\t            failure_class: FailureClass::TransportFailure,\n   326\t            details: other.to_string(),\n   327\t        },\n   328\t    }\n   329\t}\n   330\t\n   331\tfn map_contract_error(error: ContractError, request: &InvocationRequest) -> AppError {\n   332\t    AppError::InvocationFailed {\n   333\t        backend: request.resolved_target.backend.family.to_string(),\n   334\t        stage_id: request.stage_contract.stage_id,\n   335\t        failure_class: error.failure_class(),\n   336\t        details: error.to_string(),\n   337\t    }\n   338\t}\n","exit_code":0,"status":"completed"}}
