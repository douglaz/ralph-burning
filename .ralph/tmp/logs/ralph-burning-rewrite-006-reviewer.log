{"type":"item.completed","item":{"id":"item_20","type":"command_execution","command":"/run/current-system/sw/bin/bash -lc \"nl -ba src/contexts/workspace_governance/config.rs | sed -n '1,260p'\"","aggregated_output":"     1\tuse std::fmt;\n     2\tuse std::path::Path;\n     3\t\n     4\tuse toml_edit::{value, DocumentMut};\n     5\t\n     6\tuse crate::adapters::fs::FileSystem;\n     7\tuse crate::shared::domain::{FlowPreset, WorkspaceConfig};\n     8\tuse crate::shared::error::{AppError, AppResult};\n     9\t\n    10\tuse super::{load_workspace_config, workspace_config_path};\n    11\t\n    12\t/// Default: enabled.\n    13\tpub const DEFAULT_PROMPT_REVIEW_ENABLED: bool = true;\n    14\t/// Default: standard.\n    15\tpub const DEFAULT_FLOW_PRESET: FlowPreset = FlowPreset::Standard;\n    16\t\n    17\t#[derive(Debug, Clone, Copy, PartialEq, Eq)]\n    18\tpub enum ConfigValueSource {\n    19\t    Default,\n    20\t    WorkspaceToml,\n    21\t}\n    22\t\n    23\timpl fmt::Display for ConfigValueSource {\n    24\t    fn fmt(&self, f: &mut fmt::Formatter<'_>) -> fmt::Result {\n    25\t        match self {\n    26\t            Self::Default => f.write_str(\"default\"),\n    27\t            Self::WorkspaceToml => f.write_str(\"workspace.toml\"),\n    28\t        }\n    29\t    }\n    30\t}\n    31\t\n    32\t#[derive(Debug, Clone, PartialEq, Eq)]\n    33\tpub enum ConfigValue {\n    34\t    Bool(bool),\n    35\t    FlowPreset(FlowPreset),\n    36\t    String(Option<String>),\n    37\t}\n    38\t\n    39\timpl ConfigValue {\n    40\t    pub fn display_value(&self) -> String {\n    41\t        match self {\n    42\t            Self::Bool(value) => value.to_string(),\n    43\t            Self::FlowPreset(value) => value.as_str().to_owned(),\n    44\t            Self::String(Some(value)) => value.clone(),\n    45\t            Self::String(None) => \"<unset>\".to_owned(),\n    46\t        }\n    47\t    }\n    48\t\n    49\t    pub fn toml_like_value(&self) -> String {\n    50\t        match self {\n    51\t            Self::Bool(value) => value.to_string(),\n    52\t            Self::FlowPreset(value) => format!(\"\\\"{}\\\"\", value.as_str()),\n    53\t            Self::String(Some(value)) => format!(\"\\\"{value}\\\"\"),\n    54\t            Self::String(None) => \"\\\"<unset>\\\"\".to_owned(),\n    55\t        }\n    56\t    }\n    57\t}\n    58\t\n    59\t#[derive(Debug, Clone, PartialEq, Eq)]\n    60\tpub struct ConfigEntry {\n    61\t    pub key: &'static str,\n    62\t    pub value: ConfigValue,\n    63\t    pub source: ConfigValueSource,\n    64\t}\n    65\t\n    66\t#[derive(Debug, Clone, PartialEq, Eq)]\n    67\tstruct ResolvedValue<T> {\n    68\t    value: T,\n    69\t    source: ConfigValueSource,\n    70\t}\n    71\t\n    72\t#[derive(Debug, Clone, PartialEq, Eq)]\n    73\tpub struct EffectiveConfig {\n    74\t    prompt_review_enabled: ResolvedValue<bool>,\n    75\t    default_flow: ResolvedValue<FlowPreset>,\n    76\t    default_backend: ResolvedValue<Option<String>>,\n    77\t    default_model: ResolvedValue<Option<String>>,\n    78\t}\n    79\t\n    80\timpl EffectiveConfig {\n    81\t    pub fn load(base_dir: &Path) -> AppResult<Self> {\n    82\t        let config = load_workspace_config(base_dir)?;\n    83\t        Ok(Self::from_workspace_config(&config))\n    84\t    }\n    85\t\n    86\t    pub fn get(&self, key: &str) -> AppResult<ConfigEntry> {\n    87\t        let key = ConfigKey::parse(key)?;\n    88\t        Ok(self.entry_for(key))\n    89\t    }\n    90\t\n    91\t    pub fn set(base_dir: &Path, key: &str, value: &str) -> AppResult<ConfigEntry> {\n    92\t        let key = ConfigKey::parse(key)?;\n    93\t        let _ = Self::load(base_dir)?;\n    94\t\n    95\t        let config_path = workspace_config_path(base_dir);\n    96\t        let raw = FileSystem::read_to_string(&config_path)?;\n    97\t        let mut document = raw.parse::<DocumentMut>()?;\n    98\t        key.apply_to_document(&mut document, value)?;\n    99\t        FileSystem::write_atomic(&config_path, &document.to_string())?;\n   100\t\n   101\t        Self::load(base_dir)?.get(key.as_str())\n   102\t    }\n   103\t\n   104\t    pub fn entries(&self) -> Vec<ConfigEntry> {\n   105\t        ConfigKey::ALL\n   106\t            .iter()\n   107\t            .copied()\n   108\t            .map(|key| self.entry_for(key))\n   109\t            .collect()\n   110\t    }\n   111\t\n   112\t    /// Default: `true`.\n   113\t    pub fn prompt_review_enabled(&self) -> bool {\n   114\t        self.prompt_review_enabled.value\n   115\t    }\n   116\t\n   117\t    /// Default: `standard`.\n   118\t    pub fn default_flow(&self) -> FlowPreset {\n   119\t        self.default_flow.value\n   120\t    }\n   121\t\n   122\t    /// Default: unset.\n   123\t    pub fn default_backend(&self) -> Option<&str> {\n   124\t        self.default_backend.value.as_deref()\n   125\t    }\n   126\t\n   127\t    /// Default: unset.\n   128\t    pub fn default_model(&self) -> Option<&str> {\n   129\t        self.default_model.value.as_deref()\n   130\t    }\n   131\t\n   132\t    fn from_workspace_config(config: &WorkspaceConfig) -> Self {\n   133\t        let settings = &config.settings;\n   134\t        Self {\n   135\t            prompt_review_enabled: resolve_value(\n   136\t                settings.prompt_review.enabled,\n   137\t                DEFAULT_PROMPT_REVIEW_ENABLED,\n   138\t            ),\n   139\t            default_flow: resolve_value(settings.default_flow, DEFAULT_FLOW_PRESET),\n   140\t            default_backend: resolve_optional_value(settings.default_backend.as_ref()),\n   141\t            default_model: resolve_optional_value(settings.default_model.as_ref()),\n   142\t        }\n   143\t    }\n   144\t\n   145\t    fn entry_for(&self, key: ConfigKey) -> ConfigEntry {\n   146\t        match key {\n   147\t            ConfigKey::PromptReviewEnabled => ConfigEntry {\n   148\t                key: key.as_str(),\n   149\t                value: ConfigValue::Bool(self.prompt_review_enabled()),\n   150\t                source: self.prompt_review_enabled.source,\n   151\t            },\n   152\t            ConfigKey::DefaultFlow => ConfigEntry {\n   153\t                key: key.as_str(),\n   154\t                value: ConfigValue::FlowPreset(self.default_flow()),\n   155\t                source: self.default_flow.source,\n   156\t            },\n   157\t            ConfigKey::DefaultBackend => ConfigEntry {\n   158\t                key: key.as_str(),\n   159\t                value: ConfigValue::String(self.default_backend.value.clone()),\n   160\t                source: self.default_backend.source,\n   161\t            },\n   162\t            ConfigKey::DefaultModel => ConfigEntry {\n   163\t                key: key.as_str(),\n   164\t                value: ConfigValue::String(self.default_model.value.clone()),\n   165\t                source: self.default_model.source,\n   166\t            },\n   167\t        }\n   168\t    }\n   169\t}\n   170\t\n   171\tfn resolve_value<T: Copy>(value: Option<T>, default: T) -> ResolvedValue<T> {\n   172\t    match value {\n   173\t        Some(value) => ResolvedValue {\n   174\t            value,\n   175\t            source: ConfigValueSource::WorkspaceToml,\n   176\t        },\n   177\t        None => ResolvedValue {\n   178\t            value: default,\n   179\t            source: ConfigValueSource::Default,\n   180\t        },\n   181\t    }\n   182\t}\n   183\t\n   184\tfn resolve_optional_value(value: Option<&String>) -> ResolvedValue<Option<String>> {\n   185\t    match value {\n   186\t        Some(value) => ResolvedValue {\n   187\t            value: Some(value.clone()),\n   188\t            source: ConfigValueSource::WorkspaceToml,\n   189\t        },\n   190\t        None => ResolvedValue {\n   191\t            value: None,\n   192\t            source: ConfigValueSource::Default,\n   193\t        },\n   194\t    }\n   195\t}\n   196\t\n   197\t#[derive(Debug, Clone, Copy, PartialEq, Eq)]\n   198\tenum ConfigKey {\n   199\t    PromptReviewEnabled,\n   200\t    DefaultFlow,\n   201\t    DefaultBackend,\n   202\t    DefaultModel,\n   203\t}\n   204\t\n   205\timpl ConfigKey {\n   206\t    const ALL: [Self; 4] = [\n   207\t        Self::PromptReviewEnabled,\n   208\t        Self::DefaultFlow,\n   209\t        Self::DefaultBackend,\n   210\t        Self::DefaultModel,\n   211\t    ];\n   212\t\n   213\t    fn parse(value: &str) -> AppResult<Self> {\n   214\t        match value {\n   215\t            \"prompt_review.enabled\" => Ok(Self::PromptReviewEnabled),\n   216\t            \"default_flow\" => Ok(Self::DefaultFlow),\n   217\t            \"default_backend\" => Ok(Self::DefaultBackend),\n   218\t            \"default_model\" => Ok(Self::DefaultModel),\n   219\t            _ => Err(AppError::UnknownConfigKey {\n   220\t                key: value.to_owned(),\n   221\t            }),\n   222\t        }\n   223\t    }\n   224\t\n   225\t    fn as_str(self) -> &'static str {\n   226\t        match self {\n   227\t            Self::PromptReviewEnabled => \"prompt_review.enabled\",\n   228\t            Self::DefaultFlow => \"default_flow\",\n   229\t            Self::DefaultBackend => \"default_backend\",\n   230\t            Self::DefaultModel => \"default_model\",\n   231\t        }\n   232\t    }\n   233\t\n   234\t    fn apply_to_document(self, document: &mut DocumentMut, raw_value: &str) -> AppResult<()> {\n   235\t        match self {\n   236\t            Self::PromptReviewEnabled => {\n   237\t                let parsed = parse_bool(self.as_str(), raw_value)?;\n   238\t                document[\"settings\"][\"prompt_review\"][\"enabled\"] = value(parsed);\n   239\t            }\n   240\t            Self::DefaultFlow => {\n   241\t                let parsed = parse_flow_preset(self.as_str(), raw_value)?;\n   242\t                document[\"settings\"][\"default_flow\"] = value(parsed.as_str());\n   243\t            }\n   244\t            Self::DefaultBackend => apply_optional_string(document, \"default_backend\", raw_value)?,\n   245\t            Self::DefaultModel => apply_optional_string(document, \"default_model\", raw_value)?,\n   246\t        }\n   247\t\n   248\t        Ok(())\n   249\t    }\n   250\t}\n   251\t\n   252\tfn parse_bool(key: &str, raw_value: &str) -> AppResult<bool> {\n   253\t    match raw_value.trim() {\n   254\t        \"true\" => Ok(true),\n   255\t        \"false\" => Ok(false),\n   256\t        _ => Err(AppError::InvalidConfigValue {\n   257\t            key: key.to_owned(),\n   258\t            value: raw_value.to_owned(),\n   259\t            reason: \"expected `true` or `false`\".to_owned(),\n   260\t        }),\n","exit_code":0,"status":"completed"}}
