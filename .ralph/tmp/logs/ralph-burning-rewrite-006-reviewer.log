{"type":"item.completed","item":{"id":"item_7","type":"command_execution","command":"/run/current-system/sw/bin/bash -lc \"nl -ba ralph-burning-rewrite/src/contexts/project_run_record/service.rs | sed -n '1,420p'\"","aggregated_output":"     1\tuse std::path::Path;\n     2\t\n     3\tuse chrono::{DateTime, Utc};\n     4\t\n     5\tuse crate::shared::domain::{FlowPreset, ProjectId};\n     6\tuse crate::shared::error::{AppError, AppResult};\n     7\t\n     8\tuse super::journal;\n     9\tuse super::model::{\n    10\t    ArtifactRecord, JournalEvent, JournalEventType, PayloadRecord, ProjectDetail, ProjectListEntry,\n    11\t    ProjectRecord, ProjectStatusSummary, RunSnapshot, RuntimeLogEntry, SessionStore,\n    12\t};\n    13\tuse super::queries::{self, RunHistoryView, RunStatusView, RunTailView};\n    14\t\n    15\t/// Port for reading and writing project records.\n    16\tpub trait ProjectStorePort {\n    17\t    fn project_exists(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<bool>;\n    18\t    fn read_project_record(\n    19\t        &self,\n    20\t        base_dir: &Path,\n    21\t        project_id: &ProjectId,\n    22\t    ) -> AppResult<ProjectRecord>;\n    23\t    fn list_project_ids(&self, base_dir: &Path) -> AppResult<Vec<ProjectId>>;\n    24\t\n    25\t    /// Stage a project for deletion: makes it invisible to list/show but\n    26\t    /// keeps data on disk for potential rollback.\n    27\t    fn stage_delete(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<()>;\n    28\t\n    29\t    /// Finalize a staged delete: permanently removes the project data.\n    30\t    fn commit_delete(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<()>;\n    31\t\n    32\t    /// Roll back a staged delete: restores the project to its canonical path.\n    33\t    fn rollback_delete(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<()>;\n    34\t\n    35\t    /// Atomically stage and commit a new project. If any step fails,\n    36\t    /// the project must not be visible to list/show.\n    37\t    fn create_project_atomic(\n    38\t        &self,\n    39\t        base_dir: &Path,\n    40\t        record: &ProjectRecord,\n    41\t        prompt_contents: &str,\n    42\t        run_snapshot: &RunSnapshot,\n    43\t        initial_journal_line: &str,\n    44\t        sessions: &SessionStore,\n    45\t    ) -> AppResult<()>;\n    46\t}\n    47\t\n    48\t/// Port for reading and appending journal events.\n    49\tpub trait JournalStorePort {\n    50\t    fn read_journal(&self, base_dir: &Path, project_id: &ProjectId)\n    51\t        -> AppResult<Vec<JournalEvent>>;\n    52\t    fn append_event(&self, base_dir: &Path, project_id: &ProjectId, line: &str) -> AppResult<()>;\n    53\t}\n    54\t\n    55\t/// Port for reading payload and artifact durable history.\n    56\tpub trait ArtifactStorePort {\n    57\t    fn list_payloads(\n    58\t        &self,\n    59\t        base_dir: &Path,\n    60\t        project_id: &ProjectId,\n    61\t    ) -> AppResult<Vec<PayloadRecord>>;\n    62\t    fn list_artifacts(\n    63\t        &self,\n    64\t        base_dir: &Path,\n    65\t        project_id: &ProjectId,\n    66\t    ) -> AppResult<Vec<ArtifactRecord>>;\n    67\t}\n    68\t\n    69\t/// Port for reading runtime logs (separate from durable history).\n    70\tpub trait RuntimeLogStorePort {\n    71\t    fn read_runtime_logs(\n    72\t        &self,\n    73\t        base_dir: &Path,\n    74\t        project_id: &ProjectId,\n    75\t    ) -> AppResult<Vec<RuntimeLogEntry>>;\n    76\t}\n    77\t\n    78\t/// Port for reading/writing the run snapshot.\n    79\tpub trait RunSnapshotPort {\n    80\t    fn read_run_snapshot(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<RunSnapshot>;\n    81\t}\n    82\t\n    83\t/// Port for writing the run snapshot atomically.\n    84\tpub trait RunSnapshotWritePort {\n    85\t    fn write_run_snapshot(\n    86\t        &self,\n    87\t        base_dir: &Path,\n    88\t        project_id: &ProjectId,\n    89\t        snapshot: &RunSnapshot,\n    90\t    ) -> AppResult<()>;\n    91\t}\n    92\t\n    93\t/// Port for writing payload and artifact records atomically as a pair.\n    94\tpub trait PayloadArtifactWritePort {\n    95\t    fn write_payload_artifact_pair(\n    96\t        &self,\n    97\t        base_dir: &Path,\n    98\t        project_id: &ProjectId,\n    99\t        payload: &PayloadRecord,\n   100\t        artifact: &ArtifactRecord,\n   101\t    ) -> AppResult<()>;\n   102\t}\n   103\t\n   104\t/// Port for appending runtime log entries (best-effort, not durable history).\n   105\tpub trait RuntimeLogWritePort {\n   106\t    fn append_runtime_log(\n   107\t        &self,\n   108\t        base_dir: &Path,\n   109\t        project_id: &ProjectId,\n   110\t        entry: &RuntimeLogEntry,\n   111\t    ) -> AppResult<()>;\n   112\t}\n   113\t\n   114\t/// Port for reading/writing/clearing the active project pointer.\n   115\tpub trait ActiveProjectPort {\n   116\t    fn read_active_project_id(&self, base_dir: &Path) -> AppResult<Option<String>>;\n   117\t    fn clear_active_project(&self, base_dir: &Path) -> AppResult<()>;\n   118\t    fn write_active_project(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<()>;\n   119\t}\n   120\t\n   121\t/// Input for the `project create` use case.\n   122\tpub struct CreateProjectInput {\n   123\t    pub id: ProjectId,\n   124\t    pub name: String,\n   125\t    pub flow: FlowPreset,\n   126\t    pub prompt_path: String,\n   127\t    pub prompt_contents: String,\n   128\t    pub prompt_hash: String,\n   129\t    pub created_at: DateTime<Utc>,\n   130\t}\n   131\t\n   132\t/// Create a new project with all canonical files.\n   133\tpub fn create_project(\n   134\t    store: &dyn ProjectStorePort,\n   135\t    journal_store: &dyn JournalStorePort,\n   136\t    base_dir: &Path,\n   137\t    input: CreateProjectInput,\n   138\t) -> AppResult<ProjectRecord> {\n   139\t    // Check for duplicate project ID\n   140\t    if store.project_exists(base_dir, &input.id)? {\n   141\t        return Err(AppError::DuplicateProject {\n   142\t            project_id: input.id.to_string(),\n   143\t        });\n   144\t    }\n   145\t\n   146\t    let record = ProjectRecord {\n   147\t        id: input.id.clone(),\n   148\t        name: input.name,\n   149\t        flow: input.flow,\n   150\t        prompt_reference: \"prompt.md\".to_owned(),\n   151\t        prompt_hash: input.prompt_hash,\n   152\t        created_at: input.created_at,\n   153\t        status_summary: ProjectStatusSummary::Created,\n   154\t    };\n   155\t\n   156\t    let run_snapshot = RunSnapshot::initial();\n   157\t    let sessions = SessionStore::empty();\n   158\t\n   159\t    // Create the initial journal event\n   160\t    let initial_event = JournalEvent {\n   161\t        sequence: 1,\n   162\t        timestamp: input.created_at,\n   163\t        event_type: JournalEventType::ProjectCreated,\n   164\t        details: serde_json::json!({\n   165\t            \"project_id\": record.id.as_str(),\n   166\t            \"flow\": record.flow.as_str(),\n   167\t        }),\n   168\t    };\n   169\t    let journal_line = journal::serialize_event(&initial_event)?;\n   170\t\n   171\t    // Atomic creation: all files or nothing\n   172\t    store.create_project_atomic(\n   173\t        base_dir,\n   174\t        &record,\n   175\t        &input.prompt_contents,\n   176\t        &run_snapshot,\n   177\t        &journal_line,\n   178\t        &sessions,\n   179\t    )?;\n   180\t\n   181\t    // create_project_atomic writes the journal as part of the atomic init,\n   182\t    // but we don't call journal_store.append_event here because the atomic\n   183\t    // creation already wrote the initial journal line. The journal_store\n   184\t    // parameter is kept for interface consistency and future use.\n   185\t    let _ = journal_store;\n   186\t\n   187\t    Ok(record)\n   188\t}\n   189\t\n   190\t/// List all projects with summary data.\n   191\tpub fn list_projects(\n   192\t    store: &dyn ProjectStorePort,\n   193\t    active_port: &dyn ActiveProjectPort,\n   194\t    base_dir: &Path,\n   195\t) -> AppResult<Vec<ProjectListEntry>> {\n   196\t    let active_id = active_port.read_active_project_id(base_dir)?;\n   197\t    let project_ids = store.list_project_ids(base_dir)?;\n   198\t\n   199\t    let mut entries = Vec::new();\n   200\t    for pid in project_ids {\n   201\t        let record = store.read_project_record(base_dir, &pid)?;\n   202\t        let is_active = active_id.as_deref() == Some(pid.as_str());\n   203\t        entries.push(ProjectListEntry {\n   204\t            id: record.id,\n   205\t            name: record.name,\n   206\t            flow: record.flow,\n   207\t            status_summary: record.status_summary,\n   208\t            created_at: record.created_at,\n   209\t            is_active,\n   210\t        });\n   211\t    }\n   212\t\n   213\t    Ok(entries)\n   214\t}\n   215\t\n   216\t/// Show detailed project information.\n   217\tpub fn show_project(\n   218\t    store: &dyn ProjectStorePort,\n   219\t    run_port: &dyn RunSnapshotPort,\n   220\t    journal_port: &dyn JournalStorePort,\n   221\t    active_port: &dyn ActiveProjectPort,\n   222\t    base_dir: &Path,\n   223\t    project_id: &ProjectId,\n   224\t) -> AppResult<ProjectDetail> {\n   225\t    if !store.project_exists(base_dir, project_id)? {\n   226\t        return Err(AppError::ProjectNotFound {\n   227\t            project_id: project_id.to_string(),\n   228\t        });\n   229\t    }\n   230\t\n   231\t    let record = store.read_project_record(base_dir, project_id)?;\n   232\t    let run_snapshot = run_port.read_run_snapshot(base_dir, project_id)?;\n   233\t    let events = journal_port.read_journal(base_dir, project_id)?;\n   234\t    let journal_event_count = events.len() as u64;\n   235\t    let active_id = active_port.read_active_project_id(base_dir)?;\n   236\t    let is_active = active_id.as_deref() == Some(project_id.as_str());\n   237\t\n   238\t    // Count rollback points from journal events\n   239\t    let rollback_count = events\n   240\t        .iter()\n   241\t        .filter(|e| e.event_type == JournalEventType::RollbackCreated)\n   242\t        .count();\n   243\t\n   244\t    Ok(ProjectDetail {\n   245\t        record,\n   246\t        run_snapshot,\n   247\t        journal_event_count,\n   248\t        rollback_count,\n   249\t        is_active,\n   250\t    })\n   251\t}\n   252\t\n   253\t/// Delete a project. Fails if project has an active run.\n   254\t/// Clears active-project pointer if it pointed to the deleted project.\n   255\t///\n   256\t/// Transactional: if any post-validation step fails, the project remains\n   257\t/// addressable at its canonical path and the active-project pointer is\n   258\t/// unchanged.\n   259\tpub fn delete_project(\n   260\t    store: &dyn ProjectStorePort,\n   261\t    run_port: &dyn RunSnapshotPort,\n   262\t    active_port: &dyn ActiveProjectPort,\n   263\t    base_dir: &Path,\n   264\t    project_id: &ProjectId,\n   265\t) -> AppResult<()> {\n   266\t    if !store.project_exists(base_dir, project_id)? {\n   267\t        return Err(AppError::ProjectNotFound {\n   268\t            project_id: project_id.to_string(),\n   269\t        });\n   270\t    }\n   271\t\n   272\t    // Check for active run\n   273\t    let run_snapshot = run_port.read_run_snapshot(base_dir, project_id)?;\n   274\t    if run_snapshot.has_active_run() {\n   275\t        return Err(AppError::ActiveRunDelete {\n   276\t            project_id: project_id.to_string(),\n   277\t        });\n   278\t    }\n   279\t\n   280\t    // Check if this is the active project (before delete)\n   281\t    let active_id = active_port.read_active_project_id(base_dir)?;\n   282\t    let was_active = active_id.as_deref() == Some(project_id.as_str());\n   283\t\n   284\t    // Phase 1: Stage the delete — project becomes invisible to list/show\n   285\t    // but data remains on disk for rollback.\n   286\t    store.stage_delete(base_dir, project_id)?;\n   287\t\n   288\t    // Phase 2: Clear the active-project pointer if needed.\n   289\t    // If this fails, roll back the staged delete so the project remains\n   290\t    // addressable and the pointer is unchanged.\n   291\t    if was_active {\n   292\t        if let Err(clear_err) = active_port.clear_active_project(base_dir) {\n   293\t            store\n   294\t                .rollback_delete(base_dir, project_id)\n   295\t                .map_err(|restore_err| AppError::CorruptRecord {\n   296\t                    file: format!(\"projects/{}\", project_id),\n   297\t                    details: format!(\n   298\t                        \"delete partially failed: pointer clear error: {}, restore error: {}\",\n   299\t                        clear_err, restore_err\n   300\t                    ),\n   301\t                })?;\n   302\t            return Err(clear_err);\n   303\t        }\n   304\t    }\n   305\t\n   306\t    // Phase 3: Finalize — permanently remove the project data.\n   307\t    // At this point the logical delete has succeeded (project is invisible,\n   308\t    // pointer is cleared). Best-effort cleanup of the staged data.\n   309\t    let _ = store.commit_delete(base_dir, project_id);\n   310\t\n   311\t    Ok(())\n   312\t}\n   313\t\n   314\t/// Get run status for the active project.\n   315\tpub fn run_status(\n   316\t    run_port: &dyn RunSnapshotPort,\n   317\t    base_dir: &Path,\n   318\t    project_id: &ProjectId,\n   319\t) -> AppResult<RunStatusView> {\n   320\t    let snapshot = run_port.read_run_snapshot(base_dir, project_id)?;\n   321\t    Ok(queries::build_status_view(project_id.as_str(), &snapshot))\n   322\t}\n   323\t\n   324\t/// Get run history (durable only, no runtime logs).\n   325\tpub fn run_history(\n   326\t    journal_port: &dyn JournalStorePort,\n   327\t    artifact_port: &dyn ArtifactStorePort,\n   328\t    base_dir: &Path,\n   329\t    project_id: &ProjectId,\n   330\t) -> AppResult<RunHistoryView> {\n   331\t    let events = journal_port.read_journal(base_dir, project_id)?;\n   332\t    let payloads = artifact_port.list_payloads(base_dir, project_id)?;\n   333\t    let artifacts = artifact_port.list_artifacts(base_dir, project_id)?;\n   334\t\n   335\t    queries::validate_history_consistency(&payloads, &artifacts)?;\n   336\t\n   337\t    Ok(queries::build_history_view(\n   338\t        project_id.as_str(),\n   339\t        events,\n   340\t        payloads,\n   341\t        artifacts,\n   342\t    ))\n   343\t}\n   344\t\n   345\t/// Get run tail: durable history by default, with optional runtime logs.\n   346\tpub fn run_tail(\n   347\t    journal_port: &dyn JournalStorePort,\n   348\t    artifact_port: &dyn ArtifactStorePort,\n   349\t    log_port: &dyn RuntimeLogStorePort,\n   350\t    base_dir: &Path,\n   351\t    project_id: &ProjectId,\n   352\t    include_logs: bool,\n   353\t) -> AppResult<RunTailView> {\n   354\t    let events = journal_port.read_journal(base_dir, project_id)?;\n   355\t    let payloads = artifact_port.list_payloads(base_dir, project_id)?;\n   356\t    let artifacts = artifact_port.list_artifacts(base_dir, project_id)?;\n   357\t\n   358\t    queries::validate_history_consistency(&payloads, &artifacts)?;\n   359\t\n   360\t    let runtime_logs = if include_logs {\n   361\t        log_port.read_runtime_logs(base_dir, project_id)?\n   362\t    } else {\n   363\t        Vec::new()\n   364\t    };\n   365\t\n   366\t    Ok(queries::build_tail_view(\n   367\t        project_id.as_str(),\n   368\t        events,\n   369\t        payloads,\n   370\t        artifacts,\n   371\t        include_logs,\n   372\t        runtime_logs,\n   373\t    ))\n   374\t}\n","exit_code":0,"status":"completed"}}
{"type":"item.completed","item":{"id":"item_8","type":"command_execution","command":"/run/current-system/sw/bin/bash -lc \"nl -ba ralph-burning-rewrite/src/adapters/fs.rs | sed -n '1,520p'\"","aggregated_output":"     1\tuse std::env;\n     2\tuse std::fs::{self, OpenOptions};\n     3\tuse std::io::Write;\n     4\tuse std::path::{Path, PathBuf};\n     5\tuse std::process::Command;\n     6\tuse std::time::{SystemTime, UNIX_EPOCH};\n     7\t\n     8\tuse crate::contexts::agent_execution::model::RawOutputReference;\n     9\tuse crate::contexts::agent_execution::service::RawOutputPort;\n    10\tuse crate::contexts::agent_execution::session::{PersistedSessions, SessionStorePort};\n    11\tuse crate::contexts::project_run_record::journal;\n    12\tuse crate::contexts::project_run_record::model::{\n    13\t    ArtifactRecord, JournalEvent, PayloadRecord, ProjectRecord, RunSnapshot, RuntimeLogEntry,\n    14\t    SessionStore,\n    15\t};\n    16\tuse crate::contexts::project_run_record::service::{\n    17\t    ActiveProjectPort, ArtifactStorePort, JournalStorePort, PayloadArtifactWritePort,\n    18\t    ProjectStorePort, RunSnapshotPort, RunSnapshotWritePort, RuntimeLogStorePort,\n    19\t    RuntimeLogWritePort,\n    20\t};\n    21\tuse crate::shared::domain::{ProjectId, WorkspaceConfig};\n    22\tuse crate::shared::error::{AppError, AppResult};\n    23\t\n    24\tconst ACTIVE_PROJECT_FILE: &str = \"active-project\";\n    25\tconst WORKSPACE_DIR: &str = \".ralph-burning\";\n    26\tconst PROJECTS_DIR: &str = \"projects\";\n    27\tconst PROJECT_CONFIG_FILE: &str = \"project.toml\";\n    28\tconst RUN_FILE: &str = \"run.json\";\n    29\tconst JOURNAL_FILE: &str = \"journal.ndjson\";\n    30\tconst SESSIONS_FILE: &str = \"sessions.json\";\n    31\tconst PROMPT_FILE: &str = \"prompt.md\";\n    32\t\n    33\t/// Required subdirectories inside a project.\n    34\tconst PROJECT_SUBDIRS: &[&str] = &[\n    35\t    \"history/payloads\",\n    36\t    \"history/artifacts\",\n    37\t    \"runtime/logs\",\n    38\t    \"runtime/backend\",\n    39\t    \"runtime/temp\",\n    40\t    \"amendments\",\n    41\t    \"rollback\",\n    42\t];\n    43\t\n    44\tpub struct FileSystem;\n    45\t\n    46\timpl FileSystem {\n    47\t    pub fn create_workspace(\n    48\t        workspace_root: &Path,\n    49\t        workspace_config: &str,\n    50\t        required_directories: &[&str],\n    51\t    ) -> AppResult<()> {\n    52\t        fs::create_dir_all(workspace_root)?;\n    53\t\n    54\t        for directory in required_directories {\n    55\t            fs::create_dir_all(workspace_root.join(directory))?;\n    56\t        }\n    57\t\n    58\t        Self::write_atomic(&workspace_root.join(\"workspace.toml\"), workspace_config)?;\n    59\t        Ok(())\n    60\t    }\n    61\t\n    62\t    pub fn read_to_string(path: &Path) -> AppResult<String> {\n    63\t        Ok(fs::read_to_string(path)?)\n    64\t    }\n    65\t\n    66\t    pub fn write_atomic(path: &Path, contents: &str) -> AppResult<()> {\n    67\t        let parent = path.parent().ok_or_else(|| {\n    68\t            AppError::Io(std::io::Error::new(\n    69\t                std::io::ErrorKind::InvalidInput,\n    70\t                format!(\"path '{}' has no parent directory\", path.display()),\n    71\t            ))\n    72\t        })?;\n    73\t        fs::create_dir_all(parent)?;\n    74\t\n    75\t        let timestamp = SystemTime::now()\n    76\t            .duration_since(UNIX_EPOCH)\n    77\t            .map(|duration| duration.as_nanos())\n    78\t            .unwrap_or_default();\n    79\t        let temp_path = parent.join(format!(\n    80\t            \".{}.{}.{}.tmp\",\n    81\t            path.file_name()\n    82\t                .and_then(|value| value.to_str())\n    83\t                .unwrap_or(\"workspace\"),\n    84\t            std::process::id(),\n    85\t            timestamp\n    86\t        ));\n    87\t\n    88\t        let mut file = OpenOptions::new()\n    89\t            .create_new(true)\n    90\t            .write(true)\n    91\t            .open(&temp_path)?;\n    92\t        file.write_all(contents.as_bytes())?;\n    93\t        file.sync_all()?;\n    94\t        drop(file);\n    95\t\n    96\t        if let Err(error) = fs::rename(&temp_path, path) {\n    97\t            let _ = fs::remove_file(&temp_path);\n    98\t            return Err(error.into());\n    99\t        }\n   100\t\n   101\t        Ok(())\n   102\t    }\n   103\t\n   104\t    pub fn render_workspace_config(config: &WorkspaceConfig) -> AppResult<String> {\n   105\t        Ok(toml::to_string_pretty(config)?)\n   106\t    }\n   107\t\n   108\t    pub fn read_active_project(workspace_root: &Path) -> AppResult<Option<String>> {\n   109\t        let path = workspace_root.join(ACTIVE_PROJECT_FILE);\n   110\t        match fs::read_to_string(path) {\n   111\t            Ok(raw) => {\n   112\t                let trimmed = raw.trim();\n   113\t                if trimmed.is_empty() {\n   114\t                    Ok(None)\n   115\t                } else {\n   116\t                    Ok(Some(trimmed.to_owned()))\n   117\t                }\n   118\t            }\n   119\t            Err(error) if error.kind() == std::io::ErrorKind::NotFound => Ok(None),\n   120\t            Err(error) => Err(error.into()),\n   121\t        }\n   122\t    }\n   123\t\n   124\t    pub fn write_active_project(workspace_root: &Path, project_id: &str) -> AppResult<()> {\n   125\t        Self::write_atomic(&workspace_root.join(ACTIVE_PROJECT_FILE), project_id)\n   126\t    }\n   127\t\n   128\t    pub fn open_editor(path: &Path) -> AppResult<()> {\n   129\t        let editor = env::var(\"EDITOR\")\n   130\t            .ok()\n   131\t            .filter(|value| !value.trim().is_empty())\n   132\t            .or_else(|| {\n   133\t                env::var(\"VISUAL\")\n   134\t                    .ok()\n   135\t                    .filter(|value| !value.trim().is_empty())\n   136\t            })\n   137\t            .unwrap_or_else(|| \"vi\".to_owned());\n   138\t\n   139\t        let mut parts = editor.split_whitespace();\n   140\t        let program = parts.next().ok_or_else(|| AppError::EditorFailed {\n   141\t            editor: editor.clone(),\n   142\t            details: \": empty editor command\".to_owned(),\n   143\t        })?;\n   144\t        let status = Command::new(program).args(parts).arg(path).status()?;\n   145\t\n   146\t        if status.success() {\n   147\t            Ok(())\n   148\t        } else {\n   149\t            let details = match status.code() {\n   150\t                Some(code) => format!(\" with exit code {code}\"),\n   151\t                None => \" after being terminated by a signal\".to_owned(),\n   152\t            };\n   153\t            Err(AppError::EditorFailed { editor, details })\n   154\t        }\n   155\t    }\n   156\t\n   157\t    /// Compute a simple hash of content for prompt integrity tracking.\n   158\t    pub fn prompt_hash(contents: &str) -> String {\n   159\t        use std::collections::hash_map::DefaultHasher;\n   160\t        use std::hash::{Hash, Hasher};\n   161\t        let mut hasher = DefaultHasher::new();\n   162\t        contents.hash(&mut hasher);\n   163\t        format!(\"{:016x}\", hasher.finish())\n   164\t    }\n   165\t\n   166\t    // ── Helpers for project filesystem layout ──\n   167\t\n   168\t    fn workspace_root_path(base_dir: &Path) -> PathBuf {\n   169\t        base_dir.join(WORKSPACE_DIR)\n   170\t    }\n   171\t\n   172\t    fn project_root(base_dir: &Path, project_id: &ProjectId) -> PathBuf {\n   173\t        Self::workspace_root_path(base_dir)\n   174\t            .join(PROJECTS_DIR)\n   175\t            .join(project_id.as_str())\n   176\t    }\n   177\t\n   178\t    fn pending_delete_path(base_dir: &Path, project_id: &ProjectId) -> PathBuf {\n   179\t        Self::workspace_root_path(base_dir)\n   180\t            .join(PROJECTS_DIR)\n   181\t            .join(format!(\".{}.pending-delete\", project_id))\n   182\t    }\n   183\t\n   184\t    fn append_line(path: &Path, line: &str) -> AppResult<()> {\n   185\t        let parent = path.parent().ok_or_else(|| {\n   186\t            AppError::Io(std::io::Error::new(\n   187\t                std::io::ErrorKind::InvalidInput,\n   188\t                format!(\"path '{}' has no parent directory\", path.display()),\n   189\t            ))\n   190\t        })?;\n   191\t        fs::create_dir_all(parent)?;\n   192\t\n   193\t        let mut file = OpenOptions::new().create(true).append(true).open(path)?;\n   194\t        writeln!(file, \"{}\", line)?;\n   195\t        file.sync_all()?;\n   196\t        Ok(())\n   197\t    }\n   198\t}\n   199\t\n   200\t/// Filesystem-backed implementation of `ProjectStorePort`.\n   201\tpub struct FsProjectStore;\n   202\t\n   203\timpl ProjectStorePort for FsProjectStore {\n   204\t    fn project_exists(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<bool> {\n   205\t        let project_root = FileSystem::project_root(base_dir, project_id);\n   206\t        if !project_root.is_dir() {\n   207\t            return Ok(false);\n   208\t        }\n   209\t        if !project_root.join(PROJECT_CONFIG_FILE).is_file() {\n   210\t            return Err(AppError::CorruptRecord {\n   211\t                file: format!(\"projects/{}/project.toml\", project_id),\n   212\t                details: \"project directory exists but canonical project.toml is missing\"\n   213\t                    .to_owned(),\n   214\t            });\n   215\t        }\n   216\t        Ok(true)\n   217\t    }\n   218\t\n   219\t    fn read_project_record(\n   220\t        &self,\n   221\t        base_dir: &Path,\n   222\t        project_id: &ProjectId,\n   223\t    ) -> AppResult<ProjectRecord> {\n   224\t        let project_root = FileSystem::project_root(base_dir, project_id);\n   225\t        let path = project_root.join(PROJECT_CONFIG_FILE);\n   226\t        let raw = fs::read_to_string(&path).map_err(|e| {\n   227\t            if e.kind() == std::io::ErrorKind::NotFound {\n   228\t                if project_root.is_dir() {\n   229\t                    // Directory exists but project.toml is missing — corruption\n   230\t                    AppError::CorruptRecord {\n   231\t                        file: format!(\"projects/{}/project.toml\", project_id),\n   232\t                        details: \"project directory exists but canonical project.toml is missing\"\n   233\t                            .to_owned(),\n   234\t                    }\n   235\t                } else {\n   236\t                    AppError::ProjectNotFound {\n   237\t                        project_id: project_id.to_string(),\n   238\t                    }\n   239\t                }\n   240\t            } else {\n   241\t                e.into()\n   242\t            }\n   243\t        })?;\n   244\t        toml::from_str(&raw).map_err(|e| AppError::CorruptRecord {\n   245\t            file: format!(\"projects/{}/project.toml\", project_id),\n   246\t            details: e.to_string(),\n   247\t        })\n   248\t    }\n   249\t\n   250\t    fn list_project_ids(&self, base_dir: &Path) -> AppResult<Vec<ProjectId>> {\n   251\t        let projects_dir = FileSystem::workspace_root_path(base_dir).join(PROJECTS_DIR);\n   252\t        if !projects_dir.is_dir() {\n   253\t            return Ok(Vec::new());\n   254\t        }\n   255\t\n   256\t        let mut ids = Vec::new();\n   257\t        for entry in fs::read_dir(&projects_dir)? {\n   258\t            let entry = entry?;\n   259\t            if !entry.file_type()?.is_dir() {\n   260\t                continue;\n   261\t            }\n   262\t            let name = entry.file_name();\n   263\t            let name_str = name.to_string_lossy();\n   264\t            // Skip hidden directories (staging/trash from transactional operations)\n   265\t            if name_str.starts_with('.') {\n   266\t                continue;\n   267\t            }\n   268\t            if let Ok(pid) = ProjectId::new(name_str.as_ref()) {\n   269\t                if !entry.path().join(PROJECT_CONFIG_FILE).is_file() {\n   270\t                    return Err(AppError::CorruptRecord {\n   271\t                        file: format!(\"projects/{}/project.toml\", name_str),\n   272\t                        details: \"project directory exists but canonical project.toml is missing\"\n   273\t                            .to_owned(),\n   274\t                    });\n   275\t                }\n   276\t                ids.push(pid);\n   277\t            }\n   278\t        }\n   279\t\n   280\t        ids.sort_by(|a, b| a.as_str().cmp(b.as_str()));\n   281\t        Ok(ids)\n   282\t    }\n   283\t\n   284\t    fn stage_delete(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<()> {\n   285\t        let project_root = FileSystem::project_root(base_dir, project_id);\n   286\t        if !project_root.is_dir() {\n   287\t            return Err(AppError::ProjectNotFound {\n   288\t                project_id: project_id.to_string(),\n   289\t            });\n   290\t        }\n   291\t\n   292\t        let pending_path = FileSystem::pending_delete_path(base_dir, project_id);\n   293\t\n   294\t        // Clean up any leftover pending-delete from a previous crash\n   295\t        if pending_path.exists() {\n   296\t            fs::remove_dir_all(&pending_path)?;\n   297\t        }\n   298\t\n   299\t        // Atomic rename to pending-delete location — project becomes\n   300\t        // invisible to list/show but data stays on disk.\n   301\t        fs::rename(&project_root, &pending_path)?;\n   302\t        Ok(())\n   303\t    }\n   304\t\n   305\t    fn commit_delete(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<()> {\n   306\t        let pending_path = FileSystem::pending_delete_path(base_dir, project_id);\n   307\t        if pending_path.is_dir() {\n   308\t            fs::remove_dir_all(&pending_path)?;\n   309\t        }\n   310\t        Ok(())\n   311\t    }\n   312\t\n   313\t    fn rollback_delete(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<()> {\n   314\t        let project_root = FileSystem::project_root(base_dir, project_id);\n   315\t        let pending_path = FileSystem::pending_delete_path(base_dir, project_id);\n   316\t\n   317\t        if !pending_path.is_dir() {\n   318\t            return Ok(());\n   319\t        }\n   320\t\n   321\t        fs::rename(&pending_path, &project_root)?;\n   322\t        Ok(())\n   323\t    }\n   324\t\n   325\t    fn create_project_atomic(\n   326\t        &self,\n   327\t        base_dir: &Path,\n   328\t        record: &ProjectRecord,\n   329\t        prompt_contents: &str,\n   330\t        run_snapshot: &RunSnapshot,\n   331\t        initial_journal_line: &str,\n   332\t        sessions: &SessionStore,\n   333\t    ) -> AppResult<()> {\n   334\t        let project_root = FileSystem::project_root(base_dir, &record.id);\n   335\t\n   336\t        // Stage into a temporary directory alongside the final location\n   337\t        let staging_name = format!(\".{}.staging.{}\", record.id, std::process::id());\n   338\t        let staging_root = project_root\n   339\t            .parent()\n   340\t            .expect(\"project root has parent\")\n   341\t            .join(&staging_name);\n   342\t\n   343\t        // Clean up any leftover staging dir\n   344\t        if staging_root.exists() {\n   345\t            fs::remove_dir_all(&staging_root)?;\n   346\t        }\n   347\t\n   348\t        // Create staging directory and all subdirs\n   349\t        fs::create_dir_all(&staging_root)?;\n   350\t        for subdir in PROJECT_SUBDIRS {\n   351\t            fs::create_dir_all(staging_root.join(subdir))?;\n   352\t        }\n   353\t\n   354\t        // Write all canonical files into staging\n   355\t        let write_result = (|| -> AppResult<()> {\n   356\t            // project.toml\n   357\t            let project_toml = toml::to_string_pretty(record)\n   358\t                .map_err(|e| AppError::Io(std::io::Error::other(e.to_string())))?;\n   359\t            fs::write(staging_root.join(PROJECT_CONFIG_FILE), project_toml)?;\n   360\t\n   361\t            // prompt.md\n   362\t            fs::write(staging_root.join(PROMPT_FILE), prompt_contents)?;\n   363\t\n   364\t            // run.json\n   365\t            let run_json = serde_json::to_string_pretty(run_snapshot)?;\n   366\t            fs::write(staging_root.join(RUN_FILE), run_json)?;\n   367\t\n   368\t            // journal.ndjson (with initial event)\n   369\t            let mut journal_content = initial_journal_line.to_owned();\n   370\t            journal_content.push('\\n');\n   371\t            fs::write(staging_root.join(JOURNAL_FILE), journal_content)?;\n   372\t\n   373\t            // sessions.json\n   374\t            let sessions_json = serde_json::to_string_pretty(sessions)?;\n   375\t            fs::write(staging_root.join(SESSIONS_FILE), sessions_json)?;\n   376\t\n   377\t            Ok(())\n   378\t        })();\n   379\t\n   380\t        if let Err(e) = write_result {\n   381\t            // Clean up staging on failure\n   382\t            let _ = fs::remove_dir_all(&staging_root);\n   383\t            return Err(e);\n   384\t        }\n   385\t\n   386\t        // Atomic rename from staging to final location\n   387\t        if let Err(e) = fs::rename(&staging_root, &project_root) {\n   388\t            let _ = fs::remove_dir_all(&staging_root);\n   389\t            return Err(e.into());\n   390\t        }\n   391\t\n   392\t        Ok(())\n   393\t    }\n   394\t}\n   395\t\n   396\t/// Filesystem-backed implementation of `JournalStorePort`.\n   397\tpub struct FsJournalStore;\n   398\t\n   399\timpl JournalStorePort for FsJournalStore {\n   400\t    fn read_journal(\n   401\t        &self,\n   402\t        base_dir: &Path,\n   403\t        project_id: &ProjectId,\n   404\t    ) -> AppResult<Vec<JournalEvent>> {\n   405\t        let path = FileSystem::project_root(base_dir, project_id).join(JOURNAL_FILE);\n   406\t        match fs::read_to_string(&path) {\n   407\t            Ok(contents) => journal::parse_journal(&contents),\n   408\t            Err(e) if e.kind() == std::io::ErrorKind::NotFound => Err(AppError::CorruptRecord {\n   409\t                file: format!(\"projects/{}/journal.ndjson\", project_id),\n   410\t                details: \"canonical file is missing\".to_owned(),\n   411\t            }),\n   412\t            Err(e) => Err(e.into()),\n   413\t        }\n   414\t    }\n   415\t\n   416\t    fn append_event(&self, base_dir: &Path, project_id: &ProjectId, line: &str) -> AppResult<()> {\n   417\t        let path = FileSystem::project_root(base_dir, project_id).join(JOURNAL_FILE);\n   418\t        FileSystem::append_line(&path, line)\n   419\t    }\n   420\t}\n   421\t\n   422\t/// Filesystem-backed implementation of `ArtifactStorePort`.\n   423\tpub struct FsArtifactStore;\n   424\t\n   425\timpl ArtifactStorePort for FsArtifactStore {\n   426\t    fn list_payloads(\n   427\t        &self,\n   428\t        base_dir: &Path,\n   429\t        project_id: &ProjectId,\n   430\t    ) -> AppResult<Vec<PayloadRecord>> {\n   431\t        let dir = FileSystem::project_root(base_dir, project_id).join(\"history/payloads\");\n   432\t        if !dir.is_dir() {\n   433\t            return Ok(Vec::new());\n   434\t        }\n   435\t\n   436\t        let mut records = Vec::new();\n   437\t        for entry in fs::read_dir(&dir)? {\n   438\t            let entry = entry?;\n   439\t            let path = entry.path();\n   440\t            if path.extension().is_some_and(|ext| ext == \"json\") {\n   441\t                let raw = fs::read_to_string(&path)?;\n   442\t                let record: PayloadRecord =\n   443\t                    serde_json::from_str(&raw).map_err(|e| AppError::CorruptRecord {\n   444\t                        file: format!(\n   445\t                            \"history/payloads/{}\",\n   446\t                            path.file_name().unwrap_or_default().to_string_lossy()\n   447\t                        ),\n   448\t                        details: e.to_string(),\n   449\t                    })?;\n   450\t                records.push(record);\n   451\t            }\n   452\t        }\n   453\t\n   454\t        records.sort_by_key(|r| r.created_at);\n   455\t        Ok(records)\n   456\t    }\n   457\t\n   458\t    fn list_artifacts(\n   459\t        &self,\n   460\t        base_dir: &Path,\n   461\t        project_id: &ProjectId,\n   462\t    ) -> AppResult<Vec<ArtifactRecord>> {\n   463\t        let dir = FileSystem::project_root(base_dir, project_id).join(\"history/artifacts\");\n   464\t        if !dir.is_dir() {\n   465\t            return Ok(Vec::new());\n   466\t        }\n   467\t\n   468\t        let mut records = Vec::new();\n   469\t        for entry in fs::read_dir(&dir)? {\n   470\t            let entry = entry?;\n   471\t            let path = entry.path();\n   472\t            if path.extension().is_some_and(|ext| ext == \"json\") {\n   473\t                let raw = fs::read_to_string(&path)?;\n   474\t                let record: ArtifactRecord =\n   475\t                    serde_json::from_str(&raw).map_err(|e| AppError::CorruptRecord {\n   476\t                        file: format!(\n   477\t                            \"history/artifacts/{}\",\n   478\t                            path.file_name().unwrap_or_default().to_string_lossy()\n   479\t                        ),\n   480\t                        details: e.to_string(),\n   481\t                    })?;\n   482\t                records.push(record);\n   483\t            }\n   484\t        }\n   485\t\n   486\t        records.sort_by_key(|r| r.created_at);\n   487\t        Ok(records)\n   488\t    }\n   489\t}\n   490\t\n   491\t/// Filesystem-backed implementation of `RuntimeLogStorePort`.\n   492\tpub struct FsRuntimeLogStore;\n   493\t\n   494\timpl RuntimeLogStorePort for FsRuntimeLogStore {\n   495\t    fn read_runtime_logs(\n   496\t        &self,\n   497\t        base_dir: &Path,\n   498\t        project_id: &ProjectId,\n   499\t    ) -> AppResult<Vec<RuntimeLogEntry>> {\n   500\t        let dir = FileSystem::project_root(base_dir, project_id).join(\"runtime/logs\");\n   501\t        if !dir.is_dir() {\n   502\t            return Ok(Vec::new());\n   503\t        }\n   504\t\n   505\t        let mut entries = Vec::new();\n   506\t        let mut paths: Vec<_> = fs::read_dir(&dir)?\n   507\t            .filter_map(|e| e.ok())\n   508\t            .map(|e| e.path())\n   509\t            .filter(|p| p.extension().is_some_and(|ext| ext == \"ndjson\"))\n   510\t            .collect();\n   511\t        paths.sort();\n   512\t\n   513\t        // Only read the newest/latest log file per spec:\n   514\t        // \"run tail --logs appends the newest runtime logs\"\n   515\t        if let Some(path) = paths.last() {\n   516\t            let contents = fs::read_to_string(path)?;\n   517\t            for line in contents.lines() {\n   518\t                let trimmed = line.trim();\n   519\t                if trimmed.is_empty() {\n   520\t                    continue;\n","exit_code":0,"status":"completed"}}
