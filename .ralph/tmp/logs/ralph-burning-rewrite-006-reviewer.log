tage_entry.role,\n   304\t            resolved_target: stage_entry.target.clone(),\n   305\t            payload: InvocationPayload {\n   306\t                prompt: format!(\"Execute stage: {}\", stage_id.display_name()),\n   307\t                context: serde_json::json!({}),\n   308\t            },\n   309\t            timeout: Duration::from_secs(300),\n   310\t            cancellation_token: CancellationToken::new(),\n   311\t            session_policy: SessionPolicy::ReuseIfAllowed,\n   312\t            prior_session: None,\n   313\t            attempt_number: cursor.attempt,\n   314\t        };\n   315\t\n   316\t        let envelope = match agent_service.invoke(request).await {\n   317\t            Ok(env) => env,\n   318\t            Err(e) => {\n   319\t                return fail_run(\n   320\t                    &e,\n   321\t                    stage_id,\n   322\t                    &run_id,\n   323\t                    &mut seq,\n   324\t                    &mut current_snapshot,\n   325\t                    journal_store,\n   326\t                    run_snapshot_write,\n   327\t                    base_dir,\n   328\t                    project_id,\n   329\t                )\n   330\t                .await;\n   331\t            }\n   332\t        };\n   333\t\n   334\t        // Evaluate the contract (schema + domain + outcome + render)\n   335\t        let bundle = match stage_entry.contract.evaluate(&envelope.parsed_payload) {\n   336\t            Ok(bundle) => bundle,\n   337\t            Err(contract_err) => {\n   338\t                let app_err = AppError::InvocationFailed {\n   339\t                    backend: stage_entry.target.backend.family.to_string(),\n   340\t                    stage_id,\n   341\t                    failure_class: contract_err.failure_class(),\n   342\t                    details: contract_err.to_string(),\n   343\t                };\n   344\t                return fail_run(\n   345\t                    &app_err,\n   346\t                    stage_id,\n   347\t                    &run_id,\n   348\t                    &mut seq,\n   349\t                    &mut current_snapshot,\n   350\t                    journal_store,\n   351\t                    run_snapshot_write,\n   352\t                    base_dir,\n   353\t                    project_id,\n   354\t                )\n   355\t                .await;\n   356\t            }\n   357\t        };\n   358\t\n   359\t        // Persist payload + artifact pair atomically\n   360\t        let stage_now = Utc::now();\n   361\t        let payload_id = format!(\n   362\t            \"{}-{}-c{}-a{}\",\n   363\t            run_id.as_str(),\n   364\t            stage_id.as_str(),\n   365\t            cursor.cycle,\n   366\t            cursor.attempt\n   367\t        );\n   368\t        let artifact_id = format!(\"{}-artifact\", payload_id);\n   369\t\n   370\t        let payload_record = PayloadRecord {\n   371\t            payload_id: payload_id.clone(),\n   372\t            stage_id,\n   373\t            cycle: cursor.cycle,\n   374\t            attempt: cursor.attempt,\n   375\t            created_at: stage_now,\n   376\t            payload: serde_json::to_value(&bundle.payload)?,\n   377\t        };\n   378\t        let artifact_record = ArtifactRecord {\n   379\t            artifact_id: artifact_id.clone(),\n   380\t            payload_id: payload_id.clone(),\n   381\t            stage_id,\n   382\t            created_at: stage_now,\n   383\t            content: bundle.artifact.clone(),\n   384\t        };\n   385\t\n   386\t        // Atomic stage commit: payload + artifact + snapshot + journal.\n   387\t        // All four must succeed for the stage to become durably visible.\n   388\t        // Order: payload/artifact → snapshot cursor → stage_completed journal.\n   389\t        // This ensures that if any step fails, no stage_completed event leaks\n   390\t        // into the journal without a matching snapshot and durable files.\n   391\t\n   392\t        // Step 1: Write payload + artifact pair.\n   393\t        // If this fails after stage_entered, the run must persist failed state.\n   394\t        if let Err(e) =\n   395\t            artifact_write.write_payload_artifact_pair(base_dir, project_id, &payload_record, &artifact_record)\n   396\t        {\n   397\t            let commit_err = AppError::StageCommitFailed {\n   398\t                stage_id,\n   399\t                details: format!(\"payload/artifact persistence failed: {}\", e),\n   400\t            };\n   401\t            return fail_run(\n   402\t                &commit_err,\n   403\t                stage_id,\n   404\t                &run_id,\n   405\t                &mut seq,\n   406\t                &mut current_snapshot,\n   407\t                journal_store,\n   408\t                run_snapshot_write,\n   409\t                base_dir,\n   410\t                project_id,\n   411\t            )\n   412\t            .await;\n   413\t        }\n   414\t\n   415\t        // Step 2: Update snapshot cursor to reflect completed stage.\n   416\t        // Written BEFORE stage_completed journal so that snapshot failure\n   417\t        // never leaves a stage_completed event without a matching cursor.\n   418\t        let pre_commit_snapshot = current_snapshot.clone();\n   419\t        if idx + 1 < stage_plan.len() {\n   420\t            let next_stage = stage_plan[idx + 1].stage_id;\n   421\t            current_snapshot.active_run.as_mut().unwrap().stage_cursor =\n   422\t                StageCursor::initial(next_stage);\n   423\t            current_snapshot.status_summary = format!(\n   424\t                \"running: completed {}, next {}\",\n   425\t                stage_id.display_name(),\n   426\t                next_stage.display_name()\n   427\t            );\n   428\t        }\n   429\t        if let Err(e) = run_snapshot_write.write_run_snapshot(base_dir, project_id, &current_snapshot) {\n   430\t            // Roll back payload/artifact; no stage_completed was written yet.\n   431\t            // Propagate rollback failure so leaked durable history is surfaced.\n   432\t            let rollback_detail = match artifact_write.remove_payload_artifact_pair(base_dir, project_id, &payload_id, &artifact_id) {\n   433\t                Ok(()) => String::new(),\n   434\t                Err(cleanup_err) => format!(\"; payload/artifact rollback failed: {} — leaked durable history may exist\", cleanup_err),\n   435\t            };\n   436\t            current_snapshot = pre_commit_snapshot;\n   437\t            let commit_err = AppError::StageCommitFailed {\n   438\t                stage_id,\n   439\t                details: format!(\"snapshot write failed during stage commit: {}{}\", e, rollback_detail),\n   440\t            };\n   441\t            return fail_run(\n   442\t                &commit_err,\n   443\t                stage_id,\n   444\t                &run_id,\n   445\t                &mut seq,\n   446\t                &mut current_snapshot,\n   447\t                journal_store,\n   448\t                run_snapshot_write,\n   449\t                base_dir,\n   450\t                project_id,\n   451\t            )\n   452\t            .await;\n   453\t        }\n   454\t\n   455\t        // Step 3: Append stage_completed journal event.\n   456\t        // If this fails, roll back payload/artifact and overwrite snapshot\n   457\t        // via fail_run so the stage remains uncommitted.\n   458\t        seq += 1;\n   459\t        let stage_completed = journal::stage_completed_event(\n   460\t            seq,\n   461\t            Utc::now(),\n   462\t            &run_id,\n   463\t            stage_id,\n   464\t            cursor.cycle,\n   465\t            cursor.attempt,\n   466\t            &payload_id,\n   467\t            &artifact_id,\n   468\t        );\n   469\t        let stage_completed_line = journal::serialize_event(&stage_completed)?;\n   470\t        if let Err(e) = journal_store.append_event(base_dir, project_id, &stage_completed_line) {\n   471\t            // Roll back payload/artifact so no partial durable history is visible.\n   472\t            // Propagate rollback failure so leaked durable history is surfaced.\n   473\t            let rollback_detail = match artifact_write.remove_payload_artifact_pair(base_dir, project_id, &payload_id, &artifact_id) {\n   474\t                Ok(()) => String::new(),\n   475\t                Err(cleanup_err) => format!(\"; payload/artifact rollback failed: {} — leaked durable history may exist\", cleanup_err),\n   476\t            };\n   477\t            seq -= 1; // undo the seq increment since the event was not persisted\n   478\t            let commit_err = AppError::StageCommitFailed {\n   479\t                stage_id,\n   480\t                details: format!(\"journal append failed during stage commit: {}{}\", e, rollback_detail),\n   481\t            };\n   482\t            return fail_run(\n   483\t                &commit_err,\n   484\t                stage_id,\n   485\t                &run_id,\n   486\t                &mut seq,\n   487\t                &mut current_snapshot,\n   488\t                journal_store,\n   489\t                run_snapshot_write,\n   490\t                base_dir,\n   491\t                project_id,\n   492\t            )\n   493\t            .await;\n   494\t        }\n   495\t\n   496\t        // Best-effort runtime log\n   497\t        let _ = log_write.append_runtime_log(\n   498\t            base_dir,\n   499\t            project_id,\n   500\t            &RuntimeLogEntry {\n   501\t                timestamp: Utc::now(),\n   502\t                level: LogLevel::Info,\n   503\t                source: \"engine\".to_owned(),\n   504\t                message: format!(\"stage_completed: {}\", stage_id.as_str()),\n   505\t            },\n   506\t        );\n   507\t    }\n   508\t\n   509\t    // 8. All stages completed — mark run as completed