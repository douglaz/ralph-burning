{"type":"item.completed","item":{"id":"item_13","type":"command_execution","command":"/run/current-system/sw/bin/bash -lc \"nl -ba ralph-burning-rewrite/src/contexts/project_run_record/queries.rs | sed -n '1,340p'\"","aggregated_output":"     1\tuse crate::shared::error::AppResult;\n     2\t\n     3\tuse super::model::{ArtifactRecord, JournalEvent, PayloadRecord, RunSnapshot, RuntimeLogEntry};\n     4\t\n     5\t/// Read model for `run status`: canonical state only, no inference from artifacts.\n     6\t#[derive(Debug, Clone)]\n     7\tpub struct RunStatusView {\n     8\t    pub project_id: String,\n     9\t    pub status: String,\n    10\t    pub stage: Option<String>,\n    11\t    pub cycle: Option<u32>,\n    12\t    pub completion_round: Option<u32>,\n    13\t    pub summary: String,\n    14\t}\n    15\t\n    16\timpl RunStatusView {\n    17\t    pub fn from_snapshot(project_id: &str, snapshot: &RunSnapshot) -> Self {\n    18\t        match &snapshot.active_run {\n    19\t            Some(active) => Self {\n    20\t                project_id: project_id.to_owned(),\n    21\t                status: snapshot.status.display_str().to_owned(),\n    22\t                stage: Some(active.stage_cursor.stage.as_str().to_owned()),\n    23\t                cycle: Some(active.stage_cursor.cycle),\n    24\t                completion_round: Some(active.stage_cursor.completion_round),\n    25\t                summary: snapshot.status_summary.clone(),\n    26\t            },\n    27\t            None => Self {\n    28\t                project_id: project_id.to_owned(),\n    29\t                status: snapshot.status.display_str().to_owned(),\n    30\t                stage: None,\n    31\t                cycle: None,\n    32\t                completion_round: None,\n    33\t                summary: snapshot.status_summary.clone(),\n    34\t            },\n    35\t        }\n    36\t    }\n    37\t}\n    38\t\n    39\t/// Read model for `run history`: durable history only (journal + payloads + artifacts).\n    40\t/// Runtime logs never appear here.\n    41\t#[derive(Debug, Clone)]\n    42\tpub struct RunHistoryView {\n    43\t    pub project_id: String,\n    44\t    pub events: Vec<JournalEvent>,\n    45\t    pub payloads: Vec<PayloadRecord>,\n    46\t    pub artifacts: Vec<ArtifactRecord>,\n    47\t}\n    48\t\n    49\t/// Read model for `run tail`: durable history by default, with optional runtime logs.\n    50\t#[derive(Debug, Clone)]\n    51\tpub struct RunTailView {\n    52\t    pub project_id: String,\n    53\t    pub events: Vec<JournalEvent>,\n    54\t    pub payloads: Vec<PayloadRecord>,\n    55\t    pub artifacts: Vec<ArtifactRecord>,\n    56\t    pub runtime_logs: Option<Vec<RuntimeLogEntry>>,\n    57\t}\n    58\t\n    59\t/// Build a status view from canonical run state.\n    60\tpub fn build_status_view(project_id: &str, snapshot: &RunSnapshot) -> RunStatusView {\n    61\t    RunStatusView::from_snapshot(project_id, snapshot)\n    62\t}\n    63\t\n    64\t/// Build a history view from durable records only. No runtime logs.\n    65\tpub fn build_history_view(\n    66\t    project_id: &str,\n    67\t    events: Vec<JournalEvent>,\n    68\t    payloads: Vec<PayloadRecord>,\n    69\t    artifacts: Vec<ArtifactRecord>,\n    70\t) -> RunHistoryView {\n    71\t    RunHistoryView {\n    72\t        project_id: project_id.to_owned(),\n    73\t        events,\n    74\t        payloads,\n    75\t        artifacts,\n    76\t    }\n    77\t}\n    78\t\n    79\t/// Build a tail view: durable history always, runtime logs only when requested.\n    80\tpub fn build_tail_view(\n    81\t    project_id: &str,\n    82\t    events: Vec<JournalEvent>,\n    83\t    payloads: Vec<PayloadRecord>,\n    84\t    artifacts: Vec<ArtifactRecord>,\n    85\t    include_logs: bool,\n    86\t    runtime_logs: Vec<RuntimeLogEntry>,\n    87\t) -> RunTailView {\n    88\t    RunTailView {\n    89\t        project_id: project_id.to_owned(),\n    90\t        events,\n    91\t        payloads,\n    92\t        artifacts,\n    93\t        runtime_logs: if include_logs {\n    94\t            Some(runtime_logs)\n    95\t        } else {\n    96\t            None\n    97\t        },\n    98\t    }\n    99\t}\n   100\t\n   101\t/// Validate that durable history records are consistent:\n   102\t/// every artifact has a matching payload and every payload has a matching artifact.\n   103\t/// Payload + artifact are treated as a paired durable-history unit.\n   104\tpub fn validate_history_consistency(\n   105\t    payloads: &[PayloadRecord],\n   106\t    artifacts: &[ArtifactRecord],\n   107\t) -> AppResult<()> {\n   108\t    // Check orphaned artifacts (artifact without matching payload)\n   109\t    for artifact in artifacts {\n   110\t        if !payloads.iter().any(|p| p.payload_id == artifact.payload_id) {\n   111\t            return Err(crate::shared::error::AppError::CorruptRecord {\n   112\t                file: format!(\"history/artifacts/{}\", artifact.artifact_id),\n   113\t                details: format!(\n   114\t                    \"artifact references payload '{}' which does not exist\",\n   115\t                    artifact.payload_id\n   116\t                ),\n   117\t            });\n   118\t        }\n   119\t    }\n   120\t    // Check orphaned payloads (payload without matching artifact)\n   121\t    for payload in payloads {\n   122\t        if !artifacts.iter().any(|a| a.payload_id == payload.payload_id) {\n   123\t            return Err(crate::shared::error::AppError::CorruptRecord {\n   124\t                file: format!(\"history/payloads/{}\", payload.payload_id),\n   125\t                details: \"payload has no matching artifact\".to_owned(),\n   126\t            });\n   127\t        }\n   128\t    }\n   129\t    Ok(())\n   130\t}\n","exit_code":0,"status":"completed"}}
