\t}\n   355\t\n   356\t/// Get run tail: durable history by default, with optional runtime logs.\n   357\tpub fn run_tail(\n   358\t    journal_port: &dyn JournalStorePort,\n   359\t    artifact_port: &dyn ArtifactStorePort,\n   360\t    log_port: &dyn RuntimeLogStorePort,\n   361\t    base_dir: &Path,\n   362\t    project_id: &ProjectId,\n   363\t    include_logs: bool,\n   364\t) -> AppResult<RunTailView> {\n   365\t    let events = journal_port.read_journal(base_dir, project_id)?;\n   366\t    let payloads = artifact_port.list_payloads(base_dir, project_id)?;\n   367\t    let artifacts = artifact_port.list_artifacts(base_dir, project_id)?;\n   368\t\n   369\t    queries::validate_history_consistency(&payloads, &artifacts)?;\n   370\t\n   371\t    let runtime_logs = if include_logs {\n   372\t        log_port.read_runtime_logs(base_dir, project_id)?\n   373\t    } else {\n   374\t        Vec::new()\n   375\t    };\n   376\t\n   377\t    Ok(queries::build_tail_view(\n   378\t        project_id.as_str(),\n   379\t        events,\n   380\t        payloads,\n   381\t        artifacts,\n   382\t        include_logs,\n   383\t        runtime_logs,\n   384\t    ))\n   385\t}\n","exit_code":0,"status":"completed"}}
