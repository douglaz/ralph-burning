r,\n   253\t        }\n   254\t    }\n   255\t}\n   256\t\n   257\timpl fmt::Display for BackendRole {\n   258\t    fn fmt(&self, f: &mut fmt::Formatter<'_>) -> fmt::Result {\n   259\t        f.write_str(self.as_str())\n   260\t    }\n   261\t}\n   262\t\n   263\t#[derive(Debug, Clone, Copy, PartialEq, Eq, Hash, Serialize, Deserialize)]\n   264\t#[serde(rename_all = \"snake_case\")]\n   265\tpub enum SessionPolicy {\n   266\t    NewSession,\n   267\t    ReuseIfAllowed,\n   268\t}\n   269\t\n   270\t#[derive(Debug, Clone, Copy, PartialEq, Eq, Hash, Serialize, Deserialize)]\n   271\t#[serde(rename_all = \"snake_case\")]\n   272\tpub enum FlowPreset {\n   273\t    Standard,\n   274\t    QuickDev,\n   275\t    DocsChange,\n   276\t    CiImprovement,\n   277\t}\n   278\t\n   279\timpl FlowPreset {\n   280\t    pub const ALL: [Self; 4] = [\n   281\t        Self::Standard,\n   282\t        Self::QuickDev,\n   283\t        Self::DocsChange,\n   284\t        Self::CiImprovement,\n   285\t    ];\n   286\t\n   287\t    pub fn all() -> &'static [Self] {\n   288\t        &Self::ALL\n   289\t    }\n   290\t\n   291\t    pub fn as_str(self) -> &'static str {\n   292\t        match self {\n   293\t            Self::Standard => \"standard\",\n   294\t            Self::QuickDev => \"quick_dev\",\n   295\t            Self::DocsChange => \"docs_change\",\n   296\t            Self::CiImprovement => \"ci_improvement\",\n   297\t        }\n   298\t    }\n   299\t\n   300\t    pub fn description(self) -> &'static str {\n   301\t        match self {\n   302\t            Self::Standard => {\n   303\t                \"Full delivery flow with planning, implementation, QA, review, and acceptance.\"\n   304\t            }\n   305\t            Self::QuickDev => \"Fast delivery flow for small code changes with lightweight review.\",\n   306\t            Self::DocsChange => {\n   307\t                \"Documentation-focused flow for planning, content updates, and validation.\"\n   308\t            }\n   309\t            Self::CiImprovement => {\n   310\t                \"CI improvement flow for automation planning, updates, and validation.\"\n   311\t            }\n   312\t        }\n   313\t    }\n   314\t}\n   315\t\n   316\timpl fmt::Display for FlowPreset {\n   317\t    fn fmt(&self, f: &mut fmt::Formatter<'_>) -> fmt::Result {\n   318\t        f.write_str(self.as_str())\n   319\t    }\n   320\t}\n   321\t\n   322\timpl FromStr for FlowPreset {\n   323\t    type Err = AppError;\n   324\t\n   325\t    fn from_str(value: &str) -> Result<Self, Self::Err> {\n   326\t        match value {\n   327\t            \"standard\" => Ok(Self::Standard),\n   328\t            \"quick_dev\" => Ok(Self::QuickDev),\n   329\t            \"docs_change\" => Ok(Self::DocsChange),\n   330\t            \"ci_improvement\" => Ok(Self::CiImprovement),\n   331\t            _ => Err(AppError::InvalidFlowPreset {\n   332\t                flow_id: value.to_owned(),\n   333\t            }),\n   334\t        }\n   335\t    }\n   336\t}\n   337\t\n   338\t#[derive(Debug, Clone, Copy, PartialEq, Eq, Hash, Serialize, Deserialize)]\n   339\t#[serde(rename_all = \"snake_case\")]\n   340\tpub enum StageId {\n   341\t    PromptReview,\n   342\t    Planning,\n   343\t    Implementation,\n   344\t    Qa,\n   345\t    Review,\n   346\t    CompletionPanel,\n   347\t    AcceptanceQa,\n   348\t    FinalReview,\n   349\t    PlanAndImplement,\n   350\t    ApplyFixes,\n   351\t    DocsPlan,\n   352\t    DocsUpdate,\n   353\t    DocsValidation,\n   354\t    CiPlan,\n   355\t    CiUpdate,\n   356\t    CiValidation,\n   357\t}\n   358\t\n   359\timpl StageId {\n   360\t    pub const ALL: [Self; 16] = [\n   361\t        Self::PromptReview,\n   362\t        Self::Planning,\n   363\t        Self::Implementation,\n   364\t        Self::Qa,\n   365\t        Self::Review,\n   366\t        Self::CompletionPanel,\n   367\t        Self::AcceptanceQa,\n   368\t        Self::FinalReview,\n   369\t        Self::PlanAndImplement,\n   370\t        Self::ApplyFixes,\n   371\t        Self::DocsPlan,\n   372\t        Self::DocsUpdate,\n   373\t        Self::DocsValidation,\n   374\t        Self::CiPlan,\n   375\t        Self::CiUpdate,\n   376\t        Self::CiValidation,\n   377\t    ];\n   378\t\n   379\t    pub fn display_name(self) -> &'static str {\n   380\t        match self {\n   381\t            Self::PromptReview => \"Prompt Review\",\n   382\t            Self::Planning => \"Planning\",\n   383\t            Self::Implementation => \"Implementation\",\n   384\t            Self::Qa => \"QA\",\n   385\t            Self::Review => \"Review\",\n   386\t            Self::CompletionPanel => \"Completion Panel\",\n   387\t            Self::AcceptanceQa => \"Acceptance QA\",\n   388\t            Self::FinalReview => \"Final Review\",\n   389\t            Self::PlanAndImplement => \"Plan and Implement\",\n   390\t            Self::ApplyFixes => \"Apply Fixes\",\n   391\t            Self::DocsPlan => \"Docs Plan\",\n   392\t            Self::DocsUpdate => \"Docs Update\",\n   393\t            Self::DocsValidation => \"Docs Validation\",\n   394\t            Self::CiPlan => \"CI Plan\",\n   395\t            Self::CiUpdate => \"CI Update\",\n   396\t            Self::CiValidation => \"CI Validation\",\n   397\t        }\n   398\t    }\n   399\t\n   400\t    pub fn as_str(self) -> &'static str {\n   401\t        match self {\n   402\t            Self::PromptReview => \"prompt_review\",\n   403\t            Self::Planning => \"planning\",\n   404\t            Self::Implementation => \"implementation\",\n   405\t            Self::Qa => \"qa\",\n   406\t            Self::Review => \"review\",\n   407\t            Self::CompletionPanel => \"completion_panel\",\n   408\t            Self::AcceptanceQa => \"acceptance_qa\",\n   409\t            Self::FinalReview => \"final_review\",\n   410\t            Self::PlanAndImplement => \"plan_and_implement\",\n   411\t            Self::ApplyFixes => \"apply_fixes\",\n   412\t            Self::DocsPlan => \"docs_plan\",\n   413\t            Self::DocsUpdate => \"docs_update\",\n   414\t            Self::DocsValidation => \"docs_validation\",\n   415\t            Self::CiPlan => \"ci_plan\",\n   416\t            Self::CiUpdate => \"ci_update\",\n   417\t            Self::CiValidation => \"ci_validation\",\n   418\t        }\n   419\t    }\n   420\t}\n   421\t\n   422\timpl fmt::Display for StageId {\n   423\t    fn fmt(&self, f: &mut fmt::Formatter<'_>) -> fmt::Result {\n   424\t        f.write_str(self.as_str())\n   425\t    }\n   426\t}\n   427\t\n   428\t#[derive(Debug, Clone, PartialEq, Eq, Serialize, Deserialize)]\n   429\tpub struct StageCursor {\n   430\t    pub stage: StageId,\n   431\t    pub cycle: u32,\n   432\t    pub attempt: u32,\n   433\t    pub completion_round: u32,\n   434\t}\n   435\t\n   436\timpl StageCursor {\n   437\t    pub fn new(stage: StageId, cycle: u32, attempt: u32, completion_round: u32) -> AppResult<Self> {\n   438\t        if cycle == 0 {\n   439\t            return Err(AppError::InvalidStageCursorField { field: \"cycle\" });\n   440\t        }\n   441\t        if attempt == 0 {\n   442\t            return Err(AppError::InvalidStageCursorField { field: \"attempt\" });\n   443\t        }\n   444\t        if completion_round == 0 {\n   445\t            return Err(AppError::InvalidStageCursorField {\n   446\t                field: \"completion_round\",\n   447\t            });\n   448\t        }\n   449\t\n   450\t        Ok(Self {\n   451\t            stage,\n   452\t            cycle,\n   453\t            attempt,\n   454\t            completion_round,\n   455\t        })\n   456\t    }\n   457\t\n   458\t    pub fn initial(stage: StageId) -> Self {\n   459\t        Self {\n   460\t            stage,\n   461\t            cycle: 1,\n   462\t            attempt: 1,\n   463\t            completion_round: 1,\n   464\t        }\n   465\t    }\n   466\t\n   467\t    pub fn retry(&self) -> Self {\n   468\t        Self {\n   469\t            stage: self.stage,\n   470\t            cycle: self.cycle,\n   471\t            attempt: self.attempt + 1,\n   472\t            completion_round: self.completion_round,\n   473\t        }\n   474\t    }\n   475\t\n   476\t    pub fn advance_stage(&self, stage: StageId) -> Self {\n   477\t        Self {\n   478\t            stage,\n   479\t            cycle: self.cycle,\n   480\t            attempt: 1,\n   481\t            completion_round: self.completion_round,\n   482\t        }\n   483\t    }\n   484\t\n   485\t    pub fn advance_cycle(&self, stage: StageId) -> Self {\n   486\t        Self {\n   487\t            stage,\n   488\t            cycle: self.cycle + 1,\n   489\t            attempt: 1,\n   490\t            completion_round: self.completion_round,\n   491\t        }\n   492\t    }\n   493\t\n   494\t    pub fn advance_completion_round(&self, stage: StageId) -> Self {\n   495\t        Self {\n   496\t            stage,\n   497\t            cycle: self.cycle,\n   498\t            attempt: 1,\n   499\t            completion_round: self.completion_round + 1,\n   500\t        }\n   501\t    }\n   502\t}\n   503\t\n   504\t#[derive(Debug, Clone, PartialEq, Eq, Hash, Serialize, Deserialize)]\n   505\t#[serde(transparent)]\n   506\tpub struct ProjectId(String);\n   507\t\n   508\timpl ProjectId {\n   509\t    pub fn new(value: impl Into<String>) -> AppResult<Self> {\n   510\t        let normalized = value.into().trim().to_owned();\n   511\t        if normalized.is_empty()\n   512\t            || normalized == \".\"\n   513\t            || normalized == \"..\"\n   514\t            || normalized.contains('/')\n   515\t            || normalized.contains('\\\\')\n   516\t        {\n   517\t            return Err(AppError::InvalidIdentifier { value: normalized });\n   518\t        }\n   519\t\n   520\t        Ok(Self(normalized))\n","exit_code":0,"status":"completed"}}
