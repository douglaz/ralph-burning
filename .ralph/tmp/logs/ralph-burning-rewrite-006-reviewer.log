{"type":"item.completed","item":{"id":"item_11","type":"command_execution","command":"/run/current-system/sw/bin/bash -lc \"nl -ba ralph-burning-rewrite/src/shared/error.rs | sed -n '1,220p'\"","aggregated_output":"     1\tuse std::path::PathBuf;\n     2\t\n     3\tuse thiserror::Error;\n     4\t\n     5\tuse crate::shared::domain::{FailureClass, StageId};\n     6\t\n     7\tpub type AppResult<T> = Result<T, AppError>;\n     8\t\n     9\t#[derive(Debug, Error)]\n    10\tpub enum AppError {\n    11\t    #[error(\"workspace already initialized at {path}\")]\n    12\t    AlreadyInitialized { path: PathBuf },\n    13\t    #[error(\n    14\t        \"cannot initialize workspace because {path} already exists without a workspace configuration\"\n    15\t    )]\n    16\t    WorkspaceConflict { path: PathBuf },\n    17\t    #[error(\"invalid {field}: must be greater than zero\")]\n    18\t    InvalidStageCursorField { field: &'static str },\n    19\t    #[error(\"invalid identifier '{value}': identifiers must be non-empty single path segments\")]\n    20\t    InvalidIdentifier { value: String },\n    21\t    #[error(\n    22\t        \"unknown flow preset '{flow_id}'. supported presets: standard, quick_dev, docs_change, ci_improvement\"\n    23\t    )]\n    24\t    InvalidFlowPreset { flow_id: String },\n    25\t    #[error(\"unsupported workspace version {version}; supported version is {supported}\")]\n    26\t    UnsupportedWorkspaceVersion { version: u32, supported: u32 },\n    27\t    #[error(\n    28\t        \"unknown config key '{key}'. supported keys: prompt_review.enabled, default_flow, default_backend, default_model\"\n    29\t    )]\n    30\t    UnknownConfigKey { key: String },\n    31\t    #[error(\"invalid value '{value}' for config key '{key}': {reason}\")]\n    32\t    InvalidConfigValue {\n    33\t        key: String,\n    34\t        value: String,\n    35\t        reason: String,\n    36\t    },\n    37\t    #[error(\"no active project selected; run `ralph-burning project select <id>`\")]\n    38\t    NoActiveProject,\n    39\t    #[error(\n    40\t        \"project '{project_id}' was not found under .ralph-burning/projects/ or is missing project.toml\"\n    41\t    )]\n    42\t    ProjectNotFound { project_id: String },\n    43\t    #[error(\"editor '{editor}' failed{details}\")]\n    44\t    EditorFailed { editor: String, details: String },\n    45\t    #[error(\"project '{project_id}' already exists\")]\n    46\t    DuplicateProject { project_id: String },\n    47\t    #[error(\"corrupt record in {file}: {details}\")]\n    48\t    CorruptRecord { file: String, details: String },\n    49\t    #[error(\"invalid prompt file '{path}': {reason}\")]\n    50\t    InvalidPrompt { path: String, reason: String },\n    51\t    #[error(\"cannot delete project '{project_id}': it has an active run\")]\n    52\t    ActiveRunDelete { project_id: String },\n    53\t    #[error(\"journal sequence error: {details}\")]\n    54\t    JournalSequence { details: String },\n    55\t    #[error(\"cannot start run: {reason}\")]\n    56\t    RunStartFailed { reason: String },\n    57\t    #[error(\"flow '{flow_id}' is not yet supported for `run start`; only 'standard' is supported in this slice\")]\n    58\t    UnsupportedFlow { flow_id: String },\n    59\t    #[error(\"preflight check failed for stage '{stage_id}': {details}\")]\n    60\t    PreflightFailed { stage_id: StageId, details: String },\n    61\t    #[error(\"stage commit failed for stage '{stage_id}': {details}\")]\n    62\t    StageCommitFailed { stage_id: StageId, details: String },\n    63\t    #[error(\"{command} is not yet implemented\")]\n    64\t    NotYetImplemented { command: String },\n    65\t    #[error(\"backend '{backend}' is unavailable: {details}\")]\n    66\t    BackendUnavailable { backend: String, details: String },\n    67\t    #[error(\"backend '{backend}' cannot satisfy stage '{stage_id}': {details}\")]\n    68\t    CapabilityMismatch {\n    69\t        backend: String,\n    70\t        stage_id: StageId,\n    71\t        details: String,\n    72\t    },\n    73\t    #[error(\"backend invocation failed for stage '{stage_id}' via '{backend}': {details}\")]\n    74\t    InvocationFailed {\n    75\t        backend: String,\n    76\t        stage_id: StageId,\n    77\t        failure_class: FailureClass,\n    78\t        details: String,\n    79\t    },\n    80\t    #[error(\n    81\t        \"backend invocation timed out for stage '{stage_id}' via '{backend}' after {timeout_ms} ms\"\n    82\t    )]\n    83\t    InvocationTimeout {\n    84\t        backend: String,\n    85\t        stage_id: StageId,\n    86\t        timeout_ms: u64,\n    87\t    },\n    88\t    #[error(\"backend invocation cancelled for stage '{stage_id}' via '{backend}'\")]\n    89\t    InvocationCancelled { backend: String, stage_id: StageId },\n    90\t    #[error(transparent)]\n    91\t    Io(#[from] std::io::Error),\n    92\t    #[error(transparent)]\n    93\t    TomlDeserialize(#[from] toml::de::Error),\n    94\t    #[error(transparent)]\n    95\t    TomlSerialize(#[from] toml::ser::Error),\n    96\t    #[error(transparent)]\n    97\t    TomlEdit(#[from] toml_edit::TomlError),\n    98\t    #[error(transparent)]\n    99\t    SerdeJson(#[from] serde_json::Error),\n   100\t}\n   101\t\n   102\t/// Errors specific to stage contract evaluation.\n   103\t///\n   104\t/// Each variant maps to a distinct [`FailureClass`] for retry/terminal policy.\n   105\t#[derive(Debug, Error)]\n   106\tpub enum ContractError {\n   107\t    #[error(\"schema validation failed for stage '{stage_id}': {details}\")]\n   108\t    SchemaValidation { stage_id: StageId, details: String },\n   109\t\n   110\t    #[error(\"domain validation failed for stage '{stage_id}': {details}\")]\n   111\t    DomainValidation { stage_id: StageId, details: String },\n   112\t\n   113\t    #[error(\"rendering failed for stage '{stage_id}': {details}\")]\n   114\t    RenderError { stage_id: StageId, details: String },\n   115\t\n   116\t    #[error(\"non-passing QA/review outcome for stage '{stage_id}': {outcome}\")]\n   117\t    QaReviewOutcome { stage_id: StageId, outcome: String },\n   118\t}\n   119\t\n   120\timpl ContractError {\n   121\t    pub fn failure_class(&self) -> FailureClass {\n   122\t        match self {\n   123\t            Self::SchemaValidation { .. } => FailureClass::SchemaValidationFailure,\n   124\t            Self::DomainValidation { .. } | Self::RenderError { .. } => {\n   125\t                FailureClass::DomainValidationFailure\n   126\t            }\n   127\t            Self::QaReviewOutcome { .. } => FailureClass::QaReviewOutcomeFailure,\n   128\t        }\n   129\t    }\n   130\t\n   131\t    pub fn stage_id(&self) -> StageId {\n   132\t        match self {\n   133\t            Self::SchemaValidation { stage_id, .. }\n   134\t            | Self::DomainValidation { stage_id, .. }\n   135\t            | Self::RenderError { stage_id, .. }\n   136\t            | Self::QaReviewOutcome { stage_id, .. } => *stage_id,\n   137\t        }\n   138\t    }\n   139\t}\n   140\t\n   141\timpl AppError {\n   142\t    pub fn failure_class(&self) -> Option<FailureClass> {\n   143\t        match self {\n   144\t            Self::BackendUnavailable { .. } => Some(FailureClass::TransportFailure),\n   145\t            Self::CapabilityMismatch { .. } => Some(FailureClass::DomainValidationFailure),\n   146\t            Self::InvocationFailed { failure_class, .. } => Some(*failure_class),\n   147\t            Self::InvocationTimeout { .. } => Some(FailureClass::Timeout),\n   148\t            Self::InvocationCancelled { .. } => Some(FailureClass::Cancellation),\n   149\t            _ => None,\n   150\t        }\n   151\t    }\n   152\t}\n","exit_code":0,"status":"completed"}}
