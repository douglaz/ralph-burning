     temp_dir\n  2512\t            .path()\n  2513\t            .join(\".ralph-burning/projects/preflight-cli/run.json\"),\n  2514\t    )\n  2515\t    .expect(\"read run.json after\");\n  2516\t    let post_journal = fs::read_to_string(\n  2517\t        temp_dir\n  2518\t            .path()\n  2519\t            .join(\".ralph-burning/projects/preflight-cli/journal.ndjson\"),\n  2520\t    )\n  2521\t    .expect(\"read journal after\");\n  2522\t\n  2523\t    assert_eq!(\n  2524\t        pre_run_json, post_run_json,\n  2525\t        \"run.json must not change on pre-engine failure\"\n  2526\t    );\n  2527\t    assert_eq!(\n  2528\t        pre_journal, post_journal,\n  2529\t        \"journal must not change on pre-engine failure\"\n  2530\t    );\n  2531\t\n  2532\t    let payloads_dir = temp_dir\n  2533\t        .path()\n  2534\t        .join(\".ralph-burning/projects/preflight-cli/history/payloads\");\n  2535\t    let payload_count = fs::read_dir(&payloads_dir)\n  2536\t        .expect(\"read payloads dir\")\n  2537\t        .filter_map(|e| e.ok())\n  2538\t        .count();\n  2539\t    assert_eq!(payload_count, 0, \"no payloads should exist after preflight failure\");\n  2540\t}\n  2541\t\n  2542\t#[test]\n  2543\tfn run_start_backend_preflight_failure_leaves_state_unchanged() {\n  2544\t    let temp_dir = initialize_workspace_fixture();\n  2545\t    setup_standard_project(&temp_dir, \"preflight-backend\");\n  2546\t\n  2547\t    // Capture pre-run state\n  2548\t    let pre_run_json = fs::read_to_string(\n  2549\t        temp_dir\n  2550\t            .path()\n  2551\t            .join(\".ralph-burning/projects/preflight-backend/run.json\"),\n  2552\t    )\n  2553\t    .expect(\"read run.json before\");\n  2554\t    let pre_journal = fs::read_to_string(\n  2555\t        temp_dir\n  2556\t            .path()\n  2557\t            .join(\".ralph-burning/projects/preflight-backend/journal.ndjson\"),\n  2558\t    )\n  2559\t    .expect(\"read journal before\");\n  2560\t\n  2561\t    // Use env var to make the backend unavailable at preflight\n  2562\t    let output = Command::new(binary())\n  2563\t        .args([\"run\", \"start\"])\n  2564\t        .env(\"RALPH_BURNING_TEST_BACKEND_UNAVAILABLE\", \"1\")\n  2565\t        .current_dir(temp_dir.path())\n  2566\t        .output()\n  2567\t        .expect(\"run start\");\n  2568\t\n  2569\t    assert!(\n  2570\t        !output.status.success(),\n  2571\t        \"run start should fail with unavailable backend\"\n  2572\t    );\n  2573\t    let stderr = String::from_utf8_lossy(&output.stderr);\n  2574\t    assert!(\n  2575\t        stderr.contains(\"preflight\") || stderr.contains(\"unavailable\"),\n  2576\t        \"error should reference preflight or unavailable, got: {stderr}\"\n  2577\t    );\n  2578\t\n  2579\t    // Verify NO state mutation occurred — byte-identical\n  2580\t    let post_run_json = fs::read_to_string(\n  2581\t        temp_dir\n  2582\t            .path()\n  2583\t            .join(\".ralph-burning/projects/preflight-backend/run.json\"),\n  2584\t    )\n  2585\t    .expect(\"read run.json after\");\n  2586\t    let post_journal = fs::read_to_string(\n  2587\t        temp_dir\n  2588\t            .path()\n  2589\t            .join(\".ralph-burning/projects/preflight-backend/journal.ndjson\"),\n  2590\t    )\n  2591\t    .expect(\"read journal after\");\n  2592\t\n  2593\t    assert_eq!(\n  2594\t        pre_run_json, post_run_json,\n  2595\t        \"run.json must be byte-identical after preflight failure\"\n  2596\t    );\n  2597\t    assert_eq!(\n  2598\t        pre_journal, post_journal,\n  2599\t        \"journal must be byte-identical after preflight failure\"\n  2600\t    );\n  2601\t\n  2602\t    let payloads_dir = temp_dir\n  2603\t        .path()\n  2604\t        .join(\".ralph-burning/projects/preflight-backend/history/payloads\");\n  2605\t    let payload_count = fs::read_dir(&payloads_dir)\n  2606\t        .expect(\"read payloads dir\")\n  2607\t  