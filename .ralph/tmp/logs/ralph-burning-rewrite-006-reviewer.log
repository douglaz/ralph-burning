iguous running state after any failure.\n   551\t    snapshot.status = RunStatus::Failed;\n   552\t    snapshot.active_run = None;\n   553\t    snapshot.status_summary = format!(\"failed at {}: {}\", stage_id.display_name(), message);\n   554\t    run_snapshot_write.write_run_snapshot(base_dir, project_id, snapshot)?;\n   555\t\n   556\t    // Best-effort: append run_failed journal event. If this fails,\n   557\t    // the snapshot already reflects the failed state.\n   558\t    *seq += 1;\n   559\t    let run_failed =\n   560\t        journal::run_failed_event(*seq, Utc::now(), run_id, stage_id, &failure_class, &message);\n","exit_code":0,"status":"completed"}}
