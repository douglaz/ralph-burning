    payload: InvocationPayload {\n   306\t                prompt: format!(\"Execute stage: {}\", stage_id.display_name()),\n   307\t                context: serde_json::json!({}),\n   308\t            },\n   309\t            timeout: Duration::from_secs(300),\n   310\t            cancellation_token: CancellationToken::new(),\n   311\t            session_policy: SessionPolicy::ReuseIfAllowed,\n   312\t            prior_session: None,\n   313\t            attempt_number: cursor.attempt,\n   314\t        };\n   315\t\n   316\t        let envelope = match agent_service.invoke(request).await {\n   317\t            Ok(env) => env,\n   318\t            Err(e) => {\n   319\t                return fail_run(\n   320\t                    &e,\n   321\t                    stage_id,\n   322\t                    &run_id,\n   323\t                    &mut seq,\n   324\t                    &mut current_snapshot,\n   325\t                    journal_store,\n   326\t                    run_snapshot_write,\n   327\t                    base_dir,\n   328\t                    project_id,\n   329\t                )\n   330\t                .await;\n   331\t            }\n   332\t        };\n   333\t\n   334\t        // Evaluate the contract (schema + domain + outcome + render)\n   335\t        let bundle = match stage_entry.contract.evaluate(&envelope.parsed_payload) {\n   336\t            Ok(bundle) => bundle,\n   337\t            Err(contract_err) => {\n   338\t                let app_err = AppError::InvocationFailed {\n   339\t                    backend: stage_entry.target.backend.family.to_string(),\n   340\t                    stage_id,\n   341\t                    failure_class: contract_err.failure_class(),\n   342\t                    details: contract_err.to_string(),\n   343\t                };\n   344\t                return fail_run(\n   345\t                    &app_err,\n   346\t                    stage_id,\n   347\t                    &run_id,\n   348\t                    &mut seq,\n   349\t                    &mut current_snapshot,\n   350\t                    journal_store,\n   351\t                    run_snapshot_write,\n   352\t                    base_dir,\n   353\t                    project_id,\n   354\t                )\n   355\t                .await;\n   356\t            }\n   357\t        };\n   358\t\n   359\t        // Persist payload + artifact pair atomically\n   360\t        let stage_now = Utc::now();\n   361\t        let payload_id = format!(\n   362\t            \"{}-{}-c{}-a{}\",\n   363\t            run_id.as_str(),\n   364\t            stage_id.as_str(),\n   365\t            cursor.cycle,\n   366\t            cursor.attempt\n   367\t        );\n   368\t        let artifact_id = format!(\"{}-artifact\", payload_id);\n   369\t\n   370\t        let payload_record = PayloadRecord {\n   371\t            payload_id: payload_id.clone(),\n   372\t            stage_id,\n   373\t            cycle: cursor.cycle,\n   374\t            attempt: cursor.attempt,\n   375\t            created_at: stage_now,\n   376\t            payload: serde_json::to_value(&bundle.payload)?,\n   377\t        };\n   378\t        let artifact_record = ArtifactRecord {\n   379\t            artifact_id: artifact_id.clone(),\n   380\t            payload_id: payload_id.clone(),\n   381\t            stage_id,\n   382\t            created_at: stage_now,\n   383\t            content: bundle.artifact.clone(),\n   384\t        };\n   385\t\n   386\t        // Atomic stage commit: payload + artifact + snapshot + journal.\n   387\t        // All four must succeed for the stage to become durably visible.\n   388\t        // Order: payload/artifact → snapshot cursor → stage_completed journal.\n   389\t        // This ensures that if any step fails, no stage_completed event leaks\n   390\t        // into the journal without a matching snapshot and durable files.\n   391\t\n   392\t        // Step 1: Write payload + artifact pair.\n   393\t        // If this fails after stage_entered, the run must persist failed state.\n   394\t        // The fs adapter uses staging + rename so canonical files only appear on\n   395\t        // full success, but as defense-in-depth we also call remove_payload_artifact_pair\n   396\t        // to clean up any orphaned canonical files before failing the run.\n   397\t        if let Err(e) =\n   398\t            artifact_write.write_payload_artifact_pair(base_dir, project_id, &payload_record, &artifact_record)\n   399\t        {\n   400\t            // Defense-in-depth: remove any leaked canonical files.\n   401\t            let _ = artifact_write.remove_payload_artifact_pair(\n   402\t                base_dir,\n   403\t                project_id,\n   404\t                &payload_id,\n   405\t                &artifact_id,\n   406\t            );\n   407\t            let commit_err = AppError::StageCommitFailed {\n   408\t                stage_id,\n   409\t                details: format!(\"payload/artifact persistence failed: {}\", e),\n   410\t            };\n   411\t            return fail_run(\n   412\t                &commit_err,\n   413\t                stage_id,\n   414\t                &run_id,\n   415\t                &mut seq,\n   416\t                &mut current_snapshot,\n   417\t                journal_store,\n   418\t                run_snapshot_write,\n   419\t                base_dir,\n   420\t                project_id,\n   421\t            )\n   422\t            .await;\n   423\t        }\n   424\t\n   425\t        // Step 2: Update snapshot cursor to reflect completed stage.\n   426\t        // Written BEFORE stage_completed journal so that snapshot failure\n   427\t        // never leaves a stage_completed event without a matching cursor.\n   428\t        let pre_commit_snapshot = current_snapshot.clone();\n   429\t        if idx + 1 < stage_plan.len() {\n   430\t            let next_stage = stage_plan[idx + 1].stage_id;\n   431\t            current_snapshot.active_run.as_mut().unwrap().stage_cursor =\n   432\t                StageCursor::initial(next_stage);\n   433\t            current_snapshot.status_summary = format!(\n   434\t                \"running: completed {}, next {}\",\n   435\t                stage_id.display_name(),\n   436\t                next_stage.display_name()\n   437\t            );\n   438\t        }\n   439\t        if let Err(e) = run_snapshot_write.write_run_snapshot(base_dir, project_id, &current_snapshot) {\n   440\t            // Roll back payload/artifact; no stage_completed was written yet.\n   441\t            // Propagate rollback failure so leaked durable history is surfaced.\n   442\t            let rollback_detail = match artifact_write.remove_payload_artifact_pair(base_dir, project_id, &payload_id, &artifact_id) {\n   443\t                Ok(()) => String::new(),\n   444\t                Err(cleanup_err) => format!(\"; payload/artifact rollback failed: {} — leaked durable history may exist\", cleanup_err),\n   445\t            };\n   446\t            current_snapshot = pre_commit_snapshot;\n   447\t            let commit_err = AppError::StageCommitFailed {\n   448\t                stage_id,\n   449\t                details: format!(\"snapshot write failed during stage commit: {}{}\", e, rollback_detail),\n   450\t            };\n   451\t            return fail_run(\n   452\t                &commit_err,\n   453\t                stage_id,\n   454\t                &run_id,\n   455\t                &mut seq,\n   456\t                &mut current_snapshot,\n   457\t                journal_store,\n   458\t                run_snapshot_write,\n   459\t                base_dir,\n   460\t                project_id,\n   461\t            )\n   462\t            .await;\n   463\t        }\n   464\t\n   465\t        // Step 3: Append stage_completed journal event.\n   466\t        // If this fails, roll back payload/artifact and overwrite snapshot\n   467\t        // via fail_run so the stage remains uncommitted.\n   468\t        seq += 1;\n   469\t        let stage_completed = journal::stage_completed_event(\n   470\t            seq,\n   471\t            Utc::now(),\n   472\t            &run_id,\n   473\t            stage_id,\n   474\t            cursor.cycle,\n   475\t            cursor.attempt,\n   476\t            &payload_id,\n   477\t            &artifact_id,\n   478\t        );\n   479\t        let stage_completed_line = journal::serialize_event(&stage_completed)?;\n   480\t        if let Err(e) = journal_store.append_event(base_dir, project_id, &stage_completed_line) {\n   481\t            // Roll back payload/artifact so no partial durable history is visible.\n   482\t            // Propagate rollback failure so leaked durable history is surfaced.\n   483\t            let rollback_detail = match artifact_write.remove_payload_artifact_pair(base_dir, project_id, &payload_id, &artifact_id) {\n   484\t                Ok(()) => String::new(),\n   485\t                Err(cleanup_err) => format!(\"; payload/artifact rollback failed: {} — leaked durable history may exist\", cleanup_err),\n   486\t            };\n   487\t            seq -= 1; // undo the seq increment since the event was not persisted\n   488\t            let commit_err = AppError::StageCommitFailed {\n   489\t                stage_id,\n   490\t                details: format!(\"journal append failed during stage commit: {}{}\", e, rollback_detail),\n   491\t            };\n   492\t            return fail_run(\n   493\t                &commit_err,\n   494\t                stage_id,\n   495\t                &run_id,\n   496\t                &mut seq,\n   497\t                &mut current_snapshot,\n   498\t                journal_store,\n   499\t                run_snapshot_write,\n   500\t                base_dir,\n   501\t                project_id,\n   502\t            )\n   503\t            .await;\n   504\t        }\n   505\t\n   506\t        // Best-effort runtime log\n   507\t        let _ = log_write.append_runtime_log(\n   508\t            base_dir,\n   509\t            project_id,\n   510\t            &RuntimeLogEntry {\n   511\t                timestamp: Utc::now(),\n   512\t                level: LogLevel::Info,\n   513\t                source: \"engine\".to_owned(),\n   514\t                message: format!(\"stage_completed: {}\", stage_id.as_str()),\n   515\t            },\n   516\t        );\n   517\t    }\n   518\t\n   519\t    // 8. All stages completed — mark run as completed.\n   520\t    // Write completed snapshot FIRST so the run is marked as completed\n   521\t    // even if journal append fails (consistent with snapshot-first ordering).\n   522\t    current_snapshot.status = RunStatus::Completed;\n   523\t    current_snapshot.active_run = None;\n   524\t    current_snapshot.completion_rounds = 1;\n   525\t    current_snapshot.status_summary = \"completed\".to_owned();\n   526\t    run_snapshot_write.write_run_snapshot(base_dir, project_id, &current_snapshot)?;\n   527\t\n   528\t    seq += 1;\n   529\t    let run_completed = journal::run_completed_event(seq, Utc::now(), &run_id, 1);\n   530\t    let run_completed_line = journal::serialize_event(&run_completed)?;\n   531\t    journal_store.append_event(base_dir, project_id, &run_completed_line)?;\n   532\t\n   533\t    Ok(())\n   534\t}\n   535\t\n   536\t/// Record a run failure: persist failed snapshot, then journal event, return error.\n   537\t///\n   538\t/// The snapshot is written first (critical path) so the run is never left in an\n   539\t/// ambiguous running state. The journal append is best-effort relative to the\n   540\t/// snapshot — if it fails, the snapshot already reflects the failed state.\n   541\t#[allow(clippy::too_many_arguments)]\n   542\tasync fn fail_run(\n   543\t    err: &AppError,\n   544\t    stage_id: StageId,\n   545\t    run_id: &RunId,\n   546\t    seq: &mut u64,\n   547\t    snapshot: &mut RunSnapshot,\n   548\t    journal_store: &dyn JournalStorePort,\n   549\t    run_snapshot_write: &dyn RunSnapshotWritePort,\n   550\t    base_dir: &Path,\n   551\t    project_id: &ProjectId,\n   552\t) -> AppResult<()> {\n   553\t    let failure_class = err\n   554\t        .failure_class()\n   555\t        .map(|fc| format!(\"{:?}\", fc))\n   556\t        .unwrap_or_else(|| \"unknown\".to_owned());\n   557\t    let message = err.to_string();\n   558\t\n   559\t    // Critical: persist the failed snapshot first so the run is never\n   560\t    // left in an ambiguous running state after any failure.\n   561\t    snapshot.status = RunStatus::Failed;\n   562\t    snapshot.active_run = None;\n   563\t    snapshot.status_summary = format!(\"failed at {}: {}\", stage_id.display_name(), message);\n   564\t    run_snapshot_write.write_run_snapshot(base_dir, project_id, snapshot)?;\n   565\t\n   566\t    // Best-effort: append run_failed journal event. If this fails,\n   567\t    // the snapshot already reflects the failed state.\n   568\t    *seq += 1;\n   569\t    let run_failed =\n   570\t        journal::run_failed_event(*seq, Utc::now(), run_id, stage_id, &failure_class, &message);\n   571\t    if let Ok(run_failed_line) = journal::serialize_event(&run_failed) {\n   572\t        let _ = journal_store.append_event(base_dir, project_id, &run_failed_line);\n   573\t    }\n   574\t\n   575\t    Err(AppError::RunStartFailed {\n   576\t        reason: format!(\"stage {} failed: {}\", stage_id.as_str(), message),\n   577\t    })\n   578\t}\n   579\t\n   580\t/// Helper to get project root path.\n   581\tfn project_root_path(base_dir: &Path, project_id: &ProjectId) -> PathBuf {\n   582\t    base_dir\n   583\t        .join(\".ralph-burning\")\n   584\t        .join(\"projects\")\n   585\t        .join(project_id.as_str())\n   586\t}\n","exit_code":0,"status":"completed"}}
{"type":"item.completed","item":{"id":"item_10","type":"command_execution","command":"/run/current-system/sw/bin/bash -lc \"nl -ba src/cli/run.rs | sed -n '1,260p'\"","aggregated_output":"     1\tuse clap::{Args, Subcommand};\n     2\t\n     3\tuse crate::adapters::fs::{\n     4\t    FsArtifactStore, FsJournalStore, FsPayloadArtifactWriteStore, FsProjectStore,\n     5\t    FsRawOutputStore, FsRunSnapshotStore, FsRunSnapshotWriteStore, FsRuntimeLogStore,\n     6\t    FsRuntimeLogWriteStore, FsSessionStore,\n     7\t};\n     8\tuse crate::adapters::stub_backend::StubBackendAdapter;\n     9\tuse crate::contexts::agent_execution::service::AgentExecutionService;\n    10\tuse crate::contexts::project_run_record::service::{self, ProjectStorePort, RunSnapshotPort};\n    11\tuse crate::contexts::workflow_composition::engine;\n    12\tuse crate::contexts::workspace_governance;\n    13\tuse crate::contexts::workspace_governance::config::EffectiveConfig;\n    14\tuse crate::shared::domain::{FlowPreset, StageId};\n    15\tuse crate::shared::error::{AppError, AppResult};\n    16\t\n    17\t#[derive(Debug, Args)]\n    18\tpub struct RunCommand {\n    19\t    #[command(subcommand)]\n    20\t    pub command: RunSubcommand,\n    21\t}\n    22\t\n    23\t#[derive(Debug, Subcommand)]\n    24\tpub enum RunSubcommand {\n    25\t    Start,\n    26\t    Resume,\n    27\t    Status,\n    28\t    History,\n    29\t    Tail {\n    30\t        #[arg(long)]\n    31\t        logs: bool,\n    32\t    },\n    33\t    Rollback {\n    34\t        #[arg(long)]\n    35\t        to: String,\n    36\t        #[arg(long)]\n    37\t        hard: bool,\n    38\t    },\n    39\t}\n    40\t\n    41\tpub async fn handle(command: RunCommand) -> AppResult<()> {\n    42\t    match command.command {\n    43\t        RunSubcommand::Status => handle_status().await,\n    44\t        RunSubcommand::History => handle_history().await,\n    45\t        RunSubcommand::Tail { logs } => handle_tail(logs).await,\n    46\t        RunSubcommand::Start => handle_start().await,\n    47\t        RunSubcommand::Resume => Err(AppError::NotYetImplemented {\n    48\t            command: \"run resume\".to_owned(),\n    49\t        }),\n    50\t        RunSubcommand::Rollback { .. } => Err(AppError::NotYetImplemented {\n    51\t            command: \"run rollback\".to_owned(),\n    52\t        }),\n    53\t    }\n    54\t}\n    55\t\n    56\tpub fn build_agent_execution_service(\n    57\t) -> AgentExecutionService<StubBackendAdapter, FsRawOutputStore, FsSessionStore> {\n    58\t    let mut adapter = StubBackendAdapter::default();\n    59\t\n    60\t    // Test-only injection seam: environment variables configure the stub backend\n    61\t    // to simulate failure modes that aren't reachable through normal CLI usage.\n    62\t    if std::env::var(\"RALPH_BURNING_TEST_BACKEND_UNAVAILABLE\").is_ok() {\n    63\t        adapter = adapter.unavailable();\n    64\t    }\n    65\t    if let Ok(stage_str) = std::env::var(\"RALPH_BURNING_TEST_FAIL_INVOKE_STAGE\") {\n    66\t        if let Ok(stage_id) = stage_str.parse::<StageId>() {\n    67\t            adapter = adapter.with_invoke_failure(stage_id);\n    68\t        }\n    69\t    }\n    70\t\n    71\t    AgentExecutionService::new(adapter, FsRawOutputStore, FsSessionStore)\n    72\t}\n    73\t\n    74\tasync fn handle_start() -> AppResult<()> {\n    75\t    let current_dir = std::env::current_dir()?;\n    76\t\n    77\t    // Validate workspace version\n    78\t    let config = workspace_governance::load_workspace_config(&current_dir)?;\n    79\t    workspace_governance::ensure_supported_workspace_version(&config)?;\n    80\t\n    81\t    // Resolve active project\n    82\t    let project_id = workspace_governance::resolve_active_project(&current_dir)?;\n    83\t\n    84\t    // Validate canonical project record\n    85\t    let project_store = FsProjectStore;\n    86\t    let project_record = project_store.read_project_record(&current_dir, &project_id)?;\n    87\t\n    88\t    // Only standard flow is supported in this slice\n    89\t    if project_record.flow != FlowPreset::Standard {\n    90\t        return Err(AppError::UnsupportedFlow {\n    91\t            flow_id: project_record.flow.as_str().to_owned(),\n    92\t        });\n    93\t    }\n    94\t\n    95\t    // Validate run snapshot integrity\n    96\t    let run_snapshot_read = FsRunSnapshotStore;\n    97\t    let run_snapshot = run_snapshot_read.read_run_snapshot(&current_dir, &project_id)?;\n    98\t\n    99\t    // Check preconditions before engine call (fail fast with clear errors)\n   100\t    if run_snapshot.status != crate::contexts::project_run_record::model::RunStatus::NotStarted {\n   101\t        return Err(AppError::RunStartFailed {\n   102\t            reason: format!(\n   103\t                \"project snapshot status is '{}'; run start requires 'not_started'\",\n   104\t                run_snapshot.status\n   105\t            ),\n   106\t        });\n   107\t    }\n   108\t    if run_snapshot.has_active_run() {\n   109\t        return Err(AppError::RunStartFailed {\n   110\t            reason: \"project already has an active run\".to_owned(),\n   111\t        });\n   112\t    }\n   113\t\n   114\t    let effective_config = EffectiveConfig::load(&current_dir)?;\n   115\t\n   116\t    let agent_service = build_agent_execution_service();\n   117\t    let run_snapshot_write = FsRunSnapshotWriteStore;\n   118\t    let journal_store = FsJournalStore;\n   119\t    let artifact_write = FsPayloadArtifactWriteStore;\n   120\t    let log_write = FsRuntimeLogWriteStore;\n   121\t\n   122\t    println!(\"Starting run for project '{}'...\", project_id);\n   123\t\n   124\t    engine::execute_standard_run(\n   125\t        &agent_service,\n   126\t        &run_snapshot_read,\n   127\t        &run_snapshot_write,\n   128\t        &journal_store,\n   129\t        &artifact_write,\n   130\t        &log_write,\n   131\t        &current_dir,\n   132\t        &project_id,\n   133\t        &effective_config,\n   134\t    )\n   135\t    .await?;\n   136\t\n   137\t    println!(\"Run completed successfully.\");\n   138\t    Ok(())\n   139\t}\n   140\t\n   141\tasync fn handle_status() -> AppResult<()> {\n   142\t    let current_dir = std::env::current_dir()?;\n   143\t\n   144\t    let config = workspace_governance::load_workspace_config(&current_dir)?;\n   145\t    workspace_governance::ensure_supported_workspace_version(&config)?;\n   146\t\n   147\t    let project_id = workspace_governance::resolve_active_project(&current_dir)?;\n   148\t\n   149\t    // Validate canonical project record before proceeding with run queries\n   150\t    let project_store = FsProjectStore;\n   151\t    let _ = project_store.read_project_record(&current_dir, &project_id)?;\n   152\t\n   153\t    let run_store = FsRunSnapshotStore;\n   154\t    let status = service::run_status(&run_store, &current_dir, &project_id)?;\n   155\t\n   156\t    println!(\"Project: {}\", status.project_id);\n   157\t    println!(\"Status: {}\", status.status);\n   158\t    if let Some(ref stage) = status.stage {\n   159\t        println!(\"Stage: {}\", stage);\n   160\t    }\n   161\t    if let Some(cycle) = status.cycle {\n   162\t        println!(\"Cycle: {}\", cycle);\n   163\t    }\n   164\t    if let Some(round) = status.completion_round {\n   165\t        println!(\"Completion round: {}\", round);\n   166\t    }\n   167\t    println!(\"Summary: {}\", status.summary);\n   168\t\n   169\t    Ok(())\n   170\t}\n   171\t\n   172\tasync fn handle_history() -> AppResult<()> {\n   173\t    let current_dir = std::env::current_dir()?;\n   174\t\n   175\t    let config = workspace_governance::load_workspace_config(&current_dir)?;\n   176\t    workspace_governance::ensure_supported_workspace_version(&config)?;\n   177\t\n   178\t    let project_id = workspace_governance::resolve_active_project(&current_dir)?;\n   179\t\n   180\t    // Validate canonical project record before proceeding with run queries\n   181\t    let project_store = FsProjectStore;\n   182\t    let _ = project_store.read_project_record(&current_dir, &project_id)?;\n   183\t\n   184\t    let journal_store = FsJournalStore;\n   185\t    let artifact_store = FsArtifactStore;\n   186\t\n   187\t    let history = service::run_history(&journal_store, &artifact_store, &current_dir, &project_id)?;\n   188\t\n   189\t    println!(\"Project: {}\", history.project_id);\n   190\t    println!(\"--- Journal Events ---\");\n   191\t    for event in &history.events {\n   192\t        println!(\n   193\t            \"  [{}] {} - {:?}\",\n   194\t            event.sequence, event.timestamp, event.event_type\n   195\t        );\n   196\t    }\n   197\t\n   198\t    if !history.payloads.is_empty() {\n   199\t        println!(\"--- Payloads ---\");\n   200\t        for payload in &history.payloads {\n   201\t            println!(\n   202\t                \"  {} ({}, cycle {}, attempt {})\",\n   203\t                payload.payload_id, payload.stage_id, payload.cycle, payload.attempt\n   204\t            );\n   205\t        }\n   206\t    }\n   207\t\n   208\t    if !history.artifacts.is_empty() {\n   209\t        println!(\"--- Artifacts ---\");\n   210\t        for artifact in &history.artifacts {\n   211\t            println!(\n   212\t                \"  {} (payload: {}, stage: {})\",\n   213\t                artifact.artifact_id, artifact.payload_id, artifact.stage_id\n   214\t            );\n   215\t        }\n   216\t    }\n   217\t\n   218\t    Ok(())\n   219\t}\n   220\t\n   221\tasync fn handle_tail(include_logs: bool) -> AppResult<()> {\n   222\t    let current_dir = std::env::current_dir()?;\n   223\t\n   224\t    let config = workspace_governance::load_workspace_config(&current_dir)?;\n   225\t    workspace_governance::ensure_supported_workspace_version(&config)?;\n   226\t\n   227\t    let project_id = workspace_governance::resolve_active_project(&current_dir)?;\n   228\t\n   229\t    // Validate canonical project record before proceeding with run queries\n   230\t    let project_store = FsProjectStore;\n   231\t    let _ = project_store.read_project_record(&current_dir, &project_id)?;\n   232\t\n   233\t    let journal_store = FsJournalStore;\n   234\t    let artifact_store = FsArtifactStore;\n   235\t    let log_store = FsRuntimeLogStore;\n   236\t\n   237\t    let tail = service::run_tail(\n   238\t        &journal_store,\n   239\t        &artifact_store,\n   240\t        &log_store,\n   241\t        &current_dir,\n   242\t        &project_id,\n   243\t        include_logs,\n   244\t    )?;\n   245\t\n   246\t    println!(\"Project: {}\", tail.project_id);\n   247\t    println!(\"--- Durable History ---\");\n   248\t    for event in &tail.events {\n   249\t        println!(\n   250\t            \"  [{}] {} - {:?}\",\n   251\t            event.sequence, event.timestamp, event.event_type\n   252\t        );\n   253\t    }\n   254\t\n   255\t    if !tail.payloads.is_empty() {\n   256\t        println!(\"--- Payloads ---\");\n   257\t        for payload in &tail.payloads {\n   258\t            println!(\n   259\t                \"  {} ({}, cycle {}, attempt {})\",\n   260\t                payload.payload_id, payload.stage_id, payload.cycle, payload.attempt\n","exit_code":0,"status":"completed"}}
{"type":"item.completed","item":{"id":"item_9","type":"command_execution","command":"/run/current-system/sw/bin/bash -lc \"nl -ba src/adapters/fs.rs | sed -n '620,860p'\"","aggregated_output":"   620\t                    details: \"canonical file is missing\".to_owned(),\n   621\t                })\n   622\t            }\n   623\t            Err(error) => Err(error.into()),\n   624\t        }\n   625\t    }\n   626\t\n   627\t    fn save_sessions(&self, project_root: &Path, sessions: &PersistedSessions) -> AppResult<()> {\n   628\t        let path = project_root.join(SESSIONS_FILE);\n   629\t        let contents = serde_json::to_string_pretty(sessions)?;\n   630\t        FileSystem::write_atomic(&path, &contents)\n   631\t    }\n   632\t}\n   633\t\n   634\t/// Filesystem-backed implementation of `RunSnapshotWritePort`.\n   635\tpub struct FsRunSnapshotWriteStore;\n   636\t\n   637\timpl RunSnapshotWritePort for FsRunSnapshotWriteStore {\n   638\t    fn write_run_snapshot(\n   639\t        &self,\n   640\t        base_dir: &Path,\n   641\t        project_id: &ProjectId,\n   642\t        snapshot: &RunSnapshot,\n   643\t    ) -> AppResult<()> {\n   644\t        let path = FileSystem::project_root(base_dir, project_id).join(RUN_FILE);\n   645\t        let contents = serde_json::to_string_pretty(snapshot)?;\n   646\t        FileSystem::write_atomic(&path, &contents)\n   647\t    }\n   648\t}\n   649\t\n   650\t/// Filesystem-backed implementation of `PayloadArtifactWritePort`.\n   651\tpub struct FsPayloadArtifactWriteStore;\n   652\t\n   653\timpl PayloadArtifactWritePort for FsPayloadArtifactWriteStore {\n   654\t    fn write_payload_artifact_pair(\n   655\t        &self,\n   656\t        base_dir: &Path,\n   657\t        project_id: &ProjectId,\n   658\t        payload: &PayloadRecord,\n   659\t        artifact: &ArtifactRecord,\n   660\t    ) -> AppResult<()> {\n   661\t        let project_root = FileSystem::project_root(base_dir, project_id);\n   662\t\n   663\t        let payload_final = project_root\n   664\t            .join(\"history/payloads\")\n   665\t            .join(format!(\"{}.json\", payload.payload_id));\n   666\t        let artifact_final = project_root\n   667\t            .join(\"history/artifacts\")\n   668\t            .join(format!(\"{}.json\", artifact.artifact_id));\n   669\t\n   670\t        // Stage both files under runtime/temp/ first so that no canonical\n   671\t        // history file exists until both writes succeed. This prevents\n   672\t        // orphaned payloads from leaking into durable history on partial failure.\n   673\t        let staging_dir = project_root.join(\"runtime/temp\");\n   674\t        fs::create_dir_all(&staging_dir)?;\n   675\t\n   676\t        let payload_staging = staging_dir.join(format!(\".{}.payload.staging\", payload.payload_id));\n   677\t        let artifact_staging =\n   678\t            staging_dir.join(format!(\".{}.artifact.staging\", artifact.artifact_id));\n   679\t\n   680\t        let payload_json = serde_json::to_string_pretty(payload)?;\n   681\t        let artifact_json = serde_json::to_string_pretty(artifact)?;\n   682\t\n   683\t        // Write payload to staging\n   684\t        FileSystem::write_atomic(&payload_staging, &payload_json)?;\n   685\t\n   686\t        // Write artifact to staging — if this fails, clean up payload staging\n   687\t        if let Err(e) = FileSystem::write_atomic(&artifact_staging, &artifact_json) {\n   688\t            let _ = fs::remove_file(&payload_staging);\n   689\t            return Err(e);\n   690\t        }\n   691\t\n   692\t        // Rename payload staging into canonical location\n   693\t        if let Err(e) = fs::rename(&payload_staging, &payload_final) {\n   694\t            let _ = fs::remove_file(&payload_staging);\n   695\t            let _ = fs::remove_file(&artifact_staging);\n   696\t            return Err(e.into());\n   697\t        }\n   698\t\n   699\t        // Rename artifact staging into canonical location\n   700\t        if let Err(e) = fs::rename(&artifact_staging, &artifact_final) {\n   701\t            // Roll back the payload that was already moved to canonical location\n   702\t            let _ = fs::remove_file(&payload_final);\n   703\t            return Err(e.into());\n   704\t        }\n   705\t\n   706\t        Ok(())\n   707\t    }\n   708\t\n   709\t    fn remove_payload_artifact_pair(\n   710\t        &self,\n   711\t        base_dir: &Path,\n   712\t        project_id: &ProjectId,\n   713\t        payload_id: &str,\n   714\t        artifact_id: &str,\n   715\t    ) -> AppResult<()> {\n   716\t        let project_root = FileSystem::project_root(base_dir, project_id);\n   717\t\n   718\t        let payload_path = project_root\n   719\t            .join(\"history/payloads\")\n   720\t            .join(format!(\"{}.json\", payload_id));\n   721\t        let artifact_path = project_root\n   722\t            .join(\"history/artifacts\")\n   723\t            .join(format!(\"{}.json\", artifact_id));\n   724\t\n   725\t        // Remove both files, propagating errors so the caller knows about\n   726\t        // leaked durable history. NotFound is not an error (already cleaned up).\n   727\t        let mut errors = Vec::new();\n   728\t        if let Err(e) = fs::remove_file(&artifact_path) {\n   729\t            if e.kind() != std::io::ErrorKind::NotFound {\n   730\t                errors.push(format!(\"artifact {}: {}\", artifact_id, e));\n   731\t            }\n   732\t        }\n   733\t        if let Err(e) = fs::remove_file(&payload_path) {\n   734\t            if e.kind() != std::io::ErrorKind::NotFound {\n   735\t                errors.push(format!(\"payload {}: {}\", payload_id, e));\n   736\t            }\n   737\t        }\n   738\t\n   739\t        if errors.is_empty() {\n   740\t            Ok(())\n   741\t        } else {\n   742\t            Err(AppError::Io(std::io::Error::other(format!(\n   743\t                \"failed to remove payload/artifact pair: {}\",\n   744\t                errors.join(\"; \")\n   745\t            ))))\n   746\t        }\n   747\t    }\n   748\t}\n   749\t\n   750\t/// Filesystem-backed implementation of `RuntimeLogWritePort`.\n   751\tpub struct FsRuntimeLogWriteStore;\n   752\t\n   753\timpl RuntimeLogWritePort for FsRuntimeLogWriteStore {\n   754\t    fn append_runtime_log(\n   755\t        &self,\n   756\t        base_dir: &Path,\n   757\t        project_id: &ProjectId,\n   758\t        entry: &RuntimeLogEntry,\n   759\t    ) -> AppResult<()> {\n   760\t        let dir = FileSystem::project_root(base_dir, project_id).join(\"runtime/logs\");\n   761\t        fs::create_dir_all(&dir)?;\n   762\t        let path = dir.join(\"run.ndjson\");\n   763\t        let line = serde_json::to_string(entry)?;\n   764\t        FileSystem::append_line(&path, &line)\n   765\t    }\n   766\t}\n","exit_code":0,"status":"completed"}}
