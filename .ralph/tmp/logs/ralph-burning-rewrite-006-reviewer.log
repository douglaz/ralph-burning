dir = initialize_workspace_fixture();\n  2288\t    let prompt = write_prompt_fixture(temp_dir.path());\n  2289\t\n  2290\t    Command::new(binary())\n  2291\t        .args([\n  2292\t            \"project\",\n  2293\t            \"create\",\n  2294\t            \"--id\",\n  2295\t            \"quickdev\",\n  2296\t            \"--name\",\n  2297\t            \"Quick Dev\",\n  2298\t            \"--prompt\",\n  2299\t            prompt.to_str().unwrap(),\n  2300\t            \"--flow\",\n  2301\t            \"quick_dev\",\n  2302\t        ])\n  2303\t        .current_dir(temp_dir.path())\n  2304\t        .output()\n  2305\t        .expect(\"create project\");\n  2306\t\n  2307\t    Command::new(binary())\n  2308\t        .args([\"project\", \"select\", \"quickdev\"])\n  2309\t        .current_dir(temp_dir.path())\n  2310\t        .output()\n  2311\t        .expect(\"select project\");\n  2312\t\n  2313\t    let output = Command::new(binary())\n  2314\t        .args([\"run\", \"start\"])\n  2315\t        .current_dir(temp_dir.path())\n  2316\t        .output()\n  2317\t        .expect(\"run start\");\n  2318\t\n  2319\t    assert!(!output.status.success());\n  2320\t    let stderr = String::from_utf8_lossy(&output.stderr);\n  2321\t    assert!(\n  2322\t        stderr.contains(\"not yet supported\"),\n  2323\t        \"should reject non-standard flow, got: {stderr}\"\n  2324\t    );\n  2325\t}\n  2326\t\n  2327\t#[test]\n  2328\tfn run_start_rejects_already_completed_project() {\n  2329\t    let temp_dir = initialize_workspace_fixture();\n  2330\t    setup_standard_project(&temp_dir, \"run-dup\");\n  2331\t\n  2332\t    // First run should succeed\n  2333\t    let first = Command::new(binary())\n  2334\t        .args([\"run\", \"start\"])\n  2335\t        .current_dir(temp_dir.path())\n  2336\t        .output()\n  2337\t        .expect(\"first run start\");\n  2338\t    assert!(first.status.success());\n  2339\t\n  2340\t    // Second run should fail because status is