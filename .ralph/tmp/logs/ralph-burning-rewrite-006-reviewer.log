    39\t            .iter()\n    40\t            .copied()\n    41\t            .filter(|s| *s != StageId::PromptReview)\n    42\t            .collect()\n    43\t    }\n    44\t}\n    45\t\n    46\t/// Deterministic stage-to-role mapping per spec.\n    47\tpub fn role_for_stage(stage_id: StageId) -> BackendRole {\n    48\t    BackendRole::for_stage(stage_id)\n    49\t}\n    50\t\n    51\t/// Resolved target per stage for preflight.\n    52\tpub struct StagePlan {\n    53\t    pub stage_id: StageId,\n    54\t    pub role: BackendRole,\n    55\t    pub contract: contracts::StageContract,\n    56\t    pub target: ResolvedBackendTarget,\n    57\t}\n    58\t\n    59\t/// Resolve all stage targets ahead of execution for preflight validation.\n    60\tpub fn resolve_stage_plan(\n    61\t    stages: &[StageId],\n    62\t    resolver: &crate::contexts::agent_execution::service::BackendResolver,\n    63\t    workspace_defaults: Option<&BackendSelectionConfig>,\n    64\t) -> AppResult<Vec<StagePlan>> {\n    65\t    let mut plan = Vec::with_capacity(stages.len());\n    66\t    for &stage_id in stages {\n    67\t        let role = role_for_stage(stage_id);\n    68\t        let contract = contracts::contract_for_stage(stage_id);\n    69\t        let target = resolver.resolve(role, None, None, workspace_defaults)?;\n    70\t        plan.push(StagePlan {\n    71\t            stage_id,\n    72\t            role,\n    73\t            contract,\n    74\t            target,\n    75\t        });\n    76\t    }\n    77\t    Ok(plan)\n    78\t}\n    79\t\n    80\t/// Preflight: check capability and availability for every stage target.\n    81\tpub async fn preflight_check<A: AgentExecutionPort>(\n    82\t    adapter: &A,\n    83\t    plan: &[StagePlan],\n    84\t) -> AppResult<()> {\n    85\t    for entry in plan {\n    86\t        adapter\n    87\t            .check_capability(&entry.target, &entry.contract)\n    88\t            .await\n    89\t            .map_err(|e| AppError::PreflightFailed {\n    90\t                stage_id: entry.stage_id,\n    91\t                details: e.to_string(),\n    92\t            })?;\n    93\t        adapter\n    94\t            .check_availability(&entry.target)\n    95\t            .await\n    96\t            .map_err(|e| AppError::PreflightFailed {\n    97\t                stage_id: entry.stage_id,\n    98\t                details: e.to_string(),\n    99\t            })?;\n   100\t    }\n   101\t    Ok(())\n   102\t}\n   103\t\n   104\t/// Generate a new run ID from a timestamp.\n   105\tfn generate_run_id() -> AppResult<RunId> {\n   106\t    let now = Utc::now();\n   107\t    RunId::new(format!(\"run-{}\", now.format(\"%Y%m%d%H%M%S\")))\n   108\t}\n   109\t\n   110\t/// The standard-flow orchestration engine.\n   111\t///\n   112\t/// Executes all enabled standard stages in canonical order against the provided\n   113\t/// backend adapter, persisting validated payloads and rendered artifacts at\n   114\t/// durable stage boundaries.\n   115\t#[allow(clippy::too_many_arguments)]\n   116\tpub async fn execute_standard_run<A, R, S>(\n   117\t    agent_service: &AgentExecutionService<A, R, S>,\n   118\t    run_snapshot_read: &dyn RunSnapshotPort,\n   119\t    run_snapshot_write: &dyn RunSnapshotWritePort,\n   120\t    journal_store: &dyn JournalStorePort,\n   121\t    artifact_write: &dyn PayloadArtifactWritePort,\n   122\t    log_write: &dyn RuntimeLogWritePort,\n   123\t    base_dir: &Path,\n   124\t    project_id: &ProjectId,\n   125\t    effective_config: &EffectiveConfig,\n   126\t) -> AppResult<()>\n   127\twhere\n   128\t    A: AgentExecutionPort,\n   129\t    R: RawOutputPort,\n   130\t    S: SessionStorePort,\n   131\t{\n   132\t    // 1. Read current snapshot and validate preconditions\n   133\t    let snapshot = run_snapshot_read.read_run_snapshot(base_dir, project_id)?;\n   134\t\n   135\t    if snapshot.status != RunStatus::NotStarted {\n   136\t        return Err(AppError::RunStartFailed {\n   137\t            reason: format!(\n   138\t                \"project snapshot status is '{}'; run start requires 'not_started'\",\n   139\t                snapshot.status\n   140\t            ),\n   141\t        });\n   142\t    }\n   143\t    if snapshot.has_active_run() {\n   144\t        return Err(AppError::RunStartFailed {\n   145\t            reason: \"project already has an active run\".to_owned(),\n   146\t        });\n   147\t    }\n   148\t\n   149\t    // 2. Derive the stage plan\n   150\t    let prompt_review_enabled = effective_config.prompt_review_enabled();\n   151\t    let stages = standard_stage_plan(prompt_review_enabled);\n   152\t\n   153\t    // 3. Resolve backend targets for every stage\n   154\t    let workspace_defaults = BackendSelectionConfig::from_effective_config(effective_config)?;\n   155\t    let stage_plan = resolve_stage_plan(\n   156\t        stages.as_slice(),\n   157\t        agent_service.resolver(),\n   158\t        Some(&workspace_defaults),\n   159\t    )?;\n   160\t\n   161\t    // 4. Preflight checks — if any fail, leave all state unchanged\n   162\t    preflight_check(agent_service.adapter(), &stage_plan).await?;\n   163\t\n   164\t    // 5. Generate run ID and read journal for sequence tracking\n   165\t    let run_id = generate_run_id()?;\n   166\t    let now = Utc::now();\n   167\t    let events = journal_store.read_journal(base_dir, project_id)?;\n   168\t    let mut seq = journal::last_sequence(&events);\n   169\t\n   170\t    let first_stage = stage_plan[0].stage_id;\n   171\t\n   172\t    // 6. Persist run_started: write run.json with running status FIRST, then journal events.\n   173\t    // The snapshot must be durable before journal events become visible.\n   174\t    let initial_cursor = StageCursor::initial(first_stage);\n   175\t    let mut current_snapshot = RunSnapshot {\n   176\t        active_run: Some(ActiveRun {\n   177\t            run_id: run_id.as_str().to_owned(),\n   178\t            stage_cursor: initial_cursor.clone(),\n   179\t            started_at: now,\n   180\t        }),\n   181\t        status: RunStatus::Running,\n   182\t        cycle_history: vec![],\n   183\t        completion_rounds: 1,\n   184\t        rollback_point_meta: snapshot.rollback_point_meta.clone(),\n   185\t        amendment_queue: snapshot.amendment_queue.clone(),\n   186\t        status_summary: format!(\"running: {}\", first_stage.display_name()),\n   187\t    };\n   188\t    run_snapshot_write.write_run_snapshot(base_dir, project_id, &current_snapshot)?;\n   189\t\n   190\t    seq += 1;\n   191\t    let run_started = journal::run_started_event(seq, now, &run_id, first_stage);\n   192\t    let run_started_line = journal::serialize_event(&run_started)?;\n   193\t    if let Err(e) = journal_store.append_event(base_dir, project_id, &run_started_line) {\n   194\t        seq -= 1; // event was not persisted\n   195\t        return fail_run(\n   196\t            &AppError::RunStartFailed {\n   197\t                reason: format!(\"failed to persist run_started event: {}\", e),\n   198\t            },\n   199\t            first_stage,\n   200\t            &run_id,\n   201\t            &mut seq,\n   202\t            &mut current_snapshot,\n   203\t            journal_store,\n   204\t            run_snapshot_write,\n   205\t            base_dir,\n   206\t            project_id,\n   207\t        )\n   208\t        .await;\n   209\t    }\n   210\t\n   211\t    let project_root = project_root_path(base_dir, project_id);\n   212\t\n   213\t    // 7. Execute stages in order\n   214\t    for (idx, stage_entry) in stage_plan.iter().enumerate() {\n   215\t        let stage_id = stage_entry.stage_id;\n   216\t        let cursor = StageCursor::initial(stage_id);\n   217\t\n   218\t        // Emit stage_entered — if journal append fails after run_started,\n   219\t        // the run must persist failed state at this stage boundary.\n   220\t        seq += 1;\n   221\t        let stage_entered = journal::stage_entered_event(\n   222\t            seq,\n   223\t            Utc::now(),\n   224\t            &run_id,\n   225\t            stage_id,\n   226\t            cursor.cycle,\n   227\t            cursor.attempt,\n   228\t        );\n   229\t        let stage_entered_line = journal::serialize_event(&stage_entered)?;\n   230\t        if let Err(e) = journal_store.append_event(base_dir, project_id, &stage_entered_line) {\n   231\t            seq -= 1; // event was not persisted\n   232\t            return fail_run(\n   233\t                &AppError::RunStartFailed {\n   234\t                    reason: format!(\n   235\t                        \"failed to persist stage_entered event for {}: {}\",\n   236\t                        stage_id.as_str(),\n   237\t                        e\n   238\t                    ),\n   239\t                },\n   240\t                stage_id,\n   241\t                &run_id,\n   242\t                &mut seq,\n   243\t                &mut current_snapshot,\n   244\t                journal_store,\n   245\t                run_snapshot_write,\n   246\t                base_dir,\n   247\t                project_id,\n   248\t            )\n   249\t            .await;\n   250\t        }\n   251\t\n   252\t        // Update cursor in snapshot — if this fails after stage_entered,\n   253\t        // the run must persist failed state at this stage boundary.\n   254\t        current_snapshot.active_run.as_mut().unwrap().stage_cursor = cursor.clone();\n   255\t        current_snapshot.status_summary = format!(\"running: {}\", stage_id.display_name());\n   256\t        if let Err(e) =\n   257\t            run_snapshot_write.write_run_snapshot(base_dir, project_id, &current_snapshot)\n   258\t        {\n   259\t            return fail_run(\n   260\t                &AppError::RunStartFailed {\n   261\t                    reason: format!(\n   262\t                        \"failed to update snapshot for stage {}: {}\",\n   263\t                        stage_id.as_str(),\n   264\t                        e\n   265\t                    ),\n   266\t                },\n   267\t                stage_id,\n   268\t                &run_id,\n   269\t                &mut seq,\n   270\t                &mut current_snapshot,\n   271\t                journal_store,\n   272\t                run_snapshot_write,\n   273\t                base_dir,\n   274\t                project_id,\n   275\t            )\n   276\t            .await;\n   277\t        }\n   278\t\n   279\t        // Best-effort runtime log\n   280\t        let _ = log_write.append_runtime_log(\n   281\t            base_dir,\n   282\t            project_id,\n   283\t            &RuntimeLogEntry {\n   284\t                timestamp: Utc::now(),\n   285\t                level: LogLevel::Info,\n   286\t                source: \"engine\".to_owned(),\n   287\t                message: format!(\"stage_entered: {}\", stage_id.as_str()),\n   288\t            },\n   289\t        );\n   290\t\n   291\t        // Invoke the backend\n   292\t        let invocation_id = format!(\n   293\t            \"{}-{}-c{}-a{}\",\n   294\t            run_id.as_str(),\n   295\t            stage_id.as_str(),\n   296\t            cursor.cycle,\n   297\t            cursor.attempt\n   298\t        );\n   299\t        let request = InvocationRequest {\n   300\t            invocation_id,\n   301\t            project_root: project_root.clone(),\n   302\t            stage_contract: stage_entry.contract,\n   303\t            role: stage_entry.role,\n   304\t            resolved_target: stage_entry.target.clone(),\n   305\t            payload: InvocationPayload {\n   306\t                prompt: format!(\"Execute stage: {}\", stage_id.display_name()),\n   307\t                context: serde_json::json!({}),\n   308\t            },\n   309\t            timeout: Duration::from_secs(300),\n   310\t            cancellation_token: CancellationToken::new(),\n   311\t            session_policy: SessionPolicy::ReuseIfAllowed,\n   312\t            prior_session: None,\n   313\t            attempt_number: cursor.attempt,\n   314\t        };\n   315\t\n   316\t        let envelope = match agent_service.invoke(request).await {\n   317\t            Ok(env) => env,\n   318\t            Err(e) => {\n   319\t                return fail_run(\n   320\t                    &e,\n   321\t                    stage_id,\n   322\t                    &run_id,\n   323\t                    &mut seq,\n   324\t                    &mut current_snapshot,\n   325\t                    journal_store,\n   326\t                    run_snapshot_write,\n   327\t                    base_dir,\n   328\t                    project_id,\n   329\t                )\n   330\t                .await;\n   331\t            }\n   332\t        };\n   333\t\n   334\t        // Evaluate the contract (schema + domain + outcome + render)\n   335\t        let bundle = match stage_entry.contract.evaluate(&envelope.parsed_payload) {\n   336\t            Ok(bundle) => bundle,\n   337\t            Err(contract_err) => {\n   338\t                let app_err = AppError::InvocationFailed {\n   339\t                    backend: stage_entry.target.backend.family.to_string(),\n   340\t                    stage_id,\n   341\t                    failure_class: contract_err.failure_class(),\n   342\t                    details: contract_err.to_string(),\n   343\t                };\n   344\t                return fail_run(\n   345\t                    &app_err,\n   346\t                    stage_id,\n   347\t                    &run_id,\n   348\t                    &mut seq,\n   349\t                    &mut current_snapshot,\n   350\t                    journal_store,\n   351\t                    run_snapshot_write,\n   352\t                    base_dir,\n   353\t                    project_id,\n   354\t                )\n   355\t                .await;\n   356\t            }\n   357\t        };\n   358\t\n   359\t        // Persist payload + artifact pair atomically\n   360\t        let stage_now = Utc::now();\n   361\t        let payload_id = format!(\n   362\t            \"{}-{}-c{}-a{}\",\n   363\t            run_id.as_str(),\n   364\t            stage_id.as_str(),\n   365\t            cursor.cycle,\n   366\t            cursor.attempt\n   367\t        );\n   368\t        let artifact_id = format!(\"{}-artifact\", payload_id);\n   369\t\n   370\t        let payload_record = PayloadRecord {\n   371\t            payload_id: payload_id.clone(),\n   372\t            stage_id,\n   373\t            cycle: cursor.cycle,\n   374\t            attempt: cursor.attempt,\n   375\t            created_at: stage_now,\n   376\t            payload: serde_json::to_value(&bundle.payload)?,\n   377\t        };\n   378\t        let artifact_record = ArtifactRecord {\n   379\t            artifact_id: artifact_id.clone(),\n   380\t            payload_id: payload_id.clone(),\n   381\t            stage_id,\n   382\t            created_at: stage_now,\n   383\t            content: bundle.artifact.clone(),\n   384\t        };\n   385\t\n   386\t        // Atomic stage commit: payload + artifact + snapshot + journal.\n   387\t        // All four must succeed for the stage to become durably visible.\n   388\t        // Order: payload/artifact → snapshot cursor → stage_completed journal.\n   389\t        // This ensures that if any step fails, no stage_completed event leaks\n   390\t        // into the journal without a matching snapshot and durable files.\n   391\t\n   392\t        // Step 1: Write payload + artifact pair.\n   393\t        // If this fails, the stage is not committed — nothing else to roll back.\n   394\t        artifact_write\n   395\t            .write_payload_artifact_pair(base_dir, project_id, &payload_record, &artifact_record)\n   396\t            .map_err(|e| AppError::StageCommitFailed {\n   397\t                stage_id,\n   398\t                details: format!(\"payload/artifact persistence failed: {}\", e),\n   399\t            })?;\n   400\t\n   401\t        // Step 2: Update snapshot cursor to reflect completed stage.\n   402\t        // Written BEFORE stage_completed journal so that snapshot failure\n   403\t        // never leaves a stage_completed event without a matching cursor.\n   404\t        let pre_commit_snapshot = current_snapshot.clone();\n   405\t        if idx + 1 < stage_plan.len() {\n   406\t            let next_stage = stage_plan[idx + 1].stage_id;\n   407\t            current_snapshot.active_run.as_mut().unwrap().stage_cursor =\n   408\t                StageCursor::initial(next_stage);\n   409\t            current_snapshot.status_summary = format!(\n   410\t                \"running: completed {}, next {}\",\n   411\t                stage_id.display_name(),\n   412\t                next_stage.display_name()\n   413\t            );\n   414\t        }\n   415\t        if let Err(e) = run_snapshot_write.write_run_snapshot(base_dir, project_id, &current_snapshot) {\n   416\t            // Roll back payload/artifact; no stage_completed was written yet.\n   417\t            let _ =\n   418\t                artifact_write.remove_payload_artifact_pair(base_dir, project_id, &payload_id, &artifact_id);\n   419\t            current_snapshot = pre_commit_snapshot;\n   420\t            let commit_err = AppError::StageCommitFailed {\n   421\t                stage_id,\n   422\t                details: format!(\"snapshot write failed during stage commit: {}\", e),\n   423\t            };\n   424\t            return fail_run(\n   425\t                &commit_err,\n   426\t                stage_id,\n   427\t                &run_id,\n   428\t                &mut seq,\n   429\t                &mut current_snapshot,\n   430\t                journal_store,\n   431\t                run_snapshot_write,\n   432\t                base_dir,\n   433\t                project_id,\n   434\t            )\n   435\t            .await;\n   436\t        }\n   437\t\n   438\t        // Step 3: Append stage_completed journal event.\n   439\t        // If this fails, roll back payload/artifact and overwrite snapshot\n   440\t        // via fail_run so the stage remains uncommitted.\n   441\t        seq += 1;\n   442\t        let stage_completed = journal::stage_completed_event(\n   443\t            seq,\n   444\t            Utc::now(),\n   445\t            &run_id,\n   446\t            stage_id,\n   447\t            cursor.cycle,\n   448\t            cursor.attempt,\n   449\t            &payload_id,\n   450\t            &artifact_id,\n   451\t        );\n   452\t        let stage_completed_line = journal::serialize_event(&stage_completed)?;\n   453\t        if let Err(e) = journal_store.append_event(base_dir, project_id, &stage_completed_line) {\n   454\t            // Roll back payload/artifact so no partial durable history is visible\n   455\t            let _ =\n   456\t                artifact_write.remove_payload_artifact_pair(base_dir, project_id, &payload_id, &artifact_id);\n   457\t            seq -= 1; // undo the seq increment since the event was not persisted\n   458\t            let commit_err = AppError::StageCommitFailed {\n   459\t                stage_id,\n   460\t                details: format!(\"journal append failed during stage commit: {}\", e),\n   461\t            };\n   462\t            return fail_run(\n   463\t                &commit_err,\n   464\t                stage_id,\n   465\t                &run_id,\n   466\t                &mut seq,\n   467\t                &mut current_snapshot,\n   468\t                journal_store,\n   469\t                run_snapshot_write,\n   470\t                base_dir,\n   471\t                project_id,\n   472\t            )\n   473\t            .await;\n   474\t        }\n   475\t\n   476\t        // Best-effort runtime log\n   477\t        let _ = log_write.append_runtime_log(\n   478\t            base_dir,\n   479\t            project_id,\n   480\t            &RuntimeLogEntry {\n   481\t                timestamp: Utc::now(),\n   482\t                level: LogLevel::Info,\n   483\t                source: \"engine\".to_owned(),\n   484\t                message: format!(\"stage_completed: {}\", stage_id.as_str()),\n   485\t            },\n   486\t        );\n   487\t    }\n   488\t\n   489\t    // 8. All stages completed — mark run as completed.\n   490\t    // Write completed snapshot FIRST so the run is marked as completed\n   491\t    // even if journal append fails (consistent with snapshot-first ordering).\n   492\t    current_snapshot.status = RunStatus::Completed;\n   493\t    current_snapshot.active_run = None;\n   494\t    current_snapshot.completion_rounds = 1;\n   495\t    current_snapshot.status_summary = \"completed\".to_owned();\n   496\t    run_snapshot_write.write_run_snapshot(base_dir, project_id, &current_snapshot)?;\n   497\t\n   498\t    seq += 1;\n   499\t    let run_completed = journal::run_completed_event(seq, Utc::now(), &run_id, 1);\n   500\t    let run_completed_line = journal::serialize_event(&run_completed)?;\n   501\t    journal_store.append_event(base_dir, project_id, &run_completed_line)?;\n   502\t\n   503\t    Ok(())\n   504\t}\n   505\t\n   506\t/// Record a run failure: persist failed snapshot, then journal event, return error.\n   507\t///\n   508\t/// The snapshot is written first (critical path) so the run is never left in an\n   509\t/// ambiguous running state. The journal append is best-effort relative to the\n   510\t/// snapshot — if it fails, the snapshot already reflects the failed state.\n   511\t#[allow(clippy::too_many_arguments)]\n   512\tasync fn fail_run(\n   513\t    err: &AppError,\n   514\t    stage_id: StageId,\n   515\t    run_id: &RunId,\n   516\t    seq: &mut u64,\n   517\t    snapshot: &mut RunSnapshot,\n   518\t    journal_store: &dyn JournalStorePort,\n   519\t    run_snapshot_write: &dyn RunSnapshotWritePort,\n   520\t    base_dir: &Path,\n   521\t    project_id: &ProjectId,\n   522\t) -> AppResult<()> {\n   523\t    let failure_class = err\n   524\t        .failure_class()\n   525\t        .map(|fc| format!(\"{:?}\", fc))\n   526\t        .unwrap_or_else(|| \"unknown\".to_owned());\n   527\t    let message = err.to_string();\n   528\t\n   529\t    // Critical: persist the failed snapshot first so the run is never\n   530\t    // left in an ambiguous running state after any failure.\n   531\t    snapshot.status = RunStatus::Failed;\n   532\t    snapshot.active_run = None;\n   533\t    snapshot.status_summary = format!(\"failed at {}: {}\", stage_id.display_name(), message);\n   534\t    run_snapshot_write.write_run_snapshot(base_dir, project_id, snapshot)?;\n   535\t\n   536\t    // Best-effort: append run_failed journal event. If this fails,\n   537\t    // the snapshot already reflects the failed state.\n   538\t    *seq += 1;\n   539\t    let run_failed =\n   540\t        journal::run_failed_event(*seq, Utc::now(), run_id, stage_id, &failure_class, &message);\n   541\t    if let Ok(run_failed_line) = journal::serialize_event(&run_failed) {\n   542\t        let _ = journal_store.append_event(base_dir, project_id, &run_failed_line);\n   543\t    }\n   544\t\n   545\t    Err(AppError::RunStartFailed {\n   546\t        reason: format!(\"stage {} failed: {}\", stage_id.as_str(), message),\n   547\t    })\n   548\t}\n   549\t\n   550\t/// Helper to get project root path.\n   551\tfn project_root_path(base_dir: &Path, project_id: &ProjectId) -> PathBuf {\n   552\t    base_dir\n   553\t        .join(\".ralph-burning\")\n   554\t        .join(\"projects\")\n   555\t        .join(project_id.as_str())\n   556\t}\n","exit_code":0,"status":"completed"}}
