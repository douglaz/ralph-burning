        stage_id: request.stage_contract.stage_id,\n    96\t            });\n    97\t        }\n    98\t\n    99\t        if self.delay > Duration::from_millis(0) {\n   100\t            tokio::select! {\n   101\t                _ = request.cancellation_token.cancelled() => {\n   102\t                    return Err(AppError::InvocationCancelled {\n   103\t                        backend: request.resolved_target.backend.family.to_string(),\n   104\t                        stage_id: request.stage_contract.stage_id,\n   105\t                    });\n   106\t                }\n   107\t                _ = tokio::time::sleep(self.delay) => {}\n   108\t            }\n   109\t        }\n   110\t\n   111\t        let payload = canned_payload_for_stage(request.stage_contract.stage_id);\n   112\t        let raw_output = serde_json::to_string_pretty(&payload)?;\n   113\t        let prompt_token_count = count_tokens(&request.payload.prompt);\n   114\t        let completion_token_count = count_tokens(&raw_output);\n   115\t        let prompt_tokens = Some(prompt_token_count);\n   116\t        let completion_tokens = Some(completion_token_count);\n   117\t        let total_tokens = Some(prompt_token_count + completion_token_count);\n   118\t\n   119\t        let supports_reuse =\n   120\t            request.role.allows_session_reuse() && request.resolved_target.supports_session_reuse();\n   121\t        let session_reused = supports_reuse\n   122\t            && matches!(request.session_policy, SessionPolicy::ReuseIfAllowed)\n   123\t            && request.prior_session.is_some();\n   124\t        let session_id = if supports_reuse {\n   125\t            request\n   126\t                .prior_session\n   127\t                .as_ref()\n   128\t                .map(|session| session.session_id.clone())\n   129\t                .filter(|_| session_reused)\n   130\t                .or_else(|| {\n   131\t                    Some(format!(\n   132\t                        \"stub-{}-{}\"