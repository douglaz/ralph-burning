523\t                    entries.push(entry);\n   524\t                }\n   525\t            }\n   526\t        }\n   527\t\n   528\t        Ok(entries)\n   529\t    }\n   530\t}\n   531\t\n   532\t/// Filesystem-backed implementation of `RunSnapshotPort`.\n   533\tpub struct FsRunSnapshotStore;\n   534\t\n   535\timpl RunSnapshotPort for FsRunSnapshotStore {\n   536\t    fn read_run_snapshot(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<RunSnapshot> {\n   537\t        let path = FileSystem::project_root(base_dir, project_id).join(RUN_FILE);\n   538\t        match fs::read_to_string(&path) {\n   539\t            Ok(raw) => {\n   540\t                let snapshot: RunSnapshot =\n   541\t                    serde_json::from_str(&raw).map_err(|e| AppError::CorruptRecord {\n   542\t                        file: format!(\"projects/{}/run.json\", project_id),\n   543\t                        details: e.to_string(),\n   544\t                    })?;\n   545\t                // Semantic validation: reject inconsistent status/active_run combinations\n   546\t                snapshot\n   547\t                    .validate_semantics()\n   548\t                    .map_err(|details| AppError::CorruptRecord {\n   549\t                        file: format!(\"projects/{}/run.json\", project_id),\n   550\t                        details,\n   551\t                    })?;\n   552\t                Ok(snapshot)\n   553\t            }\n   554\t            Err(e) if e.kind() == std::io::ErrorKind::NotFound => Err(AppError::CorruptRecord {\n   555\t                file: format!(\"projects/{}/run.json\", project_id),\n   556\t                details: \"canonical file is missing\".to_owned(),\n   557\t            }),\n   558\t            Err(e) => Err(e.into()),\n   559\t        }\n   560\t    }\n   561\t}\n   562\t\n   563\t/// Filesystem-backed implementation of `ActiveProjectPort`.\n   564\tpub struct FsActiveProjectStore;\n   565\t\n   566\timpl ActiveProjectPort for FsActiveProjectStore {\n   567\t    fn read_active_project_id(&self, base_dir: &Path) -> AppResult<Option<String>> {\n   568\t        FileSystem::read_active_project(&FileSystem::workspace_root_path(base_dir))\n   569\t    }\n   570\t\n   571\t    fn clear_active_project(&self, base_dir: &Path) -> AppResult<()> {\n   572\t        let path = FileSystem::workspace_root_path(base_dir).join(ACTIVE_PROJECT_FILE);\n   573\t        match fs::remove_file(&path) {\n   574\t            Ok(()) => Ok(()),\n   575\t            Err(e) if e.kind() == std::io::ErrorKind::NotFound => Ok(()),\n   576\t            Err(e) => Err(e.into()),\n   577\t        }\n   578\t    }\n   579\t\n   580\t    fn write_active_project(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<()> {\n   581\t        FileSystem::write_active_project(\n   582\t            &FileSystem::workspace_root_path(base_dir),\n   583\t            project_id.as_str(),\n   584\t        )\n   585\t    }\n   586\t}\n   587\t\n   588\t/// Filesystem-backed implementation of `RawOutputPort`.\n   589\tpub struct FsRawOutputStore;\n   590\t\n   591\timpl RawOutputPort for FsRawOutputStore {\n   592\t    fn persist_raw_output(\n   593\t        &self,\n   594\t        project_root: &Path,\n   595\t        invocation_id: &str,\n   596\t        contents: &str,\n   597\t    ) -> AppResult<RawOutputReference> {\n   598\t        let path = project_root\n   599\t            .join(\"runtime/backend\")\n   600\t            .join(format!(\"{invocation_id}.raw\"));\n   601\t        FileSystem::write_atomic(&path, contents)?;\n   602\t        Ok(RawOutputReference::Stored(path))\n   603\t    }\n   604\t}\n   605\t\n   606\t/// Filesystem-backed implementation of `SessionStorePort`.\n   607\tpub struct FsSessionStore;\n   608\t\n   609\timpl SessionStorePort for FsSessionStore {\n   610\t    fn load_sessions(&self, project_root: &Path) -> AppResult<PersistedSessions> {\n   611\t        let path = project_root.join(SESSIONS_FILE);\n   61