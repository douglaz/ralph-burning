d_agent_service();\n   168\t    let config = EffectiveConfig::load(base_dir).unwrap();\n   169\t    assert!(!config.prompt_review_enabled());\n   170\t\n   171\t    let result = engine::execute_standard_run(\n   172\t        &agent_service,\n   173\t        &FsRunSnapshotStore,\n   174\t        &FsRunSnapshotWriteStore,\n   175\t        &FsJournalStore,\n   176\t        &FsPayloadArtifactWriteStore,\n   177\t        &FsRuntimeLogWriteStore,\n   178\t        base_dir,\n   179\t        &pid,\n   180\t        &config,\n   181\t    )\n   182\t    .await;\n   183\t\n   184\t    assert!(result.is_ok());\n   185\t\n   186\t    // Verify 7 stages completed (no prompt_review)\n   187\t    let payloads_dir = base_dir\n   188\t        .join(\".ralph-burning/projects/no-pr-test/history/payloads\");\n   189\t    let payload_count = fs::read_dir(&payloads_dir).unwrap().count();\n   190\t    assert_eq!(payload_count, 7, \"expected 7 payloads without prompt_review\");\n   191\t\n   192\t    // Verify no prompt_review stage_entered in journal\n   193\t    let events = FsJournalStore.read_journal(base_dir, &pid).unwrap();\n   194\t    let pr_events: Vec<_> = events\n   195\t        .iter()\n   196\t        .filter(|e| {\n   197\t            if e.event_type == JournalEventType::StageEntered {\n   198\t                e.details.get(\"stage_id\").and_then(|v| v.as_str()) == Some(\"prompt_review\")\n   199\t            } else {\n   200\t                false\n   201\t            }\n   202\t        })\n   203\t        .collect();\n   204\t    assert!(pr_events.is_empty(), \"prompt_review stage should not appear\");\n   205\t}\n   206\t\n   207\t// ── Precondition failure tests ──────────────────────────────────────────────\n   208\t\n   209\t#[tokio::test]\n   210\tasync fn run_start_rejects_already_running() {\n   211\t    let tmp = tempdir().unwrap();\n   212\t    let base_dir = tmp.path();\n   213\t\n   214\t    setup_workspace(base_dir);\n   215\t    let pid = create_standard_project(base_dir, \"running-test\");\n   216\t\n   217\t    // Manually set status to running\n   218\t    let snapshot = RunSnapshot {\n   219\t        active_run: Some(ralph_burning::contexts::project_run_record::model::ActiveRun {\n   220\t            run_id: \"run-fake\".to_owned(),\n   221\t            stage_cursor: ralph_burning::shared::domain::StageCursor::initial(StageId::Planning),\n   222\t            started_at: Utc::now(),\n   223\t        }),\n   224\t        status: RunStatus::Running,\n   225\t        cycle_history: vec![],\n   226\t        completion_rounds: 0,\n   227\t        rollback_point_meta: Default::default(),\n   228\t        amendment_queue: Default::default(),\n   229\t        status_summary: \"running\".to_owned(),\n   230\t    };\n   231\t    FsRunSnapshotWriteStore\n   232\t        .write_run_snapshot(base_dir, &pid, &snapshot)\n   233\t        .unwrap();\n   234\t\n   235\t    let agent_service = build_agent_service();\n   236\t    let config = EffectiveConfig::load(base_dir).unwrap();\n   237\t\n   238\t    let result = engine::execute_standard_run(\n   239\t        &agent_service,\n   240\t        &FsRunSnapshotStore,\n   241\t        &FsRunSnapshotWriteStore,\n   242\t        &FsJournalStore,\n   243\t        &FsPayloadArtifactWriteStore,\n   244\t        &FsRuntimeLogWriteStore,\n   245\t        base_dir,\n   246\t        &pid,\n   247\t        &config,\n   248\t    )\n   249\t    .await;\n   250\t\n   251\t    assert!(result.is_err());\n   252\t    let err = result.unwrap_err().to_string();\n   253\t    assert!(err.contains(\"not_started\"), \"unexpected error: {}\", err);\n   254\t}\n   255\t\n   256\t#[tokio::test]\n   257\tasync fn run_start_rejects_completed_project() {\n   258\t    let tmp = tempdir().unwrap();\n   259\t    let base_dir = tmp.path();\n   260\t\n   261\t    setup_workspace(base_dir);\n   262\t    let pid = create_standard_project(base_dir, \"completed-test\");\n   263\t\n   264\t    let snapshot = RunSnapshot {\n   265\t        active_run: None,\n   266\t        status: RunStatus::Completed,\n   267\t        cycle_history: vec![],\n   268\t        completion_rounds: 1,\n   269\t        rollback_point_meta: Default::default(),\n   270\t        amendment_queue: Default::default(),\n   271\t        status_summary: \"completed\".to_owned(),\n   272\t    };\n   273\t    FsRunSnapshotWriteStore\n   274\t        .write_run_snapshot(base_dir, &pid, &snapshot)\n   275\t        .unwrap();\n   276\t\n   277\t    let agent_service = build_agent_service();\n   278\t    let config = EffectiveConfig::load(base_dir).unwrap();\n   279\t\n   280\t    let result = engine::execute_standard_run(\n   281\t        &agent_service,\n   282\t        &FsRunSnapshotStore,\n   283\t        &FsRunSnapshotWriteStore,\n   284\t        &FsJournalStore,\n   285\t        &FsPayloadArtifactWriteStore,\n   286\t        &FsRuntimeLogWriteStore,\n   287\t        base_dir,\n   288\t        &pid,\n   289\t        &config,\n   290\t    )\n   291\t    .await;\n   292\t\n   293\t    assert!(result.is_err());\n   294\t}\n   295\t\n   296\t// ── Preflight failure tests ─────────────────────────────────────────────────\n   297\t\n   298\t#[tokio::test]\n   299\tasync fn preflight_failure_leaves_state_unchanged() {\n   300\t    let tmp = tempdir().unwrap();\n   301\t    let base_dir = tmp.path();\n   302\t\n   303\t    setup_workspace(base_dir);\n   304\t    let pid = create_standard_project(base_dir, \"preflight-test\");\n   305\t\n   306\t    // Use an unavailable backend to trigger preflight failure\n   307\t    let agent_service = AgentExecutionService::new(\n   308\t        StubBackendAdapter::default().unavailable(),\n   309\t        FsRawOutputStore,\n   310\t        FsSessionStore,\n   311\t    );\n   312\t    let config = EffectiveConfig::load(base_dir).unwrap();\n   313\t\n   314\t    let result = engine::execute_standard_run(\n   315\t        &agent_service,\n   316\t        &FsRunSnapshotStore,\n   317\t        &FsRunSnapshotWriteStore,\n   318\t        &FsJournalStore,\n   319\t        &FsPayloadArtifactWriteStore,\n   320\t        &FsRuntimeLogWriteStore,\n   321\t        base_dir,\n   322\t        &pid,\n   323\t        &config,\n   324\t    )\n   325\t    .await;\n   326\t\n   327\t    assert!(result.is_err());\n   328\t\n   329\t    // Verify run.json is still not_started\n   330\t    let snapshot = FsRunSnapshotStore.read_run_snapshot(base_dir, &pid).unwrap();\n   331\t    assert_eq!(snapshot.status, RunStatus::NotStarted);\n   332\t    assert!(snapshot.active_run.is_none());\n   333\t\n   334\t    // Verify journal only has project_created\n   335\t    let events = FsJournalStore.read_journal(base_dir, &pid).unwrap();\n   336\t    assert_eq!(events.len(), 1);\n   337\t    assert_eq!(events[0].event_type, JournalEventType::ProjectCreated);\n   338\t\n   339\t    // Verify no payloads or artifacts created\n   340\t    let payloads_dir = base_dir\n   341\t        .join(\".ralph-burning/projects/preflight-test/history/payloads\");\n   342\t    let payload_count = fs::read_dir(&payloads_dir).unwrap().count();\n   343\t    assert_eq!(payload_count, 0);\n   344\t}\n   345\t\n   346\t// ── Stage plan resolution tests ─────────────────────────────────────────────\n   347\t\n   348\t#[test]\n   349\tfn resolve_stage_plan_produces_correct_targets() {\n   350\t    let resolver = ralph_burning::contexts::agent_execution::service::BackendResolver::new();\n   351\t    let stages = engine::standard_stage_plan(true);\n   352\t    let plan = engine::resolve_stage_plan(&stages, &resolver, None).unwrap();\n   353\t\n   354\t    assert_eq!(plan.len(), 8);\n   355\t    assert_eq!(plan[0].stage_id, StageId::PromptReview);\n   356\t    assert_eq!(\n   357\t        plan[0].role,\n   358\t        ralph_burning::shared::domain::BackendRole::Planner\n   359\t    );\n   360\t    assert_eq!(plan[2].stage_id, StageId::Implementation);\n   361\t    assert_eq!(\n   362\t        plan[2].role,\n   363\t        ralph_burning::shared::domain::BackendRole::Implementer\n   364\t    );\n   365\t}\n   366\t\n   367\t// ── Preflight check unit test ───────────────────────────────────────────────\n   368\t\n   369\t#[tokio::test]\n   370\tasync fn preflight_check_succeeds_with_default_stub() {\n   371\t    let resolver = ralph_burning::contexts::agent_execution::service::BackendResolver::new();\n   372\t    let stages = engine::standard_stage_plan(true);\n   373\t    let plan = engine::resolve_stage_plan(&stages, &resolver, None).unwrap();\n   374\t\n   375\t    let adapter = StubBackendAdapter::default();\n   376\t    let result = engine::preflight_check(&adapter, &plan).await;\n   377\t    assert!(result.is_ok());\n   378\t}\n   379\t\n   380\t#[tokio::test]\n   381\tasync fn preflight_check_fails_with_unavailable_backend() {\n   382\t    let resolver = ralph_burning::contexts::agent_execution::service::BackendResolver::new();\n   383\t    let stages = engine::standard_stage_plan(true);\n   384\t    let plan = engine::resolve_stage_plan(&stages, &resolver, None).unwrap();\n   385\t\n   386\t    let adapter = StubBackendAdapter::default().unavailable();\n   387\t    let result = engine::preflight_check(&adapter, &plan).await;\n   388\t    assert!(result.is_err());\n   389\t}\n   390\t\n   391\t// ── Failing-port tests: journal-append and snapshot-write errors ─────────\n   392\t\n   393\tuse std::sync::atomic::{AtomicU32, Ordering};\n   394\t\n   395\t/// A journal store that delegates to `FsJournalStore` but fails on the Nth\n   396\t/// append_event call (1-indexed). This lets us test failure at specific\n   397\t/// stage-commit boundaries.\n   398\tstruct FailingJournalStore {\n   399\t    call_count: AtomicU32,\n   400\t    fail_on_call: u32,\n   401\t}\n   402\t\n   403\timpl FailingJournalStore {\n   404\t    fn new(fail_on_call: u32) -> Self {\n   405\t        Self {\n   406\t            call_count: AtomicU32::new(0),\n   407\t            fail_on_call,\n   408\t        }\n   409\t    }\n   410\t}\n   411\t\n   412\timpl JournalStorePort for FailingJournalStore {\n   413\t    fn read_journal(\n   414\t        &self,\n   415\t        base_dir: &Path,\n   416\t        project_id: &ralph_burning::shared::domain::ProjectId,\n   417\t    ) -> AppResult<Vec<JournalEvent>> {\n   418\t        FsJournalStore.read_journal(base_dir, project_id)\n   419\t    }\n   420\t\n   421\t    fn append_event(\n   422\t        &self,\n   423\t        base_dir: &Path,\n   424\t        project_id: &ralph_burning::shared::domain::ProjectId,\n   425\t        line: &str,\n   426\t    ) -> AppResult<()> {\n   427\t        let n = self.call_count.fetch_add(1, Ordering::SeqCst) + 1;\n   428\t        if n == self.fail_on_call {\n   429\t            return Err(AppError::Io(std::io::Error::other(\n   430\t                \"simulated journal append failure\",\n   431\t            )));\n   432\t        }\n   433\t        FsJournalStore.append_event(base_dir, project_id, line)\n   434\t    }\n   435\t}\n   436\t\n   437\t/// A snapshot write store that delegates to `FsRunSnapshotWriteStore` but fails\n   438\t/// on the Nth write call (1-indexed).\n   439\tstruct FailingSnapshotWriteStore {\n   440\t    call_count: AtomicU32,\n   441\t    fail_on_call: u32,\n   442\t}\n   443\t\n   444\timpl FailingSnapshotWriteStore {\n   445\t    fn new(fail_on_call: u32) -> Self {\n   446\t        Self {\n   447\t            call_count: AtomicU32::new(0),\n   448\t            fail_on_call,\n   449\t        }\n   450\t    }\n   451\t}\n   452\t\n   453\timpl RunSnapshotWritePort for FailingSnapshotWriteStore {\n   454\t    fn write_run_snapshot(\n   455\t        &self,\n   456\t        base_dir: &Path,\n   457\t        project_id: &ralph_burning::shared::domain::ProjectId,\n   458\t        snapshot: &RunSnapshot,\n   459\t    ) -> AppResult<()> {\n   460\t        let n = self.call_count.fetch_add(1, Ordering::SeqCst) + 1;\n   461\t        if n == self.fail_on_call {\n   462\t            return Err(AppError::Io(std::io::Error::other(\n   463\t                \"simulated snapshot write failure\",\n   464\t            )));\n   465\t        }\n   466\t        FsRunSnapshotWriteStore.write_run_snapshot(base_dir, project_id, snapshot)\n   467\t    }\n   468\t}\n   469\t\n   470\t/// Stage-entered journal append failure must persist failed state.\n   471\t/// The run must never be left in an ambiguous running state when the\n   472\t/// stage_entered event cannot be persisted.\n   473\t#[tokio::test]\n   474\tasync fn stage_entered_journal_failure_persists_failed_state() {\n   475\t    let tmp = tempdir().unwrap();\n   476\t    let base_dir = tmp.path();\n   477\t\n   478\t    setup_workspace(base_dir);\n   479\t    let pid = create_standard_project(base_dir, \"stage-entry-fail\");\n   480\t\n   481\t    let agent_service = build_agent_service();\n   482\t    let config = EffectiveConfig::load(base_dir).unwrap();\n   483\t\n   484\t    // The engine calls append_event for:\n   485\t    //   1: run_started\n   486\t    //   2: stage_entered (stage 1) — fail here\n   487\t    let failing_journal = FailingJournalStore::new(2);\n   488\t\n   489\t    let result = engine::execute_standard_run(\n   490\t        &agent_service,\n   491\t        &FsRunSnapshotStore,\n   492\t        &FsRunSnapshotWriteStore,\n   493\t        &failing_journal,\n   494\t        &FsPayloadArtifactWriteStore,\n   495\t        &FsRuntimeLogWriteStore,\n   496\t        base_dir,\n   497\t        &pid,\n   498\t        &config,\n   499\t    )\n   500\t    .await;\n   501\t\n   502\t    assert!(result.is_err(), \"run should fail on stage_entered journal failure\");\n   503\t\n   504\t    // Run must be in failed state, not left in running\n   505\t    let snapshot = FsRunSnapshotStore.read_run_snapshot(base_dir, &pid).unwrap();\n   506\t    assert_eq!(snapshot.status, RunStatus::Failed);\n   507\t    assert!(snapshot.active_run.is_none());\n   508\t\n   509\t    // No stage_entered event should exist for the first stage since the append failed\n   510\t    let events = FsJournalStore.read_journal(base_dir, &pid).unwrap();\n   511\t    let stage_entered_events: Vec<_> = events\n   512\t        .iter()\n   513\t        .filter(|e| e.event_type == JournalEventType::StageEntered)\n   514\t        .collect();\n   515\t    assert!(\n   516\t        stage_entered_events.is_empty(),\n   517\t        \"no stage_entered event should exist after journal failure, found {}\",\n   518\t        stage_entered_events.len()\n   519\t    );\n   520\t\n   521\t    // No payload/artifact should exist\n   522\t    let payloads_dir = base_dir\n   523\t        .join(\".ralph-burning/projects/stage-entry-fail/history/payloads\");\n   524\t    let payload_count = fs::read_dir(&payloads_dir).unwrap().count();\n   525\t    assert_eq!(payload_count, 0, \"no payloads should exist\");\n   526\t}\n   527\t\n   528\t/// Run-started journal append failure must persist failed state.\n   529\t/// The run must never be left in running state when run_started cannot be\n   530\t/// appended to the journal.\n   531\t#[tokio::test]\n   532\tasync fn run_started_journal_failure_persists_failed_state() {\n   533\t    let tmp = tempdir().unwrap();\n   534\t    let base_dir = tmp.path();\n   535\t\n   536\t    setup_workspace(base_dir);\n   537\t    let pid = create_standard_project(base_dir, \"run-started-fail\");\n   538\t\n   539\t    let agent_service = build_agent_service();\n   540\t    let config = EffectiveConfig::load(base_dir).unwrap();\n   541\t\n   542\t    // The engine calls append_event for:\n   543\t    //   1: run_started — fail here\n   544\t    let failing_journal = FailingJournalStore::new(1);\n   545\t\n   546\t    let result = engine::execute_standard_run(\n   547\t        &agent_service,\n   548\t        &FsRunSnapshotStore,\n   549\t        &FsRunSnapshotWriteStore,\n   550\t        &failing_journal,\n   551\t        &FsPayloadArtifactWriteStore,\n   552\t        &FsRuntimeLogWriteStore,\n   553\t        base_dir,\n   554\t        &pid,\n   555\t        &config,\n   556\t    )\n   557\t    .await;\n   558\t\n   559\t    assert!(result.is_err(), \"run should fail on run_started journal failure\");\n   560\t\n   561\t    // Run must be in failed state, not left in running\n   562\t    let snapshot = FsRunSnapshotStore.read_run_snapshot(base_dir, &pid).unwrap();\n   563\t    assert_eq!(snapshot.status, RunStatus::Failed);\n   564\t    assert!(snapshot.active_run.is_none());\n   565\t\n   566\t    // No payloads or artifacts should exist\n   567\t    let payloads_dir = base_dir\n   568\t        .join(\".ralph-burning/projects/run-started-fail/history/payloads\");\n   569\t    let payload_count = fs::read_dir(&payloads_dir).unwrap().count();\n   570\t    assert_eq!(payload_count, 0, \"no payloads should exist\");\n   571\t}\n   572\t\n   573\t/// Journal append failure after payload/artifact write must roll back the\n   574\t/// payload/artifact pair so no partial durable history is visible, and the\n   575\t/// run must end in failed state.\n   576\t#[tokio::test]\n   577\tasync fn journal_failure_after_payload_rolls_back_and_fails_run() {\n   578\t    let tmp = tempdir().unwrap();\n   579\t    let base_dir = tmp.path();\n   580\t\n   581\t    setup_workspace(base_dir);\n   582\t    let pid = create_standard_project(base_dir, \"journal-fail\");\n   583\t\n   584\t    let agent_service = build_agent_service();\n   585\t    let config = EffectiveConfig::load(base_dir).unwrap();\n   586\t\n   587\t    // The engine calls append_event for:\n   588\t    //   1: run_started\n   589\t    //   2: stage_entered (stage 1)\n   590\t    //   3: stage_completed (stage 1) — fail here\n   591\t    let failing_journal = FailingJournalStore::new(3);\n   592\t\n   593\t    let result = engine::execute_standard_run(\n   594\t        &agent_service,\n   595\t        &FsRunSnapshotStore,\n   596\t        &FsRunSnapshotWriteStore,\n   597\t        &failing_journal,\n   598\t        &FsPayloadArtifactWriteStore,\n   599\t        &FsRuntimeLogWriteStore,\n   600\t        base_dir,\n   601\t        &pid,\n   602\t        &config,\n   603\t    )\n   604\t    .await;\n   605\t\n   606\t    assert!(result.is_err(), \"run should fail on journal failure\");\n   607\t\n   608\t    // Run must be in failed state\n   609\t    let snapshot = FsRunSnapshotStore.read_run_snapshot(base_dir, &pid).unwrap();\n   610\t    assert_eq!(snapshot.status, RunStatus::Failed);\n   611\t    assert!(snapshot.active_run.is_none());\n   612\t\n   613\t    // No payload/artifact should be visible for the first stage since it was\n   614\t    // rolled back after journal failure\n   615\t    let payloads_dir = base_dir\n   616\t        .join(\".ralph-burning/projects/journal-fail/history/payloads\");\n   617\t    let payload_count = fs::read_dir(&payloads_dir).unwrap().count();\n   618\t    assert_eq!(payload_count, 0, \"payload should have been rolled back\");\n   619\t\n   620\t    let artifacts_dir = base_dir\n   621\t        .join(\".ralph-burning/projects/journal-fail/history/artifacts\");\n   622\t    let artifact_count = fs::read_dir(&artifacts_dir).unwrap().count();\n   623\t    assert_eq!(artifact_count, 0, \"artifact should have been rolled back\");\n   624\t\n   625\t    // No stage_completed event should exist since journal append failed\n   626\t    let events = FsJournalStore.read_journal(base_dir, &pid).unwrap();\n   627\t    let stage_completed_events: Vec<_> = events\n   628\t        .iter()\n   629\t        .filter(|e| e.event_type == JournalEventType::StageCompleted)\n   630\t        .collect();\n   631\t    assert!(\n   632\t        stage_completed_events.is_empty(),\n   633\t        \"no stage_completed event should exist after journal failure, found {}\",\n   634\t        stage_completed_events.len()\n   635\t    );\n   636\t}\n   637\t\n   638\t/// Snapshot write failure during stage commit must roll back the\n   639\t/// payload/artifact pair, leave no stage_completed journal event, and mark\n   640\t/// the run as failed. Because the engine writes the snapshot BEFORE\n   641\t/// stage_completed, a snapshot failure means stage_completed is never appended.\n   642\t#[tokio::test]\n   643\tasync fn snapshot_failure_during_stage_commit_rolls_back_without_journal_leak() {\n   644\t    let tmp = tempdir().unwrap();\n   645\t    let base_dir = tmp.path();\n   646\t\n   647\t    setup_workspace(base_dir);\n   648\t    let pid = create_standard_project(base_dir, \"snap-fail\");\n   649\t\n   650\t    let agent_service = build_agent_service();\n   651\t    let config = EffectiveConfig::load(base_dir).unwrap();\n   652\t\n   653\t    // The engine calls write_run_snapshot for:\n   654\t    //   1: initial Running snapshot (run start)\n   655\t    //   2: stage_entered cursor update (stage 1)\n   656\t    //   3: stage commit cursor update (stage 1) — fail here\n   657\t    let failing_snapshot = FailingSnapshotWriteStore::new(3);\n   658\t\n   659\t    let result = engine::execute_standard_run(\n   660\t        &agent_service,\n   661\t        &FsRunSnapshotStore,\n   662\t        &failing_snapshot,\n   663\t        &FsJournalStore,\n   664\t        &FsPayloadArtifactWriteStore,\n   665\t        &FsRuntimeLogWriteStore,\n   666\t        base_dir,\n   667\t        &pid,\n   668\t        &config,\n   669\t    )\n   670\t    .await;\n   671\t\n   672\t    assert!(result.is_err(), \"run should fail on snapshot failure\");\n   673\t\n   674\t    // The run must end in failed state. Since the failing store only fails\n   675\t    // on call 3, the fail_run recovery can still write the failed snapshot\n   676\t    // (calls 4+).\n   677\t    let snapshot = FsRunSnapshotStore.read_run_snapshot(base_dir, &pid).unwrap();\n   678\t    assert_eq!(snapshot.status, RunStatus::Failed);\n   679\t    assert!(snapshot.active_run.is_none());\n   680\t\n   681\t    // No payload/artifact should be visible for the first stage\n   682\t    let payloads_dir = base_dir\n   683\t        .join(\".ralph-burning/projects/snap-fail/history/payloads\");\n   684\t    let payload_count = fs::read_dir(&payloads_dir).unwrap().count();\n   685\t    assert_eq!(payload_count, 0, \"payload should have been rolled back\");\n   686\t\n   687\t    let artifacts_dir = base_dir\n   688\t        .join(\".ralph-burning/projects/snap-fail/history/artifacts\");\n   689\t    let artifact_count = fs::read_dir(&artifacts_dir).unwrap().count();\n   690\t    assert_eq!(artifact_count, 0, \"artifact should have been rolled back\");\n   691\t\n   692\t    // CRITICAL: No stage_completed event must exist in the journal.\n   693\t    // Because the engine writes snapshot before stage_completed, snapshot\n   694\t    // failure prevents the journal event from ever being appended.\n   695\t    let events = FsJournalStore.read_journal(base_dir, &pid).unwrap();\n   696\t    let stage_completed_events: Vec<_> = events\n   697\t        .iter()\n   698\t        .filter(|e| e.event_type == JournalEventType::StageCompleted)\n   699\t        .collect();\n   700\t    assert!(\n   701\t        stage_completed_events.is_empty(),\n   702\t        \"no stage_completed event should exist after snapshot failure, found {}\",\n   703\t        stage_completed_events.len()\n   704\t    );\n   705\t}\n","exit_code":0,"status":"completed"}}
