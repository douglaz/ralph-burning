tc::now();\n   302\t        let payload_id = format!(\n   303\t            \"{}-{}-c{}-a{}\",\n   304\t            run_id.as_str(),\n   305\t            stage_id.as_str(),\n   306\t            cursor.cycle,\n   307\t            cursor.attempt\n   308\t        );\n   309\t        let artifact_id = format!(\"{}-artifact\", payload_id);\n   310\t\n   311\t        let payload_record = PayloadRecord {\n   312\t            payload_id: payload_id.clone(),\n   313\t            stage_id,\n   314\t            cycle: cursor.cycle,\n   315\t            attempt: cursor.attempt,\n   316\t            created_at: stage_now,\n   317\t            payload: serde_json::to_value(&bundle.payload)?,\n   318\t        };\n   319\t        let artifact_record = ArtifactRecord {\n   320\t            artifact_id: artifact_id.clone(),\n   321\t            payload_id: payload_id.clone(),\n   322\t            stage_id,\n   323\t            created_at: stage_now,\n   324\t            content: bundle.artifact.clone(),\n   325\t        };\n   326\t\n   327\t        // Atomic stage commit: payload + artifact + snapshot + journal.\n   328\t        // All four must succeed for the stage to become durably visible.\n   329\t        // Order: payload/artifact → snapshot cursor → stage_completed journal.\n   330\t        // This ensures that if any step fails, no stage_completed event leaks\n   331\t        // into the journal without a matching snapshot and durable files.\n   332\t\n   333\t        // Step 1: Write payload + artifact pair.\n   334\t        // If this fails, the stage is not committed — nothing else to roll back.\n   335\t        artifact_write\n   336\t            .write_payload_artifact_pair(base_dir, project_id, &payload_record, &artifact_record)\n   337\t            .map_err(|e| AppError::StageCommitFailed {\n   338\t                stage_id,\n   339\t                details: format!(\"payload/artifact persistence failed: {}\", e),\n   340\t            })?;\n   341\t\n   342\t        // Step 2: Update snapshot cursor to reflect completed stage.\n   343\t        // Written BEFORE stage_completed journal so that snapshot failure\n   344\t        // never leaves a stage_completed event without a matching cursor.\n   345\t        let pre_commit_snapshot = current_snapshot.clone();\n   346\t        if idx + 1 < stage_plan.len() {\n   347\t            let next_stage = stage_plan[idx + 1].stage_id;\n   348\t            current_snapshot.active_run.as_mut().unwrap().stage_cursor =\n   349\t                StageCursor::initial(next_stage);\n   350\t            current_snapshot.status_summary = format!(\n   351\t                \"running: completed {}, next {}\",\n   352\t                stage_id.display_name(),\n   353\t                next_stage.display_name()\n   354\t            );\n   355\t        }\n   356\t        if let Err(e) = run_snapshot_write.write_run_snapshot(base_dir, project_id, &current_snapshot) {\n   357\t            // Roll back payload/artifact; no stage_completed was written yet.\n   358\t            let _ =\n   359\t                artifact_write.remove_payload_artifact_pair(base_dir, project_id, &payload_id, &artifact_id);\n   360\t            current_snapshot = pre_commit_snapshot;\n   361\t            let commit_err = AppError::StageCommitFailed {\n   362\t                stage_id,\n   363\t                details: format!(\"snapshot write failed during stage commit: {}\", e),\n   364\t            };\n   365\t            return fail_run(\n   366\t                &commit_err,\n   367\t                stage_id,\n   368\t                &run_id,\n   369\t                &mut seq,\n   370\t                &mut current_snapshot,\n   371\t                journal_store,\n   372\t                run_snapshot_write,\n   373\t                base_dir,\n   374\t                project_id,\n   375\t            )\n   376\t            .await;\n   377\t        }\n   378\t\n   379\t        // Step 3: Append stage_completed journal event.\n   380\t        // If this fails, roll back payload/artifact and overwrite snapshot\n   381\t        // via fail_run so the stage remains uncommitted.\n   382\t        seq += 1;\n   383\t        let stage_completed = journal::stage_completed_event(\n   384\t            seq,\n   385\t            Utc::now(),\n   386\t            &run_id,\n   387\t            stage_id,\n   388\t            cursor.cycle,\n   389\t            cursor.attempt,\n   390\t            &payload_id,\n   391\t            &artifact_id,\n   392\t        );\n   393\t        let stage_completed_line = journal::serialize_event(&stage_completed)?;\n   394\t        if let Err(e) = journal_store.append_event(base_dir, project_id, &stage_completed_line) {\n   395\t            // Roll back payload/artifact so no partial durable history is visible\n   396\t            let _ =\n   397\t                artifact_write.remove_payload_artifact_pair(base_dir, project_id, &payload_id, &artifact_id);\n   398\t            seq -= 1; // undo the seq increment since the event was not persisted\n   399\t            let commit_err = AppError::StageCommitFailed {\n   400\t                stage_id,\n   401\t                details: format!(\"journal append failed during stage commit: {}\", e),\n   402\t            };\n   403\t            return fail_run(\n   404\t                &commit_err,\n   405\t                stage_id,\n   406\t                &run_id,\n   407\t                &mut seq,\n   408\t                &mut current_snapshot,\n   409\t                journal_store,\n   410\t                run_snapshot_write,\n   411\t                base_dir,\n   412\t                project_id,\n   413\t            )\n   414\t            .await;\n   415\t        }\n   416\t\n   417\t        // Best-effort runtime log\n   418\t        let _ = log_write.append_runtime_log(\n   419\t            base_dir,\n   420\t            project_id,\n   421\t            &RuntimeLogEntry {\n   422\t                timestamp: Utc::now(),\n   423\t                level: LogLevel::Info,\n   424\t                source: \"engine\".to_owned(),\n   425\t                message: format!(\"stage_completed: {}\", stage_id.as_str()),\n   426\t            },\n   427\t        );\n   428\t    }\n   429\t\n   430\t    // 8. All stages completed — mark run as completed\n   431\t    seq += 1;\n   432\t    let run_completed = journal::run_completed_event(seq, Utc::now(), &run_id, 1);\n   433\t    let run_completed_line = journal::serialize_event(&run_completed)?;\n   434\t    journal_store.append_event(base_dir, project_id, &run_completed_line)?;\n   435\t\n   436\t    current_snapshot.status = RunStatus::Completed;\n   437\t    current_snapshot.active_run = None;\n   438\t    current_snapshot.completion_rounds = 1;\n   439\t    current_snapshot.status_summary = \"completed\".to_owned();\n   440\t    run_snapshot_write.write_run_snapshot(base_dir, project_id, &current_snapshot)?;\n   441\t\n   442\t    Ok(())\n   443\t}\n   444\t\n   445\t/// Record a run failure: persist journal event, update snapshot, return error.\n   446\t#[allow(clippy::too_many_arguments)]\n   447\tasync fn fail_run(\n   448\t    err: &AppError,\n   449\t    stage_id: StageId,\n   450\t    run_id: &RunId,\n   451\t    seq: &mut u64,\n   452\t    snapshot: &mut RunSnapshot,\n   453\t    journal_store: &dyn JournalStorePort,\n   454\t    run_snapshot_write: &dyn RunSnapshotWritePort,\n   455\t    base_dir: &Path,\n   456\t    project_id: &ProjectId,\n   457\t) -> AppResult<()> {\n   458\t    let failure_class = err\n   459\t        .failure_class()\n   460\t        .map(|fc| format!(\"{:?}\", fc))\n   461\t        .unwrap_or_else(|| \"unknown\".to_owned());\n   462\t    let message = err.to_string();\n   463\t\n   464\t    *seq += 1;\n   465\t    let run_failed =\n   466\t        journal::run_failed_event(*seq, Utc::now(), run_id, stage_id, &failure_class, &message);\n   467\t    let run_failed_line = journal::serialize_event(&run_failed)?;\n   468\t    journal_store.append_event(base_dir, project_id, &run_failed_line)?;\n   469\t\n   470\t    snapshot.status = RunStatus::Failed;\n   471\t    snapshot.active_run = None;\n   472\t    snapshot.status_summary = format!(\"failed at {}: {}\", stage_id.display_name(), message);\n   473\t    run_snapshot_write.write_run_snapshot(base_dir, project_id, snapshot)?;\n   474\t\n   475\t    Err(AppError::RunStartFailed {\n   476\t        reason: format!(\"stage {} failed: {}\", stage_id.as_str(), message),\n   477\t    })\n   478\t}\n   479\t\n   480\t/// Helper to get project root path.\n   481\tfn project_root_path(base_dir: &Path, project_id: &ProjectId) -> PathBuf {\n   482\t    base_dir\n   483\t        .join(\".ralph-burning\")\n   484\t        .join(\"projects\")\n   485\t        .join(project_id.as_str())\n   486\t}\n","exit_code":0,"status":"completed"}}
