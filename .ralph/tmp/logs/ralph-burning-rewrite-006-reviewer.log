{"type":"item.completed","item":{"id":"item_12","type":"command_execution","command":"/run/current-system/sw/bin/bash -lc \"nl -ba /root/new-ralph-burning/ralph-burning-rewrite/src/adapters/fs.rs | sed -n '1,420p'\"","aggregated_output":"     1\tuse std::env;\n     2\tuse std::fs::{self, OpenOptions};\n     3\tuse std::io::Write;\n     4\tuse std::path::{Path, PathBuf};\n     5\tuse std::process::Command;\n     6\tuse std::time::{SystemTime, UNIX_EPOCH};\n     7\t\n     8\tuse crate::contexts::agent_execution::model::RawOutputReference;\n     9\tuse crate::contexts::agent_execution::service::RawOutputPort;\n    10\tuse crate::contexts::agent_execution::session::{PersistedSessions, SessionStorePort};\n    11\tuse crate::contexts::project_run_record::journal;\n    12\tuse crate::contexts::project_run_record::model::{\n    13\t    ArtifactRecord, JournalEvent, PayloadRecord, ProjectRecord, RunSnapshot, RuntimeLogEntry,\n    14\t    SessionStore,\n    15\t};\n    16\tuse crate::contexts::project_run_record::service::{\n    17\t    ActiveProjectPort, ArtifactStorePort, JournalStorePort, PayloadArtifactWritePort,\n    18\t    ProjectStorePort, RunSnapshotPort, RunSnapshotWritePort, RuntimeLogStorePort,\n    19\t    RuntimeLogWritePort,\n    20\t};\n    21\tuse crate::shared::domain::{ProjectId, WorkspaceConfig};\n    22\tuse crate::shared::error::{AppError, AppResult};\n    23\t\n    24\tconst ACTIVE_PROJECT_FILE: &str = \"active-project\";\n    25\tconst WORKSPACE_DIR: &str = \".ralph-burning\";\n    26\tconst PROJECTS_DIR: &str = \"projects\";\n    27\tconst PROJECT_CONFIG_FILE: &str = \"project.toml\";\n    28\tconst RUN_FILE: &str = \"run.json\";\n    29\tconst JOURNAL_FILE: &str = \"journal.ndjson\";\n    30\tconst SESSIONS_FILE: &str = \"sessions.json\";\n    31\tconst PROMPT_FILE: &str = \"prompt.md\";\n    32\t\n    33\t/// Required subdirectories inside a project.\n    34\tconst PROJECT_SUBDIRS: &[&str] = &[\n    35\t    \"history/payloads\",\n    36\t    \"history/artifacts\",\n    37\t    \"runtime/logs\",\n    38\t    \"runtime/backend\",\n    39\t    \"runtime/temp\",\n    40\t    \"amendments\",\n    41\t    \"rollback\",\n    42\t];\n    43\t\n    44\tpub struct FileSystem;\n    45\t\n    46\timpl FileSystem {\n    47\t    pub fn create_workspace(\n    48\t        workspace_root: &Path,\n    49\t        workspace_config: &str,\n    50\t        required_directories: &[&str],\n    51\t    ) -> AppResult<()> {\n    52\t        fs::create_dir_all(workspace_root)?;\n    53\t\n    54\t        for directory in required_directories {\n    55\t            fs::create_dir_all(workspace_root.join(directory))?;\n    56\t        }\n    57\t\n    58\t        Self::write_atomic(&workspace_root.join(\"workspace.toml\"), workspace_config)?;\n    59\t        Ok(())\n    60\t    }\n    61\t\n    62\t    pub fn read_to_string(path: &Path) -> AppResult<String> {\n    63\t        Ok(fs::read_to_string(path)?)\n    64\t    }\n    65\t\n    66\t    pub fn write_atomic(path: &Path, contents: &str) -> AppResult<()> {\n    67\t        let parent = path.parent().ok_or_else(|| {\n    68\t            AppError::Io(std::io::Error::new(\n    69\t                std::io::ErrorKind::InvalidInput,\n    70\t                format!(\"path '{}' has no parent directory\", path.display()),\n    71\t            ))\n    72\t        })?;\n    73\t        fs::create_dir_all(parent)?;\n    74\t\n    75\t        let timestamp = SystemTime::now()\n    76\t            .duration_since(UNIX_EPOCH)\n    77\t            .map(|duration| duration.as_nanos())\n    78\t            .unwrap_or_default();\n    79\t        let temp_path = parent.join(format!(\n    80\t            \".{}.{}.{}.tmp\",\n    81\t            path.file_name()\n    82\t                .and_then(|value| value.to_str())\n    83\t                .unwrap_or(\"workspace\"),\n    84\t            std::process::id(),\n    85\t            timestamp\n    86\t        ));\n    87\t\n    88\t        let mut file = OpenOptions::new()\n    89\t            .create_new(true)\n    90\t            .write(true)\n    91\t            .open(&temp_path)?;\n    92\t        file.write_all(contents.as_bytes())?;\n    93\t        file.sync_all()?;\n    94\t        drop(file);\n    95\t\n    96\t        if let Err(error) = fs::rename(&temp_path, path) {\n    97\t            let _ = fs::remove_file(&temp_path);\n    98\t            return Err(error.into());\n    99\t        }\n   100\t\n   101\t        Ok(())\n   102\t    }\n   103\t\n   104\t    pub fn render_workspace_config(config: &WorkspaceConfig) -> AppResult<String> {\n   105\t        Ok(toml::to_string_pretty(config)?)\n   106\t    }\n   107\t\n   108\t    pub fn read_active_project(workspace_root: &Path) -> AppResult<Option<String>> {\n   109\t        let path = workspace_root.join(ACTIVE_PROJECT_FILE);\n   110\t        match fs::read_to_string(path) {\n   111\t            Ok(raw) => {\n   112\t                let trimmed = raw.trim();\n   113\t                if trimmed.is_empty() {\n   114\t                    Ok(None)\n   115\t                } else {\n   116\t                    Ok(Some(trimmed.to_owned()))\n   117\t                }\n   118\t            }\n   119\t            Err(error) if error.kind() == std::io::ErrorKind::NotFound => Ok(None),\n   120\t            Err(error) => Err(error.into()),\n   121\t        }\n   122\t    }\n   123\t\n   124\t    pub fn write_active_project(workspace_root: &Path, project_id: &str) -> AppResult<()> {\n   125\t        Self::write_atomic(&workspace_root.join(ACTIVE_PROJECT_FILE), project_id)\n   126\t    }\n   127\t\n   128\t    pub fn open_editor(path: &Path) -> AppResult<()> {\n   129\t        let editor = env::var(\"EDITOR\")\n   130\t            .ok()\n   131\t            .filter(|value| !value.trim().is_empty())\n   132\t            .or_else(|| {\n   133\t                env::var(\"VISUAL\")\n   134\t                    .ok()\n   135\t                    .filter(|value| !value.trim().is_empty())\n   136\t            })\n   137\t            .unwrap_or_else(|| \"vi\".to_owned());\n   138\t\n   139\t        let mut parts = editor.split_whitespace();\n   140\t        let program = parts.next().ok_or_else(|| AppError::EditorFailed {\n   141\t            editor: editor.clone(),\n   142\t            details: \": empty editor command\".to_owned(),\n   143\t        })?;\n   144\t        let status = Command::new(program).args(parts).arg(path).status()?;\n   145\t\n   146\t        if status.success() {\n   147\t            Ok(())\n   148\t        } else {\n   149\t            let details = match status.code() {\n   150\t                Some(code) => format!(\" with exit code {code}\"),\n   151\t                None => \" after being terminated by a signal\".to_owned(),\n   152\t            };\n   153\t            Err(AppError::EditorFailed { editor, details })\n   154\t        }\n   155\t    }\n   156\t\n   157\t    /// Compute a simple hash of content for prompt integrity tracking.\n   158\t    pub fn prompt_hash(contents: &str) -> String {\n   159\t        use std::collections::hash_map::DefaultHasher;\n   160\t        use std::hash::{Hash, Hasher};\n   161\t        let mut hasher = DefaultHasher::new();\n   162\t        contents.hash(&mut hasher);\n   163\t        format!(\"{:016x}\", hasher.finish())\n   164\t    }\n   165\t\n   166\t    // ── Helpers for project filesystem layout ──\n   167\t\n   168\t    fn workspace_root_path(base_dir: &Path) -> PathBuf {\n   169\t        base_dir.join(WORKSPACE_DIR)\n   170\t    }\n   171\t\n   172\t    fn project_root(base_dir: &Path, project_id: &ProjectId) -> PathBuf {\n   173\t        Self::workspace_root_path(base_dir)\n   174\t            .join(PROJECTS_DIR)\n   175\t            .join(project_id.as_str())\n   176\t    }\n   177\t\n   178\t    fn pending_delete_path(base_dir: &Path, project_id: &ProjectId) -> PathBuf {\n   179\t        Self::workspace_root_path(base_dir)\n   180\t            .join(PROJECTS_DIR)\n   181\t            .join(format!(\".{}.pending-delete\", project_id))\n   182\t    }\n   183\t\n   184\t    fn append_line(path: &Path, line: &str) -> AppResult<()> {\n   185\t        let parent = path.parent().ok_or_else(|| {\n   186\t            AppError::Io(std::io::Error::new(\n   187\t                std::io::ErrorKind::InvalidInput,\n   188\t                format!(\"path '{}' has no parent directory\", path.display()),\n   189\t            ))\n   190\t        })?;\n   191\t        fs::create_dir_all(parent)?;\n   192\t\n   193\t        let mut file = OpenOptions::new().create(true).append(true).open(path)?;\n   194\t        writeln!(file, \"{}\", line)?;\n   195\t        file.sync_all()?;\n   196\t        Ok(())\n   197\t    }\n   198\t}\n   199\t\n   200\t/// Filesystem-backed implementation of `ProjectStorePort`.\n   201\tpub struct FsProjectStore;\n   202\t\n   203\timpl ProjectStorePort for FsProjectStore {\n   204\t    fn project_exists(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<bool> {\n   205\t        let project_root = FileSystem::project_root(base_dir, project_id);\n   206\t        if !project_root.is_dir() {\n   207\t            return Ok(false);\n   208\t        }\n   209\t        if !project_root.join(PROJECT_CONFIG_FILE).is_file() {\n   210\t            return Err(AppError::CorruptRecord {\n   211\t                file: format!(\"projects/{}/project.toml\", project_id),\n   212\t                details: \"project directory exists but canonical project.toml is missing\"\n   213\t                    .to_owned(),\n   214\t            });\n   215\t        }\n   216\t        Ok(true)\n   217\t    }\n   218\t\n   219\t    fn read_project_record(\n   220\t        &self,\n   221\t        base_dir: &Path,\n   222\t        project_id: &ProjectId,\n   223\t    ) -> AppResult<ProjectRecord> {\n   224\t        let project_root = FileSystem::project_root(base_dir, project_id);\n   225\t        let path = project_root.join(PROJECT_CONFIG_FILE);\n   226\t        let raw = fs::read_to_string(&path).map_err(|e| {\n   227\t            if e.kind() == std::io::ErrorKind::NotFound {\n   228\t                if project_root.is_dir() {\n   229\t                    // Directory exists but project.toml is missing — corruption\n   230\t                    AppError::CorruptRecord {\n   231\t                        file: format!(\"projects/{}/project.toml\", project_id),\n   232\t                        details: \"project directory exists but canonical project.toml is missing\"\n   233\t                            .to_owned(),\n   234\t                    }\n   235\t                } else {\n   236\t                    AppError::ProjectNotFound {\n   237\t                        project_id: project_id.to_string(),\n   238\t                    }\n   239\t                }\n   240\t            } else {\n   241\t                e.into()\n   242\t            }\n   243\t        })?;\n   244\t        toml::from_str(&raw).map_err(|e| AppError::CorruptRecord {\n   245\t            file: format!(\"projects/{}/project.toml\", project_id),\n   246\t            details: e.to_string(),\n   247\t        })\n   248\t    }\n   249\t\n   250\t    fn list_project_ids(&self, base_dir: &Path) -> AppResult<Vec<ProjectId>> {\n   251\t        let projects_dir = FileSystem::workspace_root_path(base_dir).join(PROJECTS_DIR);\n   252\t        if !projects_dir.is_dir() {\n   253\t            return Ok(Vec::new());\n   254\t        }\n   255\t\n   256\t        let mut ids = Vec::new();\n   257\t        for entry in fs::read_dir(&projects_dir)? {\n   258\t            let entry = entry?;\n   259\t            if !entry.file_type()?.is_dir() {\n   260\t                continue;\n   261\t            }\n   262\t            let name = entry.file_name();\n   263\t            let name_str = name.to_string_lossy();\n   264\t            // Skip hidden directories (staging/trash from transactional operations)\n   265\t            if name_str.starts_with('.') {\n   266\t                continue;\n   267\t            }\n   268\t            if let Ok(pid) = ProjectId::new(name_str.as_ref()) {\n   269\t                if !entry.path().join(PROJECT_CONFIG_FILE).is_file() {\n   270\t                    return Err(AppError::CorruptRecord {\n   271\t                        file: format!(\"projects/{}/project.toml\", name_str),\n   272\t                        details: \"project directory exists but canonical project.toml is missing\"\n   273\t                            .to_owned(),\n   274\t                    });\n   275\t                }\n   276\t                ids.push(pid);\n   277\t            }\n   278\t        }\n   279\t\n   280\t        ids.sort_by(|a, b| a.as_str().cmp(b.as_str()));\n   281\t        Ok(ids)\n   282\t    }\n   283\t\n   284\t    fn stage_delete(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<()> {\n   285\t        let project_root = FileSystem::project_root(base_dir, project_id);\n   286\t        if !project_root.is_dir() {\n   287\t            return Err(AppError::ProjectNotFound {\n   288\t                project_id: project_id.to_string(),\n   289\t            });\n   290\t        }\n   291\t\n   292\t        let pending_path = FileSystem::pending_delete_path(base_dir, project_id);\n   293\t\n   294\t        // Clean up any leftover pending-delete from a previous crash\n   295\t        if pending_path.exists() {\n   296\t            fs::remove_dir_all(&pending_path)?;\n   297\t        }\n   298\t\n   299\t        // Atomic rename to pending-delete location — project becomes\n   300\t        // invisible to list/show but data stays on disk.\n   301\t        fs::rename(&project_root, &pending_path)?;\n   302\t        Ok(())\n   303\t    }\n   304\t\n   305\t    fn commit_delete(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<()> {\n   306\t        let pending_path = FileSystem::pending_delete_path(base_dir, project_id);\n   307\t        if pending_path.is_dir() {\n   308\t            fs::remove_dir_all(&pending_path)?;\n   309\t        }\n   310\t        Ok(())\n   311\t    }\n   312\t\n   313\t    fn rollback_delete(&self, base_dir: &Path, project_id: &ProjectId) -> AppResult<()> {\n   314\t        let project_root = FileSystem::project_root(base_dir, project_id);\n   315\t        let pending_path = FileSystem::pending_delete_path(base_dir, project_id);\n   316\t\n   317\t        if !pending_path.is_dir() {\n   318\t            return Ok(());\n   319\t        }\n   320\t\n   321\t        fs::rename(&pending_path, &project_root)?;\n   322\t        Ok(())\n   323\t    }\n   324\t\n   325\t    fn create_project_atomic(\n   326\t        &self,\n   327\t        base_dir: &Path,\n   328\t        record: &ProjectRecord,\n   329\t        prompt_contents: &str,\n   330\t        run_snapshot: &RunSnapshot,\n   331\t        initial_journal_line: &str,\n   332\t        sessions: &SessionStore,\n   333\t    ) -> AppResult<()> {\n   334\t        let project_root = FileSystem::project_root(base_dir, &record.id);\n   335\t\n   336\t        // Stage into a temporary directory alongside the final location\n   337\t        let staging_name = format!(\".{}.staging.{}\", record.id, std::process::id());\n   338\t        let staging_root = project_root\n   339\t            .parent()\n   340\t            .expect(\"project root has parent\")\n   341\t            .join(&staging_name);\n   342\t\n   343\t        // Clean up any leftover staging dir\n   344\t        if staging_root.exists() {\n   345\t            fs::remove_dir_all(&staging_root)?;\n   346\t        }\n   347\t\n   348\t        // Create staging directory and all subdirs\n   349\t        fs::create_dir_all(&staging_root)?;\n   350\t        for subdir in PROJECT_SUBDIRS {\n   351\t            fs::create_dir_all(staging_root.join(subdir))?;\n   352\t        }\n   353\t\n   354\t        // Write all canonical files into staging\n   355\t        let write_result = (|| -> AppResult<()> {\n   356\t            // project.toml\n   357\t            let project_toml = toml::to_string_pretty(record)\n   358\t                .map_err(|e| AppError::Io(std::io::Error::other(e.to_string())))?;\n   359\t            fs::write(staging_root.join(PROJECT_CONFIG_FILE), project_toml)?;\n   360\t\n   361\t            // prompt.md\n   362\t            fs::write(staging_root.join(PROMPT_FILE), prompt_contents)?;\n   363\t\n   364\t            // run.json\n   365\t            let run_json = serde_json::to_string_pretty(run_snapshot)?;\n   366\t            fs::write(staging_root.join(RUN_FILE), run_json)?;\n   367\t\n   368\t            // journal.ndjson (with initial event)\n   369\t            let mut journal_content = initial_journal_line.to_owned();\n   370\t            journal_content.push('\\n');\n   371\t            fs::write(staging_root.join(JOURNAL_FILE), journal_content)?;\n   372\t\n   373\t            // sessions.json\n   374\t            let sessions_json = serde_json::to_string_pretty(sessions)?;\n   375\t            fs::write(staging_root.join(SESSIONS_FILE), sessions_json)?;\n   376\t\n   377\t            Ok(())\n   378\t        })();\n   379\t\n   380\t        if let Err(e) = write_result {\n   381\t            // Clean up staging on failure\n   382\t            let _ = fs::remove_dir_all(&staging_root);\n   383\t            return Err(e);\n   384\t        }\n   385\t\n   386\t        // Atomic rename from staging to final location\n   387\t        if let Err(e) = fs::rename(&staging_root, &project_root) {\n   388\t            let _ = fs::remove_dir_all(&staging_root);\n   389\t            return Err(e.into());\n   390\t        }\n   391\t\n   392\t        Ok(())\n   393\t    }\n   394\t}\n   395\t\n   396\t/// Filesystem-backed implementation of `JournalStorePort`.\n   397\tpub struct FsJournalStore;\n   398\t\n   399\timpl JournalStorePort for FsJournalStore {\n   400\t    fn read_journal(\n   401\t        &self,\n   402\t        base_dir: &Path,\n   403\t        project_id: &ProjectId,\n   404\t    ) -> AppResult<Vec<JournalEvent>> {\n   405\t        let path = FileSystem::project_root(base_dir, project_id).join(JOURNAL_FILE);\n   406\t        match fs::read_to_string(&path) {\n   407\t            Ok(contents) => journal::parse_journal(&contents),\n   408\t            Err(e) if e.kind() == std::io::ErrorKind::NotFound => Err(AppError::CorruptRecord {\n   409\t                file: format!(\"projects/{}/journal.ndjson\", project_id),\n   410\t                details: \"canonical file is missing\".to_owned(),\n   411\t            }),\n   412\t            Err(e) => Err(e.into()),\n   413\t        }\n   414\t    }\n   415\t\n   416\t    fn append_event(&self, base_dir: &Path, project_id: &ProjectId, line: &str) -> AppResult<()> {\n   417\t        let path = FileSystem::project_root(base_dir, project_id).join(JOURNAL_FILE);\n   418\t        FileSystem::append_line(&path, line)\n   419\t    }\n   420\t}\n","exit_code":0,"status":"completed"}}
