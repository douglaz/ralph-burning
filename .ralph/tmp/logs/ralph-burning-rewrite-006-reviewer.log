ndle_tail(logs).await,\n    46\t        RunSubcommand::Start => handle_start().await,\n    47\t        RunSubcommand::Resume => Err(AppError::NotYetImplemented {\n    48\t            command: \"run resume\".to_owned(),\n    49\t        }),\n    50\t        RunSubcommand::Rollback { .. } => Err(AppError::NotYetImplemented {\n    51\t            command: \"run rollback\".to_owned(),\n    52\t        }),\n    53\t    }\n    54\t}\n    55\t\n    56\tpub fn build_agent_execution_service(\n    57\t) -> AgentExecutionService<StubBackendAdapter, FsRawOutputStore, FsSessionStore> {\n    58\t    AgentExecutionService::new(\n    59\t        StubBackendAdapter::default(),\n    60\t        FsRawOutputStore,\n    61\t        FsSessionStore,\n    62\t    )\n    63\t}\n    64\t\n    65\tasync fn handle_start() -> AppResult<()> {\n    66\t    let current_dir = std::env::current_dir()?;\n    67\t\n    68\t    // Validate workspace version\n    69\t    let config = workspace_governance::load_workspace_config(&current_dir)?;\n    70\t    workspace_governance::ensure_supported_workspace_version(&config)?;\n    71\t\n    72\t    // Resolve active project\n    73\t    let project_id = workspace_governance::resolve_active_project(&current_dir)?;\n    74\t\n    75\t    // Validate canonical project record\n    76\t    let project_store = FsProjectStore;\n    77\t    let project_record = project_store.read_project_record(&current_dir, &project_id)?;\n    78\t\n    79\t    // Only standard flow is supported in this slice\n    80\t    if project_record.flow != FlowPreset::Standard {\n    81\t        return Err(AppError::UnsupportedFlow {\n    82\t            flow_id: project_record.flow.as_str().to_owned(),\n    83\t        });\n    84\t    }\n    85\t\n    86\t    // Validate run snapshot integrity\n    87\t    let run_snapshot_read = FsRunSnapshotStore;\n    88\t    let run_snapshot = run_snapshot_read.read_run_snapshot(&current_dir, &project_id)?;\n    89\t\n    90\t    // Check preconditions before engine call (fail fast with clear errors)\n    91\t    if run_snapshot.status != crate::contexts::project_run_record::model::RunStatus::NotStarted {\n    92\t        return Err(AppError::RunStartFailed {\n    93\t            reason: format!(\n    94\t                \"project snapshot status is '{}'; run start requires 'not_started'\",\n    95\t                run_snapshot.status\n    96\t            ),\n    97\t        });\n    98\t    }\n    99\t    if run_snapshot.has_active_run() {\n   100\t        return Err(AppError::RunStartFailed {\n   101\t            reason: \"project already has an active run\".to_owned(),\n   102\t        });\n   103\t    }\n   104\t\n   105\t    let effective_config = EffectiveConfig::load(&current_dir)?;\n   106\t\n   107\t    let agent_service = build_agent_execution_service();\n   108\t    let run_snapshot_write = FsRunSnapshotWriteStore;\n   109\t    let journal_store = FsJournalStore;\n   110\t    let artifact_write = FsPayloadArtifactWriteStore;\n   111\t    let log_write = FsRuntimeLogWriteStore;\n   112\t\n   113\t    println!(\"Starting run for project '{}'...\", project_id);\n   114\t\n   115\t    engine::execute_standard_run(\n   116\t        &agent_service,\n   117\t        &run_snapshot_read,\n   118\t        &run_snapshot_write,\n   119\t        &journal_store,\n   120\t        &artifact_write,\n   121\t        &log_write,\n   122\t        &current_dir,\n   123\t        &project_id,\n   124\t        &effective_config,\n   125\t    )\n   126\t    .await?;\n   127\t\n   128\t    println!(\"Run completed successfully.\");\n   129\t    Ok(())\n   130\t}\n   131\t\n   132\tasync fn handle_status() -> AppResult<()> {\n   133\t    let current_dir = std::env::current_dir()?;\n   134\t\n   135\t    let config = workspace_governance::load_workspace_config(&current_dir)?;\n   136\t    workspace_governance::ensure_supported_workspace_version(&config)?;\n   137\t\n   138\t    let project_id = workspace_governance::resolve_active_project(&current_dir)?;\n   139\t\n   140\t    // Validate canonical project record before proceeding with run queries\n   141\t    let project_store = FsProjectStore;\n   142\t    let _ = project_store.read_project_record(&current_dir, &project_id)?;\n   143\t\n   144\t    let run_store = FsRunSnapshotStore;\n   145\t    let status = service::run_status(&run_store, &current_dir, &project_id)?;\n   146\t\n   147\t    println!(\"Project: {}\", status.project_id);\n   148\t    println!(\"Status: {}\", status.status);\n   149\t    if let Some(ref stage) = status.stage {\n   150\t        println!(\"Stage: {}\", stage);\n   151\t    }\n   152\t    if let Some(cycle) = status.cycle {\n   153\t        println!(\"Cycle: {}\", cycle);\n   154\t    }\n   155\t    if let Some(round) = status.completion_round {\n   156\t        println!(\"Completion round: {}\", round);\n   157\t    }\n   158\t    println!(\"Summary: {}\", status.summary);\n   159\t\n   160\t    Ok(())\n   161\t}\n   162\t\n   163\tasync fn handle_history() -> AppResult<()> {\n   164\t    let current_dir = std::env::current_dir()?;\n   165\t\n   166\t    let config = workspace_governance::load_workspace_config(&current_dir)?;\n   167\t    workspace_governance::ensure_supported_workspace_version(&config)?;\n   168\t\n   169\t    let project_id = workspace_governance::resolve_active_project(&current_dir)?;\n   170\t\n   171\t    // Validate canonical project record before proceeding with run queries\n   172\t    let project_store = FsProjectStore;\n   173\t    let _ = project_store.read_project_record(&current_dir, &project_id)?;\n   174\t\n   175\t    let journal_store = FsJournalStore;\n   176\t    let artifact_store = FsArtifactStore;\n   177\t\n   178\t    let history = service::run_history(&journal_store, &artifact_store, &current_dir, &project_id)?;\n   179\t\n   180\t    println!(\"Project: {}\", history.project_id);\n   181\t    println!(\"--- Journal Events ---\");\n   182\t    for event in &history.events {\n   183\t        println!(\n   184\t            \"  [{}] {} - {:?}\",\n   185\t            event.sequence, event.timestamp, event.event_type\n   186\t        );\n   187\t    }\n   188\t\n   189\t    if !history.payloads.is_empty() {\n   190\t        println!(\"--- Payloads ---\");\n   191\t        for payload in &history.payloads {\n   192\t            println!(\n   193\t                \"  {} ({}, cycle {}, attempt {})\",\n   194\t                payload.payload_id, payload.stage_id, payload.cycle, payload.attempt\n   195\t            );\n   196\t        }\n   197\t    }\n   198\t\n   199\t    if !history.artifacts.is_empty() {\n   200\t        println!(\"--- Artifacts ---\");\n   201\t        for artifact in &history.artifacts {\n   202\t            println!(\n   203\t                \"  {} (payload: {}, stage: {})\",\n   204\t                artifact.artifact_id, artifact.payload_id, artifact.stage_id\n   205\t            );\n   206\t        }\n   207\t    }\n   208\t\n   209\t    Ok(())\n   210\t}\n   211\t\n   212\tasync fn handle_tail(include_logs: bool) -> AppResult<()> {\n   213\t    let current_dir = std::env::current_dir()?;\n   214\t\n   215\t    let config = workspace_governance::load_workspace_config(&current_dir)?;\n   216\t    workspace_governance::ensure_supported_workspace_version(&config)?;\n   217\t\n   218\t    let project_id = workspace_governance::resolve_active_project(&current_dir)?;\n   219\t\n   220\t    // Validate canonical project record before proceeding with run queries\n","exit_code":0,"status":"completed"}}
