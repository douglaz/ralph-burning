\n    54\t        match self {\n    55\t            Self::Standard => {\n    56\t                \"Full delivery flow with planning, implementation, QA, review, and acceptance.\"\n    57\t            }\n    58\t            Self::QuickDev => \"Fast delivery flow for small code changes with lightweight review.\",\n    59\t            Self::DocsChange => {\n    60\t                \"Documentation-focused flow for planning, content updates, and validation.\"\n    61\t            }\n    62\t            Self::CiImprovement => {\n    63\t                \"CI improvement flow for automation planning, updates, and validation.\"\n    64\t            }\n    65\t        }\n    66\t    }\n    67\t}\n    68\t\n    69\timpl fmt::Display for FlowPreset {\n    70\t    fn fmt(&self, f: &mut fmt::Formatter<'_>) -> fmt::Result {\n    71\t        f.write_str(self.as_str())\n    72\t    }\n    73\t}\n    74\t\n    75\timpl FromStr for FlowPreset {\n    76\t    type Err = AppError;\n    77\t\n    78\t    fn from_str(value: &str) -> Result<Self, Self::Err> {\n    79\t        match value {\n    80\t            \"standard\" => Ok(Self::Standard),\n    81\t            \"quick_dev\" => Ok(Self::QuickDev),\n    82\t            \"docs_change\" => Ok(Self::DocsChange),\n    83\t            \"ci_improvement\" => Ok(Self::CiImprovement),\n    84\t            _ => Err(AppError::InvalidFlowPreset {\n    85\t                flow_id: value.to_owned(),\n    86\t            }),\n    87\t        }\n    88\t    }\n    89\t}\n    90\t\n    91\t#[derive(Debug, Clone, Copy, PartialEq, Eq, Hash, Serialize, Deserialize)]\n    92\t#[serde(rename_all = \"snake_case\")]\n    93\tpub enum StageId {\n    94\t    PromptReview,\n    95\t    Planning,\n    96\t    Implementation,\n    97\t    Qa,\n    98\t    Review,\n    99\t    CompletionPanel,\n   100\t    AcceptanceQa,\n   101\t    FinalReview,\n   102\t    PlanAndImplement,\n   103\t    ApplyFixes,\n   104\t    DocsPlan,\n   105\t    DocsUpdate,\n   106\t    DocsValidation,\n   107\t    CiPlan,\n   108\t    CiUpdate,\n   109\t    CiValidation,\n   110\t}\n   111\t\n   112\timpl StageId {\n   113\t    pub const ALL: [Self; 16] = [\n   114\t        Self::PromptReview,\n   115\t        Self::Planning,\n   116\t        Self::Implementation,\n   117\t        Self::Qa,\n   118\t        Self::Review,\n   119\t        Self::CompletionPanel,\n   120\t        Self::AcceptanceQa,\n   121\t        Self::FinalReview,\n   122\t        Self::PlanAndImplement,\n   123\t        Self::ApplyFixes,\n   124\t        Self::DocsPlan,\n   125\t        Self::DocsUpdate,\n   126\t        Self::DocsValidation,\n   127\t        Self::CiPlan,\n   128\t        Self::CiUpdate,\n   129\t        Self::CiValidation,\n   130\t    ];\n   131\t\n   132\t    pub fn display_name(self) -> &'static str {\n   133\t        match self {\n   134\t            Self::PromptReview => \"Prompt Review\",\n   135\t            Self::Planning => \"Planning\",\n   136\t            Self::Implementation => \"Implementation\",\n   137\t            Self::Qa => \"QA\",\n   138\t            Self::Review => \"Review\",\n   139\t            Self::CompletionPanel => \"Completion Panel\",\n   140\t            Self::AcceptanceQa => \"Acceptance QA\",\n   141\t            Self::FinalReview => \"Final Review\",\n   142\t            Self::PlanAndImplement => \"Plan and Implement\",\n   143\t            Self::ApplyFixes => \"Apply Fixes\",\n   144\t            Self::DocsPlan => \"Docs Plan\",\n   145\t            Self::DocsUpdate => \"Docs Update\",\n   146\t            Self::DocsValidation => \"Docs Validation\",\n   147\t            Self::CiPlan => \"CI Plan\",\n   148\t            Self::CiUpdate => \"CI Update\",\n   149\t            Self::CiValidation => \"CI Validation\",\n   150\t        }\n   151\t    }\n   152\t\n   153\t    pub fn as_str(self) -> &'static str {\n   154\t        match self {\n   155\t            Self::PromptReview => \"prompt_review\",\n   156\t            Self::Planning => \"planning\",\n   157\t            Self::Implementation => \"implementation\",\n   158\t            Self::Qa => \"qa\",\n   159\t            Self::Review => \"review\",\n   160\t            Self::CompletionPanel => \"completion_panel\",\n   161\t            Self::AcceptanceQa => \"acceptance_qa\",\n   162\t            Self::FinalReview => \"final_review\",\n   163\t            Self::PlanAndImplement => \"plan_and_implement\",\n   164\t            Self::ApplyFixes => \"apply_fixes\",\n   165\t            Self::DocsPlan => \"docs_plan\",\n   166\t            Self::DocsUpdate => \"docs_update\",\n   167\t            Self::DocsValidation => \"docs_validation\",\n   168\t            Self::CiPlan => \"ci_plan\",\n   169\t            Self::CiUpdate => \"ci_update\",\n   170\t            Self::CiValidation => \"ci_validation\",\n   171\t        }\n   172\t    }\n   173\t}\n   174\t\n   175\timpl fmt::Display for StageId {\n   176\t    fn fmt(&self, f: &mut fmt::Formatter<'_>) -> fmt::Result {\n   177\t        f.write_str(self.as_str())\n   178\t    }\n   179\t}\n   180\t\n   181\t#[derive(Debug, Clone, PartialEq, Eq, Serialize, Deserialize)]\n   182\tpub struct StageCursor {\n   183\t    pub stage: StageId,\n   184\t    pub cycle: u32,\n   185\t    pub attempt: u32,\n   186\t    pub completion_round: u32,\n   187\t}\n   188\t\n   189\timpl StageCursor {\n   190\t    pub fn new(stage: StageId, cycle: u32, attempt: u32, completion_round: u32) -> AppResult<Self> {\n   191\t        if cycle == 0 {\n   192\t            return Err(AppError::InvalidStageCursorField { field: \"cycle\" });\n   193\t        }\n   194\t        if attempt == 0 {\n   195\t            return Err(AppError::InvalidStageCursorField { field: \"attempt\" });\n   196\t        }\n   197\t        if completion_round == 0 {\n   198\t            return Err(AppError::InvalidStageCursorField {\n   199\t                field: \"completion_round\",\n   200\t            });\n","exit_code":0,"status":"completed"}}
