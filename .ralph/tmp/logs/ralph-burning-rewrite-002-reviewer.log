{"type":"item.completed","item":{"id":"item_38","type":"command_execution","command":"/run/current-system/sw/bin/bash -lc \"nl -ba ralph-burning-rewrite/src/contexts/workflow_composition/renderers.rs | sed -n '1,240p'\"","aggregated_output":"     1\t#![forbid(unsafe_code)]\n     2\t\n     3\t//! Deterministic Markdown renderers for validated stage payloads.\n     4\t//!\n     5\t//! Each renderer produces byte-identical output for the same input, uses canonical\n     6\t//! `cycle` terminology, and derives content only from validated structured fields —\n     7\t//! never from raw backend text.\n     8\t\n     9\tuse std::fmt::Write;\n    10\t\n    11\tuse crate::shared::domain::StageId;\n    12\t\n    13\tuse super::payloads::{ExecutionPayload, PlanningPayload, ValidationPayload};\n    14\t\n    15\t/// Render a planning payload to deterministic Markdown.\n    16\tpub fn render_planning(stage_id: StageId, payload: &PlanningPayload) -> String {\n    17\t    let mut out = String::new();\n    18\t\n    19\t    writeln!(out, \"# {}\", stage_id.display_name()).unwrap();\n    20\t    writeln!(out).unwrap();\n    21\t    writeln!(out, \"## Problem Framing\").unwrap();\n    22\t    writeln!(out).unwrap();\n    23\t    writeln!(out, \"{}\", payload.problem_framing).unwrap();\n    24\t    writeln!(out).unwrap();\n    25\t\n    26\t    writeln!(out, \"## Assumptions and Open Questions\").unwrap();\n    27\t    writeln!(out).unwrap();\n    28\t    if payload.assumptions_or_open_questions.is_empty() {\n    29\t        writeln!(out, \"None.\").unwrap();\n    30\t    } else {\n    31\t        for item in &payload.assumptions_or_open_questions {\n    32\t            writeln!(out, \"- {item}\").unwrap();\n    33\t        }\n    34\t    }\n    35\t    writeln!(out).unwrap();\n    36\t\n    37\t    writeln!(out, \"## Proposed Work\").unwrap();\n    38\t    writeln!(out).unwrap();\n    39\t    for item in &payload.proposed_work {\n    40\t        writeln!(out, \"{}. **{}**\", item.order, item.summary).unwrap();\n    41\t        if !item.details.is_empty() {\n    42\t            writeln!(out, \"   {}\", item.details).unwrap();\n    43\t        }\n    44\t    }\n    45\t    writeln!(out).unwrap();\n    46\t\n    47\t    writeln!(out, \"## Readiness\").unwrap();\n    48\t    writeln!(out).unwrap();\n    49\t    let ready_str = if payload.readiness.ready { \"Yes\" } else { \"No\" };\n    50\t    writeln!(out, \"- **Ready:** {ready_str}\").unwrap();\n    51\t    if payload.readiness.risks.is_empty() {\n    52\t        writeln!(out, \"- **Risks:** None identified.\").unwrap();\n    53\t    } else {\n    54\t        writeln!(out, \"- **Risks:**\").unwrap();\n    55\t        for risk in &payload.readiness.risks {\n    56\t            writeln!(out, \"  - {risk}\").unwrap();\n    57\t        }\n    58\t    }\n    59\t\n    60\t    out\n    61\t}\n    62\t\n    63\t/// Render an execution payload to deterministic Markdown.\n    64\tpub fn render_execution(stage_id: StageId, payload: &ExecutionPayload) -> String {\n    65\t    let mut out = String::new();\n    66\t\n    67\t    writeln!(out, \"# {}\", stage_id.display_name()).unwrap();\n    68\t    writeln!(out).unwrap();\n    69\t    writeln!(out, \"## Change Summary\").unwrap();\n    70\t    writeln!(out).unwrap();\n    71\t    writeln!(out, \"{}\", payload.change_summary).unwrap();\n    72\t    writeln!(out).unwrap();\n    73\t\n    74\t    writeln!(out, \"## Steps\").unwrap();\n    75\t    writeln!(out).unwrap();\n    76\t    for step in &payload.steps {\n    77\t        writeln!(\n    78\t            out,\n    79\t            \"{}. [{}] {}\",\n    80\t            step.order, step.status, step.description\n    81\t        )\n    82\t        .unwrap();\n    83\t    }\n    84\t    writeln!(out).unwrap();\n    85\t\n    86\t    writeln!(out, \"## Validation Evidence\").unwrap();\n    87\t    writeln!(out).unwrap();\n    88\t    if payload.validation_evidence.is_empty() {\n    89\t        writeln!(out, \"None provided.\").unwrap();\n    90\t    } else {\n    91\t        for item in &payload.validation_evidence {\n    92\t            writeln!(out, \"- {item}\").unwrap();\n    93\t        }\n    94\t    }\n    95\t    writeln!(out).unwrap();\n    96\t\n    97\t    writeln!(out, \"## Outstanding Risks\").unwrap();\n    98\t    writeln!(out).unwrap();\n    99\t    if payload.outstanding_risks.is_empty() {\n   100\t        writeln!(out, \"None identified.\").unwrap();\n   101\t    } else {\n   102\t        for risk in &payload.outstanding_risks {\n   103\t            writeln!(out, \"- {risk}\").unwrap();\n   104\t        }\n   105\t    }\n   106\t\n   107\t    out\n   108\t}\n   109\t\n   110\t/// Render a validation/review payload to deterministic Markdown.\n   111\tpub fn render_validation(stage_id: StageId, payload: &ValidationPayload) -> String {\n   112\t    let mut out = String::new();\n   113\t\n   114\t    writeln!(out, \"# {}\", stage_id.display_name()).unwrap();\n   115\t    writeln!(out).unwrap();\n   116\t    writeln!(out, \"## Outcome\").unwrap();\n   117\t    writeln!(out).unwrap();\n   118\t    writeln!(out, \"**{}**\", payload.outcome).unwrap();\n   119\t    writeln!(out).unwrap();\n   120\t\n   121\t    writeln!(out, \"## Evidence\").unwrap();\n   122\t    writeln!(out).unwrap();\n   123\t    if payload.evidence.is_empty() {\n   124\t        writeln!(out, \"None provided.\").unwrap();\n   125\t    } else {\n   126\t        for item in &payload.evidence {\n   127\t            writeln!(out, \"- {item}\").unwrap();\n   128\t        }\n   129\t    }\n   130\t    writeln!(out).unwrap();\n   131\t\n   132\t    writeln!(out, \"## Findings and Gaps\").unwrap();\n   133\t    writeln!(out).unwrap();\n   134\t    if payload.findings_or_gaps.is_empty() {\n   135\t        writeln!(out, \"None identified.\").unwrap();\n   136\t    } else {\n   137\t        for item in &payload.findings_or_gaps {\n   138\t            writeln!(out, \"- {item}\").unwrap();\n   139\t        }\n   140\t    }\n   141\t    writeln!(out).unwrap();\n   142\t\n   143\t    writeln!(out, \"## Follow-up and Amendments\").unwrap();\n   144\t    writeln!(out).unwrap();\n   145\t    if payload.follow_up_or_amendments.is_empty() {\n   146\t        writeln!(out, \"None.\").unwrap();\n   147\t    } else {\n   148\t        for item in &payload.follow_up_or_amendments {\n   149\t            writeln!(out, \"- {item}\").unwrap();\n   150\t        }\n   151\t    }\n   152\t\n   153\t    out\n   154\t}\n","exit_code":0,"status":"completed"}}
