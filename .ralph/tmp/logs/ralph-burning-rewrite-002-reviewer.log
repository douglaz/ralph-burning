───────\n    86\t\n    87\t#[test]\n    88\tfn planning_artifact_contains_expected_sections() {\n    89\t    let payload = sample_planning_payload();\n    90\t    let artifact = renderers::render_planning(StageId::Planning, &payload);\n    91\t\n    92\t    assert!(artifact.starts_with(\"# Planning\\n\"));\n    93\t    assert!(artifact.contains(\"## Problem Framing\"));\n    94\t    assert!(artifact.contains(\"We need to add stage contracts.\"));\n    95\t    assert!(artifact.contains(\"## Assumptions and Open Questions\"));\n    96\t    assert!(artifact.contains(\"- All stages are covered.\"));\n    97\t    assert!(artifact.contains(\"## Proposed Work\"));\n    98\t    assert!(artifact.contains(\"1. **Define payload types**\"));\n    99\t    assert!(artifact.contains(\"## Readiness\"));\n   100\t    assert!(artifact.contains(\"- **Ready:** Yes\"));\n   101\t}\n   102\t\n   103\t#[test]\n   104\tfn planning_artifact_uses_stage_display_name() {\n   105\t    let payload = sample_planning_payload();\n   106\t    let artifact =\n   107\t        renderers::render_planning(StageId::PromptReview, &payload);\n   108\t    assert!(artifact.starts_with(\"# Prompt Review\\n\"));\n   109\t}\n   110\t\n   111\t#[test]\n   112\tfn planning_artifact_shows_empty_assumptions() {\n   113\t    let mut payload = sample_planning_payload();\n   114\t    payload.assumptions_or_open_questions = vec![];\n   115\t    let artifact = renderers::render_planning(StageId::Planning, &payload);\n   116\t    assert!(artifact.contains(\"None.\"));\n   117\t}\n   118\t\n   119\t#[test]\n   120\tfn planning_artifact_shows_risks() {\n   121\t    let mut payload = sample_planning_payload();\n   122\t    payload.readiness.risks =\n   123\t        vec![\"Tight deadline.\".to_string(), \"API instability.\".to_string()];\n   124\t    let artifact = renderers::render_planning(StageId::Planning, &payload);\n   125\t    assert!(artifact.contains(\"- **Risks:**\"));\n   126\t    assert!(artifact.contains(\"  - Tight deadline.\"));\n   127\t    assert!(artifact.contains(\"  - API instability.\"));\n   128\t}\n   129\t\n   130\t// ── Execution artifact structure ────────────────────────────────────────────\n   131\t\n   132\t#[test]\n   133\tfn execution_artifact_contains_expected_sections() {\n   134\t    let payload = sample_execution_payload();\n   135\t    let artifact =\n   136\t        renderers::render_execution(StageId::Implementation, &payload);\n   137\t\n   138\t    assert!(artifact.starts_with(\"# Implementation\\n\"));\n   139\t    assert!(artifact.contains(\"## Change Summary\"));\n   140\t    assert!(artifact.contains(\"Added the stage contract registry.\"));\n   141\t    assert!(artifact.contains(\"## Steps\"));\n   142\t    assert!(artifact.contains(\"1. [Completed] Created payloads module\"));\n   143\t    assert!(artifact.contains(\"2. [Intended] Created renderers module\"));\n   144\t    assert!(artifact.contains(\"## Validation Evidence\"));\n   145\t    assert!(artifact.contains(\"- cargo test passes\"));\n   146\t    assert!(artifact.contains(\"## Outstanding Risks\"));\n   147\t    assert!(artifact.contains(\"None identified.\"));\n   148\t}\n   149\t\n   150\t#[test]\n   151\tfn execution_artifact_uses_stage_display_name() {\n   152\t    let payload = sample_execution_payload();\n   153\t    let artifact =\n   154\t        renderers::render_execution(StageId::PlanAndImplement, &payload);\n   155\t    assert!(artifact.starts_with(\"# Plan and Implement\\n\"));\n   156\t}\n   157\t\n   158\t// ── Validation artifact structure ───────────────────────────────────────────\n   159\t\n   160\t#[test]\n   161\tfn validation_artifact_contains_expected_sections() {\n   162\t    let payload = sample_validation_payload();\n   163\t    let artifact = renderers::render_validation(StageId::Review, &payload);\n   164\t\n   165\t    assert!(artifact.starts_with(\"# Review\\n\"));\n   166\t    assert!(artifact.contains(\"## Outcome\"));\n   167\t    assert!(artifact.contains(\"**Approved**\"));\n   168\t    assert!(artifact.contains(\"## Evidence\"));\n   169\t    assert!(artifact.contains(\"- All tests pass.\"));\n   170\t    assert!(artifact.contains(\"## Findings and Gaps\"));\n   171\t    assert!(artifact.contains(\"None identified.\"));\n   172\t    assert!(artifact.contains(\"## Follow-up and Amendments\"));\n   173\t    assert!(artifact.contains(\"None.\"));\n   174\t}\n   175\t\n   176\t#[test]\n   177\tfn validation_artifact_shows_rejected_with_follow_up() {\n   178\t    let payload = ValidationPayload {\n   179\t        outcome: ReviewOutcome::Rejected,\n   180\t        evidence: vec![\"CI fails.\".to_string()],\n   181\t        findings_or_gaps: vec![\"Missing tests.\".to_string()],\n   182\t        follow_up_or_amendments: vec![\"Add integration tests.\".to_string()],\n   183\t    };\n   184\t    let artifact =\n   185\t        renderers::render_validation(StageId::FinalReview, &payload);\n   186\t\n   187\t    assert!(artifact.starts_with(\"# Final Review\\n\"));\n   188\t    assert!(artifact.contains(\"**Rejected**\"));\n   189\t    assert!(artifact.contains(\"- CI fails.\"));\n   190\t    assert!(artifact.contains(\"- Missing tests.\"));\n   191\t    assert!(artifact.contains(\"- Add integration tests.\"));\n   192\t}\n   193\t\n   194\t#[test]\n   195\tfn validation_artifact_uses_stage_display_name() {\n   196\t    let payload = sample_validation_payload();\n   197\t    let artifact =\n   198\t        renderers::render_validation(StageId::CompletionPanel, &payload);\n   199\t    assert!(artifact.starts_with(\"# Completion Panel\\n\"));\n   200\t}\n   201\t\n   202\t// ── No raw backend text in artifacts ────────────────────────────────────────\n   203\t// Renderers take only typed payload fields, never raw text.\n   204\t// This test verifies the artifact derives exclusively from structured data.\n   205\t\n   206\t#[test]\n   207\tfn artifact_content_matches_payload_fields_only() {\n   208\t    let payload = PlanningPayload {\n   209\t        problem_framing: \"UNIQUE_MARKER_XYZ\".to_string(),\n   210\t        assumptions_or_open_questions: vec![\"ASSUMPTION_ABC\".to_string()],\n   211\t        proposed_work: vec![ProposedWorkItem {\n   212\t            order: 1,\n   213\t            summary: \"WORK_SUMMARY_123\".to_string(),\n   214\t            details: \"WORK_DETAILS_456\".to_string(),\n   215\t        }],\n   216\t        readiness: ReadinessAssessment {\n   217\t            ready: false,\n   218\t            risks: vec![\"RISK_789\".to_string()],\n   219\t        },\n   220\t    };\n   221\t    let artifact = renderers::render_planning(StageId::Planning, &payload);\n   222\t\n   223\t    assert!(artifact.contains(\"UNIQUE_MARKER_XYZ\"));\n   224\t    assert!(artifact.contains(\"ASSUMPTION_ABC\"));\n   225\t    assert!(artifact.contains(\"WORK_SUMMARY_123\"));\n   226\t    assert!(artifact.contains(\"WORK_DETAILS_456\"));\n   227\t    assert!(artifact.contains(\"RISK_789\"));\n   228\t    // No extraneous content beyond headings, bullet markers, and payload data.\n   229\t}\n","exit_code":0,"status":"completed"}}
