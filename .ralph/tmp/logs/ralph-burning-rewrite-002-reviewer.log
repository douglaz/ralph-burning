{"type":"item.completed","item":{"id":"item_37","type":"command_execution","command":"/run/current-system/sw/bin/bash -lc \"nl -ba ralph-burning-rewrite/src/contexts/workflow_composition/contracts.rs | sed -n '1,260p'\"","aggregated_output":"     1\t#![forbid(unsafe_code)]\n     2\t\n     3\t//! Stage contract registry and deterministic evaluation pipeline.\n     4\t//!\n     5\t//! Every stage in every built-in flow preset resolves to exactly one\n     6\t//! [`StageContract`]. Contract evaluation enforces a fixed order:\n     7\t//!\n     8\t//! 1. **Schema validation** — deserialize raw JSON into the typed payload.\n     9\t//! 2. **Semantic validation** — apply domain rules to the typed payload.\n    10\t//! 3. **Rendering** — produce a deterministic Markdown artifact.\n    11\t//!\n    12\t//! On schema failure, semantic validation and rendering do not run.\n    13\t//! On domain failure, rendering does not run.\n    14\t//! On any failure, no success bundle is returned.\n    15\t\n    16\tuse schemars::schema::RootSchema;\n    17\t\n    18\tuse crate::shared::domain::StageId;\n    19\tuse crate::shared::error::ContractError;\n    20\t\n    21\tuse super::payloads::{\n    22\t    ExecutionPayload, PlanningPayload, StagePayload, ValidationPayload,\n    23\t};\n    24\tuse super::renderers;\n    25\t\n    26\t// ── Contract family ─────────────────────────────────────────────────────────\n    27\t\n    28\t/// Classifies a stage into one of three payload families.\n    29\t#[derive(Debug, Clone, Copy, PartialEq, Eq, Hash)]\n    30\tpub enum ContractFamily {\n    31\t    /// prompt_review, planning, docs_plan, ci_plan\n    32\t    Planning,\n    33\t    /// implementation, plan_and_implement, apply_fixes, docs_update, ci_update\n    34\t    Execution,\n    35\t    /// qa, docs_validation, ci_validation, acceptance_qa, review, final_review,\n    36\t    /// completion_panel\n    37\t    Validation,\n    38\t}\n    39\t\n    40\t// ── Stage contract ──────────────────────────────────────────────────────────\n    41\t\n    42\t/// A stage contract binds a [`StageId`] to its payload family, schema,\n    43\t/// semantic validation rules, and renderer.\n    44\t#[derive(Debug, Clone, Copy, PartialEq, Eq)]\n    45\tpub struct StageContract {\n    46\t    pub stage_id: StageId,\n    47\t    pub family: ContractFamily,\n    48\t}\n    49\t\n    50\t/// Bundle of a validated payload and its rendered Markdown artifact.\n    51\t///\n    52\t/// Callers receive either a `ValidatedBundle` or an error — never one without\n    53\t/// the other. On any failure (schema, domain, or QA/review outcome), no bundle\n    54\t/// is returned.\n    55\t#[derive(Debug, Clone, PartialEq, Eq)]\n    56\tpub struct ValidatedBundle {\n    57\t    pub payload: StagePayload,\n    58\t    pub artifact: String,\n    59\t}\n    60\t\n    61\t// ── Registry ────────────────────────────────────────────────────────────────\n    62\t\n    63\t/// Look up the contract for a given stage. Every [`StageId`] variant resolves\n    64\t/// to exactly one contract.\n    65\tpub fn contract_for_stage(stage_id: StageId) -> StageContract {\n    66\t    let family = match stage_id {\n    67\t        StageId::PromptReview\n    68\t        | StageId::Planning\n    69\t        | StageId::DocsPlan\n    70\t        | StageId::CiPlan => ContractFamily::Planning,\n    71\t\n    72\t        StageId::Implementation\n    73\t        | StageId::PlanAndImplement\n    74\t        | StageId::ApplyFixes\n    75\t        | StageId::DocsUpdate\n    76\t        | StageId::CiUpdate => ContractFamily::Execution,\n    77\t\n    78\t        StageId::Qa\n    79\t        | StageId::DocsValidation\n    80\t        | StageId::CiValidation\n    81\t        | StageId::AcceptanceQa\n    82\t        | StageId::Review\n    83\t        | StageId::FinalReview\n    84\t        | StageId::CompletionPanel => ContractFamily::Validation,\n    85\t    };\n    86\t\n    87\t    StageContract { stage_id, family }\n    88\t}\n    89\t\n    90\t/// Return contracts for all stages, in [`StageId::ALL`] order.\n    91\tpub fn all_contracts() -> Vec<StageContract> {\n    92\t    StageId::ALL\n    93\t        .iter()\n    94\t        .map(|&id| contract_for_stage(id))\n    95\t        .collect()\n    96\t}\n    97\t\n    98\t// ── Contract implementation ─────────────────────────────────────────────────\n    99\t\n   100\timpl StageContract {\n   101\t    /// Generate the JSON Schema for this contract's payload family.\n   102\t    pub fn json_schema(&self) -> RootSchema {\n   103\t        match self.family {\n   104\t            ContractFamily::Planning => schemars::schema_for!(PlanningPayload),\n   105\t            ContractFamily::Execution => schemars::schema_for!(ExecutionPayload),\n   106\t            ContractFamily::Validation => schemars::schema_for!(ValidationPayload),\n   107\t        }\n   108\t    }\n   109\t\n   110\t    /// Evaluate a raw JSON value through the full contract pipeline.\n   111\t    ///\n   112\t    /// Schema validation → semantic validation → outcome check → rendering.\n   113\t    ///\n   114\t    /// Returns [`ValidatedBundle`] on success or a [`ContractError`] on any\n   115\t    /// failure. Non-passing QA/review outcomes are errors classified as\n   116\t    /// [`FailureClass::QaReviewOutcomeFailure`] — no success bundle is returned.\n   117\t    pub fn evaluate(&self, raw_json: &serde_json::Value) -> Result<ValidatedBundle, ContractError> {\n   118\t        // Step 1: Schema validation (deserialization into typed payload).\n   119\t        let payload = self.validate_schema(raw_json)?;\n   120\t\n   121\t        // Step 2: Semantic / domain validation.\n   122\t        self.validate_semantics(&payload)?;\n   123\t\n   124\t        // Step 3: Non-passing QA/review outcome check (before rendering).\n   125\t        self.check_outcome(&payload)?;\n   126\t\n   127\t        // Step 4: Deterministic Markdown rendering (only on full success).\n   128\t        let artifact = self.render(&payload);\n   129\t\n   130\t        Ok(ValidatedBundle { payload, artifact })\n   131\t    }\n   132\t\n   133\t    // ── Private helpers ─────────────────────────────────────────────────\n   134\t\n   135\t    fn validate_schema(&self, raw: &serde_json::Value) -> Result<StagePayload, ContractError> {\n   136\t        match self.family {\n   137\t            ContractFamily::Planning => {\n   138\t                let p: PlanningPayload =\n   139\t                    serde_json::from_value(raw.clone()).map_err(|e| {\n   140\t                        ContractError::SchemaValidation {\n   141\t                            stage_id: self.stage_id,\n   142\t                            details: e.to_string(),\n   143\t                        }\n   144\t                    })?;\n   145\t                Ok(StagePayload::Planning(p))\n   146\t            }\n   147\t            ContractFamily::Execution => {\n   148\t                let p: ExecutionPayload =\n   149\t                    serde_json::from_value(raw.clone()).map_err(|e| {\n   150\t                        ContractError::SchemaValidation {\n   151\t                            stage_id: self.stage_id,\n   152\t                            details: e.to_string(),\n   153\t                        }\n   154\t                    })?;\n   155\t                Ok(StagePayload::Execution(p))\n   156\t            }\n   157\t            ContractFamily::Validation => {\n   158\t                let p: ValidationPayload =\n   159\t                    serde_json::from_value(raw.clone()).map_err(|e| {\n   160\t                        ContractError::SchemaValidation {\n   161\t                            stage_id: self.stage_id,\n   162\t                            details: e.to_string(),\n   163\t                        }\n   164\t                    })?;\n   165\t                Ok(StagePayload::Validation(p))\n   166\t            }\n   167\t        }\n   168\t    }\n   169\t\n   170\t    fn validate_semantics(&self, payload: &StagePayload) -> Result<(), ContractError> {\n   171\t        match payload {\n   172\t            StagePayload::Planning(p) => {\n   173\t                let mut errors = Vec::new();\n   174\t                if p.problem_framing.trim().is_empty() {\n   175\t                    errors.push(\"problem_framing must not be empty\".to_string());\n   176\t                }\n   177\t                if p.proposed_work.is_empty() {\n   178\t                    errors\n   179\t                        .push(\"proposed_work must contain at least one item\".to_string());\n   180\t                }\n   181\t                for (i, item) in p.proposed_work.iter().enumerate() {\n   182\t                    if item.order == 0 {\n   183\t                        errors.push(format!(\n   184\t                            \"proposed_work[{i}].order must be positive\"\n   185\t                        ));\n   186\t                    }\n   187\t                }\n   188\t                if !errors.is_empty() {\n   189\t                    return Err(ContractError::DomainValidation {\n   190\t                        stage_id: self.stage_id,\n   191\t                        details: errors.join(\"; \"),\n   192\t                    });\n   193\t                }\n   194\t            }\n   195\t            StagePayload::Execution(p) => {\n   196\t                let mut errors = Vec::new();\n   197\t                if p.change_summary.trim().is_empty() {\n   198\t                    errors.push(\"change_summary must not be empty\".to_string());\n   199\t                }\n   200\t                if p.steps.is_empty() {\n   201\t                    errors.push(\"steps must contain at least one item\".to_string());\n   202\t                }\n   203\t                for (i, step) in p.steps.iter().enumerate() {\n   204\t                    if step.order == 0 {\n   205\t                        errors\n   206\t                            .push(format!(\"steps[{i}].order must be positive\"));\n   207\t                    }\n   208\t                }\n   209\t                if !errors.is_empty() {\n   210\t                    return Err(ContractError::DomainValidation {\n   211\t                        stage_id: self.stage_id,\n   212\t                        details: errors.join(\"; \"),\n   213\t                    });\n   214\t                }\n   215\t            }\n   216\t            StagePayload::Validation(p) => {\n   217\t                if !p.outcome.is_passing() && p.follow_up_or_amendments.is_empty()\n   218\t                {\n   219\t                    return Err(ContractError::DomainValidation {\n   220\t                        stage_id: self.stage_id,\n   221\t                        details:\n   222\t                            \"follow_up_or_amendments required when outcome is not approved\"\n   223\t                                .to_string(),\n   224\t                    });\n   225\t                }\n   226\t            }\n   227\t        }\n   228\t        Ok(())\n   229\t    }\n   230\t\n   231\t    fn render(&self, payload: &StagePayload) -> String {\n   232\t        match payload {\n   233\t            StagePayload::Planning(p) => {\n   234\t                renderers::render_planning(self.stage_id, p)\n   235\t            }\n   236\t            StagePayload::Execution(p) => {\n   237\t                renderers::render_execution(self.stage_id, p)\n   238\t            }\n   239\t            StagePayload::Validation(p) => {\n   240\t                renderers::render_validation(self.stage_id, p)\n   241\t            }\n   242\t        }\n   243\t    }\n   244\t\n   245\t    fn check_outcome(&self, payload: &StagePayload) -> Result<(), ContractError> {\n   246\t        if let StagePayload::Validation(p) = payload {\n   247\t            if !p.outcome.is_passing() {\n   248\t                return Err(ContractError::QaReviewOutcome {\n   249\t                    stage_id: self.stage_id,\n   250\t                    outcome: p.outcome.to_string(),\n   251\t                });\n   252\t            }\n   253\t        }\n   254\t        Ok(())\n   255\t    }\n   256\t}\n","exit_code":0,"status":"completed"}}
