{"type":"item.completed","item":{"id":"item_15","type":"command_execution","command":"/run/current-system/sw/bin/bash -lc 'nl -ba ralph-burning-rewrite/src/contexts/workflow_composition/renderers.rs'","aggregated_output":"     1\t#![forbid(unsafe_code)]\n     2\t\n     3\t//! Deterministic Markdown renderers for validated stage payloads.\n     4\t//!\n     5\t//! Each renderer produces byte-identical output for the same input, uses canonical\n     6\t//! `cycle` terminology, and derives content only from validated structured fields —\n     7\t//! never from raw backend text.\n     8\t\n     9\tuse std::fmt::Write;\n    10\t\n    11\tuse crate::shared::domain::StageId;\n    12\t\n    13\tuse super::payloads::{ExecutionPayload, PlanningPayload, ValidationPayload};\n    14\t\n    15\t/// Render a planning payload to deterministic Markdown.\n    16\tpub fn render_planning(stage_id: StageId, payload: &PlanningPayload) -> String {\n    17\t    let mut out = String::new();\n    18\t\n    19\t    writeln!(out, \"# {}\", stage_id.display_name()).unwrap();\n    20\t    writeln!(out).unwrap();\n    21\t    writeln!(out, \"## Problem Framing\").unwrap();\n    22\t    writeln!(out).unwrap();\n    23\t    writeln!(out, \"{}\", payload.problem_framing).unwrap();\n    24\t    writeln!(out).unwrap();\n    25\t\n    26\t    writeln!(out, \"## Assumptions and Open Questions\").unwrap();\n    27\t    writeln!(out).unwrap();\n    28\t    if payload.assumptions_or_open_questions.is_empty() {\n    29\t        writeln!(out, \"None.\").unwrap();\n    30\t    } else {\n    31\t        for item in &payload.assumptions_or_open_questions {\n    32\t            writeln!(out, \"- {item}\").unwrap();\n    33\t        }\n    34\t    }\n    35\t    writeln!(out).unwrap();\n    36\t\n    37\t    writeln!(out, \"## Proposed Work\").unwrap();\n    38\t    writeln!(out).unwrap();\n    39\t    for item in &payload.proposed_work {\n    40\t        writeln!(out, \"{}. **{}**\", item.order, item.summary).unwrap();\n    41\t        if !item.details.is_empty() {\n    42\t            writeln!(out, \"   {}\", item.details).unwrap();\n    43\t        }\n    44\t    }\n    45\t    writeln!(out).unwrap();\n    46\t\n    47\t    writeln!(out, \"## Readiness\").unwrap();\n    48\t    writeln!(out).unwrap();\n    49\t    let ready_str = if payload.readiness.ready { \"Yes\" } else { \"No\" };\n    50\t    writeln!(out, \"- **Ready:** {ready_str}\").unwrap();\n    51\t    if payload.readiness.risks.is_empty() {\n    52\t        writeln!(out, \"- **Risks:** None identified.\").unwrap();\n    53\t    } else {\n    54\t        writeln!(out, \"- **Risks:**\").unwrap();\n    55\t        for risk in &payload.readiness.risks {\n    56\t            writeln!(out, \"  - {risk}\").unwrap();\n    57\t        }\n    58\t    }\n    59\t\n    60\t    out\n    61\t}\n    62\t\n    63\t/// Render an execution payload to deterministic Markdown.\n    64\tpub fn render_execution(stage_id: StageId, payload: &ExecutionPayload) -> String {\n    65\t    let mut out = String::new();\n    66\t\n    67\t    writeln!(out, \"# {}\", stage_id.display_name()).unwrap();\n    68\t    writeln!(out).unwrap();\n    69\t    writeln!(out, \"## Change Summary\").unwrap();\n    70\t    writeln!(out).unwrap();\n    71\t    writeln!(out, \"{}\", payload.change_summary).unwrap();\n    72\t    writeln!(out).unwrap();\n    73\t\n    74\t    writeln!(out, \"## Steps\").unwrap();\n    75\t    writeln!(out).unwrap();\n    76\t    for step in &payload.steps {\n    77\t        writeln!(\n    78\t            out,\n    79\t            \"{}. [{}] {}\",\n    80\t            step.order, step.status, step.description\n    81\t        )\n    82\t        .unwrap();\n    83\t    }\n    84\t    writeln!(out).unwrap();\n    85\t\n    86\t    writeln!(out, \"## Validation Evidence\").unwrap();\n    87\t    writeln!(out).unwrap();\n    88\t    if payload.validation_evidence.is_empty() {\n    89\t        writeln!(out, \"None provided.\").unwrap();\n    90\t    } else {\n    91\t        for item in &payload.validation_evidence {\n    92\t            writeln!(out, \"- {item}\").unwrap();\n    93\t        }\n    94\t    }\n    95\t    writeln!(out).unwrap();\n    96\t\n    97\t    writeln!(out, \"## Outstanding Risks\").unwrap();\n    98\t    writeln!(out).unwrap();\n    99\t    if payload.outstanding_risks.is_empty() {\n   100\t        writeln!(out, \"None identified.\").unwrap();\n   101\t    } else {\n   102\t        for risk in &payload.outstanding_risks {\n   103\t            writeln!(out, \"- {risk}\").unwrap();\n   104\t        }\n   105\t    }\n   106\t\n   107\t    out\n   108\t}\n   109\t\n   110\t/// Render a validation/review payload to deterministic Markdown.\n   111\tpub fn render_validation(stage_id: StageId, payload: &ValidationPayload) -> String {\n   112\t    let mut out = String::new();\n   113\t\n   114\t    writeln!(out, \"# {}\", stage_id.display_name()).unwrap();\n   115\t    writeln!(out).unwrap();\n   116\t    writeln!(out, \"## Outcome\").unwrap();\n   117\t    writeln!(out).unwrap();\n   118\t    writeln!(out, \"**{}**\", payload.outcome).unwrap();\n   119\t    writeln!(out).unwrap();\n   120\t\n   121\t    writeln!(out, \"## Evidence\").unwrap();\n   122\t    writeln!(out).unwrap();\n   123\t    if payload.evidence.is_empty() {\n   124\t        writeln!(out, \"None provided.\").unwrap();\n   125\t    } else {\n   126\t        for item in &payload.evidence {\n   127\t            writeln!(out, \"- {item}\").unwrap();\n   128\t        }\n   129\t    }\n   130\t    writeln!(out).unwrap();\n   131\t\n   132\t    writeln!(out, \"## Findings and Gaps\").unwrap();\n   133\t    writeln!(out).unwrap();\n   134\t    if payload.findings_or_gaps.is_empty() {\n   135\t        writeln!(out, \"None identified.\").unwrap();\n   136\t    } else {\n   137\t        for item in &payload.findings_or_gaps {\n   138\t            writeln!(out, \"- {item}\").unwrap();\n   139\t        }\n   140\t    }\n   141\t    writeln!(out).unwrap();\n   142\t\n   143\t    writeln!(out, \"## Follow-up and Amendments\").unwrap();\n   144\t    writeln!(out).unwrap();\n   145\t    if payload.follow_up_or_amendments.is_empty() {\n   146\t        writeln!(out, \"None.\").unwrap();\n   147\t    } else {\n   148\t        for item in &payload.follow_up_or_amendments {\n   149\t            writeln!(out, \"- {item}\").unwrap();\n   150\t        }\n   151\t    }\n   152\t\n   153\t    out\n   154\t}\n","exit_code":0,"status":"completed"}}
{"type":"item.completed","item":{"id":"item_16","type":"command_execution","command":"/run/current-system/sw/bin/bash -lc 'nl -ba ralph-burning-rewrite/tests/unit/stage_contract_test.rs'","aggregated_output":"     1\t#![forbid(unsafe_code)]\n     2\t\n     3\tuse ralph_burning::contexts::workflow_composition::contracts::{\n     4\t    all_contracts, contract_for_stage, ContractFamily,\n     5\t};\n     6\tuse ralph_burning::contexts::workflow_composition::{built_in_flows, flow_definition};\n     7\tuse ralph_burning::shared::domain::{FailureClass, FlowPreset, StageId};\n     8\tuse ralph_burning::shared::error::ContractError;\n     9\tuse serde_json::json;\n    10\t\n    11\t// ── Helpers ─────────────────────────────────────────────────────────────────\n    12\t\n    13\tfn valid_planning_json() -> serde_json::Value {\n    14\t    json!({\n    15\t        \"problem_framing\": \"Implement stage contracts for the orchestrator.\",\n    16\t        \"assumptions_or_open_questions\": [\"Schema coverage is exhaustive.\"],\n    17\t        \"proposed_work\": [\n    18\t            {\n    19\t                \"order\": 1,\n    20\t                \"summary\": \"Define payload types\",\n    21\t                \"details\": \"Create typed structs for each contract family.\"\n    22\t            }\n    23\t        ],\n    24\t        \"readiness\": {\n    25\t            \"ready\": true,\n    26\t            \"risks\": []\n    27\t        }\n    28\t    })\n    29\t}\n    30\t\n    31\tfn valid_execution_json() -> serde_json::Value {\n    32\t    json!({\n    33\t        \"change_summary\": \"Added stage contract registry.\",\n    34\t        \"steps\": [\n    35\t            {\n    36\t                \"order\": 1,\n    37\t                \"description\": \"Created payloads module\",\n    38\t                \"status\": \"completed\"\n    39\t            }\n    40\t        ],\n    41\t        \"validation_evidence\": [\"cargo test passes\"],\n    42\t        \"outstanding_risks\": []\n    43\t    })\n    44\t}\n    45\t\n    46\tfn valid_validation_approved_json() -> serde_json::Value {\n    47\t    json!({\n    48\t        \"outcome\": \"approved\",\n    49\t        \"evidence\": [\"All tests pass.\"],\n    50\t        \"findings_or_gaps\": [],\n    51\t        \"follow_up_or_amendments\": []\n    52\t    })\n    53\t}\n    54\t\n    55\tfn valid_validation_rejected_json() -> serde_json::Value {\n    56\t    json!({\n    57\t        \"outcome\": \"rejected\",\n    58\t        \"evidence\": [\"Tests fail on CI.\"],\n    59\t        \"findings_or_gaps\": [\"Missing edge-case coverage.\"],\n    60\t        \"follow_up_or_amendments\": [\"Add tests for empty inputs.\"]\n    61\t    })\n    62\t}\n    63\t\n    64\t// ── Registry completeness ───────────────────────────────────────────────────\n    65\t\n    66\t#[test]\n    67\tfn every_stage_id_has_a_contract() {\n    68\t    let contracts = all_contracts();\n    69\t    assert_eq!(contracts.len(), StageId::ALL.len());\n    70\t\n    71\t    for &stage_id in &StageId::ALL {\n    72\t        let contract = contract_for_stage(stage_id);\n    73\t        assert_eq!(contract.stage_id, stage_id);\n    74\t    }\n    75\t}\n    76\t\n    77\t#[test]\n    78\tfn every_stage_in_every_built_in_flow_has_contract_coverage() {\n    79\t    for flow in built_in_flows() {\n    80\t        for &stage_id in flow.stages {\n    81\t            let contract = contract_for_stage(stage_id);\n    82\t            assert_eq!(\n    83\t                contract.stage_id, stage_id,\n    84\t                \"stage {} in flow {} has no matching contract\",\n    85\t                stage_id, flow.preset\n    86\t            );\n    87\t        }\n    88\t    }\n    89\t}\n    90\t\n    91\t#[test]\n    92\tfn planning_stages_map_to_planning_family() {\n    93\t    for stage_id in [\n    94\t        StageId::PromptReview,\n    95\t        StageId::Planning,\n    96\t        StageId::DocsPlan,\n    97\t        StageId::CiPlan,\n    98\t    ] {\n    99\t        assert_eq!(\n   100\t            contract_for_stage(stage_id).family,\n   101\t            ContractFamily::Planning,\n   102\t            \"{stage_id} should be Planning family\"\n   103\t        );\n   104\t    }\n   105\t}\n   106\t\n   107\t#[test]\n   108\tfn execution_stages_map_to_execution_family() {\n   109\t    for stage_id in [\n   110\t        StageId::Implementation,\n   111\t        StageId::PlanAndImplement,\n   112\t        StageId::ApplyFixes,\n   113\t        StageId::DocsUpdate,\n   114\t        StageId::CiUpdate,\n   115\t    ] {\n   116\t        assert_eq!(\n   117\t            contract_for_stage(stage_id).family,\n   118\t            ContractFamily::Execution,\n   119\t            \"{stage_id} should be Execution family\"\n   120\t        );\n   121\t    }\n   122\t}\n   123\t\n   124\t#[test]\n   125\tfn validation_stages_map_to_validation_family() {\n   126\t    for stage_id in [\n   127\t        StageId::Qa,\n   128\t        StageId::DocsValidation,\n   129\t        StageId::CiValidation,\n   130\t        StageId::AcceptanceQa,\n   131\t        StageId::Review,\n   132\t        StageId::FinalReview,\n   133\t        StageId::CompletionPanel,\n   134\t    ] {\n   135\t        assert_eq!(\n   136\t            contract_for_stage(stage_id).family,\n   137\t            ContractFamily::Validation,\n   138\t            \"{stage_id} should be Validation family\"\n   139\t        );\n   140\t    }\n   141\t}\n   142\t\n   143\t// ── Schema validation ───────────────────────────────────────────────────────\n   144\t\n   145\t#[test]\n   146\tfn schema_failure_short_circuits_semantic_validation() {\n   147\t    let contract = contract_for_stage(StageId::Planning);\n   148\t    // Missing required fields → schema error, no domain error.\n   149\t    let bad_json = json!({\"not_a_real_field\": true});\n   150\t    let err = contract.evaluate(&bad_json).unwrap_err();\n   151\t    assert!(\n   152\t        matches!(err, ContractError::SchemaValidation { .. }),\n   153\t        \"expected SchemaValidation, got: {err:?}\"\n   154\t    );\n   155\t    assert_eq!(err.failure_class(), FailureClass::SchemaValidationFailure);\n   156\t}\n   157\t\n   158\t#[test]\n   159\tfn schema_failure_short_circuits_rendering() {\n   160\t    // An execution contract with invalid JSON should never reach the renderer.\n   161\t    let contract = contract_for_stage(StageId::Implementation);\n   162\t    let bad_json = json!(42);\n   163\t    let err = contract.evaluate(&bad_json).unwrap_err();\n   164\t    assert!(matches!(err, ContractError::SchemaValidation { .. }));\n   165\t}\n   166\t\n   167\t// ── Semantic / domain validation ────────────────────────────────────────────\n   168\t\n   169\t#[test]\n   170\tfn domain_failure_short_circuits_rendering() {\n   171\t    let contract = contract_for_stage(StageId::Planning);\n   172\t    // Schema-valid but domain-invalid: empty problem_framing.\n   173\t    let json = json!({\n   174\t        \"problem_framing\": \"   \",\n   175\t        \"assumptions_or_open_questions\": [],\n   176\t        \"proposed_work\": [],\n   177\t        \"readiness\": { \"ready\": false, \"risks\": [] }\n   178\t    });\n   179\t    let err = contract.evaluate(&json).unwrap_err();\n   180\t    assert!(\n   181\t        matches!(err, ContractError::DomainValidation { .. }),\n   182\t        \"expected DomainValidation, got: {err:?}\"\n   183\t    );\n   184\t    assert_eq!(\n   185\t        err.failure_class(),\n   186\t        FailureClass::DomainValidationFailure\n   187\t    );\n   188\t}\n   189\t\n   190\t#[test]\n   191\tfn planning_rejects_zero_order_work_item() {\n   192\t    let contract = contract_for_stage(StageId::Planning);\n   193\t    let json = json!({\n   194\t        \"problem_framing\": \"Valid framing.\",\n   195\t        \"assumptions_or_open_questions\": [],\n   196\t        \"proposed_work\": [\n   197\t            { \"order\": 0, \"summary\": \"Bad order\", \"details\": \"\" }\n   198\t        ],\n   199\t        \"readiness\": { \"ready\": true, \"risks\": [] }\n   200\t    });\n   201\t    let err = contract.evaluate(&json).unwrap_err();\n   202\t    assert!(matches!(err, ContractError::DomainValidation { .. }));\n   203\t}\n   204\t\n   205\t#[test]\n   206\tfn execution_rejects_empty_change_summary() {\n   207\t    let contract = contract_for_stage(StageId::Implementation);\n   208\t    let json = json!({\n   209\t        \"change_summary\": \"\",\n   210\t        \"steps\": [{ \"order\": 1, \"description\": \"step\", \"status\": \"completed\" }],\n   211\t        \"validation_evidence\": [],\n   212\t        \"outstanding_risks\": []\n   213\t    });\n   214\t    let err = contract.evaluate(&json).unwrap_err();\n   215\t    assert!(matches!(err, ContractError::DomainValidation { .. }));\n   216\t}\n   217\t\n   218\t#[test]\n   219\tfn execution_rejects_empty_steps() {\n   220\t    let contract = contract_for_stage(StageId::Implementation);\n   221\t    let json = json!({\n   222\t        \"change_summary\": \"Did things.\",\n   223\t        \"steps\": [],\n   224\t        \"validation_evidence\": [],\n   225\t        \"outstanding_risks\": []\n   226\t    });\n   227\t    let err = contract.evaluate(&json).unwrap_err();\n   228\t    assert!(matches!(err, ContractError::DomainValidation { .. }));\n   229\t}\n   230\t\n   231\t#[test]\n   232\tfn validation_rejects_non_passing_without_follow_up() {\n   233\t    let contract = contract_for_stage(StageId::Review);\n   234\t    let json = json!({\n   235\t        \"outcome\": \"request_changes\",\n   236\t        \"evidence\": [\"Some evidence.\"],\n   237\t        \"findings_or_gaps\": [\"A gap.\"],\n   238\t        \"follow_up_or_amendments\": []\n   239\t    });\n   240\t    let err = contract.evaluate(&json).unwrap_err();\n   241\t    assert!(matches!(err, ContractError::DomainValidation { .. }));\n   242\t}\n   243\t\n   244\t// ── Successful evaluation ───────────────────────────────────────────────────\n   245\t\n   246\t#[test]\n   247\tfn planning_contract_evaluates_successfully() {\n   248\t    let contract = contract_for_stage(StageId::Planning);\n   249\t    let result = contract.evaluate(&valid_planning_json()).unwrap();\n   250\t    assert!(result.outcome_failure.is_none());\n   251\t    assert!(!result.bundle.artifact.is_empty());\n   252\t    assert!(result.bundle.artifact.contains(\"# Planning\"));\n   253\t}\n   254\t\n   255\t#[test]\n   256\tfn execution_contract_evaluates_successfully() {\n   257\t    let contract = contract_for_stage(StageId::Implementation);\n   258\t    let result = contract.evaluate(&valid_execution_json()).unwrap();\n   259\t    assert!(result.outcome_failure.is_none());\n   260\t    assert!(result.bundle.artifact.contains(\"# Implementation\"));\n   261\t}\n   262\t\n   263\t#[test]\n   264\tfn validation_approved_evaluates_with_no_outcome_failure() {\n   265\t    let contract = contract_for_stage(StageId::Review);\n   266\t    let result = contract.evaluate(&valid_validation_approved_json()).unwrap();\n   267\t    assert!(result.outcome_failure.is_none());\n   268\t    assert!(result.bundle.artifact.contains(\"**Approved**\"));\n   269\t}\n   270\t\n   271\t// ── QA/Review outcome failure mapping ───────────────────────────────────────\n   272\t\n   273\t#[test]\n   274\tfn non_passing_review_maps_to_qa_review_outcome_failure() {\n   275\t    let contract = contract_for_stage(StageId::Review);\n   276\t    let result = contract.evaluate(&valid_validation_rejected_json()).unwrap();\n   277\t    assert_eq!(\n   278\t        result.outcome_failure,\n   279\t        Some(FailureClass::QaReviewOutcomeFailure)\n   280\t    );\n   281\t    // Bundle is still returned — the payload is valid.\n   282\t    assert!(result.bundle.artifact.contains(\"**Rejected**\"));\n   283\t}\n   284\t\n   285\t#[test]\n   286\tfn conditionally_approved_maps_to_qa_review_outcome_failure() {\n   287\t    let contract = contract_for_stage(StageId::Qa);\n   288\t    let json = json!({\n   289\t        \"outcome\": \"conditionally_approved\",\n   290\t        \"evidence\": [\"Mostly good.\"],\n   291\t        \"findings_or_gaps\": [\"Minor issue.\"],\n   292\t        \"follow_up_or_amendments\": [\"Fix minor issue.\"]\n   293\t    });\n   294\t    let result = contract.evaluate(&json).unwrap();\n   295\t    assert_eq!(\n   296\t        result.outcome_failure,\n   297\t        Some(FailureClass::QaReviewOutcomeFailure)\n   298\t    );\n   299\t}\n   300\t\n   301\t// ── JSON Schema generation ──────────────────────────────────────────────────\n   302\t\n   303\t#[test]\n   304\tfn json_schema_is_generated_for_each_family() {\n   305\t    for &stage_id in &StageId::ALL {\n   306\t        let contract = contract_for_stage(stage_id);\n   307\t        let schema = contract.json_schema();\n   308\t        // Schema must have a root schema object with definitions.\n   309\t        assert!(\n   310\t            schema.schema.metadata.is_some() || !schema.definitions.is_empty()\n   311\t                || schema.schema.object.is_some()\n   312\t                || schema.schema.subschemas.is_some(),\n   313\t            \"schema for {stage_id} should have content\"\n   314\t        );\n   315\t    }\n   316\t}\n   317\t\n   318\t// ── Conformance scenario IDs ────────────────────────────────────────────────\n   319\t// These tests verify the scenario IDs referenced in\n   320\t// tests/conformance/features/stage_contracts.feature\n   321\t\n   322\t#[test]\n   323\tfn sc_eval_001_successful_planning_contract_evaluation() {\n   324\t    let contract = contract_for_stage(StageId::Planning);\n   325\t    let result = contract.evaluate(&valid_planning_json());\n   326\t    assert!(result.is_ok());\n   327\t    let success = result.unwrap();\n   328\t    assert!(success.outcome_failure.is_none());\n   329\t}\n   330\t\n   331\t#[test]\n   332\tfn sc_eval_002_successful_execution_contract_evaluation() {\n   333\t    let contract = contract_for_stage(StageId::Implementation);\n   334\t    let result = contract.evaluate(&valid_execution_json());\n   335\t    assert!(result.is_ok());\n   336\t}\n   337\t\n   338\t#[test]\n   339\tfn sc_eval_003_successful_validation_contract_evaluation() {\n   340\t    let contract = contract_for_stage(StageId::Review);\n   341\t    let result = contract.evaluate(&valid_validation_approved_json());\n   342\t    assert!(result.is_ok());\n   343\t    assert!(result.unwrap().outcome_failure.is_none());\n   344\t}\n   345\t\n   346\t#[test]\n   347\tfn sc_eval_004_schema_failure_prevents_semantic_validation() {\n   348\t    let contract = contract_for_stage(StageId::Planning);\n   349\t    let err = contract.evaluate(&json!({})).unwrap_err();\n   350\t    assert!(matches!(err, ContractError::SchemaValidation { .. }));\n   351\t}\n   352\t\n   353\t#[test]\n   354\tfn sc_eval_005_domain_failure_prevents_rendering() {\n   355\t    let contract = contract_for_stage(StageId::Implementation);\n   356\t    let json = json!({\n   357\t        \"change_summary\": \"   \",\n   358\t        \"steps\": [],\n   359\t        \"validation_evidence\": [],\n   360\t        \"outstanding_risks\": []\n   361\t    });\n   362\t    let err = contract.evaluate(&json).unwrap_err();\n   363\t    assert!(matches!(err, ContractError::DomainValidation { .. }));\n   364\t}\n   365\t\n   366\t#[test]\n   367\tfn sc_eval_006_qa_review_outcome_failure() {\n   368\t    let contract = contract_for_stage(StageId::FinalReview);\n   369\t    let json = json!({\n   370\t        \"outcome\": \"rejected\",\n   371\t        \"evidence\": [\"Fails acceptance.\"],\n   372\t        \"findings_or_gaps\": [\"Critical gap.\"],\n   373\t        \"follow_up_or_amendments\": [\"Rework needed.\"]\n   374\t    });\n   375\t    let result = contract.evaluate(&json).unwrap();\n   376\t    assert_eq!(\n   377\t        result.outcome_failure,\n   378\t        Some(FailureClass::QaReviewOutcomeFailure)\n   379\t    );\n   380\t}\n   381\t\n   382\t// ── All flows have complete contract coverage ───────────────────────────────\n   383\t\n   384\t#[test]\n   385\tfn sc_eval_007_all_presets_have_complete_contract_coverage() {\n   386\t    for preset in FlowPreset::all() {\n   387\t        let flow = flow_definition(*preset);\n   388\t        for &stage_id in flow.stages {\n   389\t            let _contract = contract_for_stage(stage_id);\n   390\t            // No panic = contract exists.\n   391\t        }\n   392\t    }\n   393\t}\n","exit_code":0,"status":"completed"}}
