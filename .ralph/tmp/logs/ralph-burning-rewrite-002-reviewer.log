er_matches_spec() {\n    54\t    assert_eq!(\n    55\t        &[\n    56\t            StageId::DocsPlan,\n    57\t            StageId::DocsUpdate,\n    58\t            StageId::DocsValidation,\n    59\t            StageId::Review,\n    60\t        ],\n    61\t        flow_definition(FlowPreset::DocsChange).stages\n    62\t    );\n    63\t}\n    64\t\n    65\t#[test]\n    66\tfn ci_improvement_flow_stage_order_matches_spec() {\n    67\t    assert_eq!(\n    68\t        &[\n    69\t            StageId::CiPlan,\n    70\t            StageId::CiUpdate,\n    71\t            StageId::CiValidation,\n    72\t            StageId::Review,\n    73\t        ],\n    74\t        flow_definition(FlowPreset::CiImprovement).stages\n    75\t    );\n    76\t}\n","exit_code":0,"status":"completed"}}
