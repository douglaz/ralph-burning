{"type":"item.completed","item":{"id":"item_11","type":"command_execution","command":"/run/current-system/sw/bin/bash -lc 'nl -ba ralph-burning-rewrite/src/shared/error.rs'","aggregated_output":"     1\tuse std::path::PathBuf;\n     2\t\n     3\tuse thiserror::Error;\n     4\t\n     5\tuse crate::shared::domain::{FailureClass, StageId};\n     6\t\n     7\tpub type AppResult<T> = Result<T, AppError>;\n     8\t\n     9\t#[derive(Debug, Error)]\n    10\tpub enum AppError {\n    11\t    #[error(\"workspace already initialized at {path}\")]\n    12\t    AlreadyInitialized { path: PathBuf },\n    13\t    #[error(\n    14\t        \"cannot initialize workspace because {path} already exists without a workspace configuration\"\n    15\t    )]\n    16\t    WorkspaceConflict { path: PathBuf },\n    17\t    #[error(\"invalid {field}: must be greater than zero\")]\n    18\t    InvalidStageCursorField { field: &'static str },\n    19\t    #[error(\"invalid identifier '{value}': identifiers must not be empty\")]\n    20\t    InvalidIdentifier { value: String },\n    21\t    #[error(\n    22\t        \"unknown flow preset '{flow_id}'. supported presets: standard, quick_dev, docs_change, ci_improvement\"\n    23\t    )]\n    24\t    InvalidFlowPreset { flow_id: String },\n    25\t    #[error(\"unsupported workspace version {version}; supported version is {supported}\")]\n    26\t    UnsupportedWorkspaceVersion { version: u32, supported: u32 },\n    27\t    #[error(\"{command} is not yet implemented\")]\n    28\t    NotYetImplemented { command: String },\n    29\t    #[error(transparent)]\n    30\t    Io(#[from] std::io::Error),\n    31\t    #[error(transparent)]\n    32\t    TomlDeserialize(#[from] toml::de::Error),\n    33\t    #[error(transparent)]\n    34\t    TomlSerialize(#[from] toml::ser::Error),\n    35\t}\n    36\t\n    37\t/// Errors specific to stage contract evaluation.\n    38\t///\n    39\t/// Each variant maps to a distinct [`FailureClass`] for retry/terminal policy.\n    40\t#[derive(Debug, Error)]\n    41\tpub enum ContractError {\n    42\t    #[error(\"schema validation failed for stage '{stage_id}': {details}\")]\n    43\t    SchemaValidation { stage_id: StageId, details: String },\n    44\t\n    45\t    #[error(\"domain validation failed for stage '{stage_id}': {details}\")]\n    46\t    DomainValidation { stage_id: StageId, details: String },\n    47\t\n    48\t    #[error(\"rendering failed for stage '{stage_id}': {details}\")]\n    49\t    RenderError { stage_id: StageId, details: String },\n    50\t}\n    51\t\n    52\timpl ContractError {\n    53\t    pub fn failure_class(&self) -> FailureClass {\n    54\t        match self {\n    55\t            Self::SchemaValidation { .. } => FailureClass::SchemaValidationFailure,\n    56\t            Self::DomainValidation { .. } | Self::RenderError { .. } => {\n    57\t                FailureClass::DomainValidationFailure\n    58\t            }\n    59\t        }\n    60\t    }\n    61\t\n    62\t    pub fn stage_id(&self) -> StageId {\n    63\t        match self {\n    64\t            Self::SchemaValidation { stage_id, .. }\n    65\t            | Self::DomainValidation { stage_id, .. }\n    66\t            | Self::RenderError { stage_id, .. } => *stage_id,\n    67\t        }\n    68\t    }\n    69\t}\n","exit_code":0,"status":"completed"}}
{"type":"item.completed","item":{"id":"item_12","type":"command_execution","command":"/run/current-system/sw/bin/bash -lc 'nl -ba ralph-burning-rewrite/src/contexts/workflow_composition/contracts.rs'","aggregated_output":"     1\t#![forbid(unsafe_code)]\n     2\t\n     3\t//! Stage contract registry and deterministic evaluation pipeline.\n     4\t//!\n     5\t//! Every stage in every built-in flow preset resolves to exactly one\n     6\t//! [`StageContract`]. Contract evaluation enforces a fixed order:\n     7\t//!\n     8\t//! 1. **Schema validation** — deserialize raw JSON into the typed payload.\n     9\t//! 2. **Semantic validation** — apply domain rules to the typed payload.\n    10\t//! 3. **Rendering** — produce a deterministic Markdown artifact.\n    11\t//!\n    12\t//! On schema failure, semantic validation and rendering do not run.\n    13\t//! On domain failure, rendering does not run.\n    14\t//! On any failure, no success bundle is returned.\n    15\t\n    16\tuse schemars::schema::RootSchema;\n    17\t\n    18\tuse crate::shared::domain::{FailureClass, StageId};\n    19\tuse crate::shared::error::ContractError;\n    20\t\n    21\tuse super::payloads::{\n    22\t    ExecutionPayload, PlanningPayload, StagePayload, ValidationPayload,\n    23\t};\n    24\tuse super::renderers;\n    25\t\n    26\t// ── Contract family ─────────────────────────────────────────────────────────\n    27\t\n    28\t/// Classifies a stage into one of three payload families.\n    29\t#[derive(Debug, Clone, Copy, PartialEq, Eq, Hash)]\n    30\tpub enum ContractFamily {\n    31\t    /// prompt_review, planning, docs_plan, ci_plan\n    32\t    Planning,\n    33\t    /// implementation, plan_and_implement, apply_fixes, docs_update, ci_update\n    34\t    Execution,\n    35\t    /// qa, docs_validation, ci_validation, acceptance_qa, review, final_review,\n    36\t    /// completion_panel\n    37\t    Validation,\n    38\t}\n    39\t\n    40\t// ── Stage contract ──────────────────────────────────────────────────────────\n    41\t\n    42\t/// A stage contract binds a [`StageId`] to its payload family, schema,\n    43\t/// semantic validation rules, and renderer.\n    44\t#[derive(Debug, Clone, Copy, PartialEq, Eq)]\n    45\tpub struct StageContract {\n    46\t    pub stage_id: StageId,\n    47\t    pub family: ContractFamily,\n    48\t}\n    49\t\n    50\t/// Bundle of a validated payload and its rendered Markdown artifact.\n    51\t///\n    52\t/// Callers receive either a `ValidatedBundle` or an error — never one without\n    53\t/// the other.\n    54\t#[derive(Debug, Clone, PartialEq, Eq)]\n    55\tpub struct ValidatedBundle {\n    56\t    pub payload: StagePayload,\n    57\t    pub artifact: String,\n    58\t}\n    59\t\n    60\t/// Outcome of a successful contract evaluation.\n    61\t#[derive(Debug, Clone, PartialEq, Eq)]\n    62\tpub struct EvalSuccess {\n    63\t    pub bundle: ValidatedBundle,\n    64\t    /// Set to [`FailureClass::QaReviewOutcomeFailure`] when a validation/review\n    65\t    /// stage produces a non-passing outcome. The bundle is still returned\n    66\t    /// because the payload is structurally and semantically valid — only the\n    67\t    /// workflow-level outcome is non-passing.\n    68\t    pub outcome_failure: Option<FailureClass>,\n    69\t}\n    70\t\n    71\t// ── Registry ────────────────────────────────────────────────────────────────\n    72\t\n    73\t/// Look up the contract for a given stage. Every [`StageId`] variant resolves\n    74\t/// to exactly one contract.\n    75\tpub fn contract_for_stage(stage_id: StageId) -> StageContract {\n    76\t    let family = match stage_id {\n    77\t        StageId::PromptReview\n    78\t        | StageId::Planning\n    79\t        | StageId::DocsPlan\n    80\t        | StageId::CiPlan => ContractFamily::Planning,\n    81\t\n    82\t        StageId::Implementation\n    83\t        | StageId::PlanAndImplement\n    84\t        | StageId::ApplyFixes\n    85\t        | StageId::DocsUpdate\n    86\t        | StageId::CiUpdate => ContractFamily::Execution,\n    87\t\n    88\t        StageId::Qa\n    89\t        | StageId::DocsValidation\n    90\t        | StageId::CiValidation\n    91\t        | StageId::AcceptanceQa\n    92\t        | StageId::Review\n    93\t        | StageId::FinalReview\n    94\t        | StageId::CompletionPanel => ContractFamily::Validation,\n    95\t    };\n    96\t\n    97\t    StageContract { stage_id, family }\n    98\t}\n    99\t\n   100\t/// Return contracts for all stages, in [`StageId::ALL`] order.\n   101\tpub fn all_contracts() -> Vec<StageContract> {\n   102\t    StageId::ALL\n   103\t        .iter()\n   104\t        .map(|&id| contract_for_stage(id))\n   105\t        .collect()\n   106\t}\n   107\t\n   108\t// ── Contract implementation ─────────────────────────────────────────────────\n   109\t\n   110\timpl StageContract {\n   111\t    /// Generate the JSON Schema for this contract's payload family.\n   112\t    pub fn json_schema(&self) -> RootSchema {\n   113\t        match self.family {\n   114\t            ContractFamily::Planning => schemars::schema_for!(PlanningPayload),\n   115\t            ContractFamily::Execution => schemars::schema_for!(ExecutionPayload),\n   116\t            ContractFamily::Validation => schemars::schema_for!(ValidationPayload),\n   117\t        }\n   118\t    }\n   119\t\n   120\t    /// Evaluate a raw JSON value through the full contract pipeline.\n   121\t    ///\n   122\t    /// Schema validation → semantic validation → rendering.\n   123\t    ///\n   124\t    /// Returns [`EvalSuccess`] on success (which may still carry a\n   125\t    /// [`FailureClass::QaReviewOutcomeFailure`] for non-passing review outcomes)\n   126\t    /// or a [`ContractError`] on any hard failure.\n   127\t    pub fn evaluate(&self, raw_json: &serde_json::Value) -> Result<EvalSuccess, ContractError> {\n   128\t        // Step 1: Schema validation (deserialization into typed payload).\n   129\t        let payload = self.validate_schema(raw_json)?;\n   130\t\n   131\t        // Step 2: Semantic / domain validation.\n   132\t        self.validate_semantics(&payload)?;\n   133\t\n   134\t        // Step 3: Deterministic Markdown rendering.\n   135\t        let artifact = self.render(&payload);\n   136\t\n   137\t        // Step 4: Map non-passing QA/review outcomes.\n   138\t        let outcome_failure = Self::check_outcome_failure(&payload);\n   139\t\n   140\t        Ok(EvalSuccess {\n   141\t            bundle: ValidatedBundle { payload, artifact },\n   142\t            outcome_failure,\n   143\t        })\n   144\t    }\n   145\t\n   146\t    // ── Private helpers ─────────────────────────────────────────────────\n   147\t\n   148\t    fn validate_schema(&self, raw: &serde_json::Value) -> Result<StagePayload, ContractError> {\n   149\t        match self.family {\n   150\t            ContractFamily::Planning => {\n   151\t                let p: PlanningPayload =\n   152\t                    serde_json::from_value(raw.clone()).map_err(|e| {\n   153\t                        ContractError::SchemaValidation {\n   154\t                            stage_id: self.stage_id,\n   155\t                            details: e.to_string(),\n   156\t                        }\n   157\t                    })?;\n   158\t                Ok(StagePayload::Planning(p))\n   159\t            }\n   160\t            ContractFamily::Execution => {\n   161\t                let p: ExecutionPayload =\n   162\t                    serde_json::from_value(raw.clone()).map_err(|e| {\n   163\t                        ContractError::SchemaValidation {\n   164\t                            stage_id: self.stage_id,\n   165\t                            details: e.to_string(),\n   166\t                        }\n   167\t                    })?;\n   168\t                Ok(StagePayload::Execution(p))\n   169\t            }\n   170\t            ContractFamily::Validation => {\n   171\t                let p: ValidationPayload =\n   172\t                    serde_json::from_value(raw.clone()).map_err(|e| {\n   173\t                        ContractError::SchemaValidation {\n   174\t                            stage_id: self.stage_id,\n   175\t                            details: e.to_string(),\n   176\t                        }\n   177\t                    })?;\n   178\t                Ok(StagePayload::Validation(p))\n   179\t            }\n   180\t        }\n   181\t    }\n   182\t\n   183\t    fn validate_semantics(&self, payload: &StagePayload) -> Result<(), ContractError> {\n   184\t        match payload {\n   185\t            StagePayload::Planning(p) => {\n   186\t                let mut errors = Vec::new();\n   187\t                if p.problem_framing.trim().is_empty() {\n   188\t                    errors.push(\"problem_framing must not be empty\".to_string());\n   189\t                }\n   190\t                if p.proposed_work.is_empty() {\n   191\t                    errors\n   192\t                        .push(\"proposed_work must contain at least one item\".to_string());\n   193\t                }\n   194\t                for (i, item) in p.proposed_work.iter().enumerate() {\n   195\t                    if item.order == 0 {\n   196\t                        errors.push(format!(\n   197\t                            \"proposed_work[{i}].order must be positive\"\n   198\t                        ));\n   199\t                    }\n   200\t                }\n   201\t                if !errors.is_empty() {\n   202\t                    return Err(ContractError::DomainValidation {\n   203\t                        stage_id: self.stage_id,\n   204\t                        details: errors.join(\"; \"),\n   205\t                    });\n   206\t                }\n   207\t            }\n   208\t            StagePayload::Execution(p) => {\n   209\t                let mut errors = Vec::new();\n   210\t                if p.change_summary.trim().is_empty() {\n   211\t                    errors.push(\"change_summary must not be empty\".to_string());\n   212\t                }\n   213\t                if p.steps.is_empty() {\n   214\t                    errors.push(\"steps must contain at least one item\".to_string());\n   215\t                }\n   216\t                for (i, step) in p.steps.iter().enumerate() {\n   217\t                    if step.order == 0 {\n   218\t                        errors\n   219\t                            .push(format!(\"steps[{i}].order must be positive\"));\n   220\t                    }\n   221\t                }\n   222\t                if !errors.is_empty() {\n   223\t                    return Err(ContractError::DomainValidation {\n   224\t                        stage_id: self.stage_id,\n   225\t                        details: errors.join(\"; \"),\n   226\t                    });\n   227\t                }\n   228\t            }\n   229\t            StagePayload::Validation(p) => {\n   230\t                if !p.outcome.is_passing() && p.follow_up_or_amendments.is_empty()\n   231\t                {\n   232\t                    return Err(ContractError::DomainValidation {\n   233\t                        stage_id: self.stage_id,\n   234\t                        details:\n   235\t                            \"follow_up_or_amendments required when outcome is not approved\"\n   236\t                                .to_string(),\n   237\t                    });\n   238\t                }\n   239\t            }\n   240\t        }\n   241\t        Ok(())\n   242\t    }\n   243\t\n   244\t    fn render(&self, payload: &StagePayload) -> String {\n   245\t        match payload {\n   246\t            StagePayload::Planning(p) => {\n   247\t                renderers::render_planning(self.stage_id, p)\n   248\t            }\n   249\t            StagePayload::Execution(p) => {\n   250\t                renderers::render_execution(self.stage_id, p)\n   251\t            }\n   252\t            StagePayload::Validation(p) => {\n   253\t                renderers::render_validation(self.stage_id, p)\n   254\t            }\n   255\t        }\n   256\t    }\n   257\t\n   258\t    fn check_outcome_failure(payload: &StagePayload) -> Option<FailureClass> {\n   259\t        if let StagePayload::Validation(p) = payload {\n   260\t            if !p.outcome.is_passing() {\n   261\t                return Some(FailureClass::QaReviewOutcomeFailure);\n   262\t            }\n   263\t        }\n   264\t        None\n   265\t    }\n   266\t}\n","exit_code":0,"status":"completed"}}
