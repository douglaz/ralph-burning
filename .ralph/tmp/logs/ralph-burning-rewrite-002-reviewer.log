/ ── Successful evaluation ───────────────────────────────────────────────────\n   245\t\n   246\t#[test]\n   247\tfn planning_contract_evaluates_successfully() {\n   248\t    let contract = contract_for_stage(StageId::Planning);\n   249\t    let bundle = contract.evaluate(&valid_planning_json()).unwrap();\n   250\t    assert!(!bundle.artifact.is_empty());\n   251\t    assert!(bundle.artifact.contains(\"# Planning\"));\n   252\t}\n   253\t\n   254\t#[test]\n   255\tfn execution_contract_evaluates_successfully() {\n   256\t    let contract = contract_for_stage(StageId::Implementation);\n   257\t    let bundle = contract.evaluate(&valid_execution_json()).unwrap();\n   258\t    assert!(bundle.artifact.contains(\"# Implementation\"));\n   259\t}\n   260\t\n   261\t#[test]\n   262\tfn validation_approved_evaluates_with_no_outcome_failure() {\n   263\t    let contract = contract_for_stage(StageId::Review);\n   264\t    let bundle = contract.evaluate(&valid_validation_approved_json()).unwrap();\n   265\t    assert!(bundle.artifact.contains(\"**Approved**\"));\n   266\t}\n   267\t\n   268\t// ── QA/Review outcome failure mapping ───────────────────────────────────────\n   269\t\n   270\t#[test]\n   271\tfn non_passing_review_maps_to_qa_review_outcome_failure() {\n   272\t    let contract = contract_for_stage(StageId::Review);\n   273\t    let err = contract\n   274\t        .evaluate(&valid_validation_rejected_json())\n   275\t        .unwrap_err();\n   276\t    assert!(\n   277\t        matches!(err, ContractError::QaReviewOutcome { .. }),\n   278\t        \"expected QaReviewOutcome, got: {err:?}\"\n   279\t    );\n   280\t    assert_eq!(err.failure_class(), FailureClass::QaReviewOutcomeFailure);\n   281\t}\n   282\t\n   283\t#[test]\n   284\tfn conditionally_approved_maps_to_qa_review_outcome_failure() {\n   285\t    let contract = contract_for_stage(StageId::Qa);\n   286\t    let json = json!({\n   287\t        \"outcome\": \"conditionally_approved\",\n   288\t        \"evidence\": [\"Mostly good.\"],\n   289\t        \"findings_or_gaps\": [\"Minor issue.\"],\n   290\t        \"follow_up_or_amendments\": [\"Fix minor issue.\"]\n   291\t    });\n   292\t    let err = contract.evaluate(&json).unwrap_err();\n   293\t    assert!(matches!(err, ContractError::QaReviewOutcome { .. }));\n   294\t    assert_eq!(err.failure_class(), FailureClass::QaReviewOutcomeFailure);\n   295\t}\n   296\t\n   297\t// ── JSON Schema generation ──────────────────────────────────────────────────\n   298\t\n   299\t#[test]\n   300\tfn json_schema_is_generated_for_each_family() {\n   301\t    for &stage_id in &StageId::ALL {\n   302\t        let contract = contract_for_stage(stage_id);\n   303\t        let schema = contract.json_schema();\n   304\t        // Schema must have a root schema object with definitions.\n   305\t        assert!(\n   306\t            schema.schema.metadata.is_some() || !schema.definitions.is_empty()\n   307\t                || schema.schema.object.is_some()\n   308\t                || schema.schema.subschemas.is_some(),\n   309\t            \"schema for {stage_id} should have content\"\n   310\t        );\n   311\t    }\n   312\t}\n   313\t\n   314\t// ── Conformance scenario IDs ────────────────────────────────────────────────\n   315\t// These tests verify the scenario IDs referenced in\n   316\t// tests/conformance/features/stage_contracts.feature\n   317\t\n   318\t#[test]\n   319\tfn sc_eval_001_successful_planning_contract_evaluation() {\n   320\t    let contract = contract_for_stage(StageId::Planning);\n   321\t    let bundle = contract.evaluate(&valid_planning_json()).unwrap();\n   322\t    assert!(!bundle.artifact.is_empty());\n   323\t}\n   324\t\n   325\t#[test]\n   326\tfn sc_eval_002_successful_execution_contract_evaluation() {\n   327\t    let contract = contract_for_stage(StageId::Implementation);\n   328\t    let bundle = contract.evaluate(&valid_execution_json()).unwrap();\n   329\t    assert!(!bundle.artifact.is_empty());\n   330\t}\n   331\t\n   332\t#[test]\n   333\tfn sc_eval_003_successful_validation_contract_evaluation() {\n   334\t    let contract = contract_for_stage(StageId::Review);\n   335\t    let bundle = contract.evaluate(&valid_validation_approved_json()).unwrap();\n   336\t    assert!(!bundle.artifact.is_empty());\n   337\t}\n   338\t\n   339\t#[test]\n   340\tfn sc_eval_004_schema_failure_prevents_semantic_validation() {\n   341\t    let contract = contract_for_stage(StageId::Planning);\n   342\t    let err = contract.evaluate(&json!({})).unwrap_err();\n   343\t    assert!(matches!(err, ContractError::SchemaValidation { .. }));\n   344\t}\n   345\t\n   346\t#[test]\n   347\tfn sc_eval_005_domain_failure_prevents_rendering() {\n   348\t    let contract = contract_for_stage(StageId::Implementation);\n   349\t    let json = json!({\n   350\t        \"change_summary\": \"   \",\n   351\t        \"steps\": [],\n   352\t        \"validation_evidence\": [],\n   353\t        \"outstanding_risks\": []\n   354\t    });\n   355\t    let err = contract.evaluate(&json).unwrap_err();\n   356\t    assert!(matches!(err, ContractError::DomainValidation { .. }));\n   357\t}\n   358\t\n   359\t#[test]\n   360\tfn sc_eval_006_qa_review_outcome_failure() {\n   361\t    let contract = contract_for_stage(StageId::FinalReview);\n   362\t    let json = json!({\n   363\t        \"outcome\": \"rejected\",\n   364\t        \"evidence\": [\"Fails acceptance.\"],\n   365\t        \"findings_or_gaps\": [\"Critical gap.\"],\n   366\t        \"follow_up_or_amendments\": [\"Rework needed.\"]\n   367\t    });\n   368\t    let err = contract.evaluate(&json).unwrap_err();\n   369\t    assert!(matches!(err, ContractError::QaReviewOutcome { .. }));\n   370\t    assert_eq!(err.failure_class(), FailureClass::QaReviewOutcomeFailure);\n   371\t}\n   372\t\n   373\t// ── All flows have complete contract coverage ───────────────────────────────\n   374\t\n   375\t#[test]\n   376\tfn sc_eval_007_all_presets_have_complete_contract_coverage() {\n   377\t    for preset in FlowPreset::all() {\n   378\t        let flow = flow_definition(*preset);\n   379\t        for &stage_id in flow.stages {\n   380\t            let _contract = contract_for_stage(stage_id);\n   381\t            // No panic = contract exists.\n   382\t        }\n   383\t    }\n   384\t}\n   385\t\n   386\t// ── SC-EVAL-009: Non-passing outcomes are distinct from schema/domain ────────\n   387\t\n   388\t#[test]\n   389\tfn sc_eval_009_non_passing_review_not_schema_or_domain_failure() {\n   390\t    let contract = contract_for_stage(StageId::Review);\n   391\t    let json = json!({\n   392\t        \"outcome\": \"request_changes\",\n   393\t        \"evidence\": [\"Some evidence.\"],\n   394\t        \"findings_or_gaps\": [\"A gap.\"],\n   395\t        \"follow_up_or_amendments\": [\"Fix it.\"]\n   396\t    });\n   397\t    let err = contract.evaluate(&json).unwrap_err();\n   398\t    assert!(matches!(err, ContractError::QaReviewOutcome { .. }));\n   399\t    assert_eq!(err.failure_class(), FailureClass::QaReviewOutcomeFailure);\n   400\t    assert_ne!(err.failure_class(), FailureClass::SchemaValidationFailure);\n   401\t    assert_ne!(err.failure_class(), FailureClass::DomainValidationFailure);\n   402\t}\n   403\t\n   404\t// ── Runtime validation alignment with generated schema ───────────────────────\n   405\t\n   406\t#[test]\n   407\tfn schema_validation_rejects_what_generated_schema_marks_required() {\n   408\t    // Proves that runtime deserialization (evaluate) rejects a payload missing\n   409\t    // fields that the generated JSON Schema marks as required, ensuring the two\n   410\t    // validation paths stay aligned.\n   411\t    use jsonschema::JSONSchema;\n   412\t\n   413\t    let contract = contract_for_stage(StageId::Planning);\n   414\t    let schema_value =\n   415\t        serde_json::to_value(contract.json_schema()).expect(\"schema serializes\");\n   416\t    let compiled =\n   417\t        JSONSchema::compile(&schema_value).expect(\"schema compiles\");\n   418\t\n   419\t    let missing_fields = json!({\"not_a_real_field\": true});\n   420\t\n   421\t    // Generated schema rejects this payload.\n   422\t    assert!(\n   423\t        !compiled.is_valid(&missing_fields),\n   424\t        \"generated schema should reject payload missing required fields\"\n   425\t    );\n   426\t    // Runtime evaluation also rejects it.\n   427\t    let err = contract.evaluate(&missing_fields).unwrap_err();\n   428\t    assert!(\n   429\t        matches!(err, ContractError::SchemaValidation { .. }),\n   430\t        \"runtime evaluation should also reject: {err:?}\"\n   431\t    );\n   432\t}\n   433\t\n   434\t#[test]\n   435\tfn schema_validation_accepts_what_generated_schema_accepts() {\n   436\t    use jsonschema::JSONSchema;\n   437\t\n   438\t    let contract = contract_for_stage(StageId::Planning);\n   439\t    let schema_value =\n   440\t        serde_json::to_value(contract.json_schema()).expect(\"schema serializes\");\n   441\t    let compiled =\n   442\t        JSONSchema::compile(&schema_value).expect(\"schema compiles\");\n   443\t\n   444\t    let valid = valid_planning_json();\n   445\t\n   446\t    // Generated schema accepts this payload.\n   447\t    assert!(\n   448\t        compiled.is_valid(&valid),\n   449\t        \"generated schema should accept valid payload\"\n   450\t    );\n   451\t    // Runtime evaluation also accepts it.\n   452\t    assert!(\n   453\t        contract.evaluate(&valid).is_ok(),\n   454\t        \"runtime evaluation should also accept valid payload\"\n   455\t    );\n   456\t}\n","exit_code":0,"status":"completed"}}
