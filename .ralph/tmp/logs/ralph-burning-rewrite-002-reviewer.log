{"type":"item.completed","item":{"id":"item_47","type":"command_execution","command":"/run/current-system/sw/bin/bash -lc \"nl -ba ralph-burning-rewrite/src/contexts/workflow_composition/mod.rs | sed -n '1,180p'\"","aggregated_output":"     1\tpub mod contracts;\n     2\tpub mod payloads;\n     3\tpub mod renderers;\n     4\t\n     5\tuse crate::shared::domain::{FlowPreset, StageId};\n     6\tuse crate::shared::error::AppResult;\n     7\t\n     8\t#[derive(Debug, Clone, Copy, PartialEq, Eq)]\n     9\tpub struct ValidationProfile {\n    10\t    pub name: &'static str,\n    11\t    pub summary: &'static str,\n    12\t    pub final_review_enabled: bool,\n    13\t}\n    14\t\n    15\t#[derive(Debug, Clone, Copy, PartialEq, Eq)]\n    16\tpub struct FlowDefinition {\n    17\t    pub preset: FlowPreset,\n    18\t    pub description: &'static str,\n    19\t    pub stages: &'static [StageId],\n    20\t    pub validation_profile: ValidationProfile,\n    21\t}\n    22\t\n    23\tconst STANDARD_STAGES: [StageId; 8] = [\n    24\t    StageId::PromptReview,\n    25\t    StageId::Planning,\n    26\t    StageId::Implementation,\n    27\t    StageId::Qa,\n    28\t    StageId::Review,\n    29\t    StageId::CompletionPanel,\n    30\t    StageId::AcceptanceQa,\n    31\t    StageId::FinalReview,\n    32\t];\n    33\t\n    34\tconst QUICK_DEV_STAGES: [StageId; 4] = [\n    35\t    StageId::PlanAndImplement,\n    36\t    StageId::Review,\n    37\t    StageId::ApplyFixes,\n    38\t    StageId::FinalReview,\n    39\t];\n    40\t\n    41\tconst DOCS_CHANGE_STAGES: [StageId; 4] = [\n    42\t    StageId::DocsPlan,\n    43\t    StageId::DocsUpdate,\n    44\t    StageId::DocsValidation,\n    45\t    StageId::Review,\n    46\t];\n    47\t\n    48\tconst CI_IMPROVEMENT_STAGES: [StageId; 4] = [\n    49\t    StageId::CiPlan,\n    50\t    StageId::CiUpdate,\n    51\t    StageId::CiValidation,\n    52\t    StageId::Review,\n    53\t];\n    54\t\n    55\tconst FLOW_DEFINITIONS: [FlowDefinition; 4] = [\n    56\t    FlowDefinition {\n    57\t        preset: FlowPreset::Standard,\n    58\t        description:\n    59\t            \"Full delivery flow with planning, implementation, QA, review, and acceptance.\",\n    60\t        stages: &STANDARD_STAGES,\n    61\t        validation_profile: ValidationProfile {\n    62\t            name: \"standard-default\",\n    63\t            summary: \"Full validation suite with completion and acceptance checks.\",\n    64\t            final_review_enabled: true,\n    65\t        },\n    66\t    },\n    67\t    FlowDefinition {\n    68\t        preset: FlowPreset::QuickDev,\n    69\t        description: \"Fast delivery flow for small code changes with lightweight review.\",\n    70\t        stages: &QUICK_DEV_STAGES,\n    71\t        validation_profile: ValidationProfile {\n    72\t            name: \"quick-dev-default\",\n    73\t            summary: \"Lightweight panel with final review enabled by default.\",\n    74\t            final_review_enabled: true,\n    75\t        },\n    76\t    },\n    77\t    FlowDefinition {\n    78\t        preset: FlowPreset::DocsChange,\n    79\t        description: \"Documentation-focused flow for planning, content updates, and validation.\",\n    80\t        stages: &DOCS_CHANGE_STAGES,\n    81\t        validation_profile: ValidationProfile {\n    82\t            name: \"docs-default\",\n    83\t            summary: \"Documentation validation with final review disabled by default.\",\n    84\t            final_review_enabled: false,\n    85\t        },\n    86\t    },\n    87\t    FlowDefinition {\n    88\t        preset: FlowPreset::CiImprovement,\n    89\t        description: \"CI improvement flow for automation planning, updates, and validation.\",\n    90\t        stages: &CI_IMPROVEMENT_STAGES,\n    91\t        validation_profile: ValidationProfile {\n    92\t            name: \"ci-default\",\n    93\t            summary: \"Automation validation with final review disabled by default.\",\n    94\t            final_review_enabled: false,\n    95\t        },\n    96\t    },\n    97\t];\n    98\t\n    99\tpub fn built_in_flows() -> &'static [FlowDefinition] {\n   100\t    &FLOW_DEFINITIONS\n   101\t}\n   102\t\n   103\tpub fn flow_definition(preset: FlowPreset) -> &'static FlowDefinition {\n   104\t    match preset {\n   105\t        FlowPreset::Standard => &FLOW_DEFINITIONS[0],\n   106\t        FlowPreset::QuickDev => &FLOW_DEFINITIONS[1],\n   107\t        FlowPreset::DocsChange => &FLOW_DEFINITIONS[2],\n   108\t        FlowPreset::CiImprovement => &FLOW_DEFINITIONS[3],\n   109\t    }\n   110\t}\n   111\t\n   112\tpub fn flow_definition_by_id(flow_id: &str) -> AppResult<&'static FlowDefinition> {\n   113\t    let preset = flow_id.parse::<FlowPreset>()?;\n   114\t    Ok(flow_definition(preset))\n   115\t}\n","exit_code":0,"status":"completed"}}
