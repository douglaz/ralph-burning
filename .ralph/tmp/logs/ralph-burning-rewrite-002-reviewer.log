{"type":"item.completed","item":{"id":"item_39","type":"command_execution","command":"/run/current-system/sw/bin/bash -lc \"nl -ba ralph-burning-rewrite/src/contexts/workflow_composition/payloads.rs | sed -n '1,220p'\"","aggregated_output":"     1\t#![forbid(unsafe_code)]\n     2\t\n     3\t//! Typed stage payload models for each contract family.\n     4\t//!\n     5\t//! Three payload families cover all 16 stages:\n     6\t//! - **Planning**: prompt_review, planning, docs_plan, ci_plan\n     7\t//! - **Execution**: implementation, plan_and_implement, apply_fixes, docs_update, ci_update\n     8\t//! - **Validation**: qa, docs_validation, ci_validation, acceptance_qa, review, final_review,\n     9\t//!   completion_panel\n    10\t\n    11\tuse schemars::JsonSchema;\n    12\tuse serde::{Deserialize, Serialize};\n    13\t\n    14\t// ── Planning family ─────────────────────────────────────────────────────────\n    15\t\n    16\t/// Payload for planning-style stages.\n    17\t///\n    18\t/// Requires structured problem framing, assumptions or open questions,\n    19\t/// ordered proposed work, and explicit readiness/risk fields.\n    20\t#[derive(Debug, Clone, PartialEq, Eq, Serialize, Deserialize, JsonSchema)]\n    21\tpub struct PlanningPayload {\n    22\t    pub problem_framing: String,\n    23\t    pub assumptions_or_open_questions: Vec<String>,\n    24\t    pub proposed_work: Vec<ProposedWorkItem>,\n    25\t    pub readiness: ReadinessAssessment,\n    26\t}\n    27\t\n    28\t#[derive(Debug, Clone, PartialEq, Eq, Serialize, Deserialize, JsonSchema)]\n    29\tpub struct ProposedWorkItem {\n    30\t    pub order: u32,\n    31\t    pub summary: String,\n    32\t    pub details: String,\n    33\t}\n    34\t\n    35\t#[derive(Debug, Clone, PartialEq, Eq, Serialize, Deserialize, JsonSchema)]\n    36\tpub struct ReadinessAssessment {\n    37\t    pub ready: bool,\n    38\t    pub risks: Vec<String>,\n    39\t}\n    40\t\n    41\t// ── Execution family ────────────────────────────────────────────────────────\n    42\t\n    43\t/// Payload for execution/update stages.\n    44\t///\n    45\t/// Requires structured change summaries, intended or completed steps,\n    46\t/// validation evidence or plans, and outstanding-risk fields.\n    47\t#[derive(Debug, Clone, PartialEq, Eq, Serialize, Deserialize, JsonSchema)]\n    48\tpub struct ExecutionPayload {\n    49\t    pub change_summary: String,\n    50\t    pub steps: Vec<ExecutionStep>,\n    51\t    pub validation_evidence: Vec<String>,\n    52\t    pub outstanding_risks: Vec<String>,\n    53\t}\n    54\t\n    55\t#[derive(Debug, Clone, PartialEq, Eq, Serialize, Deserialize, JsonSchema)]\n    56\tpub struct ExecutionStep {\n    57\t    pub order: u32,\n    58\t    pub description: String,\n    59\t    pub status: StepStatus,\n    60\t}\n    61\t\n    62\t#[derive(Debug, Clone, Copy, PartialEq, Eq, Serialize, Deserialize, JsonSchema)]\n    63\t#[serde(rename_all = \"snake_case\")]\n    64\tpub enum StepStatus {\n    65\t    Intended,\n    66\t    Completed,\n    67\t    Skipped,\n    68\t}\n    69\t\n    70\timpl std::fmt::Display for StepStatus {\n    71\t    fn fmt(&self, f: &mut std::fmt::Formatter<'_>) -> std::fmt::Result {\n    72\t        match self {\n    73\t            Self::Intended => f.write_str(\"Intended\"),\n    74\t            Self::Completed => f.write_str(\"Completed\"),\n    75\t            Self::Skipped => f.write_str(\"Skipped\"),\n    76\t        }\n    77\t    }\n    78\t}\n    79\t\n    80\t// ── Validation / Review family ──────────────────────────────────────────────\n    81\t\n    82\t/// Payload for validation/review stages.\n    83\t///\n    84\t/// Requires an explicit outcome/decision enum plus evidence, findings or gaps,\n    85\t/// and follow-up or amendment data when the outcome is not cleanly approved.\n    86\t#[derive(Debug, Clone, PartialEq, Eq, Serialize, Deserialize, JsonSchema)]\n    87\tpub struct ValidationPayload {\n    88\t    pub outcome: ReviewOutcome,\n    89\t    pub evidence: Vec<String>,\n    90\t    pub findings_or_gaps: Vec<String>,\n    91\t    pub follow_up_or_amendments: Vec<String>,\n    92\t}\n    93\t\n    94\t#[derive(Debug, Clone, Copy, PartialEq, Eq, Serialize, Deserialize, JsonSchema)]\n    95\t#[serde(rename_all = \"snake_case\")]\n    96\tpub enum ReviewOutcome {\n    97\t    Approved,\n    98\t    ConditionallyApproved,\n    99\t    RequestChanges,\n   100\t    Rejected,\n   101\t}\n   102\t\n   103\timpl ReviewOutcome {\n   104\t    /// Returns `true` only for a clean approval with no conditions.\n   105\t    pub fn is_passing(self) -> bool {\n   106\t        matches!(self, Self::Approved)\n   107\t    }\n   108\t}\n   109\t\n   110\timpl std::fmt::Display for ReviewOutcome {\n   111\t    fn fmt(&self, f: &mut std::fmt::Formatter<'_>) -> std::fmt::Result {\n   112\t        match self {\n   113\t            Self::Approved => f.write_str(\"Approved\"),\n   114\t            Self::ConditionallyApproved => f.write_str(\"Conditionally Approved\"),\n   115\t            Self::RequestChanges => f.write_str(\"Request Changes\"),\n   116\t            Self::Rejected => f.write_str(\"Rejected\"),\n   117\t        }\n   118\t    }\n   119\t}\n   120\t\n   121\t// ── Wrapper enum ────────────────────────────────────────────────────────────\n   122\t\n   123\t/// Typed stage payload, wrapping one of the three contract families.\n   124\t#[derive(Debug, Clone, PartialEq, Eq, Serialize, Deserialize)]\n   125\t#[serde(tag = \"family\", content = \"data\")]\n   126\tpub enum StagePayload {\n   127\t    Planning(PlanningPayload),\n   128\t    Execution(ExecutionPayload),\n   129\t    Validation(ValidationPayload),\n   130\t}\n","exit_code":0,"status":"completed"}}
