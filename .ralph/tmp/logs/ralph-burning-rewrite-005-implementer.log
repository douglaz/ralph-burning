\n            );\n            NormalizedOutput {\n                text: raw.to_owned(),\n                ..Default::default()\n            }\n        }\n    }\n}\n\nfn log_parse_retry_token_metrics(\n    role: &str,\n    phase: &str,\n    loop_number: u32,\n    attempt: u8,\n    backend: &str,\n    session_reused: bool,\n    normalized: &crate::backend::output_normalizer::NormalizedOutput,\n) {\n    info!(\n","exit_code":0,"status":"completed"}}
