{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "additionalProperties": false,
  "description": "Payload for validation/review stages.\n\nRequires an explicit outcome/decision enum plus evidence, findings or gaps, and follow-up or amendment data when the outcome is not cleanly approved.",
  "properties": {
    "evidence": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "findings_or_gaps": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "follow_up_or_amendments": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "outcome": {
      "enum": [
        "approved",
        "conditionally_approved",
        "request_changes",
        "rejected"
      ],
      "type": "string"
    }
  },
  "required": [
    "evidence",
    "findings_or_gaps",
    "follow_up_or_amendments",
    "outcome"
  ],
  "title": "ValidationPayload",
  "type": "object"
}