{"sequence":46,"timestamp":"2026-04-30T10:34:20.229901543Z","event_type":"amendment_queued","details":{"amendment_id":"fr-2-92961389","body":"src/contexts/bead_workflow/pr_watch.rs:265 and src/contexts/bead_workflow/pr_watch.rs:504 merge whatever PR head is current when `gh pr merge` runs, even though CI, bot reaction, and line comments were checked against the earlier `PrStatusSnapshot.head_sha`. A push between the poll and merge can be merged without the watcher having observed CI/bot approval for that head. Thread the observed head SHA into `merge_pr` and use `gh pr merge --match-head-commit <head_sha>` or abort when no head SHA is available.","classification":"fix_current_bead","dedup_key":"d8748f5ec35904004a08f4bc3eaaacced113364c1d71710105d499a8cc2e0265","reviewer_sources":[{"backend_family":"codex","model_id":"gpt-5.5-xhigh","reviewer_id":"reviewer-1"}],"run_id":"run-20260430082849","source":"workflow_stage","source_stage":"final_review"}}
